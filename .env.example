# ── Base de données PostgreSQL ────────────────────────────────
DB_NAME=erp_db
DB_USER=erp_user
DB_PASSWORD=change_me_in_production
DB_HOST=db
DB_PORT=5432

# ── Redis ─────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── MinIO (stockage fichiers PDF / uploads) ───────────────────
MINIO_ROOT_USER=change_me
MINIO_ROOT_PASSWORD=change_me_in_production
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET_PDF=erp-pdf
MINIO_BUCKET_UPLOADS=erp-uploads
MINIO_ACCESS_KEY=change_me
MINIO_SECRET_KEY=change_me_in_production

# ── SCA13 : sauvegarde hors-boite (OFF par defaut) ─────────────
# Cible S3-compatible EXTERNE pour la copie hors-boite des dumps Postgres
# (core/backup.py, dump_database). OFF sans les 4 variables ci-dessous
# TOUTES posees : aucun appel reseau supplementaire, comportement identique
# a avant SCA13. Choix du fournisseur (Hetzner Storage Box, Backblaze B2,
# AWS S3, autre — tout endpoint compatible S3 fonctionne) = decision
# fondateur. Voir docs/scale-runway.md section SCA13 pour l'activation.
# BACKUP_OFFSITE_ENDPOINT=https://<endpoint-s3-compatible>
# BACKUP_OFFSITE_BUCKET=<nom-bucket>
# BACKUP_OFFSITE_ACCESS_KEY=<cle>
# BACKUP_OFFSITE_SECRET_KEY=<secret>
# BACKUP_OFFSITE_RETAIN_LAST=7

# ── Django ────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=erp_agentique.settings.dev
DJANGO_SECRET_KEY=change_me_generate_with_python_secrets
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# YHARD1 — chiffrement au repos des champs sensibles (TOTP, RIB, N° CNSS/AMO/CIMR,
# CIN, secrets webhook, clé privée VAPID). VIDE = aucun chiffrement (comportement
# identique à l'existant). Renseigner une (ou plusieurs, séparées par des virgules
# pour la rotation) clé Fernet : python -c "from cryptography.fernet import Fernet;
# print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=

# ── SCA16 : dimensionnement gunicorn/celery (optionnel) ────────
# Surcharge les workers/threads gunicorn et la concurrency Celery sans
# éditer docker-compose*.yml. Défauts = comportement ACTUEL (commentés
# ci-dessous) : gunicorn_workers=3/threads=4 en prod (4/pas de --threads en
# dev), CELERY_CONCURRENCY vide = défaut natif Celery (cpu_count()).
# Formule de dimensionnement : docs/scale-runway.md section SCA16.
# GUNICORN_WORKERS=3
# GUNICORN_THREADS=4
# CELERY_CONCURRENCY=
# CELERY_INTERACTIVE_CONCURRENCY=2

# ── FastAPI ───────────────────────────────────────────────────
FASTAPI_SECRET_KEY=change_me_generate_with_python_secrets

# ── API IA / OCR (ZhipuAI GLM) ───────────────────────────────
# Obtenir la clé sur : https://open.bigmodel.cn/
ZHIPU_API_KEY=your_zhipu_api_key_here

# ── Agent SQL (LangChain + Groq) ─────────────────────────────
# Obtenir la clé sur : https://console.groq.com/
GROQ_API_KEY=your_groq_api_key
SQL_AGENT_PROVIDER=groq
SQL_AGENT_MODEL=llama-3.3-70b-versatile

# ── Autres clés API (optionnel) ───────────────────────────────
OPENAI_API_KEY=your_openai_api_key
CLAUDE_API_KEY=your_claude_api_key

# ── ENG17 : fabrique créative (OFF par défaut, key-gated) ──────
# Chaque adaptateur de apps/adsengine/creative_factory.py est ACTIVÉ uniquement
# si sa clé est posée ; sans clé il no-ope proprement (aucun appel réseau, aucun
# asset créé). Aucune dépendance pip nouvelle (httpx). Décommentez + renseignez
# pour activer un fournisseur.
# ZAPCAP_API_KEY=          # sous-titrage de reels
# FAL_API_KEY=             # B-roll / statiques génératifs
# TEMPLATED_API_KEY=       # stamps de marque
# ELEVENLABS_API_KEY=      # voix FR / darija
# JSON2VIDEO_API_KEY=      # assemblage d'explainers

# ── ADSENG-ODOO : connecteur Odoo LECTURE SEULE (OFF par défaut) ──
# Le coût-par-signature du moteur pub se calcule aussi contre les VRAIES
# signatures du fondateur (crm.lead gagnés + sale.order confirmés) qui vivent
# dans Odoo Online. Connecteur JSON-RPC STRICTEMENT lecture-seule (jamais
# create/write/unlink, jamais SQL — règle #1). Sans ces 4 variables, tout
# no-ope (aucun appel réseau). Diagnostic : manage.py odoo_pull.
# ODOO_URL=https://taqinor-solutions.odoo.com   # URL de l'instance Odoo Online
# ODOO_DB=taqinor-solutions                      # nom de la base Odoo
# ODOO_USERNAME=                                 # login utilisateur Odoo
# ODOO_API_KEY=                                  # clé d'API Odoo (= mot de passe RPC)

# ── Email SendGrid (formulaire contact landing) ───────────────
# Obtenir la clé sur : https://app.sendgrid.com/settings/api_keys
# Vérifier l'expéditeur sur : https://app.sendgrid.com/settings/sender_auth
SENDGRID_API_KEY=your_sendgrid_api_key
EMAIL_BACKEND=anymail.backends.sendgrid.EmailBackend
DEFAULT_FROM_EMAIL=contact@votre-domaine.com
CONTACT_EMAIL=contact@votre-domaine.com

# ── Contact form (PARKED by default) ──────────────────────────
# Public landing-page contact form is OFF by default: the endpoint returns 404
# and no email is sent. To re-enable, set BOTH flags to 1 and rebuild the
# frontend (docker compose up -d --build). See CLAUDE.md.
CONTACT_FORM_ENABLED=0
VITE_CONTACT_FORM_ENABLED=0

# ── Frontend ──────────────────────────────────────────────────
VITE_API_URL=http://localhost/api/django
VITE_IA_API_URL=http://localhost/api/fastapi
# SCA24 — marque produit neutre affichée sur l'écran de login (pré-auth, avant
# de connaître la société de l'utilisateur donc avant tout TenantTheme). Vide
# = repli sobre "ERP". Le thème par société (logo/couleur) s'applique APRÈS
# connexion, dans le shell, via l'endpoint core TenantTheme existant.
VITE_PRODUCT_NAME=

# Recepteur leads site web (apps/crm/webhooks.py) ? secret statique obligatoire
WEBSITE_LEAD_WEBHOOK_SECRET=
# Tenant cible des leads web (vide = premiere Company)
WEBSITE_LEADS_COMPANY_ID=
