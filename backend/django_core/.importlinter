# import-linter contracts (M3) — architectural import rules enforced in CI by
# the `lint-imports` step. The goal is to PIN the decoupling already achieved
# (M1: string FKs between core domains; M5: a pure `core` foundation app) so a
# future careless import cannot silently reintroduce a load-time cycle.
#
# These contracts are intentionally scoped to the invariants that genuinely
# hold today. The five business-core apps (crm, ventes, stock, installations,
# sav) still call each other at the service/selector layer, so a full
# "no cycles between the core apps" / strict three-tier `layers` contract does
# NOT pass yet — that deeper decoupling is tracked by the remaining M-series
# tasks. What is locked here is real and regression-prone:
#
#   1. core domain *models* stay mutually decoupled (the M1 win — a model-level
#      cross-import is exactly what collided in production), and
#   2. the `core` foundation app never imports a domain-core or satellite app
#      (it must remain a base layer everything can depend DOWN on), and
#   3. the business-core `ventes` app never imports the `audit` satellite (the
#      M4 win — that last upward back-edge was replaced by the core event bus:
#      ventes emits `document_pdf_generated` and audit subscribes).

[importlinter]
root_packages =
    apps
    authentication
    core

[importlinter:contract:core-domain-models-decoupled]
name = Core domain models stay decoupled (string FKs only between domains — locks M1)
type = independence
modules =
    apps.crm.models
    apps.ventes.models
    apps.stock.models
    apps.sav.models
    apps.installations.models
# A domain model may call its OWN app's selector/service layer LAZILY
# (function-local import inside a model method — e.g. `NoteDebit.tva_par_taux`
# → `ventes.selectors.tva_buckets`, `Ticket` → `sav.selectors.droits_restants`,
# `Lead.save` → `crm.services.normalize_phone/email` [QW10 dedup columns]).
# These run at call time, never at model load, so they cannot reintroduce the
# load-time model→model cycle this contract exists to prevent. grimp still sees
# the static edge, and because the selector/service layer legitimately crosses
# domains (documented above), it makes the 5 model modules appear transitively
# coupled. Prune ONLY these intra-app model→own-selector/service entry edges: a
# DIRECT cross-domain `X.models -> Y.models` import is a separate edge and stays
# caught.
ignore_imports =
    apps.ventes.models -> apps.ventes.selectors
    apps.sav.models -> apps.sav.selectors
    apps.crm.models -> apps.crm.services
# ODX17 — `apps.ventes.models` ends with a transitional RE-EXPORT shim
# (`from apps.facturation.models import Facture, ...`, kept until ODX22 so all
# existing callers of `apps.ventes.models.Facture` keep working). That single
# entry edge then reaches `apps.facturation.models -> apps.ventes.selectors`
# (Facture/Avoir's OWN lazy TVA selector call, pruned under the
# `facturation-models-decoupled` contract below) which transitively touches
# stock/crm/sav/installations via ventes' selector/service layer — the SAME
# legitimate cross-domain reads the two ignore rules above already tolerate,
# just reached one hop further through the shim. Prune only this shim edge; a
# DIRECT `apps.ventes.models -> apps.{stock,crm,sav,installations}.models`
# import would still be caught.
    apps.ventes.models -> apps.facturation.models

[importlinter:contract:installations-split-models-decoupled]
name = Split installations model modules never import a sibling domain's models (locks M1 after the M7 split)
type = forbidden
source_modules =
    apps.installations.models_chantier
    apps.installations.models_field
    apps.installations.models_installation
    apps.installations.models_intervention
forbidden_modules =
    apps.crm.models
    apps.ventes.models
    apps.stock.models
    apps.sav.models

[importlinter:contract:ventes-does-not-import-audit]
name = Business-core ventes never imports the audit satellite (locks the M4 back-edge removal — reactions go through core.events)
type = forbidden
source_modules =
    apps.ventes
forbidden_modules =
    apps.audit
# YEVNT5 — the notifications satellite writes a best-effort audit line per
# `notify()` channel (lazy `from apps.audit import recorder` inside
# `_audit_notify`). That is notifications' OWN cross-cutting logging, not ventes
# coupling to audit: the M4 intent (ventes must not DIRECTLY reach audit) holds.
# Ignore only this one satellite→satellite edge so the transitive
# ventes→notifications→audit path does not trip the forbidden contract.
ignore_imports =
    apps.notifications.services -> apps.audit.recorder
# XPUR11/XPUR13 — stock's services write their OWN best-effort audit trail for
# override actions (duplicate-invoice / off-contract-price overrides). ventes
# imports stock.services only for stock movements & QR; stock auditing itself is
# stock's cross-cutting concern, not ventes reaching audit. Ignore this
# stock→audit edge so the transitive ventes→stock.services→audit path is allowed.
    apps.stock.services -> apps.audit.recorder
    apps.stock.services -> apps.audit.models
# ARC34 — le moteur d'automation écrit sa PROPRE trace d'audit (imports
# fonction-locaux `audit.recorder`/`audit.models` dans `engine`, préexistants) ;
# depuis qu'ARC34 abonne sav/contrats à `automation.engine` via leurs services,
# le chemin transitif ventes→…→automation→audit apparaît. C'est le logging
# transverse d'automation, PAS ventes atteignant audit directement (même motif
# que les exceptions notifications/stock ci-dessus). Ignore ces arêtes
# automation→audit.
    apps.automation.engine -> apps.audit.recorder
    apps.automation.engine -> apps.audit.models

[importlinter:contract:ged-models-decoupled]
name = GED models never import a business-core domain's models (string FKs only — GED38)
type = forbidden
source_modules =
    apps.ged.models
forbidden_modules =
    apps.crm.models
    apps.ventes.models
    apps.stock.models
    apps.sav.models
    apps.installations.models

[importlinter:contract:marketing-models-decoupled]
name = Marketing models never import a business-core domain's models (string FKs only — ODX9/ODX10)
type = forbidden
source_modules =
    apps.marketing.models
forbidden_modules =
    apps.crm.models
    apps.ventes.models
    apps.stock.models
    apps.sav.models
    apps.installations.models
    apps.compta.models

[importlinter:contract:facturation-models-decoupled]
name = Facturation models never import a business-core domain's models (string FKs only — ODX17)
type = forbidden
source_modules =
    apps.facturation.models
forbidden_modules =
    apps.crm.models
    apps.ventes.models
    apps.stock.models
    apps.sav.models
    apps.installations.models
    apps.compta.models
# ODX17 — Facture/Avoir (déplacées ici depuis ventes) délèguent LAZILY leur
# calcul TVA au selector partagé `ventes.selectors.tva_buckets/_canonical_totaux`
# (function-local import dans les properties `total_ht`/`tva_par_taux`/
# `total_ttc`, exactement le patron déjà toléré pour
# `apps.ventes.models -> apps.ventes.selectors` ci-dessus). Ignore uniquement
# cette arête d'entrée ; un import DIRECT `apps.facturation.models ->
# apps.ventes.models` resterait détecté.
ignore_imports =
    apps.facturation.models -> apps.ventes.selectors

[importlinter:contract:achats-models-decoupled]
name = Achats models never import a business-core domain's models (string FKs only — ODX19)
type = forbidden
source_modules =
    apps.achats.models
forbidden_modules =
    apps.crm.models
    apps.ventes.models
    apps.stock.models
    apps.sav.models
    apps.installations.models
    apps.compta.models

# ODX22 (PARTIAL) — ajout des contrats d'indépendance de MODÈLES pour les apps
# sorties de compta (ao, portail) + confirmés pour facturation/achats/marketing
# ci-dessus. Le contrat « les apps satellites n'importent pas les views d'une
# autre app » n'est PAS ajouté : les shims de ré-export TRANSITOIRES (ODX18/20
# `apps.facturation.views -> apps.ventes.views`, `apps.achats.views ->
# apps.stock.views`, et ODX11/12 `apps.ao.views -> apps.compta.views`,
# `apps.portail.views -> apps.compta.views`) importent volontairement les views
# de l'app source tant que le corps n'y est pas relogé — un tel contrat serait
# rouge aujourd'hui. À ajouter quand ces corps auront migré. Aucun shim de
# ré-export (compta/ventes/stock `.models`) n'a zéro référent (serializers/views/
# services/admin les importent encore) : tous conservés, aucun retiré.
[importlinter:contract:ao-models-decoupled]
name = AO models never import a business-core domain's models (string FKs only — ODX11/ODX22)
type = forbidden
source_modules =
    apps.ao.models
forbidden_modules =
    apps.crm.models
    apps.ventes.models
    apps.stock.models
    apps.sav.models
    apps.installations.models
    apps.compta.models

[importlinter:contract:portail-models-decoupled]
name = Portail models never import a business-core domain's models (string FKs only — ODX12/ODX22)
type = forbidden
source_modules =
    apps.portail.models
forbidden_modules =
    apps.crm.models
    apps.ventes.models
    apps.stock.models
    apps.sav.models
    apps.installations.models
    apps.compta.models

[importlinter:contract:tiers-is-a-base-layer]
name = The tiers foundation app imports downward only (no domain-core or satellite app — locks ARC17)
type = forbidden
source_modules =
    apps.tiers
forbidden_modules =
    apps.crm
    apps.ventes
    apps.stock
    apps.installations
    apps.sav
    apps.compta
    apps.reporting
    apps.automation
    apps.monitoring
    apps.notifications
    apps.publicapi
    apps.audit
    apps.documents
    apps.dataimport
    apps.contact
# ARC18/19/21 — les modules de TEST des ponts Tiers importent volontairement les
# vrais modèles historiques (crm.Client/Lead, stock.Fournisseur, compta.Partenaire,
# rh.DossierEmploye) et le service crm pour PROUVER que le miroir one-way et la
# bascule flag-gatée fonctionnent de bout en bout. Ce sont des tests d'intégration
# cross-couche, PAS un couplage de production : le code de PRODUCTION de `tiers`
# reste strictement base-layer (aucun import statique de domaine — vérifié). On
# ignore uniquement ces arêtes test→domaine (même motif que les exceptions
# core.tests.* ci-dessous).
ignore_imports =
    apps.tiers.tests.test_arc18_bridge -> apps.crm.models
    apps.tiers.tests.test_arc18_bridge -> apps.stock.models
    apps.tiers.tests.test_arc19_bridge -> apps.compta.models
    apps.tiers.tests.test_arc19_bridge -> apps.rh.models
    apps.tiers.tests.test_arc21_source_ecriture -> apps.crm.models
    apps.tiers.tests.test_arc21_source_ecriture -> apps.crm.services

# ARC6 — `core.numbering` (fabrique de références anti-collision, ex
# `apps.ventes.utils.references`) est une primitive de FONDATION relogée ici :
# elle reçoit en paramètre le modèle/préfixe/société dont elle a besoin, n'importe
# donc AUCUNE app métier et respecte nativement le contrat base-layer ci-dessous.
# `apps.ventes.utils.references` n'est plus qu'un shim de ré-export bit-identique.
[importlinter:contract:core-foundation-is-a-base-layer]
name = The core foundation app imports downward only (no domain-core or satellite app)
type = forbidden
source_modules =
    core
forbidden_modules =
    apps.crm
    apps.ventes
    apps.stock
    apps.installations
    apps.sav
    apps.reporting
    apps.automation
    apps.monitoring
    apps.notifications
    apps.publicapi
    apps.audit
    apps.documents
    apps.dataimport
    apps.contact
# YRBAC6/YRBAC9 — two core SECURITY-RATCHET *test* modules deliberately import
# real domain serializers/models to prove the core masking mixins actually strip
# sensitive fields (prix_achat/marge) and that no public endpoint leaks. These
# are cross-layer integration tests, not production `core` coupling: the base-
# layer intent (core PRODUCTION code imports downward only) holds. Ignore only
# these specific test→domain edges.
ignore_imports =
    core.tests.test_sensitive_field_leak -> apps.stock.serializers
    core.tests.test_sensitive_field_leak -> apps.stock.models
    core.tests.test_public_endpoint_hardening -> apps.ventes.models
    core.tests.test_public_endpoint_hardening -> apps.crm.models
    core.tests.test_registre_traitements -> apps.crm.models
# YHARD4/YHARD10 — two more core cross-layer INTEGRATION tests: YHARD4 asserts
# the i18n content-translation layer round-trips a real domain serializer, and
# YHARD10's export-anonymise UAT-clone command is proven against a real
# crm.Client. Same rationale as the YRBAC6/9 exceptions above — test-only
# cross-layer edges, not production `core` coupling (core prod code imports
# downward only). Ignore just these specific test→domain edges.
    core.tests.test_yhard4_i18n_content -> apps.stock.models
    core.tests.test_yhard4_i18n_content -> apps.stock.serializers
    core.tests.test_yhard10_export_anonymise -> apps.crm.models
# ARC1/2/6 + SCA30-33 — les tests des primitives noyau (TenantModel, viewset
# scopé, numérotation, kit DocumentMetier) exercent la primitive contre de VRAIS
# modèles/viewsets domaine ; même motif que les exceptions ci-dessus (arêtes
# test→domaine, jamais du couplage `core` de production — le code prod de core
# n'importe plus records.views depuis le fold repair, cf. document_viewset qui
# INJECTE désormais le chatter mixin).
    core.tests.test_tenant_model -> apps.notifications.models
    core.tests.test_numbering -> apps.crm.models
    core.tests.test_numbering -> apps.ventes.models
    core.tests.test_numbering -> apps.ventes.utils.references
    core.tests.test_company_scoped_viewset -> apps.crm.views
    core.tests.test_company_scoped_viewset -> apps.sav.views
    core.tests.test_company_scoped_viewset -> apps.installations.views.transporteur
    core.tests.test_documents_viewset -> apps.records.views
    core.tests.test_documents_status -> apps.installations.models_demande_achat
    core.tests.test_documents_status -> apps.installations.models_ordre_soustraitance
