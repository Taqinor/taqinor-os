# W321 — Cache immuable pour les assets statiques versionnés/rarement modifiés.
# Servis directement par la couche assets (run_worker_first les exclut, voir
# astro.config.mjs) : ce fichier est copié tel quel dans dist/ par Astro et lu
# par Cloudflare (Pages/_headers, honoré aussi par Workers Static Assets).
# Ne touche PAS les documents HTML (revalidation forcée par le Worker, W33).

/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/photos/*
  Cache-Control: public, max-age=31536000, immutable

/videos/*
  Cache-Control: public, max-age=31536000, immutable

/fiches/*
  Cache-Control: public, max-age=31536000, immutable

/og/*
  Cache-Control: public, max-age=31536000, immutable
