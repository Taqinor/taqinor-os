---
/**
 * Pied de page partagé — UN seul pied identique sur TOUT le site (W29).
 * La liste « Services » (texte non cliquable) est remplacée par une colonne
 * « Solutions » de VRAIS liens. Colonnes : Solutions · Ressources ·
 * « Installation solaire par ville » · Contact · ligne légale. On ne lie que
 * des pages qui existent réellement.
 *
 * W152 : bloc marque renforcé (logo + tagline), boutons CTA téléphone/WhatsApp,
 * liseré doré en haut, hiérarchie de colonnes améliorée.
 *
 * W246 — bande de clôture chaude, AU-DESSUS de la grille de liens (grille
 * intacte) : glyphe zellige + ligne de marque, lien de parcours devis
 * (/devis/mon-toit, localisé) bien visible, et une reprise WhatsApp unique à
 * faible friction — le footer ne finit plus froid sur une ligne légale.
 * Reduced-motion-safe (glyphe SVG statique, aucune propriété de reflow
 * animée) et CLS zéro (aucune dimension asynchrone).
 */
import Logo from './Logo.astro';
import { NAP, WHATSAPP_LEADS } from '../lib/nap';
import { whatsappLink } from '../lib/whatsapp';
import { CITIES } from '../lib/realisations';
import { getLocaleFromPath, stripLocale, useTranslations } from '../i18n/utils';
import { localizeNavHref, quoteJourneyHref } from '../i18n/pages';

// Locale courante déduite de l'URL ; libellés via dictionnaire (repli FR).
// Le rendu FR reste byte-identique : t() rend les libellés FR existants et
// localizeNavHref('/x','fr') renvoie '/x' inchangé.
const locale = getLocaleFromPath(Astro.url.pathname);
const t = useTranslations(locale);
const L = (href: string) => localizeNavHref(href, locale);

const wa = whatsappLink(WHATSAPP_LEADS, 'Bonjour, je souhaite des informations sur une installation solaire.');
// W246 — lien de parcours devis localisé (même point de bascule unique que
// l'en-tête / CtaBand / StickyCta : quoteJourneyHref, jamais un href codé en dur).
const journeyHref = quoteJourneyHref(locale);

// Colonne Solutions — VRAIS liens vers chaque service (W29).
const solutions = [
  { href: '/résidentiel', label: t('nav.residential') },
  { href: '/professionnel', label: t('nav.professional') },
  { href: '/pompage-solaire', label: t('nav.pumping') },
  { href: '/batteries-stockage', label: t('nav.batteries') },
  { href: '/maintenance-monitoring', label: t('nav.maintenance') },
  { href: '/regularization-article-33', label: t('nav.regularization') },
];

// Colonne Ressources (W29) + équipement & garanties (pages existantes liées
// ailleurs sur le site, conservées ici pour le maillage).
const ressources = [
  { href: '/realisations', label: t('nav.realisations') },
  { href: '/guides', label: t('nav.guides') },
  { href: '/faq', label: t('nav.faq') },
  { href: '/loi-82-21', label: t('nav.law') },
  { href: '/pourquoi-taqinor', label: t('nav.why') },
  { href: '/financement', label: t('nav.financing') },
  { href: '/marocains-du-monde', label: t('nav.mre') },
  { href: '/à-propos', label: t('nav.about') },
  { href: '/équipement', label: t('nav.equipment') },
  { href: '/produits', label: 'Fiches techniques' },
  { href: '/garanties', label: t('footer.guarantees') },
];

const linkClass = 'transition-colors hover:text-white';
---

<footer class="footer-root bg-nuit text-lune">
  {/* Liseré brass gradient en haut — 2 px, pas d'animation, CLS zéro */}
  <div class="footer-seam" aria-hidden="true"></div>

  {/* ── W246/W369 : bande de clôture chaude — wordmark surdimensionné (W369)
      + glyphe zellige agrandi (W369) + ligne de marque + CTA parcours devis
      + reprise WhatsApp. Air généreux au-dessus de la grille de liens
      (inchangée) : c'est le dernier cadre art-directé du site, pas un
      sitemap. Le footer ne finit plus froid sur une ligne légale. ── */}
  <div class="footer-frame border-b border-white/10 px-4 pb-12 pt-14 text-center sm:pt-20">
    <div class="mx-auto flex max-w-3xl flex-col items-center gap-6">
      <div class="footer-frame-word" aria-hidden="true">
        <Logo size={44} theme="dark" />
      </div>

      <span class="footer-frame-mark" aria-hidden="true">
        <svg width="40" height="40" viewBox="0 0 34 34" fill="none" class="footer-frame-glyph" aria-hidden="true">
          <rect x="7.5" y="7.5" width="19" height="19" stroke="currentColor" stroke-width="1.25" />
          <rect x="7.5" y="7.5" width="19" height="19" stroke="currentColor" stroke-width="1.25" transform="rotate(45 17 17)" />
          <circle cx="17" cy="17" r="2.1" fill="currentColor" />
        </svg>
      </span>

      <p class="display text-balance text-lg text-white sm:text-xl">{t('footer.closingLine')}</p>

      <a href={journeyHref} class="glow footer-journey-cta inline-flex items-center gap-2 bg-brass-400 px-6 py-3 text-sm font-bold text-azur-950 transition-colors hover:bg-brass-300">
        {t('footer.journeyCta')}
      </a>

      <a href={wa} rel="noopener noreferrer" class="footer-wa-recapture text-sm text-lune-soft transition-colors hover:text-white">
        {t('footer.whatsappRecapture')}
      </a>
    </div>
  </div>

  {/* ── Bloc principal ── */}
  <div class="mx-auto grid max-w-6xl gap-10 px-4 py-14 md:grid-cols-4">

    {/* Colonne 1 — Bloc marque */}
    <div class="flex flex-col gap-5">
      <div>
        <Logo size={22} theme="dark" />
        <p class="mt-3 text-sm leading-relaxed text-lune-soft">
          {t('footer.tagline')}
        </p>
      </div>

      {/* CTA téléphone & WhatsApp */}
      <div class="flex flex-col gap-2.5">
        <a
          href={`tel:${NAP.phone}`}
          class="footer-cta-btn footer-cta-phone inline-flex items-center gap-2 px-3.5 py-2.5 text-sm font-semibold"
          dir="ltr"
        >
          {/* Icône téléphone */}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
          {NAP.phoneDisplayIntl}
        </a>
        <a
          href={wa}
          rel="noopener noreferrer"
          class="footer-cta-btn footer-cta-wa inline-flex items-center gap-2 px-3.5 py-2.5 text-sm font-semibold"
        >
          {/* Icône WhatsApp (SVG inline, aucune dépendance externe) */}
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
            <path d="M12 0C5.373 0 0 5.373 0 12c0 2.127.558 4.121 1.532 5.848L0 24l6.334-1.51A11.953 11.953 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 0 1-5.003-1.368l-.358-.214-3.76.897.933-3.659-.233-.374A9.796 9.796 0 0 1 2.182 12C2.182 6.578 6.578 2.182 12 2.182c5.423 0 9.818 4.396 9.818 9.818 0 5.423-4.395 9.818-9.818 9.818z"/>
          </svg>
          {t('common.whatsapp')}
        </a>
      </div>
    </div>

    {/* Colonne 2 — Solutions */}
    <div>
      <h2 class="tech-label mb-4 text-brass-300">{t('nav.solutions')}</h2>
      <ul class="space-y-2 text-sm">
        {solutions.map((s) => <li><a href={L(s.href)} class={linkClass}>{s.label}</a></li>)}
        <li><a href={L('/nos-solutions')} class={linkClass}>{t('nav.allSolutions')}</a></li>
      </ul>
    </div>

    {/* Colonne 3 — Ressources */}
    <div>
      <h2 class="tech-label mb-4 text-brass-300">{t('nav.resources')}</h2>
      <ul class="space-y-2 text-sm">
        {ressources.map((r) => <li><a href={L(r.href)} class={linkClass}>{r.label}</a></li>)}
        <li><a href={L('/contact')} class={linkClass}>{t('footer.contactLink')}</a></li>
      </ul>
    </div>

    {/* Colonne 4 — Contact (coordonnées textuelles) */}
    <div>
      <h2 class="tech-label mb-4 text-brass-300">{t('footer.contact')}</h2>
      <ul class="space-y-2 text-sm">
        <li><a href={`tel:${NAP.phone}`} class={linkClass} dir="ltr">{NAP.phoneDisplayIntl}</a></li>
        <li><a href={`mailto:${NAP.email}`} class={linkClass} dir="ltr">{NAP.email}</a></li>
        <li><a href={wa} rel="noopener" class={linkClass}>{t('common.whatsapp')}</a></li>
        <li class="text-lune-soft">{t('footer.serviceArea')} : {NAP.serviceArea.slice(0, -1).join(', ')} — {t('footer.allMorocco')}</li>
      </ul>
    </div>
  </div>

  {/* ── Maillage par ville ── */}
  <div class="border-t border-white/10 px-4 py-6">
    <div class="mx-auto max-w-6xl">
      <h2 class="tech-label mb-3 text-brass-300">{t('footer.byCity')}</h2>
      <ul class="flex flex-wrap gap-x-5 gap-y-2 text-sm text-lune-soft">
        {CITIES.map((c) => (
          <li><a href={`/installation-solaire-${c.slug}`} class={linkClass}>{t('footer.byCityItem')} {c.intro}</a></li>
        ))}
      </ul>
    </div>
  </div>

  {/* ── Ligne légale ── */}
  <div class="space-y-1.5 border-t border-white/10 px-4 py-5 text-center text-xs text-lune-faint">
    <p>{t('footer.legalLine')}</p>
    <p>
      © 2026 {NAP.name}. {t('footer.rights')} ·
      <a href={L('/mentions-legales')} class="underline underline-offset-2 transition-colors hover:text-white">{t('footer.legal')}</a> ·
      <a href={L('/politique-de-confidentialite')} class="underline underline-offset-2 transition-colors hover:text-white">{t('footer.privacy')}</a>
    </p>
  </div>
</footer>

<style>
  /* Liseré brass gradient en haut du footer — 2 px, aucune animation, CLS zéro. */
  .footer-seam {
    height: 2px;
    background: linear-gradient(
      to right,
      transparent 0%,
      var(--color-brass-600) 15%,
      var(--color-brass-400) 35%,
      var(--color-brass-300) 50%,
      var(--color-brass-400) 65%,
      var(--color-brass-600) 85%,
      transparent 100%
    );
    opacity: 0.7;
  }

  /* Boutons CTA téléphone et WhatsApp dans le bloc marque */
  .footer-cta-btn {
    border-radius: 0;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  /* Bouton téléphone — contour brass */
  .footer-cta-phone {
    color: var(--color-lune);
    border: 1px solid rgb(243 204 102 / 0.35);
    background: rgb(243 204 102 / 0.06);
  }
  .footer-cta-phone:hover {
    background: rgb(243 204 102 / 0.12);
    color: var(--color-brass-300);
    border-color: rgb(243 204 102 / 0.55);
  }

  /* Bouton WhatsApp — fond brass plein (même CTA doré que dans l'en-tête) */
  .footer-cta-wa {
    background: var(--color-brass-400);
    color: var(--color-azur-950);
  }
  .footer-cta-wa:hover {
    background: var(--color-brass-300);
  }

  /* W246 — cadre de clôture : glyphe zellige statique (aucune propriété de
     reflow animée, aucune dimension asynchrone → CLS zéro). */
  .footer-frame-mark {
    display: inline-flex;
    color: var(--color-brass-400);
  }
  .footer-frame-glyph {
    color: var(--color-brass-300);
    filter: drop-shadow(0 0 12px rgb(232 181 74 / 0.3));
  }

  /* W369 — wordmark surdimensionné : le composant Logo porte déjà sa taille
     en prop (44px ici, vs 22px dans la colonne marque) ; ce wrapper ne fait
     qu'assurer une hauteur de ligne stable (aucun reflow, CLS zéro). */
  .footer-frame-word {
    line-height: 1;
  }

  .footer-journey-cta {
    border-radius: 0;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .footer-wa-recapture {
    transition: color 0.2s ease;
  }

  /* Réduire les animations si prefers-reduced-motion : les transitions CSS
     sont déjà déclarées inline sur les hover ci-dessus, mais on les désactive
     pour les utilisateurs qui préfèrent moins de mouvement. */
  @media (prefers-reduced-motion: reduce) {
    .footer-cta-btn,
    .footer-seam,
    .footer-journey-cta,
    .footer-wa-recapture {
      transition: none;
    }
  }
</style>
