---
/**
 * Pied de page partagé — UN seul pied identique sur TOUT le site (W29).
 * La liste « Services » (texte non cliquable) est remplacée par une colonne
 * « Solutions » de VRAIS liens. Colonnes : Solutions · Ressources ·
 * « Installation solaire par ville » · Contact · ligne légale. On ne lie que
 * des pages qui existent réellement.
 */
import Logo from './Logo.astro';
import { NAP, WHATSAPP_LEADS } from '../lib/nap';
import { whatsappLink } from '../lib/whatsapp';
import { CITIES } from '../lib/realisations';

const wa = whatsappLink(WHATSAPP_LEADS, 'Bonjour, je souhaite des informations sur une installation solaire.');

// Colonne Solutions — VRAIS liens vers chaque service (W29).
const solutions = [
  { href: '/résidentiel', label: 'Résidentiel' },
  { href: '/professionnel', label: 'Professionnel' },
  { href: '/pompage-solaire', label: 'Pompage solaire' },
  { href: '/batteries-stockage', label: 'Batteries & stockage' },
  { href: '/maintenance-monitoring', label: 'Maintenance & monitoring' },
  { href: '/regularization-article-33', label: 'Régularisation Loi 82-21' },
];

// Colonne Ressources (W29) + équipement & garanties (pages existantes liées
// ailleurs sur le site, conservées ici pour le maillage).
const ressources = [
  { href: '/realisations', label: 'Réalisations' },
  { href: '/guides', label: 'Guides' },
  { href: '/faq', label: 'FAQ' },
  { href: '/loi-82-21', label: 'Loi 82-21 expliquée' },
  { href: '/pourquoi-taqinor', label: 'Pourquoi Taqinor' },
  { href: '/financement', label: 'Financement & rentabilité' },
  { href: '/marocains-du-monde', label: 'Marocains du monde' },
  { href: '/à-propos', label: 'À propos' },
  { href: '/équipement', label: 'Équipement' },
  { href: '/garanties', label: 'Nos garanties' },
];

const linkClass = 'transition-colors hover:text-white';
---

<footer class="border-t border-white/10 bg-nuit text-lune">
  <div class="mx-auto grid max-w-6xl gap-10 px-4 py-14 md:grid-cols-4">
    <div>
      <Logo size={22} theme="dark" />
      <p class="mt-4 text-sm leading-relaxed text-lune-soft">
        Installations solaires dimensionnées par l'ingénierie, conformes à la loi 82-21.
      </p>
    </div>
    <div>
      <h2 class="tech-label mb-4 text-brass-300">Solutions</h2>
      <ul class="space-y-2 text-sm">
        {solutions.map((s) => <li><a href={s.href} class={linkClass}>{s.label}</a></li>)}
        <li><a href="/nos-solutions" class={linkClass}>Toutes nos solutions</a></li>
      </ul>
    </div>
    <div>
      <h2 class="tech-label mb-4 text-brass-300">Ressources</h2>
      <ul class="space-y-2 text-sm">
        {ressources.map((r) => <li><a href={r.href} class={linkClass}>{r.label}</a></li>)}
        <li><a href="/contact" class={linkClass}>Contact</a></li>
      </ul>
    </div>
    <div>
      <h2 class="tech-label mb-4 text-brass-300">Contact</h2>
      <ul class="space-y-2 text-sm">
        <li><a href={`tel:${NAP.phone}`} class={linkClass}>{NAP.phoneDisplayIntl}</a></li>
        <li><a href={`mailto:${NAP.email}`} class={linkClass}>{NAP.email}</a></li>
        <li><a href={wa} rel="noopener" class={linkClass}>WhatsApp</a></li>
        <li class="text-lune-soft">Zone d'intervention : {NAP.serviceArea.slice(0, -1).join(', ')} — tout le Maroc</li>
      </ul>
    </div>
  </div>
  <div class="border-t border-white/10 px-4 py-6">
    <div class="mx-auto max-w-6xl">
      <h2 class="tech-label mb-3 text-brass-300">Installation solaire par ville</h2>
      <ul class="flex flex-wrap gap-x-5 gap-y-2 text-sm text-lune-soft">
        {CITIES.map((c) => (
          <li><a href={`/installation-solaire-${c.slug}`} class={linkClass}>Installation solaire {c.intro}</a></li>
        ))}
      </ul>
    </div>
  </div>
  <div class="space-y-1.5 border-t border-white/10 px-4 py-5 text-center text-xs text-lune-faint">
    <p>TAQINOR Solutions SARLAU — RC 691213 (Casablanca) — ICE 003799642000067</p>
    <p>
      © 2026 {NAP.name}. Tous droits réservés ·
      <a href="/mentions-legales" class="underline underline-offset-2 transition-colors hover:text-white">Mentions légales</a> ·
      <a href="/politique-de-confidentialite" class="underline underline-offset-2 transition-colors hover:text-white">Confidentialité</a>
    </p>
  </div>
</footer>
