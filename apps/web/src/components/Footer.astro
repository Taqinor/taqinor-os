---
import Logo from './Logo.astro';
import { NAP } from '../lib/nap';
import { whatsappLink } from '../lib/whatsapp';

const wa = whatsappLink(NAP.whatsapp, 'Bonjour, je souhaite des informations sur une installation solaire.');
---

<footer class="bg-navy-950 text-navy-100">
  <div class="mx-auto grid max-w-6xl gap-10 px-4 py-12 md:grid-cols-4">
    <div>
      <Logo size={22} theme="dark" />
      <p class="mt-3 text-sm leading-relaxed text-navy-100/80">
        Installations solaires dimensionnées par l'ingénierie, conformes à la loi 82-21.
      </p>
    </div>
    <div>
      <h2 class="mb-3 text-sm font-bold uppercase tracking-wide text-white">Services</h2>
      <ul class="space-y-2 text-sm">
        {NAP.services.map((s) => <li>{s}</li>)}
      </ul>
    </div>
    <div>
      <h2 class="mb-3 text-sm font-bold uppercase tracking-wide text-white">Pages</h2>
      <ul class="space-y-2 text-sm">
        <li><a href="/résidentiel" class="hover:underline">Résidentiel</a></li>
        <li><a href="/professionnel" class="hover:underline">Professionnel</a></li>
        <li><a href="/équipement" class="hover:underline">Équipement</a></li>
        <li><a href="/loi-82-21" class="hover:underline">Loi 82-21</a></li>
        <li><a href="/regularization-article-33" class="hover:underline">Régularisation Article 33</a></li>
        <li><a href="/contact" class="hover:underline">Contact</a></li>
      </ul>
    </div>
    <div>
      <h2 class="mb-3 text-sm font-bold uppercase tracking-wide text-white">Contact</h2>
      <ul class="space-y-2 text-sm">
        <li><a href={`tel:${NAP.phone}`} class="hover:underline">{NAP.phoneDisplay}</a></li>
        <li><a href={`mailto:${NAP.email}`} class="hover:underline">{NAP.email}</a></li>
        <li><a href={wa} rel="noopener" class="hover:underline">WhatsApp</a></li>
        <li class="text-navy-100/70">Zone d'intervention : {NAP.serviceArea.slice(0, -1).join(', ')} — tout le Maroc</li>
      </ul>
    </div>
  </div>
  <div class="border-t border-white/10 py-4 text-center text-xs text-navy-100/60">
    © 2026 {NAP.name}. Tous droits réservés.
  </div>
</footer>
