---
/**
 * Maquette HTML/CSS d'un échange WhatsApp réel anonymisé — élément de
 * confiance « la suite se passe sur WhatsApp ». Aucune capture d'écran ;
 * tout est construit en HTML/CSS pour rester net et léger.
 * PLACEHOLDER(MERYEM): les messages sont représentatifs — à ajuster si
 * Meryem préfère un échange type différent.
 *
 * W67 — i18n : seuls les bulles AFFICHÉES + « WhatsApp direct » + le sous-titre
 * sont traduits (FR/EN/AR). Le lien WhatsApp pré-rempli reste EN FRANÇAIS (il
 * atteint l'équipe FR) — l'argument de `whatsappLink(...)` n'est jamais traduit.
 * Les CHIFFRES (1 800 MAD, 5 à 9 kWc) et les LIEUX (Casablanca) restent
 * identiques dans toutes les langues. Rendu FR inchangé (branche `fr` = strings
 * actuels mot pour mot).
 */
import { WHATSAPP_LEADS } from '../lib/nap';
import { whatsappLink } from '../lib/whatsapp';
import { getLocaleFromPath } from '../i18n/utils';
import type { Locale } from '../i18n/config';

// Lien pré-rempli : message TOUJOURS en français (il arrive à l'équipe FR).
const wa = whatsappLink(WHATSAPP_LEADS, 'Bonjour, je viens de faire le diagnostic sur taqinor.ma.');

const locale = getLocaleFromPath(Astro.url.pathname);

const STR: Record<
  Locale,
  { subtitle: string; cta: string; photo: string; msgs: string[] }
> = {
  fr: {
    subtitle: 'répond généralement en quelques minutes',
    cta: 'WhatsApp direct',
    photo: '📷 Photo de la toiture',
    msgs: [
      'Bonjour, je viens de faire le diagnostic sur taqinor.ma — facture ~1 800 MAD, villa à Casablanca.',
      'Bonjour ! Merci pour votre diagnostic. Avec ce profil, on part sur 5 à 9 kWc. Quelques photos de votre toiture et je peux affiner avant la visite technique.',
      'Parfait, belle exposition sud. Je vous propose un passage jeudi pour la visite — l’étude complète est gratuite et sans engagement.',
    ],
  },
  en: {
    subtitle: 'usually replies within a few minutes',
    cta: 'WhatsApp direct',
    photo: '📷 Photo of the roof',
    msgs: [
      'Hello, I just did the diagnostic on taqinor.ma — bill ~1 800 MAD, villa in Casablanca.',
      'Hello! Thanks for your diagnostic. With this profile, we’re looking at 5 à 9 kWc. A few photos of your roof and I can refine before the technical visit.',
      'Perfect, lovely south exposure. I can come by on Thursday for the visit — the full study is free and with no commitment.',
    ],
  },
  ar: {
    subtitle: 'يردّ عادةً خلال بضع دقائق',
    cta: 'WhatsApp مباشر',
    photo: '📷 صورة للسطح',
    msgs: [
      'مرحبًا، أنجزتُ للتوّ التشخيص على taqinor.ma — الفاتورة ~1 800 MAD، فيلا في Casablanca.',
      'مرحبًا! شكرًا على تشخيصك. مع هذا الملف، نتّجه نحو 5 à 9 kWc. بعض الصور لسطحك وأستطيع الضبط قبل الزيارة التقنية.',
      'ممتاز، تعرّض جنوبي جميل. أقترح المرور يوم الخميس للزيارة — الدراسة الكاملة مجانية ودون أي التزام.',
    ],
  },
};
const s = STR[locale] ?? STR.fr;

const exchange = [
  { from: 'client', text: s.msgs[0], time: '09:42' },
  { from: 'taqinor', text: s.msgs[1], time: '09:45' },
  { from: 'client', text: s.photo, photo: true, time: '09:51' },
  { from: 'taqinor', text: s.msgs[2], time: '09:54' },
];
---

<div class="mx-auto w-full max-w-[340px]">
  <div class="overflow-hidden rounded-[2rem] border-[6px] border-azur-950 bg-[#e7ddd3] shadow-[0_30px_70px_-30px_rgb(10_18_56/0.55)]">
    <!-- Barre du contact — avec point « en ligne » -->
    <div class="flex items-center gap-3 bg-azur-950 px-4 pb-3 pt-5">
      <!-- Avatar + pastille « en ligne » -->
      <div class="relative shrink-0">
        <span class="flex h-9 w-9 items-center justify-center rounded-full bg-brass-400 font-display text-sm font-extrabold text-azur-950" aria-hidden="true">T</span>
        <!-- Pastille verte « en ligne » -->
        <span class="absolute bottom-0 right-0 h-2.5 w-2.5 rounded-full border-2 border-azur-950 bg-[#25d366]" aria-hidden="true"></span>
      </div>
      <div class="min-w-0 flex-1 leading-tight">
        <p class="text-sm font-bold text-white">Taqinor</p>
        <!-- Statut « en ligne » (aria) + sous-titre -->
        <p class="text-[11px] text-azur-200" aria-label="en ligne">{s.subtitle}</p>
      </div>
      <!-- Icônes de barre (décoratif) -->
      <div class="flex shrink-0 items-center gap-3" aria-hidden="true">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-azur-200 opacity-70"><path d="M22 16.92v3a2 2 0 0 1-2.18 2A19.8 19.8 0 0 1 3.09 5.18 2 2 0 0 1 5.07 3h3a2 2 0 0 1 2 1.72 12.9 12.9 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L9.09 10.91a16 16 0 0 0 4 4l1.27-1.27a2 2 0 0 1 2.11-.45 12.9 12.9 0 0 0 2.81.7A2 2 0 0 1 21 16.92z"/></svg>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-azur-200 opacity-70"><circle cx="12" cy="12" r="1"/><circle cx="19" cy="12" r="1"/><circle cx="5" cy="12" r="1"/></svg>
      </div>
    </div>

    <!-- Date de séparation — discret, style WhatsApp -->
    <div class="flex items-center justify-center px-3 py-2" aria-hidden="true">
      <span class="rounded-full bg-[#c8b8a8]/50 px-2.5 py-0.5 text-[10px] font-semibold text-[#5c4d3c]">Aujourd'hui</span>
    </div>

    <!-- Fil de conversation -->
    <div class="flex flex-col gap-1.5 px-3 pb-4">
      {exchange.map((m) => (
        <div
          class:list={[
            'wa-bubble relative max-w-[85%] px-3 pb-1.5 pt-2 text-[13px] leading-snug shadow-sm',
            m.from === 'client'
              ? 'wa-bubble--out self-end rounded-[10px_10px_3px_10px] bg-[#d7f7c8] text-encre'
              : 'wa-bubble--in self-start rounded-[10px_10px_10px_3px] bg-blanc text-encre',
          ]}
        >
          {/* Queue de bulle côté taqinor */}
          {m.from !== 'client' && (
            <span class="wa-tail-in" aria-hidden="true"></span>
          )}
          {/* Queue de bulle côté client */}
          {m.from === 'client' && (
            <span class="wa-tail-out" aria-hidden="true"></span>
          )}

          {m.photo ? (
            <span class="flex items-center gap-2 text-encre-soft">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2"/><circle cx="9" cy="10" r="2"/><path d="m21 17-5-5-4 4-2-2-5 5"/></svg>
              {m.text}
            </span>
          ) : (
            m.text
          )}

          <!-- Heure + indicateurs de statut -->
          <span class="wa-meta mt-0.5 flex items-center justify-end gap-1">
            <span class="text-[10px] text-encre-faint">{m.time}</span>
            {/* Double coche : lu (bleu) pour les messages client, envoyé (gris) pour Taqinor */}
            {m.from === 'client' && (
              <span aria-label="lu" class="wa-ticks wa-ticks--read">
                {/* ✓✓ double coche SVG */}
                <svg width="14" height="9" viewBox="0 0 14 9" fill="none" aria-hidden="true">
                  <path d="M1 4.5L4.5 8L9 1" stroke="#53bdeb" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M5 4.5L8.5 8L13 1" stroke="#53bdeb" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            )}
          </span>
        </div>
      ))}
    </div>
  </div>
  <a href={wa} rel="noopener" class="mt-5 flex items-center justify-center gap-2 bg-ok-600 px-5 py-3 text-sm font-bold text-white transition-opacity hover:opacity-90">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 0 0-8.6 15.1L2 22l5-1.3A10 10 0 1 0 12 2Zm5.4 14.1c-.2.6-1.3 1.2-1.8 1.2-.5.1-1 .2-3.3-.7-2.8-1.1-4.6-4-4.7-4.2-.1-.2-1.1-1.5-1.1-2.9s.7-2 1-2.3c.2-.3.5-.3.7-.3h.5c.2 0 .4 0 .6.4l.9 2.1c.1.2.1.4 0 .6l-.4.6-.5.5c-.2.2-.3.4-.1.7.2.3.9 1.4 1.9 2.3 1.3 1.1 2.3 1.5 2.6 1.6.3.1.5.1.7-.1l1-1.2c.2-.3.4-.2.7-.1l2 1c.3.1.5.2.6.4 0 .1 0 .7-.3 1.4Z"/></svg>
    {s.cta}
  </a>
</div>

<style>
  /* W193 — Queues de bulle WhatsApp */
  .wa-bubble { position: relative; }

  /* Queue côté entrant (gauche) */
  .wa-tail-in {
    position: absolute;
    top: 0;
    left: -7px;
    width: 0;
    height: 0;
    border-top: 8px solid #ffffff;
    border-left: 7px solid transparent;
  }

  /* Queue côté sortant (droite) */
  .wa-tail-out {
    position: absolute;
    top: 0;
    right: -7px;
    width: 0;
    height: 0;
    border-top: 8px solid #d7f7c8;
    border-right: 7px solid transparent;
  }

  /* Heure + ticks alignés */
  .wa-meta {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 2px;
    margin-top: 2px;
  }

  /* Ticks de lecture */
  .wa-ticks { display: inline-flex; align-items: center; }
  .wa-ticks--read svg path { stroke: #53bdeb; }
</style>
