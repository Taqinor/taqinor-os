---
/**
 * Image responsive servie depuis public/photos/ (sorties de
 * scripts/process-photos.mjs) : AVIF + WebP, srcset par largeurs.
 * `name` = nom de base, `widths` = largeurs générées (desc.),
 * `ratio` = rapport w/h du cadrage (pour width/height anti-CLS).
 *
 * W181 — prop `position` (alias `objectPosition`) optionnel : définit
 * l'attribut style `object-position` sur l'<img>. Défaut : non défini
 * (laisse le CSS appelant décider, typiquement `object-center`). Tous
 * les appels existants sans ce prop restent inchangés.
 */
interface Props {
  name: string;
  alt: string;
  widths: number[];
  ratio: number;
  sizes?: string;
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'auto';
  class?: string;
  style?: string;
  /** W181 — Point focal CSS, ex. 'center top', '30% 60%'. Défaut : non défini. */
  position?: string;
  /** Alias de `position` pour compatibilité avec les noms React-style. */
  objectPosition?: string;
}
const {
  name,
  alt,
  widths,
  ratio,
  sizes = '100vw',
  loading = 'lazy',
  fetchpriority = 'auto',
  class: className = '',
  style: styleProp = '',
  position,
  objectPosition,
} = Astro.props;

import { intrinsicHeight, largestWidth, photoSrcset } from '../lib/picture';

const largest = largestWidth(widths);

// W181 — construire le style avec object-position si fourni
const focalPoint = position ?? objectPosition;
const styleAttr = [
  focalPoint ? `object-position:${focalPoint}` : '',
  styleProp,
].filter(Boolean).join(';') || undefined;
---

<picture>
  <source type="image/avif" srcset={photoSrcset(name, widths, 'avif')} sizes={sizes} />
  <source type="image/webp" srcset={photoSrcset(name, widths, 'webp')} sizes={sizes} />
  <img
    src={`/photos/${name}-${largest}.webp`}
    alt={alt}
    width={largest}
    height={intrinsicHeight(largest, ratio)}
    loading={loading}
    decoding="async"
    fetchpriority={fetchpriority}
    class={className}
    style={styleAttr}
  />
</picture>
