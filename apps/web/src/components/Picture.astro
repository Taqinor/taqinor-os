---
/**
 * Image responsive servie depuis public/photos/ (sorties de
 * scripts/process-photos.mjs) : AVIF + WebP, srcset par largeurs.
 * `name` = nom de base, `widths` = largeurs générées (desc.),
 * `ratio` = rapport w/h du cadrage (pour width/height anti-CLS).
 *
 * W181 — prop `position` (alias `objectPosition`) optionnel : définit
 * l'attribut style `object-position` sur l'<img>. Défaut : non défini
 * (laisse le CSS appelant décider, typiquement `object-center`). Tous
 * les appels existants sans ce prop restent inchangés.
 *
 * W155 — prop `portraitPosition` optionnel : remplace l'object-position
 * en mode portrait (orientation:portrait) pour un meilleur cadrage sur
 * téléphones tenus en portrait. Implémenté via un <style> inline scoped
 * par data-pid (identifiant unique par instance). Aucun nouveau fichier
 * image n'est nécessaire — même srcset, cadrage CSS uniquement.
 */
interface Props {
  name: string;
  alt: string;
  widths: number[];
  ratio: number;
  sizes?: string;
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'auto';
  class?: string;
  style?: string;
  /** W181 — Point focal CSS, ex. 'center top', '30% 60%'. Défaut : non défini. */
  position?: string;
  /** Alias de `position` pour compatibilité avec les noms React-style. */
  objectPosition?: string;
  /**
   * W155 — Point focal CSS en mode portrait (prefers orientation:portrait).
   * Ex. 'center 30%'. Quand défini, remplace `position`/`objectPosition`
   * en portrait via un <style> inline scoped. Callers existants inchangés.
   */
  portraitPosition?: string;
}
const {
  name,
  alt,
  widths,
  ratio,
  sizes = '100vw',
  loading = 'lazy',
  fetchpriority = 'auto',
  class: className = '',
  style: styleProp = '',
  position,
  objectPosition,
  portraitPosition,
} = Astro.props;

import { intrinsicHeight, largestWidth, photoSrcset } from '../lib/picture';

const largest = largestWidth(widths);

// W181 — construire le style avec object-position si fourni
const focalPoint = position ?? objectPosition;
const styleAttr = [
  focalPoint ? `object-position:${focalPoint}` : '',
  styleProp,
].filter(Boolean).join(';') || undefined;

// W155 — identifiant unique pour scoper le portrait override
// On génère un id court et stable (hash du name + portraitPosition).
let portraitPid: string | undefined;
if (portraitPosition) {
  // Simple deterministic id: base the name + first char of portraitPosition
  portraitPid = 'pp-' + name.replace(/[^a-z0-9]/gi, '').slice(0, 12) + '-' + portraitPosition.replace(/[^a-z0-9]/gi, '').slice(0, 6);
}
---

<picture>
  <source type="image/avif" srcset={photoSrcset(name, widths, 'avif')} sizes={sizes} />
  <source type="image/webp" srcset={photoSrcset(name, widths, 'webp')} sizes={sizes} />
  <img
    src={`/photos/${name}-${largest}.webp`}
    alt={alt}
    width={largest}
    height={intrinsicHeight(largest, ratio)}
    loading={loading}
    decoding="async"
    fetchpriority={fetchpriority}
    class={className}
    style={styleAttr}
    data-pid={portraitPid}
  />
</picture>
{portraitPid && (
  <style set:html={`@media (orientation:portrait){[data-pid="${portraitPid}"]{object-position:${portraitPosition}!important}}`} />
)}
