---
/**
 * FAQ accessible sans JavaScript (details/summary natifs).
 * PLACEHOLDER(MERYEM): tout le contenu FAQ est provisoire — à remplacer
 * par les questions/réponses de Meryem.
 */
interface Props {
  items: { q: string; a: string }[];
  heading?: string;
}
const { items, heading = 'Questions fréquentes' } = Astro.props;
---

<section class="mx-auto max-w-3xl px-4 py-16">
  <p class="tech-label rule-amber text-ink-soft">FAQ</p>
  <h2 class="display mt-3 text-3xl">{heading}</h2>
  <div class="mt-8 border-t border-ink/15">
    {items.map((item) => (
      <details class="group border-b border-ink/15 py-5">
        <summary class="flex cursor-pointer list-none items-baseline gap-4 font-display text-base font-semibold marker:hidden [&::-webkit-details-marker]:hidden">
          <span class="font-mono text-sm font-medium text-amber-500 transition-transform group-open:rotate-90 inline-block" aria-hidden="true">›</span>
          {item.q}
        </summary>
        <p class="mt-3 pl-8 text-sm leading-relaxed text-ink-soft">{item.a}</p>
      </details>
    ))}
  </div>
</section>
