---
/**
 * FAQ accessible sans JavaScript (details/summary natifs).
 * PLACEHOLDER(MERYEM): tout le contenu FAQ est provisoire — à remplacer
 * par les questions/réponses de Meryem.
 */
interface Props {
  items: { q: string; a: string; cluster?: string }[];
  heading?: string;
  /**
   * Émettre le JSON-LD FAQPage (défaut true). Une seule page du site doit
   * porter le FAQPage pour ces questions — la page dédiée `/faq`. L'accueil
   * réutilise le MÊME composant pour l'accordéon visuel mais passe
   * `schema={false}` afin d'éviter un FAQPage en double / concurrent sur des
   * questions qui se recoupent (hygiène données structurées, W19).
   */
  schema?: boolean;
}
import { getLocaleFromPath, useTranslations } from '../i18n/utils';
const t = useTranslations(getLocaleFromPath(Astro.url.pathname));
const { items, heading = t('faq.heading'), schema = true } = Astro.props;

// JSON-LD FAQPage — strictement aligné sur les questions rendues ci-dessous
const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: items.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
};

// W330 — id stable et déeplinkable par question (indexé, pas slugifié : reste
// stable en FR/EN/AR sans dépendre d'une regex \w latine sur du texte arabe).
// Quand `cluster` est fourni sur au moins un item, les questions sont
// regroupées sous des <h2> par cluster (ordre de première apparition) ; sinon
// le rendu reste la liste plate inchangée (tous les autres appelants du site,
// ex. accueil, garanties, guides — non concernés par W330).
const hasClusters = items.some((item) => item.cluster);

type Group = { cluster: string | null; items: { q: string; a: string; id: string }[] };
const groups: Group[] = [];
items.forEach((item, i) => {
  const id = `faq-q-${i + 1}`;
  const clusterKey = hasClusters ? item.cluster ?? null : null;
  const last = groups[groups.length - 1];
  if (last && last.cluster === clusterKey) {
    last.items.push({ q: item.q, a: item.a, id });
  } else {
    groups.push({ cluster: clusterKey, items: [{ q: item.q, a: item.a, id }] });
  }
});
---

{schema && <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />}

<!-- W51 — FAQ dans le système navy+or : fond nuit, texte lune/blanc, marqueurs
     laiton. Markup details/summary et logique JSON-LD INCHANGÉS.
     W330 — quand des clusters sont fournis, chaque groupe de questions est
     rendu sous un <h2> propre avec un id stable par question (deep-link
     #faq-q-N), pour la lisibilité et pour que chaque réponse reste citable
     indépendamment (objectif AEO W297/W330). -->
<section class="border-t border-white/10 bg-nuit px-4 py-16 text-lune">
  <div class="mx-auto max-w-3xl">
  <p class="tech-label rule-brass text-brass-300">FAQ</p>
  <h2 class="display v2-section-title mt-3 text-3xl text-white">{heading}</h2>
  <div class="mt-8">
    {groups.map((group) => (
      <div class="faq-cluster">
        {group.cluster && (
          <h2 class="v2-section-title mt-10 text-lg font-bold text-brass-300 first:mt-0">{group.cluster}</h2>
        )}
        <div class="border-t border-white/10">
          {group.items.map((item) => (
            <details id={item.id} class="group scroll-mt-24 border-b border-white/10 py-5">
              <summary class="flex cursor-pointer list-none items-baseline gap-4 font-display text-base font-bold text-white marker:hidden [&::-webkit-details-marker]:hidden">
                <span class="inline-block h-2 w-2 flex-none rotate-45 border-[1.5px] border-brass-400 transition-transform group-open:rotate-[135deg]" aria-hidden="true"></span>
                <span class="faq-bidi">{item.q}</span>
              </summary>
              <p class="faq-bidi mt-3 ps-6 text-sm leading-relaxed text-lune-soft">{item.a}</p>
            </details>
          ))}
        </div>
      </div>
    ))}
  </div>
  </div>
</section>

<style>
  /*
   * W-numérotation RTL — les questions/réponses arrivent en texte simple
   * (props) et peuvent contenir des nombres latins (ex. "30 ans", "6 000
   * cycles"). En RTL, sans indication, le navigateur peut réordonner ces
   * runs numériques. `unicode-bidi: plaintext` fait détecter au navigateur
   * la direction de CHAQUE élément selon l'algorithme bidi Unicode standard
   * à partir de son propre contenu, ce qui isole les runs numériques latins
   * et les rend LTR correctement, sans toucher au rendu FR/EN (plaintext né
   * comme LTR n'a aucun effet visible sur du texte déjà LTR).
   */
  .faq-bidi {
    unicode-bidi: plaintext;
  }
</style>
