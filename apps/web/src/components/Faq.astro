---
/**
 * FAQ accessible sans JavaScript (details/summary natifs).
 * PLACEHOLDER(MERYEM): tout le contenu FAQ est provisoire — à remplacer
 * par les questions/réponses de Meryem.
 */
interface Props {
  items: { q: string; a: string }[];
  heading?: string;
  /**
   * Émettre le JSON-LD FAQPage (défaut true). Une seule page du site doit
   * porter le FAQPage pour ces questions — la page dédiée `/faq`. L'accueil
   * réutilise le MÊME composant pour l'accordéon visuel mais passe
   * `schema={false}` afin d'éviter un FAQPage en double / concurrent sur des
   * questions qui se recoupent (hygiène données structurées, W19).
   */
  schema?: boolean;
}
const { items, heading = 'Questions fréquentes', schema = true } = Astro.props;

// JSON-LD FAQPage — strictement aligné sur les questions rendues ci-dessous
const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: items.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
};
---

{schema && <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />}

<section class="bg-blanc-azur px-4 py-16 text-encre">
  <div class="mx-auto max-w-3xl">
  <p class="tech-label rule-brass text-azur-600">FAQ</p>
  <h2 class="display mt-3 text-3xl">{heading}</h2>
  <div class="mt-8 border-t border-azur-900/15">
    {items.map((item) => (
      <details class="group border-b border-azur-900/15 py-5">
        <summary class="flex cursor-pointer list-none items-baseline gap-4 font-display text-base font-bold marker:hidden [&::-webkit-details-marker]:hidden">
          <span class="inline-block h-2 w-2 flex-none rotate-45 border-[1.5px] border-azur-600 transition-transform group-open:rotate-[135deg]" aria-hidden="true"></span>
          {item.q}
        </summary>
        <p class="mt-3 pl-6 text-sm leading-relaxed text-encre-soft">{item.a}</p>
      </details>
    ))}
  </div>
  </div>
</section>
