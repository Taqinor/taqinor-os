---
/**
 * « Diagnostic solaire » ENRICHI — variante PRIVÉE (preview) du composant de
 * conversion. Identique au DiagnosticForm en production, à une seule chose
 * près : une section FACULTATIVE et repliable « Ajouter des détails » à
 * l'étape identité (type d'alimentation, surface de toiture, orientation).
 *
 * Règle de conversion absolue : ces champs ne bloquent, ne retardent et ne
 * conditionnent JAMAIS la capture. Soumettre sans y toucher reproduit à
 * l'identique le comportement actuel (même bande ROI, même payload + champs
 * facultatifs vides, même deeplink WhatsApp, même CAPI). La soumission part
 * vers /api/preview-lead (miroir de /api/simulate) : un seul POST, jamais de
 * seconde requête. La logique de progression réutilise src/lib/diagnostic.ts
 * inchangée — les champs facultatifs vivent hors de toute validation d'étape.
 */
import { BILL_RANGES } from '../lib/billRange';
import { ROOF_TYPES } from '../lib/lead';
import { SUPPLY_TYPES, ORIENTATIONS } from '../lib/enrichment';

interface Props {
  heading?: string;
  /**
   * Mode « une page » (opt-in, pro-11) : tous les champs sur une seule page, sans
   * pagination 3 étapes (indicateur de progression + boutons Précédent/Suivant
   * masqués, bouton d'envoi toujours visible). ADDITIF : absent/false reproduit
   * EXACTEMENT le comportement actuel (wizard 3 étapes), payload + endpoint
   * inchangés. Le simulateur pré-remplit alors facture/toit/surface/orientation/kWc.
   */
  singleStep?: boolean;
}
const { heading = 'Diagnostic solaire — 60 secondes', singleStep = false } = Astro.props;

// Aide à la saisie : grandes villes/communes — la saisie libre reste acceptée
const VILLES = [
  'Casablanca', 'Rabat', 'Marrakech', 'Tanger', 'Agadir', 'Fès', 'Meknès',
  'Oujda', 'Kénitra', 'Tétouan', 'Salé', 'Témara', 'Mohammedia', 'El Jadida',
  'Nouaceur', 'Bouskoura', 'Dar Bouazza', 'Settat', 'Berrechid', 'Khouribga',
  'Béni Mellal', 'Safi', 'Essaouira', 'Nador', 'Al Hoceïma', 'Larache',
  'Khémisset', 'Ifrane', 'Errachidia', 'Ouarzazate', 'Laâyoune', 'Dakhla',
];

// W188 — ≥16 px font-size (prevents iOS zoom-on-focus), min ~44 px tap height.
// W194 — focus ring boosted to /50 opacity; aria-invalid field style in <style>.
const inputClass =
  'w-full min-h-[44px] border border-azur-900/20 bg-blanc px-3 py-3 text-base outline-none transition-colors focus:border-azur-600 focus:ring-2 focus:ring-azur-600/50 placeholder:text-encre-faint';
---

<!-- ACTE FINAL — la nuit s'ouvre : le diagnostic arrive en pleine lumière -->
<div class="seam-lumiere" aria-hidden="true"></div>
<section id="simulateur" class="scroll-mt-20 bg-blanc-azur px-4 pb-20 pt-12 text-encre sm:pb-24">
  <div class:list={['mx-auto grid items-start gap-6', Astro.slots.has('aside') ? 'max-w-5xl lg:grid-cols-[1.4fr_1fr]' : 'max-w-2xl']}>
  <div class="border border-azur-900/15 bg-blanc shadow-[0_24px_60px_-28px_rgb(15_28_84/0.35)]">
    <div class="border-b border-azur-900/10 px-6 py-5 sm:px-8">
      <p class="tech-label text-azur-600">Diagnostic · sans engagement · aucune donnée vendue</p>
      <h2 class="display mt-2 text-2xl sm:text-3xl">{heading}</h2>

      <!-- Indicateur de progression -->
      <div class="mt-5 flex items-center gap-3" aria-hidden="true">
        <span data-seg="1" class="h-1 flex-1 bg-azur-600 transition-colors"></span>
        <span data-seg="2" class="h-1 flex-1 bg-azur-100 transition-colors"></span>
        <span data-seg="3" class="h-1 flex-1 bg-azur-100 transition-colors"></span>
      </div>
      <p id="diag-progress" class="tech-label mt-2 text-encre-faint" aria-live="polite">Étape 1 sur 3</p>
    </div>

    <form id="lead-form" class="p-6 sm:p-8" novalidate data-single-step={singleStep ? 'true' : undefined}>
      <!-- Étape 1 — la question de diagnostic, zéro donnée personnelle -->
      <fieldset data-step="1" class="flex flex-col gap-4 border-0 p-0">
        <legend class="display mb-1 text-lg">Votre étude commence ici</legend>
        <div>
          <label for="lf-bill" class="mb-1 block text-sm font-semibold">Facture d'électricité mensuelle *</label>
          <select id="lf-bill" name="billRange" required class={inputClass}>
            <option value="" disabled selected>Choisir une tranche…</option>
            {BILL_RANGES.map((r) => <option value={r.id}>{r.label}</option>)}
          </select>
        </div>
        <div>
          <label for="lf-roof" class="mb-1 block text-sm font-semibold">Type de toiture *</label>
          <select id="lf-roof" name="roofType" required class={inputClass}>
            <option value="" disabled selected>Choisir…</option>
            {ROOF_TYPES.map((r) => <option value={r.id}>{r.label}</option>)}
          </select>
        </div>
      </fieldset>

      <!-- Étape 2 — localisation + signal préliminaire en direct -->
      <fieldset data-step="2" class="hidden flex-col gap-4 border-0 p-0">
        <legend class="display mb-1 text-lg">Votre commune</legend>
        <div>
          <label for="lf-city" class="mb-1 block text-sm font-semibold">{singleStep ? 'Adresse / ville *' : 'Ville / commune *'}</label>
          <input id="lf-city" name="city" required autocomplete="address-level2" list="lf-villes" class={inputClass} />
          <datalist id="lf-villes">
            {VILLES.map((v) => <option value={v} />)}
          </datalist>
        </div>
        <p id="diag-sun" class="hidden border-l-4 border-azur-600 bg-blanc-azur py-2.5 pl-4 pr-3 text-sm font-semibold text-azur-700" aria-live="polite"></p>
      </fieldset>

      <!-- Étape 3 — identité, cadrée « Recevez votre étude sur WhatsApp » -->
      <fieldset data-step="3" class="hidden flex-col gap-4 border-0 p-0">
        <legend class="display mb-1 text-lg">Recevez votre étude sur WhatsApp</legend>
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="lf-name" class="mb-1 block text-sm font-semibold">Nom complet *</label>
            <input id="lf-name" name="fullName" required autocomplete="name" class={inputClass} />
          </div>
          <div>
            <label for="lf-phone" class="mb-1 block text-sm font-semibold">Téléphone *</label>
            <input id="lf-phone" name="phone" required type="tel" inputmode="tel" autocomplete="tel"
              aria-describedby="lf-phone-err" placeholder="06 XX XX XX XX" class={inputClass} />
            <p id="lf-phone-err" role="alert" class="mt-1 hidden text-xs text-alert-600"></p>
          </div>
        </div>

        <!-- Section FACULTATIVE — repliée par défaut, jamais un obstacle.
             Disclosure native <details> : utilisable sans JS, n'avale aucun
             focus, ne gate jamais le bouton « Recevoir mon étude ». -->
        <details class="group border border-azur-900/15 bg-blanc-azur/60">
          <summary class="flex cursor-pointer list-none items-center justify-between gap-3 px-4 py-3 text-sm font-semibold text-encre-soft transition-colors hover:text-azur-700">
            <span class="flex items-center gap-2">
              <svg class="h-4 w-4 flex-none text-azur-600 transition-transform group-open:rotate-45" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 5v14M5 12h14" stroke-linecap="round"/></svg>
              Ajouter des détails — facultatif
            </span>
            <span class="tech-label text-encre-faint group-open:hidden">Optionnel</span>
          </summary>
          <div class="flex flex-col gap-4 border-t border-azur-900/10 px-4 pb-4 pt-4">
            <p class="text-xs leading-relaxed text-encre-soft">
              Facultatif — pour une étude plus précise. Sinon, on regarde ça ensemble sur WhatsApp.
              La plupart des propriétaires ne connaissent pas ces détails : ce n'est pas grave.
            </p>
            <div>
              <label for="lf-supply" class="mb-1 block text-sm font-semibold">Type d'alimentation</label>
              <select id="lf-supply" name="supplyType" class={inputClass}>
                <option value="" selected>Je préfère ne pas préciser</option>
                {SUPPLY_TYPES.map((s) => <option value={s.id}>{s.label}</option>)}
              </select>
            </div>
            <div>
              <label for="lf-area" class="mb-1 block text-sm font-semibold">Surface de toiture disponible (m²)</label>
              <input id="lf-area" name="roofArea" type="number" inputmode="decimal" step="any" min="0"
                placeholder="ex. 80" class={inputClass} />
            </div>
            <div>
              <label for="lf-orient" class="mb-1 block text-sm font-semibold">Orientation principale</label>
              <select id="lf-orient" name="orientation" class={inputClass}>
                <option value="" selected>Je préfère ne pas préciser</option>
                {ORIENTATIONS.map((o) => <option value={o.id}>{o.label}</option>)}
              </select>
            </div>
          </div>
        </details>

        <label class="flex min-h-[44px] cursor-pointer items-center gap-2 text-sm">
          <input type="checkbox" name="whatsappOptIn" class="h-5 w-5 shrink-0 cursor-pointer accent-azur-600" checked />
          <span>Je préfère être contacté(e) par WhatsApp</span>
        </label>
        <label class="flex min-h-[44px] cursor-pointer items-start gap-2 text-sm">
          <input type="checkbox" name="consent" required class="h-5 w-5 mt-0.5 shrink-0 cursor-pointer accent-azur-600" />
          <span>
            J'accepte d'être contacté(e) par Taqinor par WhatsApp et par email au sujet de ma
            demande d'étude solaire. * <a href="/politique-de-confidentialite" target="_blank" rel="noopener" class="text-encre-faint underline underline-offset-2 hover:text-azur-700">Politique de confidentialité</a>
          </span>
        </label>
      </fieldset>

      <!-- fbclid + UTM persistés — remplis depuis sessionStorage au chargement -->
      <input type="hidden" name="fbclid" />
      <input type="hidden" name="utm_source" />
      <input type="hidden" name="utm_medium" />
      <input type="hidden" name="utm_campaign" />
      <input type="hidden" name="utm_content" />
      <input type="hidden" name="utm_term" />
      <!-- Puissance crête estimée — pré-remplie par l'estimateur de toiture
           quand le diagnostic est ouvert depuis lui. Vide partout ailleurs :
           le payload reste alors identique au formulaire live. -->
      <input type="hidden" name="estimatedKwc" id="lf-kwc-est" />

      <p id="lf-err" role="alert" class="mt-4 hidden border border-alert-600/30 bg-alert-50 px-3 py-2 text-sm text-alert-600"></p>

      <div class="mt-6 flex items-center justify-between gap-3">
        <button type="button" id="diag-back"
          class="invisible border border-azur-900/20 px-5 py-3 text-sm font-semibold text-encre-soft transition-colors hover:border-azur-600 hover:text-azur-700">
          ← Retour
        </button>
        <button type="button" id="diag-next"
          class="bg-azur-600 px-6 py-3.5 text-base font-bold text-white transition-colors hover:bg-azur-700">
          Continuer →
        </button>
        <!-- W191 — spinner hidden by default; shown via JS during submit -->
        <button type="submit" id="lf-submit"
          class="hidden items-center gap-2 bg-brass-400 px-7 py-3.5 text-base font-bold text-azur-950 transition-colors hover:bg-brass-300 disabled:opacity-60">
          <span id="lf-spinner" class="spinner hidden" aria-hidden="true"></span>
          <span id="lf-submit-label">Recevoir mon étude sur WhatsApp</span>
        </button>
      </div>
    </form>

    <!-- Extrait d'étude — l'état de résultat -->
    <div id="lf-success" class="hidden p-8">
      <p class="tech-label rule-brass text-brass-600">Extrait d'étude préliminaire</p>
      <div class="mt-6 grid gap-8 sm:grid-cols-2">
        <div>
          <p id="lf-kwc" class="fig text-4xl text-azur-600 sm:text-5xl"></p>
          <p class="tech-label mt-2 text-encre-faint">Puissance estimée</p>
        </div>
        <div>
          <p id="lf-roi" class="fig text-4xl text-azur-600 sm:text-5xl"></p>
          <p class="tech-label mt-2 text-encre-faint">Retour sur investissement</p>
        </div>
      </div>
      <p class="mt-6 border-t border-azur-900/10 pt-5 text-sm leading-relaxed text-encre-soft">
        Fourchette préliminaire calculée à partir de votre tranche de facture — le chiffrage
        précis est établi après visite technique. La suite se passe sur WhatsApp.
      </p>
      <a id="lf-wa" href="#" rel="noopener"
        class="mt-6 inline-flex w-full items-center justify-center gap-2 bg-ok-600 px-6 py-4 text-base font-bold text-white transition-opacity hover:opacity-90 sm:w-auto">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 0 0-8.6 15.1L2 22l5-1.3A10 10 0 1 0 12 2Zm5.4 14.1c-.2.6-1.3 1.2-1.8 1.2-.5.1-1 .2-3.3-.7-2.8-1.1-4.6-4-4.7-4.2-.1-.2-1.1-1.5-1.1-2.9s.7-2 1-2.3c.2-.3.5-.3.7-.3h.5c.2 0 .4 0 .6.4l.9 2.1c.1.2.1.4 0 .6l-.4.6-.5.5c-.2.2-.3.4-.1.7.2.3.9 1.4 1.9 2.3 1.3 1.1 2.3 1.5 2.6 1.6.3.1.5.1.7-.1l1-1.2c.2-.3.4-.2.7-.1l2 1c.3.1.5.2.6.4 0 .1 0 .7-.3 1.4Z"/></svg>
        Recevoir mon étude sur WhatsApp
      </a>
    </div>
  </div>
  {Astro.slots.has('aside') && (
    <div class="lg:sticky lg:top-24">
      <slot name="aside" />
    </div>
  )}
  </div>
</section>

<!-- W194 — validation / error / focus-ring / placeholder styles (Astro-scoped). -->
<style>
  /* Champs invalides (aria-invalid posé par le JS de validation) */
  input[aria-invalid="true"],
  select[aria-invalid="true"] {
    border-color: var(--color-alert-600);
    box-shadow: 0 0 0 2px rgb(179 64 42 / 0.2);
  }
  /* Message d'erreur global — fond plus visible */
  #lf-err:not(.hidden) {
    border-color: var(--color-alert-600);
    background-color: var(--color-alert-50);
  }
</style>

<script>
  import { normalizeMoroccanPhone } from '../lib/phone';
  import { nextStep, progressLabel, sunshineSignal, validateStep, type DiagnosticState } from '../lib/diagnostic';

  const form = document.getElementById('lead-form') as HTMLFormElement | null;
  const success = document.getElementById('lf-success')!;
  const kwcEl = document.getElementById('lf-kwc')!;
  const roiEl = document.getElementById('lf-roi')!;
  const waEl = document.getElementById('lf-wa') as HTMLAnchorElement;
  const errEl = document.getElementById('lf-err')!;
  const phoneErr = document.getElementById('lf-phone-err')!;
  const submitBtn = document.getElementById('lf-submit') as HTMLButtonElement;
  const nextBtn = document.getElementById('diag-next') as HTMLButtonElement;
  const backBtn = document.getElementById('diag-back') as HTMLButtonElement;
  const progressEl = document.getElementById('diag-progress')!;
  const sunEl = document.getElementById('diag-sun')!;
  // W191 — spinner elements (null-safe)
  const spinnerEl = document.getElementById('lf-spinner') as HTMLElement | null;
  const submitLabelEl = document.getElementById('lf-submit-label') as HTMLElement | null;

  // Reprise fbclid + UTM depuis sessionStorage (capture first-touch du Layout)
  const TRACK_KEYS = ['fbclid', 'utm_source', 'utm_medium', 'utm_campaign', 'utm_content', 'utm_term'];
  for (const k of TRACK_KEYS) {
    const input = form?.elements.namedItem(k) as HTMLInputElement | null;
    if (input) {
      try {
        input.value = sessionStorage.getItem('tq_' + k) ?? '';
      } catch {}
    }
  }

  // Mode « une page » (opt-in, pro-11) : tous les champs visibles, sans wizard.
  // Le simulateur pré-remplit facture/toit/surface/orientation/kWc — le visiteur ne
  // tape que Nom/Téléphone/Adresse. Absent ailleurs → wizard 3 étapes inchangé.
  const singleStep = form?.dataset.singleStep === 'true';

  // --- Progression 3 étapes (état partiel = abandon silencieux, rien n'est envoyé) ---
  let step: 1 | 2 | 3 = 1;

  function readState(): DiagnosticState {
    const fd = new FormData(form!);
    return {
      billRange: String(fd.get('billRange') ?? ''),
      roofType: String(fd.get('roofType') ?? ''),
      city: String(fd.get('city') ?? ''),
      fullName: String(fd.get('fullName') ?? ''),
      phone: String(fd.get('phone') ?? ''),
      consent: fd.get('consent') === 'on',
    };
  }

  function renderStep(focusActive = false) {
    for (const fs of form!.querySelectorAll<HTMLFieldSetElement>('fieldset[data-step]')) {
      const visible = Number(fs.dataset.step) === step;
      fs.classList.toggle('hidden', !visible);
      fs.classList.toggle('flex', visible);
    }
    document.querySelectorAll<HTMLElement>('[data-seg]').forEach((seg) => {
      const on = Number(seg.dataset.seg) <= step;
      seg.classList.toggle('bg-azur-600', on);
      seg.classList.toggle('bg-azur-100', !on);
    });
    progressEl.textContent = progressLabel(step);
    backBtn.classList.toggle('invisible', step === 1);
    nextBtn.classList.toggle('hidden', step === 3);
    submitBtn.classList.toggle('hidden', step !== 3);
    errEl.classList.add('hidden');
    if (focusActive) {
      form!
        .querySelector<HTMLElement>(`fieldset[data-step="${step}"] select, fieldset[data-step="${step}"] input`)
        ?.focus();
    }
  }

  // Mode « une page » : montre TOUS les fieldsets, masque l'indicateur de progression
  // et les boutons Précédent/Suivant, force le bouton d'envoi visible — et n'arme PAS
  // le wizard. Le gestionnaire de soumission reste rigoureusement identique.
  function renderSingleStep() {
    for (const fs of form!.querySelectorAll<HTMLFieldSetElement>('fieldset[data-step]')) {
      fs.classList.remove('hidden');
      fs.classList.add('flex');
    }
    progressEl.classList.add('hidden');
    document.querySelectorAll<HTMLElement>('[data-seg]').forEach((seg) => seg.classList.add('hidden'));
    nextBtn.classList.add('hidden');
    backBtn.classList.add('hidden');
    submitBtn.classList.remove('hidden');
    errEl.classList.add('hidden');
  }

  if (!singleStep) {
    nextBtn.addEventListener('click', () => {
      const s = readState();
      const check = validateStep(step as 1 | 2, s);
      if (!check.ok) {
        errEl.textContent = String(Object.values(check.errors)[0]);
        errEl.classList.remove('hidden');
        return;
      }
      step = nextStep(step, s);
      renderStep(true);
    });

    backBtn.addEventListener('click', () => {
      if (step > 1) step = (step - 1) as 1 | 2;
      renderStep(true);
    });
  }

  // Signal préliminaire en direct (étape 2 du wizard, ou champ adresse en une page)
  document.getElementById('lf-city')?.addEventListener('input', (e) => {
    const signal = sunshineSignal((e.target as HTMLInputElement).value);
    sunEl.textContent = signal;
    sunEl.classList.toggle('hidden', !signal);
  });

  if (singleStep) renderSingleStep();
  else renderStep();

  // --- Soumission : miroir de /api/simulate + champs FACULTATIFS ride-along.
  //     Les champs facultatifs ne sont ajoutés au payload que s'ils sont
  //     remplis : un envoi « sans détails » est identique au formulaire live. ---
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    errEl.classList.add('hidden');
    phoneErr.classList.add('hidden');

    const fd = new FormData(form);
    const phone = normalizeMoroccanPhone(String(fd.get('phone') ?? ''));
    if (!phone.ok) {
      phoneErr.textContent = phone.error ?? 'Numéro invalide';
      phoneErr.classList.remove('hidden');
      return;
    }

    const payload: Record<string, unknown> = {
      fullName: fd.get('fullName'),
      phone: fd.get('phone'),
      whatsappOptIn: fd.get('whatsappOptIn') === 'on',
      city: fd.get('city'),
      roofType: fd.get('roofType'),
      billRange: fd.get('billRange'),
      consent: fd.get('consent') === 'on',
    };
    for (const k of TRACK_KEYS) {
      const v = String(fd.get(k) ?? '');
      if (v) payload[k] = v;
    }
    // Champs FACULTATIFS — uniquement s'ils ont une valeur (jamais bloquants)
    const supplyType = String(fd.get('supplyType') ?? '');
    if (supplyType) payload.supplyType = supplyType;
    const roofArea = String(fd.get('roofArea') ?? '').trim();
    if (roofArea) payload.roofArea = roofArea;
    const orientation = String(fd.get('orientation') ?? '');
    if (orientation) payload.orientation = orientation;
    const estimatedKwc = String(fd.get('estimatedKwc') ?? '').trim();
    if (estimatedKwc) payload.estimatedKwc = estimatedKwc;

    submitBtn.disabled = true;
    // W191 — show spinner + aria-busy; update label text without destroying innerHTML
    if (submitLabelEl) submitLabelEl.textContent = 'Calcul en cours…';
    else submitBtn.textContent = 'Calcul en cours…';
    spinnerEl?.classList.remove('hidden');
    submitBtn.classList.add('flex');
    form?.setAttribute('aria-busy', 'true');
    try {
      const res = await fetch('/api/preview-lead', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const data = await res.json();
      if (!res.ok || !data.ok) {
        const first = data?.errors ? String(Object.values(data.errors)[0]) : 'Une erreur est survenue. Réessayez.';
        errEl.textContent = first;
        errEl.classList.remove('hidden');
        return;
      }
      form.classList.add('hidden');
      kwcEl.textContent = data.band.kwcLabel;
      roiEl.textContent = data.band.paybackLabel;
      waEl.href = data.whatsappUrl;
      // W191 — fade-in result (CSS animation gated under no-preference)
      success.classList.add('result-fade');
      success.classList.remove('hidden');
      success.scrollIntoView({ behavior: 'smooth', block: 'center' });
      if (/Android|iPhone|iPad/i.test(navigator.userAgent)) {
        setTimeout(() => {
          window.location.href = data.whatsappUrl;
        }, 1800);
      }
    } catch {
      errEl.textContent = 'Connexion impossible. Vérifiez votre réseau et réessayez.';
      errEl.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      // W191 — restore button state
      spinnerEl?.classList.add('hidden');
      submitBtn.classList.remove('flex');
      form?.removeAttribute('aria-busy');
      if (submitLabelEl) submitLabelEl.textContent = 'Recevoir mon étude sur WhatsApp';
      else submitBtn.textContent = 'Recevoir mon étude sur WhatsApp';
    }
  });
</script>
