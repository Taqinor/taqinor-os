---
/**
 * « Diagnostic solaire » — restaging en 3 étapes du formulaire de lead,
 * LE composant de conversion du site. UI seulement : la soumission reste
 * POST /api/simulate avec exactement la même charge utile ; fbclid + UTM
 * repris du sessionStorage (capture dans Layout) en champs cachés ; seuil
 * 1 000 MAD, bande ROI et consentement horodaté côté serveur, inchangés.
 * Progression/validation côté client : src/lib/diagnostic.ts (testé).
 */
import { BILL_RANGES } from '../lib/billRange';
import { ROOF_TYPES } from '../lib/lead';
import { getLocaleFromPath, stripLocale, useTranslations } from '../i18n/utils';
import { localizeNavHref } from '../i18n/pages';
import type { Locale } from '../i18n/config';

interface Props {
  heading?: string;
  /** Locale du formulaire — libellés VISIBLES uniquement. La charge utile, les
   *  noms de champs, le seuil 1 000 MAD, l'endpoint /api/simulate et le deeplink
   *  WhatsApp restent identiques dans toutes les langues. Par défaut : déduit de
   *  l'URL (FR à la racine), ce qui laisse le rendu FR strictement inchangé. */
  locale?: Locale;
}
const locale: Locale = Astro.props.locale ?? getLocaleFromPath(Astro.url.pathname);
const t = useTranslations(locale);
const { heading = t('form.heading') } = Astro.props;
// Libellés traduits des options — la value reste l'id (jamais traduite), donc
// la charge utile soumise est identique dans toutes les langues.
const billLabel = (id: string) => t(`bill.${id}`);
const roofLabel = (id: string) => t(`roof.${id}`);
const privacyHref = localizeNavHref('/politique-de-confidentialite', locale);
// Chaînes d'exécution (mises à jour par le script) — sérialisées en data-i18n.
const runtimeStrings = JSON.stringify({
  progress: t('form.progress'),
  submit: t('form.submit'),
  submitting: t('form.submitting'),
  errBill: t('form.err.bill'),
  errRoof: t('form.err.roof'),
  errCity: t('form.err.city'),
  errName: t('form.err.name'),
  errPhone: t('form.err.phone'),
  errConsent: t('form.err.consent'),
  errGeneric: t('form.err.generic'),
  errNetwork: t('form.err.network'),
});

// Aide à la saisie : grandes villes/communes — la saisie libre reste acceptée
const VILLES = [
  'Casablanca', 'Rabat', 'Marrakech', 'Tanger', 'Agadir', 'Fès', 'Meknès',
  'Oujda', 'Kénitra', 'Tétouan', 'Salé', 'Témara', 'Mohammedia', 'El Jadida',
  'Nouaceur', 'Bouskoura', 'Dar Bouazza', 'Settat', 'Berrechid', 'Khouribga',
  'Béni Mellal', 'Safi', 'Essaouira', 'Nador', 'Al Hoceïma', 'Larache',
  'Khémisset', 'Ifrane', 'Errachidia', 'Ouarzazate', 'Laâyoune', 'Dakhla',
];

// W51 — Le diagnostic vit désormais dans le système navy+or (champs sombres,
// texte lune/blanc, accents laiton). Comportement, markup, attributs (hors
// classes) et script INCHANGÉS.
// W188 — ≥16 px font-size (prevents iOS zoom-on-focus), min ~44 px tap height.
// py-3 + text-base + border ≈ 46 px ; placeholder contrast raised to lune-soft.
const inputClass =
  'w-full min-h-[44px] border border-white/15 bg-nuit-800 px-3 py-3 text-base text-white placeholder:text-lune-soft outline-none transition-colors focus:border-brass-400 focus:ring-2 focus:ring-brass-400/30';
---

<!-- ACTE FINAL — le diagnostic, dans la nuit éclairée d'or (W51). La couture
     reste une lueur de laiton, mais sur la nuit (le diagnostic n'est plus la
     « salle blanche » : il fait désormais partie du site navy+or). -->
<div class="h-20 bg-[radial-gradient(60%_130%_at_50%_100%,rgb(232_181_74/0.16),transparent_70%)]" aria-hidden="true"></div>
<section id="simulateur" class="scroll-mt-20 border-t border-white/10 bg-nuit px-4 pb-20 pt-12 text-lune sm:pb-24">
  <div class:list={['mx-auto grid items-start gap-6', Astro.slots.has('aside') ? 'max-w-5xl lg:grid-cols-[1.4fr_1fr]' : 'max-w-2xl']}>
  <div class="cine-card">
    <div class="border-b border-white/10 px-6 py-5 sm:px-8">
      <p class="tech-label text-brass-300">{t('form.eyebrow')}</p>
      <h2 class="display v2-section-title mt-2 text-2xl text-white sm:text-3xl">{heading}</h2>

      <!-- Indicateur de progression — l'état actif/inactif est piloté par le
           script (bg-azur-600 / bg-azur-100, INCHANGÉ) ; les segments restent
           lisibles sur la nuit. -->
      <div class="mt-5 flex items-center gap-3" aria-hidden="true">
        <span data-seg="1" class="h-1 flex-1 bg-azur-600 transition-colors"></span>
        <span data-seg="2" class="h-1 flex-1 bg-azur-100 transition-colors"></span>
        <span data-seg="3" class="h-1 flex-1 bg-azur-100 transition-colors"></span>
      </div>
      <p id="diag-progress" class="tech-label mt-2 text-lune-faint" aria-live="polite">{t('form.progress').replace('{step}', '1')}</p>
    </div>

    <form id="lead-form" class="p-6 sm:p-8" novalidate data-i18n={runtimeStrings}>
      <!-- Étape 1 — la question de diagnostic, zéro donnée personnelle -->
      <fieldset data-step="1" class="flex flex-col gap-4 border-0 p-0">
        <legend class="display mb-1 text-lg text-white">{t('form.step1.legend')}</legend>
        <div>
          <label for="lf-bill" class="mb-1 block text-sm font-semibold text-lune">{t('form.bill.label')}</label>
          <select id="lf-bill" name="billRange" required class={inputClass}>
            <option value="" disabled selected>{t('form.bill.placeholder')}</option>
            {BILL_RANGES.map((r) => <option value={r.id}>{billLabel(r.id)}</option>)}
          </select>
        </div>
        <div>
          <label for="lf-roof" class="mb-1 block text-sm font-semibold text-lune">{t('form.roof.label')}</label>
          <select id="lf-roof" name="roofType" required class={inputClass}>
            <option value="" disabled selected>{t('form.roof.placeholder')}</option>
            {ROOF_TYPES.map((r) => <option value={r.id}>{roofLabel(r.id)}</option>)}
          </select>
        </div>
      </fieldset>

      <!-- Étape 2 — localisation + signal préliminaire en direct -->
      <fieldset data-step="2" class="hidden flex-col gap-4 border-0 p-0">
        <legend class="display mb-1 text-lg text-white">{t('form.step2.legend')}</legend>
        <div>
          <label for="lf-city" class="mb-1 block text-sm font-semibold text-lune">{t('form.city.label')}</label>
          <input id="lf-city" name="city" required autocomplete="address-level2" list="lf-villes" class={inputClass} />
          <datalist id="lf-villes">
            {VILLES.map((v) => <option value={v} />)}
          </datalist>
        </div>
        <p id="diag-sun" class="hidden border-s-4 border-brass-400 bg-white/5 py-2.5 pe-3 ps-4 text-sm font-semibold text-brass-300" aria-live="polite"></p>
      </fieldset>

      <!-- Étape 3 — identité, cadrée « Recevez votre étude sur WhatsApp » -->
      <fieldset data-step="3" class="hidden flex-col gap-4 border-0 p-0">
        <legend class="display mb-1 text-lg text-white">{t('form.step3.legend')}</legend>
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="lf-name" class="mb-1 block text-sm font-semibold text-lune">{t('form.name.label')}</label>
            <input id="lf-name" name="fullName" required autocomplete="name" class={inputClass} />
          </div>
          <div>
            <label for="lf-phone" class="mb-1 block text-sm font-semibold text-lune">{t('form.phone.label')}</label>
            <input id="lf-phone" name="phone" required type="tel" inputmode="tel" autocomplete="tel" dir="ltr"
              aria-describedby="lf-phone-err" placeholder={t('form.phone.placeholder')} class={inputClass} />
            <p id="lf-phone-err" role="alert" class="mt-1 hidden text-xs text-alert-300"></p>
          </div>
        </div>
        <label class="flex min-h-[44px] cursor-pointer items-center gap-2 text-sm text-lune">
          <input type="checkbox" name="whatsappOptIn" class="h-5 w-5 shrink-0 cursor-pointer accent-brass-400" checked />
          <span>{t('form.waOptIn')}</span>
        </label>
        <label class="flex min-h-[44px] cursor-pointer items-start gap-2 text-sm text-lune">
          <input type="checkbox" name="consent" required class="h-5 w-5 shrink-0 mt-0.5 cursor-pointer accent-brass-400" />
          <span>
            {t('form.consent.pre')} <a href={privacyHref} target="_blank" rel="noopener" class="text-lune-faint underline underline-offset-2 hover:text-brass-300">{t('form.consent.link')}</a>
          </span>
        </label>
      </fieldset>

      <!-- fbclid + UTM persistés — remplis depuis sessionStorage au chargement -->
      <input type="hidden" name="fbclid" />
      <input type="hidden" name="utm_source" />
      <input type="hidden" name="utm_medium" />
      <input type="hidden" name="utm_campaign" />
      <input type="hidden" name="utm_content" />
      <input type="hidden" name="utm_term" />

      <p id="lf-err" role="alert" class="mt-4 hidden border border-alert-300/40 bg-alert-300/10 px-3 py-2 text-sm text-alert-300"></p>

      <div class="mt-6 flex items-center justify-between gap-3">
        <button type="button" id="diag-back"
          class="invisible border border-white/20 px-5 py-3 text-sm font-semibold text-lune-soft transition-colors hover:border-white hover:text-white">
          {t('form.back')}
        </button>
        <button type="button" id="diag-next"
          class="bg-azur-600 px-6 py-3.5 text-base font-bold text-white transition-colors hover:bg-azur-700">
          {t('form.next')}
        </button>
        <button type="submit" id="lf-submit"
          class="hidden bg-brass-400 px-7 py-3.5 text-base font-bold text-azur-950 transition-colors hover:bg-brass-300 disabled:opacity-60">
          {t('form.submit')}
        </button>
      </div>
    </form>

    <!-- Extrait d'étude — l'état de résultat -->
    <div id="lf-success" class="hidden p-8">
      <p class="tech-label rule-brass text-brass-300">{t('form.success.eyebrow')}</p>
      <div class="mt-6 grid gap-8 sm:grid-cols-2">
        <div>
          <p id="lf-kwc" class="fig lum text-4xl sm:text-5xl" dir="ltr"></p>
          <p class="tech-label mt-2 text-lune-faint">{t('form.success.kwc')}</p>
        </div>
        <div>
          <p id="lf-roi" class="fig lum text-4xl sm:text-5xl" dir="ltr"></p>
          <p class="tech-label mt-2 text-lune-faint">{t('form.success.roi')}</p>
        </div>
      </div>
      <p class="mt-6 border-t border-white/10 pt-5 text-sm leading-relaxed text-lune-soft">
        {t('form.success.note')}
      </p>
      <a id="lf-wa" href="#" rel="noopener"
        class="mt-6 inline-flex w-full items-center justify-center gap-2 bg-ok-600 px-6 py-4 text-base font-bold text-white transition-opacity hover:opacity-90 sm:w-auto">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 0 0-8.6 15.1L2 22l5-1.3A10 10 0 1 0 12 2Zm5.4 14.1c-.2.6-1.3 1.2-1.8 1.2-.5.1-1 .2-3.3-.7-2.8-1.1-4.6-4-4.7-4.2-.1-.2-1.1-1.5-1.1-2.9s.7-2 1-2.3c.2-.3.5-.3.7-.3h.5c.2 0 .4 0 .6.4l.9 2.1c.1.2.1.4 0 .6l-.4.6-.5.5c-.2.2-.3.4-.1.7.2.3.9 1.4 1.9 2.3 1.3 1.1 2.3 1.5 2.6 1.6.3.1.5.1.7-.1l1-1.2c.2-.3.4-.2.7-.1l2 1c.3.1.5.2.6.4 0 .1 0 .7-.3 1.4Z"/></svg>
        {t('form.submit')}
      </a>
    </div>
  </div>
  {Astro.slots.has('aside') && (
    <div class="lg:sticky lg:top-24">
      <slot name="aside" />
    </div>
  )}
  </div>
</section>

<script>
  import { normalizeMoroccanPhone } from '../lib/phone';
  import { nextStep, sunshineSignal, validateStep, type DiagnosticState } from '../lib/diagnostic';

  const form = document.getElementById('lead-form') as HTMLFormElement | null;
  const success = document.getElementById('lf-success')!;
  const kwcEl = document.getElementById('lf-kwc')!;
  const roiEl = document.getElementById('lf-roi')!;
  const waEl = document.getElementById('lf-wa') as HTMLAnchorElement;
  const errEl = document.getElementById('lf-err')!;
  const phoneErr = document.getElementById('lf-phone-err')!;
  const submitBtn = document.getElementById('lf-submit') as HTMLButtonElement;
  const nextBtn = document.getElementById('diag-next') as HTMLButtonElement;
  const backBtn = document.getElementById('diag-back') as HTMLButtonElement;
  const progressEl = document.getElementById('diag-progress')!;
  const sunEl = document.getElementById('diag-sun')!;

  // Chaînes traduites embarquées par le serveur (libellés VISIBLES uniquement —
  // jamais la charge utile). Repli sur le FR si l'attribut manque.
  const I18N = (() => {
    const fallback = {
      progress: 'Étape {step} sur 3', submit: 'Recevoir mon étude sur WhatsApp',
      submitting: 'Calcul en cours…', errBill: 'Choisissez votre tranche de facture',
      errRoof: 'Choisissez votre type de toiture', errCity: 'Indiquez votre ville ou commune',
      errName: 'Indiquez votre nom complet', errPhone: 'Numéro de téléphone marocain invalide',
      errConsent: 'Le consentement est requis pour recevoir votre étude',
      errGeneric: 'Une erreur est survenue. Réessayez.',
      errNetwork: 'Connexion impossible. Vérifiez votre réseau et réessayez.',
    };
    try { return { ...fallback, ...JSON.parse(form?.dataset.i18n ?? '{}') }; } catch { return fallback; }
  })();
  // Traduit un message de validation d'étape (renvoyé en FR par validateStep)
  // vers la locale courante, via la clé du champ en erreur.
  const ERR_BY_FIELD: Record<string, string> = {
    billRange: I18N.errBill, roofType: I18N.errRoof, city: I18N.errCity,
    fullName: I18N.errName, phone: I18N.errPhone, consent: I18N.errConsent,
  };

  // Reprise fbclid + UTM depuis sessionStorage (capture first-touch du Layout)
  const TRACK_KEYS = ['fbclid', 'utm_source', 'utm_medium', 'utm_campaign', 'utm_content', 'utm_term'];
  for (const k of TRACK_KEYS) {
    const input = form?.elements.namedItem(k) as HTMLInputElement | null;
    if (input) {
      try {
        input.value = sessionStorage.getItem('tq_' + k) ?? '';
      } catch {}
    }
  }

  // --- Progression 3 étapes (état partiel = abandon silencieux, rien n'est envoyé) ---
  let step: 1 | 2 | 3 = 1;

  function readState(): DiagnosticState {
    const fd = new FormData(form!);
    return {
      billRange: String(fd.get('billRange') ?? ''),
      roofType: String(fd.get('roofType') ?? ''),
      city: String(fd.get('city') ?? ''),
      fullName: String(fd.get('fullName') ?? ''),
      phone: String(fd.get('phone') ?? ''),
      consent: fd.get('consent') === 'on',
    };
  }

  // focusActive : déplace le focus vers le 1er champ de l'étape visible —
  // uniquement lors d'un changement d'étape voulu par l'utilisateur, jamais
  // au chargement (sinon on volerait le focus à l'arrivée sur la page).
  function renderStep(focusActive = false) {
    for (const fs of form!.querySelectorAll<HTMLFieldSetElement>('fieldset[data-step]')) {
      const visible = Number(fs.dataset.step) === step;
      fs.classList.toggle('hidden', !visible);
      fs.classList.toggle('flex', visible);
    }
    document.querySelectorAll<HTMLElement>('[data-seg]').forEach((seg) => {
      const on = Number(seg.dataset.seg) <= step;
      seg.classList.toggle('bg-azur-600', on);
      seg.classList.toggle('bg-azur-100', !on);
    });
    progressEl.textContent = I18N.progress.replace('{step}', String(step));
    backBtn.classList.toggle('invisible', step === 1);
    nextBtn.classList.toggle('hidden', step === 3);
    submitBtn.classList.toggle('hidden', step !== 3);
    errEl.classList.add('hidden');
    if (focusActive) {
      form!
        .querySelector<HTMLElement>(`fieldset[data-step="${step}"] select, fieldset[data-step="${step}"] input`)
        ?.focus();
    }
  }

  nextBtn.addEventListener('click', () => {
    const s = readState();
    const check = validateStep(step as 1 | 2, s);
    if (!check.ok) {
      // validateStep renvoie le message FR ; on affiche sa version localisée
      // d'après le champ en erreur (repli sur le message FR si non mappé).
      const [field, frMsg] = Object.entries(check.errors)[0];
      errEl.textContent = ERR_BY_FIELD[field] ?? String(frMsg);
      errEl.classList.remove('hidden');
      return;
    }
    step = nextStep(step, s);
    renderStep(true);
  });

  backBtn.addEventListener('click', () => {
    if (step > 1) step = (step - 1) as 1 | 2;
    renderStep(true);
  });

  // Signal préliminaire en direct à l'étape 2
  document.getElementById('lf-city')?.addEventListener('input', (e) => {
    const signal = sunshineSignal((e.target as HTMLInputElement).value);
    sunEl.textContent = signal;
    sunEl.classList.toggle('hidden', !signal);
  });

  renderStep();

  // --- Soumission : identique au formulaire d'origine (payload, API, seuil) ---
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    errEl.classList.add('hidden');
    phoneErr.classList.add('hidden');

    const fd = new FormData(form);
    const phone = normalizeMoroccanPhone(String(fd.get('phone') ?? ''));
    if (!phone.ok) {
      phoneErr.textContent = I18N.errPhone;
      phoneErr.classList.remove('hidden');
      return;
    }

    const payload: Record<string, unknown> = {
      fullName: fd.get('fullName'),
      phone: fd.get('phone'),
      whatsappOptIn: fd.get('whatsappOptIn') === 'on',
      city: fd.get('city'),
      roofType: fd.get('roofType'),
      billRange: fd.get('billRange'),
      consent: fd.get('consent') === 'on',
    };
    for (const k of TRACK_KEYS) {
      const v = String(fd.get(k) ?? '');
      if (v) payload[k] = v;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = I18N.submitting;
    try {
      const res = await fetch('/api/simulate', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const data = await res.json();
      if (!res.ok || !data.ok) {
        const first = data?.errors ? String(Object.values(data.errors)[0]) : I18N.errGeneric;
        errEl.textContent = first;
        errEl.classList.remove('hidden');
        return;
      }
      form.classList.add('hidden');
      kwcEl.textContent = data.band.kwcLabel;
      roiEl.textContent = data.band.paybackLabel;
      waEl.href = data.whatsappUrl;
      success.classList.remove('hidden');
      success.scrollIntoView({ behavior: 'smooth', block: 'center' });
      // Sur mobile : ouverture automatique de WhatsApp après l'état de remerciement
      if (/Android|iPhone|iPad/i.test(navigator.userAgent)) {
        setTimeout(() => {
          window.location.href = data.whatsappUrl;
        }, 1800);
      }
    } catch {
      errEl.textContent = I18N.errNetwork;
      errEl.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = I18N.submit;
    }
  });
</script>
