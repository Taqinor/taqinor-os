---
// Logotype TAQINOR — image OFFICIELLE (le même PNG que le générateur de devis,
// `quote_engine/assets/logo.png`). Le PNG est à fond TRANSPARENT et son texte est
// bleu nuit : invisible directement sur l'en-tête sombre. On le pose donc sur une
// petite PUCE BLANCHE arrondie (badge), qui le rend lisible sur fond sombre comme
// clair. `size` ≈ la taille historique du logotype ; l'image est un carré.
interface Props {
  size?: number;
  theme?: 'light' | 'dark';
}
const { size = 26 } = Astro.props;
const h = Math.round(size * 1.6); // hauteur (= largeur) de l'image dans la puce
---

<span class="inline-flex items-center rounded-md bg-white px-1.5 py-1 shadow-sm">
  <img
    src="/logo.png"
    alt="TAQINOR"
    width={h}
    height={h}
    style={`height:${h}px;width:${h}px`}
    class="block"
    loading="eager"
    decoding="async"
  />
</span>
