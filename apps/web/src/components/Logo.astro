---
// Logotype TAQINOR — porté en TEXTE (le mot reste lisible, sélectionnable et
// accessible) et dessiné fidèlement au logo OFFICIEL
// (quote_engine/assets/logo.png) : le « O » est remplacé par le SOLEIL de la
// marque — un disque doré ceint de 8 rayons et traversé d'un éclair bleu nuit.
// L'ancienne version texte n'avait qu'un disque brass plat sans rayons : elle
// ne ressemblait pas au vrai logo, d'où ce rendu. Sur l'en-tête sombre
// (theme="dark") le texte passe en blanc ; le soleil garde ses couleurs de
// marque sur les deux fonds (il porte son propre disque doré).
//
// W168 — lueur brass sur le soleil (réduite si prefers-reduced-motion).
// La classe `.sun-glow` applique un filter:drop-shadow doré subtil via CSS ;
// l'animation pulse est masquée par la media query reduced-motion.
interface Props {
  size?: number;
  theme?: 'light' | 'dark';
}
const { size = 26, theme = 'light' } = Astro.props;
const textColor = theme === 'dark' ? '#ffffff' : '#0a1238';
const gold = '#f7b919'; // jaune solaire vif du logo officiel
const ink = '#0a1238'; // bleu nuit de l'éclair (= azur-950)
const sun = Math.round(size * 1.2); // le soleil (rayons compris) déborde un peu la hauteur des lettres

// 8 rayons régulièrement répartis (générés pour éviter le code répétitif).
const cx = 50;
const cy = 50;
const rInner = 35;
const rOuter = 47;
const rays = Array.from({ length: 8 }, (_, i) => {
  const a = (Math.PI / 4) * i;
  return {
    x1: +(cx + rInner * Math.cos(a)).toFixed(2),
    y1: +(cy + rInner * Math.sin(a)).toFixed(2),
    x2: +(cx + rOuter * Math.cos(a)).toFixed(2),
    y2: +(cy + rOuter * Math.sin(a)).toFixed(2),
  };
});
---

{/* Bug-fix (2026-07-04) : le mot-marque LATIN « TAQINOR » ne doit JAMAIS être
    miroité en arabe. Le conteneur est `inline-flex` : sous <html dir="rtl"> il
    héritait `direction:rtl`, ce qui INVERSE l'ordre visuel des items flex →
    « TAQIN · soleil · R » se lisait « R · soleil · TAQIN » (« ROTAQIN »). On
    force `dir="ltr"` + `unicode-bidi:isolate` sur la racine pour l'extraire de
    tout contexte bidi RTL — le logo reste identique dans les trois locales. */}
<span
  dir="ltr"
  class="inline-flex items-center font-display"
  style={`font-weight:800;font-size:${size}px;color:${textColor};line-height:1;letter-spacing:0.02em;unicode-bidi:isolate;`}
  aria-label="TAQINOR"
>
  <span aria-hidden="true">TAQIN</span>
  <svg
    width={sun}
    height={sun}
    viewBox="0 0 100 100"
    aria-hidden="true"
    class="sun-glow mx-px inline-block shrink-0"
    style="vertical-align:middle;"
  >
    <g stroke={gold} stroke-width="6" stroke-linecap="round">
      {rays.map((r) => <line x1={r.x1} y1={r.y1} x2={r.x2} y2={r.y2} />)}
    </g>
    <circle cx="50" cy="50" r="28" fill={gold} />
    <path
      d="M52.1 28.8 L31.1 54.2 L50 54.2 L47.9 71 L68.9 45.8 L50 45.8 Z"
      fill={ink}
    />
  </svg>
  <span aria-hidden="true">R</span>
</span>

<style>
  /* Static brass drop-shadow — always present, gives depth without animation */
  .sun-glow {
    filter: drop-shadow(0 0 4px rgb(247 185 25 / 0.45)) drop-shadow(0 0 10px rgb(232 181 74 / 0.25));
  }

  /* Gentle pulse only when motion is welcome */
  @media (prefers-reduced-motion: no-preference) {
    .sun-glow {
      animation: sun-pulse 3.5s ease-in-out infinite;
    }
  }

  @keyframes sun-pulse {
    0%, 100% {
      filter: drop-shadow(0 0 4px rgb(247 185 25 / 0.45)) drop-shadow(0 0 10px rgb(232 181 74 / 0.25));
    }
    50% {
      filter: drop-shadow(0 0 6px rgb(247 185 25 / 0.65)) drop-shadow(0 0 18px rgb(232 181 74 / 0.35));
    }
  }
</style>
