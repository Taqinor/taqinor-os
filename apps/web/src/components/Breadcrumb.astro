---
/**
 * Fil d'Ariane — visuel discret + JSON-LD BreadcrumbList (W9).
 * `items` : du plus général au plus précis. Le dernier élément est la page
 * courante (sans lien). Les `href` relatifs sont résolus en URL absolues pour
 * le JSON-LD (Astro.site).
 */
interface Crumb {
  label: string;
  href?: string;
}
interface Props {
  items: Crumb[];
  /** Ton clair pour fond sombre (défaut) ou foncé pour fond clair. */
  tone?: 'light' | 'dark';
}
const { items, tone = 'light' } = Astro.props;

const abs = (href?: string) => (href ? new URL(href, Astro.site).href : undefined);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: items.map((c, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: c.label,
    ...(abs(c.href) ? { item: abs(c.href) } : {}),
  })),
};

const txt = tone === 'dark' ? 'text-encre-faint' : 'text-lune-faint';
const link = tone === 'dark' ? 'hover:text-encre' : 'hover:text-lune';
---

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

<nav aria-label="Fil d'Ariane" class={`mx-auto max-w-6xl px-4 pt-6 text-xs ${txt}`}>
  <ol class="flex flex-wrap items-center gap-x-2 gap-y-1">
    {items.map((c, i) => (
      <li class="flex items-center gap-x-2">
        {c.href && i < items.length - 1 ? (
          <a href={c.href} class={`transition-colors ${link}`}>{c.label}</a>
        ) : (
          <span aria-current="page">{c.label}</span>
        )}
        {i < items.length - 1 && <span aria-hidden="true">/</span>}
      </li>
    ))}
  </ol>
</nav>
