---
/**
 * Fil d'Ariane — visuel discret + JSON-LD BreadcrumbList (W9).
 * `items` : du plus général au plus précis. Le dernier élément est la page
 * courante (sans lien). Les `href` relatifs sont résolus en URL absolues pour
 * le JSON-LD (Astro.site).
 *
 * W166 — séparateur chevron directionnel : se retourne en RTL via
 * `[dir=rtl]` (rotate 180°), invisible aux lecteurs d'écran (aria-hidden).
 *
 * W312 — le libellé « Accueil »/« Home »/« الرئيسية » du premier maillon est
 * repris depuis le dictionnaire i18n (`breadcrumb.home`), jamais depuis la
 * chaîne codée en dur que chaque appelant passe encore : dès que ce premier
 * item pointe vers la racine d'une locale (`/`, `/en`, `/ar`, avec ou sans
 * barre finale), son `label` est remplacé ici. Aucun des ~100 appels
 * `<Breadcrumb items={...} />` n'a besoin d'être modifié.
 */
import { LOCALES } from '../i18n/config';
import { getLocaleFromPath, useTranslations } from '../i18n/utils';

interface Crumb {
  label: string;
  href?: string;
}
interface Props {
  items: Crumb[];
  /** Ton clair pour fond sombre (défaut) ou foncé pour fond clair. */
  tone?: 'light' | 'dark';
}
const { items: rawItems, tone = 'light' } = Astro.props;
const t = useTranslations(getLocaleFromPath(Astro.url.pathname));

/** Racines de locale reconnues comme « accueil » : /, /en, /ar (barre finale optionnelle). */
const localeRoots = new Set<string>(['/', ...LOCALES.flatMap((l) => [`/${l}`, `/${l}/`])]);
const isHomeHref = (href?: string) => !!href && localeRoots.has(href);

const items = rawItems.map((item, i) =>
  i === 0 && isHomeHref(item.href) ? { ...item, label: t('breadcrumb.home') } : item,
);

const abs = (href?: string) => (href ? new URL(href, Astro.site).href : undefined);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: items.map((c, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: c.label,
    ...(abs(c.href) ? { item: abs(c.href) } : {}),
  })),
};

const txt = tone === 'dark' ? 'text-encre-faint' : 'text-lune-faint';
const link = tone === 'dark' ? 'hover:text-encre' : 'hover:text-lune';
---

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

<nav aria-label={t('breadcrumb.label')} class={`mx-auto max-w-6xl px-4 pt-6 text-xs ${txt}`}>
  <ol class="flex flex-wrap items-center gap-x-2 gap-y-1">
    {items.map((c, i) => (
      <li class="flex items-center gap-x-2">
        {c.href && i < items.length - 1 ? (
          <a href={c.href} class={`transition-colors ${link}`}>{c.label}</a>
        ) : (
          <span aria-current="page">{c.label}</span>
        )}
        {i < items.length - 1 && (
          <svg
            aria-hidden="true"
            width="10"
            height="10"
            viewBox="0 0 10 10"
            fill="none"
            class="breadcrumb-sep shrink-0"
            style="opacity:0.5;"
          >
            {/* Chevron pointing right in LTR; CSS flips it in RTL via [dir=rtl] */}
            <polyline
              points="3,1 7,5 3,9"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>
        )}
      </li>
    ))}
  </ol>
</nav>

<style>
  /* Flip the chevron in RTL contexts so it always points "forward" in reading direction */
  :global([dir="rtl"]) .breadcrumb-sep {
    transform: scaleX(-1);
  }
</style>
