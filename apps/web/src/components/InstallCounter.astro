---
/**
 * WJ35 / WC5-WC6 — InstallCounter : compteur animé, chiffre RÉEL uniquement.
 * Depuis 2026-07-05 il affiche la PRODUCTION mesurée cumulée de la flotte
 * suivie (MEASURED_FLEET_LIFETIME_MWH, realisations.ts) — plus la capacité
 * installée (le total de puissance posée a été retiré du site par le
 * fondateur). Aucun nombre fabriqué ; si la flotte mesurée est vide, le
 * composant ne rend rien (même discipline que <Testimonials/> / <StarRating/>).
 *
 * Reduced-motion : le compte-up (0 → valeur finale) est gated
 * `prefers-reduced-motion: no-preference` — sous reduced-motion la valeur
 * finale s'affiche directement (voir script). Zéro CLS : la largeur finale
 * est réservée avant toute animation (src/lib/countup.ts reserveWidth).
 */
import { MEASURED_FLEET_LIFETIME_MWH } from '../lib/realisations';

// WC5/WC6 (2026-07-05) : on n'affiche plus la CAPACITÉ installée (« 43,48 kWc »,
// retirée du site par décision du fondateur) mais la PRODUCTION réellement
// MESURÉE de la flotte suivie (MWh) — un chiffre de preuve, pas de capacité.
const totalMwhLabel = MEASURED_FLEET_LIFETIME_MWH.toLocaleString('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
const hasData = MEASURED_FLEET_LIFETIME_MWH > 0;
---

{hasData && (
  <div class="install-counter" data-install-counter>
    <div class="install-counter__item">
      <p class="install-counter__value fig lum" data-tally data-final={totalMwhLabel} aria-hidden="true">{totalMwhLabel}</p>
      <p class="install-counter__label tech-label" data-i18n data-fr="MWh produits et mesurés" data-en="MWh produced and measured" data-ar="ميغاواط-ساعة مُنتَجة ومقيسة">
        MWh produits et mesurés
      </p>
    </div>
    <p class="sr-only">
      {totalMwhLabel} MWh produits et mesurés — cumul du suivi de production en temps réel.
    </p>
  </div>
)}

<style>
  .install-counter {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .install-counter__value {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-variant-numeric: tabular-nums;
  }
  .install-counter__label {
    margin-top: 0.25rem;
    color: var(--color-lune-faint, #8d96b4);
  }
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>

<script>
  import { formatFrame, shouldDigitRoll, reserveWidth } from '../lib/countup';

  const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;

  function countUp(el: HTMLElement) {
    const finalText = el.dataset.final ?? el.textContent ?? '';
    if (!finalText) return;
    reserveWidth(el);
    if (reduce || !shouldDigitRoll(finalText)) {
      el.textContent = finalText;
      return;
    }
    const dur = 1100;
    let start: number | null = null;
    function frame(t: number) {
      if (start === null) start = t;
      const p = Math.min(1, (t - start) / dur);
      const e = 1 - Math.pow(1 - p, 3);
      el.textContent = formatFrame(finalText, e);
      if (p < 1) requestAnimationFrame(frame);
      else el.textContent = finalText;
    }
    requestAnimationFrame(frame);
  }

  const nodes = document.querySelectorAll<HTMLElement>('[data-install-counter] [data-tally]');
  if (nodes.length === 0) {
    // rien à faire
  } else if (reduce || !('IntersectionObserver' in window)) {
    nodes.forEach((el) => { el.textContent = el.dataset.final ?? el.textContent; });
  } else {
    const io = new IntersectionObserver(
      (entries, obs) => {
        for (const entry of entries) {
          if (!entry.isIntersecting) continue;
          countUp(entry.target as HTMLElement);
          obs.unobserve(entry.target);
        }
      },
      { rootMargin: '0px 0px -10% 0px', threshold: 0.2 },
    );
    nodes.forEach((el) => io.observe(el));
  }
</script>
