---
/**
 * Section vidéo de chantier — clic pour lire (la vidéo n'est jamais
 * préchargée : seule l'affiche ~250 Ko est servie au chargement).
 * Montage narratif sur les installations réelles (coupe A « calme » par
 * défaut ; la coupe B et le choix final : /media-test, page privée).
 *
 * W67 — i18n : prose, aria-label et alt traduits (FR/EN/AR). Les NOMS DE LIEUX
 * (El Jadida, Nouaceur) et tous les chemins /videos/... restent identiques dans
 * toutes les langues. Rendu FR inchangé (branche `fr` = strings actuels mot
 * pour mot).
 *
 * W179 — hover-zoom standardisé à scale(1.04) (réduit-mouvement safe).
 * W182 — framing palette nuit/laiton, dimensions explicites anti-CLS,
 *         preload="none" + poster sur la vidéo, considération save-data/mobile.
 * W269 — « cinéma du chantier » : mouvement réel. Réutilise la technique
 *         différée-muette-en-boucle du héros (index.astro) : au scroll dans
 *         le champ (IntersectionObserver, gated reduced-motion + saveData),
 *         l'affiche est remplacée par une boucle muette courte (3–6 s, même
 *         fichier chantier-a.mp4 — aucun nouvel asset) qui joue en fondu ;
 *         le bouton play reste superposé pour la lecture complète, avec son,
 *         sans boucle, contrôles natifs. Jamais de préchargement bloquant :
 *         `preload="none"`, chargement déclenché uniquement par
 *         l'intersection (comme le héros est déclenché par l'interaction).
 * W346 — la façade clic-pour-lire (affiche + bouton play + injection du
 *         <video> réel au clic) est désormais LiteVideo.astro, un primitif
 *         générique extrait d'ici. Ce composant garde SA prose i18n et
 *         SON enrichissement propre (la boucle teaser W269, superposée en
 *         `absolute inset-0` par-dessus LiteVideo) — la boucle s'accroche à
 *         l'événement `litevideo:play` de LiteVideo pour se couper avant que
 *         la lecture complète ne démarre. Rendu FR inchangé.
 * WB24 — captionsSrc/captionsLang passés à LiteVideo dès qu'un vrai fichier
 *         VTT existe pour chantier-a.mp4 (WCAG 1.2.2). Aucun fichier n'est
 *         disponible aujourd'hui : les props restent `undefined`, donc aucun
 *         <track> n'est rendu — plomberie prête, rendu inchangé.
 */
import { getLocaleFromPath } from '../i18n/utils';
import type { Locale } from '../i18n/config';
import LiteVideo from './LiteVideo.astro';

const locale = getLocaleFromPath(Astro.url.pathname);

const STR: Record<
  Locale,
  { eyebrow: string; title: string; lead: string; imgAlt: string; playLabel: string }
> = {
  fr: {
    eyebrow: '30 secondes de chantier — installations réelles',
    title: "Regardez l'équipe au travail",
    lead: "Portage, pose, mise en service, et le soleil sur les panneaux d'El Jadida. Images brutes de nos chantiers de Nouaceur et El Jadida — sans mise en scène.",
    imgAlt: 'Deux installateurs Taqinor fixant un panneau solaire sur un toit-terrasse',
    playLabel: 'Lire la vidéo de chantier',
  },
  en: {
    eyebrow: '30 seconds on site — real installations',
    title: 'Watch the team at work',
    lead: 'Carrying, mounting, commissioning, and the sun on the panels of El Jadida. Raw footage from our sites in Nouaceur and El Jadida — nothing staged.',
    imgAlt: 'Two Taqinor installers fixing a solar panel onto a rooftop terrace',
    playLabel: 'Play the on-site video',
  },
  ar: {
    eyebrow: '30 ثانية من ورشة العمل — تركيبات حقيقية',
    title: 'شاهد الفريق أثناء العمل',
    lead: 'حملٌ وتركيبٌ وتشغيل، والشمس على الألواح في الجديدة. لقطات خام من ورشاتنا في النواصر والجديدة — دون أي إخراج.',
    imgAlt: 'مركِّبان من Taqinor يثبّتان لوحًا شمسيًا على سطح',
    playLabel: 'تشغيل فيديو الورشة',
  },
};
const s = STR[locale] ?? STR.fr;
---

<section class="px-4 py-20 text-white sm:py-24">
  <div class="mx-auto max-w-6xl">
    <div class="flex flex-wrap items-end justify-between gap-4">
      <div>
        <p class="tech-label rule-brass text-brass-300">{s.eyebrow}</p>
        {/* set:html : préserve l'apostrophe brute « l'équipe » exactement comme
            le rendu FR d'origine (une expression Astro l'échapperait en &#39;). */}
        <h2 class="display mt-3 text-3xl text-white sm:text-4xl" set:html={s.title}></h2>
      </div>
      <p class="max-w-sm text-sm leading-relaxed text-lune-soft">
        <Fragment set:html={s.lead} />
      </p>
    </div>

    <!--
      W182 — Framing palette nuit/laiton :
        • Bordure laiton (border-brass-400/40) + anneau de lueur douce
        • Dimensions explicites sur l'affiche (anti-CLS : 16/9, 1600x900)
        • preload="none" sur la video (chargée à la demande)
        • poster="/videos/chantier-poster.webp" sur la video (premier frame visible)
        • W179 : group-hover scale-[1.04] (standardisé, était 1.02)
      W346 — la façade clic-pour-lire elle-même est LiteVideo (affiche +
        bouton play + injection du <video> réel au clic). La boucle teaser
        W269 est superposée en `absolute inset-0` par-dessus, dans le même
        conteneur `border-brass-400/40` qu'avant (rendu inchangé).
    -->
    <div
      id="chantier-player"
      class="relative mt-8 border border-brass-400/40"
      style="box-shadow: 0 0 0 1px rgb(232 181 74 / 0.08), 0 24px 60px -20px rgb(0 0 0 / 0.7);"
    >
      <LiteVideo
        id="chantier-lite-video"
        src="/videos/chantier-a.mp4"
        poster="/videos/chantier-poster"
        alt={s.imgAlt}
        playLabel={s.playLabel}
        aspectRatio="16/9"
        posterWidth={1600}
        posterHeight={900}
        captionsSrc={undefined}
        captionsLang={undefined}
      />
      {/* W269 — boucle teaser muette (3–6 s), jamais préchargée : `src` posé
          uniquement par le script au moment de l'intersection. Fondu depuis
          l'affiche (opacity-0 → opacity-100), jamais de saut visuel. Superposée
          par-dessus la façade LiteVideo (pointer-events: none — le clic passe
          au bouton play de LiteVideo en dessous). */}
      <video
        id="chantier-teaser"
        class="chantier-teaser pointer-events-none absolute inset-0 h-full w-full object-cover opacity-0"
        muted
        loop
        playsinline
        preload="none"
        aria-hidden="true"
        tabindex="-1"
        poster="/videos/chantier-poster.webp"
      ></video>
    </div>
  </div>
</section>

<style>
  /* W269 — fondu de la boucle teaser par-dessus l'affiche (jamais de saut) */
  .chantier-teaser {
    transition: opacity 500ms ease;
  }
  .chantier-teaser.chantier-teaser--visible {
    opacity: 1;
  }
</style>

<script>
  // W269 — Boucle teaser : reprend la technique différée-muette du héros
  // (index.astro « Vidéo héro : différée ») mais déclenchée par l'ENTRÉE dans
  // le champ (IntersectionObserver) plutôt que par le chargement/interaction —
  // cette section est sous la ligne de flottaison. Gated reduced-motion +
  // saveData : sous l'une ou l'autre, l'affiche reste seule (comme le héros).
  // Boucle plafonnée à 6 s (repart à 0) : même fichier chantier-a.mp4, aucun
  // nouvel asset — si le clip est plus court, `loop` natif prend le relais.
  //
  // W346 — le clic-pour-lire lui-même est géré par LiteVideo.astro ; ce script
  // n'écoute plus que `litevideo:play` (émis par LiteVideo juste avant de
  // monter le <video> réel) pour couper la boucle teaser avant la lecture
  // complète (évite un second flux audio/vidéo qui jouerait en double).
  const wrap = document.getElementById('chantier-player');
  const liteVideoRoot = document.getElementById('chantier-lite-video');
  const teaser = document.getElementById('chantier-teaser') as HTMLVideoElement | null;

  const motionOk = matchMedia('(prefers-reduced-motion: no-preference)').matches;
  // @ts-expect-error saveData non typé partout
  const saveData = navigator.connection?.saveData === true;

  const TEASER_MAX_S = 6;

  if (teaser && motionOk && !saveData && 'IntersectionObserver' in window) {
    let armed = false;
    const arm = () => {
      if (armed) return;
      armed = true;
      teaser.src = '/videos/chantier-a.mp4';
      teaser.addEventListener('timeupdate', () => {
        if (teaser.currentTime >= TEASER_MAX_S) teaser.currentTime = 0;
      });
      teaser.play().then(() => teaser.classList.add('chantier-teaser--visible')).catch(() => {});
    };
    const io = new IntersectionObserver(
      (entries, obs) => {
        for (const entry of entries) {
          if (!entry.isIntersecting) continue;
          arm();
          obs.disconnect();
        }
      },
      { rootMargin: '0px 0px -10% 0px', threshold: 0.25 },
    );
    io.observe(wrap ?? teaser);
  }

  liteVideoRoot?.addEventListener('litevideo:play', () => {
    // Stoppe ET masque la boucle teaser avant que LiteVideo ne monte la
    // lecture complète — le teaser est un frère DOM de LiteVideo (superposé
    // en absolute inset-0 par-dessus, ordre source), donc rester visible le
    // laisserait recouvrir le <video> réel injecté par LiteVideo.
    teaser?.pause();
    teaser?.classList.remove('chantier-teaser--visible');
    if (teaser) teaser.style.display = 'none';
  });
</script>
