---
/**
 * Teaser de réassurance « garanties » (W16) — bloc compact repris UNIQUEMENT
 * des chiffres déjà publiés sur /garanties : 12 ans produit, 30 ans de
 * performance linéaire (≥ 87,4 %), 10 ans onduleur & batterie, 20 ans structure, 2 ans
 * main-d'œuvre, + monitoring Deye Cloud avec accès client. AUCUN délai de
 * réponse (SLA) ni politique de sous-performance inventés. Renvoie vers
 * /garanties. Pensé pour les sections sombres (accueil, résidentiel,
 * professionnel) ; `seam` ajoute une bordure haute si la section précédente est
 * elle aussi sombre.
 *
 * W67 — i18n : prose/labels traduits (FR/EN/AR), CHIFFRES (les nombres, les
 * pourcentages) identiques dans toutes les langues (12 / 30 / 87,4 % / Deye
 * Cloud restent à l'identique) — seul le MOT d'unité localise (« ans » →
 * « years » / « سنة »/« سنوات »/« سنتان »), même règle que /garanties. Le
 * rendu FR reste byte-identique (branche `fr` = strings actuels mot pour mot ;
 * `localizeNavHref('/garanties','fr') === '/garanties'`).
 */
import { getLocaleFromPath } from '../i18n/utils';
import { localizeNavHref } from '../i18n/pages';
import type { Locale } from '../i18n/config';

interface Props {
  /** Bordure haute de séparation (défaut true). */
  seam?: boolean;
}
const { seam = true } = Astro.props;

const locale = getLocaleFromPath(Astro.url.pathname);
const L = (href: string) => localizeNavHref(href, locale);

// Chiffres STRICTEMENT identiques au tableau de /garanties (source publiée) —
// les valeurs (« 12 ans », « 87,4 % »…) ne sont JAMAIS traduites, seuls les
// libellés le sont.
// `monitoring` est scindé autour du nom de marque « Deye Cloud » (invariant
// dans toutes les locales) : seuls les mots autour sont traduits, le littéral
// « Deye Cloud » reste dans le corps rendu (et donc identique partout).
const STR: Record<
  Locale,
  {
    eyebrow: string;
    title: string;
    monitoringBefore: string;
    monitoringAfter: string;
    cta: string;
    labels: string[];
  }
> = {
  fr: {
    eyebrow: 'Garanties écrites',
    title: 'De 2 à 30 ans, noir sur blanc',
    monitoringBefore: 'Et un monitoring',
    monitoringAfter: 'avec accès client inclus sur chaque installation.',
    cta: 'Voir toutes nos garanties →',
    labels: [
      'Produit panneaux',
      'Performance ≥ 87,4 %',
      'Onduleur & batterie',
      'Structure acier',
      'Main-d’œuvre Taqinor',
    ],
  },
  en: {
    eyebrow: 'Written warranties',
    title: 'From 2 to 30 years, in black and white',
    monitoringBefore: 'Plus',
    monitoringAfter: 'monitoring with client access included on every installation.',
    cta: 'See all our warranties →',
    labels: [
      'Panel product',
      'Performance ≥ 87.4 %',
      'Inverter & battery',
      'Steel structure',
      'Taqinor labour',
    ],
  },
  ar: {
    eyebrow: 'ضمانات مكتوبة',
    title: 'من سنتين إلى 30 سنة، مكتوبة بوضوح',
    monitoringBefore: 'بالإضافة إلى مراقبة',
    monitoringAfter: 'مع وصول العميل المضمَّن في كل تركيب.',
    cta: 'اطّلع على جميع ضماناتنا →',
    labels: [
      'منتج الألواح',
      'الأداء ≥ 87.4 %',
      'العاكس والبطارية',
      'الهيكل الفولاذي',
      'يد عاملة Taqinor',
    ],
  },
};
const s = STR[locale] ?? STR.fr;

// Les NOMBRES sont identiques dans toutes les locales : seul le mot d'unité
// localise (même règle que /garanties : « ans » → « years » / AR).
const YEARS_BY_LOCALE: Record<Locale, string[]> = {
  fr: ['12 ans', '30 ans', '10 ans', '20 ans', '2 ans'],
  en: ['12 years', '30 years', '10 years', '20 years', '2 years'],
  ar: ['12 سنة', '30 سنة', '10 سنوات', '20 سنة', 'سنتان'],
};
const years = YEARS_BY_LOCALE[locale] ?? YEARS_BY_LOCALE.fr;
const items = years.map((yrs, i) => ({ years: yrs, label: s.labels[i] }));
---

<section class={`px-4 py-16 sm:py-20${seam ? ' border-t border-white/10' : ''}`}>
  <div class="mx-auto max-w-6xl">
    <div class="flex flex-wrap items-end justify-between gap-4">
      <div class="v2-rise">
        <p class="tech-label v2-kicker rule-brass text-brass-300">{s.eyebrow}</p>
        <h2 class="display v2-section-title mt-5 text-white">{s.title}</h2>
      </div>
      <p class="v2-rise max-w-sm text-sm leading-relaxed text-lune-soft">
        {s.monitoringBefore} Deye Cloud {s.monitoringAfter}
        <a href={L('/garanties')} class="border-b border-brass-400 pb-0.5 font-semibold text-brass-300 transition-colors hover:text-brass-200">{s.cta}</a>
      </p>
    </div>
    <dl class="mt-10 grid grid-cols-2 gap-x-6 gap-y-8 sm:grid-cols-3 lg:grid-cols-5" data-stagger>
      {items.map((it, i) => (
        <div class="v2-rise" style={`--v2-i:${i}`}>
          <dd class="fig lum whitespace-nowrap text-3xl sm:text-4xl" data-tally>{it.years}</dd>
          <dt class="tech-label mt-2 text-lune-faint">{it.label}</dt>
        </div>
      ))}
    </dl>
  </div>
</section>
