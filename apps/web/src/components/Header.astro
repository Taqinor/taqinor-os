---
/**
 * En-tête partagé — UNE seule nav sur TOUT le site, accueil compris (W28).
 * Navigation principale : Solutions (déroulant), Réalisations, Équipement,
 * Ressources (déroulant), À propos — + CTA « Obtenir mon étude gratuite »
 * (WJ36 : pointe le parcours devis /devis/mon-toit) et téléphone.
 *
 * Les deux déclencheurs de menu déroulant SONT de vrais liens (Solutions →
 * /nos-solutions, Ressources → /guides) : sans JS, le menu reste atteignable
 * (survol souris + focus clavier via CSS, et le lien parent mène au hub). Avec
 * JS : ArrowDown ouvre et focalise le 1er item, Échap referme et rend le focus
 * au déclencheur, aria-expanded reflète l'état. Loi 82-21 (explainer) sort du
 * menu de 1er niveau → vit dans Ressources + le pied de page + les liens
 * contextuels (jamais en nav primaire).
 *
 * W150 — Scroll-reactive: starts transparent over hero, transitions to
 * solid + backdrop-blur + condensed height once scrolled past ~80 px.
 * W151 — Active-page indicator: brass underline + aria-current="page".
 * W163 — Chevrons rotate on open + polished dropdown panels.
 * W164 — Mobile menu: animated panel, phone SVG, LanguageSwitcher inside,
 *         scrollable on small screens.
 * W210 — .glow on primary CTA button.
 * W264 — Solutions dropdown: leading glyphs reuse the SAME per-solution SVG
 *         paths already shipped on the homepage (W58, index.astro
 *         `solutionIcons`) — no new iconography invented. Résidentiel &
 *         Professionnel (the two mass-market entry points) are visually
 *         featured (subtitle line, slightly larger row) over the four more
 *         specialised paths. Ressources is honestly split: financement +
 *         marocains-du-monde are service/offer items (own labelled group),
 *         separate from the editorial/blog group — CSS-only, no JS added.
 * W251 — Header CTA proof fragment: on long-scroll pages (guides/blog) the
 *         sticky CTA pairs with a compact <StarRating/> (WJ35's existing
 *         no-op-safe component reading src/lib/testimonials.ts GOOGLE_RATING).
 *         Renders NOTHING until the founder supplies a real rating (WG5) —
 *         never a placeholder number.
 */
import Logo from './Logo.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';
import StarRating from './StarRating.astro';
import Picture from './Picture.astro';
import { hasRating } from '../lib/testimonials';
import { DEYE_CLOUD_URL, NAP } from '../lib/nap';
import { REALISATIONS } from '../lib/realisations';
import { getLocaleFromPath, stripLocale, useTranslations } from '../i18n/utils';
import { localesForPath, localizeNavHref, QUOTE_JOURNEY_PATH } from '../i18n/pages';

// Locale courante déduite de l'URL ; traductions via dictionnaire (repli FR).
// Le rendu FR reste byte-identique : t() rend les libellés FR existants et
// localizeNavHref('/x','fr') renvoie '/x' inchangé.
const locale = getLocaleFromPath(Astro.url.pathname);
const t = useTranslations(locale);
const rootPath = stripLocale(Astro.url.pathname);
const pageLocales = localesForPath(rootPath);
const L = (href: string) => localizeNavHref(href, locale);

// Solutions — dans cet ordre (W28). Le déclencheur pointe vers /nos-solutions.
// W264 — `featured` : les deux points d'entrée grand public (résidentiel,
// professionnel/industriel) sont visuellement mis en avant dans le déroulant ;
// les quatre chemins plus spécialisés restent listés mais en second plan.
const solutions = [
  { href: '/résidentiel', label: t('nav.residential'), featured: true },
  { href: '/professionnel', label: t('nav.professional'), featured: true },
  { href: '/pompage-solaire', label: t('nav.pumping'), featured: false },
  { href: '/batteries-stockage', label: t('nav.batteries'), featured: false },
  { href: '/maintenance-monitoring', label: t('nav.maintenance'), featured: false },
  { href: '/recharge-voiture-electrique-solaire', label: t('nav.evCharging'), featured: false },
  { href: '/regularization-article-33', label: t('nav.regularization'), featured: false },
];

// W264 — Iconographie du déroulant Solutions : MÊMES tracés SVG que la page
// d'accueil (W58, index.astro `solutionIcons`), indexés par href pour rester
// stables si l'ordre change. Un seul trait, currentColor (teinte brass).
const solutionIcons: Record<string, string> = {
  '/résidentiel': '<path d="M4 13 12 5l8 8" /><path d="M6 11v8h12v-8" /><path d="M10 19v-4h4v4" />',
  '/professionnel': '<path d="M4 21V8l7-3v4l7-3v15" /><path d="M4 21h16" /><path d="M8 12h0M8 16h0M14 12h0M14 16h0" />',
  '/pompage-solaire': '<path d="M12 3v6" /><path d="M5 21c1.6-2 3.2-2 4.8 0s3.2 2 4.8 0 3.2-2 4.4 0" /><path d="M8 9h8l-2 6H10z" />',
  '/batteries-stockage': '<path d="M5 8h14v11H5z" /><path d="M9 5h6v3H9z" /><path d="M12 11v5" /><path d="M9.5 13.5h5" />',
  '/maintenance-monitoring': '<path d="M4 18 9 12l3 3 4-6 4 5" /><path d="M4 21h16" /><circle cx="9" cy="12" r="0.6" /><circle cx="16" cy="9" r="0.6" />',
  '/recharge-voiture-electrique-solaire': '<path d="M5 17h14" /><path d="M5 17V11l2-4h10l2 4v6" /><circle cx="8" cy="17" r="1.4" /><circle cx="16" cy="17" r="1.4" /><path d="M12 3v3" /><path d="M10.5 5h3" />',
  '/regularization-article-33': '<path d="M7 4h7l4 4v12H7z" /><path d="M14 4v4h4" /><path d="M9.5 14l1.5 1.5 3-3.5" />',
};

// W370 — Panneau Solutions à deux colonnes : la carte à droite reprend une
// vraie réalisation Taqinor (photo + chiffre mesuré, src/lib/realisations.ts)
// et bascule au survol/focus de chaque lien. DATA-GATED : seuls les hrefs
// listés ci-dessous ont une réalisation réelle à montrer (les 5 chantiers
// publiés sont TOUS `segment: 'residentiel'` aujourd'hui — la plus grande,
// El Jadida 17,04 kWc, sert aussi de preuve C&I sur /professionnel, verbatim
// la même donnée). Les hrefs absents de cette table (pompage, batteries,
// maintenance, régularisation) n'ont ENCORE aucune photo Taqinor publiée pour
// ce type de chantier : la carte ne rend rien pour eux plutôt que d'inventer
// ou de réutiliser une photo hors-sujet — jamais de placeholder.
const bestRealisation = [...REALISATIONS].sort((a, b) => b.kwcNum - a.kwcNum)[0];
const solutionPreview: Record<string, { photo: string; alt: string; ville: string; kwc: string; production: string | null }> = {
  '/résidentiel': {
    photo: bestRealisation.photos[0].name,
    alt: bestRealisation.photos[0].alt,
    ville: bestRealisation.ville,
    kwc: bestRealisation.kwc,
    production: bestRealisation.production,
  },
  '/professionnel': {
    photo: bestRealisation.photos[0].name,
    alt: bestRealisation.photos[0].alt,
    ville: bestRealisation.ville,
    kwc: bestRealisation.kwc,
    production: bestRealisation.production,
  },
};
// W370 — Libellés de la carte, mécanisme de repli identique au reste du
// fichier (petite table locale, FR verbatim inchangé).
const previewStr: Record<'fr' | 'en' | 'ar', { measured: string; discover: string }> = {
  fr: { measured: 'kWh/an mesurés', discover: 'Voir cette installation' },
  en: { measured: 'kWh/year measured', discover: 'See this installation' },
  ar: { measured: 'kWh/سنة مقيسة', discover: 'اكتشفوا هذا التركيب' },
};
const previewT = previewStr[locale] ?? previewStr.fr;

// Ressources — le déclencheur pointe vers /guides (repli sans-JS).
// W264 — Split honnête : les items adjacents à un service (financement,
// marocains-du-monde) sont désormais un groupe « Offre » distinct du groupe
// éditorial/blog — ils ne se lisent plus comme du contenu de blog.
const ressourcesOffre = [
  { href: '/financement', label: t('nav.financing') },
  { href: '/marocains-du-monde', label: t('nav.mre') },
  { href: '/loi-82-21', label: t('nav.law') },
];
const ressourcesContenu = [
  { href: '/guides', label: t('nav.guides') },
  { href: '/blog', label: 'Blog' },
  { href: '/faq', label: t('nav.faq') },
  { href: '/produits', label: 'Fiches techniques' },
  { href: '/pourquoi-taqinor', label: t('nav.why') },
];
// W264 — Libellés des deux groupes du déroulant Ressources. Pas de nouvelle
// clé i18n partagée (portée limitée à Header.astro) : petite table locale,
// même mécanisme de repli FR que le reste du fichier.
const ressourcesGroupLabels: Record<'fr' | 'en' | 'ar', { offre: string; contenu: string }> = {
  fr: { offre: 'Nos services', contenu: 'Guides & actualités' },
  en: { offre: 'Our services', contenu: 'Guides & news' },
  ar: { offre: 'خدماتنا', contenu: 'أدلة وأخبار' },
};
const ressourcesGroups = ressourcesGroupLabels[locale] ?? ressourcesGroupLabels.fr;

// W340 — « Espace client » : lien EXTERNE vers le vrai portail Deye Cloud
// (DEYE_CLOUD_URL, source unique lib/nap.ts) — jamais passé par L() puisque
// ce n'est pas une route interne. Même mécanisme de repli local que les
// autres petites tables de ce fichier.
const espaceClientLabel = locale === 'en' ? 'Client area' : locale === 'ar' ? 'الفضاء الخاص' : 'Espace client';

// W251 — Pages longues (guides/blog) : la preuve sociale compacte accompagne
// le CTA brass au lieu du bouton seul. `showProof` combine « bonne page » ET
// « donnée réelle disponible » — sur toute autre page, ou tant que
// GOOGLE_RATING n'est pas renseigné par le fondateur, rien ne change ici.
const isLongScrollPage = rootPath === '/guides' || rootPath.startsWith('/guides/') ||
  rootPath === '/blog' || rootPath.startsWith('/blog/');
const showHeaderProof = isLongScrollPage && hasRating();

// Liste à plat conservée pour la détection de page active + le menu mobile
// (ordre inchangé pour ne pas perturber l'existant hors dropdown desktop).
const ressources = [
  { href: '/guides', label: t('nav.guides') },
  { href: '/blog', label: 'Blog' },
  { href: '/faq', label: t('nav.faq') },
  { href: '/produits', label: 'Fiches techniques' },
  { href: '/loi-82-21', label: t('nav.law') },
  { href: '/pourquoi-taqinor', label: t('nav.why') },
  { href: '/financement', label: t('nav.financing') },
  { href: '/marocains-du-monde', label: t('nav.mre') },
];

// W151 — Détecter la page active pour l'indicateur dans la nav desktop.
// rootPath est déjà sans préfixe de locale (ex. "/realisations", "/").
const isActive = (href: string) => {
  const clean = href.replace(/\/$/, '') || '/';
  const current = rootPath.replace(/\/$/, '') || '/';
  return current === clean || (clean !== '/' && current.startsWith(clean + '/'));
};

// Indicateur Solutions actif si on est sur /nos-solutions ou une sous-page.
const solutionsActive = isActive('/nos-solutions') ||
  solutions.some((s) => isActive(s.href));
const ressourcesActive = isActive('/guides') ||
  ressources.some((r) => isActive(r.href));

const linkBase =
  'group/link relative text-sm font-medium text-lune-soft transition-colors hover:text-white';
// W151 — variante active : texte blanc + indicateur brass visible au repos.
const linkBaseActive =
  'group/link relative text-sm font-medium text-white';
// W311 — inset-inline-start-0 (logique) au lieu de left-0 : le soulignement
// grandit depuis le bon côté (début de ligne) sous dir="rtl" au lieu de
// rester ancré à gauche physique.
const underline =
  'absolute -bottom-1 inset-inline-start-0 h-0.5 w-0 bg-brass-400 transition-all duration-200 group-hover/link:w-full';
// W151 — underline actif : toujours pleine largeur, couleur brass.
const underlineActive =
  'absolute -bottom-1 inset-inline-start-0 h-0.5 w-full bg-brass-400';
// Classes de révélation du panneau : survol, focus clavier OU classe .is-open (JS).
const menuReveal =
  'invisible translate-y-1 opacity-0 transition-all duration-150 group-hover:visible group-hover:translate-y-0 group-hover:opacity-100 group-focus-within:visible group-focus-within:translate-y-0 group-focus-within:opacity-100 group-[.is-open]:visible group-[.is-open]:translate-y-0 group-[.is-open]:opacity-100';
const itemClass =
  'block px-3 py-2 text-sm text-lune-soft transition-colors hover:bg-white/5 hover:text-white focus:bg-white/5 focus:text-white focus:outline-none';
---

{/* W150 — Spacer keeps the page layout stable; the header is sticky/fixed-like
    but uses `sticky` which doesn't remove from flow, so no spacer needed for
    `sticky`. The header chrome transitions its own bg/blur only — zero CLS. */}
<header
  id="site-header"
  class="sticky top-0 z-50 border-b border-transparent bg-transparent transition-[background-color,border-color,backdrop-filter] duration-300 motion-reduce:transition-none"
>
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-2 px-4 py-3 sm:gap-4" id="header-inner">
    <a href={L('/')} aria-label="TAQINOR — accueil">
      <Logo size={24} theme="dark" />
    </a>
    <nav class="hidden items-center gap-7 lg:flex" aria-label={t('nav.primary')}>
      <!-- Solutions (déroulant) -->
      <div class="dropdown group relative" data-dropdown>
        <a
          href={L('/nos-solutions')}
          class={`flex items-center gap-1 ${solutionsActive ? linkBaseActive : linkBase}`}
          data-dropdown-trigger
          aria-haspopup="true"
          aria-expanded="false"
          {solutionsActive ? { 'aria-current': 'page' } : {}}
        >{t('nav.solutions')}
          {/* W163 — chevron: rotates 180° when dropdown is open (.is-open on parent) */}
          <svg
            width="11" height="11" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="2.5" stroke-linecap="round"
            stroke-linejoin="round" aria-hidden="true"
            class="dropdown-chevron opacity-70 transition-transform duration-200 motion-reduce:transition-none"
          ><polyline points="6 9 12 15 18 9"></polyline></svg>
          <span class={solutionsActive ? underlineActive : underline}></span>
        </a>
        {/* W163 — polished panel: rounded, layered shadow, brass top accent.
            W264 — widened (w-72) to fit leading glyphs + featured subtitles.
            W370 — Mega-panel: a second column (preview card, w-64) joins the
            link list once ≥1 real realisation exists to show (solutionPreview).
            CSS-only swap: each link carries data-preview-trigger, each card
            carries data-preview-card + a matching key; :hover/:focus-within on
            an [data-preview-trigger] reveals ONLY the sibling card sharing its
            key (see <style> below) — no JS, keyboard-safe (focus works exactly
            like hover), degrades to "no card" if solutionPreview lacks a href. */}
        <div class={`absolute start-0 top-full z-50 flex items-start pt-3 ${menuReveal}`}>
          <ul
            class="menu-links w-72 overflow-hidden rounded-lg border border-white/10 bg-nuit/95 p-2 shadow-[0_4px_6px_-2px_rgb(0_0_0/0.4),0_12px_40px_-8px_rgb(0_0_0/0.6)] backdrop-blur before:absolute before:inset-x-0 before:top-0 before:h-[2px] before:bg-brass-400/60 relative"
            role="menu" aria-label={t('nav.solutions')}
          >
            <li role="none"><a href={L('/nos-solutions')} role="menuitem" class={`${itemClass} font-semibold text-white`}>{t('nav.allSolutions')}</a></li>
            {solutions.map((s) => (
              <li role="none">
                <a
                  href={L(s.href)}
                  role="menuitem"
                  class={`${itemClass} flex items-center gap-3 ${s.featured ? 'py-2.5' : ''}`}
                  {...(solutionPreview[s.href] ? { 'data-preview-trigger': s.href } : {})}
                >
                  <svg
                    width={s.featured ? 20 : 16} height={s.featured ? 20 : 16}
                    viewBox="0 0 24 24" fill="none" stroke="currentColor"
                    stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"
                    aria-hidden="true"
                    class={`flex-none ${s.featured ? 'text-brass-300' : 'text-lune-faint'}`}
                    set:html={solutionIcons[s.href] ?? ''}
                  />
                  <span class={s.featured ? 'font-semibold text-white' : ''}>{s.label}</span>
                </a>
              </li>
            ))}
          </ul>
          {/* W370 — Colonne de preview : une carte par href avec donnée réelle,
              masquée par défaut, révélée par [data-preview-trigger] survolé/
              focus via CSS pur (voir <style>). La première carte (résidentiel)
              reste visible tant qu'aucun lien n'est survolé/focalisé — état de
              repos cohérent avec le lien "featured" mis en avant en premier. */}
          {Object.keys(solutionPreview).length > 0 && (
            <div class="menu-preview ms-2 hidden w-64 overflow-hidden rounded-lg border border-white/10 bg-nuit shadow-[0_4px_6px_-2px_rgb(0_0_0/0.4),0_12px_40px_-8px_rgb(0_0_0/0.6)] lg:block">
              {Object.entries(solutionPreview).map(([href, p], i) => (
                <a
                  href={L(href)}
                  data-preview-card={href}
                  class:list={['preview-card group/preview', i === 0 ? 'preview-card--default' : '']}
                  tabindex="-1"
                  aria-hidden="true"
                >
                  <div class="relative aspect-[4/3] overflow-hidden">
                    <Picture
                      name={p.photo} alt={p.alt} widths={[1600, 1024, 640]} ratio={4 / 3}
                      sizes="256px" class="h-full w-full object-cover transition-transform duration-500 group-hover/preview:scale-105"
                    />
                    <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-nuit/95 to-transparent px-3 pb-2 pt-8">
                      <span class="fig lum text-lg">{p.kwc}</span>
                    </div>
                  </div>
                  <div class="p-3">
                    <p class="tech-label text-brass-300">{p.ville}</p>
                    {p.production && <p class="mt-1 text-xs text-lune-soft">{p.production.replace(/\/an$/, '')} {previewT.measured}</p>}
                    <p class="mt-2 text-xs font-semibold text-white">{previewT.discover} →</p>
                  </div>
                </a>
              ))}
            </div>
          )}
        </div>
      </div>

      <a
        href={L('/realisations')}
        class={isActive('/realisations') ? linkBaseActive : linkBase}
        {...(isActive('/realisations') ? { 'aria-current': 'page' } : {})}
      >{t('nav.realisations')}<span class={isActive('/realisations') ? underlineActive : underline}></span></a>
      <a
        href={L('/équipement')}
        class={isActive('/équipement') ? linkBaseActive : linkBase}
        {...(isActive('/équipement') ? { 'aria-current': 'page' } : {})}
      >{t('nav.equipment')}<span class={isActive('/équipement') ? underlineActive : underline}></span></a>

      <!-- Ressources (déroulant) -->
      <div class="dropdown group relative" data-dropdown>
        <a
          href={L('/guides')}
          class={`flex items-center gap-1 ${ressourcesActive ? linkBaseActive : linkBase}`}
          data-dropdown-trigger
          aria-haspopup="true"
          aria-expanded="false"
          {...(ressourcesActive ? { 'aria-current': 'page' } : {})}
        >{t('nav.resources')}
          {/* W163 — chevron rotates on open */}
          <svg
            width="11" height="11" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="2.5" stroke-linecap="round"
            stroke-linejoin="round" aria-hidden="true"
            class="dropdown-chevron opacity-70 transition-transform duration-200 motion-reduce:transition-none"
          ><polyline points="6 9 12 15 18 9"></polyline></svg>
          <span class={ressourcesActive ? underlineActive : underline}></span>
        </a>
        {/* W163 — polished panel: rounded, layered shadow, brass top accent.
            W264 — honest split: service-adjacent items (financement,
            marocains-du-monde, loi 82-21) get their own labelled group,
            visually separated from the editorial/blog group — so financing
            reads as an offer, not a blog post. CSS-only, same <ul role="menu">
            keyboard/focus contract as before (ArrowUp/Down still walk every
            [role=menuitem] in DOM order across both groups). */}
        <div class={`absolute start-0 top-full z-50 pt-3 ${menuReveal}`}>
          <ul
            class="w-64 overflow-hidden rounded-lg border border-white/10 bg-nuit/95 p-2 shadow-[0_4px_6px_-2px_rgb(0_0_0/0.4),0_12px_40px_-8px_rgb(0_0_0/0.6)] backdrop-blur before:absolute before:inset-x-0 before:top-0 before:h-[2px] before:bg-brass-400/60 relative"
            role="menu" aria-label={t('nav.resources')}
          >
            <li role="none" class="tech-label px-3 pb-1 pt-1.5 text-brass-300/90" aria-hidden="true">{ressourcesGroups.offre}</li>
            {ressourcesOffre.map((r) => (
              <li role="none"><a href={L(r.href)} role="menuitem" class={itemClass}>{r.label}</a></li>
            ))}
            {/* W340 — Espace client : lien externe (Deye Cloud), pas L() ;
                nouvel onglet, aucun flux de données touché. */}
            <li role="none"><a href={DEYE_CLOUD_URL} rel="noopener noreferrer" target="_blank" role="menuitem" class={itemClass}>{espaceClientLabel}</a></li>
            <li role="none" class="my-1.5 border-t border-white/10" aria-hidden="true"></li>
            <li role="none" class="tech-label px-3 pb-1 pt-1 text-lune-faint" aria-hidden="true">{ressourcesGroups.contenu}</li>
            {ressourcesContenu.map((r) => (
              <li role="none"><a href={L(r.href)} role="menuitem" class={itemClass}>{r.label}</a></li>
            ))}
          </ul>
        </div>
      </div>

      <a
        href={L('/à-propos')}
        class={isActive('/à-propos') ? linkBaseActive : linkBase}
        {...(isActive('/à-propos') ? { 'aria-current': 'page' } : {})}
      >{t('nav.about')}<span class={isActive('/à-propos') ? underlineActive : underline}></span></a>
    </nav>
    <div class="flex items-center gap-1.5 sm:gap-3">
      <LanguageSwitcher path={rootPath} current={locale} locales={pageLocales} />
      <a
        href={`tel:${NAP.phone}`}
        class="hidden items-center gap-1.5 text-sm font-semibold text-lune-soft transition-colors hover:text-white md:flex"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        {NAP.phoneDisplayIntl}
      </a>
      {/* W251 — Proof fragment beside the CTA on long-scroll pages (guides/
          blog) ONLY, and only once a real Google rating exists (WG5) —
          StarRating itself is also no-op-safe, this wrapper just avoids
          reserving any layout space elsewhere. Hidden on narrow mobile
          widths to protect the header's compact row. */}
      {showHeaderProof && (
        <div class="hidden items-center xl:flex">
          <StarRating compact />
        </div>
      )}
      {/* W210 — .glow on primary CTA. WJ36 — the ONE brass action: the quote
          journey (/devis/mon-toit), primary label verbatim. The container
          flexes with the string (no fixed width) — AR runs 25–35 % longer. */}
      <a
        href={L(QUOTE_JOURNEY_PATH)}
        class="glow whitespace-nowrap bg-brass-400 px-3 py-2 text-sm font-bold text-azur-950 transition-colors hover:bg-brass-300 sm:px-4"
      >{t('cta.primary')}</a>
      {/* W164 — Mobile menu toggle (hamburger icon) */}
      <button
        id="menu-toggle"
        class="border border-white/20 p-2 lg:hidden"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label={t('nav.openMenu')}
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>
    </div>
  </div>
  {/* W164 — Mobile menu: animated slide-down panel, scrollable on small screens.
      Uses grid-rows trick for height animation (no JS height measurement needed).
      Reduced-motion: state switches without animate. */}
  <nav
    id="mobile-menu"
    class="grid grid-rows-[0fr] overflow-hidden border-t border-white/10 bg-nuit transition-[grid-template-rows] duration-300 ease-out motion-reduce:transition-none lg:hidden"
    aria-label={t('nav.mobile')}
    aria-hidden="true"
    inert
  >
    <div class="max-h-[calc(100svh-3.5rem)] overflow-y-auto overscroll-contain">
      <div class="flex flex-col gap-5 px-4 py-4">
        <div>
          <a href={L('/nos-solutions')} class="tech-label block text-brass-300">{t('nav.solutions')}</a>
          <ul class="mt-2 flex flex-col gap-2 border-s border-white/10 ps-3">
            {solutions.map((s) => (
              <li><a href={L(s.href)} class="block text-base font-semibold text-white">{s.label}</a></li>
            ))}
          </ul>
        </div>
        <ul class="flex flex-col gap-3">
          <li><a href={L('/realisations')} class="block font-display text-base font-bold text-white">{t('nav.realisations')}</a></li>
          <li><a href={L('/équipement')} class="block font-display text-base font-bold text-white">{t('nav.equipment')}</a></li>
          <li><a href={L('/à-propos')} class="block font-display text-base font-bold text-white">{t('nav.about')}</a></li>
        </ul>
        <div>
          <a href={L('/guides')} class="tech-label block text-brass-300">{t('nav.resources')}</a>
          <ul class="mt-2 flex flex-col gap-2 border-s border-white/10 ps-3">
            {ressources.map((r) => (
              <li><a href={L(r.href)} class="block text-base font-semibold text-white">{r.label}</a></li>
            ))}
            {/* W340 — Espace client : lien externe (Deye Cloud), pas L(). */}
            <li><a href={DEYE_CLOUD_URL} rel="noopener noreferrer" target="_blank" class="block text-base font-semibold text-white">{espaceClientLabel}</a></li>
          </ul>
        </div>
        <ul class="flex flex-col gap-3 border-t border-white/10 pt-4">
          {/* W164 — Inline phone SVG replacing emoji 📞 */}
          <li>
            <a href={`tel:${NAP.phone}`} class="flex items-center gap-2 text-sm font-semibold text-lune-soft">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              {NAP.phoneDisplayIntl}
            </a>
          </li>
          {/* WJ36 — mobile nav primary CTA → quote journey, label verbatim */}
          <li><a href={L(QUOTE_JOURNEY_PATH)} class="glow mt-1 inline-block bg-brass-400 px-4 py-2 text-sm font-bold text-azur-950">{t('cta.primary')}</a></li>
        </ul>
        {/* W164 — LanguageSwitcher inside the mobile menu */}
        <div class="border-t border-white/10 pt-3">
          <LanguageSwitcher path={rootPath} current={locale} locales={pageLocales} />
        </div>
      </div>
    </div>
  </nav>
</header>

<style>
  /* W370 — Mega-panel preview card, CSS-only swap.
     Rest state: only the FIRST card (.preview-card--default, résidentiel)
     shows — matches the first "featured" link in the list. Hovering/
     focusing a [data-preview-trigger] link reveals ITS matching
     [data-preview-card] and hides every other card, including the default.
     Pure sibling-combinator CSS: no JS, and it degrades safely — with no
     hover/focus the default card simply stays put. */
  .menu-preview .preview-card {
    display: none;
  }
  .menu-preview .preview-card--default {
    display: block;
  }
  /* Any trigger hovered/focused inside the link list first hides EVERY card
     (including the default), then the more specific href-matched rule below
     re-shows only the one whose data-preview-card matches the hovered href. */
  .menu-links:has([data-preview-trigger]:hover) ~ .menu-preview .preview-card,
  .menu-links:has([data-preview-trigger]:focus-visible) ~ .menu-preview .preview-card {
    display: none;
  }
  .menu-links:has([data-preview-trigger="/résidentiel"]:hover) ~ .menu-preview [data-preview-card="/résidentiel"],
  .menu-links:has([data-preview-trigger="/résidentiel"]:focus-visible) ~ .menu-preview [data-preview-card="/résidentiel"],
  .menu-links:has([data-preview-trigger="/professionnel"]:hover) ~ .menu-preview [data-preview-card="/professionnel"],
  .menu-links:has([data-preview-trigger="/professionnel"]:focus-visible) ~ .menu-preview [data-preview-card="/professionnel"] {
    display: block;
  }
</style>

<script>
  // ── W150 — Scroll-reactive header ──────────────────────────────────────────
  // Start transparent over the hero; transition to solid once past ~80 px.
  // Uses rAF pattern (same as StickyCta) to batch reads. No layout change —
  // only bg/border/blur visual properties animate, zero CLS.
  const header = document.getElementById('site-header');

  function applyHeaderScroll(scrolled: boolean) {
    if (!header) return;
    if (scrolled) {
      header.classList.add(
        'border-white/10', 'bg-nuit/90', 'backdrop-blur',
      );
      header.classList.remove('border-transparent', 'bg-transparent');
    } else {
      header.classList.add('border-transparent', 'bg-transparent');
      header.classList.remove(
        'border-white/10', 'bg-nuit/90', 'backdrop-blur',
      );
    }
  }

  // Apply on paint to avoid flash if page loads mid-scroll.
  applyHeaderScroll(scrollY > 80);

  let headerTicking = false;
  addEventListener(
    'scroll',
    () => {
      if (headerTicking) return;
      headerTicking = true;
      requestAnimationFrame(() => {
        applyHeaderScroll(scrollY > 80);
        headerTicking = false;
      });
    },
    { passive: true },
  );

  // ── W164 — Mobile menu animated panel ──────────────────────────────────────
  // Uses CSS grid-rows transition (0fr ↔ 1fr) — no JS height measurement,
  // no reflow. Reduced-motion: class toggle still switches state instantly
  // (transition-none in motion-reduce).
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');

  toggle?.addEventListener('click', () => {
    const isOpen = menu?.getAttribute('aria-hidden') === 'false';
    if (isOpen) {
      menu?.classList.replace('grid-rows-[1fr]', 'grid-rows-[0fr]');
      menu?.setAttribute('aria-hidden', 'true');
      // W314 — inert alongside aria-hidden: keeps focusable links behind the
      // closed panel truly unreachable (not just visually/AT-hidden).
      menu?.setAttribute('inert', '');
      toggle.setAttribute('aria-expanded', 'false');
    } else {
      menu?.classList.replace('grid-rows-[0fr]', 'grid-rows-[1fr]');
      menu?.setAttribute('aria-hidden', 'false');
      menu?.removeAttribute('inert');
      toggle.setAttribute('aria-expanded', 'true');
    }
  });

  // ── Déroulants desktop ──────────────────────────────────────────────────────
  // Amélioration progressive (survol + focus marchent déjà en CSS pur).
  // W163 — chevron rotation: toggle .is-open on the dropdown wrapper
  // and let CSS handle the rotation via the [.is-open] selector.
  document.querySelectorAll<HTMLElement>('[data-dropdown]').forEach((dd) => {
    const trigger = dd.querySelector<HTMLElement>('[data-dropdown-trigger]');
    const chevron = trigger?.querySelector<SVGElement>('.dropdown-chevron');
    const items = Array.from(dd.querySelectorAll<HTMLElement>('[role="menuitem"]'));
    if (!trigger) return;
    const open = () => {
      dd.classList.add('is-open');
      trigger.setAttribute('aria-expanded', 'true');
      // W163 — rotate chevron
      chevron?.classList.add('rotate-180');
    };
    const close = () => {
      dd.classList.remove('is-open');
      trigger.setAttribute('aria-expanded', 'false');
      // W163 — reset chevron
      chevron?.classList.remove('rotate-180');
    };

    dd.addEventListener('mouseenter', open);
    dd.addEventListener('mouseleave', close);
    dd.addEventListener('focusout', (e) => {
      if (!dd.contains((e as FocusEvent).relatedTarget as Node | null)) close();
    });

    trigger.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowDown') { e.preventDefault(); open(); items[0]?.focus(); }
    });

    dd.addEventListener('keydown', (e) => {
      const idx = items.indexOf(document.activeElement as HTMLElement);
      if (e.key === 'Escape') { close(); trigger.focus(); }
      else if (e.key === 'ArrowDown' && idx > -1) { e.preventDefault(); items[Math.min(idx + 1, items.length - 1)]?.focus(); }
      else if (e.key === 'ArrowUp' && idx > -1) { e.preventDefault(); (idx === 0 ? trigger : items[idx - 1])?.focus(); }
    });
  });
</script>
