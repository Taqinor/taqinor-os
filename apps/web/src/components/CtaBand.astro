---
/**
 * Bande d'appel finale — version « respiration » : section blanche avec
 * carte bordée de bleu, pour ne plus empiler deux blocs marine au-dessus
 * du pied de page. L'empreinte zellige sert de marqueur.
 */
import ZelligeDivider from './ZelligeDivider.astro';
import { getLocaleFromPath, useTranslations } from '../i18n/utils';
import { quoteJourneyHref } from '../i18n/pages';

interface Props {
  title?: string;
  buttonLabel?: string;
  href?: string;
  /** false si la section précédente est déjà claire (pas de couture nuit→jour) */
  seam?: boolean;
}
// Locale déduite de l'URL ; défauts traduits (repli FR → rendu FR inchangé).
// WJ36 — le lien par défaut est le parcours devis /devis/mon-toit via
// quoteJourneyHref (point de bascule unique de WJ38 pour EN/AR), et le
// libellé par défaut est LE CTA principal du site (cta.primary, verbatim).
const locale = getLocaleFromPath(Astro.url.pathname);
const t = useTranslations(locale);
const defaultHref = quoteJourneyHref(locale);
const {
  title = t('cta.title'),
  buttonLabel = t('cta.primary'),
  href = defaultHref,
  seam = true,
} = Astro.props;
---

{seam && <div class="seam-lumiere" aria-hidden="true"></div>}
<section class="bg-blanc-azur px-4 py-16 text-encre sm:py-20">
  <ZelligeDivider />
  <div class="mx-auto mt-6 max-w-3xl border-2 border-azur-600 bg-blanc px-6 py-10 text-center sm:px-10">
    <p class="tech-label text-azur-600">{t('cta.eyebrow')}</p>
    <h2 class="display v2-section-title mx-auto mt-3 max-w-2xl text-3xl sm:text-4xl">{title}</h2>
    {/* W210 — .glow signature golden halo on the primary CTA */}
    <a
      href={href}
      class="glow mt-8 inline-block bg-brass-400 px-7 py-3.5 text-base font-bold text-azur-950 transition-colors hover:bg-brass-300"
    >{buttonLabel}</a>
    {/* WJ37 — reassurance strip under the primary CTA: builds trust without
        adding a second competing action. Once per band, FR/EN/AR. This
        section is the light (blanc-azur) surface, so use the ink-scale
        token (encre-faint, ≈5.5:1 AA on blanc), not the night-scale lune. */}
    <p class="mt-3 text-sm text-encre-faint">{t('cta.reassurance')}</p>
  </div>
</section>
