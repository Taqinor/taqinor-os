---
interface Props {
  title?: string;
  buttonLabel?: string;
  href?: string;
}
const {
  title = 'Une étude technique gratuite, sans engagement.',
  buttonLabel = 'Demander mon étude',
  href = '/contact#simulateur',
} = Astro.props;
---

<section class="zellige-bg-dark bg-azur-900 px-4 py-16 text-center">
  <p class="tech-label text-azur-200">Étude gratuite</p>
  <h2 class="display mx-auto mt-3 max-w-2xl text-3xl text-white sm:text-4xl">{title}</h2>
  <a
    href={href}
    class="mt-8 inline-block bg-brass-400 px-8 py-3.5 text-base font-bold text-azur-950 transition-colors hover:bg-brass-300"
  >{buttonLabel}</a>
</section>
