---
interface Props {
  title?: string;
  buttonLabel?: string;
  href?: string;
}
const {
  title = 'Une étude technique gratuite, sans engagement.',
  buttonLabel = 'Demander mon étude',
  href = '/contact#simulateur',
} = Astro.props;
---

<section class="grid-paper-dark bg-night px-4 py-16 text-center">
  <p class="tech-label text-amber-400">Étude gratuite</p>
  <h2 class="display mx-auto mt-3 max-w-2xl text-3xl text-paper sm:text-4xl">{title}</h2>
  <a
    href={href}
    class="mt-8 inline-block bg-amber-400 px-8 py-3.5 text-base font-bold text-ink transition-colors hover:bg-amber-300"
  >{buttonLabel}</a>
</section>
