---
/**
 * « Comment ça marche sur votre toit » — schéma illustratif réutilisable de
 * l'installation, à destination d'un visiteur non technique :
 *   soleil → panneaux sur le toit → onduleur → votre maison (autoconsommation)
 *   + réseau (injection du surplus, clin d'œil discret au cadre loi 82-21).
 *
 * 100 % SVG/CSS, aucune dépendance, aucune photo. Voix d'ingénieur, pas de
 * « clip-art écolo ». Statique par défaut ; tout mouvement est CSS, discret,
 * et entièrement neutralisé sous prefers-reduced-motion (le schéma reste
 * complet et lisible sans animation). Aucune propriété de reflow → zéro CLS.
 *
 * Composant autonome : déposer <SchemaInstallation /> sur n'importe quelle
 * page (résidentiel/professionnel/preview) suffit — la promotion est un
 * drop-in. Hérite des tokens « Cinéma du chantier » (nuit/laiton/azur,
 * Archivo/Hanken).
 */
interface Props {
  /** Titre de section ; surchargé selon la page d'accueil. */
  heading?: string;
  /** Sur-titre (kicker). */
  kicker?: string;
}
const {
  heading = "L'énergie, du soleil à votre prise",
  kicker = 'Comment ça marche sur votre toit',
} = Astro.props;

// Icône réutilisée par chaque station (viewBox 56×56, traits hérités currentColor).
---

<section class="schema relative isolate overflow-hidden px-4 py-20 sm:py-28">
  <div class="schema-glow" aria-hidden="true"></div>
  <div class="mx-auto max-w-6xl">
    <p class="tech-label rule-brass text-brass-300">{kicker}</p>
    <h2 class="display mt-5 max-w-2xl text-3xl text-white sm:text-4xl">{heading}</h2>
    <p class="mt-4 max-w-2xl text-base leading-relaxed text-lune-soft sm:text-lg">
      Le même courant suit toujours le même chemin. Vos appareils se servent d'abord ;
      ce que vous ne consommez pas part sur le réseau au lieu d'être perdu.
    </p>

    <div class="schema-flow mt-12" role="list">
      <!-- 1 — Soleil -->
      <figure class="schema-station schema-station--sun" role="listitem">
        <div class="schema-icon" aria-hidden="true">
          <svg viewBox="0 0 56 56" fill="none">
            <circle cx="28" cy="28" r="10" fill="currentColor" />
            <g stroke="currentColor" stroke-width="2.4" stroke-linecap="round">
              <path d="M28 4v7M28 45v7M4 28h7M45 28h7M11 11l5 5M40 40l5 5M45 11l-5 5M16 40l-5 5" />
            </g>
          </svg>
        </div>
        <figcaption>
          <p class="schema-step">01</p>
          <h3 class="schema-title">Le soleil</h3>
          <p class="schema-desc">Le Maroc reçoit 2 800 à 3 400 heures de soleil par an — une ressource gratuite et constante.</p>
        </figcaption>
      </figure>

      <div class="schema-link" aria-hidden="true"><span class="schema-pulse"></span></div>

      <!-- 2 — Panneaux sur le toit -->
      <figure class="schema-station" role="listitem">
        <div class="schema-icon" aria-hidden="true">
          <svg viewBox="0 0 56 56" fill="none">
            <path d="M6 44 L26 30 L50 30 L50 44 Z" fill="currentColor" fill-opacity="0.14" stroke="currentColor" stroke-width="2.2" stroke-linejoin="round" />
            <g stroke="currentColor" stroke-width="1.6" opacity="0.9">
              <path d="M32.5 30 L29 44 M39 30 L37 44 M45.5 30 L45 44" />
              <path d="M9.5 41 L50 41 M16 37 L50 37 M22.5 33 L50 33" />
            </g>
            <path d="M4 47 L52 47" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" opacity="0.5" />
          </svg>
        </div>
        <figcaption>
          <p class="schema-step">02</p>
          <h3 class="schema-title">Les panneaux</h3>
          <p class="schema-desc">Posés sur votre toiture, ils captent la lumière et produisent un courant continu, en silence et sans pièce mobile.</p>
        </figcaption>
      </figure>

      <div class="schema-link" aria-hidden="true"><span class="schema-pulse"></span></div>

      <!-- 3 — Onduleur -->
      <figure class="schema-station" role="listitem">
        <div class="schema-icon" aria-hidden="true">
          <svg viewBox="0 0 56 56" fill="none">
            <rect x="14" y="8" width="28" height="40" rx="3" stroke="currentColor" stroke-width="2.2" />
            <path d="M19 20c3.2 0 3.2-8 6.4-8s3.2 8 6.4 8M24 20c3.2 0 3.2 8 6.4 8s3.2-8 6.4-8" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
            <circle cx="21" cy="40" r="2" fill="currentColor" />
            <path d="M28 36h8M28 40h8M28 44h5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" opacity="0.8" />
          </svg>
        </div>
        <figcaption>
          <p class="schema-step">03</p>
          <h3 class="schema-title">L'onduleur</h3>
          <p class="schema-desc">Il transforme ce courant continu en 220 V — exactement le courant qui alimente vos prises et vos appareils.</p>
        </figcaption>
      </figure>

      <div class="schema-link schema-link--split" aria-hidden="true"><span class="schema-pulse"></span></div>

      <!-- 4 — Le partage : maison d'abord, surplus au réseau -->
      <div class="schema-split" role="listitem">
        <figure class="schema-station schema-station--branch schema-station--house">
          <div class="schema-icon" aria-hidden="true">
            <svg viewBox="0 0 56 56" fill="none">
              <path d="M8 26 L28 10 L48 26" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" />
              <path d="M13 24 V46 H43 V24" stroke="currentColor" stroke-width="2.2" stroke-linejoin="round" />
              <rect x="24" y="32" width="8" height="14" fill="currentColor" fill-opacity="0.22" stroke="currentColor" stroke-width="1.8" />
            </svg>
          </div>
          <figcaption>
            <p class="schema-step schema-step--brass">Autoconsommation</p>
            <h3 class="schema-title">Votre maison d'abord</h3>
            <p class="schema-desc">Le courant alimente en priorité vos appareils. Chaque kilowattheure produit est un kilowattheure que vous n'achetez plus.</p>
          </figcaption>
        </figure>

        <figure class="schema-station schema-station--branch schema-station--grid">
          <div class="schema-icon" aria-hidden="true">
            <svg viewBox="0 0 56 56" fill="none">
              <path d="M28 6 V50" stroke="currentColor" stroke-width="2.2" />
              <path d="M16 16 H40 M14 24 H42" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
              <path d="M28 16 L16 50 M28 16 L40 50 M28 24 L20 40 M28 24 L36 40" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" opacity="0.85" />
              <path d="M18 13 L28 16 L38 13" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </div>
          <figcaption>
            <p class="schema-step schema-step--brass">Injection du surplus</p>
            <h3 class="schema-title">Le réseau, en appoint</h3>
            <p class="schema-desc">Le surplus que vous ne consommez pas est injecté sur le réseau plutôt que perdu — dans le cadre prévu par la loi 82-21.</p>
          </figcaption>
        </figure>
      </div>
    </div>

    <p class="mt-10 max-w-2xl text-xs leading-relaxed text-lune-faint">
      Schéma de principe. La répartition réelle entre autoconsommation et injection dépend de
      votre consommation, de l'orientation de la toiture et du dimensionnement — précisés lors
      de l'étude technique.
    </p>
  </div>
</section>

<style>
  /* ——— Scène « Cinéma du chantier » : nuit, lumière dorée, azur structurel ——— */
  .schema {
    background:
      linear-gradient(to bottom, var(--color-nuit-800), var(--color-nuit));
    border-top: 1px solid rgb(255 255 255 / 0.08);
  }
  /* Lueur solaire diffuse, ancrée en haut à gauche (origine du courant) */
  .schema-glow {
    position: absolute;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    background: radial-gradient(38rem 22rem at 14% 8%, rgb(232 181 74 / 0.1), transparent 60%);
  }

  /* Flux : empilé sur mobile, ligne sur desktop (grille à colonnes auto). */
  .schema-flow {
    display: grid;
    gap: 0.75rem;
    grid-template-columns: 1fr;
    align-items: stretch;
  }

  .schema-station {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    padding: 1.25rem;
    background: rgb(255 255 255 / 0.04);
    border: 1px solid rgb(255 255 255 / 0.09);
    box-shadow: 0 24px 60px -34px rgb(0 0 0 / 0.85);
  }

  .schema-icon {
    flex: none;
    width: 3.25rem;
    height: 3.25rem;
    color: var(--color-azur-200);
  }
  .schema-icon svg { width: 100%; height: 100%; display: block; }
  /* Le soleil rayonne en doré ; la maison « s'éclaire » en doré (énergie reçue) */
  .schema-station--sun .schema-icon { color: var(--color-brass-300); filter: drop-shadow(0 0 12px rgb(232 181 74 / 0.4)); }
  .schema-station--house .schema-icon { color: var(--color-brass-300); }
  .schema-station--grid .schema-icon { color: var(--color-lune-soft); }

  .schema-step {
    font-family: var(--font-sans);
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-lune-faint);
  }
  .schema-step--brass { color: var(--color-brass-300); }
  .schema-title {
    font-family: var(--font-display);
    font-weight: 800;
    font-stretch: 108%;
    letter-spacing: -0.01em;
    line-height: 1.1;
    font-size: 1.125rem;
    color: #fff;
    margin-top: 0.25rem;
  }
  .schema-desc {
    margin-top: 0.4rem;
    font-size: 0.875rem;
    line-height: 1.55;
    color: var(--color-lune-soft);
  }

  /* Connecteur doré : trait + tête de flèche, avec impulsion d'énergie. */
  .schema-link {
    position: relative;
    align-self: center;
    justify-self: center;
    width: 2px;
    height: 2.25rem;
    background: linear-gradient(to bottom, transparent, var(--color-brass-400), transparent);
  }
  .schema-link::after {
    /* tête de flèche (pointe vers le bas en pile mobile) */
    content: '';
    position: absolute;
    left: 50%;
    bottom: -1px;
    width: 7px;
    height: 7px;
    border-right: 2px solid var(--color-brass-400);
    border-bottom: 2px solid var(--color-brass-400);
    transform: translateX(-50%) rotate(45deg);
  }
  .schema-pulse {
    position: absolute;
    left: 50%;
    top: 0;
    width: 6px;
    height: 6px;
    margin-left: -3px;
    border-radius: 50%;
    background: var(--color-brass-300);
    box-shadow: 0 0 10px 1px rgb(243 204 102 / 0.7);
    opacity: 0;
  }

  /* La paire maison / réseau : empilée, héritée de la même carte braise. */
  .schema-split {
    display: grid;
    gap: 0.75rem;
    grid-template-columns: 1fr;
  }
  .schema-station--branch { height: 100%; }

  /* ——— Desktop : la lecture devient horizontale, gauche → droite ——— */
  @media (min-width: 768px) {
    .schema-flow {
      grid-template-columns: 1fr auto 1fr auto 1fr auto 1.15fr;
      align-items: center;
    }
    .schema-station {
      flex-direction: column;
      height: 100%;
    }
    .schema-link {
      width: 100%;
      height: 2px;
      background: linear-gradient(to right, transparent, var(--color-brass-400), transparent);
    }
    .schema-link::after {
      left: auto;
      right: -1px;
      bottom: 50%;
      transform: translateY(50%) rotate(-45deg);
    }
    .schema-split { gap: 1rem; }
  }

  /* ——— Mouvement : impulsion d'énergie le long des connecteurs ———
       Uniquement hors prefers-reduced-motion. Sans mouvement, le schéma est
       complet : connecteurs dorés + flèches restent visibles et lisibles. */
  @media (prefers-reduced-motion: no-preference) {
    .schema-pulse {
      animation: schema-pulse-y 2.6s ease-in-out infinite;
    }
    .schema-link--split .schema-pulse { animation-delay: 0.4s; }
    @keyframes schema-pulse-y {
      0% { opacity: 0; transform: translateY(0); }
      15% { opacity: 1; }
      85% { opacity: 1; }
      100% { opacity: 0; transform: translateY(2.25rem); }
    }
    @media (min-width: 768px) {
      .schema-pulse { animation-name: schema-pulse-x; }
      @keyframes schema-pulse-x {
        0% { opacity: 0; transform: translateX(0); }
        15% { opacity: 1; }
        85% { opacity: 1; }
        100% { opacity: 0; transform: translateX(calc(100% - 6px)); }
      }
    }
  }
</style>
