---
/**
 * Le fondateur — section de confiance, PHOTO-READY avec repli texte.
 *
 * INTÉGRITÉ : aucun crédit inventé. On ne s'appuie QUE sur les faits déjà
 * publiés sur le site : docteur-ingénieur, 10+ ans de R&D chez Huawei,
 * Ericsson et STMicroelectronics, et la validation personnelle de chaque
 * étude/dimensionnement avant toute commande. Le nom (Reda Kasri) n'apparaît
 * QUE dans la variante portrait ; le repli texte reste anonyme, à l'identique
 * de l'accueil actuel.
 *
 * Pour activer le portrait : déposer le fichier fourni par le fondateur sous
 * public/photos/ (traité par scripts/process-photos.mjs) puis mettre son nom
 * de base ci-dessous. null → repli texte uniquement (aucune image inventée).
 */
const FOUNDER_PHOTO: string | null = null;

import Picture from './Picture.astro';
---

<section class="border-t border-white/10 px-4 py-20 sm:py-28">
  <div class="mx-auto grid max-w-6xl gap-12 lg:grid-cols-[1.1fr_1fr] lg:items-center">
    <div class="v2-rise">
      <p class="tech-label v2-kicker rule-brass text-brass-300">Le fondateur</p>
      <h2 class="display v2-section-title mt-5 max-w-md text-white">Un docteur-ingénieur valide chaque étude, à la main</h2>
      <p class="v2-lead mt-5 max-w-md text-lune-soft">
        Le fondateur de Taqinor a passé plus de dix ans en recherche et développement chez
        <strong class="text-white">Huawei, Ericsson et STMicroelectronics</strong>. Avant toute
        commande, il relit et valide personnellement le dimensionnement : une étude qui sort
        d’ici a été défendue par quelqu’un qui répond du chiffre.
      </p>
      <a href="/à-propos" class="mt-8 inline-block border-b-2 border-brass-400 pb-0.5 text-sm font-bold text-white transition-colors hover:text-brass-300">
        Le fondateur et sa méthode →
      </a>
    </div>
    {FOUNDER_PHOTO ? (
      <figure class="v2-rise">
        <Picture
          name={FOUNDER_PHOTO}
          alt="Reda Kasri, fondateur et docteur-ingénieur de Taqinor"
          widths={[640, 480]}
          ratio={4 / 5}
          sizes="(min-width:1024px) 40vw, 100vw"
          class="w-full object-cover"
        />
        <figcaption class="tech-label mt-3 text-lune-faint">Reda Kasri · fondateur, docteur-ingénieur</figcaption>
      </figure>
    ) : (
      <dl class="grid grid-cols-2 gap-x-6 gap-y-10 border-l-2 border-brass-400/60 pl-6 sm:pl-10" data-stagger>
        <div class="v2-rise" style="--v2-i:0">
          <dd class="font-display text-xl font-bold text-white">Docteur-ingénieur</dd>
          <dt class="tech-label mt-2 text-lune-faint">Chaque étude validée par le fondateur</dt>
        </div>
        <div class="v2-rise" style="--v2-i:1">
          <dd class="fig lum whitespace-nowrap text-4xl" data-tally>10+ ans</dd>
          <dt class="tech-label mt-2 text-lune-faint">De R&D chez Huawei, Ericsson, STMicroelectronics</dt>
        </div>
      </dl>
    )}
  </div>
</section>
