---
/**
 * Empreinte zellige — LE marqueur de section de « L'Étude ». Une seule
 * étoile à huit pointes en filets (deux carrés superposés à 45°), à
 * l'échelle d'une empreinte digitale. Jamais de fond maillé.
 *
 * W168 — présence élevée : motif agrandi (28 px → 4× plus de surface que
 * l'ancien 18 px), opacité augmentée, filets plus épais, lignes de règle
 * plus longues pour un meilleur équilibre visuel.
 *
 * W366 — L'étoile se dessine elle-même : tracé au trait (stroke-dashoffset)
 * au lieu d'un pop scale/rotate, cohérent avec ZelligeSignature. Gated
 * `.v2-js` (posé par V2Enhance, monté par toutes les pages qui utilisent ce
 * composant) ET `prefers-reduced-motion: no-preference`. Sans JS / en
 * reduced-motion : les carrés sont un stroke SVG normal, immédiatement
 * visible — état final identique, pixel pour pixel, au rendu d'avant W366.
 * Zéro CLS : stroke-dashoffset + opacity seuls, jamais de propriété de
 * layout animée.
 */
interface Props {
  /** 'blue' = filets bleus sur fond clair ; 'white' = filets blancs sur fond bleu */
  tone?: 'blue' | 'white';
}
const { tone = 'blue' } = Astro.props;
const stroke = tone === 'white' ? '#ffffff' : '#2342b5';
---

<div class="flex items-center justify-center gap-4 py-3" aria-hidden="true">
  <span class="h-px w-16" style={`background:${stroke};opacity:0.45;`}></span>
  <svg width="28" height="28" viewBox="0 0 28 28" fill="none" opacity="0.80" class="zellige-div-glyph">
    <g stroke={stroke} stroke-width="1.4">
      <rect x="5" y="5" width="18" height="18" class="zellige-div-stroke zellige-div-stroke-1" pathLength="72" />
      <rect x="5" y="5" width="18" height="18" transform="rotate(45 14 14)" class="zellige-div-stroke zellige-div-stroke-2" pathLength="72" />
    </g>
  </svg>
  <span class="h-px w-16" style={`background:${stroke};opacity:0.45;`}></span>
</div>

<style>
  @media (prefers-reduced-motion: no-preference) {
    :global(.v2-js) .zellige-div-stroke {
      stroke-dasharray: 72;
      stroke-dashoffset: 72;
      animation: zelligeDivDraw 0.8s cubic-bezier(0.2, 0.65, 0.25, 1) forwards;
    }
    :global(.v2-js) .zellige-div-stroke-2 {
      animation-delay: 0.22s;
    }
    @keyframes zelligeDivDraw {
      to { stroke-dashoffset: 0; }
    }
  }
</style>
