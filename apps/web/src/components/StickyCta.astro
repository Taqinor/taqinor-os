---
/**
 * CTA collant à l'apparition au scroll : WhatsApp (secondaire) + le CTA
 * principal « Obtenir mon étude gratuite » → parcours devis /devis/mon-toit
 * (WJ36). Barre pleine largeur sur mobile (zone du pouce,
 * safe-area-inset-bottom), pilule compacte en bas à droite sur desktop.
 * Masqué tant que le héros est à l'écran et quand le formulaire
 * (#simulateur) est visible — pour ne jamais doubler le CTA principal.
 * W59 — pilule desktop plus compacte + marge de sécurité au bord, et
 * repli au défilement vers le bas (réapparition au défilement vers le haut)
 * pour ne jamais recouvrir le contenu (cartes, dernière réalisation…).
 * W165 — WhatsApp restyled to brass/night palette + .glow treatment +
 *         safe-area-inset-bottom for notched iPhones.
 * W210 — .glow on the diagnostic CTA button.
 */
import { WHATSAPP_LEADS } from '../lib/nap';
import { pageContextWhatsappText, whatsappLink } from '../lib/whatsapp';
import { getLocaleFromPath, stripLocale, useTranslations } from '../i18n/utils';
import { quoteJourneyHref } from '../i18n/pages';

// Le texte WhatsApp pré-rempli reste FR (il atteint l'équipe FR). Seuls le
// libellé visible et le lien du CTA principal sont localisés (FR = inchangé).
// WJ36 — le CTA principal pointe le parcours devis (/devis/mon-toit) via
// quoteJourneyHref (point de bascule unique de WJ38).
const locale = getLocaleFromPath(Astro.url.pathname);
const t = useTranslations(locale);
const diagHref = quoteJourneyHref(locale);
// WJ50 — préremplissage contextualisé PAR PAGE (chemin racine, sans préfixe de
// locale) : l'équipe ouvre le chat en sachant déjà d'où le client écrit, et
// chaque point d'entrée reste distinguable dans le CRM.
const wa = whatsappLink(WHATSAPP_LEADS, pageContextWhatsappText(stripLocale(Astro.url.pathname)));
---

<div
  id="sticky-cta"
  class="fixed inset-x-0 bottom-0 z-40 hidden border-t border-white/15 bg-nuit/95 px-3 py-2.5 shadow-[0_-8px_30px_-12px_rgb(0_0_0/0.8)] backdrop-blur transition-transform duration-300 ease-out will-change-transform motion-reduce:transition-none sm:inset-x-auto sm:bottom-6 sm:right-6 sm:rounded-full sm:border sm:border-white/15 sm:px-1.5 sm:py-1.5 sm:shadow-[0_14px_40px_-12px_rgb(0_0_0/0.85)]"
  style="padding-bottom: max(0.625rem, env(safe-area-inset-bottom));"
>
  <div class="mx-auto max-w-md sm:max-w-none">
    {/* WJ37 — reassurance strip: mobile-only (the thumb-zone full-width bar),
        hidden on the compact desktop pill where there's no room without
        widening it. One line, centered, brass-adjacent ink — not a second
        CTA, so it never competes with WhatsApp / the primary button. */}
    <p class="mb-1.5 text-center text-[11px] leading-tight text-lune-faint sm:hidden">{t('cta.reassurance')}</p>
    <div class="flex items-center gap-2.5 sm:gap-1.5">
    {/* W165 — WhatsApp: brass/night palette replacing the green, + .glow resting halo */}
    <a
      href={wa}
      rel="noopener"
      class="glow flex flex-1 items-center justify-center gap-2 border border-brass-400/40 bg-nuit px-4 py-2.5 text-sm font-bold text-brass-300 transition-colors hover:border-brass-400/70 hover:bg-white/5 hover:text-brass-200 sm:flex-none sm:gap-1.5 sm:rounded-full sm:px-3.5 sm:py-2 sm:text-[13px]"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="sm:h-[15px] sm:w-[15px]"><path d="M12 2a10 10 0 0 0-8.6 15.1L2 22l5-1.3A10 10 0 1 0 12 2Zm5.4 14.1c-.2.6-1.3 1.2-1.8 1.2-.5.1-1 .2-3.3-.7-2.8-1.1-4.6-4-4.7-4.2-.1-.2-1.1-1.5-1.1-2.9s.7-2 1-2.3c.2-.3.5-.3.7-.3h.5c.2 0 .4 0 .6.4l.9 2.1c.1.2.1.4 0 .6l-.4.6-.5.5c-.2.2-.3.4-.1.7.2.3.9 1.4 1.9 2.3 1.3 1.1 2.3 1.5 2.6 1.6.3.1.5.1.7-.1l1-1.2c.2-.3.4-.2.7-.1l2 1c.3.1.5.2.6.4 0 .1 0 .7-.3 1.4Z"/></svg>
      WhatsApp
    </a>
    {/* W210 — .glow on the brass diagnostic CTA.
        W364 — stable view-transition-name: the one persistent primary CTA
        keeps its own identity across a cross-document transition (no
        cross-fade against itself), independent of whichever photo pair is
        morphing on a given navigation. No-op where the API isn't supported. */}
    <a
      id="sticky-diag"
      href={diagHref}
      class="glow primary-cta-vt flex flex-1 items-center justify-center bg-brass-400 px-4 py-2.5 text-sm font-bold text-azur-950 transition-colors hover:bg-brass-300 sm:flex-none sm:rounded-full sm:px-3.5 sm:py-2 sm:text-[13px]"
    >{t('cta.primary')}</a>
    </div>
  </div>
</div>

<script>
  const bar = document.getElementById('sticky-cta');
  const form = document.getElementById('simulateur');

  // WJ36 — le CTA principal mène TOUJOURS au parcours devis /devis/mon-toit
  // (plus de bascule vers l'ancre #simulateur). Le formulaire embarqué reste
  // observé ci-dessous uniquement pour masquer la barre quand il est visible.

  let pastHero = false;
  let formVisible = false;
  // W59 — repli au défilement vers le BAS, réapparition vers le HAUT, pour ne
  // jamais recouvrir le contenu pendant la lecture. Couche posée PAR-DESSUS
  // pastHero/formVisible (qui gardent seuls le contrôle du `hidden`).
  let collapsed = false;
  let lastY = scrollY;

  function update() {
    bar?.classList.toggle('hidden', !pastHero || formVisible);
    // On glisse la pilule hors-champ (transform, donc zéro reflow) quand on
    // descend ; elle revient dès qu'on remonte ou qu'on s'arrête en haut.
    bar?.classList.toggle('translate-y-[150%]', collapsed);
  }

  let ticking = false;
  addEventListener(
    'scroll',
    () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        const y = scrollY;
        pastHero = y > 480;
        // Direction du défilement (seuil de 6 px pour ignorer le bruit) :
        // bas → replier, haut ou tout en haut → ré-afficher.
        if (y > lastY + 6) collapsed = true;
        else if (y < lastY - 6 || y < 240) collapsed = false;
        lastY = y;
        update();
        ticking = false;
      });
    },
    { passive: true },
  );

  if (form && 'IntersectionObserver' in window) {
    new IntersectionObserver(
      (entries) => {
        formVisible = entries[0].isIntersecting;
        update();
      },
      { rootMargin: '0px 0px -20% 0px' },
    ).observe(form);
  }
</script>
