---
/**
 * CTA collant à l'apparition au scroll : WhatsApp + étude gratuite.
 * Barre pleine largeur sur mobile, pilule compacte en bas à droite sur desktop.
 * Masqué tant que le héros est à l'écran et quand le formulaire
 * (#simulateur) est visible — pour ne jamais doubler le CTA principal.
 * W59 — pilule desktop plus compacte + marge de sécurité au bord, et
 * repli au défilement vers le bas (réapparition au défilement vers le haut)
 * pour ne jamais recouvrir le contenu (cartes, dernière réalisation…).
 */
import { WHATSAPP_LEADS } from '../lib/nap';
import { whatsappLink } from '../lib/whatsapp';

const wa = whatsappLink(WHATSAPP_LEADS, 'Bonjour, je souhaite une étude pour une installation solaire.');
---

<div
  id="sticky-cta"
  class="fixed inset-x-0 bottom-0 z-40 hidden border-t border-white/15 bg-nuit/95 px-3 py-2.5 shadow-[0_-8px_30px_-12px_rgb(0_0_0/0.8)] backdrop-blur transition-transform duration-300 ease-out will-change-transform motion-reduce:transition-none sm:inset-x-auto sm:bottom-6 sm:right-6 sm:rounded-full sm:border sm:px-1.5 sm:py-1.5 sm:shadow-[0_14px_40px_-12px_rgb(0_0_0/0.85)]"
>
  <div class="mx-auto flex max-w-md items-center gap-2.5 sm:max-w-none sm:gap-1.5">
    <a
      href={wa}
      rel="noopener"
      class="flex flex-1 items-center justify-center gap-2 bg-ok-600 px-4 py-2.5 text-sm font-bold text-white transition-opacity hover:opacity-90 sm:flex-none sm:gap-1.5 sm:rounded-full sm:px-3.5 sm:py-2 sm:text-[13px]"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="sm:h-[15px] sm:w-[15px]"><path d="M12 2a10 10 0 0 0-8.6 15.1L2 22l5-1.3A10 10 0 1 0 12 2Zm5.4 14.1c-.2.6-1.3 1.2-1.8 1.2-.5.1-1 .2-3.3-.7-2.8-1.1-4.6-4-4.7-4.2-.1-.2-1.1-1.5-1.1-2.9s.7-2 1-2.3c.2-.3.5-.3.7-.3h.5c.2 0 .4 0 .6.4l.9 2.1c.1.2.1.4 0 .6l-.4.6-.5.5c-.2.2-.3.4-.1.7.2.3.9 1.4 1.9 2.3 1.3 1.1 2.3 1.5 2.6 1.6.3.1.5.1.7-.1l1-1.2c.2-.3.4-.2.7-.1l2 1c.3.1.5.2.6.4 0 .1 0 .7-.3 1.4Z"/></svg>
      WhatsApp
    </a>
    <a
      id="sticky-diag"
      href="/contact#simulateur"
      class="flex flex-1 items-center justify-center bg-brass-400 px-4 py-2.5 text-sm font-bold text-azur-950 transition-colors hover:bg-brass-300 sm:flex-none sm:rounded-full sm:px-3.5 sm:py-2 sm:text-[13px]"
    >Diagnostic gratuit</a>
  </div>
</div>

<script>
  const bar = document.getElementById('sticky-cta');
  const form = document.getElementById('simulateur');

  // Si le diagnostic est sur CETTE page : on y défile, on ne quitte jamais la page
  if (form) {
    (document.getElementById('sticky-diag') as HTMLAnchorElement).href = '#simulateur';
  }

  let pastHero = false;
  let formVisible = false;
  // W59 — repli au défilement vers le BAS, réapparition vers le HAUT, pour ne
  // jamais recouvrir le contenu pendant la lecture. Couche posée PAR-DESSUS
  // pastHero/formVisible (qui gardent seuls le contrôle du `hidden`).
  let collapsed = false;
  let lastY = scrollY;

  function update() {
    bar?.classList.toggle('hidden', !pastHero || formVisible);
    // On glisse la pilule hors-champ (transform, donc zéro reflow) quand on
    // descend ; elle revient dès qu'on remonte ou qu'on s'arrête en haut.
    bar?.classList.toggle('translate-y-[150%]', collapsed);
  }

  let ticking = false;
  addEventListener(
    'scroll',
    () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        const y = scrollY;
        pastHero = y > 480;
        // Direction du défilement (seuil de 6 px pour ignorer le bruit) :
        // bas → replier, haut ou tout en haut → ré-afficher.
        if (y > lastY + 6) collapsed = true;
        else if (y < lastY - 6 || y < 240) collapsed = false;
        lastY = y;
        update();
        ticking = false;
      });
    },
    { passive: true },
  );

  if (form && 'IntersectionObserver' in window) {
    new IntersectionObserver(
      (entries) => {
        formVisible = entries[0].isIntersecting;
        update();
      },
      { rootMargin: '0px 0px -20% 0px' },
    ).observe(form);
  }
</script>
