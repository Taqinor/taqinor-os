---
/**
 * Enrichissement v2 — additif et privé. À placer EN TÊTE du contenu de chaque
 * page /v2*. Rôles :
 *  1. pose le gate `.v2-js` (inline, synchrone) avant le rendu du contenu qui
 *     suit — sans JS, le gate n'est jamais posé et tout reste visible ;
 *  2. importe la couche v2.css (portée .v2) ;
 *  3. exécute l'UNIQUE script de mouvement : IntersectionObserver pour les
 *     révélations + le count-up (sans CLS), et une parallaxe d'en-tête
 *     desktop (transform seulement).
 *
 * Tout mouvement est désactivé sous prefers-reduced-motion: reduce.
 * Aucune dépendance, aucune librairie d'animation.
 *
 * La couche photo (Ken Burns d'en-tête + montée d'échelle au défilement) est
 * importée ci-dessous : elle s'applique donc automatiquement à toute page qui
 * monte <V2Enhance/>, sans marquage par page.
 */
import '../styles/v2.css';
import '../styles/v3-photo-motion.css';
---

<script is:inline>
  document.documentElement.classList.add('v2-js');
</script>

<script>
  import { formatFrame, shouldDigitRoll } from '../lib/countup';

  const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;

  // Verrouille la largeur d'un élément inline pour éviter tout décalage (CLS)
  // pendant l'animation. Un élément de bloc a déjà une largeur stable.
  function lockWidth(el: HTMLElement) {
    if (getComputedStyle(el).display.startsWith('inline')) {
      const w = el.getBoundingClientRect().width;
      el.style.display = 'inline-block';
      el.style.minWidth = w + 'px';
    }
  }

  // Anime un nombre simple de 0 → sa valeur (unité préservée, largeur verrouillée).
  // Pour une valeur COMPOSÉE / plage (« 60–90 % », « 3–7 ans », « 3 à 5 kWc »…),
  // on ne roule RIEN : la largeur est réservée puis la valeur finale est révélée
  // immédiatement (via .v2-in déjà posé), donc aucune image intermédiaire absurde
  // ne peut apparaître. Voir src/lib/countup.ts.
  function countUp(el: HTMLElement) {
    const finalText = el.dataset.v2final ?? (el.dataset.v2final = el.textContent ?? '');
    if (!finalText) return;

    // Réserve la largeur finale dans tous les cas (anti-CLS), avant toute
    // animation, donc même les valeurs composées ne provoquent aucun décalage.
    lockWidth(el);

    // Valeur composée / plage : aucune animation de chiffres — la valeur finale
    // est déjà affichée (révélée par la classe .v2-in). On la laisse telle quelle.
    if (!shouldDigitRoll(finalText)) {
      el.textContent = finalText;
      return;
    }

    const dur = 1100;
    let start: number | null = null;
    function frame(t: number) {
      if (start === null) start = t;
      const p = Math.min(1, (t - start) / dur);
      const e = 1 - Math.pow(1 - p, 3); // easeOutCubic
      el.textContent = formatFrame(finalText, e);
      if (p < 1) requestAnimationFrame(frame);
      else el.textContent = finalText; // valeur finale exacte
    }
    requestAnimationFrame(frame);
  }

  if (!reduce && 'IntersectionObserver' in window) {
    const io = new IntersectionObserver(
      (entries, obs) => {
        for (const entry of entries) {
          if (!entry.isIntersecting) continue;
          const el = entry.target as HTMLElement;
          el.classList.add('v2-in');
          if (el.hasAttribute('data-tally')) countUp(el);
          obs.unobserve(el);
        }
      },
      { rootMargin: '0px 0px -10% 0px', threshold: 0.2 },
    );
    document.querySelectorAll<HTMLElement>('.v2-rise, [data-tally]').forEach((el) => io.observe(el));

    // Parallaxe d'en-tête — desktop uniquement, transform seulement, sur-cadrage
    // léger (scale 1.1) pour ne jamais découvrir de bord. Désactivée < 1024 px.
    const media = document.querySelector<HTMLElement>('.v2-hero-media');
    if (media && window.innerWidth >= 1024) {
      // Le scale(1.1) est déjà posé en CSS statique — on N'applique RIEN au
      // chargement (pas de mutation de l'élément LCP) ; on n'ajoute la
      // translation qu'au premier défilement.
      const over = media.offsetHeight * 0.045; // marge < sur-cadrage (5 %)
      const apply = () => {
        const y = Math.min(window.scrollY * 0.12, over);
        media.style.transform = `scale(1.1) translate3d(0, ${y}px, 0)`;
      };
      let ticking = false;
      window.addEventListener(
        'scroll',
        () => {
          if (ticking) return;
          ticking = true;
          requestAnimationFrame(() => {
            apply();
            ticking = false;
          });
        },
        { passive: true },
      );
    }
  }
</script>
