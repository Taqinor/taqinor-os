---
/**
 * Enrichissement v2 — additif et privé. À placer EN TÊTE du contenu de chaque
 * page /v2*. Rôles :
 *  1. pose le gate `.v2-js` (inline, synchrone) avant le rendu du contenu qui
 *     suit — sans JS, le gate n'est jamais posé et tout reste visible ;
 *  2. importe la couche v2.css (portée .v2) ;
 *  3. exécute l'UNIQUE script de mouvement : IntersectionObserver pour les
 *     révélations + le count-up (sans CLS), et une parallaxe d'en-tête
 *     desktop (transform seulement).
 *
 * Tout mouvement est désactivé sous prefers-reduced-motion: reduce.
 * Aucune dépendance, aucune librairie d'animation.
 *
 * La couche photo (Ken Burns d'en-tête + montée d'échelle au défilement) est
 * importée ci-dessous : elle s'applique donc automatiquement à toute page qui
 * monte <V2Enhance/>, sans marquage par page.
 */
import '../styles/v2.css';
import '../styles/v3-photo-motion.css';
---

<script is:inline>
  document.documentElement.classList.add('v2-js');
</script>

<script>
  import { formatFrame, shouldDigitRoll, scrubProgress } from '../lib/countup';

  const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;

  // Verrouille la largeur d'un élément inline pour éviter tout décalage (CLS)
  // pendant l'animation. Un élément de bloc a déjà une largeur stable.
  function lockWidth(el: HTMLElement) {
    if (getComputedStyle(el).display.startsWith('inline')) {
      const w = el.getBoundingClientRect().width;
      el.style.display = 'inline-block';
      el.style.minWidth = w + 'px';
    }
  }

  // Anime un nombre simple de 0 → sa valeur (unité préservée, largeur verrouillée).
  // Pour une valeur COMPOSÉE / plage (« 60–90 % », « 3–7 ans », « 3 à 5 kWc »…),
  // on ne roule RIEN : la largeur est réservée puis la valeur finale est révélée
  // immédiatement (via .v2-in déjà posé), donc aucune image intermédiaire absurde
  // ne peut apparaître. Voir src/lib/countup.ts.
  function countUp(el: HTMLElement) {
    const finalText = el.dataset.v2final ?? (el.dataset.v2final = el.textContent ?? '');
    if (!finalText) return;

    // Réserve la largeur finale dans tous les cas (anti-CLS), avant toute
    // animation, donc même les valeurs composées ne provoquent aucun décalage.
    lockWidth(el);

    // Valeur composée / plage : aucune animation de chiffres — la valeur finale
    // est déjà affichée (révélée par la classe .v2-in). On la laisse telle quelle.
    if (!shouldDigitRoll(finalText)) {
      el.textContent = finalText;
      return;
    }

    const dur = 1100;
    let start: number | null = null;
    function frame(t: number) {
      if (start === null) start = t;
      const p = Math.min(1, (t - start) / dur);
      const e = 1 - Math.pow(1 - p, 3); // easeOutCubic
      el.textContent = formatFrame(finalText, e);
      if (p < 1) requestAnimationFrame(frame);
      else el.textContent = finalText; // valeur finale exacte
    }
    requestAnimationFrame(frame);
  }

  // W361 — support natif de `animation-timeline: view()` : dans ce cas, les
  // .v2-rise sont déjà pilotées par le compositeur (v2.css), donc la classe
  // .v2-in n'a plus besoin d'être posée pour DÉCLENCHER le fondu (elle reste
  // posée pour compat, cf. v2.css). Les chiffres, eux, ne peuvent pas être
  // "scrubbés" en CSS pur (le texte n'est pas animable) : on les pilote donc
  // ici via un échantillonnage rAF de la position de défilement, cohérent
  // avec la même fenêtre `entry 0% → cover 35%` que l'animation CSS — pour
  // que le nombre et son fondu terminent leur course ensemble, à l'identique
  // visuellement. Dégrade proprement vers le fire-once IO plus bas si le
  // navigateur ne supporte pas `animation-timeline`.
  const supportsScrollTimeline =
    typeof CSS !== 'undefined' && typeof CSS.supports === 'function' && CSS.supports('animation-timeline', 'view()');

  if (!reduce && supportsScrollTimeline) {
    const tallies = Array.from(document.querySelectorAll<HTMLElement>('[data-tally]'));
    // La valeur finale est capturée UNE fois (avant toute mutation), largeur
    // verrouillée immédiatement (zéro CLS dès la première frame scrubbée).
    for (const el of tallies) {
      el.dataset.v2final = el.dataset.v2final ?? el.textContent ?? '';
      lockWidth(el);
    }
    let ticking = false;
    const vh = () => window.innerHeight || document.documentElement.clientHeight;
    const apply = () => {
      const viewportHeight = vh();
      for (const el of tallies) {
        const finalText = el.dataset.v2final ?? '';
        if (!finalText) continue;
        if (el.dataset.v2Done === '1') continue;
        const rect = el.getBoundingClientRect();
        const p = scrubProgress(rect.top, viewportHeight);
        el.textContent = shouldDigitRoll(finalText) ? formatFrame(finalText, p) : finalText;
        if (p >= 1) el.dataset.v2Done = '1'; // valeur finale atteinte, on arrête d'échantillonner cet élément
      }
      ticking = false;
    };
    apply(); // image initiale correcte avant tout scroll (ex. chiffres déjà au-dessus du pli)
    window.addEventListener(
      'scroll',
      () => {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(apply);
      },
      { passive: true },
    );
    // Les .v2-rise sont déjà scrubbées par v2.css (animation-timeline: view());
    // on pose quand même .v2-in pour toute logique dépendante ailleurs, sans
    // dupliquer d'observer.
    const io = new IntersectionObserver(
      (entries, obs) => {
        for (const entry of entries) {
          if (!entry.isIntersecting) continue;
          entry.target.classList.add('v2-in');
          obs.unobserve(entry.target);
        }
      },
      { rootMargin: '0px 0px -10% 0px', threshold: 0.2 },
    );
    document.querySelectorAll<HTMLElement>('.v2-rise').forEach((el) => io.observe(el));
  } else if (!reduce && 'IntersectionObserver' in window) {
    const io = new IntersectionObserver(
      (entries, obs) => {
        for (const entry of entries) {
          if (!entry.isIntersecting) continue;
          const el = entry.target as HTMLElement;
          el.classList.add('v2-in');
          if (el.hasAttribute('data-tally')) countUp(el);
          obs.unobserve(el);
        }
      },
      { rootMargin: '0px 0px -10% 0px', threshold: 0.2 },
    );
    document.querySelectorAll<HTMLElement>('.v2-rise, [data-tally]').forEach((el) => io.observe(el));
  }

  // Parallaxe d'en-tête — desktop uniquement, transform seulement, sur-cadrage
  // léger (scale 1.1) pour ne jamais découvrir de bord. Désactivée < 1024 px.
  // Indépendante de la branche scroll-timeline ci-dessus (ne concerne que
  // .v2-hero-media, jamais les .v2-rise/[data-tally]) : elle doit s'exécuter
  // dans les deux cas, sinon le support natif de `animation-timeline`
  // désactiverait silencieusement la parallaxe du héros — régression W373.
  //
  // W373 — Plan de profondeur : le même listener de scroll déplace AUSSI
  // .hero-depth-layer (si présent sur la page), à un facteur plus LENT
  // (0.045 vs 0.12) que l'affiche — la couche perçue "plus loin" bouge moins
  // vite, illusion de profondeur classique. Purement transform/opacity,
  // jamais posé au chargement (aucune mutation avant le premier scroll) donc
  // aucun impact sur le LCP (l'affiche <img fetchpriority="high"> reste seule
  // responsable du premier rendu).
  if (!reduce && 'IntersectionObserver' in window) {
    const media = document.querySelector<HTMLElement>('.v2-hero-media');
    const depthLayer = document.querySelector<HTMLElement>('.hero-depth-layer');
    if (media && window.innerWidth >= 1024) {
      // Le scale(1.1) est déjà posé en CSS statique — on N'applique RIEN au
      // chargement (pas de mutation de l'élément LCP) ; on n'ajoute la
      // translation qu'au premier défilement.
      const over = media.offsetHeight * 0.045; // marge < sur-cadrage (5 %)
      const depthOver = depthLayer ? depthLayer.offsetHeight * 0.03 : 0;
      const apply = () => {
        const y = Math.min(window.scrollY * 0.12, over);
        media.style.transform = `scale(1.1) translate3d(0, ${y}px, 0)`;
        if (depthLayer) {
          // Facteur ~2.5× plus lent que l'affiche : plan perçu plus profond.
          const dy = Math.min(window.scrollY * 0.045, depthOver);
          depthLayer.style.transform = `translate3d(0, ${dy}px, 0)`;
        }
      };
      let ticking = false;
      window.addEventListener(
        'scroll',
        () => {
          if (ticking) return;
          ticking = true;
          requestAnimationFrame(() => {
            apply();
            ticking = false;
          });
        },
        { passive: true },
      );
    }
  }
</script>
