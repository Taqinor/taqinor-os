---
/**
 * Sélecteur interactif des 3 régimes de la loi 82-21 (décret 2-25-100).
 * La logique vit dans src/lib/regime.ts (testée unitairement).
 */
import { REGIMES } from '../lib/regime';

const inputClass =
  'w-full border border-ink/20 bg-paper px-3 py-2.5 text-sm outline-none transition-colors focus:border-amber-500 focus:ring-2 focus:ring-amber-400/30';
---

<div class="border border-ink/15 bg-sand/60 p-6 sm:p-8">
  <p class="tech-label text-ink-soft">Diagnostic immédiat</p>
  <h2 class="display mt-2 text-2xl">Quel régime s'applique à votre installation ?</h2>
  <p class="mt-1 text-sm text-ink-soft">Trois questions, réponse immédiate.</p>

  <form id="regime-form" class="mt-7 grid gap-4 sm:grid-cols-3">
    <div>
      <label for="rg-power" class="mb-1 block text-sm font-semibold">Puissance (kW)</label>
      <input id="rg-power" type="number" min="0" step="0.1" value="5" class={inputClass} />
    </div>
    <div>
      <label for="rg-grid" class="mb-1 block text-sm font-semibold">Raccordement</label>
      <select id="rg-grid" class={inputClass}>
        <option value="yes" selected>Raccordée au réseau</option>
        <option value="no">Site isolé (non raccordé)</option>
      </select>
    </div>
    <div>
      <label for="rg-voltage" class="mb-1 block text-sm font-semibold">Niveau de tension</label>
      <select id="rg-voltage" class={inputClass}>
        <option value="BT" selected>Basse tension (BT)</option>
        <option value="MT">Moyenne tension (MT)</option>
        <option value="HT">Haute / très haute tension (HT-THT)</option>
      </select>
    </div>
  </form>

  <div id="regime-result" class="mt-7 border border-ink/15 bg-paper p-6 shadow-[6px_6px_0_0_rgb(245_193_0)]">
    <p class="tech-label text-amber-700">Régime applicable</p>
    <h3 id="rg-title" class="display mt-2 text-xl"></h3>
    <p id="rg-summary" class="mt-2 text-sm leading-relaxed text-ink-soft"></p>
    <ul id="rg-obligations" class="mt-4 space-y-2 text-sm"></ul>
    <a href="/contact" class="mt-5 inline-block bg-ink px-5 py-2.5 text-sm font-bold text-paper transition-colors hover:bg-night-soft">
      Faire vérifier mon dossier
    </a>
  </div>
</div>

<script define:vars={{ regimes: REGIMES }}>
  // determineRegime dupliqué ici volontairement minime — la source de vérité
  // typée et testée est src/lib/regime.ts (mêmes seuils).
  function determineRegime(powerKw, gridConnected, voltage) {
    if (!gridConnected) return 'declaration';
    if (powerKw >= 5000) return 'autorisation';
    if (voltage === 'BT' && powerKw < 11) return 'declaration';
    return 'accord';
  }

  const power = document.getElementById('rg-power');
  const grid = document.getElementById('rg-grid');
  const voltage = document.getElementById('rg-voltage');

  function render() {
    const id = determineRegime(parseFloat(power.value) || 0, grid.value === 'yes', voltage.value);
    const info = regimes[id];
    document.getElementById('rg-title').textContent = info.title;
    document.getElementById('rg-summary').textContent = info.summary;
    document.getElementById('rg-obligations').innerHTML = info.obligations
      .map((o) => `<li class="flex gap-2.5"><span class="font-mono font-medium text-amber-500" aria-hidden="true">+</span><span>${o}</span></li>`)
      .join('');
  }

  for (const el of [power, grid, voltage]) el.addEventListener('input', render);
  render();
</script>
