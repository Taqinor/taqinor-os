---
/**
 * /suivi/<token> — SUIVI POST-SIGNATURE CLIENT (QX34 / WJ115).
 *
 * Page privée tokenisée que TAQINOR partage APRÈS la signature : elle affiche la
 * timeline des jalons du projet (proposition acceptée → acompte reçu → matériel
 * commandé → installation → facturé), dérivée côté backend des lignes EXISTANTES
 * (aucun statut muté). Rendu côté serveur (prerender=false) : le frontmatter lit
 * les jalons depuis l'endpoint public/token et n'affiche jamais aucun prix
 * d'achat / marge (le backend ne les envoie pas). noindex=true : page privée.
 *
 * Même discipline de robustesse que /proposition/<token> : rate-limit du SSR,
 * borne de timeout (AbortController), 404 propre sur token invalide, jamais de
 * page blanche. Le chemin est produit par le builder unique côté backend
 * (apps/ventes/utils/client_links.suivi_path) — cette page EST sa landing.
 */
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import { clientIpFromRequest, rateLimit } from '../../lib/rateLimit';

interface Milestone {
  key: string;
  label: string;
  done: boolean;
  date: string | null;
}
interface SuiviResponse {
  reference: string;
  milestones: Milestone[];
}

const API_BASE = (import.meta.env.PUBLIC_API_BASE as string | undefined) ?? 'https://api.taqinor.ma';
const { token } = Astro.params as { token: string };

function suiviEndpoint(apiBase: string, tok: string): string {
  const base = (apiBase || 'https://api.taqinor.ma').replace(/\/+$/, '');
  return `${base}/api/django/public/suivi/${encodeURIComponent(tok)}/`;
}

const SSR_FETCH_TIMEOUT_MS = 8000;
let data: SuiviResponse | null = null;
let errorDetail: string | null = null;
let httpStatus = 200;
let isTimeout = false;

// Même garde que /proposition : un token opaque mais devinable ne doit pas
// pouvoir être bombardé pour sonder des tokens valides. Bucket distinct, généreux
// (un foyer peut relire son suivi plusieurs fois), écrête seulement l'automatisé.
const rl = rateLimit(`suivi-view:${clientIpFromRequest(Astro.request)}`, { limit: 60, windowMs: 60_000 });
if (!rl.allowed) {
  httpStatus = 429;
  errorDetail = 'Trop de tentatives depuis cette connexion — réessayez dans un instant.';
} else if (!token || !token.trim()) {
  httpStatus = 404;
  errorDetail = 'Ce lien de suivi est introuvable ou a expiré.';
} else {
  const controller = new AbortController();
  const timer = setTimeout(() => controller.abort(), SSR_FETCH_TIMEOUT_MS);
  try {
    const res = await fetch(suiviEndpoint(API_BASE, token), {
      headers: { accept: 'application/json' },
      signal: controller.signal,
    });
    httpStatus = res.status;
    if (res.ok) {
      data = (await res.json()) as SuiviResponse;
    } else {
      let detail = '';
      try {
        const body = (await res.json()) as { detail?: string };
        detail = typeof body.detail === 'string' ? body.detail : '';
      } catch {
        detail = '';
      }
      errorDetail =
        detail ||
        (res.status === 404
          ? 'Ce lien de suivi est introuvable ou a expiré.'
          : 'Ce suivi n’est pas accessible pour le moment.');
    }
  } catch (err) {
    httpStatus = 502;
    isTimeout = err instanceof Error && err.name === 'AbortError';
    errorDetail = isTimeout
      ? 'La connexion est lente — ce suivi met plus de temps que prévu à charger. Réessayez dans un instant.'
      : 'Suivi momentanément indisponible. Veuillez réessayer dans un instant.';
  } finally {
    clearTimeout(timer);
  }
}

if (!data && (httpStatus === 404 || httpStatus === 200)) {
  Astro.response.status = httpStatus === 200 ? 404 : httpStatus;
} else if (!data) {
  Astro.response.status = httpStatus;
}

const ok = !!data;
const reference = data?.reference || '';
const milestones: Milestone[] = ok && Array.isArray(data?.milestones) ? data!.milestones : [];
// Étape courante = premier jalon non encore atteint (pour le libellé de tête).
const doneCount = milestones.filter((m) => m.done).length;
const pageTitle = ok ? `Suivi ${reference} | Taqinor` : 'Suivi | Taqinor';
const ogTitle = 'Votre suivi de projet solaire | Taqinor';
---

<Layout
  title={pageTitle}
  description="Le suivi de votre projet solaire Taqinor, étape par étape."
  noindex={true}
  ogTitle={ogTitle}
  ogSlug="proposition"
  ogImageAlt="Taqinor — suivi de votre projet solaire"
>
  {!ok ? (
    <section class="mx-auto flex min-h-[60dvh] max-w-2xl flex-col items-center justify-center px-5 py-24 text-center">
      <div class="rule-brass mx-auto text-brass-300" aria-hidden="true"></div>
      <h1 class="display mt-6 text-3xl text-lune sm:text-4xl">Suivi indisponible</h1>
      <p class="v2-body mt-4 max-w-md">{errorDetail}</p>
      {(isTimeout || httpStatus === 429) ? (
        <a href={Astro.url.href} class="btn-pill mt-8" style="background: var(--color-brass-400); color: var(--color-nuit); border-color: var(--color-brass-400)">
          Réessayer
        </a>
      ) : (
        <a href="/" class="btn-pill mt-8">Retour à l’accueil</a>
      )}
    </section>
  ) : (
    <section class="mx-auto max-w-2xl px-5 py-16 sm:px-8 sm:py-24">
      <p class="tech-label rule-brass text-brass-300">Suivi de votre projet</p>
      <h1 class="display mt-3 text-3xl text-lune sm:text-4xl">Où en est votre installation</h1>
      {reference && (
        <p class="mt-2 text-sm text-lune-faint">
          Référence <span class="fig text-lune" dir="ltr">{reference}</span>
        </p>
      )}
      <p class="v2-body mt-2 text-sm text-lune-soft">
        {doneCount} étape{doneCount > 1 ? 's' : ''} sur {milestones.length} franchie{doneCount > 1 ? 's' : ''}.
      </p>

      <ol class="mt-8 space-y-4">
        {milestones.map((m) => (
          <li class="cine-card flex items-start gap-4 rounded-xl p-4">
            <span
              class={`mt-0.5 flex h-6 w-6 flex-none items-center justify-center rounded-full text-xs font-bold ${m.done ? 'bg-brass-400 text-nuit' : 'border border-white/20 text-lune-faint'}`}
              aria-hidden="true"
            >
              {m.done ? '✓' : ''}
            </span>
            <div class="min-w-0">
              <p class={`text-base font-semibold ${m.done ? 'text-lune' : 'text-lune-faint'}`}>{m.label}</p>
              {m.done && m.date ? (
                <p class="mt-0.5 text-xs text-lune-faint" dir="ltr">{m.date}</p>
              ) : (
                <p class="mt-0.5 text-xs text-lune-faint">
                  {m.done ? 'Fait' : 'À venir'}
                </p>
              )}
            </div>
          </li>
        ))}
      </ol>

      <p class="mt-10 text-sm text-lune-faint">
        Une question sur votre projet ? Contactez votre conseiller Taqinor.
      </p>
    </section>
  )}
</Layout>
