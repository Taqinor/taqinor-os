---
import Layout from '../layouts/Layout.astro';
import { NAP } from '../lib/nap';

// Politique de confidentialité — ton factuel, descriptions honnêtes de ce
// que le site fait réellement (diagnostic + capture fbclid/UTM). Référence
// loi 09-08 (protection des données à caractère personnel, Maroc).
const sections = [
  {
    t: 'Ce que nous collectons',
    p: 'Lorsque vous remplissez le diagnostic solaire, nous collectons : votre nom complet, votre numéro de téléphone, votre ville ou commune, votre type de toiture et votre tranche de facture d’électricité. Vous choisissez aussi si vous préférez être contacté(e) par WhatsApp.',
  },
  {
    t: 'Pourquoi nous les collectons',
    p: 'Pour établir votre étude solaire préliminaire et vous l’envoyer, puis vous recontacter — par WhatsApp et par email — uniquement si vous avez coché la case de consentement. Aucune autre utilisation.',
  },
  {
    t: 'Mesure publicitaire (fbclid et UTM)',
    p: 'Si vous arrivez sur le site depuis une publicité, le lien peut contenir des paramètres techniques (fbclid, utm_source, utm_medium, utm_campaign, utm_content, utm_term). Nous les conservons avec votre demande pour mesurer l’efficacité de nos campagnes — savoir quelle publicité a conduit à quelle demande. Ils ne contiennent ni votre nom ni votre numéro et ne servent qu’à cette mesure.',
  },
  {
    t: 'Qui y a accède, où elles vont',
    p: 'Vos données sont accessibles à l’équipe Taqinor uniquement. Elles ne sont jamais vendues, louées ni cédées à des tiers. Le site est hébergé sur l’infrastructure Cloudflare.',
  },
  {
    t: 'Durée de conservation',
    p: 'Nous conservons votre demande le temps de son traitement commercial, puis aussi longtemps qu’une relation client existe. Vous pouvez demander sa suppression à tout moment (voir ci-dessous).',
  },
  {
    t: 'Vos droits',
    p: `Conformément à la loi 09-08 relative à la protection des personnes physiques à l’égard du traitement des données à caractère personnel, vous disposez d’un droit d’accès, de rectification et de suppression de vos données. Pour l’exercer, écrivez à ${NAP.email} — nous répondons sous des délais raisonnables.`,
  },
  {
    t: 'Consentement',
    p: 'La case à cocher du diagnostic constitue votre consentement explicite à être recontacté(e). Sa date et son heure sont enregistrées avec votre demande. Retirer votre consentement est aussi simple que l’accorder : un message suffit.',
  },
];
---

<Layout
  title="Politique de confidentialité | Taqinor"
  description="Ce que le diagnostic solaire Taqinor collecte, pourquoi, qui y accède, et vos droits (loi 09-08) — en langage clair."
  ogSlug="accueil"
>
  <section class="px-4 py-14 text-white">
    <div class="mx-auto max-w-3xl">
      <p class="tech-label rule-brass cine-in text-brass-300">Loi 09-08 · langage clair</p>
      <h1 class="display cine-in mt-4 text-4xl [animation-delay:120ms]">Politique de confidentialité</h1>
      <p class="cine-in mt-4 max-w-xl leading-relaxed text-white/85 [animation-delay:240ms]">
        Ce que nous collectons, pourquoi, et ce que vous pouvez exiger — sans jargon.
      </p>
    </div>
  </section>

  <!-- Le document, en pleine lumière -->
  <div class="seam-lumiere" aria-hidden="true"></div>
  <section class="bg-blanc-azur px-4 pb-16 pt-6 text-encre"
    ><div class="mx-auto max-w-3xl">
    {sections.map((s, i) => (
      <div class="border-b border-azur-900/15 py-7 first:pt-0">
        <h2 class="display flex items-baseline gap-4 text-xl">
          <span class="fig text-lg text-azur-600">{String(i + 1).padStart(2, '0')}</span>
          {s.t}
        </h2>
        <p class="mt-3 pl-10 text-sm leading-relaxed text-encre-soft">{s.p}</p>
      </div>
    ))}
    <p class="mt-7 text-xs text-encre-faint">
      Dernière mise à jour : juin 2026 — TAQINOR Solutions SARLAU, RC 691213 (Casablanca).
      Voir aussi les <a href="/mentions-legales" class="underline decoration-azur-600 underline-offset-2">mentions légales</a>.
    </p>
    </div>
  </section>
</Layout>
