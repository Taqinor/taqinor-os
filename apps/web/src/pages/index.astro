<style>
  /* W155 — Portrait-crop héro : recadrage en haut sur téléphones verticaux.
     Les mêmes images sont servies ; on décale l'object-position vers le haut
     pour que les panneaux (haut de l'image) restent visibles sur un écran 9:19. */
  @media (orientation: portrait) {
    .hero-portrait-img {
      object-position: center 20%;
    }
  }

  /* Scrim héro RELEVÉ : compense la chaleur du grade « heure dorée » et
     garantit le contraste AA du headline blanc sur la photo. */
  .hero-scrim-v3 {
    --hero-scrim-strength: 0.52;
  }

  /* ── W373 — Plan de profondeur du héros ───────────────────────────────
     Voile de lumière statique (dégradés radiaux seuls, aucune image) posé
     au repos ; le script (V2Enhance) n'anime que sa `transform` au scroll,
     à un facteur plus LENT que le sur-cadrage de l'affiche (couche plus
     profonde = déplacement plus faible, illusion de profondeur classique).
     `opacity` de base très faible pour rester un « souffle », jamais un
     voile qui dégraderait la lisibilité du headline (le scrim reste
     au-dessus en z-index via l'ordre du DOM + la même pile isolate). */
  .hero-depth-layer {
    background:
      radial-gradient(38% 32% at 82% 22%, rgb(232 181 74 / 0.16), transparent 70%),
      radial-gradient(30% 26% at 14% 78%, rgb(232 181 74 / 0.08), transparent 72%);
    opacity: 0.9;
    pointer-events: none;
  }
  @media (prefers-reduced-motion: no-preference) {
    @media (min-width: 1024px) {
      .hero-depth-layer {
        will-change: transform;
      }
    }
  }

  /* ── W368 — CTA magnétique ───────────────────────────────────────────
     Le script (ci-dessous) pose uniquement `transform: translate(x, y)`
     (±8 px max) au pointermove ; cette règle ajoute juste le retour doux à
     l'origine quand le pointeur quitte le bouton (pointerleave retire
     l'inline style, la transition ci-dessous anime le retour). Transform
     seul : jamais de reflow, jamais de CLS. Gated (pointer:fine) +
     reduced-motion dans le script — cette transition CSS elle-même est
     inoffensive sans mouvement (elle ne s'active que si `transform` change,
     ce qui n'arrive que si le script l'anime). */
  @media (prefers-reduced-motion: no-preference) and (pointer: fine) {
    .magnetic-cta {
      transition: transform var(--dur-hover) var(--ease-cine), background-color var(--dur-hover) ease;
      will-change: transform;
    }
  }

  /* ── W271 — Lightbox galerie ────────────────────────────────────────── */
  .gallery-lightbox {
    max-width: min(92vw, 1100px);
    max-height: 90vh;
    border: none;
    background: var(--color-nuit);
