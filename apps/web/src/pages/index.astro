---
import Layout from '../layouts/Layout.astro';
import Article33Ribbon from '../components/Article33Ribbon.astro';
import LeadForm from '../components/LeadForm.astro';
import Faq from '../components/Faq.astro';
import Picture from '../components/Picture.astro';
import VideoChantier from '../components/VideoChantier.astro';
import StickyCta from '../components/StickyCta.astro';
import ZelligeDivider from '../components/ZelligeDivider.astro';
import { NAP } from '../lib/nap';

// PLACEHOLDER(MERYEM): headline + sous-titre du hero — copie provisoire.
const heroTitle = 'Votre électricité, produite sur votre toit.';
const heroSub =
  'Taqinor conçoit, installe et déclare des installations solaires dimensionnées par l’ingénierie — pour villas, industries et hôtels, partout au Maroc.';

// PLACEHOLDER(REDA): nombre réel d'installations à fournir — la tuile centrale
// de la bande de confiance affichera « +N installations » dès qu'il est connu.
const installCount: number | null = null;

// PLACEHOLDER(MERYEM): témoignages provisoires — à remplacer par de vrais
// clients (nom, ville, citation) avant mise en avant publicitaire.
const testimonials = [
  {
    quote:
      'Installation de 9 kWc posée en deux jours, dossier de raccordement géré de bout en bout. La facture est passée de 2 400 MAD à moins de 400 MAD.',
    name: 'H. B.',
    detail: 'Villa, Casablanca',
  },
  {
    quote:
      'Le dimensionnement annoncé correspond exactement à la production mesurée. Suivi en ligne clair, équipe joignable.',
    name: 'S. R.',
    detail: 'Hangar industriel, Tanger',
  },
  {
    quote:
      'Ils ont régularisé notre installation existante dans le cadre de l’Article 33 sans interruption d’activité.',
    name: 'K. M.',
    detail: 'Hôtel, Marrakech',
  },
];

// PLACEHOLDER(MERYEM): FAQ provisoire.
const faq = [
  {
    q: 'Combien coûte une installation solaire résidentielle ?',
    a: 'Cela dépend de votre consommation et de votre toiture. Une villa avec une facture de 1 500 MAD par mois s’équipe typiquement en 4 à 6 kWc. Le formulaire ci-dessous vous donne une fourchette immédiate ; le chiffrage précis est établi après visite technique.',
  },
  {
    q: 'Que dit la loi 82-21 pour les particuliers ?',
    a: 'En basse tension, une installation de moins de 11 kW relève du régime de déclaration : une formalité préalable, pas une autorisation. Taqinor prépare et dépose la déclaration pour vous.',
  },
  {
    q: 'Mon installation existante n’est pas déclarée. Que faire ?',
    a: 'L’Article 33 de la loi 82-21 ouvre une fenêtre de régularisation pour les installations existantes. La fenêtre est ouverte : déposez maintenant. Voir la page Régularisation pour la procédure en 5 étapes.',
  },
  {
    q: 'Combien de temps durent les panneaux ?',
    a: 'Les panneaux sont garantis en performance sur 25 ans (généralement ≥ 84 % de la puissance initiale à 25 ans). Les onduleurs se remplacent typiquement une fois sur la durée de vie de l’installation.',
  },
  {
    q: 'Faut-il des batteries ?',
    a: 'Pas nécessairement. Si votre consommation est principalement diurne, l’autoconsommation directe est le meilleur investissement. Les batteries se justifient pour la consommation nocturne ou la continuité de service — nous le calculons dans l’étude.',
  },
];

// Galerie de chantiers — photos réelles, débrumées, jamais de retouche générative.
const gallery = [
  { name: 'champ-villa', alt: 'Champ de panneaux solaires Taqinor sur toit plat de villa, ciel bleu', widths: [1600, 1024, 640], ratio: 3 / 2, label: 'Champ résidentiel · toit plat' },
  { name: 'villa-zellige', alt: 'Installation solaire Taqinor sur villa marocaine à toiture en zellige turquoise', widths: [1600, 1024, 640], ratio: 4 / 3, label: 'Villa · toiture traditionnelle' },
  { name: 'terrasse-terre-cuite', alt: 'Rangée de panneaux solaires sur toit-terrasse en terre cuite', widths: [1600, 1024, 640], ratio: 3 / 2, label: 'Toit-terrasse · terre cuite' },
  { name: 'equipe-gilet-taqinor', alt: "Installateur en gilet Taqinor posant les rails d'une structure", widths: [1600, 1024, 640], ratio: 1, label: 'Pose des rails · structure' },
  { name: 'entretien-jet', alt: "Nettoyage au jet d'eau d'un champ de panneaux par l'équipe", widths: [1600, 1024, 640], ratio: 1, label: 'Entretien · nettoyage' },
  { name: 'silhouette-acrotere', alt: 'Panneau solaire et chauffe-eau solaire sur acrotère blanc, ciel bleu profond', widths: [1600, 1024, 640], ratio: 4 / 3, label: 'Détail · panneau + chauffe-eau' },
  { name: 'mesure-rails', alt: 'Traçage et mesure des rails de fixation au mètre sur toiture', widths: [1600, 1024, 640], ratio: 4 / 3, label: 'Traçage · mesure des rails' },
  { name: 'equipe-trois', alt: 'Équipe Taqinor de trois installateurs devant une longue rangée de panneaux', widths: [1600, 1024, 640], ratio: 3 / 2, label: 'Équipe · fin de chantier' },
];
---

<Layout
  title="Taqinor — Installations solaires au Maroc, conformes loi 82-21"
  description="Conception, installation et déclaration d'installations solaires pour villas, industries et hôtels au Maroc. Étude gratuite, dimensionnement par l'ingénierie, conformité loi 82-21."
  ogSlug="accueil"
>
  <Article33Ribbon />

  <!-- Hero — vidéo de chantier en lecture auto muette (affiche en repli,
       respect de prefers-reduced-motion, chargement après le reste) -->
  <section class="relative isolate overflow-hidden bg-azur-950 text-white">
    <div class="absolute inset-0 -z-10">
      <picture>
        <source type="image/avif" sizes="100vw"
          srcset="/videos/hero-poster-640.avif 640w, /videos/hero-poster-960.avif 960w, /videos/hero-poster-1600.avif 1600w" />
        <source type="image/webp" sizes="100vw"
          srcset="/videos/hero-poster-640.webp 640w, /videos/hero-poster-960.webp 960w, /videos/hero-poster-1600.webp 1600w" />
        <img src="/videos/hero-poster-1600.webp" alt="" width="1600" height="900"
          loading="eager" decoding="async" fetchpriority="high"
          class="h-full w-full object-cover" />
      </picture>
      <video
        id="hero-video"
        muted
        loop
        playsinline
        preload="none"
        aria-hidden="true"
        tabindex="-1"
        class="absolute inset-0 h-full w-full object-cover opacity-0 transition-opacity duration-700"
      ></video>
      <div class="absolute inset-0 bg-gradient-to-t from-azur-950 via-azur-950/65 to-azur-900/35"></div>
    </div>
    <div class="mx-auto max-w-6xl px-4 pb-12 pt-20 sm:pb-16 sm:pt-28">
      <p class="tech-label rule-brass text-brass-300">Casablanca · Rabat · Marrakech · tout le Maroc</p>
      <h1 class="display mt-5 max-w-3xl text-4xl sm:text-6xl">{heroTitle}</h1>
      <p class="mt-5 max-w-2xl text-base leading-relaxed text-white/85 sm:text-lg">{heroSub}</p>
      <div class="mt-9 flex flex-wrap items-center gap-4">
        <a href="#simulateur" class="bg-brass-400 px-7 py-3.5 text-base font-bold text-azur-950 transition-colors hover:bg-brass-300">
          Estimer mon installation
        </a>
        <a href="/regularization-article-33" class="border border-white/40 px-7 py-3.5 text-base font-semibold text-white transition-colors hover:border-white hover:bg-white/10">
          Régulariser une installation existante
        </a>
      </div>

      <!-- Chiffres clés — laiton, réservé aux nombres -->
      <dl class="mt-14 grid max-w-3xl grid-cols-3 gap-3 border-t border-white/20 pt-6 sm:gap-6">
        <div>
          <dd class="fig text-base text-brass-300 sm:text-4xl">25 ans</dd>
          <dt class="tech-label mt-2 text-white/70">Garantie panneaux</dt>
        </div>
        <div>
          <dd class="fig text-base text-brass-300 sm:text-4xl">3–7 ans</dd>
          <dt class="tech-label mt-2 text-white/70">Retour typique</dt>
        </div>
        <div>
          <dd class="fig text-base text-brass-300 sm:text-4xl">60–90 %</dd>
          <dt class="tech-label mt-2 text-white/70">Facture couverte</dt>
        </div>
      </dl>
    </div>
  </section>

  <!-- Bande de confiance — immédiatement sous le héros -->
  <section class="border-b border-azur-900/10 bg-blanc-azur px-4 py-8">
    <div class="mx-auto grid max-w-6xl gap-6 text-center sm:grid-cols-3 sm:gap-8">
      <div class="flex flex-col items-center gap-1.5">
        <p class="font-display text-lg font-bold text-azur-700">Docteur-ingénieur</p>
        <p class="text-sm text-encre-soft">Chaque installation dimensionnée par calcul, pas par catalogue</p>
      </div>
      <div class="flex flex-col items-center gap-1.5 border-azur-900/10 max-sm:border-t max-sm:pt-5 sm:border-x">
        {installCount ? (
          <p class="font-display text-lg font-bold text-azur-700">+{installCount} installations</p>
        ) : (
          <p class="font-display text-lg font-bold text-azur-700">Production mesurée</p>
        )}
        <p class="text-sm text-encre-soft">Chaque chantier suivi par monitoring — nous publions ce que nous mesurons</p>
      </div>
      <div class="flex flex-col items-center gap-1.5 max-sm:border-t max-sm:border-azur-900/10 max-sm:pt-5">
        <p class="font-display text-lg font-bold text-azur-700">{NAP.serviceArea.slice(0, -1).join(' · ')}</p>
        <p class="text-sm text-encre-soft">Interventions dans tout le Maroc</p>
      </div>
    </div>
  </section>

  <!-- Segments — deux métiers -->
  <section class="mx-auto max-w-6xl px-4 py-16">
    <p class="tech-label rule-brass text-azur-600">Deux métiers</p>
    <h2 class="display mt-3 max-w-xl text-3xl sm:text-4xl">Une exigence d'ingénierie, du pavillon à l'usine</h2>
    <div class="mt-10 grid gap-6 md:grid-cols-2">
      <a href="/résidentiel" class="reveal group block border border-azur-900/15 bg-blanc transition-all hover:-translate-y-1 hover:border-azur-600 hover:shadow-[0_18px_50px_-18px_rgb(15_28_84/0.4)]">
        <div class="overflow-hidden">
          <Picture
            name="crepuscule-penthouse"
            alt="Installation solaire résidentielle Taqinor au crépuscule, penthouse blanc et chauffe-eau solaire"
            widths={[1600, 1024, 640]}
            ratio={4 / 3}
            sizes="(min-width: 768px) 50vw, 100vw"
            class="aspect-[4/3] w-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
          />
        </div>
        <div class="p-7">
          <p class="tech-label text-azur-600">Villas · appartements</p>
          <h3 class="display mt-2 text-2xl">Résidentiel</h3>
          <p class="mt-3 text-sm leading-relaxed text-encre-soft">
            À partir d'une facture de 1 000 MAD par mois, le solaire devient un placement
            mesurable. Dimensionnement, pose, déclaration loi 82-21.
          </p>
          <span class="mt-5 inline-block border-b-2 border-azur-600 pb-0.5 text-sm font-bold text-azur-700">Voir le résidentiel →</span>
        </div>
      </a>
      <a href="/professionnel" class="reveal group block border border-azur-900/15 bg-blanc transition-all hover:-translate-y-1 hover:border-azur-600 hover:shadow-[0_18px_50px_-18px_rgb(15_28_84/0.4)]">
        <div class="overflow-hidden">
          <Picture
            name="industriel-couchant"
            alt="Chantier solaire industriel Taqinor au couchant, double rangée de panneaux"
            widths={[2000, 1280, 768, 480]}
            ratio={16 / 9}
            sizes="(min-width: 768px) 50vw, 100vw"
            class="aspect-[4/3] w-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
          />
        </div>
        <div class="p-7">
          <p class="tech-label text-azur-600">Industriels · hôtels · cliniques</p>
          <h3 class="display mt-2 text-2xl">Professionnel</h3>
          <p class="mt-3 text-sm leading-relaxed text-encre-soft">
            Réduction du poste électricité, valorisation du surplus et conformité au régime
            moyenne tension de la loi 82-21.
          </p>
          <span class="mt-5 inline-block border-b-2 border-azur-600 pb-0.5 text-sm font-bold text-azur-700">Voir le professionnel →</span>
        </div>
      </a>
    </div>
  </section>

  <ZelligeDivider />

  <!-- Galerie de chantiers réels -->
  <section class="zellige-bg px-4 py-16">
    <div class="mx-auto max-w-6xl">
      <div class="flex flex-wrap items-end justify-between gap-4">
        <div>
          <p class="tech-label rule-brass text-azur-600">Photos de chantier réelles</p>
          <h2 class="display mt-3 text-3xl sm:text-4xl">Nos installations, telles quelles</h2>
        </div>
        <p class="max-w-sm text-sm leading-relaxed text-encre-soft">
          Chaque image vient d'un chantier Taqinor au Maroc — recadrage, exposition et
          clarté ajustés, rien d'ajouté, rien d'effacé.
        </p>
      </div>
      <div class="mt-10 columns-2 gap-4 md:columns-3 [&>figure]:mb-4 [&>figure]:break-inside-avoid">
        {gallery.map((g) => (
          <figure class="reveal group overflow-hidden border border-azur-900/15 bg-blanc">
            <Picture
              name={g.name}
              alt={g.alt}
              widths={g.widths}
              ratio={g.ratio}
              sizes="(min-width: 768px) 33vw, 50vw"
              class="w-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
            />
            <figcaption class="tech-label flex items-center justify-between gap-2 px-3 py-2.5 text-encre-faint">
              {g.label}
              <span class="h-1.5 w-1.5 flex-none rotate-45 border border-azur-600" aria-hidden="true"></span>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <VideoChantier />

  <!-- Témoignages -->
  <section class="mx-auto max-w-6xl px-4 py-16">
    <p class="tech-label rule-brass text-azur-600">Retours clients</p>
    <h2 class="display mt-3 text-3xl sm:text-4xl">Ils produisent déjà leur électricité</h2>
    <div class="mt-10 grid gap-6 md:grid-cols-3">
      {testimonials.map((t) => (
        <figure class="reveal flex flex-col border border-azur-900/15 border-t-4 border-t-azur-600 bg-blanc-azur p-7">
          <blockquote class="flex-1 text-sm leading-relaxed">« {t.quote} »</blockquote>
          <figcaption class="mt-5 border-t border-azur-900/10 pt-4 text-sm">
            <span class="font-display font-bold">{t.name}</span>
            <span class="text-encre-soft"> — {t.detail}</span>
          </figcaption>
        </figure>
      ))}
    </div>
  </section>

  <ZelligeDivider />

  <LeadForm />

  <Faq items={faq} />

  <StickyCta />
</Layout>

<script>
  // Vidéo héro : chargée seulement après le chargement complet de la page,
  // jamais si l'utilisateur préfère réduire les animations ou économiser
  // les données — l'affiche reste alors le visuel du héros.
  const video = document.getElementById('hero-video') as HTMLVideoElement | null;
  const motionOk = matchMedia('(prefers-reduced-motion: no-preference)').matches;
  // @ts-expect-error saveData non typé partout
  const saveData = navigator.connection?.saveData === true;
  if (video && motionOk && !saveData) {
    let started = false;
    const start = () => {
      if (started) return;
      started = true;
      video.src = '/videos/hero.mp4';
      video.play().then(() => video.classList.add('opacity-100')).catch(() => {});
    };
    // Première interaction, ou 2,8 s après le chargement complet — la vidéo
    // (2,2 Mo) ne concurrence jamais le rendu initial.
    for (const ev of ['scroll', 'pointerdown', 'touchstart', 'keydown']) {
      addEventListener(ev, start, { once: true, passive: true });
    }
    const arm = () => setTimeout(start, 2800);
    if (document.readyState === 'complete') arm();
    else addEventListener('load', arm, { once: true });
  }
</script>
