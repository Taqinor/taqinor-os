  .gallery-lightbox-close {
    position: absolute;
    top: 0.6rem;
    right: 0.6rem;
    z-index: 1;
    display: flex;
    height: 2.25rem;
    width: 2.25rem;
    align-items: center;
    justify-content: center;
    border-radius: 9999px;
    background: rgb(6 10 30 / 0.7);
    color: white;
  }
  .gallery-lightbox-close:hover {
    background: rgb(6 10 30 / 0.9);
  }
  /* Transition d'ouverture — gated reduced-motion : le dialogue apparaît
     instantanément sans préférence de mouvement réduit. */
  @media (prefers-reduced-motion: no-preference) {
    .gallery-lightbox {
      transition: opacity 0.2s ease, transform 0.2s ease;
    }
    .gallery-lightbox:not([open]) {
