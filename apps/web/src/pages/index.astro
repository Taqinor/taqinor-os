---
/**
 * Page publique d'accueil — composition « élévation » promue en production
 * (2026-06-22) : héros cinématographique plein cadre (~100svh), preuve par
 * chantier portée par la galerie, signature zellige unique, set complet des
 * sections séquencé et aéré (tokens .section / .v2-body / .fig), discipline
 * laiton (l'or vit sur les chiffres .lum et le seul CTA principal ; les
 * eyebrows sont rétrogradés en lune), grade « heure dorée » (.v3-grade) sur la
 * photographie de contenu — JAMAIS le héros (protection LCP). Mouvements et
 * chiffres réutilisent les hooks de l'accueil (count-up héro, Ken Burns,
 * .cine-in / .v2-rise), tous gated `prefers-reduced-motion`.
 * Voir apps/web/DESIGN_RATIONALE.md.
 *
 * W249 — Un seul entonnoir : l'ancien second formulaire DiagnosticForm en
 * fin de page (qui dupliquait les deux InstantEstimator déjà présents sur
 * cette même page) est retiré ; DiagnosticForm.astro + /api/simulate restent
 * intacts dans le code comme repli documenté (montés ailleurs).
 */
import Layout from '../layouts/Layout.astro';
import V2Enhance from '../components/V2Enhance.astro';
import Article33Ribbon from '../components/Article33Ribbon.astro';
import Faq from '../components/Faq.astro';
import Picture from '../components/Picture.astro';
import VideoChantier from '../components/VideoChantier.astro';
import VideoCompteur from '../components/VideoCompteur.astro';
import StickyCta from '../components/StickyCta.astro';
import WhatsAppMock from '../components/WhatsAppMock.astro';
import GarantiesTeaser from '../components/GarantiesTeaser.astro';
import InstantEstimator from '../components/InstantEstimator.astro';
import Testimonials from '../components/Testimonials.astro';
import BrandStrip from '../components/BrandStrip.astro';
import ZelligeSignature from '../components/ZelligeSignature.astro';
import FounderPortrait from '../components/FounderPortrait.astro';
import { WHATSAPP_LEADS } from '../lib/nap';
import { whatsappLink, zeroFormWhatsappText } from '../lib/whatsapp';
import { REGIE_MARGINAL_RATE_SECOND, REGIE_MARGINAL_RATE_HIGH } from '../lib/regieTariff';
import { REALISATIONS, realisationBySlug } from '../lib/realisations';
import { YIELD_TABLE } from '../lib/yieldTable';

const waDirect = whatsappLink(WHATSAPP_LEADS, 'Bonjour, je souhaite une étude pour une installation solaire.');
// W349 — porte sans formulaire : action secondaire du héros, pour le visiteur
// qui ne veut/peut rien lire ni remplir — une photo de facture suffit.
const waZeroForm = whatsappLink(WHATSAPP_LEADS, zeroFormWhatsappText());

// W284 — Chiffres précis, jamais arrondis : dérivés de REALISATIONS (source
// unique de vérité, apps/web/src/lib/realisations.ts), jamais recopiés en dur.
// Si REALISATIONS change, ces valeurs suivent automatiquement — plus aucun
// risque de chiffre qui devient silencieusement faux.
const totalKwc = REALISATIONS.reduce((sum, r) => sum + r.kwcNum, 0);
const totalKwcLabel = totalKwc.toLocaleString('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' kWc';
// La plus grande installation résidentielle publiée (réf. 468, El Jadida) —
// protagoniste du héros et de l'aside final. Dérivée par tri sur kwcNum,
// jamais une référence recopiée à la main.
const featured = [...REALISATIONS].sort((a, b) => b.kwcNum - a.kwcNum)[0];

// WJ73 — L'écart estimation-vs-preuve, expliqué honnêtement. Le chantier
// phare (réf. 468) mesure ≈1 256 kWh/kWc/an (21 406 kWh / 17,04 kWc) — un
// visiteur qui divise ces deux chiffres déjà publiés sur cette page tombe sur
// un nombre bien inférieur aux ≈1 650 kWh/kWc/an que la table de rendement
// (yieldTable.ts, PVGIS) donne pour un plein sud à 29° à Casablanca, l'
// hypothèse utilisée par le tableau modélisé de TOUTE estimation du site.
// Plutôt que de laisser cet écart de 24 % sans explication (un « gotcha »
// pour qui fait le calcul), on l'explique en une ligne, honnêtement : les
// toits réels ne sont pas tous plein sud à l'inclinaison optimale — l'étude
// affine. AUCUN chiffre inventé : les deux valeurs viennent de sources déjà
// committées (REALISATIONS + YIELD_TABLE), jamais recopiées à la main.
const featuredYieldPerKwc = featured.productionNum && featured.kwcNum
  ? Math.round(featured.productionNum / featured.kwcNum)
  : null;
const casablancaSouthOptimalYield = YIELD_TABLE.casablanca.grid['0']['29'];

// W205 — Le chiffre protagoniste de l’en-tête est séparé pour le count-up.
// La largeur est réservée (tabular-nums + min-width verrouillée par JS) → zéro CLS.
const heroFigure = (featured.productionNum ?? 0).toLocaleString('fr-FR');
const heroTitleSuffix = ` kWh par an, produits sur un toit d’${featured.ville}.`;
const heroSub =
  `Installation réf. ${featured.ref} — ${featured.kwc}, dimensionnée, posée et mesurée par Taqinor. La vôtre commence par un diagnostic de 60 secondes.`;

// W267 — Sous-ligne monétaire du héros. AUCUN chiffre inventé : la
// consommation réelle du foyer réf. 468 n'est publiée nulle part sur le site,
// donc on ne peut PAS appeler `annualSavingsMad(production, consommation)`
// sans inventer cette seconde variable. La seule dérivation honnête à partir
// de la SEULE donnée publiée (21 406 kWh produits) est de valoriser cette
// production aux deux tranches marginales hautes réelles du barème RÉGIE (via
// le module public `regieTariff.ts` — la page publique NE doit PAS importer le
// « cerveau » estimateur ; garde d'architecture), cohérent avec « notre plus
// grande résidentielle de 2026 », donc un foyer situé sans ambiguïté dans le
// haut de barème : c'est exactement la même fourchette « ≈ 1,38–1,60 MAD/kWh »
// déjà publiée et documentée dans billRange.ts / recharge-voiture-electrique-solaire.astro.
// Fourchette (jamais un chiffre unique) : reflète le fait que l'autoconsommation
// réelle du foyer n'est pas connue — poser une seule valeur ponctuelle
// inventerait une précision qu'on n'a pas.
const heroProductionKwh = featured.productionNum ?? 0;
const heroTariffLowRate = REGIE_MARGINAL_RATE_SECOND; // 1,3817 MAD/kWh
const heroTariffHighRate = REGIE_MARGINAL_RATE_HIGH; // 1,5958 MAD/kWh
const heroMoneyLow = Math.round((heroProductionKwh * heroTariffLowRate) / 100) * 100;
const heroMoneyHigh = Math.round((heroProductionKwh * heroTariffHighRate) / 100) * 100;
const heroMoneyLine = `≈ ${heroMoneyLow.toLocaleString('fr-FR')} à ${heroMoneyHigh.toLocaleString('fr-FR')} MAD effacés de la facture chaque année`;

// W54 — L'ancien tableau de données (variable `cases`) a été retiré : les
// mêmes installations vivaient en double (cartes photo + cartes données). La
// galerie photo porte désormais seule la preuve par chantier (ville · kWc ·
// production mesurée · matériel sur chaque carte). Données RÉELLES du dossier
// entreprise 2026 — aucune citation inventée.

// PLACEHOLDER(MERYEM) : FAQ provisoire.
const faq = [
  { q: 'Combien coûte une installation solaire résidentielle ?', a: 'Cela dépend de votre consommation et de votre toiture. Une villa avec une facture de 1 500 MAD par mois s’équipe typiquement en 4 à 6 kWc. Le diagnostic ci-dessous vous donne une fourchette immédiate ; le chiffrage précis est établi après visite technique.' },
  { q: 'Que dit la loi 82-21 pour les particuliers ?', a: 'En basse tension, une installation de moins de 11 kW relève du régime de déclaration : une formalité préalable, pas une autorisation. Taqinor prépare et dépose la déclaration pour vous.' },
  { q: 'Mon installation existante n’est pas déclarée. Que faire ?', a: 'L’Article 33 de la loi 82-21 ouvre une fenêtre de régularisation pour les installations existantes. La fenêtre est ouverte : déposez maintenant. Voir la page Régularisation pour la procédure en 5 étapes.' },
  { q: 'Combien de temps durent les panneaux ?', a: 'Les panneaux sont garantis en performance sur 25 ans (généralement ≥ 84,8 % de la puissance initiale à 25 ans). Les onduleurs se remplacent typiquement une fois sur la durée de vie de l’installation.' },
  { q: 'Faut-il des batteries ?', a: 'Pas nécessairement. Si votre consommation est principalement diurne, l’autoconsommation directe est le meilleur investissement. Les batteries se justifient pour la consommation nocturne ou la continuité de service — nous le calculons dans l’étude.' },
];

// W284 — kwc/prod ne sont plus recopiés à la main : dérivés de REALISATIONS
// via `slug` (source unique de vérité) pour ne jamais diverger silencieusement.
// `prod` reste `null` quand la photo ne doit PAS afficher de production (ex.
// la photo « fin de chantier » n'est pas la carte production de sa réf.) —
// ce choix éditorial (quelle photo porte le chiffre) reste ici, seul le
// CHIFFRE lui-même est dérivé.
const galleryRaw = [
  { name: 'reflet-468', alt: 'Le soleil se reflète sur la rangée de panneaux pendant la pose, El Jadida', widths: [1600, 1024, 640], ratio: 3 / 2, showProd: true, type: '24 × Canadian Solar 710 Wc · Deye 15 kW', slug: 'el-jadida-17-kwc' },
  { name: 'equipe-trois', alt: 'Équipe Taqinor devant la longue rangée de panneaux en fin de chantier, El Jadida', widths: [1600, 1024, 640], ratio: 3 / 2, showProd: false, type: 'Fin de chantier · équipe Taqinor', slug: 'el-jadida-17-kwc' },
  { name: 'hero-skyline', alt: 'Rangée de panneaux solaires devant la skyline de Casablanca et un minaret, lumière dorée', widths: [2000, 1280, 768, 480], ratio: 16 / 9, showProd: true, type: '16 × Canadian Solar 710 Wc · Deye 10 kW', slug: 'casablanca-11-kwc' },
  { name: 'portrait-400', alt: "L'ingénieur devant le champ de panneaux, skyline de Casablanca", widths: [1600, 1024, 640], ratio: 4 / 3, showProd: false, type: 'Production mesurée — Deye Cloud', slug: 'casablanca-11-kwc' },
  { name: 'champ-villa', alt: 'Champ de huit panneaux sur toit plat de villa, El Jadida', widths: [1600, 1024, 640], ratio: 3 / 2, showProd: true, type: '8 × Canadian Solar 710 Wc · Deye 5 kW', slug: 'el-jadida-6-kwc' },
  { name: 'pose-134', alt: "L'équipe incline un panneau pendant la pose, Casablanca", widths: [1600, 1024, 640], ratio: 4 / 3, showProd: true, type: 'Pose en cours · 8 × Canadian Solar 710 Wc', slug: 'casablanca-6-kwc' },
  { name: 'equipe-gilet-taqinor', alt: "Installateur en gilet Taqinor posant les rails d'une structure, Nouaceur", widths: [1600, 1024, 640], ratio: 1, showProd: false, type: 'Pose des rails · 6 × JA Solar', slug: 'nouaceur-4-kwc' },
  { name: 'entretien-jet', alt: "Nettoyage au jet d'eau du champ de panneaux, Nouaceur", widths: [1600, 1024, 640], ratio: 1, showProd: false, type: 'Entretien du champ · 6 × JA Solar', slug: 'nouaceur-4-kwc' },
];
const gallery = galleryRaw.map((g) => {
  const r = realisationBySlug(g.slug);
  return {
    ...g,
    ville: r?.ville ?? '',
    kwc: r?.kwc ?? '',
    prod: g.showProd ? (r?.production ?? null) : null,
  };
});

// W271 — Chips de filtre ville : « Toutes » + les villes réellement présentes
// dans `gallery` ci-dessus (aucune ville inventée ; l'ordre suit le premier
// passage de chaque ville dans le tableau — El Jadida, Casablanca, Nouaceur).
const galleryCities = ['Toutes', ...Array.from(new Set(gallery.map((g) => g.ville)))];

// Nos solutions (W31) — toutes les offres visibles dès l'accueil, pas seulement
// dans le menu. Descriptions reprises du positionnement déjà publié, sans
// nouveau claim ni chiffre. Cartes texte (aucune image) → zéro CLS.
const solutions = [
  { href: '/résidentiel', tag: 'Villas & appartements', title: 'Solaire résidentiel', body: 'Dimensionné sur votre facture réelle, déclaration loi 82-21 incluse.' },
  { href: '/professionnel', tag: 'Industriels · hôtels · cliniques', title: 'Solaire professionnel', body: 'Réduction du poste électricité, moyenne tension, conformité loi 82-21.' },
  { href: '/pompage-solaire', tag: 'Agriculture & irrigation', title: 'Pompage solaire', body: 'Pompage au fil du soleil, souvent sans batteries, dimensionné au besoin réel.' },
  { href: '/batteries-stockage', tag: 'Autoconsommation', title: 'Batteries & stockage', body: 'Stockage LFP pour le nocturne ou la continuité de service — quand l’étude le justifie.' },
  { href: '/maintenance-monitoring', tag: 'Après la pose', title: 'Maintenance & monitoring', body: 'Supervision Deye Cloud avec accès client, SAV proactif, dossier technique.' },
  { href: '/regularization-article-33', tag: 'Mise en conformité', title: 'Régularisation Loi 82-21', body: 'Régularisation des installations existantes via l’Article 33.' },
];

// W65 — Les marques tier-1 vivent désormais dans <BrandStrip> (src/lib/brands.ts) :
// logos officiels quand un fichier existe (public/brands/), mots-marques stylés
// en repli. Sept marques confirmées par le fondateur (ajout Jinko, Huawei, Nexans).

// W57 — Le parcours réel, de bout en bout. Faits déjà publiés sur le site
// (diagnostic 60 s, échange WhatsApp, visite & étude gratuite, pose, mise en
// service, monitoring Deye Cloud avec accès client). Aucun délai/SLA inventé.
const journey = [
  { n: '1', title: 'Diagnostic 60 secondes', body: 'Une fourchette immédiate à partir de votre facture, sans engagement.' },
  { n: '2', title: 'Échange WhatsApp', body: 'Direct avec l’équipe technique, photos de toiture à l’appui — pas de centre d’appels.' },
  { n: '3', title: 'Visite technique & étude gratuite', body: 'Lecture de la toiture sur site, étude complète et devis à 0 MAD.' },
  { n: '4', title: 'Pose', body: 'Matériel tier-1 installé avec son dossier technique complet.' },
  { n: '5', title: 'Mise en service', body: 'Raccordement, contrôles, et dossier loi 82-21 mené à terme.' },
  { n: '6', title: 'Monitoring Deye Cloud', body: 'Production relevée en continu, accès client inclus : vous lisez vos kWh à la source.' },
];

// W252 — « Comment ça marche » : bande 4 étapes sous le héros, le device
// standard 3-4 icônes qu'on retrouve chez tous les acteurs sérieux du secteur.
// Ce sont les 4 MÊMES stades que la frise « Le parcours » plus bas (§ Comment
// ça se passe) — juste condensés en 4 (au lieu de 6) pour répondre tout de
// suite, sous le héros, à « que se passe-t-il après le formulaire ? ». Aucun
// délai/SLA inventé ; les 4 stades sont ceux réellement livrés par le parcours
// construit (diagnostic → étude signée → devis + signature en ligne → pose &
// SAV, cf. /devis/mon-toit).
const howItWorks = [
  { n: '1', title: 'Estimation instantanée', body: 'Votre facture donne une fourchette kWc en 60 secondes, sans engagement.' },
  { n: '2', title: 'Étude personnalisée signée', body: 'Visite technique, dimensionnement sur votre toiture réelle, validé et signé avant tout devis.' },
  { n: '3', title: 'Devis + signature en ligne', body: 'Le chiffrage détaillé se signe électroniquement, où que vous soyez.' },
  { n: '4', title: 'Installation & SAV', body: 'Pose par notre équipe, mise en service, puis monitoring Deye Cloud et SAV proactif.' },
];

// W58 — Iconographie sobre des cartes « Nos solutions » : un trait SVG par
// carte, currentColor (teinte brass), dans le langage de marque. Indexée par
// href pour rester stable même si l'ordre des cartes change.
const solutionIcons: Record<string, string> = {
  '/résidentiel': '<path d="M4 13 12 5l8 8" /><path d="M6 11v8h12v-8" /><path d="M10 19v-4h4v4" />',
  '/professionnel': '<path d="M4 21V8l7-3v4l7-3v15" /><path d="M4 21h16" /><path d="M8 12h0M8 16h0M14 12h0M14 16h0" />',
  '/pompage-solaire': '<path d="M12 3v6" /><path d="M5 21c1.6-2 3.2-2 4.8 0s3.2 2 4.8 0 3.2-2 4.4 0" /><path d="M8 9h8l-2 6H10z" />',
  '/batteries-stockage': '<path d="M5 8h14v11H5z" /><path d="M9 5h6v3H9z" /><path d="M12 11v5" /><path d="M9.5 13.5h5" />',
  '/maintenance-monitoring': '<path d="M4 18 9 12l3 3 4-6 4 5" /><path d="M4 21h16" /><circle cx="9" cy="12" r="0.6" /><circle cx="16" cy="9" r="0.6" />',
  '/regularization-article-33': '<path d="M7 4h7l4 4v12H7z" /><path d="M14 4v4h4" /><path d="M9.5 14l1.5 1.5 3-3.5" />',
};

// Pourquoi Taqinor / confiance — bande de quatre chiffres monumentaux, faits
// déjà publiés. Décision fondateur 2026-06-22 : le slot « docteur-ingénieur »
// est remplacé par la conformité loi 82-21 — un signal de confiance concret et
// non personnel (le crédit fondateur vivra sur la page équipe). Les trois autres
// valeurs (chantiers visitables, kWc installés, Deye Cloud) sont inchangées,
// mais W284 les dérive désormais de REALISATIONS plutôt que de les recopier à
// la main. L'or vit sur les chiffres .lum (discipline laiton). Aucun claim
// inventé.
const chantiersVisitablesCount = new Set(REALISATIONS.map((r) => r.ville)).size;
const trust = [
  { fig: String(chantiersVisitablesCount), tally: false, label: 'Chantiers visitables', body: 'Installations réelles à voir sur demande — Casablanca, El Jadida, Nouaceur' },
  { fig: totalKwcLabel, tally: true, label: 'Installés', body: 'Casablanca, El Jadida, Nouaceur' },
  { fig: 'Loi 82-21', tally: false, label: 'Conformité incluse', body: 'Déclaration préparée et déposée pour vous par Taqinor' },
  { fig: 'Deye Cloud', tally: false, label: 'Production mesurée', body: 'Monitoring sur chaque installation, accès client inclus' },
];

// W265 — L'histoire de l'investissement sur 25 ans : SEULE rupture tonale
// claire de la page (fond blanc-azur, texte encre), en position 3-4 pour
// aérer le dark→light→dark. Chiffres STRICTEMENT repris de /financement (déjà
// publiés) — aucun nouveau nombre.
const investment = [
  { v: '3–7 ans', label: 'Retour sur investissement typique' },
  { v: '25 ans', label: 'Garantie de performance des panneaux' },
  { v: '60–90 %', label: 'De la facture couverte' },
  { v: '0 MAD', label: 'L’étude et le diagnostic' },
];

// W276 — « Notre moteur, conçu au Maroc » : l'histoire vraie d'ingénierie
// interne, racontée avec les TROIS outils réellement construits et déjà en
// production sur le site (aucun logiciel tiers, aucun claim inventé) :
//   1. L'estimateur piloté par la facture (moteur d'estimation maison —
//      position solaire calculée maison, espacement inter-rangées dérivé
//      d'une règle solstice d'hiver).
//   2. Le moteur de toiture 3D (/devis/mon-toit — traçage de toiture,
//      orientation/inclinaison réelles, pas un abaque générique).
//   3. Le moteur de devis premium (apps/ventes/quote_engine, PDF signé en
//      ligne, cf. CLAUDE.md règle #4) qui rend le devis final.
// Aucun chiffre fabriqué ici : le lien mène directement vers le parcours réel
// (/devis/mon-toit) pour que le visiteur le VÉRIFIE lui-même en 60 secondes.
const engineeringPillars = [
  {
    title: 'L’estimateur piloté par la facture',
    body: 'Votre facture d’électricité suffit : notre moteur calcule la position du soleil et l’espacement des rangées de panneaux selon une règle d’ombrage au solstice d’hiver — pas un abaque générique importé.',
  },
  {
    title: 'Le moteur de toiture 3D',
    body: 'Tracez votre toit, orientez-le, et le dimensionnement s’ajuste à la géométrie réelle de votre maison — la même technologie que vous testez dans le diagnostic ci-dessus.',
  },
  {
    title: 'Le moteur de devis',
    body: 'Le chiffrage qui en sort se signe électroniquement, en ligne — aucune ressaisie manuelle entre l’étude et le document que vous signez.',
  },
];
---

<Layout
  title="Taqinor — Installations solaires au Maroc, conformes loi 82-21"
  description="Conception, installation et déclaration d'installations solaires pour villas, industries et hôtels au Maroc. Étude gratuite, dimensionnement par l'ingénierie, conformité loi 82-21."
  ogSlug="accueil"
  preloadHeroPoster
>
  <div class="v2">
    <V2Enhance />
    <Article33Ribbon />

    {/* ── 1 · HÉROS CINÉMATOGRAPHIQUE (~100svh) — la photo est le protagoniste ── */}
    <section class="relative isolate flex min-h-[100svh] flex-col justify-end overflow-hidden text-white">
      <div class="v2-hero-media absolute inset-0 -z-10">
        {/* Affiche héro plein cadre (élément LCP) — Ken Burns hérité de la couche
            photo. JAMAIS de .v3-grade ici (protection LCP) : seul le scrim, relevé
            sur cette page, porte la chaleur sans toucher le contraste du texte.
            W155 — Portrait-crop : en orientation portrait (téléphone tenu vertical),
            les sources portrait sont sélectionnées en priorité ; l'object-position
            recentre les panneaux (center 20%). */}
        <picture>
          <source type="image/avif" media="(orientation: portrait)" sizes="100vw"
            srcset="/videos/hero-poster-540.avif 540w, /videos/hero-poster-720.avif 720w, /videos/hero-poster-1080.avif 1080w" />
          <source type="image/webp" media="(orientation: portrait)" sizes="100vw"
            srcset="/videos/hero-poster-540.webp 540w, /videos/hero-poster-720.webp 720w, /videos/hero-poster-1080.webp 1080w" />
          <source type="image/avif" sizes="100vw"
            srcset="/videos/hero-poster-540.avif 540w, /videos/hero-poster-720.avif 720w, /videos/hero-poster-1080.avif 1080w, /videos/hero-poster-1600.avif 1600w" />
          <source type="image/webp" sizes="100vw"
            srcset="/videos/hero-poster-540.webp 540w, /videos/hero-poster-720.webp 720w, /videos/hero-poster-1080.webp 1080w, /videos/hero-poster-1600.webp 1600w" />
          <img src="/videos/hero-poster-1600.webp" alt="" width="1600" height="900"
            loading="eager" decoding="async" fetchpriority="high"
            class="h-full w-full object-cover hero-portrait-img" />
        </picture>
        <video id="hero-video" muted loop playsinline preload="none" aria-hidden="true" tabindex="-1"
          class="absolute inset-0 h-full w-full object-cover opacity-0 transition-opacity duration-700"></video>
        {/* Scrim canonique RELEVÉ (--hero-scrim-strength 0.52) : compense la
            chaleur du grade « heure dorée » et garde le headline ≥ AA. */}
        <div class="hero-scrim hero-scrim-v3 absolute inset-0"></div>
        {/* W373 — Plan de profondeur : un voile de lumière laiton très
            discret, purement décoratif (aucune image, aucune requête —
            dégradés CSS seuls), qui parallaxe plus LENTEMENT que l'affiche
            derrière lui (facteur JS distinct, voir V2Enhance). N'affecte
            JAMAIS le LCP : posé APRÈS l'<img fetchpriority="high"> dans le
            DOM, aucun poids réseau, transform/opacity seuls au scroll. */}
        <div class="hero-depth-layer absolute inset-0" aria-hidden="true"></div>
      </div>

      {/* W161/W275 — Invitation au défilement : chevron animé (statique sous
          prefers-reduced-motion) + un court libellé, pour qu'un héros
          photographique ~100svh ne repose plus sur un seul chevron discret
          comme unique signal que le site continue. */}
      <div class="absolute bottom-6 left-1/2 flex -translate-x-1/2 flex-col items-center gap-1.5 scroll-chevron" aria-hidden="true">
        <span class="tech-label text-white/70">Voir nos réalisations mesurées</span>
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="6 9 12 15 18 9" />
        </svg>
