  /* ── W271 — Chips de filtre ville : masque les cartes hors filtre via une
     classe posée par le script, jamais via [hidden] pour laisser data-stagger
     rejouer proprement l'apparition au premier rendu. */
  [data-gallery-card].gallery-card-hidden {
    display: none;
  }

  /* ── W371 — Scrollytelling épinglé de « Comment ça se passe » ─────────────
     Repos = la grille plate d'origine (aucune règle ci-dessous ne s'applique
     tant que le script n'a pas posé `.journey-pinned` sur la section, ce qui
     n'arrive que desktop + motion ok). Zéro CLS : le sticky ne change ni la
     largeur ni la hauteur du flux, seule sa `position` change à l'ancrage. */
  @media (min-width: 1024px) and (prefers-reduced-motion: no-preference) {
    .journey-pinned .journey-sticky-col {
      position: sticky;
      top: 6rem;
      align-self: start;
    }

    /* Le corps de chaque étape est présent au repos (progressive enhancement :
       lisible sans JS/hors media match) ; une fois épinglé, seule l'étape
       active « s'allume », les autres s'estompent doucement — jamais masquées
       (aucun CLS, aucune perte de contenu pour un lecteur d'écran). */
    .journey-pinned .journey-step {
      opacity: 0.42;
      transition: opacity 0.35s ease, border-color 0.35s ease;
    }
    .journey-pinned .journey-step[data-journey-active] {
      opacity: 1;
    }
    .journey-pinned .journey-step[data-journey-active] .journey-step-rule {
      background-color: var(--color-brass-300, #e8b54a);
    }

    /* Copie appariée dans la colonne épinglée : ne s'affiche que lorsque le
       pinning est armé, jamais avant (repli intégral vers la description
       statique existante quand JS/desktop/motion ne sont pas tous réunis). */
    .journey-pinned .journey-active-caption {
      display: block;
    }
  }
</style>

<script>
  // Vidéo héro : différée — première interaction ou 2,8 s après chargement ;
  // jamais si reduced-motion ou économie de données (l'affiche reste le héros).
  const video = document.getElementById('hero-video') as HTMLVideoElement | null;
  const motionOk = matchMedia('(prefers-reduced-motion: no-preference)').matches;
  // @ts-expect-error saveData non typé partout
  const saveData = navigator.connection?.saveData === true;
  if (video && motionOk && !saveData) {
    let started = false;
    const start = () => {
      if (started) return;
      started = true;
      video.src = '/videos/hero.mp4';
      video.play().then(() => video.classList.add('opacity-100')).catch(() => {});
    };
    for (const ev of ['scroll', 'pointerdown', 'touchstart', 'keydown']) {
      addEventListener(ev, start, { once: true, passive: true });
    }
    const arm = () => setTimeout(start, 2800);
    if (document.readyState === 'complete') arm();
    else addEventListener('load', arm, { once: true });
  }
</script>

<script>
  // W205 — Count-up sur le chiffre protagoniste héro (21 406).
  // Reduced-motion safe : la valeur finale est affichée immédiatement.
  // Anti-CLS : la largeur finale est verrouillée AVANT toute animation.
  import { formatFrame, shouldDigitRoll } from '../lib/countup';

  const el = document.querySelector<HTMLElement>('[data-hero-tally]');
  if (el) {
    const finalText = el.textContent ?? '';
    // Réserve la largeur (anti-CLS) avant toute animation
    if (getComputedStyle(el).display.startsWith('inline')) {
      const w = el.getBoundingClientRect().width;
      el.style.display = 'inline-block';
      el.style.minWidth = w + 'px';
    }

    const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduce || !shouldDigitRoll(finalText)) {
      // Reduced-motion ou valeur composée → valeur finale immédiate
      el.textContent = finalText;
    } else {
      // Count-up dès la première vue (l'élément est above-the-fold)
      const dur = 1400; // légèrement plus lent que les stats pour son statut de protagoniste
      let start: number | null = null;
      function frame(t: number) {
        if (start === null) start = t;
        const p = Math.min(1, (t - start) / dur);
        const e = 1 - Math.pow(1 - p, 3); // easeOutCubic
        el!.textContent = formatFrame(finalText, e);
        if (p < 1) requestAnimationFrame(frame);
        else el!.textContent = finalText;
      }
      // Déclenché au chargement (above-the-fold) avec un délai minimal pour
      // laisser le navigateur peindre l'affiche d'abord.
      const kick = () => requestAnimationFrame(frame);
      if (document.readyState === 'complete') kick();
      else addEventListener('load', kick, { once: true });
    }
  }
</script>

<script>
  // W365 — Balayage de lumière laiton, une seule fois, sur le titre héros.
  // Armé UNIQUEMENT après `load` (jamais avant : aucune peinture supplémentaire
  // ne concurrence l'affiche héros pour le LCP). Le CSS (.hero-title-sweep,
  // global.css) ne fait RIEN tant que .hero-sweep-armed n'est pas posée, donc
  // ce script ne peut jamais retarder ni modifier la première peinture.
  const heroTitle = document.getElementById('hero-title');
  if (heroTitle) {
    const arm = () => heroTitle.classList.add('hero-sweep-armed');
    if (document.readyState === 'complete') requestAnimationFrame(arm);
    else addEventListener('load', () => requestAnimationFrame(arm), { once: true });
  }
</script>

<script>
  // W368 — CTA magnétique : le bouton brass du héros suit très légèrement le
  // pointeur (±8 px max), transform seul (aucun reflow). Gated souris/trackpad
  // précis uniquement ((pointer:fine) — jamais sur tactile, où « pointermove »
  // n'a pas de sens) et prefers-reduced-motion. Progressive enhancement pur :
  // sans JS ou hors media match, le bouton reste un lien normal, taille et
  // position inchangées.
  const magnet = document.getElementById('hero-cta-magnetic');
  const canMagnet =
    matchMedia('(prefers-reduced-motion: no-preference)').matches && matchMedia('(pointer: fine)').matches;
  if (magnet && canMagnet) {
    const strength = 8; // px — déplacement maximal, discipline « chuchoté »
    let raf = 0;
    magnet.addEventListener('pointermove', (ev) => {
      const rect = magnet.getBoundingClientRect();
      const relX = (ev.clientX - rect.left) / rect.width - 0.5; // -0.5 … 0.5
      const relY = (ev.clientY - rect.top) / rect.height - 0.5;
      if (raf) cancelAnimationFrame(raf);
      raf = requestAnimationFrame(() => {
        magnet.style.transform = `translate(${(relX * 2 * strength).toFixed(1)}px, ${(relY * 2 * strength).toFixed(1)}px)`;
      });
    });
    magnet.addEventListener('pointerleave', () => {
      if (raf) cancelAnimationFrame(raf);
      magnet.style.transform = '';
    });
  }
</script>

<script>
  // W271 — Filtre de galerie par ville + lightbox. Pur DOM, sans dépendance.
  // Sans JS : toutes les cartes restent visibles et le bouton d'agrandissement
  // reste un <button> normal sans handler (progressive enhancement — jamais
  // un piège au clavier ou pour les lecteurs d'écran).

  // — Filtre ville —
  const filterGroup = document.querySelector<HTMLElement>('[data-gallery-filter]');
  const cards = Array.from(document.querySelectorAll<HTMLElement>('[data-gallery-card]'));
  if (filterGroup) {
    filterGroup.addEventListener('click', (ev) => {
      const btn = (ev.target as HTMLElement).closest<HTMLButtonElement>('button[data-city]');
      if (!btn) return;
      const city = btn.dataset.city;
      filterGroup.querySelectorAll<HTMLButtonElement>('button[data-city]').forEach((b) => {
        const active = b === btn;
        b.setAttribute('aria-pressed', active ? 'true' : 'false');
        b.classList.toggle('gallery-filter-chip-active', active);
        b.classList.toggle('border-brass-400', active);
        b.classList.toggle('bg-brass-400/10', active);
        b.classList.toggle('text-brass-300', active);
        b.classList.toggle('border-white/25', !active);
        b.classList.toggle('text-lune-soft', !active);
      });
      cards.forEach((card) => {
        const show = city === 'Toutes' || card.dataset.city === city;
        card.classList.toggle('gallery-card-hidden', !show);
      });
    });
  }

  // — Lightbox —
  const dialog = document.getElementById('gallery-lightbox') as HTMLDialogElement | null;
  if (dialog && typeof dialog.showModal === 'function') {
    const img = dialog.querySelector<HTMLImageElement>('[data-lightbox-img]');
    const captionEl = dialog.querySelector<HTMLElement>('[data-lightbox-caption]');
    const typeEl = dialog.querySelector<HTMLElement>('[data-lightbox-type]');
    const closeBtn = dialog.querySelector<HTMLButtonElement>('[data-lightbox-close]');

    let lastTrigger: HTMLElement | null = null;

    const openFromButton = (btn: HTMLElement) => {
      const name = btn.dataset.name ?? '';
      const widths = (btn.dataset.widths ?? '').split(',').map((w) => parseInt(w, 10)).filter((n) => !Number.isNaN(n));
      const largest = widths.length ? Math.max(...widths) : 1600;
      if (img) {
        img.src = `/photos/${name}-${largest}.webp`;
        img.alt = btn.dataset.alt ?? '';
      }
      if (captionEl) captionEl.textContent = btn.dataset.caption ?? '';
      if (typeEl) typeEl.textContent = btn.dataset.type ?? '';
      lastTrigger = btn;
      dialog.showModal();
    };

    document.querySelectorAll<HTMLButtonElement>('[data-lightbox-open]').forEach((btn) => {
      btn.addEventListener('click', () => openFromButton(btn));
    });

    const closeDialog = () => {
      dialog.close();
    };
    closeBtn?.addEventListener('click', closeDialog);

    // Clic sur le fond (backdrop) → fermeture. <dialog> natif gère déjà Échap.
    dialog.addEventListener('click', (ev) => {
      if (ev.target === dialog) closeDialog();
    });

    // Rendre le focus au déclencheur à la fermeture (accessibilité clavier).
    dialog.addEventListener('close', () => {
      lastTrigger?.focus();
    });
  }
</script>

<script>
  // W371 — Scrollytelling épinglé, UNIQUE sur la page (« Comment ça se passe »).
  // Progressive enhancement pur : sans JS, ou hors desktop, ou sous
  // prefers-reduced-motion, la section reste la grille plate d'origine — ce
  // script ne fait qu'AJOUTER une classe + un attribut, jamais de
  // scroll-jack (aucun preventDefault, aucun scrollTo forcé).
  const journeySection = document.querySelector<HTMLElement>('[data-journey-section]');
  const steps = Array.from(document.querySelectorAll<HTMLElement>('[data-journey-step]'));
  const caption = document.querySelector<HTMLElement>('[data-journey-caption]');

  if (journeySection && steps.length && 'IntersectionObserver' in window) {
    const desktopMotionOk = matchMedia('(min-width: 1024px) and (prefers-reduced-motion: no-preference)');

    let io: IntersectionObserver | null = null;

    const setActive = (step: HTMLElement) => {
      for (const s of steps) s.removeAttribute('data-journey-active');
      step.setAttribute('data-journey-active', '');
      if (caption) {
        const title = step.dataset.journeyTitle ?? '';
        const body = step.dataset.journeyBody ?? '';
        caption.textContent = title && body ? `${title} — ${body}` : '';
      }
    };

    const teardown = () => {
      io?.disconnect();
      io = null;
      journeySection.classList.remove('journey-pinned');
      for (const s of steps) s.removeAttribute('data-journey-active');
      if (caption) {
        caption.hidden = true;
        caption.textContent = '';
      }
    };

    const setup = () => {
      journeySection.classList.add('journey-pinned');
      if (caption) caption.hidden = false;
      // Le pas dont le centre est le plus proche du centre du viewport
      // « s'allume » — une fenêtre resserrée autour de la ligne médiane,
      // pas un simple seuil d'entrée, pour un couplage lecture/animation net.
      io = new IntersectionObserver(
        (entries) => {
          const visible = entries.filter((e) => e.isIntersecting);
          if (!visible.length) return;
          const closest = visible.reduce((best, e) =>
            Math.abs(e.boundingClientRect.top) < Math.abs(best.boundingClientRect.top) ? e : best
          );
          setActive(closest.target as HTMLElement);
        },
        { rootMargin: '-45% 0px -45% 0px', threshold: 0 }
      );
      for (const s of steps) io.observe(s);
      // Premier pas actif par défaut, avant tout croisement de seuil.
      setActive(steps[0]);
    };

    const sync = () => {
      if (desktopMotionOk.matches) setup();
      else teardown();
    };

    sync();
    desktopMotionOk.addEventListener('change', sync);
  }
</script>
