---
/**
 * À propos / Notre approche (W13 + W27) — centre le FONDATEUR et la MÉTHODE.
 * W27 (autorisé par le propriétaire) nomme désormais le parcours du fondateur :
 * docteur-ingénieur, 10+ ans de R&D chez Huawei, Ericsson et STMicroelectronics,
 * plus un court récit honnête (pourquoi un ingénieur lance une entreprise
 * solaire). AUCUN projet, date, titre, taille d'équipe ni anecdote inventés.
 * Page DISTINCTE de /pourquoi-taqinor (qui liste les différenciateurs) et
 * croisée avec elle — ici l'angle est « le fondateur et sa méthode ». Aucun
 * placeholder entre crochets. Page publique, indexée.
 */
import Layout from '../layouts/Layout.astro';
import V2Enhance from '../components/V2Enhance.astro';
import Article33Ribbon from '../components/Article33Ribbon.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import CtaBand from '../components/CtaBand.astro';
import StickyCta from '../components/StickyCta.astro';
import FounderPortrait from '../components/FounderPortrait.astro';
import InstallCounter from '../components/InstallCounter.astro';
import CertLogoRow from '../components/CertLogoRow.astro';
import { REALISATIONS } from '../lib/realisations';
import { NAP } from '../lib/nap';

/**
 * W345 — Presse & partenaires : factsheet DÉRIVÉE, aucun chiffre saisi à la
 * main. La ville vient de realisations.ts (déjà la source unique de vérité
 * utilisée par impact-taqinor.astro) ; RC/ICE sont les valeurs déjà publiées
 * sur mentions-legales.astro. Aucune date de création d'entreprise n'est
 * publiée nulle part sur le site — on ne l'invente donc pas ici ; le plus
 * ancien chantier documenté (realisations.ts) sert d'ancrage factuel à sa
 * place.
 *
 * RULE B (2026-07-04) : le compte brut d'installations n'est plus une
 * statistique publique mise en avant, et l'agrégat kWc installé (somme des
 * chantiers) ne l'est plus non plus — remplacés par des faits par chantier
 * déjà utilisés ailleurs sur le site (marques tier-1, chantier le plus
 * ancien).
 */
// realisations.ts liste aujourd'hui les chantiers du plus récent au plus
// ancien (avril 2026 → octobre 2025) : le dernier élément est le plus ancien
// documenté. Sert d'ancrage factuel — aucune date de création d'entreprise
// n'est publiée nulle part sur le site, donc on ne l'invente pas ici.
const earliestRealisation = REALISATIONS[REALISATIONS.length - 1];

// La méthode « l'étude d'abord, le chantier ensuite » — déroulé déjà décrit sur
// l'accueil et la page Pourquoi : diagnostic → échange technique → étude → pose
// → monitoring. Aucun délai chiffré inventé.
const etapes = [
  {
    n: '01',
    title: 'On lit la toiture et la facture',
    body: 'Surface utile, orientation, ombrage, consommation réelle : ces quatre données fixent la puissance et le matériel. Nous ne faisons que les lire et en tirer le bon dimensionnement. Le diagnostic et l’étude sont à 0 MAD.',
  },
  {
    n: '02',
    title: 'Le fondateur signe l’étude',
    body: 'Avant toute commande, le fondateur — docteur-ingénieur, plus de 10 ans de R&D — relit et valide personnellement le dimensionnement. Une étude qui sort d’ici a été défendue par quelqu’un qui répond du chiffre.',
  },
  {
    n: '03',
    title: 'On pose, dossier à l’appui',
    body: 'Marques tier-1 uniquement, installées avec leur dossier technique complet : schémas unifilaires, calcul de câbles, protections, mise en service. Nos chantiers de Casablanca, El Jadida et Nouaceur sont réels et se visitent sur demande.',
  },
  {
    n: '04',
    title: 'Le compteur prend le relais',
    body: 'Une fois en service, le suivi de production en temps réel relève la production en continu et le client garde son accès : ce qu’on avait annoncé devient lisible sur un compteur. En parallèle, le dossier loi 82-21 est mené à terme, déclaration ou régularisation comprise.',
  },
];
---

<Layout
  title="À propos — le fondateur, docteur-ingénieur, derrière chaque étude | Taqinor"
  description="Le fondateur de Taqinor est docteur-ingénieur, passé par plus de dix ans de R&D chez Huawei, Ericsson et STMicroelectronics. Il valide personnellement chaque étude avant la moindre commande de matériel. Voici pourquoi un ingénieur s’est mis au solaire, et ce que cela change pour vous."
  ogSlug="accueil"
>
  <div class="v2">
    <V2Enhance />
    <Article33Ribbon />

    <Breadcrumb items={[{ label: 'Accueil', href: '/' }, { label: 'À propos' }]} />

    <section class="px-4 pb-10 pt-16 text-white sm:pt-20">
      <div class="mx-auto max-w-3xl">
        <p class="tech-label v2-kicker rule-brass cine-in text-lune">Le fondateur</p>
        <h1 class="display v2-page-title cine-in mt-5 [animation-delay:120ms]">Un docteur-ingénieur valide chaque étude, à la main</h1>
        <p class="v2-lead cine-in mt-6 max-w-xl text-white/85 [animation-delay:240ms]">
          Le fondateur de Taqinor a passé plus de dix ans en recherche et développement chez
          <strong class="text-white">Huawei, Ericsson et STMicroelectronics</strong>. Il a quitté ce
          monde pour le solaire parce qu’il y a vu, partout, le même réflexe : vendre un kit avant
          d’avoir fait le calcul. Ici, l’ordre est inversé — et c’est lui qui signe le calcul.
        </p>
      </div>
    </section>

    {/* W266 — portrait réel + note signée à la première personne, composant
        partagé avec l'accueil (remplace l'ancien bloc <figure> en doublon
        dans ce héros ; mêmes faits, une seule source). */}
    <FounderPortrait />

    {/* W280 — InstallCounter : chiffres réels d'installations, dérivés de
        realisations.ts (aucun nombre fabriqué). No-op-safe : ne rend rien si
        REALISATIONS est vide. */}
    <section class="px-4 pb-4 sm:pb-6">
      <div class="mx-auto max-w-3xl">
        <InstallCounter />
      </div>
    </section>

    <!-- Le fondateur — ses standards, pas une biographie -->
    <div class="v2-seam" aria-hidden="true"></div>
    <section class="bg-blanc-azur px-4 pb-20 pt-10 text-encre sm:pb-24">
      <div class="mx-auto max-w-3xl">
        <p class="tech-label v2-kicker rule-brass text-azur-600">Un parcours d’ingénieur</p>
        <h2 class="display v2-section-title mt-5">Dix ans de R&D, mis au service de votre toiture</h2>
        <p class="v2-lead mt-5 text-encre-soft">
          Docteur-ingénieur, le fondateur a mené plus de dix ans de recherche et développement chez
          <strong class="text-encre">Huawei, Ericsson et STMicroelectronics</strong>. Trois maisons
          où une décision technique ne se prend pas à l’intuition : elle se mesure, se vérifie, et
          se défend chiffres à l’appui. C’est exactement cette discipline qu’il applique aujourd’hui
          à une installation solaire — un objet bien plus simple, mais dont l’économie tient
          pourtant à quelques paramètres qu’on néglige trop souvent de calculer.
        </p>
        <p class="mt-5 text-encre-soft">
          Concrètement, <strong class="text-encre">il valide personnellement chaque étude avant
          qu’une seule référence ne soit commandée</strong>. La puissance retenue, le choix de
          l’onduleur, l’opportunité d’une batterie : rien n’est décidé par un commercial pressé ou
          recopié d’un kit. Tout part de votre facture et de votre toiture, et tout est tranché par
          quelqu’un dont le métier, depuis plus de dix ans, est de lire ce genre de calcul. C’est
          cette signature qui sépare un dimensionnement d’une estimation au jugé.
        </p>
        <p class="mt-5 text-encre-soft">
          Pourquoi un ingénieur quitte la R&amp;D de pointe pour le solaire au Maroc ? Parce que le
          décalage y est devenu intenable : un actif qui engage le client sur vingt-cinq ans, vendu
          en une après-midi comme on vend un électroménager. Le solaire est d’abord un problème de
          mesure — combien vous consommez, quand, sur quelle surface, avec quel ombrage — et ce
          problème-là, un ingénieur sait le résoudre. Taqinor existe pour traiter chaque toiture
          comme un dossier technique, pas comme une vente.
        </p>
        <p class="mt-5 max-w-xl border-l-4 border-azur-600 pl-4 text-sm leading-relaxed text-encre-soft">
          Cette même rigueur nous conduit parfois à vous déconseiller le solaire, quand les chiffres
          ne suivent pas pour votre profil. Un ingénieur n’est pas payé pour placer du matériel : il
          est là pour dimensionner juste, ou dire non.
        </p>
      </div>
    </section>

    <!-- La méthode — l'étude d'abord, le chantier ensuite -->
    <section class="px-4 py-20 sm:py-28">
      <div class="mx-auto max-w-6xl">
        <p class="tech-label v2-kicker rule-brass text-lune">La méthode</p>
        <h2 class="display v2-section-title mt-5 text-white">Quatre temps, et l’ordre n’est pas négociable</h2>
        <p class="v2-lead mt-5 max-w-2xl text-lune-soft">
          La même logique se déroule du premier contact au suivi de production. Le calcul vient
          avant le devis, le devis avant la pose, la mesure après la pose : intervertir ces temps,
          c’est revenir au kit qu’on cherche justement à éviter.
        </p>
        <div class="mt-10 grid gap-6 md:grid-cols-2" data-stagger>
          {etapes.map((e, i) => (
            <div class="v2-rise cine-card flex flex-col p-7" style={`--v2-i:${i}`}>
              <p class="fig lum text-3xl">{e.n}</p>
              <h3 class="display mt-2 text-2xl text-white">{e.title}</h3>
              <p class="mt-3 flex-1 text-sm leading-relaxed text-lune-soft">{e.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Nos standards, en bref + renvoi vers Pourquoi (différenciateurs) -->
    <section class="border-y border-white/10 px-4 py-16 sm:py-20">
      <div class="mx-auto grid max-w-6xl gap-10 lg:grid-cols-[1.1fr_1fr] lg:items-center">
        <div class="v2-rise">
          <p class="tech-label v2-kicker rule-brass text-lune">Ce que la méthode produit</p>
          <h2 class="display v2-section-title mt-5 text-white">La même exigence, déclinée en quatre engagements</h2>
          <p class="v2-lead mt-5 text-lune-soft">
            La conviction du fondateur ne reste pas sur cette page : elle se lit dans les choix
            concrets de chaque chantier — matériel tier-1, suivi de production en temps réel avec accès client,
            dossier loi 82-21 mené à terme, installations qu’on peut aller voir. Vous voulez ces
            différences détaillées, point par point ? C’est l’objet de la page <strong class="text-white">Pourquoi Taqinor</strong>.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href="/pourquoi-taqinor" class="bg-brass-400 px-6 py-3 text-sm font-bold text-azur-950 transition-colors hover:bg-brass-300">Pourquoi Taqinor →</a>
            <a href="/realisations" class="border border-white/40 px-6 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">Nos réalisations →</a>
          </div>
        </div>
        <dl class="grid grid-cols-2 gap-x-6 gap-y-10 border-l-2 border-white/25 pl-6 sm:pl-10" data-stagger>
          <div class="v2-rise" style="--v2-i:0">
            <dd class="font-display text-xl font-bold text-white">Docteur-ingénieur</dd>
            <dt class="tech-label mt-2 text-lune-faint">10+ ans d’expertise R&D — chaque étude validée</dt>
          </div>
          <div class="v2-rise" style="--v2-i:1">
            <dd class="font-display text-xl font-bold text-white">Suivi en temps réel</dd>
            <dt class="tech-label mt-2 text-lune-faint">Production mesurée, accès client inclus</dt>
          </div>
          <div class="v2-rise" style="--v2-i:2">
            <dd class="font-display text-xl font-bold text-white">Tier-1 only</dd>
            <dt class="tech-label mt-2 text-lune-faint">Canadian Solar, JA Solar, Deye, Huawei, Dyness</dt>
          </div>
          <div class="v2-rise" style="--v2-i:3">
            <dd class="font-display text-xl font-bold text-white">Loi 82-21</dd>
            <dt class="tech-label mt-2 text-lune-faint">Déclaration et régularisation, de bout en bout</dt>
          </div>
        </dl>
      </div>
    </section>

    {/* W280 — CertLogoRow : normes/garanties déjà publiées ailleurs (garanties.astro),
        no-op-safe (aucun logo fabriqué). */}
    <section class="border-y border-white/10 px-4 py-14 sm:py-16">
      <div class="mx-auto max-w-6xl">
        <CertLogoRow />
      </div>
    </section>

    <!-- W345 — Presse & partenaires : porte dédiée, distincte du formulaire de vente -->
    <div class="v2-seam" aria-hidden="true"></div>
    <section class="border-y border-white/10 bg-blanc-azur px-4 py-16 text-encre sm:py-20">
      <div class="mx-auto max-w-5xl">
        <p class="tech-label v2-kicker rule-brass text-azur-600">Presse & partenaires</p>
        <h2 class="display v2-section-title mt-5">Vous représentez un média, une banque ou un partenaire ?</h2>
        <p class="v2-lead mt-5 max-w-2xl text-encre-soft">
          Un journaliste, une banque ou un partenaire potentiel qui vérifie notre identité n'a pas
          besoin d'un devis — voici de quoi instruire un dossier, et un canal dédié pour aller plus
          loin.
        </p>

        <div class="mt-10 grid gap-8 lg:grid-cols-[1.1fr_1fr]">
          {/* Fiche factuelle — chaque chiffre est dérivé, aucun n'est saisi à la main */}
          <dl class="grid grid-cols-2 gap-x-6 gap-y-8 border-t-2 border-azur-900 pt-6">
            <div>
              <dd class="font-display text-2xl font-bold">{NAP.name}</dd>
              <dt class="tech-label mt-2 text-encre-faint">Raison sociale</dt>
            </div>
            <div>
              <dd class="font-display text-2xl font-bold">Casablanca</dd>
              <dt class="tech-label mt-2 text-encre-faint">Registre de commerce (RC 691213)</dt>
            </div>
            <div>
              <dd class="font-display text-2xl font-bold">Tier-1 only</dd>
              <dt class="tech-label mt-2 text-encre-faint">Canadian Solar, JA Solar, Deye, Huawei, Dyness</dt>
            </div>
            <div>
              <dd class="font-display text-2xl font-bold">{earliestRealisation.date}</dd>
              <dt class="tech-label mt-2 text-encre-faint">Chantier documenté le plus ancien ({earliestRealisation.ville})</dt>
            </div>
          </dl>

          {/* Canal presse dédié + logo téléchargeable */}
          <div class="border-2 border-azur-600/30 bg-blanc p-7 text-center sm:p-8">
            <p class="tech-label text-azur-600">Contact presse & partenariats</p>
            <p class="mt-3 text-sm leading-relaxed text-encre-soft">
              Écrivez-nous directement — précisez qu'il s'agit d'une demande presse ou partenariat
              pour un traitement adapté, distinct de nos demandes de devis.
            </p>
            <p class="mt-5">
              <a href={`mailto:${NAP.email}`} class="font-semibold underline decoration-azur-600 decoration-2 underline-offset-4" dir="ltr">{NAP.email}</a>
            </p>
            <p class="mt-2">
              <a href={`tel:${NAP.phone}`} class="text-sm underline decoration-azur-600 decoration-2 underline-offset-4" dir="ltr">{NAP.phoneDisplayIntl}</a>
            </p>
            <a
              href="/logo.png"
              download
              class="mt-6 inline-flex items-center gap-2 border border-azur-900/25 px-5 py-2.5 text-sm font-semibold text-encre transition-colors hover:border-azur-600"
            >
              Télécharger le logo (PNG) ↓
            </a>
          </div>
        </div>

        <p class="mx-auto mt-10 max-w-2xl border-l-4 border-azur-600 pl-4 text-xs leading-relaxed text-encre-faint">
          Identité légale complète (RC, ICE) sur la page <a href="/mentions-legales" class="underline decoration-azur-600 decoration-2 underline-offset-4">Mentions légales</a>.
        </p>
      </div>
    </section>

    <CtaBand title="Mettez le fondateur sur votre toiture : l’étude est gratuite." href="/devis/mon-toit" />

    <StickyCta />
  </div>
</Layout>
