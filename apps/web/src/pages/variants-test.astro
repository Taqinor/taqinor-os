---
/**
 * Page de travail PRIVÉE — variantes de conversion à arbitrer par le
 * propriétaire. Non liée, noindex, exclue du sitemap. AUCUNE variante
 * n'est en production : la prod reste la version actuelle tant qu'un
 * choix n'est pas donné. Tous les chiffres viennent du dossier
 * entreprise ou de la logique ROI — aucun fait inventé.
 *
 * NOTE pour le propriétaire : l'exemple « 2 400 → 400 MAD » suggéré ne
 * figure ni dans le dossier ni dans la logique ROI — il n'est donc PAS
 * utilisé. Fournissez une facture avant/après réelle et la variante A
 * sera reconstruite autour.
 */
import '../styles/global.css';

const variants = {
  headlines: [
    {
      id: 'H-A',
      angle: 'Résultat chiffré',
      h1: '21 406 kWh par an, produits sur un toit d’El Jadida.',
      sub: 'Installation réf. 468 — 17,04 kWc, dimensionnée, posée et mesurée par Taqinor. La vôtre commence par un diagnostic de 60 secondes.',
      hypothese: 'Les acheteurs marocains comparent : un résultat réel et vérifiable ancre la crédibilité dès la première seconde — mieux qu’une promesse.',
    },
    {
      id: 'H-B',
      angle: 'Preuve / vérifiabilité',
      h1: 'La production est mesurée. Le dossier technique est remis.',
      sub: 'Cinq installations livrées en 2026, toutes suivies sur SolarMan. Le solaire en ingénieur — schémas, calculs et garanties à l’appui.',
      hypothese: 'La décision se joue sur la légitimité du vendeur : la vérifiabilité (monitoring, dossier remis) est le différenciateur le plus défendable.',
    },
    {
      id: 'H-C',
      angle: 'Indépendance',
      h1: 'Votre toit produit. Le réseau devient l’appoint.',
      sub: 'Autoconsommation avec stockage, dimensionnée sur votre consommation réelle — conforme loi 82-21, partout au Maroc.',
      hypothese: 'Le motif d’autonomie (hausse des tarifs, coupures) est le déclencheur émotionnel le plus fort du résidentiel — formulé en ingénieur, pas en slogan.',
    },
  ],
  ctas: [
    {
      id: 'C-1',
      label: 'Recevez votre étude sur WhatsApp',
      step1: 'Votre étude commence ici',
      hypothese: 'Continuité de promesse : le canal (WhatsApp) est annoncé dès le bouton — zéro surprise, friction minimale au Maroc.',
    },
    {
      id: 'C-2',
      label: 'Diagnostic gratuit',
      step1: 'Votre situation',
      hypothese: 'Cadrage « diagnostic » (actuel) : technique, gratuit, sans engagement — le moins commercial des trois.',
    },
    {
      id: 'C-3',
      label: 'Calculez votre économie réelle',
      step1: 'Votre facture aujourd’hui',
      hypothese: 'Cadrage « calculateur » : invite l’auto-évaluation, attire les comparateurs — le mot « réelle » oppose Taqinor aux promesses gonflées.',
    },
  ],
};
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Variantes — privé</title>
    <meta name="robots" content="noindex, nofollow" />
  </head>
  <body class="bg-blanc-azur font-sans text-encre antialiased">
    <div class="mx-auto max-w-6xl px-4 py-10">
      <h1 class="display text-2xl">Variantes de conversion — à arbitrer</h1>
      <p class="mt-2 max-w-2xl text-sm text-encre-soft">
        Rien de tout ceci n'est en production. Ordre de priorité (impact conversion) :
        titre du héros → libellé du CTA → composition du héros → placement de la preuve.
        Chaque chiffre vient du dossier ou de la logique ROI.
        <strong class="text-alert-600">L'exemple « 2 400 → 400 MAD » n'est pas traçable au dossier — non utilisé
        (fournir une facture avant/après réelle pour le reconstruire).</strong>
      </p>

      <!-- ============ 1. TITRES DU HÉROS ============ -->
      <h2 class="display mt-12 text-xl">1 — Titre du héros × 3 <span class="text-sm font-normal text-encre-soft">(sur l'affiche vidéo réelle, largeur pleine + mobile 375)</span></h2>
      {variants.headlines.map((v) => (
        <section class="mt-6 border border-azur-900/15 bg-blanc">
          <header class="flex flex-wrap items-baseline justify-between gap-2 bg-azur-950 px-5 py-3 text-white">
            <strong>{v.id} — {v.angle}</strong>
          </header>
          <!-- Desktop pleine largeur -->
          <div class="relative isolate overflow-hidden bg-azur-950 text-white">
            <img src="/videos/hero-poster-1600.webp" alt="" class="absolute inset-0 -z-10 h-full w-full object-cover" loading="lazy" />
            <div class="absolute inset-0 -z-10 bg-gradient-to-r from-azur-950/95 via-azur-950/60 to-azur-950/15"></div>
            <div class="px-8 pb-14 pt-12">
              <p class="tech-label rule-brass text-brass-300">L'étude d'abord, le chantier ensuite</p>
              <h3 class="display mt-4 max-w-[18ch] text-[clamp(1.8rem,4.5vw,3.4rem)]">{v.h1}</h3>
              <p class="mt-4 max-w-xl text-base leading-relaxed text-white/85">{v.sub}</p>
              <div class="mt-7 flex flex-wrap gap-3">
                <span class="bg-brass-400 px-7 py-3.5 font-bold text-azur-950">Diagnostic gratuit</span>
                <span class="border border-white/40 px-6 py-3.5 font-semibold text-white">WhatsApp direct</span>
              </div>
            </div>
          </div>
          <!-- Mobile 375 -->
          <div class="flex justify-center bg-blanc-azur py-6">
            <div class="w-[375px] overflow-hidden border-4 border-azur-950">
              <div class="relative isolate overflow-hidden bg-azur-950 text-white">
                <img src="/videos/hero-poster-720.webp" alt="" class="absolute inset-0 -z-10 h-full w-full object-cover" loading="lazy" />
                <div class="absolute inset-0 -z-10 bg-gradient-to-r from-azur-950/95 via-azur-950/65 to-azur-950/30"></div>
                <div class="px-4 pb-10 pt-8">
                  <p class="tech-label rule-brass text-brass-300">L'étude d'abord</p>
                  <h3 class="display mt-3 text-[1.7rem]">{v.h1}</h3>
                  <p class="mt-3 text-sm leading-relaxed text-white/85">{v.sub}</p>
                  <div class="mt-5 flex flex-col gap-2.5">
                    <span class="bg-brass-400 px-6 py-3 text-center font-bold text-azur-950">Diagnostic gratuit</span>
                    <span class="border border-white/40 px-6 py-3 text-center font-semibold text-white">WhatsApp direct</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <p class="border-t border-azur-900/10 px-5 py-3 text-sm text-encre-soft"><strong>Hypothèse :</strong> {v.hypothese}</p>
        </section>
      ))}

      <!-- ============ 2. LIBELLÉ DU CTA ============ -->
      <h2 class="display mt-14 text-xl">2 — CTA principal × 3 <span class="text-sm font-normal text-encre-soft">(chacun avec le titre d'étape 1 assorti — la promesse continue sans rupture)</span></h2>
      <div class="mt-6 grid gap-6 lg:grid-cols-3">
        {variants.ctas.map((c) => (
          <section class="border border-azur-900/15 bg-blanc">
            <header class="bg-azur-950 px-5 py-3 font-bold text-white">{c.id}</header>
            <div class="space-y-5 p-6">
              <span class="inline-block bg-brass-400 px-7 py-3.5 font-bold text-azur-950">{c.label}</span>
              <div class="border border-azur-900/15 p-4">
                <div class="flex gap-2" aria-hidden="true">
                  <span class="h-1 flex-1 bg-azur-600"></span><span class="h-1 flex-1 bg-azur-100"></span><span class="h-1 flex-1 bg-azur-100"></span>
                </div>
                <p class="tech-label mt-2 text-encre-faint">Étape 1 sur 3</p>
                <p class="display mt-2 text-lg">{c.step1}</p>
                <p class="mt-1 text-xs text-encre-faint">Facture d'électricité mensuelle * · Type de toiture *</p>
              </div>
              <p class="text-sm text-encre-soft"><strong>Hypothèse :</strong> {c.hypothese}</p>
            </div>
          </section>
        ))}
      </div>

      <!-- ============ 3. COMPOSITION DU HÉROS ============ -->
      <h2 class="display mt-14 text-xl">3 — Composition du héros × 2</h2>
      <section class="mt-6 border border-azur-900/15 bg-blanc">
        <header class="bg-azur-950 px-5 py-3 font-bold text-white">3-A — Vidéo plein cadre <span class="font-normal text-azur-200">(ACTUEL, en production)</span></header>
        <div class="relative isolate overflow-hidden bg-azur-950 text-white">
          <img src="/videos/hero-poster-1600.webp" alt="" class="absolute inset-0 -z-10 h-full w-full object-cover" loading="lazy" />
          <div class="absolute inset-0 -z-10 bg-gradient-to-r from-azur-950/95 via-azur-950/60 to-azur-950/15"></div>
          <div class="px-8 pb-14 pt-12">
            <p class="tech-label rule-brass text-brass-300">L'étude d'abord, le chantier ensuite</p>
            <h3 class="display mt-4 max-w-[16ch] text-[clamp(1.8rem,4.5vw,3.4rem)]">Votre électricité, produite sur votre toit.</h3>
            <p class="mt-4 max-w-xl text-white/85">Taqinor conçoit, installe et déclare des installations solaires dimensionnées par l'ingénierie.</p>
            <div class="mt-7"><span class="bg-brass-400 px-7 py-3.5 font-bold text-azur-950">Diagnostic gratuit</span></div>
          </div>
        </div>
        <p class="border-t border-azur-900/10 px-5 py-3 text-sm text-encre-soft"><strong>Hypothèse :</strong> l'image réelle en mouvement prouve « on installe vraiment » — registre émotionnel, lecture instantanée.</p>
      </section>
      <section class="mt-6 border border-azur-900/15 bg-blanc">
        <header class="bg-azur-950 px-5 py-3 font-bold text-white">3-B — « Extrait d'étude » : texte + carte de données réelles</header>
        <div class="relative isolate overflow-hidden bg-azur-950 text-white">
          <img src="/videos/hero-poster-1600.webp" alt="" class="absolute inset-0 -z-10 h-full w-full object-cover opacity-40" loading="lazy" />
          <div class="absolute inset-0 -z-10 bg-gradient-to-r from-azur-950 via-azur-950/90 to-azur-900/70"></div>
          <div class="grid gap-10 px-8 pb-14 pt-12 lg:grid-cols-[1.1fr_1fr] lg:items-center">
            <div>
              <p class="tech-label rule-brass text-brass-300">L'étude d'abord, le chantier ensuite</p>
              <h3 class="display mt-4 max-w-[16ch] text-[clamp(1.8rem,4vw,3rem)]">Votre électricité, produite sur votre toit.</h3>
              <p class="mt-4 max-w-lg text-white/85">Chaque installation Taqinor est livrée avec son dossier technique et suivie sur SolarMan. Voici à quoi ressemble le résultat.</p>
              <div class="mt-7"><span class="bg-brass-400 px-7 py-3.5 font-bold text-azur-950">Diagnostic gratuit</span></div>
            </div>
            <div class="border-t-4 border-brass-400 bg-blanc p-6 text-encre shadow-[0_30px_70px_-30px_rgb(0_0_0/0.6)]">
              <p class="tech-label text-brass-600">Extrait d'étude — réf. 400 · Casablanca · avril 2026</p>
              <div class="mt-5 grid grid-cols-2 gap-x-4 gap-y-6">
                <div><p class="fig text-4xl text-azur-600">11,36 <span class="text-lg">kWc</span></p><p class="tech-label mt-1.5 text-encre-faint">Puissance installée</p></div>
                <div><p class="fig text-4xl text-azur-600">14 271 <span class="text-lg">kWh/an</span></p><p class="tech-label mt-1.5 text-encre-faint">Production mesurée</p></div>
                <div><p class="fig text-4xl text-azur-600">16 <span class="text-lg">panneaux</span></p><p class="tech-label mt-1.5 text-encre-faint">Canadian Solar 710 Wc</p></div>
                <div><p class="fig text-4xl text-azur-600">10 <span class="text-lg">kWh</span></p><p class="tech-label mt-1.5 text-encre-faint">Stockage Dyness LFP</p></div>
              </div>
              <p class="mt-5 border-t border-azur-900/10 pt-3 text-xs text-encre-soft">Production suivie sur SolarMan — accès client inclus.</p>
            </div>
          </div>
        </div>
        <p class="border-t border-azur-900/10 px-5 py-3 text-sm text-encre-soft"><strong>Hypothèse :</strong> montrer le livrable (l'extrait d'étude) au-dessus de la ligne de flottaison — registre rationnel, prouve la compétence avant tout argument.</p>
      </section>

      <!-- ============ 4. PLACEMENT DE LA PREUVE ============ -->
      <h2 class="display mt-14 text-xl">4 — Placement de la preuve × 2</h2>
      <section class="mt-6 border border-azur-900/15 bg-blanc">
        <header class="bg-azur-950 px-5 py-3 font-bold text-white">4-A — Actuel : fiches chantier en section dédiée, diagnostic ensuite <span class="font-normal text-azur-200">(en production)</span></header>
        <p class="px-5 py-3 text-sm text-encre-soft">Séquence actuelle de l'accueil : galerie → vidéo → fiches chantier → diagnostic. La preuve prépare la demande mais en est séparée.</p>
      </section>
      <section class="mt-6 border border-azur-900/15 bg-blanc">
        <header class="bg-azur-950 px-5 py-3 font-bold text-white">4-B — Fiche la plus forte ACCOLÉE au diagnostic</header>
        <div class="bg-blanc-azur p-6">
          <div class="mx-auto grid max-w-4xl gap-6 lg:grid-cols-[1.2fr_1fr]">
            <div class="border border-azur-900/15 bg-blanc p-6">
              <p class="tech-label text-azur-600">Diagnostic · sans engagement</p>
              <p class="display mt-2 text-xl">Diagnostic solaire — 60 secondes</p>
              <div class="mt-4 flex gap-2" aria-hidden="true"><span class="h-1 flex-1 bg-azur-600"></span><span class="h-1 flex-1 bg-azur-100"></span><span class="h-1 flex-1 bg-azur-100"></span></div>
              <p class="mt-4 text-sm text-encre-soft">Facture d'électricité mensuelle *</p>
              <div class="mt-1 border border-azur-900/20 px-3 py-2.5 text-sm text-encre-faint">Choisir une tranche…</div>
              <p class="mt-3 text-sm text-encre-soft">Type de toiture *</p>
              <div class="mt-1 border border-azur-900/20 px-3 py-2.5 text-sm text-encre-faint">Choisir…</div>
              <span class="mt-5 inline-block bg-azur-600 px-6 py-3 font-bold text-white">Continuer →</span>
            </div>
            <aside class="flex flex-col border border-azur-900/15 border-t-4 border-t-azur-600 bg-blanc p-6">
              <p class="tech-label text-encre-faint">Dernière installation livrée</p>
              <p class="fig mt-3 text-4xl text-azur-600">17,04 kWc</p>
              <p class="tech-label mt-1 text-encre-faint">El Jadida · avril 2026</p>
              <p class="mt-4 text-sm text-encre-soft">Production : <strong class="text-encre">21 406 kWh/an</strong><br />24 × Canadian Solar 710 Wc · Deye 15 kW · 15 kWh Dyness</p>
              <p class="mt-4 border-t border-azur-900/10 pt-3 text-xs text-encre-faint">Production mesurée — SolarMan. Visites de site possibles sur demande.</p>
            </aside>
          </div>
        </div>
        <p class="border-t border-azur-900/10 px-5 py-3 text-sm text-encre-soft"><strong>Hypothèse :</strong> la preuve sociale adjacente au formulaire lève l'hésitation au moment exact de la demande (littérature conversion : +15-30 %).</p>
      </section>
    </div>
  </body>
</html>
