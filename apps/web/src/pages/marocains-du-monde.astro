---
/**
 * Marocains du monde / MRE (W7). Utilise UNIQUEMENT le positionnement déjà
 * présent sur le site (WhatsApp-first, diagnostic à distance, monitoring Deye
 * Cloud avec accès client, conformité loi 82-21, zone = tout le Maroc). Aucun
 * claim factuel nouveau, aucun SLA inventé.
 */
import Layout from '../layouts/Layout.astro';
import V2Enhance from '../components/V2Enhance.astro';
import Article33Ribbon from '../components/Article33Ribbon.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import Picture from '../components/Picture.astro';
import WhatsAppMock from '../components/WhatsAppMock.astro';
import CtaBand from '../components/CtaBand.astro';
import StickyCta from '../components/StickyCta.astro';
import { WHATSAPP_LEADS } from '../lib/nap';
import { whatsappLink } from '../lib/whatsapp';

const wa = whatsappLink(WHATSAPP_LEADS, 'Bonjour, je suis Marocain·e à l’étranger et je souhaite étudier une installation solaire pour ma villa au Maroc.');

const etapes = [
  { n: '1', body: 'Diagnostic en 60 secondes — vous obtenez une fourchette immédiate, où que vous soyez.' },
  { n: '2', body: 'Échange WhatsApp direct avec l’équipe technique : vous (ou un proche sur place) envoyez les photos de toiture, nous coordonnons à distance.' },
  { n: '3', body: 'Visite technique sur site, étude complète gratuite, puis devis — vous n’avez pas besoin d’être au Maroc pour lancer l’étude.' },
];
---

<Layout
  title="Marocains du monde : votre installation solaire au Maroc, suivie à distance | Taqinor"
  description="Vous êtes Marocain·e à l'étranger ? Taqinor installe et suit votre installation solaire au Maroc à distance — diagnostic et coordination par WhatsApp, monitoring Deye Cloud avec accès client, conformité loi 82-21, partout au Maroc."
  ogSlug="accueil"
>
  <div class="v2">
    <V2Enhance />
    <Article33Ribbon />

    <Breadcrumb items={[{ label: 'Accueil', href: '/' }, { label: 'Marocains du monde' }]} />

    <section class="relative isolate mt-6 overflow-hidden text-white">
      <div class="v2-hero-media absolute inset-0 -z-10">
        <Picture name="crepuscule-penthouse" alt="" widths={[1600, 1024, 640]} ratio={4 / 3} sizes="100vw"
          loading="eager" fetchpriority="high" class="h-full w-full object-cover object-[65%_40%]" />
        <div class="absolute inset-0 bg-gradient-to-t from-nuit via-nuit/55 to-nuit/25"></div>
      </div>
      <div class="mx-auto max-w-6xl px-4 pb-16 pt-24 sm:pb-20 sm:pt-32">
        <p class="tech-label v2-kicker rule-brass cine-in text-brass-300">Marocains du monde · MRE</p>
        <h1 class="display v2-page-title cine-in mt-5 max-w-[22ch] [animation-delay:120ms]">
          Vous êtes Marocain·e à l’étranger ?
        </h1>
        <p class="v2-lead cine-in mt-6 max-w-2xl text-white/85 [animation-delay:240ms]">
          Nous installons et suivons l’installation de votre villa au Maroc, à distance, de
          l’étude au monitoring. Tout commence par un échange WhatsApp — pas de centre d’appels,
          pas de relances.
        </p>
      </div>
    </section>

    <!-- À distance, mais sur le terrain -->
    <section class="border-y border-white/10 px-4 py-20 sm:py-24">
      <div class="mx-auto grid max-w-6xl items-center gap-12 lg:grid-cols-[1.1fr_1fr]">
        <div class="v2-rise">
          <p class="tech-label v2-kicker rule-brass text-brass-300">Comment ça se passe</p>
          <h2 class="display v2-section-title mt-5 max-w-md text-white">La distance n’est pas un obstacle</h2>
          <p class="v2-lead mt-5 max-w-md text-lune-soft">
            Votre diagnostic arrive sur WhatsApp, vous échangez directement avec l’équipe
            technique, photos de toiture à l’appui, jusqu’à la visite sur site. Vous n’avez pas
            besoin d’être au Maroc pour lancer l’étude.
          </p>
          <ol class="mt-8 space-y-3 text-sm text-lune">
            {etapes.map((e) => (
              <li class="flex gap-3"><span class="fig lum text-lg">{e.n}.</span>{e.body}</li>
            ))}
          </ol>
          <a href={wa} rel="noopener" class="mt-8 inline-flex items-center gap-2 bg-ok-600 px-6 py-3.5 text-base font-bold text-white transition-opacity hover:opacity-90">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 0 0-8.6 15.1L2 22l5-1.3A10 10 0 1 0 12 2Zm5.4 14.1c-.2.6-1.3 1.2-1.8 1.2-.5.1-1 .2-3.3-.7-2.8-1.1-4.6-4-4.7-4.2-.1-.2-1.1-1.5-1.1-2.9s.7-2 1-2.3c.2-.3.5-.3.7-.3h.5c.2 0 .4 0 .6.4l.9 2.1c.1.2.1.4 0 .6l-.4.6-.5.5c-.2.2-.3.4-.1.7.2.3.9 1.4 1.9 2.3 1.3 1.1 2.3 1.5 2.6 1.6.3.1.5.1.7-.1l1-1.2c.2-.3.4-.2.7-.1l2 1c.3.1.5.2.6.4 0 .1 0 .7-.3 1.4Z"/></svg>
            Démarrer sur WhatsApp
          </a>
        </div>
        <div class="v2-rise">
          <WhatsAppMock />
        </div>
      </div>
    </section>

    <!-- Suivi à distance + conformité -->
    <section class="px-4 py-20 sm:py-24">
      <div class="mx-auto grid max-w-6xl gap-8 md:grid-cols-3" data-stagger>
        <div class="v2-rise" style="--v2-i:0">
          <h3 class="display text-xl text-white">Suivez votre production de l’étranger</h3>
          <p class="mt-3 text-sm leading-relaxed text-lune-soft">Chaque installation est supervisée sur Deye Cloud, avec accès client inclus : depuis l’application mobile, vous voyez la production de votre villa en temps réel, où que vous soyez.</p>
        </div>
        <div class="v2-rise" style="--v2-i:1">
          <h3 class="display text-xl text-white">La conformité, gérée pour vous</h3>
          <p class="mt-3 text-sm leading-relaxed text-lune-soft">Déclaration ou régularisation loi 82-21 : nous identifions le régime et constituons le dossier, sans que vous ayez à vous déplacer. <a href="/loi-82-21" class="border-b border-brass-400 pb-0.5 font-semibold text-brass-300 transition-colors hover:text-brass-200">Voir les régimes →</a></p>
        </div>
        <div class="v2-rise" style="--v2-i:2">
          <h3 class="display text-xl text-white">Partout au Maroc</h3>
          <p class="mt-3 text-sm leading-relaxed text-lune-soft">Casablanca, Rabat, Marrakech, Tanger, Agadir — et tout le Maroc. <a href="/realisations" class="border-b border-brass-400 pb-0.5 font-semibold text-brass-300 transition-colors hover:text-brass-200">Voir nos réalisations →</a></p>
        </div>
      </div>
      <div class="mx-auto mt-10 flex max-w-6xl flex-wrap gap-3">
        <a href="/résidentiel" class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">Solaire résidentiel →</a>
        <a href="/pourquoi-taqinor" class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">Pourquoi Taqinor →</a>
      </div>
    </section>

    <CtaBand title="Votre villa au Maroc, étudiée et suivie à distance." href="/contact#simulateur" />

    <StickyCta />
  </div>
</Layout>
