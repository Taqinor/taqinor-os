---
/**
 * W114/W115/W118 — DESIGN DEVIS (interne, authentifié, noindex).
 *
 * Page de travail de Meriem : ouvre ?lead=<id>, se connecte à l'ERP (JWT), charge
 * le lead (repère/contour + contact), boote le builder COMPLET (mode normal) hydraté
 * avec le repère du client (W113), laisse dessiner/auto-remplir/éditer (panneaux +
 * optimiseur visibles ICI), puis « Valider & générer le devis » :
 *   1. sérialise le layout finalisé (W113),
 *   2. POST /api/django/ventes/devis/from-layout/  {layout, lead}  (Bearer JWT),
 *   3. POST /api/django/ventes/devis/<id>/layout/   (persistance idempotente),
 *   4. W115 — capture le PNG de la 3D et POST /devis/<id>/roof-image/ (multipart),
 *   5. W118 — surface le lien de proposition tokenisé (WhatsApp / e-mail / copier).
 *
 * Le jeton d'accès vit en sessionStorage (jamais de persistance longue durée). Les
 * panneaux/optimiseur n'apparaissent QUE sur cette page authentifiée — jamais sur la
 * capture client publique.
 */
import Layout from '../../layouts/Layout.astro';

const inputClass =
  'w-full border border-white/15 bg-white/5 px-3 py-3 text-base text-white placeholder:text-lune-faint outline-none transition-colors focus:border-brass-400 focus:ring-2 focus:ring-brass-400/30';
const chipClass =
  'rp9-chip border border-white/20 px-3.5 py-2 text-sm font-semibold text-lune-soft transition-colors hover:border-brass-400 hover:text-brass-300';
---

<Layout
  title="Design devis (interne) | Taqinor"
  description="Page de travail interne, non indexée."
  noindex={true}
>
  <section class="bg-nuit px-4 py-10 sm:py-14">
    <div class="mx-auto max-w-6xl">
      <p class="tech-label rule-brass text-brass-300">Interne · design devis</p>

      <!-- LOGIN — minimal, inline. Caché une fois authentifié. -->
      <form id="dd-login" class="cine-card mt-6 max-w-md space-y-4 p-6">
        <h1 class="display text-xl text-white">Connexion ERP</h1>
        <p class="text-sm text-lune-soft">Connectez-vous pour charger le lead et générer le devis.</p>
        <label class="block text-sm text-lune-soft">
          Identifiant ERP
          <input id="dd-user" type="text" autocomplete="username" class={`${inputClass} mt-1`} />
        </label>
        <label class="block text-sm text-lune-soft">
          Mot de passe
          <input id="dd-pass" type="password" autocomplete="current-password" class={`${inputClass} mt-1`} />
        </label>
        <p id="dd-login-error" hidden class="text-sm text-alert-300" aria-live="polite"></p>
        <button type="submit" id="dd-login-btn"
          class="w-full bg-brass-400 px-6 py-3 text-base font-bold text-azur-950 transition-colors hover:bg-brass-300 disabled:opacity-50">
          Se connecter
        </button>
      </form>

      <!-- ATELIER — masqué tant qu'on n'est pas authentifié + un lead chargé. -->
      <div id="dd-workspace" hidden class="mt-6">
        <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-2">
          <h1 class="display text-xl text-white sm:text-2xl">
            Lead <span id="dd-lead-id" class="text-brass-300">—</span> ·
            <span id="dd-lead-name" class="text-lune-soft">—</span>
          </h1>
          <button type="button" id="dd-logout"
            class="border border-white/25 px-3 py-2 text-xs font-semibold text-lune-soft transition-colors hover:border-brass-400 hover:text-brass-300">
            Se déconnecter
          </button>
        </div>
        <p id="dd-status" class="mt-2 text-sm text-lune-faint" aria-live="polite">Chargement du lead…</p>

        <!-- ÉTAPE FACTURE (alimente le besoin de l'optimiseur). -->
        <div class="cine-card mt-6 p-5">
          <label for="rp9-bill" class="block text-sm text-lune-soft">
            Facture d'électricité moyenne par mois (MAD)
          </label>
          <div class="mt-2 flex items-center gap-3">
            <input id="rp9-bill" name="bill" type="text" inputmode="decimal" step="any"
              placeholder="ex. 1 500" class={`${inputClass} max-w-[12rem]`} />
            <span class="text-xs text-lune-faint">≈ <span id="rp9-bill-kwh" class="fig">—</span> par an</span>
          </div>
        </div>

        <!-- BUILDER — DOM complet (mêmes ids que la preview pro-11). Le tool boote en
             mode normal (panneaux + optimiseur). On garde le strict nécessaire ; les
             sous-panneaux facultatifs sont null-gardés côté script. -->
        <div class="cine-card mt-6 overflow-hidden">
          <form id="rp9-search" class="flex flex-col gap-3 border-b border-white/10 p-4 sm:flex-row">
            <label for="rp9-address" class="sr-only">Adresse</label>
            <div class="relative flex-1">
              <input id="rp9-address" name="address" type="text" autocomplete="off"
                role="combobox" aria-autocomplete="list" aria-expanded="false"
                aria-controls="rp9-suggestions" aria-haspopup="listbox"
                placeholder="Adresse du client" class={inputClass} />
              <ul id="rp9-suggestions" role="listbox" aria-label="Suggestions d'adresses" hidden
                class="absolute left-0 right-0 top-full z-20 mt-1 max-h-72 overflow-auto border border-white/15 bg-nuit-900 shadow-xl"></ul>
            </div>
            <button type="submit" class="flex-none bg-brass-400 px-6 py-3 text-base font-bold text-azur-950 hover:bg-brass-300">Localiser</button>
          </form>

          <div id="rp9-map" class="h-[56vh] min-h-[360px] w-full bg-nuit-700"
            role="application" aria-label="Carte 3D pour dessiner le toit">
            <div id="rp9-compass" class="rp9-compass" aria-hidden="true">
              <div id="rp9-compass-arrow" class="rp9-compass-arrow"><span>N</span><span>S</span></div>
            </div>
          </div>

          <div class="flex flex-wrap items-center gap-3 border-t border-white/10 p-4">
            <button type="button" id="rp9-finish" disabled class={`${chipClass} disabled:opacity-40`}>Terminer le tracé</button>
            <button type="button" id="rp9-undo-point" hidden class={chipClass}>Annuler le dernier point</button>
            <button type="button" id="rp9-clear" class={chipClass}>Effacer</button>
            <button type="button" id="rp9-add-area" disabled class={`${chipClass} disabled:opacity-50`}>+ Ajouter une zone</button>
            <p class="ml-auto text-sm text-lune-faint"><span>Surface&nbsp;: </span><span id="rp9-area-value" class="text-white">—</span></p>
          </div>

          <!-- Contrôles de config (mode normal) -->
          <div id="rp9-config" hidden class="space-y-4 border-t border-white/10 bg-nuit-800 p-4">
            <div class="flex flex-wrap items-center gap-2">
              <span class="tech-label mr-1 text-lune-faint">Type de toit</span>
              <button type="button" data-rooftype="flat" class={chipClass} aria-pressed="true">Toit plat</button>
              <button type="button" data-rooftype="pitched" class={chipClass} aria-pressed="false">Toit en pente / tuiles</button>
            </div>
            <div class="flex flex-wrap items-center gap-2">
              <button type="button" id="rp9-optimum" class={`${chipClass} border-brass-400 text-brass-300`}>↺ Réinitialiser</button>
              <span id="rp9-optimum-note" class="min-w-0 flex-1 text-xs text-lune-faint"></span>
            </div>
            <div id="rp9-flat-controls" class="space-y-4">
              <div id="rp9-flat-only" class="space-y-4">
                <div class="flex flex-wrap items-center gap-2">
                  <span class="tech-label mr-1 text-lune-faint">Orientation</span>
                  <button type="button" data-family="south" class={chipClass} aria-pressed="true">Plein sud<span class="rp9-reco-badge" hidden> ✓</span></button>
                  <button type="button" data-family="eastwest" class={chipClass} aria-pressed="false">Est-Ouest<span class="rp9-reco-badge" hidden> ✓</span></button>
                </div>
                <div class="flex flex-wrap items-center gap-2">
                  <span class="tech-label mr-1 text-lune-faint">Inclinaison</span>
                  <button type="button" data-tilt="reco" class={chipClass} aria-pressed="true">Recommandé<span class="rp9-reco-badge" hidden> ✓</span></button>
                  <button type="button" data-tilt="29" class={chipClass} aria-pressed="false">29°<span class="rp9-reco-badge" hidden> ✓</span></button>
                  <button type="button" data-tilt="15" class={chipClass} aria-pressed="false">15°<span class="rp9-reco-badge" hidden> ✓</span></button>
                  <button type="button" data-tilt="10" class={chipClass} aria-pressed="false">10°<span class="rp9-reco-badge" hidden> ✓</span></button>
                </div>
                <div class="flex items-center gap-3">
                  <label for="rp9-tilt-range" class="tech-label shrink-0 text-lune-faint">Inclinaison fine</label>
                  <input id="rp9-tilt-range" type="range" min="5" max="35" step="1" value="29" class="rp9-range min-w-0 flex-1" />
                  <span id="rp9-tilt-value" class="w-16 shrink-0 text-right text-sm font-semibold text-brass-300">29°</span>
                </div>
                <div id="rp9-azimuth-group" hidden class="flex flex-wrap items-center gap-2">
                  <span class="tech-label mr-1 text-lune-faint">Azimut</span>
                  <button type="button" data-azimuth="south" class={chipClass} aria-pressed="true">Plein sud<span class="rp9-reco-badge" hidden> ✓</span></button>
                  <button type="button" data-azimuth="aligned" class={chipClass} aria-pressed="false">Aligné toit<span class="rp9-reco-badge" hidden> ✓</span></button>
                </div>
              </div>
              <div class="flex flex-wrap items-center gap-2">
                <span class="tech-label mr-1 text-lune-faint">Panneaux</span>
                <button type="button" data-orient="auto" class={chipClass} aria-pressed="true">Auto</button>
                <button type="button" data-orient="portrait" class={chipClass} aria-pressed="false">Portrait<span class="rp9-reco-badge" hidden> ✓</span></button>
                <button type="button" data-orient="landscape" class={chipClass} aria-pressed="false">Paysage<span class="rp9-reco-badge" hidden> ✓</span></button>
              </div>
              <div class="flex flex-wrap items-center gap-2">
                <span class="tech-label mr-1 text-lune-faint">Marge de rive</span>
                <button type="button" data-margin="keep" class={chipClass} aria-pressed="true">Garder<span class="rp9-reco-badge" hidden> ✓</span></button>
                <button type="button" data-margin="remove" class={chipClass} aria-pressed="false">Pleine rive<span class="rp9-reco-badge" hidden> ✓</span></button>
              </div>
              <div class="flex flex-wrap items-center gap-2">
                <label for="rp9-overhang-input" class="tech-label mr-1 text-lune-faint">Débord (m)</label>
                <input id="rp9-overhang-input" type="number" inputmode="decimal" step="any" min="0" value="0"
                  class="fig h-9 w-20 border border-white/20 bg-nuit-900 px-2 text-center text-base text-white outline-none focus:border-brass-400" />
              </div>
            </div>
            <div id="rp9-pitched-controls" hidden class="space-y-4">
              <div class="flex flex-wrap items-center gap-2">
                <span class="tech-label mr-1 text-lune-faint">Pente</span>
                <button type="button" data-pitch="15" class={chipClass} aria-pressed="false">~15°</button>
                <button type="button" data-pitch="22" class={chipClass} aria-pressed="true">~22°</button>
                <button type="button" data-pitch="30" class={chipClass} aria-pressed="false">~30°</button>
                <button type="button" data-pitch="45" class={chipClass} aria-pressed="false">~45°</button>
              </div>
              <div class="flex items-center gap-3">
                <label for="rp9-pitch-range" class="tech-label shrink-0 text-lune-faint">Pente fine</label>
                <input id="rp9-pitch-range" type="range" min="5" max="45" step="1" value="22" class="rp9-range min-w-0 flex-1" />
                <span id="rp9-pitch-value" class="w-12 shrink-0 text-right text-sm font-semibold text-brass-300">22°</span>
              </div>
              <div class="flex flex-wrap items-center gap-2">
                <span class="tech-label mr-1 text-lune-faint">Face du pan</span>
                <button type="button" data-facing="180" class={chipClass} aria-pressed="true">Sud</button>
                <button type="button" data-facing="135" class={chipClass} aria-pressed="false">Sud-Est</button>
                <button type="button" data-facing="225" class={chipClass} aria-pressed="false">Sud-Ouest</button>
                <button type="button" data-facing="90" class={chipClass} aria-pressed="false">Est</button>
                <button type="button" data-facing="270" class={chipClass} aria-pressed="false">Ouest</button>
              </div>
              <p id="rp9-facing-note" class="min-h-[1rem] text-xs text-lune-faint" aria-live="polite"></p>
              <div class="flex items-center gap-3">
                <label for="rp9-facing-range" class="tech-label shrink-0 text-lune-faint">Sens de la pente</label>
                <input id="rp9-facing-range" type="range" min="0" max="359" step="any" value="180" class="rp9-range min-w-0 flex-1" />
                <span id="rp9-facing-value" class="w-28 shrink-0 text-right text-sm font-semibold text-brass-300">Sud · 180°</span>
              </div>
              <p id="rp9-pitched-note" class="min-h-[1.25rem] text-xs text-lune-soft" aria-live="polite"></p>
            </div>
          </div>
          <p id="rp9-status" class="border-t border-white/10 px-4 py-3 text-sm text-lune-faint" aria-live="polite">Chargement…</p>
        </div>

        <!-- RECOMMANDATION (panneaux/optimiseur visibles ici) -->
        <div id="rp9-results" class="rp9-results cine-card mt-6 p-6">
          <p class="tech-label rule-brass text-brass-300">Recommandation</p>
          <p id="rp9-reco-title" class="fig mt-4 text-2xl text-brass-300">—</p>
          <div class="mt-5 border border-white/10 bg-nuit-800/60 p-4">
            <label for="rp9-need-input" class="tech-label text-lune-faint">Panneaux nécessaires</label>
            <div class="mt-2 flex items-center gap-3">
              <button type="button" id="rp9-need-minus" aria-label="Un de moins" class="h-11 w-11 border border-white/25 text-2xl text-white">−</button>
              <input id="rp9-need-input" type="text" inputmode="numeric" value="—" disabled
                class="fig h-11 w-20 border border-white/20 bg-nuit-900 text-center text-2xl text-white" />
              <button type="button" id="rp9-need-plus" aria-label="Un de plus" class="h-11 w-11 border border-white/25 text-2xl text-white">+</button>
            </div>
            <p id="rp9-need-note" class="mt-2 min-h-[1.5rem] text-xs text-lune-faint" aria-live="polite"></p>
          </div>
          <dl class="mt-5 grid grid-cols-2 gap-x-6 gap-y-6" aria-live="polite">
            <div><dd id="rp9-reco-kwc" class="fig text-2xl text-white">—</dd><dt class="tech-label mt-1 text-lune-faint">Puissance</dt></div>
            <div><dd id="rp9-reco-panels" class="fig text-2xl text-white">—</dd><dt class="tech-label mt-1 text-lune-faint">Panneaux</dt></div>
            <div><dd id="rp9-reco-prod" class="fig text-xl text-white">—</dd><dt class="tech-label mt-1 text-lune-faint">Production</dt></div>
            <div><dd id="rp9-reco-cover" class="fig text-xl text-white">—</dd><dt class="tech-label mt-1 text-lune-faint">Couverture</dt></div>
          </dl>
          <div class="mt-5 border-t border-white/10 pt-5">
            <dd id="rp9-reco-savings" class="fig text-xl text-brass-300">—</dd>
            <dt class="tech-label mt-1 text-lune-faint">Économies estimées</dt>
          </div>
          <p id="rp9-reco-why" class="mt-5 min-h-[3.5rem] text-xs text-lune-soft"></p>
          <p id="rp9-reco-bifacial" class="mt-2 text-xs text-lune-faint/80"></p>
          <p id="rp9-reco-band" class="mt-2 min-h-[2.5rem] text-xs text-lune-faint/80" aria-live="polite"></p>
          <p id="rp9-maxline" class="mt-3 text-xs text-lune-faint"></p>
        </div>

        <!-- VALIDER & GÉNÉRER -->
        <div class="cine-card mt-6 p-6">
          <button type="button" id="dd-generate"
            class="inline-flex w-full items-center justify-center gap-2 bg-ok-600 px-6 py-4 text-base font-bold text-white transition-opacity hover:opacity-90 disabled:cursor-not-allowed disabled:opacity-50">
            Valider & générer le devis
          </button>
          <p id="dd-gen-status" hidden class="mt-3 text-sm text-lune-soft" aria-live="polite"></p>
          <p id="dd-gen-error" hidden class="mt-3 text-sm text-alert-300" aria-live="polite"></p>

          <!-- W118 — LIVRAISON : lien de proposition + WhatsApp / e-mail / copier. -->
          <div id="dd-deliver" hidden class="mt-5 space-y-4 border-t border-white/10 pt-5">
            <p class="tech-label text-brass-300">Devis créé · <span id="dd-ref" class="text-white">—</span></p>
            <label class="block text-sm text-lune-soft">
              Lien de la proposition
              <input id="dd-proposal-url" type="text" readonly class={`${inputClass} mt-1`} />
            </label>
            <div class="flex flex-wrap gap-3">
              <a id="dd-wa" href="#" target="_blank" rel="noopener"
                class="inline-flex items-center gap-2 bg-ok-600 px-4 py-2.5 text-sm font-bold text-white hover:opacity-90">WhatsApp</a>
              <a id="dd-mail" href="#"
                class="inline-flex items-center gap-2 border border-brass-400 px-4 py-2.5 text-sm font-bold text-brass-300 hover:bg-brass-400/10">E-mail</a>
              <button type="button" id="dd-copy"
                class="inline-flex items-center gap-2 border border-white/25 px-4 py-2.5 text-sm font-semibold text-lune-soft hover:border-brass-400 hover:text-brass-300">Copier le lien</button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .rp9-reco-badge { margin-left: 0.35rem; font-size: 0.7rem; font-weight: 700; color: var(--color-brass-300, #f3cc66); }
  .rp9-results { min-height: 320px; }
  .rp9-map :global(.maplibregl-map) { position: absolute; inset: 0; }
  #rp9-map { position: relative; }
  .rp9-chip[aria-pressed='true'] {
    border-color: var(--color-brass-400, #e8b54a);
    color: var(--color-brass-300, #f3cc66);
    background: rgb(232 181 74 / 0.15);
  }
  .rp9-compass { position: absolute; top: 12px; left: 12px; z-index: 2; width: 48px; height: 48px;
    border-radius: 9999px; background: rgb(7 11 29 / 0.72); pointer-events: none; }
  .rp9-compass-arrow { position: absolute; inset: 0; display: flex; flex-direction: column;
    align-items: center; justify-content: space-between; padding: 5px 0; font: 700 0.7rem/1 sans-serif; }
</style>

<script>
  import { whatsappLink } from '../../lib/whatsapp';
  import { designProposalUrl, designWhatsappText, designMailto } from '../../lib/devisDesign';

  const API_BASE = (import.meta.env.PUBLIC_API_BASE ?? 'https://api.taqinor.ma') as string;
  const TOKEN_KEY = 'taqinor_erp_access';
  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const $ = <T extends HTMLElement>(id: string) => document.getElementById(id) as T | null;
  const loginForm = $<HTMLFormElement>('dd-login');
  const workspace = $('dd-workspace');
  const statusEl = $('dd-status');
  const loginErr = $('dd-login-error');

  type RoofToolApi = { serializeLayout: (billKwh?: number | null) => unknown; snapshot: () => string | null };
  let api: RoofToolApi | null = null;
  let leadId = '';
  let lead: Record<string, unknown> | null = null;
  let started = false;

  const params = new URLSearchParams(location.search);
  leadId = params.get('lead') ?? '';

  function token(): string | null {
    try { return sessionStorage.getItem(TOKEN_KEY); } catch { return null; }
  }
  function setToken(t: string | null) {
    try { if (t) sessionStorage.setItem(TOKEN_KEY, t); else sessionStorage.removeItem(TOKEN_KEY); } catch { /* sessionStorage indispo */ }
  }
  function authHeaders(): Record<string, string> {
    const t = token();
    return t ? { authorization: `Bearer ${t}` } : {};
  }

  function showLogin(msg?: string) {
    if (loginForm) loginForm.hidden = false;
    if (workspace) workspace.hidden = true;
    if (msg && loginErr) { loginErr.textContent = msg; loginErr.hidden = false; }
  }

  async function login(username: string, password: string): Promise<boolean> {
    try {
      const res = await fetch(`${API_BASE}/api/django/token/`, {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        // Champ générique « Identifiant ERP » → on envoie username ET email (au cas où).
        body: JSON.stringify({ username, email: username, password }),
      });
      if (!res.ok) return false;
      const data = (await res.json()) as { access?: string };
      if (!data.access) return false;
      setToken(data.access);
      return true;
    } catch {
      return false;
    }
  }

  async function loadLead(): Promise<boolean> {
    const res = await fetch(`${API_BASE}/api/django/crm/leads/${encodeURIComponent(leadId)}/`, {
      headers: { ...authHeaders() },
    });
    if (res.status === 401) { setToken(null); showLogin('Session expirée — reconnectez-vous.'); return false; }
    if (!res.ok) { if (statusEl) statusEl.textContent = `Lead introuvable (erreur ${res.status}).`; return false; }
    lead = (await res.json()) as Record<string, unknown>;
    return true;
  }

  async function boot() {
    if (started) return;
    if (!leadId) { if (statusEl) statusEl.textContent = 'Aucun lead indiqué (?lead=<id> manquant).'; return; }
    const ok = await loadLead();
    if (!ok || !lead) return;
    started = true;
    if (loginForm) loginForm.hidden = true;
    if (workspace) workspace.hidden = false;
    // Affiche l'identité du lead.
    const name = (lead.fullName as string) || '';
    $('dd-lead-id')!.textContent = leadId;
    $('dd-lead-name')!.textContent = name || '—';
    // Pré-remplit l'adresse depuis le lead.
    const addrEl = $<HTMLInputElement>('rp9-address');
    if (addrEl && lead.city) addrEl.value = String(lead.city);

    // Clé carte publique + boot du builder COMPLET, hydraté avec le repère du client.
    let key = '';
    let mapboxToken = '';
    try {
      const cfg = (await (await fetch('/api/roof-config')).json()) as { available?: boolean; maptilerKey?: string; mapboxToken?: string };
      if (cfg.available && cfg.maptilerKey) { key = cfg.maptilerKey; mapboxToken = cfg.mapboxToken || ''; }
    } catch { /* repli sans carte */ }
    if (!key) { if (statusEl) statusEl.textContent = 'Carte indisponible (clé manquante).'; return; }

    const mod = await import('../../scripts/roof-tool-pro11.ts');
    mod.initRoofToolPro8({
      maptilerKey: key,
      mapboxToken: mapboxToken || undefined,
      reducedMotion,
      hydrate: { lead: lead as never },
      onApiReady: (a) => { api = a; },
    });
    if (statusEl) statusEl.textContent = 'Repère du client chargé. Dessinez/ajustez, puis « Valider & générer le devis ».';
  }

  loginForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (loginErr) loginErr.hidden = true;
    const u = $<HTMLInputElement>('dd-user')?.value.trim() ?? '';
    const p = $<HTMLInputElement>('dd-pass')?.value ?? '';
    const btn = $<HTMLButtonElement>('dd-login-btn');
    if (btn) btn.disabled = true;
    const ok = await login(u, p);
    if (btn) btn.disabled = false;
    if (!ok) { showLogin('Identifiant ou mot de passe incorrect.'); return; }
    await boot();
  });

  $('dd-logout')?.addEventListener('click', () => { setToken(null); location.reload(); });

  // — Génération du devis (W114) + snapshot (W115) + livraison (W118) —
  const genBtn = $<HTMLButtonElement>('dd-generate');
  const genStatus = $('dd-gen-status');
  const genErr = $('dd-gen-error');

  function setGenStatus(msg: string) { if (genStatus) { genStatus.textContent = msg; genStatus.hidden = false; } }
  function setGenError(msg: string) { if (genErr) { genErr.textContent = msg; genErr.hidden = false; } }

  /** Convertit un data URL PNG en Blob (pour l'upload multipart). */
  function dataUrlToBlob(dataUrl: string): Blob | null {
    const m = /^data:([^;]+);base64,(.*)$/.exec(dataUrl);
    if (!m) return null;
    const mime = m[1];
    const bin = atob(m[2]);
    const bytes = new Uint8Array(bin.length);
    for (let i = 0; i < bin.length; i++) bytes[i] = bin.charCodeAt(i);
    return new Blob([bytes], { type: mime });
  }

  genBtn?.addEventListener('click', async () => {
    if (genErr) genErr.hidden = true;
    if (!api) { setGenError('Outil non prêt — tracez le toit puis réessayez.'); return; }
    const t = token();
    if (!t) { showLogin('Session expirée — reconnectez-vous.'); return; }
    genBtn.disabled = true;
    setGenStatus('Génération du devis…');
    try {
      const layout = api.serializeLayout();
      // 1) Crée le devis depuis le layout.
      const createRes = await fetch(`${API_BASE}/api/django/ventes/devis/from-layout/`, {
        method: 'POST',
        headers: { 'content-type': 'application/json', ...authHeaders() },
        body: JSON.stringify({ layout, lead: leadId }),
      });
      if (createRes.status === 401) { setToken(null); showLogin('Session expirée — reconnectez-vous.'); genBtn.disabled = false; return; }
      if (!createRes.ok) {
        setGenError(`Création du devis impossible (erreur ${createRes.status}).`);
        genBtn.disabled = false;
        return;
      }
      const devis = (await createRes.json()) as { id: number; reference: string; proposal_token: string; proposal_path: string };

      // 2) Persistance idempotente du layout finalisé.
      await fetch(`${API_BASE}/api/django/ventes/devis/${devis.id}/layout/`, {
        method: 'POST',
        headers: { 'content-type': 'application/json', ...authHeaders() },
        body: JSON.stringify(layout),
      }).catch(() => { /* persistance best-effort, on continue */ });

      // 3) W115 — capture le PNG de la 3D et l'envoie (multipart).
      setGenStatus('Capture de la vue 3D…');
      const png = api.snapshot();
      if (png) {
        const blob = dataUrlToBlob(png);
        if (blob) {
          const fd = new FormData();
          fd.append('image', blob, `devis-${devis.id}.png`);
          await fetch(`${API_BASE}/api/django/ventes/devis/${devis.id}/roof-image/`, {
            method: 'POST',
            headers: { ...authHeaders() },
            body: fd,
          }).catch(() => { /* image best-effort */ });
        }
      }

      // 4) W118 — surface le lien de proposition + WhatsApp / e-mail / copier.
      const proposalUrl = designProposalUrl(location.origin, devis.proposal_path);
      $('dd-ref')!.textContent = devis.reference;
      const urlInput = $<HTMLInputElement>('dd-proposal-url');
      if (urlInput) urlInput.value = proposalUrl;

      const phone = (lead?.phone as string) || '';
      const name = (lead?.fullName as string) || '';
      const email = (lead?.email as string) || '';
      const waEl = $<HTMLAnchorElement>('dd-wa');
      const mailEl = $<HTMLAnchorElement>('dd-mail');
      if (waEl) {
        if (phone) { waEl.href = whatsappLink(phone, designWhatsappText(name, proposalUrl)); waEl.hidden = false; }
        else waEl.hidden = true;
      }
      if (mailEl) {
        if (email) { mailEl.href = designMailto(email, name, proposalUrl); mailEl.hidden = false; }
        else mailEl.hidden = true;
      }
      $('dd-copy')?.addEventListener('click', () => {
        try { void navigator.clipboard?.writeText(proposalUrl); } catch { /* presse-papier indispo */ }
      });
      $('dd-deliver')!.hidden = false;
      setGenStatus(`Devis ${devis.reference} créé.`);
    } catch {
      setGenError('Erreur réseau pendant la génération. Réessayez.');
      genBtn.disabled = false;
    }
  });

  // — Démarrage : si déjà authentifié (token en session), on boote directement. —
  if (token()) void boot();
  else showLogin();
</script>
