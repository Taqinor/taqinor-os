---
import Layout from '../layouts/Layout.astro';
import Article33Ribbon from '../components/Article33Ribbon.astro';
import DiagnosticForm from '../components/DiagnosticForm.astro';
import { NAP } from '../lib/nap';
import { whatsappLink, regularizationWhatsappText } from '../lib/whatsapp';

const waGeneral = whatsappLink(NAP.whatsapp, 'Bonjour, je souhaite une étude pour une installation solaire.');
const waRegul = whatsappLink(NAP.whatsapp, regularizationWhatsappText());
---

<Layout
  title="Contact — étude solaire gratuite | Taqinor"
  description="Demandez votre étude solaire gratuite : formulaire d'estimation immédiate, WhatsApp direct, intervention dans tout le Maroc. Réponse sous 24 h ouvrées."
  ogSlug="contact"
>
  <Article33Ribbon />

  <section class="bg-azur-900 px-4 py-14 text-white">
    <div class="mx-auto max-w-6xl">
      <p class="tech-label rule-brass text-brass-300">Réponse sous 24 h ouvrées</p>
      <h1 class="display mt-4 max-w-2xl text-4xl sm:text-5xl">Parlons de votre installation</h1>
      <p class="mt-4 max-w-xl leading-relaxed text-white/85">
        Le formulaire vous donne une fourchette immédiate. Pour aller plus vite,
        écrivez-nous directement sur WhatsApp.
      </p>
    </div>
  </section>

  <DiagnosticForm heading="Diagnostic solaire — estimation immédiate" />

  <section class="mx-auto max-w-2xl px-4 pb-16">
    <div class="grid gap-4 sm:grid-cols-2">
      <a href={waGeneral} rel="noopener"
        class="group border border-azur-900/15 bg-blanc p-6 text-center transition-all hover:-translate-y-0.5 hover:border-azur-600 hover:shadow-[0_14px_40px_-16px_rgb(15_28_84/0.4)]">
        <p class="tech-label text-azur-600">Nouveau projet</p>
        <p class="mt-2 font-display font-bold">WhatsApp — nouvelle installation</p>
        <p class="mt-1 text-sm text-encre-soft">Étude et devis pour un nouveau projet</p>
      </a>
      <a href={waRegul} rel="noopener"
        class="group border border-azur-900/15 bg-blanc p-6 text-center transition-all hover:-translate-y-0.5 hover:border-azur-600 hover:shadow-[0_14px_40px_-16px_rgb(15_28_84/0.4)]">
        <p class="tech-label text-azur-600">Article 33</p>
        <p class="mt-2 font-display font-bold">WhatsApp — régularisation</p>
        <p class="mt-1 text-sm text-encre-soft">Installation existante à mettre en conformité</p>
      </a>
    </div>

    <div class="mt-8 border border-azur-900/15 bg-blanc-azur p-7 text-center text-sm">
      <p class="font-display text-lg font-bold">{NAP.name}</p>
      <p class="mt-2">
        <a href={`tel:${NAP.phone}`} class="font-semibold underline decoration-azur-600 decoration-2 underline-offset-4">{NAP.phoneDisplay}</a>
        &nbsp;·&nbsp;
        <a href={`mailto:${NAP.email}`} class="underline decoration-azur-600 decoration-2 underline-offset-4">{NAP.email}</a>
      </p>
      <p class="mt-3 text-encre-soft">
        Zone d'intervention : {NAP.serviceArea.slice(0, -1).join(', ')} — déplacements dans tout le Maroc.
      </p>
      <p class="mt-1 text-xs text-encre-faint">Interventions sur site uniquement — pas d'accueil du public en agence.</p>
    </div>
  </section>
</Layout>
