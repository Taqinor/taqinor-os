---
import Layout from '../layouts/Layout.astro';
import Article33Ribbon from '../components/Article33Ribbon.astro';
import LeadForm from '../components/LeadForm.astro';
import { NAP } from '../lib/nap';
import { whatsappLink, regularizationWhatsappText } from '../lib/whatsapp';

const waGeneral = whatsappLink(NAP.whatsapp, 'Bonjour, je souhaite une étude pour une installation solaire.');
const waRegul = whatsappLink(NAP.whatsapp, regularizationWhatsappText());
---

<Layout
  title="Contact — étude solaire gratuite | Taqinor"
  description="Demandez votre étude solaire gratuite : formulaire d'estimation immédiate, WhatsApp direct, intervention dans tout le Maroc. Réponse sous 24 h ouvrées."
  ogSlug="contact"
>
  <Article33Ribbon />

  <section class="grid-paper-dark bg-night px-4 py-14 text-paper">
    <div class="mx-auto max-w-6xl">
      <p class="tech-label rule-amber text-amber-400">Réponse sous 24 h ouvrées</p>
      <h1 class="display mt-4 max-w-2xl text-4xl sm:text-5xl">Parlons de votre installation</h1>
      <p class="mt-4 max-w-xl leading-relaxed text-paper/85">
        Le formulaire vous donne une fourchette immédiate. Pour aller plus vite,
        écrivez-nous directement sur WhatsApp.
      </p>
    </div>
  </section>

  <LeadForm heading="Demande d'étude — estimation immédiate" />

  <section class="mx-auto max-w-2xl px-4 pb-16">
    <div class="grid gap-4 sm:grid-cols-2">
      <a href={waGeneral} rel="noopener"
        class="group border border-ink/15 bg-paper p-6 text-center transition-all hover:-translate-y-0.5 hover:shadow-[6px_6px_0_0_rgb(245_193_0)]">
        <p class="tech-label text-ink-faint">Nouveau projet</p>
        <p class="mt-2 font-display font-bold">WhatsApp — nouvelle installation</p>
        <p class="mt-1 text-sm text-ink-soft">Étude et devis pour un nouveau projet</p>
      </a>
      <a href={waRegul} rel="noopener"
        class="group border border-ink/15 bg-paper p-6 text-center transition-all hover:-translate-y-0.5 hover:shadow-[6px_6px_0_0_rgb(245_193_0)]">
        <p class="tech-label text-ink-faint">Article 33</p>
        <p class="mt-2 font-display font-bold">WhatsApp — régularisation</p>
        <p class="mt-1 text-sm text-ink-soft">Installation existante à mettre en conformité</p>
      </a>
    </div>

    <div class="mt-8 border border-ink/15 bg-sand/60 p-7 text-center text-sm">
      <p class="font-display text-lg font-bold">{NAP.name}</p>
      <p class="mt-2">
        <a href={`tel:${NAP.phone}`} class="font-mono text-sm underline decoration-amber-400 decoration-2 underline-offset-4">{NAP.phoneDisplay}</a>
        &nbsp;·&nbsp;
        <a href={`mailto:${NAP.email}`} class="underline decoration-amber-400 decoration-2 underline-offset-4">{NAP.email}</a>
      </p>
      <p class="mt-3 text-ink-soft">
        Zone d'intervention : {NAP.serviceArea.slice(0, -1).join(', ')} — déplacements dans tout le Maroc.
      </p>
      <p class="mt-1 text-xs text-ink-faint">Interventions sur site uniquement — pas d'accueil du public en agence.</p>
    </div>
  </section>
</Layout>
