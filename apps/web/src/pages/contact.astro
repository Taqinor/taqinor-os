---
/**
 * Page publique — élévation « élégance retenue » : typographie éditoriale,
 * révélations au défilement, chiffres count-up, parallaxe d'en-tête (desktop)
 * + mouvement photo (Ken Burns d'en-tête, montée d'échelle au défilement).
 * Tout le mouvement est désactivé sous prefers-reduced-motion.
 * Voir apps/web/DESIGN_RATIONALE.md.
 *
 * W262 — Zone d'intervention reformulée honnêtement : axe Casablanca–Rabat
 * (où sont les chantiers réels) + les autres villes NAP.serviceArea nommées
 * sur devis, plus de « déplacements dans tout le Maroc » implicite.
 *
 * W249 — /contact devient la page « parler à un humain » : le formulaire
 * DiagnosticForm (qui dupliquait la capture de /devis/mon-toit et de
 * l'accueil) est retiré d'ici. DiagnosticForm.astro + /api/simulate restent
 * intacts dans le code comme repli documenté (montés ailleurs) — cette page
 * ne contenait déjà, sous le formulaire, que des portes humaines (WhatsApp,
 * téléphone, NAP, SAV) : elle en devient la version pure, avec en plus un
 * rappel téléphonique explicite.
 *
 * WJ97 — [correctif] « Demander un rappel » n'était qu'un lien wa.me
 * MISLABELED comme un rappel téléphonique : cliquer dessus ouvrait WhatsApp
 * (pas un appel) et ne créait AUCUN lead CRM — la demande n'atteignait jamais
 * personne côté ERP tant que le client n'envoyait pas lui-même le message. La
 * carte « Par téléphone » porte désormais un VRAI mini-formulaire (nom +
 * téléphone, `#rappel-form` plus bas) qui poste un lead via
 * `/api/capture-lead` avec `contactPreference: 'phone_ok'` + `quickCallback:
 * true` (lib/lead.ts) — DISTINCT de tout CTA WhatsApp (canal `whatsapp_only`)
 * — pendant que le lien WhatsApp original reste disponible juste à côté,
 * clairement étiqueté comme un canal séparé.
 */
import Layout from '../layouts/Layout.astro';
import V2Enhance from '../components/V2Enhance.astro';
import Article33Ribbon from '../components/Article33Ribbon.astro';
import StarRating from '../components/StarRating.astro';
import { NAP, WHATSAPP_LEADS } from '../lib/nap';
import { whatsappLink, regularizationWhatsappText } from '../lib/whatsapp';

const waGeneral = whatsappLink(WHATSAPP_LEADS, 'Bonjour, je souhaite une étude pour une installation solaire.');
const waRegul = whatsappLink(WHATSAPP_LEADS, regularizationWhatsappText());
// W249 — rappel téléphonique : message WhatsApp pré-rempli qui demande
// explicitement un rappel (plutôt qu'un devis en ligne) — porte humaine pour
// qui préfère parler de vive voix.
const waRappel = whatsappLink(
  WHATSAPP_LEADS,
  'Bonjour, pouvez-vous me rappeler par téléphone pour parler de mon projet solaire ?',
);

/**
 * W285 — « Visiter un chantier » devient une action : même invitation que
 * pourquoi-taqinor.astro (« Demandez à visiter »), mais ici sous forme de
 * raccourci WhatsApp direct plutôt qu'un simple lien vers /realisations.
 */
const waVisite = whatsappLink(
  WHATSAPP_LEADS,
  'Bonjour, je souhaite visiter une installation réelle Taqinor avant de me décider.',
);

/**
 * W339 — « Déjà client ? » porte SAV/urgence, SÉPARÉE des portes de
 * prospection commerciale ci-dessus (nouveau projet / rappel / régularisation).
 * Même numéro WhatsApp que le reste du site (WHATSAPP_LEADS — un seul numéro connu à ce
 * jour), mais un message pré-rempli qui identifie explicitement un signalement
 * de panne sur une installation EXISTANTE, pour que l'équipe SAV le route
 * différemment d'une demande de devis dès la première lecture.
 */
const waSav = whatsappLink(
  WHATSAPP_LEADS,
  'Bonjour, je suis déjà client Taqinor et je signale un problème sur mon installation existante (SAV). Merci de me recontacter.',
);
---

<Layout
  title="Contact — parlez à un humain | Taqinor"
  description="WhatsApp direct, rappel téléphonique, coordonnées complètes : parlez à l'équipe technique Taqinor pour votre projet solaire. Réponse sous 48 h ouvrées."
  ogSlug="contact"
>
  <div class="v2">
    <V2Enhance />
    <Article33Ribbon />

    <section class="px-4 py-20 text-white">
      <div class="mx-auto max-w-6xl">
        <p class="tech-label v2-kicker rule-brass cine-in text-brass-300">Réponse sous 48 h ouvrées</p>
        <h1 class="display v2-page-title cine-in mt-5 max-w-2xl [animation-delay:120ms]">Parlez à un humain</h1>
        <p class="v2-lead cine-in mt-5 max-w-xl text-white/85 [animation-delay:240ms]">
          Pas de formulaire ici : écrivez-nous directement sur WhatsApp, appelez, ou demandez à être
          rappelé. Pour une estimation chiffrée en 60 secondes, le diagnostic vit sur la page d'accueil.
        </p>
        {/* W280 — StarRating : note Google réelle uniquement, no-op-safe
            (n'affiche rien tant que le fondateur n'a pas renseigné une vraie note). */}
        <div class="cine-in mt-6 [animation-delay:320ms]">
          <StarRating />
        </div>
      </div>
    </section>

    <!-- W249 — page « parler à un humain » : les raccourcis WhatsApp/téléphone et la fiche NAP -->
    <section class="bg-blanc-azur px-4 py-16 text-encre">
      <div class="mx-auto max-w-4xl">
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4" data-stagger>
          <a href={waGeneral} rel="noopener"
            class="v2-rise group border border-azur-900/15 bg-blanc p-6 text-center transition-all hover:-translate-y-0.5 hover:border-azur-600 hover:shadow-[0_14px_40px_-16px_rgb(15_28_84/0.4)]" style="--v2-i:0">
            <p class="tech-label text-azur-600">Nouveau projet</p>
            <p class="mt-2 font-display font-bold">WhatsApp — nouvelle installation</p>
            <p class="mt-1 text-sm text-encre-soft">Étude et devis pour un nouveau projet</p>
          </a>
          {/* WJ97 — rappel téléphonique RÉEL (distinct de WhatsApp) : ouvre le
              mini-formulaire #rappel-form plus bas, qui poste un vrai lead au
              CRM (contactPreference: 'phone_ok') au lieu d'un lien wa.me
              mislabeled comme un rappel. */}
          <a href="#rappel-form" data-rappel-open rel="noopener"
            class="v2-rise group border border-azur-900/15 bg-blanc p-6 text-center transition-all hover:-translate-y-0.5 hover:border-azur-600 hover:shadow-[0_14px_40px_-16px_rgb(15_28_84/0.4)]" style="--v2-i:1">
            <p class="tech-label text-azur-600">Par téléphone</p>
            <p class="mt-2 font-display font-bold">Demander un rappel</p>
            <p class="mt-1 text-sm text-encre-soft">On vous rappelle — laissez votre nom et numéro</p>
          </a>
          <a href={waRegul} rel="noopener"
            class="v2-rise group border border-azur-900/15 bg-blanc p-6 text-center transition-all hover:-translate-y-0.5 hover:border-azur-600 hover:shadow-[0_14px_40px_-16px_rgb(15_28_84/0.4)]" style="--v2-i:2">
            <p class="tech-label text-azur-600">Article 33</p>
            <p class="mt-2 font-display font-bold">WhatsApp — régularisation</p>
            <p class="mt-1 text-sm text-encre-soft">Installation existante à mettre en conformité</p>
          </a>
          {/* W285 — « Visiter un chantier » devient une action : même
              invitation que pourquoi-taqinor.astro, en raccourci WhatsApp direct. */}
          <a href={waVisite} rel="noopener"
            class="v2-rise group border border-azur-900/15 bg-blanc p-6 text-center transition-all hover:-translate-y-0.5 hover:border-azur-600 hover:shadow-[0_14px_40px_-16px_rgb(15_28_84/0.4)]" style="--v2-i:3">
            <p class="tech-label text-azur-600">Voir avant de signer</p>
            <p class="mt-2 font-display font-bold">WhatsApp — visiter un chantier</p>
            <p class="mt-1 text-sm text-encre-soft">Je souhaite visiter une installation réelle</p>
          </a>
        </div>

        <!-- WJ97 — mini-formulaire de rappel RÉEL : nom + téléphone seulement,
             poste un lead via /api/capture-lead (contactPreference: 'phone_ok',
             quickCallback: true — lib/lead.ts). Masqué par défaut, révélé par
             la carte « Demander un rappel » ci-dessus (ancre #rappel-form). Le
             lien WhatsApp reste disponible juste en dessous, clairement séparé. -->
        <div id="rappel-form" class="v2-rise mt-8 border-2 border-azur-600/40 bg-blanc p-7 text-sm" hidden>
          <p class="tech-label text-azur-600">Par téléphone</p>
          <h2 class="display mt-1 text-xl font-bold">On vous rappelle</h2>
          <p class="mt-2 text-encre-soft">
            Laissez votre nom et votre numéro : un conseiller Taqinor vous rappelle directement,
            aucune saisie supplémentaire.
          </p>
          <form id="rappel-form-el" novalidate class="mt-5 space-y-3">
            <div aria-hidden="true" style="position:absolute; left:-9999px; width:1px; height:1px; overflow:hidden;">
              <label>Ne pas remplir<input id="rappel-hp" name="website_url" type="text" tabindex="-1" autocomplete="off" /></label>
            </div>
            <div>
              <label for="rappel-nom" class="block text-xs font-semibold text-encre-soft">Nom complet</label>
              <input id="rappel-nom" name="fullName" type="text" required autocomplete="name"
                class="mt-1 w-full border border-azur-900/20 bg-blanc-azur px-4 py-2.5 text-encre focus:border-azur-600 focus:outline-none" />
            </div>
            <div>
              <label for="rappel-tel" class="block text-xs font-semibold text-encre-soft">Téléphone</label>
              <input id="rappel-tel" name="phone" type="tel" required autocomplete="tel" placeholder="06 12 34 56 78"
                class="mt-1 w-full border border-azur-900/20 bg-blanc-azur px-4 py-2.5 text-encre focus:border-azur-600 focus:outline-none" />
            </div>
            <label class="flex items-start gap-2 text-xs text-encre-soft">
              <input id="rappel-consent" name="consent" type="checkbox" required class="mt-0.5" />
              <span>J'accepte d'être recontacté(e) par Taqinor au sujet de mon projet solaire.</span>
            </label>
            <button type="submit" id="rappel-submit"
              class="inline-flex w-full items-center justify-center gap-2 bg-brass-400 px-6 py-3 text-sm font-bold text-azur-950 transition-colors hover:bg-brass-300 sm:w-auto">
              Demander à être rappelé(e)
            </button>
            <p id="rappel-status" role="status" class="text-sm" hidden></p>
          </form>
          <p class="mt-4 border-t border-azur-900/10 pt-4 text-encre-soft">
            Vous préférez écrire ? <a href={waRappel} rel="noopener" class="font-semibold underline decoration-azur-600 decoration-2 underline-offset-4">Contactez-nous plutôt sur WhatsApp</a>.
          </p>
        </div>

        <div class="v2-rise mt-8 border border-azur-900/15 bg-blanc-azur p-7 text-center text-sm">
          <p class="font-display text-lg font-bold">{NAP.name}</p>
          <p class="mt-2">
            <a href={`tel:${NAP.phone}`} class="font-semibold underline decoration-azur-600 decoration-2 underline-offset-4">{NAP.phoneDisplayIntl}</a>
            &nbsp;·&nbsp;
            <a href={`mailto:${NAP.email}`} class="underline decoration-azur-600 decoration-2 underline-offset-4">{NAP.email}</a>
          </p>
          <p class="mt-3 text-encre-soft">
            Zone d'intervention : axe Casablanca–Rabat, et {NAP.serviceArea.slice(2, -1).join(', ')} sur devis.
          </p>
          <p class="mt-1 text-xs text-encre-faint">Interventions sur site uniquement — pas d'accueil du public en agence.</p>
        </div>
      </div>
    </section>

    <!-- W339 — « Déjà client ? » porte SAV/urgence : séparée visuellement et
         fonctionnellement du bloc devis ci-dessus. WhatsApp pré-rempli en
         signalement de panne, routé vers l'équipe SAV — jamais le webhook de
         leads commerciaux. -->
    <section id="deja-client" class="border-t border-azur-900/10 bg-blanc px-4 py-16 text-encre">
      <div class="mx-auto max-w-2xl">
        <div class="v2-rise border-2 border-azur-600/40 bg-blanc-azur p-7 text-center sm:p-9">
          <p class="tech-label text-azur-600">Déjà client ?</p>
          <h2 class="display mt-2 text-2xl font-bold sm:text-3xl">Un souci sur votre installation ?</h2>
          <p class="mt-3 text-sm leading-relaxed text-encre-soft">
            Que faire si votre onduleur affiche une erreur ? Photographiez l'écran et écrivez-nous
            sur WhatsApp — c'est le moyen le plus rapide de joindre l'équipe SAV, qui traite votre
            signalement séparément d'une nouvelle demande de devis.
          </p>
          <div class="mt-6 flex flex-wrap items-center justify-center gap-3">
            <a
              href={waSav}
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 bg-brass-400 px-6 py-3 text-sm font-bold text-azur-950 transition-colors hover:bg-brass-300"
            >
              WhatsApp — signaler une panne (SAV)
            </a>
            <a
              href={`tel:${NAP.phone}`}
              class="inline-flex items-center gap-2 border border-azur-900/25 px-6 py-3 text-sm font-semibold text-encre transition-colors hover:border-azur-600"
            >
              {NAP.phoneDisplayIntl}
            </a>
          </div>
        </div>
      </div>
    </section>
  </div>
</Layout>

<script>
  // WJ97 — révèle #rappel-form au clic sur la carte « Demander un rappel »
  // (jamais affiché par défaut : la grille reste dense pour qui ne veut que
  // WhatsApp) puis poste un lead RÉEL via /api/capture-lead, DISTINCT du canal
  // WhatsApp (contactPreference: 'phone_ok', quickCallback: true — lib/lead.ts
  // relâche city/roofType/billRange pour ce chemin, jamais une valeur inventée).
  const openLinks = document.querySelectorAll<HTMLAnchorElement>('[data-rappel-open]');
  const formWrap = document.getElementById('rappel-form');
  openLinks.forEach((a) => {
    a.addEventListener('click', (e) => {
      e.preventDefault();
      if (formWrap) {
        formWrap.hidden = false;
        formWrap.scrollIntoView({ behavior: 'smooth', block: 'center' });
        document.getElementById('rappel-nom')?.focus();
      }
    });
  });

  const form = document.getElementById('rappel-form-el') as HTMLFormElement | null;
  const statusEl = document.getElementById('rappel-status');
  const submitBtn = document.getElementById('rappel-submit') as HTMLButtonElement | null;
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!statusEl || !submitBtn) return;
    const fullName = (document.getElementById('rappel-nom') as HTMLInputElement | null)?.value ?? '';
    const phone = (document.getElementById('rappel-tel') as HTMLInputElement | null)?.value ?? '';
    const consent = (document.getElementById('rappel-consent') as HTMLInputElement | null)?.checked === true;
    const websiteUrl = (document.getElementById('rappel-hp') as HTMLInputElement | null)?.value ?? '';

    statusEl.hidden = true;
    submitBtn.disabled = true;
    try {
      const res = await fetch('/api/capture-lead', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify({
          fullName,
          phone,
          consent,
          website_url: websiteUrl,
          whatsappOptIn: false,
          // WJ97 — chemin rappel rapide : nom + téléphone seulement (jamais de
          // ville/toiture/facture inventées pour satisfaire un champ requis).
          quickCallback: true,
          // Canal explicite, distinct de tout CTA WhatsApp (lib/lead.ts CONTACT_PREFERENCES).
          contactPreference: 'phone_ok',
        }),
      });
      const data = (await res.json().catch(() => null)) as { ok?: boolean; errors?: Record<string, string> } | null;
      if (res.ok && data?.ok) {
        statusEl.textContent = 'Merci — un conseiller Taqinor vous rappelle très vite.';
        statusEl.className = 'text-sm text-azur-700';
        statusEl.hidden = false;
        form.reset();
        form.hidden = true;
      } else {
        statusEl.textContent = 'Service momentanément indisponible — contactez-nous plutôt sur WhatsApp, nous répondons vite.';
        statusEl.className = 'text-sm text-red-700';
        statusEl.hidden = false;
      }
    } catch {
      statusEl.textContent = 'Service momentanément indisponible — contactez-nous plutôt sur WhatsApp, nous répondons vite.';
      statusEl.className = 'text-sm text-red-700';
      statusEl.hidden = false;
    } finally {
      submitBtn.disabled = false;
    }
  });
</script>
