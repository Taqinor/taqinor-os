---
/**
 * Pompage solaire (W23) — page de CAPACITÉ, pas de preuve. Taqinor n'a AUCUNE
 * installation de pompage posée à ce jour : ZÉRO projet inventé, ZÉRO photo,
 * ZÉRO chiffre de production. On décrit la méthode (étude d'abord), les
 * variables de dimensionnement et le SEUL avantage fiscal vérifié (exonération
 * de TVA du pompage agricole — strictement le pompage agricole, jamais le
 * photovoltaïque résidentiel en toiture).
 */
import Layout from '../layouts/Layout.astro';
import V2Enhance from '../components/V2Enhance.astro';
import Article33Ribbon from '../components/Article33Ribbon.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import CtaBand from '../components/CtaBand.astro';
import StickyCta from '../components/StickyCta.astro';

const etapes = [
  {
    k: '01',
    title: 'Captage solaire',
    body: 'Les panneaux photovoltaïques convertissent l’ensoleillement en électricité tout au long de la journée. La puissance du champ est calculée à partir de l’eau réellement nécessaire, pas à partir d’un kit standard.',
  },
  {
    k: '02',
    title: 'Pompage au fil du soleil',
    body: 'Le plus souvent en entraînement direct, sans batteries : la pompe fonctionne pendant les heures d’ensoleillement et débite d’autant plus que le soleil est fort. On supprime ainsi le coût et l’entretien d’un parc de batteries.',
  },
  {
    k: '03',
    title: 'Stockage de l’eau, pas de l’énergie',
    body: 'L’eau est stockée dans un bassin ou un réservoir au lieu d’être stockée dans des batteries. Le réservoir constitue la réserve : on pompe quand le soleil donne, on irrigue quand la culture en a besoin.',
  },
  {
    k: '04',
    title: 'Pilotage par variateur',
    body: 'Un variateur (contrôleur) adapte la vitesse de la pompe à l’énergie disponible, démarre en douceur et protège le moteur (marche à sec, sous-tension). C’est lui qui rend le système robuste au fil des saisons.',
  },
];

const variables = [
  {
    title: 'Débit',
    body: 'Le volume d’eau à délivrer, exprimé en m³/h ou en m³/jour. Il découle des besoins de la culture et de la surface à irriguer, pas d’un catalogue.',
  },
  {
    title: 'HMT',
    body: 'La hauteur manométrique totale : la hauteur réelle que la pompe doit vaincre — profondeur du niveau d’eau, dénivelé jusqu’au bassin et pertes de charge dans les conduites.',
  },
  {
    title: 'Profondeur du forage',
    body: 'La profondeur du puits ou du forage et le niveau dynamique de l’eau conditionnent le choix de la pompe (immergée ou de surface) et la puissance du champ solaire.',
  },
  {
    title: 'Besoins en eau de la culture',
    body: 'Le type de culture, la surface et la saison fixent la quantité d’eau visée. C’est le point de départ du calcul : tout le reste se dimensionne sur ce besoin.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Pompage solaire',
  serviceType: 'Pompage solaire photovoltaïque',
  provider: { '@type': 'Organization', name: 'Taqinor', url: 'https://taqinor.ma' },
  areaServed: { '@type': 'Country', name: 'Maroc' },
  description:
    'Étude et dimensionnement de systèmes de pompage solaire pour l’agriculture et l’irrigation au Maroc : pompe et champ photovoltaïque calculés sur le débit, la HMT et les besoins en eau réels.',
};
---

<Layout
  title="Pompage solaire pour l’agriculture au Maroc | Taqinor"
  description="Le pompage solaire expliqué honnêtement : panneaux qui entraînent la pompe au fil du soleil, eau stockée dans un bassin plutôt que dans des batteries, système dimensionné sur le débit, la HMT et les besoins de la culture. Exonération de TVA pour le pompage agricole au Maroc."
  ogSlug="accueil"
>
  <div class="v2">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <V2Enhance />
    <Article33Ribbon />

    <Breadcrumb items={[{ label: 'Accueil', href: '/' }, { label: 'Pompage solaire' }]} />

    <section class="px-4 pb-10 pt-16 text-white sm:pt-20">
      <div class="mx-auto max-w-3xl">
        <p class="tech-label v2-kicker rule-brass cine-in text-brass-300">Nouveau service</p>
        <h1 class="display v2-page-title cine-in mt-5 [animation-delay:120ms]">Pomper l’eau au soleil, pas au gasoil</h1>
        <p class="v2-lead cine-in mt-6 max-w-xl text-white/85 [animation-delay:240ms]">
          Pour l’agriculture et l’irrigation, le pompage solaire remplace le groupe diesel par
          des panneaux qui entraînent directement la pompe. Comme pour nos installations en
          toiture, la règle est la même : l’étude d’abord. Le système se calcule sur votre eau
          réelle — débit, hauteur, profondeur, culture — jamais sur un kit standard.
        </p>
      </div>
    </section>

    <!-- Comment ça marche -->
    <section class="px-4 pb-20 sm:pb-24">
      <div class="mx-auto max-w-6xl">
        <p class="tech-label v2-kicker rule-brass text-brass-300">Comment ça marche</p>
        <h2 class="display v2-section-title mt-5 text-white">Du soleil au champ, en quatre temps</h2>
        <div class="mt-10 grid gap-6 md:grid-cols-2" data-stagger>
          {etapes.map((e, i) => (
            <div class="v2-rise cine-card flex flex-col p-7" style={`--v2-i:${i}`}>
              <p class="fig lum text-3xl">{e.k}</p>
              <h3 class="display mt-2 text-2xl text-white">{e.title}</h3>
              <p class="mt-3 flex-1 text-sm leading-relaxed text-lune-soft">{e.body}</p>
            </div>
          ))}
        </div>
        <p class="mx-auto mt-8 max-w-2xl text-sm leading-relaxed text-lune-faint">
          Les ordres de grandeur dépendent entièrement de votre site : nous donnons une méthode,
          jamais un devis avant l’étude. Le matériel solaire repose sur les mêmes marques tier-1 que
          nos toitures — <a href="/équipement" class="border-b border-brass-400 pb-0.5 font-semibold text-brass-300 transition-colors hover:text-brass-200">voir l’équipement →</a>
        </p>
      </div>
    </section>

    <!-- Les variables de dimensionnement (fond clair) -->
    <div class="v2-seam" aria-hidden="true"></div>
    <section class="bg-blanc-azur px-4 pb-20 pt-10 text-encre sm:pb-24">
      <div class="mx-auto max-w-6xl">
        <p class="tech-label v2-kicker rule-brass text-azur-600">L’étude d’abord</p>
        <h2 class="display v2-section-title mt-5">Ce qui décide du dimensionnement</h2>
        <p class="v2-lead mt-5 max-w-2xl text-encre-soft">
          Un système de pompage solaire ne se choisit pas sur étagère. La pompe et le champ
          photovoltaïque sont calculés à partir de quatre variables concrètes, mesurées sur place.
        </p>
        <div class="mt-10 grid gap-6 md:grid-cols-2" data-stagger>
          {variables.map((v, i) => (
            <div class="v2-rise border-t-2 border-azur-900 bg-blanc p-6" style={`--v2-i:${i}`}>
              <h3 class="display text-xl text-azur-700">{v.title}</h3>
              <p class="mt-3 text-sm leading-relaxed text-encre-soft">{v.body}</p>
            </div>
          ))}
        </div>
        <p class="mx-auto mt-8 max-w-2xl border-l-4 border-azur-600 pl-4 text-sm leading-relaxed text-encre-soft">
          C’est l’étude qui décide du matériel, jamais l’inverse. Chaque dimensionnement part du
          besoin en eau réel de votre exploitation. <a href="/contact#simulateur" class="border-b border-azur-600 pb-0.5 font-semibold text-azur-600 transition-colors hover:text-azur-700">Demander un diagnostic →</a>
        </p>
      </div>
    </section>

    <!-- Avantage fiscal : exonération de TVA (pompage agricole uniquement) -->
    <section class="px-4 py-20 sm:py-28">
      <div class="mx-auto max-w-6xl">
        <div class="grid gap-10 lg:grid-cols-[1.1fr_1fr] lg:items-center">
          <div class="v2-rise">
            <p class="tech-label v2-kicker rule-brass text-brass-300">Avantage fiscal vérifié</p>
            <h2 class="display v2-section-title mt-5 text-white">Le pompage agricole exonéré de TVA</h2>
            <p class="v2-lead mt-5 text-lune-soft">
              Au Maroc, les systèmes de pompage de l’eau fonctionnant à l’énergie solaire
              bénéficient d’une exonération générale de TVA qui couvre la pompe et les panneaux
              pour le pompage agricole. Concrètement, cela allège le coût d’investissement de
              l’équipement de pompage solaire pour une exploitation.
            </p>
          </div>
          <div class="v2-rise cine-card p-7" style="--v2-i:1">
            <h3 class="display text-xl text-white">À ne pas confondre</h3>
            <p class="mt-3 text-sm leading-relaxed text-lune-soft">
              Cet avantage concerne le <strong class="text-white">pompage agricole</strong> — la pompe
              et son champ solaire — et <strong class="text-white">pas le photovoltaïque résidentiel
              en toiture</strong>. Une installation solaire sur le toit d’une maison ne relève pas de
              cette exonération : ce sont deux régimes distincts, à ne pas mélanger.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Bloc liens / segment professionnel -->
    <section class="border-t border-white/10 px-4 py-16 sm:py-20">
      <div class="mx-auto max-w-6xl">
        <p class="tech-label v2-kicker rule-brass text-brass-300">Pour aller plus loin</p>
        <h2 class="display v2-section-title mt-5 text-white">L’agriculture, un segment professionnel</h2>
        <p class="v2-lead mt-5 max-w-2xl text-lune-soft">
          Le pompage solaire s’adresse aux exploitations agricoles et aux professionnels. La
          démarche reste la nôtre : étude technique d’abord, matériel tier-1 ensuite, dossier
          complet à la livraison.
        </p>
        <div class="mt-10 flex flex-wrap gap-3">
          <a href="/contact#simulateur" class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">Demander un diagnostic →</a>
          <a href="/professionnel" class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">Solaire professionnel →</a>
          <a href="/équipement" class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">Voir l’équipement →</a>
        </div>
      </div>
    </section>

    <CtaBand title="Un projet de pompage solaire ? Commencez par l’étude gratuite." href="/contact#simulateur" />

    <StickyCta />
  </div>
</Layout>
