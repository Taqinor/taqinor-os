---
import Layout from '../layouts/Layout.astro';
import Article33Ribbon from '../components/Article33Ribbon.astro';
import RegimeSelector from '../components/RegimeSelector.astro';
import CtaBand from '../components/CtaBand.astro';
import { REGIMES } from '../lib/regime';
---

<Layout
  title="Loi 82-21 : les 3 régimes de l'autoproduction au Maroc | Taqinor"
  description="Déclaration, accord de raccordement ou autorisation ? Identifiez en 3 questions le régime de la loi 82-21 (décret 2-25-100) applicable à votre installation solaire, en vigueur depuis le 9 juin 2026."
  ogSlug="loi-82-21"
>
  <Article33Ribbon />

  <section class="grid-paper-dark bg-night px-4 py-16 text-paper sm:py-20">
    <div class="mx-auto max-w-6xl">
      <p class="tech-label rule-amber text-amber-400">Loi 82-21 · décret 2-25-100</p>
      <h1 class="display mt-4 max-w-2xl text-4xl sm:text-5xl">Trois régimes, un seul qui vous concerne</h1>
      <p class="mt-5 max-w-xl leading-relaxed text-paper/85">
        La loi 82-21 sur l'autoproduction d'énergie électrique et son décret d'application
        2-25-100 sont en vigueur depuis le 9 juin 2026. Toute installation d'autoproduction —
        nouvelle ou existante — relève désormais de l'un des trois régimes ci-dessous, selon sa
        puissance et son raccordement.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-4xl px-4 py-14">
    <RegimeSelector />
  </section>

  <section class="mx-auto max-w-4xl px-4 pb-14">
    <p class="tech-label rule-amber text-ink-soft">Référence</p>
    <h2 class="display mt-3 text-3xl">Les trois régimes en détail</h2>
    <div class="mt-8 grid gap-6">
      {Object.values(REGIMES).map((r, i) => (
        <div class="reveal grid gap-4 border border-ink/15 bg-paper p-6 sm:grid-cols-[auto_1fr] sm:p-7">
          <span class="fig text-4xl text-amber-700" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
          <div>
            <h3 class="display text-xl">{r.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-ink-soft">{r.summary}</p>
            <ul class="mt-4 space-y-2 text-sm">
              {r.obligations.map((o) => (
                <li class="flex gap-2.5"><span class="font-mono font-medium text-amber-700" aria-hidden="true">+</span><span>{o}</span></li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>
    <div class="mt-10 border-2 border-amber-400 bg-amber-400/10 p-7">
      <p class="tech-label text-amber-700">Installations existantes</p>
      <h2 class="display mt-2 text-2xl">Vous avez déjà une installation non déclarée ?</h2>
      <p class="mt-3 max-w-xl text-sm leading-relaxed text-ink-soft">
        L'Article 33 de la loi ouvre une fenêtre de régularisation pour les installations
        existantes. La fenêtre est ouverte — la procédure et les sanctions en cas d'inaction
        sont détaillées sur la page dédiée.
      </p>
      <a href="/regularization-article-33" class="mt-5 inline-block bg-ink px-6 py-3 text-sm font-bold text-paper transition-colors hover:bg-night-soft">
        Régulariser mon installation
      </a>
    </div>
  </section>

  <CtaBand title="Un doute sur votre régime ? Nous vérifions gratuitement." buttonLabel="Faire vérifier mon dossier" />
</Layout>
