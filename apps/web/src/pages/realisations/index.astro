---
/**
 * Hub des réalisations (W3) — galerie indexée des installations réelles, chaque
 * carte liée vers son étude de cas. Données issues de `realisations.ts`.
 *
 * W171 — caption scrim via PhotoCaption.astro (plus de duplication inline)
 * W178 — lightbox accessible (vanilla JS, ESC/flèches, focus-trap, aria)
 * W179 — hover-zoom standardisé à 1.04 sur toutes les cartes (reduced-motion safe)
 * W181 — object-position lu depuis realisations.ts (objectPosition optionnel)
 */
import Layout from '../../layouts/Layout.astro';
import V2Enhance from '../../components/V2Enhance.astro';
import Article33Ribbon from '../../components/Article33Ribbon.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import Picture from '../../components/Picture.astro';
import PhotoCaption from '../../components/PhotoCaption.astro';
import CtaBand from '../../components/CtaBand.astro';
import StickyCta from '../../components/StickyCta.astro';
import { REALISATIONS } from '../../lib/realisations';

const total = REALISATIONS.reduce((s, r) => s + r.kwcNum, 0);
const totalLabel = total.toLocaleString('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' kWc';
// On met en avant des dimensions substantielles (puissance, villes, chantiers
// visitables) plutôt qu'un total fixe de projets (cadrage W14, « récence »).
const villesCount = new Set(REALISATIONS.map((r) => r.ville)).size;

// Préparer les données lightbox pour chaque carte
const galleryItems = REALISATIONS.map((r) => ({
  slug: r.slug,
  photo: r.photos[0],
  label: `${r.ville} · ${r.kwc} · ${r.date}`,
}));
---

<Layout
  title="Nos réalisations solaires au Maroc — installations mesurées | Taqinor"
  description="Les installations solaires réellement posées et mesurées par Taqinor : villas de Casablanca, El Jadida et Nouaceur, puissance, production suivie sur Deye Cloud et matériel posé. Études de cas détaillées."
  ogSlug="accueil"
>
  <div class="v2">
    <V2Enhance />
    <Article33Ribbon />

    <Breadcrumb items={[{ label: 'Accueil', href: '/' }, { label: 'Réalisations' }]} />

    <section class="px-4 pb-12 pt-16 text-white sm:pt-20">
      <div class="mx-auto max-w-6xl">
        <p class="tech-label v2-kicker rule-brass cine-in text-brass-300">Réalisations récentes</p>
        <h1 class="display v2-page-title cine-in mt-5 max-w-3xl [animation-delay:120ms]">Nos dernières réalisations</h1>
        <p class="v2-lead cine-in mt-6 max-w-xl text-white/85 [animation-delay:240ms]">
          Des chantiers réels, à voir sur demande — Casablanca, El Jadida, Nouaceur. Chaque étude
          de cas reprend la puissance posée, le matériel et, quand elle est mesurée, la production
          suivie sur Deye Cloud. Rien d'ajouté, rien d'effacé.
        </p>
        <dl class="cine-in mt-8 flex flex-wrap gap-x-10 gap-y-4 [animation-delay:360ms]">
          <div>
            <dt class="tech-label text-lune-faint">Puissance installée</dt>
            <dd class="fig lum text-3xl">{totalLabel}</dd>
          </div>
          <div>
            <dt class="tech-label text-lune-faint">Villes</dt>
            <dd class="fig lum text-3xl">{villesCount}</dd>
          </div>
          <div>
            <dt class="tech-label text-lune-faint">Chantiers</dt>
            <dd class="font-display text-2xl font-bold text-white">visitables sur demande</dd>
          </div>
        </dl>
      </div>
    </section>

    <!-- W178 : galerie avec lightbox — data-lightbox-gallery désigne le groupe -->
    <section class="px-4 pb-24 sm:pb-32">
      <div class="mx-auto grid max-w-6xl gap-6 md:grid-cols-2 lg:grid-cols-3" data-stagger data-lightbox-gallery>
        {REALISATIONS.map((r, i) => (
          <div class="v2-rise relative" style={`--v2-i:${i}`}>
            <!-- Bouton lightbox sur l'image -->
            <button
              type="button"
              class="photo-card-btn cine-card group relative block w-full overflow-hidden text-left"
              data-lightbox-trigger
              data-lightbox-src={`/photos/${r.photos[0].name}-${Math.max(...r.photos[0].widths)}.webp`}
              data-lightbox-alt={r.photos[0].alt}
              data-lightbox-label={`${r.ville} · ${r.kwc} · ${r.date}`}
              aria-label={`Agrandir la photo : ${r.photos[0].alt}`}
            >
              {/* W180 — ratio=3/2 aligné sur l'aspect-[3/2] CSS : les photos
                  proviennent de ratio variés (16/9, 4/3, 1:1) mais sont toutes
                  recadrées en 3/2 par le CSS. Le ratio déclaré doit correspondre
                  pour que width/height attrs réservent la bonne hauteur (anti-CLS). */}
              <Picture
                name={r.photos[0].name}
                alt={r.photos[0].alt}
                widths={r.photos[0].widths}
                ratio={3 / 2}
                sizes="(min-width: 1024px) 33vw, (min-width: 768px) 50vw, 100vw"
                style={(r.photos[0] as any).objectPosition ? `object-position:${(r.photos[0] as any).objectPosition}` : undefined}
                class="photo-card-img aspect-[3/2] w-full object-cover"
              />
              <PhotoCaption
                caption={`${r.ville} · ${r.date}`}
                sub={r.kwc + (r.production ? ` · ${r.production}` : '')}
                detail={r.panneaux}
              />
            </button>
            <!-- Lien vers l'étude de cas sous la photo -->
            <a
              href={`/realisations/${r.slug}`}
              class="mt-2 inline-block border-b-2 border-brass-400 pb-0.5 text-sm font-bold text-white transition-colors hover:text-brass-300"
            >
              Voir l'étude de cas →
            </a>
          </div>
        ))}
      </div>
    </section>

    <CtaBand title="La prochaine étude de cas, c'est peut-être votre toiture." href="/contact#simulateur" />

    <StickyCta />
  </div>

  <!-- W178 : Lightbox accessible (vanilla JS, ESC/flèches, focus-trap, aria) -->
  <div
    id="tq-lightbox"
    role="dialog"
    aria-modal="true"
    aria-label="Photo agrandie"
    class="lightbox-overlay"
    hidden
  >
    <button type="button" id="tq-lb-close" class="lightbox-close" aria-label="Fermer (Échap)">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
        <path d="M18 6 6 18M6 6l12 12"/>
      </svg>
    </button>
    <button type="button" id="tq-lb-prev" class="lightbox-arrow lightbox-arrow--prev" aria-label="Photo précédente (←)">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
        <path d="m15 18-6-6 6-6"/>
      </svg>
    </button>
    <div class="lightbox-img-wrap">
      <img id="tq-lb-img" src="" alt="" class="lightbox-img" />
      <p id="tq-lb-label" class="lightbox-label"></p>
    </div>
    <button type="button" id="tq-lb-next" class="lightbox-arrow lightbox-arrow--next" aria-label="Photo suivante (→)">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
        <path d="m9 18 6-6-6-6"/>
      </svg>
    </button>
  </div>
</Layout>

<style>
  /* W179 — hover-zoom standardisé 1.04, reduced-motion safe */
  @media (prefers-reduced-motion: no-preference) {
    .photo-card-img {
      transition: transform 700ms cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }
    .photo-card-btn:hover .photo-card-img,
    .photo-card-btn:focus-visible .photo-card-img {
      transform: scale(1.04);
    }
  }

  /* W178 — lightbox */
  .lightbox-overlay {
    position: fixed;
    inset: 0;
    z-index: 9000;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgb(7 11 29 / 0.94);
    padding: 1rem;
  }
  .lightbox-overlay[hidden] {
    display: none;
  }
  .lightbox-img-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: min(90vw, 1200px);
    gap: 0.75rem;
  }
  .lightbox-img {
    display: block;
    max-width: 100%;
    max-height: 80vh;
    object-fit: contain;
    border: 1px solid rgb(255 255 255 / 0.12);
    box-shadow: 0 32px 80px -20px rgb(0 0 0 / 0.8);
  }
  .lightbox-label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-lune-soft);
    text-align: center;
  }
  .lightbox-close {
    position: fixed;
    top: 1.25rem;
    right: 1.25rem;
    z-index: 9001;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    color: var(--color-lune);
    border: 1px solid rgb(255 255 255 / 0.2);
    background: rgb(7 11 29 / 0.7);
    cursor: pointer;
    transition: color 200ms, border-color 200ms;
  }
  .lightbox-close:hover,
  .lightbox-close:focus-visible {
    color: var(--color-brass-300);
    border-color: var(--color-brass-400);
    outline: none;
  }
  .lightbox-arrow {
    position: fixed;
    top: 50%;
    transform: translateY(-50%);
    z-index: 9001;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    color: var(--color-lune);
    border: 1px solid rgb(255 255 255 / 0.2);
    background: rgb(7 11 29 / 0.7);
    cursor: pointer;
    transition: color 200ms, border-color 200ms;
  }
  .lightbox-arrow--prev { left: 1rem; }
  .lightbox-arrow--next { right: 1rem; }
  .lightbox-arrow:hover,
  .lightbox-arrow:focus-visible {
    color: var(--color-brass-300);
    border-color: var(--color-brass-400);
    outline: none;
  }
</style>

<script>
  // W178 — Lightbox accessible, vanilla JS, focus-trap, keyboard ESC/arrows
  interface LbItem {
    src: string;
    alt: string;
    label: string;
  }

  const overlay = document.getElementById('tq-lightbox') as HTMLElement | null;
  const imgEl = document.getElementById('tq-lb-img') as HTMLImageElement | null;
  const labelEl = document.getElementById('tq-lb-label') as HTMLElement | null;
  const closeBtn = document.getElementById('tq-lb-close') as HTMLButtonElement | null;
  const prevBtn = document.getElementById('tq-lb-prev') as HTMLButtonElement | null;
  const nextBtn = document.getElementById('tq-lb-next') as HTMLButtonElement | null;

  if (!overlay || !imgEl || !labelEl || !closeBtn || !prevBtn || !nextBtn) {
    // Graceful: lightbox elements not found
  } else {
    let items: LbItem[] = [];
    let current = 0;
    let lastFocus: HTMLElement | null = null;

    function show(idx: number) {
      if (!items.length) return;
      current = ((idx % items.length) + items.length) % items.length;
      imgEl!.src = items[current].src;
      imgEl!.alt = items[current].alt;
      labelEl!.textContent = items[current].label;
      overlay!.hidden = false;
      overlay!.removeAttribute('hidden');
      // Show/hide arrows only when multiple items
      const multi = items.length > 1;
      prevBtn!.style.display = multi ? '' : 'none';
      nextBtn!.style.display = multi ? '' : 'none';
      closeBtn!.focus();
      document.body.style.overflow = 'hidden';
    }

    function close() {
      overlay!.hidden = true;
      document.body.style.overflow = '';
      lastFocus?.focus();
    }

    // Collect triggers
    function initTriggers() {
      const triggers = document.querySelectorAll<HTMLElement>('[data-lightbox-trigger]');
      items = Array.from(triggers).map((t) => ({
        src: t.dataset.lightboxSrc ?? '',
        alt: t.dataset.lightboxAlt ?? '',
        label: t.dataset.lightboxLabel ?? '',
      }));

      triggers.forEach((t, idx) => {
        t.addEventListener('click', (e) => {
          e.preventDefault();
          lastFocus = t;
          show(idx);
        });
      });
    }

    closeBtn.addEventListener('click', close);
    prevBtn.addEventListener('click', () => show(current - 1));
    nextBtn.addEventListener('click', () => show(current + 1));

    // Keyboard: ESC closes, arrows navigate
    overlay.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Escape') close();
      if (e.key === 'ArrowLeft') show(current - 1);
      if (e.key === 'ArrowRight') show(current + 1);
      // Focus-trap: Tab cycles within lightbox
      if (e.key === 'Tab') {
        const focusable = Array.from(
          overlay!.querySelectorAll<HTMLElement>('button, [href], input, [tabindex]:not([tabindex="-1"])')
        ).filter((el) => !el.hidden && el.offsetParent !== null);
        if (!focusable.length) return;
        const first = focusable[0];
        const last = focusable[focusable.length - 1];
        if (e.shiftKey) {
          if (document.activeElement === first) {
            e.preventDefault();
            last.focus();
          }
        } else {
          if (document.activeElement === last) {
            e.preventDefault();
            first.focus();
          }
        }
      }
    });

    // Click on backdrop (outside img-wrap) closes
    overlay.addEventListener('click', (e) => {
      if (e.target === overlay) close();
    });

    initTriggers();
  }
</script>
