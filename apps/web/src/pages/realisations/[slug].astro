---
/**
 * Étude de cas — une page par installation réelle (W3). Données 100 % issues
 * de `src/lib/realisations.ts` (elles-mêmes reprises des pages publiques
 * existantes) : aucun chiffre inventé. La carte production est OMISE quand la
 * production mesurée n'est pas publiée (ex. Nouaceur). Page publique, indexée.
 *
 * W171 — caption scrim via PhotoCaption.astro
 * W178 — lightbox accessible sur les photos de la galerie
 * W179 — hover-zoom standardisé à 1.04 (reduced-motion safe)
 * W181 — object-position depuis RealisationPhoto.objectPosition
 * W184 — diptych avant/pendant/après si phases présentes dans les données
 * W185 — OG card propre à chaque réalisation : l'image héro réelle est passée
 *         via le prop ogImage de Layout (pris en charge depuis W185).
 */
import Layout from '../../layouts/Layout.astro';
import V2Enhance from '../../components/V2Enhance.astro';
import Article33Ribbon from '../../components/Article33Ribbon.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import Picture from '../../components/Picture.astro';
import PhotoCaption from '../../components/PhotoCaption.astro';
import CtaBand from '../../components/CtaBand.astro';
import StickyCta from '../../components/StickyCta.astro';
import { REALISATIONS, CITIES } from '../../lib/realisations';
import { caseStudyBySlug } from '../../lib/caseStudies';
import { NAP, WHATSAPP_LEADS } from '../../lib/nap';
import { whatsappLink, caseStudyWhatsappText } from '../../lib/whatsapp';

export function getStaticPaths() {
  return REALISATIONS.map((r) => ({ params: { slug: r.slug }, props: { r } }));
}

const { r } = Astro.props;

// Récit propre à l'étude (W42) — déporté dans lib/caseStudies.ts pour que les
// cinq pages ne partagent plus une prose identique. Repli sûr garanti.
const cs = caseStudyBySlug(r.slug);

// La ville-page correspondante (si la ville est exactement dans la zone de
// service couverte : Casablanca/Rabat/Marrakech/Tanger/Agadir).
const cityPage = CITIES.find((c) => c.name === r.ville);
// Lien ville à afficher : la ville exacte si elle a sa page, sinon la ville de
// service la plus pertinente fournie par l'étude (ex. El Jadida/Nouaceur →
// Casablanca, même région) ; `null` si aucune n'est pertinente.
const cityLink = cityPage
  ? { href: `/installation-solaire-${cityPage.slug}`, label: `Installation solaire ${cityPage.intro}` }
  : cs.cityLink;
const segmentHref = r.segment === 'professionnel' ? '/professionnel' : '/résidentiel';
const segmentLabel = r.segment === 'professionnel' ? 'Professionnel' : 'Résidentiel';
const ogSlug = r.segment === 'professionnel' ? 'professionnel' : 'residentiel';

const hero = r.photos[0];
const rest = r.photos.slice(1);
const heroLargest = Math.max(...hero.widths);
const heroImg = new URL(`/photos/${hero.name}-${heroLargest}.webp`, Astro.site).href;

const equipment = [
  { label: 'Panneaux', value: r.panneaux },
  { label: 'Onduleur', value: r.onduleur },
  { label: 'Stockage', value: r.batterie },
].filter((e) => e.value);

const title = cs.title;
const description = cs.description;

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: `Installation solaire ${r.kwc} à ${r.ville} — réf. ${r.ref}`,
  description: r.resume,
  image: heroImg,
  about: { '@type': 'Thing', name: 'Installation solaire photovoltaïque' },
  author: { '@type': 'Organization', name: NAP.name, url: NAP.url },
  publisher: { '@type': 'Organization', name: NAP.name, url: NAP.url },
  mainEntityOfPage: new URL(Astro.url.pathname, Astro.site).href,
};

// W184 — diptych avant/pendant/après : photos avec une `phase` définie
const phasedPhotos = r.photos.filter((p) => p.phase);
const phaseLabels: Record<string, string> = {
  before: 'Avant',
  during: 'Pendant',
  after: 'Après',
};
const hasDiptych = phasedPhotos.length >= 2;

// W178 — lightbox : toutes les photos de la galerie (rest), index depuis 0
const galleryPhotos = rest;

// W327 — « kWc le plus proche du vôtre » : l'autre étude dont la puissance
// installée (kwcNum) est la plus proche de celle-ci, en excluant la page
// courante. Comparaison purement numérique sur un champ réel — aucune
// proximité inventée.
const nearestCase = REALISATIONS
  .filter((other) => other.slug !== r.slug)
  .sort((a, b) => Math.abs(a.kwcNum - r.kwcNum) - Math.abs(b.kwcNum - r.kwcNum))[0];

// W350 — bouton WhatsApp PROPRE À CETTE étude (bio-link social → réalisation
// → WhatsApp déjà contextualisé). Distinct du bouton générique de StickyCta.
const waCaseStudy = whatsappLink(
  WHATSAPP_LEADS,
  caseStudyWhatsappText({ ville: r.ville, kwc: r.kwc, ref: r.ref }),
);
---

<Layout
  title={title}
  description={description}
  ogSlug={ogSlug}
  ogImage={heroImg}
  ogImageAlt={`Installation solaire ${r.kwc} à ${r.ville} — photo de chantier`}
>
  <script type="application/ld+json" set:html={JSON.stringify(articleJsonLd)} />
  <div class="v2">
    <V2Enhance />
    <Article33Ribbon />

    <Breadcrumb
      items={[
        { label: 'Accueil', href: '/' },
        { label: 'Réalisations', href: '/realisations' },
        { label: `${r.ville} · ${r.kwc}` },
      ]}
    />

    <!-- ACTE I — la photo de chantier est la lumière -->
    <section class="relative isolate mt-6 overflow-hidden text-white">
      <div class="v2-hero-media absolute inset-0 -z-10">
        {/* W155 — portraitPosition : recadrage doux vers le haut sur téléphones
            verticaux (les panneaux sont en haut de la photo de chantier). Si
            hero.objectPosition est déjà défini, il est gardé en paysage ; le
            portrait override est center 25% (haut du champ) par défaut. */}
        <Picture
          name={hero.name}
          alt={hero.alt}
          widths={hero.widths}
          ratio={hero.ratio}
          sizes="100vw"
          loading="eager"
          fetchpriority="high"
          position={hero.objectPosition}
          portraitPosition="center 25%"
          class="h-full w-full object-cover"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-nuit via-nuit/55 to-nuit/20"></div>
      </div>
      <div class="mx-auto max-w-6xl px-4 pb-16 pt-24 sm:pb-20 sm:pt-32">
        <p class="tech-label v2-kicker rule-brass cine-in text-lune">Réf. {r.ref} · {r.ville} · {r.date}</p>
        <h1 class="display v2-page-title cine-in mt-5 max-w-[20ch] [animation-delay:120ms]">
          {r.kwc} d'installation solaire {cityPage ? cityPage.intro : `à ${r.ville}`}
        </h1>
        <p class="v2-lead cine-in mt-6 max-w-xl text-white/85 [animation-delay:240ms]">{r.resume}</p>
      </div>
    </section>

    <!-- Chiffres-clés — uniquement ce qui est publié -->
    <section class="border-y border-white/10 px-4 py-14 sm:py-16">
      <dl class="mx-auto grid max-w-6xl gap-x-6 gap-y-10 sm:grid-cols-2 lg:grid-cols-4" data-stagger>
        <div class="v2-rise" style="--v2-i:0">
          {/* W211 — whitespace-nowrap retiré (ex. « 21 406 kWh/an » peut déborder à 320 px) */}
          <dd class="fig lum text-3xl sm:text-4xl" data-tally>{r.kwc}</dd>
          <dt class="tech-label mt-2 text-lune-faint">Puissance installée</dt>
        </div>
        {r.production && (
          <div class="v2-rise" style="--v2-i:1">
            <dd class="fig lum text-3xl sm:text-4xl" data-tally>{r.production}</dd>
            <dt class="tech-label mt-2 text-lune-faint">Production mesurée — Deye Cloud</dt>
          </div>
        )}
        <div class="v2-rise" style="--v2-i:2">
          <dd class="font-display text-xl font-bold text-white">{r.panneaux}</dd>
          <dt class="tech-label mt-2 text-lune-faint">Panneaux posés</dt>
        </div>
        <div class="v2-rise" style="--v2-i:3">
          <dd class="font-display text-xl font-bold text-white">{r.ville}</dd>
          <dt class="tech-label mt-2 text-lune-faint">{r.region}</dt>
        </div>
      </dl>
    </section>

    <!-- Le récit du chantier : situation, dimensionnement, résultat mesuré -->
    <section class="mx-auto max-w-3xl px-4 py-20 sm:py-28">
      <p class="tech-label v2-kicker rule-brass text-lune">Le chantier, raconté</p>
      <h2 class="display v2-section-title mt-5 text-white">Pourquoi {r.kwc}, sur cette toiture</h2>
      <p class="v2-lead mt-5 text-lune-soft">{cs.situation}</p>
      <p class="v2-lead mt-4 text-lune-soft">{cs.sizing}</p>
      <p class="v2-lead mt-4 text-lune-soft">{cs.result}</p>
      {/* W327 — voix du client : NO-OP tant que WG6 n'a fourni aucune vraie
          citation (cs.clientQuote reste `undefined` pour les cinq études
          actuelles) ; rien n'est rendu dans ce cas, jamais de placeholder. */}
      {cs.clientQuote && (
        <blockquote class="mt-8 border-l-2 border-brass-400 pl-5">
          <p class="v2-lead text-white">« {cs.clientQuote.text} »</p>
          <cite class="tech-label mt-3 block not-italic text-lune-faint">— {cs.clientQuote.author}</cite>
        </blockquote>
      )}
    </section>

    <!-- W184 — Diptych avant/pendant/après (si données présentes) -->
    {hasDiptych && (
      <section class="border-t border-white/10 px-4 py-20 sm:py-24">
        <div class="mx-auto max-w-6xl">
          <p class="tech-label v2-kicker rule-brass text-lune">Le chantier en phases</p>
          <h2 class="display v2-section-title mt-5 text-white">Avant · Pendant · Après</h2>
          <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3" data-stagger>
            {phasedPhotos.map((p, i) => (
              <figure
                class="v2-rise phase-card cine-card group relative overflow-hidden"
                style={`--v2-i:${i}`}
                data-phase={p.phase}
              >
                <button
                  type="button"
                  class="phase-btn block w-full overflow-hidden text-left"
                  data-lightbox-trigger-slug
                  data-lightbox-src={`/photos/${p.name}-${Math.max(...p.widths)}.webp`}
                  data-lightbox-alt={p.alt}
                  data-lightbox-label={`${phaseLabels[p.phase!] ?? p.phase} — ${p.alt}`}
                  aria-label={`Agrandir : ${p.alt}`}
                >
                  <Picture
                    name={p.name}
                    alt={p.alt}
                    widths={p.widths}
                    ratio={p.ratio}
                    sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
                    style={p.objectPosition ? `object-position:${p.objectPosition}` : undefined}
                    class="slug-photo-img w-full object-cover"
                  />
                  <PhotoCaption caption={phaseLabels[p.phase!] ?? p.phase} />
                </button>
                <figcaption class="sr-only">{p.alt}</figcaption>
              </figure>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- Le matériel posé -->
    <section class="border-t border-white/10 px-4 py-20 sm:py-24">
      <div class="mx-auto max-w-3xl">
        <p class="tech-label v2-kicker rule-brass text-lune">Le matériel posé</p>
        <h2 class="display v2-section-title mt-5 text-white">Ce qui est réellement sur le toit</h2>
        <p class="v2-lead mt-5 text-lune-soft">{cs.install}</p>
        <div class="mt-8 border-t-2 border-white/20" data-stagger>
          {equipment.map((e, i) => (
            <div class="v2-rise flex items-baseline justify-between gap-4 border-b border-white/10 py-4" style={`--v2-i:${i}`}>
              <span class="tech-label text-lune-faint">{e.label}</span>
              <span class="text-right font-display text-base font-bold text-white">{e.value}</span>
            </div>
          ))}
        </div>
        <p class="mt-5 text-sm text-lune-soft">
          Marques tier-1 sourcées via des distributeurs officiels au Maroc — garanties locales
          activables. <a href="/équipement" class="border-b border-azur-200/60 pb-0.5 font-semibold text-azur-200 transition-colors hover:text-white">Voir tout l'équipement →</a>
        </p>
      </div>
    </section>

    <!-- Galerie chantier — W178 lightbox + W171 PhotoCaption + W179 hover-zoom -->
    {galleryPhotos.length > 0 && (
      <section class="px-4 py-20 sm:py-24">
        <div class="mx-auto max-w-6xl">
          <p class="tech-label v2-kicker rule-brass text-lune">Pièces du dossier</p>
          <h2 class="display v2-section-title mt-5 text-white">Le chantier, tel quel</h2>
          <div class="mt-10 grid gap-5 sm:grid-cols-2" data-stagger data-lightbox-gallery-slug>
            {galleryPhotos.map((p, i) => (
              <figure
                class="v2-rise cine-card group relative overflow-hidden"
                style={`--v2-i:${i}`}
              >
                <button
                  type="button"
                  class="slug-gallery-btn block w-full overflow-hidden text-left"
                  data-lightbox-trigger-slug
                  data-lightbox-src={`/photos/${p.name}-${Math.max(...p.widths)}.webp`}
                  data-lightbox-alt={p.alt}
                  data-lightbox-label={p.alt}
                  aria-label={`Agrandir : ${p.alt}`}
                >
                  <Picture
                    name={p.name}
                    alt={p.alt}
                    widths={p.widths}
                    ratio={p.ratio}
                    sizes="(min-width: 640px) 50vw, 100vw"
                    style={p.objectPosition ? `object-position:${p.objectPosition}` : undefined}
                    class="slug-photo-img w-full object-cover"
                  />
                </button>
                <figcaption class="sr-only">{p.alt}</figcaption>
              </figure>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- W327 — « kWc le plus proche du vôtre » : le prochain pas naturel pour
         un acheteur qui compare sa propre toiture à un cas précis. -->
    {nearestCase && (
      <section class="border-t border-white/10 px-4 py-16">
        <div class="mx-auto max-w-6xl">
          <a
            href={`/realisations/${nearestCase.slug}`}
            class="group flex flex-wrap items-center justify-between gap-4 border border-brass-400/40 bg-white/[0.03] px-6 py-5 transition-colors hover:border-brass-400 hover:bg-white/[0.06]"
          >
            <span>
              <span class="tech-label block text-brass-300">Un kWc plus proche du vôtre</span>
              <span class="mt-1 block font-display text-lg font-bold text-white">
                {nearestCase.kwc} à {nearestCase.ville}{nearestCase.production ? ` · ${nearestCase.production}` : ''}
              </span>
            </span>
            <span class="motion-safe:transition-transform motion-safe:duration-200 motion-safe:group-hover:translate-x-1 text-sm font-bold text-azur-200" aria-hidden="true">
              Voir l'étude de cas →
            </span>
          </a>
        </div>
      </section>
    )}

    <!-- W344 — Référence soft vers /parrainage : la preuve la plus forte du
         site (une étude de cas réelle) ne doit pas être une impasse. Ton
         discret, non-transactionnel — pas de montant/récompense affiché ici
         (voir /parrainage pour les conditions, WG14-gated). -->
    <section class="border-t border-white/10 px-4 py-16">
      <div class="mx-auto max-w-6xl">
        <a
          href="/parrainage"
          class="group flex flex-wrap items-center justify-between gap-4 border border-white/20 px-6 py-5 transition-colors hover:border-brass-400/60 hover:bg-white/[0.03]"
        >
          <span>
            <span class="tech-label block text-lune-faint">Le bouche-à-oreille compte</span>
            <span class="mt-1 block font-display text-lg font-bold text-white">
              Un proche a un profil similaire ? Recommandez Taqinor
            </span>
          </span>
          <span class="motion-safe:transition-transform motion-safe:duration-200 motion-safe:group-hover:translate-x-1 text-sm font-bold text-azur-200" aria-hidden="true">
            Découvrir le parrainage →
          </span>
        </a>
      </div>
    </section>

    <!-- Liens contextuels -->
    <section class="border-t border-white/10 px-4 py-16">
      <div class="mx-auto flex max-w-6xl flex-wrap gap-3">
        {cityLink && (
          <a href={cityLink.href} class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">
            {cityLink.label} →
          </a>
        )}
        <a href={segmentHref} class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">
          Solaire {segmentLabel.toLowerCase()} →
        </a>
        <a href="/realisations" class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">
          Toutes nos réalisations →
        </a>
      </div>
    </section>

    <CtaBand title={`Une étude comme celle de ${r.ville}, pour votre toiture.`} href="/devis/mon-toit" />

    <!-- W350 — WhatsApp PROPRE À CETTE étude : le message cite déjà la ville,
         la puissance et la référence exactes (bio-link réseaux sociaux →
         réalisation → WhatsApp déjà contextualisé, sans rien à retaper). -->
    <section class="border-t border-white/10 bg-blanc-azur px-4 py-10 text-center text-encre">
      <p class="mx-auto max-w-xl text-sm text-encre-soft">
        Une question sur cette installation de {r.kwc} à {r.ville} ?
      </p>
      <a
        href={waCaseStudy}
        rel="noopener noreferrer"
        target="_blank"
        class="mt-4 inline-flex items-center gap-2 border border-azur-600 px-5 py-2.5 text-sm font-bold text-azur-600 transition-colors hover:bg-azur-600 hover:text-white"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 0 0-8.6 15.1L2 22l5-1.3A10 10 0 1 0 12 2Zm5.4 14.1c-.2.6-1.3 1.2-1.8 1.2-.5.1-1 .2-3.3-.7-2.8-1.1-4.6-4-4.7-4.2-.1-.2-1.1-1.5-1.1-2.9s.7-2 1-2.3c.2-.3.5-.3.7-.3h.5c.2 0 .4 0 .6.4l.9 2.1c.1.2.1.4 0 .6l-.4.6-.5.5c-.2.2-.3.4-.1.7.2.3.9 1.4 1.9 2.3 1.3 1.1 2.3 1.5 2.6 1.6.3.1.5.1.7-.1l1-1.2c.2-.3.4-.2.7-.1l2 1c.3.1.5.2.6.4 0 .1 0 .7-.3 1.4Z"/></svg>
        Discuter de cette installation sur WhatsApp
      </a>
    </section>

    <StickyCta />
  </div>

  <!-- W178 — Lightbox accessible pour photos de la galerie et diptych -->
  <div
    id="tq-lightbox-slug"
    role="dialog"
    aria-modal="true"
    aria-label="Photo agrandie"
    class="slug-lightbox-overlay"
    hidden
  >
    <button type="button" id="tq-lb-slug-close" class="slug-lightbox-close" aria-label="Fermer (Échap)">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
        <path d="M18 6 6 18M6 6l12 12"/>
      </svg>
    </button>
    <button type="button" id="tq-lb-slug-prev" class="slug-lightbox-arrow slug-lightbox-arrow--prev" aria-label="Photo précédente (←)">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
        <path d="m15 18-6-6 6-6"/>
      </svg>
    </button>
    <div class="slug-lightbox-img-wrap">
      <img id="tq-lb-slug-img" src="" alt="" class="slug-lightbox-img" />
      <p id="tq-lb-slug-label" class="slug-lightbox-label"></p>
    </div>
    <button type="button" id="tq-lb-slug-next" class="slug-lightbox-arrow slug-lightbox-arrow--next" aria-label="Photo suivante (→)">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
        <path d="m9 18 6-6-6-6"/>
      </svg>
    </button>
  </div>
</Layout>

<style>
  /* W179 — hover-zoom standardisé 1.04, reduced-motion safe */
  @media (prefers-reduced-motion: no-preference) {
    .slug-photo-img {
      transition: transform 700ms cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }
    .slug-gallery-btn:hover .slug-photo-img,
    .slug-gallery-btn:focus-visible .slug-photo-img,
    .phase-btn:hover .slug-photo-img,
    .phase-btn:focus-visible .slug-photo-img {
      transform: scale(1.04);
    }
  }

  /* W178 — lightbox slug */
  .slug-lightbox-overlay {
    position: fixed;
    inset: 0;
    z-index: 9000;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgb(7 11 29 / 0.94);
    padding: 1rem;
  }
  .slug-lightbox-overlay[hidden] {
    display: none;
  }
  .slug-lightbox-img-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: min(90vw, 1200px);
    gap: 0.75rem;
  }
  .slug-lightbox-img {
    display: block;
    max-width: 100%;
    max-height: 80vh;
    object-fit: contain;
    border: 1px solid rgb(255 255 255 / 0.12);
    box-shadow: 0 32px 80px -20px rgb(0 0 0 / 0.8);
  }
  .slug-lightbox-label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-lune-soft);
    text-align: center;
  }
  .slug-lightbox-close {
    position: fixed;
    top: 1.25rem;
    right: 1.25rem;
    z-index: 9001;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    color: var(--color-lune);
    border: 1px solid rgb(255 255 255 / 0.2);
    background: rgb(7 11 29 / 0.7);
    cursor: pointer;
    transition: color 200ms, border-color 200ms;
  }
  .slug-lightbox-close:hover,
  .slug-lightbox-close:focus-visible {
    color: var(--color-brass-300);
    border-color: var(--color-brass-400);
    outline: none;
  }
  .slug-lightbox-arrow {
    position: fixed;
    top: 50%;
    transform: translateY(-50%);
    z-index: 9001;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    color: var(--color-lune);
    border: 1px solid rgb(255 255 255 / 0.2);
    background: rgb(7 11 29 / 0.7);
    cursor: pointer;
    transition: color 200ms, border-color 200ms;
  }
  .slug-lightbox-arrow--prev { left: 1rem; }
  .slug-lightbox-arrow--next { right: 1rem; }
  .slug-lightbox-arrow:hover,
  .slug-lightbox-arrow:focus-visible {
    color: var(--color-brass-300);
    border-color: var(--color-brass-400);
    outline: none;
  }
</style>

<script>
  // W178 — Lightbox [slug].astro : galerie + diptych, vanilla JS, focus-trap
  interface LbItem {
    src: string;
    alt: string;
    label: string;
  }

  const overlay = document.getElementById('tq-lightbox-slug') as HTMLElement | null;
  const imgEl = document.getElementById('tq-lb-slug-img') as HTMLImageElement | null;
  const labelEl = document.getElementById('tq-lb-slug-label') as HTMLElement | null;
  const closeBtn = document.getElementById('tq-lb-slug-close') as HTMLButtonElement | null;
  const prevBtn = document.getElementById('tq-lb-slug-prev') as HTMLButtonElement | null;
  const nextBtn = document.getElementById('tq-lb-slug-next') as HTMLButtonElement | null;

  if (overlay && imgEl && labelEl && closeBtn && prevBtn && nextBtn) {
    let items: LbItem[] = [];
    let current = 0;
    let lastFocus: HTMLElement | null = null;

    function show(idx: number) {
      if (!items.length) return;
      current = ((idx % items.length) + items.length) % items.length;
      imgEl!.src = items[current].src;
      imgEl!.alt = items[current].alt;
      labelEl!.textContent = items[current].label;
      overlay!.hidden = false;
      overlay!.removeAttribute('hidden');
      const multi = items.length > 1;
      prevBtn!.style.display = multi ? '' : 'none';
      nextBtn!.style.display = multi ? '' : 'none';
      closeBtn!.focus();
      document.body.style.overflow = 'hidden';
    }

    function close() {
      overlay!.hidden = true;
      document.body.style.overflow = '';
      lastFocus?.focus();
    }

    // Collect all triggers (gallery + diptych phases combined)
    const triggers = document.querySelectorAll<HTMLElement>('[data-lightbox-trigger-slug]');
    items = Array.from(triggers).map((t) => ({
      src: t.dataset.lightboxSrc ?? '',
      alt: t.dataset.lightboxAlt ?? '',
      label: t.dataset.lightboxLabel ?? '',
    }));

    triggers.forEach((t, idx) => {
      t.addEventListener('click', () => {
        lastFocus = t;
        show(idx);
      });
    });

    closeBtn.addEventListener('click', close);
    prevBtn.addEventListener('click', () => show(current - 1));
    nextBtn.addEventListener('click', () => show(current + 1));

    overlay.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Escape') close();
      if (e.key === 'ArrowLeft') show(current - 1);
      if (e.key === 'ArrowRight') show(current + 1);
      if (e.key === 'Tab') {
        const focusable = Array.from(
          overlay!.querySelectorAll<HTMLElement>('button, [href], [tabindex]:not([tabindex="-1"])')
        ).filter((el) => !el.hidden && el.offsetParent !== null);
        if (!focusable.length) return;
        const first = focusable[0];
        const last = focusable[focusable.length - 1];
        if (e.shiftKey) {
          if (document.activeElement === first) {
            e.preventDefault();
            last.focus();
          }
        } else {
          if (document.activeElement === last) {
            e.preventDefault();
            first.focus();
          }
        }
      }
    });

    overlay.addEventListener('click', (e) => {
      if (e.target === overlay) close();
    });
  }
</script>
