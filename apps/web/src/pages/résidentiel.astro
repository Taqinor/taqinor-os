---
import Layout from '../layouts/Layout.astro';
import Article33Ribbon from '../components/Article33Ribbon.astro';
import LeadForm from '../components/LeadForm.astro';
import CtaBand from '../components/CtaBand.astro';

// Exemples de dimensionnement par tranche de facture — fourchettes
// indicatives (≈1,4 MAD/kWh, ≈1 600 kWh/kWc/an), jamais un devis.
const sizingExamples = [
  { bill: '1 000 – 1 500 MAD', kwc: '3 à 5 kWc', payback: '5 à 7 ans' },
  { bill: '1 500 – 3 000 MAD', kwc: '5 à 9 kWc', payback: '4 à 6 ans' },
  { bill: '3 000 – 5 000 MAD', kwc: '9 à 15 kWc', payback: '4 à 6 ans' },
  { bill: '5 000 MAD et plus', kwc: '15 kWc et plus', payback: '3 à 5 ans' },
];
---

<Layout
  title="Solaire résidentiel au Maroc — villas et appartements | Taqinor"
  description="Installation solaire pour villa ou appartement au Maroc : dimensionnement à partir de votre facture, retour sur investissement en 3 à 7 ans, déclaration loi 82-21 incluse."
  ogSlug="residentiel"
>
  <Article33Ribbon />

  <section class="bg-navy-950 px-4 py-14 text-white">
    <div class="mx-auto max-w-3xl">
      <h1 class="text-3xl font-bold sm:text-4xl">Solaire résidentiel : un placement qui se calcule</h1>
      <p class="mt-4 leading-relaxed text-white/80">
        Une installation bien dimensionnée couvre 60 à 90 % de la consommation d'une villa.
        Le calcul part de votre facture réelle, du profil de consommation et de l'orientation
        de la toiture — pas d'un kit standard.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-4xl px-4 pt-10">
    <figure class="overflow-hidden rounded-2xl">
      <img src="/photos/installation-crepuscule.webp" alt="Installation solaire résidentielle Taqinor au crépuscule, toit-terrasse avec palmiers" width="1000" height="760" loading="eager" decoding="async" class="max-h-96 w-full object-cover" />
      <figcaption class="mt-2 text-center text-xs text-navy-800/75">Installation résidentielle Taqinor — photo de chantier réelle.</figcaption>
    </figure>
  </section>

  <section class="mx-auto max-w-4xl px-4 py-12">
    <h2 class="text-2xl font-bold">Quelle puissance pour quelle facture ?</h2>
    <p class="mt-2 text-sm text-navy-800/70">
      Fourchettes typiques constatées sur nos installations. Le chiffrage exact est établi
      après visite technique.
    </p>
    <div class="mt-6 overflow-x-auto">
      <table class="w-full border-collapse text-sm">
        <thead>
          <tr class="bg-navy-900 text-left text-white">
            <th class="rounded-tl-lg px-4 py-3 font-semibold">Facture mensuelle</th>
            <th class="px-4 py-3 font-semibold">Puissance typique</th>
            <th class="rounded-tr-lg px-4 py-3 font-semibold">Retour sur investissement</th>
          </tr>
        </thead>
        <tbody>
          {sizingExamples.map((r) => (
            <tr class="border-b border-navy-100">
              <td class="px-4 py-3 font-semibold">{r.bill}</td>
              <td class="px-4 py-3">{r.kwc}</td>
              <td class="px-4 py-3">{r.payback}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <p class="mt-3 text-xs text-navy-800/75">
      En dessous de 1 000 MAD par mois, le retour sur investissement dépasse généralement
      7 ans — nous vous le dirons honnêtement.
    </p>
  </section>

  <section class="bg-navy-50 px-4 py-12">
    <div class="mx-auto max-w-4xl">
      <h2 class="text-2xl font-bold">L'illustration sur 25 ans</h2>
      <p class="mt-3 leading-relaxed text-navy-800/85">
        Les panneaux sont garantis en performance sur 25 ans. Pour une villa avec une facture
        de 2 000 MAD par mois, une installation de 6 kWc représente un investissement de
        l'ordre de 60 000 à 75 000 MAD et évite environ 20 000 MAD d'électricité par an.
        L'investissement est remboursé en 4 à 6 ans ; les 19 à 21 années suivantes,
        l'électricité produite est quasi gratuite — seul un remplacement d'onduleur est à
        prévoir sur la période.
      </p>
      <ul class="mt-5 grid gap-3 text-sm sm:grid-cols-3">
        <li class="rounded-xl border border-navy-100 bg-white p-4">
          <p class="text-lg font-bold">25 ans</p>
          <p class="mt-1 text-navy-800/70">de garantie de performance des panneaux</p>
        </li>
        <li class="rounded-xl border border-navy-100 bg-white p-4">
          <p class="text-lg font-bold">3 à 7 ans</p>
          <p class="mt-1 text-navy-800/70">de retour sur investissement typique</p>
        </li>
        <li class="rounded-xl border border-navy-100 bg-white p-4">
          <p class="text-lg font-bold">&lt; 11 kW</p>
          <p class="mt-1 text-navy-800/70">en basse tension : simple déclaration loi 82-21, gérée par Taqinor</p>
        </li>
      </ul>
    </div>
  </section>

  <LeadForm heading="Votre fourchette en 30 secondes" />

  <CtaBand />
</Layout>
