---
import Layout from '../layouts/Layout.astro';
import Article33Ribbon from '../components/Article33Ribbon.astro';
import LeadForm from '../components/LeadForm.astro';
import CtaBand from '../components/CtaBand.astro';
import Picture from '../components/Picture.astro';

// Exemples de dimensionnement par tranche de facture — fourchettes
// indicatives (≈1,4 MAD/kWh, ≈1 600 kWh/kWc/an), jamais un devis.
const sizingExamples = [
  { bill: '1 000 – 1 500 MAD', kwc: '3 à 5 kWc', payback: '5 à 7 ans' },
  { bill: '1 500 – 3 000 MAD', kwc: '5 à 9 kWc', payback: '4 à 6 ans' },
  { bill: '3 000 – 5 000 MAD', kwc: '9 à 15 kWc', payback: '4 à 6 ans' },
  { bill: '5 000 MAD et plus', kwc: '15 kWc et plus', payback: '3 à 5 ans' },
];
---

<Layout
  title="Solaire résidentiel au Maroc — villas et appartements | Taqinor"
  description="Installation solaire pour villa ou appartement au Maroc : dimensionnement à partir de votre facture, retour sur investissement en 3 à 7 ans, déclaration loi 82-21 incluse."
  ogSlug="residentiel"
>
  <Article33Ribbon />

  <!-- Hero — photo crépuscule pleine largeur -->
  <section class="relative isolate overflow-hidden bg-night text-paper">
    <div class="absolute inset-0 -z-10">
      <Picture
        name="crepuscule-penthouse"
        alt=""
        widths={[1600, 1024, 640]}
        ratio={4 / 3}
        sizes="100vw"
        loading="eager"
        fetchpriority="high"
        class="h-full w-full object-cover object-[65%_40%]"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-night/95 via-night/45 to-night/5"></div>
    </div>
    <div class="mx-auto max-w-6xl px-4 py-20 sm:py-28">
      <p class="tech-label rule-amber text-amber-400">Villas · appartements</p>
      <h1 class="display mt-4 max-w-2xl text-4xl sm:text-5xl">Solaire résidentiel : un placement qui se calcule</h1>
      <p class="mt-5 max-w-xl leading-relaxed text-paper/85">
        Une installation bien dimensionnée couvre 60 à 90 % de la consommation d'une villa.
        Le calcul part de votre facture réelle, du profil de consommation et de l'orientation
        de la toiture — pas d'un kit standard.
      </p>
    </div>
  </section>

  <!-- Fiche de dimensionnement -->
  <section class="mx-auto max-w-4xl px-4 py-16">
    <p class="tech-label rule-amber text-ink-soft">Fourchettes constatées</p>
    <h2 class="display mt-3 text-3xl">Quelle puissance pour quelle facture ?</h2>
    <p class="mt-3 text-sm text-ink-soft">
      Fourchettes typiques constatées sur nos installations. Le chiffrage exact est établi
      après visite technique.
    </p>
    <div class="mt-8 border-t-2 border-ink">
      <div class="tech-label hidden grid-cols-[1.2fr_1fr_1fr] gap-4 border-b border-ink/15 py-3 text-ink-faint sm:grid">
        <span>Facture mensuelle</span><span>Puissance typique</span><span>Retour sur investissement</span>
      </div>
      {sizingExamples.map((r) => (
        <div class="grid gap-1 border-b border-ink/15 py-5 sm:grid-cols-[1.2fr_1fr_1fr] sm:items-baseline sm:gap-4">
          <span class="font-display text-lg font-bold">{r.bill}</span>
          <span class="fig text-2xl text-amber-700 sm:text-3xl">{r.kwc}</span>
          <span class="text-sm text-ink-soft"><span class="fig text-2xl text-ink sm:text-3xl">{r.payback}</span></span>
        </div>
      ))}
    </div>
    <p class="mt-4 text-xs text-ink-faint">
      En dessous de 1 000 MAD par mois, le retour sur investissement dépasse généralement
      7 ans — nous vous le dirons honnêtement.
    </p>
  </section>

  <!-- Illustration 25 ans -->
  <section class="grid-paper border-y border-ink/10 bg-sand/50 px-4 py-16">
    <div class="mx-auto grid max-w-6xl gap-10 lg:grid-cols-[1.1fr_1fr] lg:items-center">
      <div>
        <p class="tech-label rule-amber text-ink-soft">L'horizon d'investissement</p>
        <h2 class="display mt-3 text-3xl">L'illustration sur 25 ans</h2>
        <p class="mt-4 leading-relaxed text-ink-soft">
          Les panneaux sont garantis en performance sur 25 ans. Pour une villa avec une facture
          de 2 000 MAD par mois, une installation de 6 kWc représente un investissement de
          l'ordre de 60 000 à 75 000 MAD et évite environ 20 000 MAD d'électricité par an.
          L'investissement est remboursé en 4 à 6 ans ; les 19 à 21 années suivantes,
          l'électricité produite est quasi gratuite — seul un remplacement d'onduleur est à
          prévoir sur la période.
        </p>
        <ul class="mt-7 grid gap-4 sm:grid-cols-3">
          <li class="border border-ink/15 bg-paper p-5">
            <p class="fig text-3xl text-amber-700">25 ans</p>
            <p class="mt-2 text-xs leading-relaxed text-ink-soft">de garantie de performance des panneaux</p>
          </li>
          <li class="border border-ink/15 bg-paper p-5">
            <p class="fig text-3xl text-amber-700">3–7 ans</p>
            <p class="mt-2 text-xs leading-relaxed text-ink-soft">de retour sur investissement typique</p>
          </li>
          <li class="border border-ink/15 bg-paper p-5">
            <p class="fig text-3xl text-amber-700">&lt; 11 kW</p>
            <p class="mt-2 text-xs leading-relaxed text-ink-soft">en basse tension : simple déclaration loi 82-21, gérée par Taqinor</p>
          </li>
        </ul>
      </div>
      <div class="grid gap-4">
        <figure class="reveal overflow-hidden border border-ink/15">
          <Picture
            name="villa-zellige"
            alt="Installation solaire Taqinor sur villa marocaine à toiture pyramidale en zellige turquoise"
            widths={[1600, 1024, 640]}
            ratio={4 / 3}
            sizes="(min-width: 1024px) 40vw, 100vw"
            class="w-full object-cover"
          />
          <figcaption class="tech-label bg-paper px-3 py-2.5 text-ink-faint">Villa · toiture traditionnelle préservée</figcaption>
        </figure>
        <figure class="reveal overflow-hidden border border-ink/15">
          <Picture
            name="champ-villa"
            alt="Champ de panneaux noirs sur toit plat de villa, ciel bleu"
            widths={[1600, 1024, 640]}
            ratio={3 / 2}
            sizes="(min-width: 1024px) 40vw, 100vw"
            class="w-full object-cover"
          />
          <figcaption class="tech-label bg-paper px-3 py-2.5 text-ink-faint">Champ résidentiel · photo de chantier réelle</figcaption>
        </figure>
      </div>
    </div>
  </section>

  <LeadForm heading="Votre fourchette en 30 secondes" />

  <CtaBand />
</Layout>
