---
/**
 * Page publique — élévation « bleu Majorelle élevé + âme marocaine, appliquée
 * avec discipline ». ÉLÈVE le système v2 « élégance retenue » / « Cinéma du
 * chantier » (il ne le remplace PAS) : nuit profonde (#070b1d) + laiton, aucun
 * noir. Mêmes hooks de mouvement que l'accueil élevé (.cine-in / .v2-rise,
 * count-up, Ken Burns), tous gated `prefers-reduced-motion`. Données et chiffres
 * VERBATIM — aucun fait inventé ; le formulaire et son flux de lead sont
 * inchangés byte-for-byte (composant partagé DiagnosticForm, conservé dans le
 * code comme repli documenté — cf. /api/simulate).
 *
 * W249 — Un seul entonnoir : l'acte final n'est plus DiagnosticForm mais le
 * widget d'estimation instantanée partagé avec l'accueil (InstantEstimator,
 * W250 — même cerveau billEstimate.ts, même CTA vers le parcours devis). Deux
 * captures divergentes sur la même page brouillaient l'attribution ; le
 * composant DiagnosticForm reste intact et importé ailleurs (résidentiel garde
 * son data-flow inchangé partout où il est encore monté).
 *
 * Élévations appliquées (réf. /preview/accueil-v3 + index.astro) :
 *  1. héros cinématographique plus haut (~92svh), photo plein cadre
 *     protagoniste, eyebrow lune + titre ancrés bas, UN CTA brass + ghost
 *     WhatsApp, chevron de défilement ; scrim relevé (.hero-scrim-v3) ;
 *  2. discipline laiton : l'or sur les chiffres (.lum) et le CTA principal ;
 *     les eyebrows brass sont rétrogradés en lune ;
 *  3. grade « heure dorée » (.v3-grade) sur la photographie de contenu ;
 *  4. rythme via les tokens .section / .section-tight + coutures .seam-soft ;
 *  5. un seul langage de mouvement .cine-in (+ stagger) / .v2-rise ;
 *  6. typographie .display / .fig / .v2-body resserrée.
 */
import Layout from '../layouts/Layout.astro';
import V2Enhance from '../components/V2Enhance.astro';
import Article33Ribbon from '../components/Article33Ribbon.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import InstantEstimator from '../components/InstantEstimator.astro';
import CtaBand from '../components/CtaBand.astro';
import Picture from '../components/Picture.astro';
import StickyCta from '../components/StickyCta.astro';
import ZelligeDivider from '../components/ZelligeDivider.astro';
import GarantiesTeaser from '../components/GarantiesTeaser.astro';
import Testimonials from '../components/Testimonials.astro';
import Faq from '../components/Faq.astro';
import ServiceWarrantyTable from '../components/ServiceWarrantyTable.astro';
import RelatedLinks from '../components/RelatedLinks.astro';
import { BILL_RANGES, localEstimateBand } from '../lib/billRange';
import { formatMAD } from '../lib/format';
import { WHATSAPP_LEADS } from '../lib/nap';
import { whatsappLink } from '../lib/whatsapp';
import { serviceFaqItems } from '../lib/serviceFaq';

const waDirect = whatsappLink(WHATSAPP_LEADS, 'Bonjour, je souhaite une étude pour une installation solaire.');

// W263 — FAQ partagée + garanties par composant, localisées FR (repli par défaut).
const faqItems = serviceFaqItems('residentiel', 'fr');

const PRIX_PAR_KWC = { bas: 10000, haut: 12500 };
const arrondi5k = (v: number) => Math.round(v / 5000) * 5000;

const EXEMPLES_REELS: Record<string, string> = {
  '1000-1500': 'Exemple réel : réf. NC-10/25 — 3,72 kWc, Nouaceur, octobre 2025',
  '1500-3000': 'Exemple réel : réf. 236 — 5,68 kWc, El Jadida, mars 2026',
  '3000-5000': 'Exemple réel : réf. 400 — 11,36 kWc, Casablanca, avril 2026',
  '5000-10000': 'Exemple réel : réf. 468 — 17,04 kWc, El Jadida, avril 2026',
};

const brackets = BILL_RANGES.filter((r) => r.qualifies && r.id !== 'gt10000').map((r) => {
  const band = localEstimateBand(r.id);
  return {
    bill: r.label,
    kwc: band.kwcLabel,
    payback: band.paybackLabel,
    invest: `${formatMAD(arrondi5k(band.kwcMin * PRIX_PAR_KWC.bas))} – ${formatMAD(arrondi5k(band.kwcMax * PRIX_PAR_KWC.haut))}`,
    exemple: EXEMPLES_REELS[r.id] ?? null,
  };
});
---

<Layout
  title="Solaire pour villa et appartement au Maroc — chiffré sur facture | Taqinor"
  description="11,36 kWc à Casablanca, 14 271 kWh mesurés : nos installations résidentielles dimensionnées sur votre facture réelle, avec ordres de grandeur honnêtes, retour en 3 à 7 ans et déclaration loi 82-21."
  ogSlug="residentiel"
>
  <div class="v2">
    <V2Enhance />
    <Article33Ribbon />

    <Breadcrumb items={[{ label: 'Accueil', href: '/' }, { label: 'Résidentiel' }]} />

    {/* ── 1 · HÉROS CINÉMATOGRAPHIQUE (~92svh) — la photo est le protagoniste ── */}
    <section class="relative isolate flex min-h-[92svh] flex-col justify-end overflow-hidden text-white">
      <div class="v2-hero-media absolute inset-0 -z-10">
        {/* Affiche héro plein cadre (élément LCP) — JAMAIS de .v3-grade ici
            (protection LCP) : seul le scrim relevé porte la chaleur. */}
        <Picture name="crepuscule-penthouse" alt="" widths={[1600, 1024, 640]} ratio={4 / 3} sizes="100vw"
          loading="eager" fetchpriority="high" class="h-full w-full object-cover object-[65%_40%]" />
        {/* Scrim canonique relevé (.hero-scrim-v3 → --hero-scrim-strength 0.52) :
            compense la chaleur de la photo et garde le headline ≥ AA. */}
        <div class="hero-scrim hero-scrim-v3 absolute inset-0"></div>
      </div>

      {/* Chevron d'invitation au défilement — statique sous reduced-motion */}
      <div class="absolute bottom-6 left-1/2 -translate-x-1/2 scroll-chevron" aria-hidden="true">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="6 9 12 15 18 9" />
        </svg>
      </div>

      {/* Contenu ancré BAS — eyebrow rétrogradé en lune (discipline laiton) */}
      <div class="mx-auto w-full max-w-6xl px-4 pb-24 pt-32 sm:pb-32">
        <p class="tech-label v2-kicker rule-brass cine-in text-lune">Villas · appartements</p>
        <h1 class="display v2-page-title cine-in cine-in-1 mt-5 max-w-[18ch]">Votre facture connaît déjà la taille de votre installation</h1>
        <p class="v2-lead cine-in cine-in-2 mt-6 max-w-xl text-white/85">
          Bien dimensionnée, une installation couvre 60 à 90 % de ce qu'une villa consomme. Trois
          chiffres suffisent à fixer la puissance : votre relevé ONEE, vos heures de pointe et
          l'orientation du toit. Nous travaillons à partir de ces relevés, et nous vous disons
          franchement la puissance qu'ils appellent — ni plus pour gonfler la facture, ni moins
          pour faire un prix d'appel.
        </p>
        <div class="cine-in cine-in-3 mt-10 flex flex-wrap items-center gap-3">
          {/* UN seul CTA brass (discipline laiton) — l'or est ici autorisé */}
          <a href="/devis/mon-toit" class="glow-hero bg-brass-400 px-8 py-4 text-lg font-bold text-azur-950 transition-all hover:bg-brass-300">
            Obtenir mon étude gratuite →
          </a>
          {/* Ghost WhatsApp — contour blanc, aucun laiton */}
          <a href={waDirect} rel="noopener" class="inline-flex items-center gap-2 border border-white/40 px-6 py-3.5 text-base font-semibold text-white backdrop-blur-sm transition-colors hover:border-white hover:bg-white/10">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 0 0-8.6 15.1L2 22l5-1.3A10 10 0 1 0 12 2Zm5.4 14.1c-.2.6-1.3 1.2-1.8 1.2-.5.1-1 .2-3.3-.7-2.8-1.1-4.6-4-4.7-4.2-.1-.2-1.1-1.5-1.1-2.9s.7-2 1-2.3c.2-.3.5-.3.7-.3h.5c.2 0 .4 0 .6.4l.9 2.1c.1.2.1.4 0 .6l-.4.6-.5.5c-.2.2-.3.4-.1.7.2.3.9 1.4 1.9 2.3 1.3 1.1 2.3 1.5 2.6 1.6.3.1.5.1.7-.1l1-1.2c.2-.3.4-.2.7-.1l2 1c.3.1.5.2.6.4 0 .1 0 .7-.3 1.4Z"/></svg>
            WhatsApp direct
          </a>
        </div>
      </div>
    </section>

    {/* Extrait d'étude — la carte « salle blanche » respire en pleine largeur
        sous le héros (chiffres VERBATIM réf. 400). L'azur porte les chiffres :
        l'or reste réservé au CTA héro et aux chiffres .lum du grand livre. */}
    <div class="seam-soft" aria-hidden="true"></div>
    <section class="section-tight px-4">
      <aside class="v2-rise mx-auto max-w-3xl border-t-4 border-brass-400 bg-blanc p-6 text-encre shadow-premium sm:p-8">
        <p class="tech-label text-brass-600">Extrait d'étude — réf. 400 · Casablanca · avril 2026</p>
        <div class="mt-5 grid grid-cols-2 gap-x-4 gap-y-6 sm:grid-cols-4">
          <div><p class="fig text-3xl text-azur-600 sm:text-4xl">11,36 <span class="text-base">kWc</span></p><p class="tech-label mt-1.5 text-encre-faint">Puissance installée</p></div>
          <div><p class="fig text-3xl text-azur-600 sm:text-4xl">14 271 <span class="text-base">kWh/an</span></p><p class="tech-label mt-1.5 text-encre-faint">Production estimée</p></div>
          <div><p class="fig text-3xl text-azur-600 sm:text-4xl">16 <span class="text-base">panneaux</span></p><p class="tech-label mt-1.5 text-encre-faint">Canadian Solar 710 Wc</p></div>
          <div><p class="fig text-3xl text-azur-600 sm:text-4xl">10 <span class="text-base">kWh</span></p><p class="tech-label mt-1.5 text-encre-faint">Stockage Dyness LFP</p></div>
        </div>
        <p class="mt-5 border-t border-azur-900/10 pt-3 text-xs text-encre-soft">Production estimée à partir du rendement mesuré de nos chantiers.</p>
      </aside>
    </section>

    {/* Transparence des prix — le grand livre, chiffres qui s'égrènent.
        Eyebrow rétrogradé en lune (discipline laiton). */}
    <section class="section mx-auto max-w-4xl px-4">
      {/* W274 — Système de numérotation par chapitre (01/02…), même dispositif
          que l'accueil (index.astro) : étendu ici pour que le procédé éditorial
          soit cohérent sur tout le site plutôt qu'exclusif à l'accueil. */}
      <p class="tech-label v2-kicker rule-brass text-lune"><span class="mr-2 font-display text-xs text-azur-200/80" aria-hidden="true">01</span>Transparence des prix</p>
      <h2 class="display v2-section-title mt-5 text-white">Votre facture vous place déjà dans une fourchette</h2>
      <p class="v2-lead mt-4 max-w-2xl text-lune-soft">
        Voici les ordres de grandeur relevés sur nos chantiers résidentiels — <strong class="text-lune">jamais un
        devis</strong>. Le chiffre exact tombe après la visite technique ; et si votre profil ne
        rentabilise pas le solaire, nous vous le dirons avant que vous n'ayez signé quoi que ce soit.
      </p>
      <div class="mt-10 border-t-2 border-brass-400/60" data-stagger>
        <div class="tech-label hidden grid-cols-[1.1fr_0.8fr_1.2fr_0.8fr] gap-4 border-b border-white/10 py-3 text-lune-faint sm:grid">
          <span>Facture mensuelle</span><span>Puissance</span><span>Investissement (ordre de grandeur)</span><span>Retour</span>
        </div>
        {brackets.map((b, i) => (
          <div class="v2-rise border-b border-white/10 py-5" style={`--v2-i:${i}`}>
            <div class="grid gap-1.5 sm:grid-cols-[1.1fr_0.8fr_1.2fr_0.8fr] sm:items-baseline sm:gap-4">
              <span class="font-display text-base font-bold text-white">{b.bill}</span>
              <span class="fig lum text-xl sm:text-2xl" data-tally>{b.kwc}</span>
              <span class="fig text-lg text-lune sm:text-xl">{b.invest}</span>
              <span class="fig text-xl text-brass-300 sm:text-2xl" data-tally>{b.payback}</span>
            </div>
            {b.exemple && <p class="tech-label mt-2.5 text-lune-faint">{b.exemple}</p>}
          </div>
        ))}
      </div>
      <p class="mt-5 max-w-2xl text-xs leading-relaxed text-lune-soft">
        Sous 1 000 MAD par mois, le retour dépasse le plus souvent 7 ans : nous le disons
        plutôt que de forcer la vente. Au-delà de 10 000 MAD, la consommation sort du cadre
        résidentiel et appelle une étude dédiée — voir Professionnel.
      </p>
    </section>

    <ZelligeDivider tone="white" />

    {/* Illustration 30 ans — eyebrow rétrogradé en lune (discipline laiton) */}
    <div class="seam-soft" aria-hidden="true"></div>
    <section class="section px-4">
      <div class="mx-auto grid max-w-6xl gap-12 lg:grid-cols-[1.1fr_1fr] lg:items-center">
        <div class="v2-rise">
          {/* W274 — Chapitre 02, même dispositif que ci-dessus. */}
          <p class="tech-label v2-kicker rule-brass text-lune"><span class="mr-2 font-display text-xs text-azur-200/80" aria-hidden="true">02</span>L'horizon d'investissement</p>
          <h2 class="display v2-section-title mt-5 text-white">Ce que les 30 ans donnent, année par année</h2>
          <p class="v2-lead mt-5 text-lune-soft">
            Le constructeur garantit la performance des panneaux sur 30 ans (garantie linéaire). Prenez une villa à
            2 000 MAD de facture mensuelle : 6 kWc se chiffrent autour de 60 000 à 75 000 MAD et
            effacent chaque année quelque 12 000 à 16 000 MAD d'électricité (au barème régie ONEE),
            pour la part autoconsommée — aucun tarif de rachat résidentiel (BT) n'étant encore publié,
            le surplus injecté ne vaut rien tant que ce barème n'existe pas.
            Quatre à six ans pour rembourser ; ensuite, sur les vingt-quatre à vingt-six années qui
            restent, le kilowattheure ne coûte presque plus rien — il n'y a qu'un onduleur à
            remplacer une fois sur la durée.
          </p>
          <dl class="mt-10 grid grid-cols-1 gap-4 sm:grid-cols-3 border-l-2 border-brass-400/60 pl-6" data-stagger>
            <div class="v2-rise" style="--v2-i:0">
              <dd class="fig lum whitespace-nowrap text-2xl sm:text-4xl" data-tally>30 ans</dd>
              <dt class="tech-label mt-1.5 text-lune-faint">Garantie panneaux</dt>
            </div>
            <div class="v2-rise" style="--v2-i:1">
              <dd class="fig lum whitespace-nowrap text-2xl sm:text-4xl" data-tally>3–7 ans</dd>
              <dt class="tech-label mt-1.5 text-lune-faint">Retour typique</dt>
            </div>
            <div class="v2-rise" style="--v2-i:2">
              <dd class="fig lum whitespace-nowrap text-2xl sm:text-4xl" data-tally>&lt; 11 kW</dd>
              <dt class="tech-label mt-1.5 text-lune-faint">Simple déclaration</dt>
            </div>
          </dl>
        </div>
        <div class="grid gap-4">
          <figure class="v2-rise cine-card group relative overflow-hidden">
            <Picture name="pose-134" alt="L'équipe Taqinor incline un panneau pendant la pose sur une villa de Casablanca"
              widths={[1600, 1024, 640]} ratio={4 / 3} sizes="(min-width: 1024px) 40vw, 100vw"
              class="v3-grade w-full object-cover transition-transform duration-700 group-hover:scale-[1.04]" />
            <figcaption class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-nuit/95 to-transparent px-4 pb-3 pt-12">
              <span class="tech-label block text-brass-300">Casablanca · 5,68 kWc · 7 135 kWh/an</span>
              <span class="mt-0.5 block text-xs text-lune">Pose en cours · 8 × Canadian Solar 710 Wc · mars 2026</span>
            </figcaption>
          </figure>
          <figure class="v2-rise cine-card group relative overflow-hidden">
            <Picture name="champ-villa" alt="Champ de huit panneaux sur toit plat de villa à El Jadida, ciel bleu"
              widths={[1600, 1024, 640]} ratio={3 / 2} sizes="(min-width: 1024px) 40vw, 100vw"
              class="v3-grade w-full object-cover transition-transform duration-700 group-hover:scale-[1.04]" />
            <figcaption class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-nuit/95 to-transparent px-4 pb-3 pt-12">
              <span class="tech-label block text-brass-300">El Jadida · 5,68 kWc · 7 135 kWh/an</span>
              <span class="mt-0.5 block text-xs text-lune">8 × Canadian Solar 710 Wc · Deye 5 kW · production estimée (rendement mesuré)</span>
            </figcaption>
          </figure>
        </div>
      </div>
    </section>

    {/* Liens contextuels — cluster prix/résidentiel (W299) */}
    <div class="seam-soft" aria-hidden="true"></div>
    <section class="section-tight px-4">
      <div class="mx-auto max-w-6xl">
        <RelatedLinks mt="mt-0" links={[
          { href: '/realisations', label: 'Nos réalisations résidentielles' },
          { href: '/prix-panneaux-solaires-maroc', label: 'Prix des panneaux solaires au Maroc' },
          { href: '/guides/combien-de-panneaux-pour-ma-maison', label: 'Combien de panneaux pour ma maison ?' },
          { href: '/équipement', label: "L'équipement posé" },
          { href: '/garanties', label: 'Nos garanties' },
          { href: '/batteries-stockage', label: 'Batteries & stockage' },
          { href: '/financement', label: 'Financement & rentabilité' },
          { href: '/pourquoi-taqinor', label: 'Pourquoi Taqinor' },
        ]} />
      </div>
    </section>

    <!-- W62 — Avis clients (vide → ne rend rien tant qu'aucun vrai avis) -->
    <Testimonials />

    <!-- Réassurance : les garanties écrites, en bref (renvoi vers /garanties) -->
    <GarantiesTeaser />

    <!-- W263 — FAQ partagée (entretien/prix/inclus-exclus/délais/garanties)
         + garantie par composant, AVANT le formulaire final. schema={false} :
         /faq reste l'unique page émettant le FAQPage JSON-LD (W19). -->
    <Faq schema={false} heading="Questions fréquentes — solaire résidentiel" items={faqItems} />
    <section class="section-tight bg-blanc-azur px-4 text-encre">
      <ServiceWarrantyTable />
    </section>

    <!-- ACTE FINAL — la salle blanche (W249 : un seul entonnoir, InstantEstimator) -->
    <InstantEstimator variant="hero" />

    <CtaBand
      title="Une question avant de vous lancer ? Parlez à un humain."
      buttonLabel="WhatsApp direct avec un conseiller"
      href={waDirect}
      seam={false}
    />

    <StickyCta />
  </div>
</Layout>

<style>
  /* Scrim héro relevé pour l'élévation : compense la chaleur de la photo
     plein cadre et garantit le contraste AA du headline blanc (réf. v3). */
  .hero-scrim-v3 {
    --hero-scrim-strength: 0.52;
  }
</style>
