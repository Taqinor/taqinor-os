---
/**
 * Page publique — élévation « élégance retenue » : typographie éditoriale,
 * révélations au défilement, chiffres count-up, parallaxe d'en-tête (desktop)
 * + mouvement photo (Ken Burns d'en-tête, montée d'échelle au défilement).
 * Tout le mouvement est désactivé sous prefers-reduced-motion. Le diagnostic
 * et son flux de données restent inchangés (composant partagé DiagnosticForm).
 * Voir apps/web/DESIGN_RATIONALE.md.
 */
import Layout from '../layouts/Layout.astro';
import V2Enhance from '../components/V2Enhance.astro';
import Article33Ribbon from '../components/Article33Ribbon.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import DiagnosticForm from '../components/DiagnosticForm.astro';
import CtaBand from '../components/CtaBand.astro';
import Picture from '../components/Picture.astro';
import StickyCta from '../components/StickyCta.astro';
import ZelligeDivider from '../components/ZelligeDivider.astro';
import GarantiesTeaser from '../components/GarantiesTeaser.astro';
import { localEstimateBand } from '../lib/billRange';
import { formatMAD } from '../lib/format';

const segments = [
  { n: '01', title: 'Industriels', body: 'Le poste électricité pèse directement sur le prix de revient. Une toiture de hangar amortit une installation en 3 à 5 ans, avec une production alignée sur les heures de fonctionnement des ateliers.' },
  { n: '02', title: 'Hôtels', body: 'Climatisation, blanchisserie, piscines : la consommation diurne des hôtels correspond exactement au profil de production solaire. Le solaire lisse un poste de charge qui croît chaque année.' },
  { n: '03', title: 'Cliniques', body: 'Continuité de service et maîtrise des coûts. Le couplage solaire + batteries sécurise les équipements critiques tout en réduisant la facture de jour.' },
];

const PRIX_PAR_KWC = { bas: 8500, haut: 11000 };
const arrondi10k = (v: number) => Math.round(v / 10000) * 10000;
const proBrackets = (['5000-10000', 'gt10000'] as const).map((id) => {
  const band = localEstimateBand(id);
  return {
    bill: id === '5000-10000' ? '5 000 – 10 000 MAD / mois' : 'Plus de 10 000 MAD / mois',
    kwc: band.kwcLabel,
    invest:
      id === 'gt10000'
        ? `à partir de ${formatMAD(arrondi10k(band.kwcMin * PRIX_PAR_KWC.bas))} — étude dédiée`
        : `${formatMAD(arrondi10k(band.kwcMin * PRIX_PAR_KWC.bas))} – ${formatMAD(arrondi10k(band.kwcMax * PRIX_PAR_KWC.haut))}`,
    payback: band.paybackLabel,
    exemple: id === '5000-10000' ? 'Exemple réel : réf. 468 — 17,04 kWc, El Jadida, avril 2026' : null,
  };
});
---

<Layout
  title="Solaire pour industriels, hôtels et cliniques au Maroc | Taqinor"
  description="Installations solaires moyenne tension pour sites professionnels au Maroc : ordres de grandeur transparents, réduction du poste électricité, valorisation du surplus, conformité loi 82-21."
  ogSlug="professionnel"
>
  <div class="v2">
    <V2Enhance />
    <Article33Ribbon />

    <Breadcrumb items={[{ label: 'Accueil', href: '/' }, { label: 'Professionnel' }]} />

    <!-- ACTE I — le couchant industriel plein cadre -->
    <section class="relative isolate overflow-hidden text-white">
      <div class="v2-hero-media absolute inset-0 -z-10">
        <Picture name="industriel-couchant" alt="" widths={[2000, 1280, 768, 480]} ratio={16 / 9} sizes="100vw"
          loading="eager" fetchpriority="high" class="h-full w-full object-cover object-[70%_30%]" />
        <div class="absolute inset-0 bg-gradient-to-t from-nuit via-nuit/40 to-transparent"></div>
      </div>
      <div class="mx-auto max-w-6xl px-4 pb-20 pt-28 sm:pb-24 sm:pt-36">
        <p class="tech-label v2-kicker rule-brass cine-in text-brass-300">Industriels · hôtels · cliniques</p>
        <h1 class="display v2-page-title cine-in mt-5 max-w-[20ch] [animation-delay:120ms]">L'électricité, un poste de coût que vous pouvez reprendre en main</h1>
        <p class="v2-lead cine-in mt-6 max-w-xl text-white/85 [animation-delay:240ms]">
          Pour un site professionnel, une installation solaire n'est pas un geste d'image :
          c'est un actif productif, amorti en 3 à 5 ans, qui produit ensuite pendant plus de
          20 ans. Taqinor dimensionne sur vos courbes de charge réelles.
        </p>
        <dl class="cine-in mt-10 grid max-w-2xl grid-cols-3 gap-3 border-t border-white/20 pt-6 sm:gap-6 [animation-delay:360ms]">
          <div>
            <dd class="fig lum text-base sm:text-4xl" data-tally>3–5 ans</dd>
            <dt class="tech-label mt-2 text-lune">Amortissement</dt>
          </div>
          <div>
            <dd class="fig lum text-base sm:text-4xl" data-tally>+20 ans</dd>
            <dt class="tech-label mt-2 text-lune">De production</dt>
          </div>
          <div>
            <dd class="fig lum text-base sm:text-4xl" data-tally>5 MW</dd>
            <dt class="tech-label mt-2 text-lune">Seuil d'autorisation</dt>
          </div>
        </dl>
      </div>
    </section>

    <!-- Trois segments -->
    <section class="mx-auto max-w-6xl px-4 py-24 sm:py-32">
      <div class="grid gap-6 md:grid-cols-3" data-stagger>
        {segments.map((s, i) => (
          <div class="v2-rise border-l-2 border-brass-400/60 pl-6" style={`--v2-i:${i}`}>
            <p class="fig lum text-2xl">{s.n}</p>
            <h2 class="display mt-2 text-2xl text-white">{s.title}</h2>
            <p class="mt-3 text-sm leading-relaxed text-lune-soft">{s.body}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Ordres de grandeur pro — le grand livre, chiffres qui s'égrènent -->
    <section class="border-y border-white/10 px-4 py-24 sm:py-32">
      <div class="mx-auto max-w-4xl">
        <p class="tech-label v2-kicker rule-brass text-brass-300">Transparence des prix</p>
        <h2 class="display v2-section-title mt-5 text-white">Ordres de grandeur pour un site professionnel</h2>
        <p class="v2-lead mt-4 max-w-2xl text-lune-soft">
          Fourchettes indicatives en toiture professionnelle — <strong class="text-lune">jamais un devis</strong> :
          le dimensionnement réel part de vos courbes de charge et des conditions de votre
          raccordement. En toiture de hangar ou de bâtiment professionnel, le coût au kWc installé
          est plus faible qu'en résidentiel (effet d'échelle) : à puissance égale, la fourchette
          est donc inférieure à celle de la page Résidentiel.
        </p>
        <div class="mt-10 border-t-2 border-brass-400/60" data-stagger>
          {proBrackets.map((b, i) => (
            <div class="v2-rise border-b border-white/10 py-5" style={`--v2-i:${i}`}>
              <div class="grid gap-1.5 sm:grid-cols-[1fr_0.7fr_1.3fr_0.7fr] sm:items-baseline sm:gap-4">
                <span class="font-display text-base font-bold text-white">{b.bill}</span>
                <span class="fig lum text-xl sm:text-2xl" data-tally>{b.kwc}</span>
                <span class="fig text-lg text-lune sm:text-xl">{b.invest}</span>
                <span class="fig text-xl text-brass-300 sm:text-2xl" data-tally>{b.payback}</span>
              </div>
              {b.exemple && <p class="tech-label mt-2.5 text-lune-faint">{b.exemple}</p>}
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Précision du geste — photos de chantier légendées -->
    <section class="mx-auto max-w-6xl px-4 py-24 sm:py-32">
      <div class="grid gap-4 sm:grid-cols-2" data-stagger>
        <figure class="v2-rise cine-card group relative overflow-hidden" style="--v2-i:0">
          <Picture name="mesure-rails" alt="Traçage et mesure au mètre des rails de fixation sur toiture professionnelle"
            widths={[1600, 1024, 640]} ratio={4 / 3} sizes="(min-width: 640px) 50vw, 100vw"
            class="w-full object-cover transition-transform duration-700 group-hover:scale-[1.04]" />
          <figcaption class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-nuit/95 to-transparent px-4 pb-3 pt-12">
            <span class="tech-label block text-brass-300">Nouaceur · 3,72 kWc · implantation</span>
            <span class="mt-0.5 block text-xs text-lune">Chaque rail est tracé et mesuré avant fixation</span>
          </figcaption>
        </figure>
        <figure class="v2-rise cine-card group relative overflow-hidden" style="--v2-i:1">
          <Picture name="equipe-trois" alt="Équipe Taqinor devant une longue rangée de panneaux en fin de chantier"
            widths={[1600, 1024, 640]} ratio={3 / 2} sizes="(min-width: 640px) 50vw, 100vw"
            class="w-full object-cover transition-transform duration-700 group-hover:scale-[1.04]" />
          <figcaption class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-nuit/95 to-transparent px-4 pb-3 pt-12">
            <span class="tech-label block text-brass-300">El Jadida · 17,04 kWc · 21 406 kWh/an</span>
            <span class="mt-0.5 block text-xs text-lune">Fin de chantier · 24 × Canadian Solar 710 Wc · Deye 15 kW triphasé</span>
          </figcaption>
        </figure>
      </div>
    </section>

    <ZelligeDivider tone="white" />

    <!-- Surplus + régimes MT -->
    <section class="px-4 py-24 sm:py-32">
      <div class="mx-auto max-w-3xl">
        <div class="v2-rise">
          <p class="tech-label v2-kicker rule-brass text-brass-300">Loi 82-21 · moyenne tension</p>
          <h2 class="display v2-section-title mt-5 text-white">Le surplus ne se perd pas</h2>
          <p class="v2-lead mt-5 text-lune-soft">
            La loi 82-21 encadre l'autoproduction et la valorisation de l'excédent injecté au
            réseau. Pour un site en moyenne tension, le dimensionnement intègre dès l'étude la
            part autoconsommée et la part excédentaire, selon les conditions de votre accord de
            raccordement — pour que chaque kWh produit ait une valeur.
          </p>
        </div>
        <div class="v2-rise">
          <h2 class="display v2-section-title mt-12 text-white">Moyenne et haute tension : votre régime loi 82-21</h2>
          <p class="v2-lead mt-5 text-lune-soft">
            Jusqu'à 5 MW raccordés en basse ou moyenne tension, l'installation relève de
            l'<strong class="text-lune">accord de raccordement</strong> avec le gestionnaire de réseau. À partir de
            5 MW (moyenne, haute ou très haute tension), elle relève du régime
            d'<strong class="text-lune">autorisation</strong>. Taqinor constitue le dossier technique et suit la
            procédure jusqu'à la mise en service.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href="/loi-82-21" class="inline-block border border-white/40 px-6 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">
              Identifier mon régime en 3 questions
            </a>
            <a href="/équipement" class="inline-block border border-white/40 px-6 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">
              Voir l'équipement posé
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Réassurance : les garanties écrites, en bref (renvoi vers /garanties) -->
    <GarantiesTeaser />

    <!-- ACTE FINAL — la salle blanche -->
    <DiagnosticForm heading="Diagnostic pour votre site professionnel" />

    <CtaBand title="Vos courbes de charge méritent une étude sérieuse." href="#simulateur" seam={false} />

    <StickyCta />
  </div>
</Layout>
