---
/**
 * Page publique — élévation « bleu Majorelle élevé + âme marocaine, appliquée
 * avec discipline ». ÉLÈVE le système v2 « élégance retenue » / « Cinéma du
 * chantier » (il ne le remplace PAS) : nuit profonde (#070b1d) + laiton, aucun
 * noir. Mêmes hooks de mouvement que l'accueil élevé (.cine-in / .v2-rise,
 * count-up, Ken Burns), tous gated `prefers-reduced-motion`. Données et chiffres
 * VERBATIM — aucun fait inventé ; le formulaire et son flux de lead sont
 * inchangés byte-for-byte (composant partagé DiagnosticForm).
 *
 * Élévations appliquées (réf. /preview/accueil-v3 + index.astro) :
 *  1. héros cinématographique plus haut (~92svh), photo plein cadre
 *     protagoniste, eyebrow lune + titre + chiffres .lum ancrés bas, UN CTA
 *     brass + ghost WhatsApp, chevron ; scrim relevé (.hero-scrim-v3) ;
 *  2. discipline laiton : l'or sur les chiffres (.lum) et le CTA principal ;
 *     les eyebrows brass sont rétrogradés en lune ;
 *  3. grade « heure dorée » (.v3-grade) sur la photographie de contenu ;
 *  4. rythme via les tokens .section / .section-tight + coutures .seam-soft ;
 *  5. un seul langage de mouvement .cine-in (+ stagger) / .v2-rise ;
 *  6. typographie .display / .fig / .v2-body resserrée.
 */
import Layout from '../layouts/Layout.astro';
import V2Enhance from '../components/V2Enhance.astro';
import Article33Ribbon from '../components/Article33Ribbon.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import DiagnosticForm from '../components/DiagnosticForm.astro';
import CtaBand from '../components/CtaBand.astro';
import Picture from '../components/Picture.astro';
import StickyCta from '../components/StickyCta.astro';
import ZelligeDivider from '../components/ZelligeDivider.astro';
import GarantiesTeaser from '../components/GarantiesTeaser.astro';
import Testimonials from '../components/Testimonials.astro';
import { localEstimateBand } from '../lib/billRange';
import { formatMAD } from '../lib/format';
import { WHATSAPP_LEADS } from '../lib/nap';
import { whatsappLink } from '../lib/whatsapp';

const waDirect = whatsappLink(WHATSAPP_LEADS, 'Bonjour, je souhaite une étude pour une installation solaire.');

const segments = [
  { n: '01', title: 'Industriels', body: "Chaque kWh entre dans le prix de revient d'une pièce produite. Une toiture de hangar, large et plane, se rembourse en 3 à 5 ans et produit pile aux heures où les machines tournent — la production tombe quand la demande est là." },
  { n: '02', title: 'Hôtels', body: "Climatisation l'après-midi, blanchisserie le matin, pompes de piscine en continu : la courbe d'un hôtel épouse celle du soleil, heure pour heure. Le solaire vient plafonner un poste qui grimpe chaque saison." },
  { n: '03', title: 'Cliniques', body: "Un bloc ne tolère pas la coupure. Onduleurs hybrides plus batteries tiennent les équipements critiques pendant les creux du réseau, et en journée la facture baisse sur le reste du bâtiment." },
];

const PRIX_PAR_KWC = { bas: 8500, haut: 11000 };
const arrondi10k = (v: number) => Math.round(v / 10000) * 10000;
const proBrackets = (['5000-10000', 'gt10000'] as const).map((id) => {
  const band = localEstimateBand(id);
  return {
    bill: id === '5000-10000' ? '5 000 – 10 000 MAD / mois' : 'Plus de 10 000 MAD / mois',
    kwc: band.kwcLabel,
    invest:
      id === 'gt10000'
        ? `à partir de ${formatMAD(arrondi10k(band.kwcMin * PRIX_PAR_KWC.bas))} — étude dédiée`
        : `${formatMAD(arrondi10k(band.kwcMin * PRIX_PAR_KWC.bas))} – ${formatMAD(arrondi10k(band.kwcMax * PRIX_PAR_KWC.haut))}`,
    payback: band.paybackLabel,
    exemple: id === '5000-10000' ? 'Exemple réel : réf. 468 — 17,04 kWc, El Jadida, avril 2026' : null,
  };
});
---

<Layout
  title="Solaire industriel, hôtelier et clinique au Maroc — amorti en 3 à 5 ans | Taqinor"
  description="17,04 kWc à El Jadida, 21 406 kWh par an : installations solaires moyenne tension dimensionnées sur vos courbes de charge, surplus valorisé sous loi 82-21, du raccordement (≤ 5 MW) à l'autorisation."
  ogSlug="professionnel"
>
  <div class="v2">
    <V2Enhance />
    <Article33Ribbon />

    <Breadcrumb items={[{ label: 'Accueil', href: '/' }, { label: 'Professionnel' }]} />

    {/* ── 1 · HÉROS CINÉMATOGRAPHIQUE (~92svh) — le couchant industriel protagoniste ── */}
    <section class="relative isolate flex min-h-[92svh] flex-col justify-end overflow-hidden text-white">
      <div class="v2-hero-media absolute inset-0 -z-10">
        {/* Affiche héro plein cadre (élément LCP) — JAMAIS de .v3-grade ici
            (protection LCP) : seul le scrim relevé porte la chaleur. */}
        <Picture name="industriel-couchant" alt="" widths={[2000, 1280, 768, 480]} ratio={16 / 9} sizes="100vw"
          loading="eager" fetchpriority="high" class="h-full w-full object-cover object-[70%_30%]" />
        {/* Scrim canonique relevé (.hero-scrim-v3 → --hero-scrim-strength 0.52) :
            compense la chaleur du couchant et garde le headline ≥ AA. */}
        <div class="hero-scrim hero-scrim-v3 absolute inset-0"></div>
      </div>

      {/* Chevron d'invitation au défilement — statique sous reduced-motion */}
      <div class="absolute bottom-6 left-1/2 -translate-x-1/2 scroll-chevron" aria-hidden="true">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="6 9 12 15 18 9" />
        </svg>
      </div>

      {/* Contenu ancré BAS — eyebrow rétrogradé en lune (discipline laiton) */}
      <div class="mx-auto w-full max-w-6xl px-4 pb-24 pt-32 sm:pb-32">
        <p class="tech-label v2-kicker rule-brass cine-in text-lune">Industriels · hôtels · cliniques</p>
        <h1 class="display v2-page-title cine-in cine-in-1 mt-5 max-w-[20ch]">Votre poste électricité, vous pouvez le piloter au lieu de le subir</h1>
        <p class="v2-lead cine-in cine-in-2 mt-6 max-w-xl text-white/85">
          Sur un site professionnel, le solaire n'est pas une vitrine : c'est un équipement de
          production, remboursé en 3 à 5 ans, qui débite ensuite plus de vingt ans. À El Jadida,
          17,04 kWc fournissent 21 406 kWh par an. Le dimensionnement, lui, part de vos courbes
          de charge — pas d'un gabarit.
        </p>
        <div class="cine-in cine-in-3 mt-10 flex flex-wrap items-center gap-3">
          {/* UN seul CTA brass (discipline laiton) — l'or est ici autorisé */}
          <a href="/devis/mon-toit" class="glow-hero bg-brass-400 px-8 py-4 text-lg font-bold text-azur-950 transition-all hover:bg-brass-300">
            Obtenir mon étude gratuite →
          </a>
          {/* Ghost WhatsApp — contour blanc, aucun laiton */}
          <a href={waDirect} rel="noopener" class="inline-flex items-center gap-2 border border-white/40 px-6 py-3.5 text-base font-semibold text-white backdrop-blur-sm transition-colors hover:border-white hover:bg-white/10">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 0 0-8.6 15.1L2 22l5-1.3A10 10 0 1 0 12 2Zm5.4 14.1c-.2.6-1.3 1.2-1.8 1.2-.5.1-1 .2-3.3-.7-2.8-1.1-4.6-4-4.7-4.2-.1-.2-1.1-1.5-1.1-2.9s.7-2 1-2.3c.2-.3.5-.3.7-.3h.5c.2 0 .4 0 .6.4l.9 2.1c.1.2.1.4 0 .6l-.4.6-.5.5c-.2.2-.3.4-.1.7.2.3.9 1.4 1.9 2.3 1.3 1.1 2.3 1.5 2.6 1.6.3.1.5.1.7-.1l1-1.2c.2-.3.4-.2.7-.1l2 1c.3.1.5.2.6.4 0 .1 0 .7-.3 1.4Z"/></svg>
            WhatsApp direct
          </a>
        </div>
        {/* Chiffres clés du héros — l'or vit ici sur les .lum (discipline laiton) */}
        <dl class="cine-in cine-in-4 mt-10 grid max-w-2xl grid-cols-3 gap-3 border-t border-white/20 pt-6 sm:gap-6">
          <div>
            <dd class="fig lum text-base sm:text-4xl" data-tally>3–5 ans</dd>
            <dt class="tech-label mt-2 text-lune">Amortissement</dt>
          </div>
          <div>
            <dd class="fig lum text-base sm:text-4xl" data-tally>+20 ans</dd>
            <dt class="tech-label mt-2 text-lune">De production</dt>
          </div>
          <div>
            <dd class="fig lum text-base sm:text-4xl" data-tally>5 MW</dd>
            <dt class="tech-label mt-2 text-lune">Seuil d'autorisation</dt>
          </div>
        </dl>
      </div>
    </section>

    {/* Trois segments */}
    <div class="seam-soft" aria-hidden="true"></div>
    <section class="section mx-auto max-w-6xl px-4">
      <div class="grid gap-6 md:grid-cols-3" data-stagger>
        {segments.map((s, i) => (
          <div class="v2-rise border-l-2 border-brass-400/60 pl-6" style={`--v2-i:${i}`}>
            <p class="fig lum text-2xl">{s.n}</p>
            <h2 class="display mt-2 text-2xl text-white">{s.title}</h2>
            <p class="mt-3 text-sm leading-relaxed text-lune-soft">{s.body}</p>
          </div>
        ))}
      </div>
    </section>

    {/* Ordres de grandeur pro — le grand livre, chiffres qui s'égrènent.
        Eyebrow rétrogradé en lune (discipline laiton). */}
    <div class="seam-soft" aria-hidden="true"></div>
    <section class="section px-4">
      <div class="mx-auto max-w-4xl">
        <p class="tech-label v2-kicker rule-brass text-lune">Transparence des prix</p>
        <h2 class="display v2-section-title mt-5 text-white">À quel budget s'attendre pour un site professionnel</h2>
        <p class="v2-lead mt-4 max-w-2xl text-lune-soft">
          Fourchettes indicatives en toiture professionnelle — <strong class="text-lune">jamais un devis</strong>.
          Le chiffrage réel se cale sur vos courbes de charge et sur les conditions de votre
          raccordement. Sur un grand toit de hangar, chaque kWc posé revient moins cher qu'en
          résidentiel : plus la surface est continue, plus le coût unitaire baisse, et la fourchette
          ci-dessous passe donc sous celle de la page Résidentiel.
        </p>
        <div class="mt-10 border-t-2 border-brass-400/60" data-stagger>
          {proBrackets.map((b, i) => (
            <div class="v2-rise border-b border-white/10 py-5" style={`--v2-i:${i}`}>
              <div class="grid gap-1.5 sm:grid-cols-[1fr_0.7fr_1.3fr_0.7fr] sm:items-baseline sm:gap-4">
                <span class="font-display text-base font-bold text-white">{b.bill}</span>
                <span class="fig lum text-xl sm:text-2xl" data-tally>{b.kwc}</span>
                <span class="fig text-lg text-lune sm:text-xl">{b.invest}</span>
                <span class="fig text-xl text-brass-300 sm:text-2xl" data-tally>{b.payback}</span>
              </div>
              {b.exemple && <p class="tech-label mt-2.5 text-lune-faint">{b.exemple}</p>}
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* Précision du geste — photos de chantier légendées */}
    <div class="seam-soft" aria-hidden="true"></div>
    <section class="section mx-auto max-w-6xl px-4">
      <div class="grid gap-4 sm:grid-cols-2" data-stagger>
        <figure class="v2-rise cine-card group relative overflow-hidden" style="--v2-i:0">
          <Picture name="mesure-rails" alt="Traçage et mesure au mètre des rails de fixation sur toiture professionnelle"
            widths={[1600, 1024, 640]} ratio={4 / 3} sizes="(min-width: 640px) 50vw, 100vw"
            class="v3-grade w-full object-cover transition-transform duration-700 group-hover:scale-[1.04]" />
          <figcaption class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-nuit/95 to-transparent px-4 pb-3 pt-12">
            <span class="tech-label block text-brass-300">Nouaceur · 3,72 kWc · implantation</span>
            <span class="mt-0.5 block text-xs text-lune">Chaque rail est tracé et mesuré avant fixation</span>
          </figcaption>
        </figure>
        <figure class="v2-rise cine-card group relative overflow-hidden" style="--v2-i:1">
          <Picture name="equipe-trois" alt="Équipe Taqinor devant une longue rangée de panneaux en fin de chantier"
            widths={[1600, 1024, 640]} ratio={3 / 2} sizes="(min-width: 640px) 50vw, 100vw"
            class="v3-grade w-full object-cover transition-transform duration-700 group-hover:scale-[1.04]" />
          <figcaption class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-nuit/95 to-transparent px-4 pb-3 pt-12">
            <span class="tech-label block text-brass-300">El Jadida · 17,04 kWc · 21 406 kWh/an</span>
            <span class="mt-0.5 block text-xs text-lune">Fin de chantier · 24 × Canadian Solar 710 Wc · Deye 15 kW triphasé</span>
          </figcaption>
        </figure>
      </div>
    </section>

    <ZelligeDivider tone="white" />

    {/* Surplus + régimes MT — eyebrow rétrogradé en lune (discipline laiton) */}
    <section class="section px-4">
      <div class="mx-auto max-w-3xl">
        <div class="v2-rise">
          <p class="tech-label v2-kicker rule-brass text-lune">Loi 82-21 · moyenne tension</p>
          <h2 class="display v2-section-title mt-5 text-white">Faire payer chaque kilowattheure exporté</h2>
          <p class="v2-lead mt-5 text-lune-soft">
            La loi 82-21 fixe le cadre de l'autoproduction et de l'excédent renvoyé au réseau. En
            moyenne tension, l'étude distingue dès le départ ce que vous consommez sur place de ce
            que vous injectez, selon les termes de votre accord de raccordement. L'idée tient en une
            phrase : qu'un kilowattheure produit chez vous ne reparte jamais sans contrepartie.
          </p>
        </div>
        <div class="v2-rise">
          <h2 class="display v2-section-title mt-12 text-white">Sous quel régime loi 82-21 tombe votre site</h2>
          <p class="v2-lead mt-5 text-lune-soft">
            La puissance tranche. Jusqu'à 5 MW en basse ou moyenne tension, un simple
            <strong class="text-lune">accord de raccordement</strong> avec le gestionnaire de réseau suffit. Franchi
            le seuil de 5 MW — moyenne, haute ou très haute tension — vous basculez dans le régime
            d'<strong class="text-lune">autorisation</strong>. Dans les deux cas, nous montons le dossier technique
            et le portons jusqu'à la mise en service.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href="/loi-82-21" class="inline-block border border-white/40 px-6 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">
              Identifier mon régime en 3 questions
            </a>
            <a href="/équipement" class="inline-block border border-white/40 px-6 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">
              Voir l'équipement posé
            </a>
          </div>
        </div>
      </div>
    </section>

    {/* Liens contextuels */}
    <div class="seam-soft" aria-hidden="true"></div>
    <section class="section-tight px-4">
      <div class="mx-auto flex max-w-6xl flex-wrap gap-3">
        <a href="/realisations" class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">Nos réalisations →</a>
        <a href="/équipement" class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">L'équipement posé →</a>
        <a href="/pompage-solaire" class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">Pompage solaire →</a>
        <a href="/financement" class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">Financement &amp; rentabilité →</a>
        <a href="/pourquoi-taqinor" class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">Pourquoi Taqinor →</a>
      </div>
    </section>

    <!-- W62 — Avis clients (vide → ne rend rien tant qu'aucun vrai avis) -->
    <Testimonials />

    <!-- Réassurance : les garanties écrites, en bref (renvoi vers /garanties) -->
    <GarantiesTeaser />

    <!-- ACTE FINAL — la salle blanche -->
    <DiagnosticForm heading="Diagnostic pour votre site professionnel" />

    <CtaBand title="Vos courbes de charge méritent une étude sérieuse." href="/devis/mon-toit" seam={false} />

    <StickyCta />
  </div>
</Layout>

<style>
  /* Scrim héro relevé pour l'élévation : compense la chaleur du couchant
     plein cadre et garantit le contraste AA du headline blanc (réf. v3). */
  .hero-scrim-v3 {
    --hero-scrim-strength: 0.52;
  }
</style>
