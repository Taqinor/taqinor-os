---
import Layout from '../layouts/Layout.astro';
import Article33Ribbon from '../components/Article33Ribbon.astro';
import DiagnosticForm from '../components/DiagnosticForm.astro';
import CtaBand from '../components/CtaBand.astro';
import Picture from '../components/Picture.astro';
import StickyCta from '../components/StickyCta.astro';
import ZelligeDivider from '../components/ZelligeDivider.astro';
import { localEstimateBand } from '../lib/billRange';
import { formatMAD } from '../lib/format';

const segments = [
  {
    n: '01',
    title: 'Industriels',
    body: 'Le poste électricité pèse directement sur le prix de revient. Une toiture de hangar amortit une installation en 3 à 5 ans, avec une production alignée sur les heures de fonctionnement des ateliers.',
  },
  {
    n: '02',
    title: 'Hôtels',
    body: 'Climatisation, blanchisserie, piscines : la consommation diurne des hôtels correspond exactement au profil de production solaire. Le solaire lisse un poste de charge qui croît chaque année.',
  },
  {
    n: '03',
    title: 'Cliniques',
    body: 'Continuité de service et maîtrise des coûts. Le couplage solaire + batteries sécurise les équipements critiques tout en réduisant la facture de jour.',
  },
];

// Ordres de grandeur professionnels — dérivés des bandes kWc du simulateur
// (≈ 8 500 à 11 000 MAD/kWc en toiture pro, dégressif avec la taille).
const PRIX_PAR_KWC = { bas: 8500, haut: 11000 };
const arrondi10k = (v: number) => Math.round(v / 10000) * 10000;
const proBrackets = (['5000-10000', 'gt10000'] as const).map((id) => {
  const band = localEstimateBand(id);
  return {
    bill: id === '5000-10000' ? '5 000 – 10 000 MAD / mois' : 'Plus de 10 000 MAD / mois',
    kwc: band.kwcLabel,
    invest:
      id === 'gt10000'
        ? `à partir de ${formatMAD(arrondi10k(band.kwcMin * PRIX_PAR_KWC.bas))} — étude dédiée`
        : `${formatMAD(arrondi10k(band.kwcMin * PRIX_PAR_KWC.bas))} – ${formatMAD(arrondi10k(band.kwcMax * PRIX_PAR_KWC.haut))}`,
    payback: band.paybackLabel,
  };
});
---

<Layout
  title="Solaire pour industriels, hôtels et cliniques au Maroc | Taqinor"
  description="Installations solaires moyenne tension pour sites professionnels au Maroc : ordres de grandeur transparents, réduction du poste électricité, valorisation du surplus, conformité loi 82-21."
  ogSlug="professionnel"
>
  <Article33Ribbon />

  <!-- Hero — chantier industriel au couchant -->
  <section class="relative isolate overflow-hidden bg-azur-950 text-white">
    <div class="absolute inset-0 -z-10">
      <Picture
        name="industriel-couchant"
        alt=""
        widths={[2000, 1280, 768, 480]}
        ratio={16 / 9}
        sizes="100vw"
        loading="eager"
        fetchpriority="high"
        class="h-full w-full object-cover object-[70%_30%]"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-azur-950/95 via-azur-950/50 to-azur-950/10"></div>
    </div>
    <div class="mx-auto max-w-6xl px-4 py-16 sm:py-24">
      <p class="tech-label rule-brass text-brass-300">Industriels · hôtels · cliniques</p>
      <h1 class="display mt-4 max-w-[20ch] text-[clamp(1.9rem,6vw,3.4rem)]">L'électricité, un poste de coût que vous pouvez reprendre en main</h1>
      <p class="mt-5 max-w-xl leading-relaxed text-white/85">
        Pour un site professionnel, une installation solaire n'est pas un geste d'image :
        c'est un actif productif, amorti en 3 à 5 ans, qui produit ensuite pendant plus de
        20 ans. Taqinor dimensionne sur vos courbes de charge réelles.
      </p>
      <dl class="mt-10 grid max-w-2xl grid-cols-3 gap-3 border-t border-white/20 pt-6 sm:gap-6">
        <div>
          <dd class="fig text-base text-brass-300 sm:text-4xl">3–5 ans</dd>
          <dt class="tech-label mt-2 text-white/70">Amortissement</dt>
        </div>
        <div>
          <dd class="fig text-base text-brass-300 sm:text-4xl">+20 ans</dd>
          <dt class="tech-label mt-2 text-white/70">De production</dt>
        </div>
        <div>
          <dd class="fig text-base text-brass-300 sm:text-4xl">5 MW</dd>
          <dt class="tech-label mt-2 text-white/70">Seuil d'autorisation</dt>
        </div>
      </dl>
    </div>
  </section>

  <!-- Trois segments -->
  <section class="mx-auto max-w-6xl px-4 py-20 sm:py-24">
    <div class="grid gap-6 md:grid-cols-3">
      {segments.map((s) => (
        <div class="reveal border-l-2 border-azur-600 pl-6">
          <p class="fig text-2xl text-azur-600">{s.n}</p>
          <h2 class="display mt-2 text-2xl">{s.title}</h2>
          <p class="mt-3 text-sm leading-relaxed text-encre-soft">{s.body}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Ordres de grandeur pro -->
  <section class="bg-blanc-azur px-4 py-20 sm:py-24">
    <div class="mx-auto max-w-4xl">
      <p class="tech-label rule-brass text-azur-600">Transparence des prix</p>
      <h2 class="display mt-4 text-3xl">Ordres de grandeur pour un site professionnel</h2>
      <p class="mt-3 max-w-2xl text-sm leading-relaxed text-encre-soft">
        Fourchettes indicatives en toiture professionnelle — <strong class="text-encre">jamais un devis</strong> :
        le dimensionnement réel part de vos courbes de charge et des conditions de votre
        raccordement.
      </p>
      <div class="mt-8 border-t-2 border-azur-900">
        {proBrackets.map((b) => (
          <div class="grid gap-1.5 border-b border-azur-900/15 py-5 sm:grid-cols-[1fr_0.7fr_1.3fr_0.7fr] sm:items-baseline sm:gap-4">
            <span class="font-display text-base font-bold">{b.bill}</span>
            <span class="fig text-xl text-azur-600 sm:text-2xl">{b.kwc}</span>
            <span class="fig text-lg text-encre sm:text-xl">{b.invest}</span>
            <span class="fig text-xl text-brass-600 sm:text-2xl">{b.payback}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Précision du geste — photos de chantier légendées -->
  <section class="mx-auto max-w-6xl px-4 py-20 sm:py-24">
    <div class="grid gap-4 sm:grid-cols-2">
      <figure class="reveal overflow-hidden border border-azur-900/15 bg-blanc">
        <Picture
          name="mesure-rails"
          alt="Traçage et mesure au mètre des rails de fixation sur toiture professionnelle"
          widths={[1600, 1024, 640]}
          ratio={4 / 3}
          sizes="(min-width: 640px) 50vw, 100vw"
          class="w-full object-cover"
        />
        <figcaption class="px-3 py-2.5">
          <span class="tech-label block text-azur-700">Maroc · implantation</span>
          <span class="mt-0.5 block text-xs text-encre-soft">Chaque rail est tracé et mesuré avant fixation</span>
        </figcaption>
      </figure>
      <figure class="reveal overflow-hidden border border-azur-900/15 bg-blanc">
        <Picture
          name="equipe-trois"
          alt="Équipe Taqinor devant une longue rangée de panneaux en fin de chantier"
          widths={[1600, 1024, 640]}
          ratio={3 / 2}
          sizes="(min-width: 640px) 50vw, 100vw"
          class="w-full object-cover"
        />
        <figcaption class="px-3 py-2.5">
          <span class="tech-label block text-azur-700">Maroc · ≈ 8 kWc</span>
          <span class="mt-0.5 block text-xs text-encre-soft">Fin de chantier · équipe Taqinor</span>
        </figcaption>
      </figure>
    </div>
  </section>

  <ZelligeDivider />

  <!-- Surplus + régimes MT -->
  <section class="bg-blanc-azur px-4 py-20 sm:py-24">
    <div class="mx-auto max-w-3xl">
      <p class="tech-label rule-brass text-azur-600">Loi 82-21 · moyenne tension</p>
      <h2 class="display mt-4 text-3xl">Le surplus ne se perd pas</h2>
      <p class="mt-4 leading-relaxed text-encre-soft">
        La loi 82-21 encadre l'autoproduction et la valorisation de l'excédent injecté au
        réseau. Pour un site en moyenne tension, le dimensionnement intègre dès l'étude la
        part autoconsommée et la part excédentaire, selon les conditions de votre accord de
        raccordement — pour que chaque kWh produit ait une valeur.
      </p>
      <h2 class="display mt-10 text-3xl">Moyenne et haute tension : votre régime loi 82-21</h2>
      <p class="mt-4 leading-relaxed text-encre-soft">
        Jusqu'à 5 MW raccordés en basse ou moyenne tension, l'installation relève de
        l'<strong class="text-encre">accord de raccordement</strong> avec le gestionnaire de réseau. À partir de
        5 MW (moyenne, haute ou très haute tension), elle relève du régime
        d'<strong class="text-encre">autorisation</strong>. Taqinor constitue le dossier technique et suit la
        procédure jusqu'à la mise en service.
      </p>
      <a href="/loi-82-21" class="mt-7 inline-block bg-azur-700 px-6 py-3 text-sm font-bold text-white transition-colors hover:bg-azur-600">
        Identifier mon régime en 3 questions
      </a>
    </div>
  </section>

  <DiagnosticForm heading="Diagnostic pour votre site professionnel" />

  <CtaBand title="Vos courbes de charge méritent une étude sérieuse." />

  <StickyCta />
</Layout>
