---
/**
 * Page publique — élévation « bleu Majorelle élevé + âme marocaine, appliquée
 * avec discipline ». ÉLÈVE le système v2 « élégance retenue » / « Cinéma du
 * chantier » (il ne le remplace PAS) : nuit profonde (#070b1d) + laiton, aucun
 * noir. Mêmes hooks de mouvement que l'accueil élevé (.cine-in / .v2-rise,
 * count-up, Ken Burns), tous gated `prefers-reduced-motion`. Données et chiffres
 * VERBATIM — aucun fait inventé ; le formulaire et son flux de lead sont
 * inchangés byte-for-byte (composant partagé DiagnosticForm).
 *
 * Élévations appliquées (réf. /preview/accueil-v3 + index.astro) :
 *  1. héros cinématographique plus haut (~92svh), photo plein cadre
 *     protagoniste, eyebrow lune + titre + chiffres .lum ancrés bas, UN CTA
 *     brass + ghost WhatsApp, chevron ; scrim relevé (.hero-scrim-v3) ;
 *  2. discipline laiton : l'or sur les chiffres (.lum) et le CTA principal ;
 *     les eyebrows brass sont rétrogradés en lune ;
 *  3. grade « heure dorée » (.v3-grade) sur la photographie de contenu ;
 *  4. rythme via les tokens .section / .section-tight + coutures .seam-soft ;
 *  5. un seul langage de mouvement .cine-in (+ stagger) / .v2-rise ;
 *  6. typographie .display / .fig / .v2-body resserrée.
 */
import Layout from '../layouts/Layout.astro';
import V2Enhance from '../components/V2Enhance.astro';
import Article33Ribbon from '../components/Article33Ribbon.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import DiagnosticForm from '../components/DiagnosticForm.astro';
import CtaBand from '../components/CtaBand.astro';
import Picture from '../components/Picture.astro';
import StickyCta from '../components/StickyCta.astro';
import ZelligeDivider from '../components/ZelligeDivider.astro';
import GarantiesTeaser from '../components/GarantiesTeaser.astro';
import Testimonials from '../components/Testimonials.astro';
import CertLogoRow from '../components/CertLogoRow.astro';
import Faq from '../components/Faq.astro';
import ServiceWarrantyTable from '../components/ServiceWarrantyTable.astro';
import { localEstimateBand } from '../lib/billRange';
import { formatMAD } from '../lib/format';
import { WHATSAPP_LEADS } from '../lib/nap';
import { whatsappLink } from '../lib/whatsapp';
import { serviceFaqItems } from '../lib/serviceFaq';

const waDirect = whatsappLink(WHATSAPP_LEADS, 'Bonjour, je souhaite une étude pour une installation solaire.');

// W263 — FAQ partagée + garanties par composant, localisées FR.
const faqItems = serviceFaqItems('professionnel', 'fr');
// W337 — invitation « visiter un chantier », même mécanique que pourquoi-taqinor.astro
const waVisite = whatsappLink(WHATSAPP_LEADS, 'Bonjour, je souhaite visiter une installation professionnelle réelle.');

// W337 — RC Pro / assurance : scaffold no-op-safe (WG8). Aucune donnée réelle
// n'existe encore côté fondateur → reste `null` et la section ne rend RIEN
// tant que la valeur n'est pas fournie. Ne jamais inventer un numéro de police.
const RC_PRO_ASSURANCE: string | null = null;

// W260 — sous-cartes d'auto-identification par type de bâtiment (au lieu d'un
// seul bloc générique) : un acheteur C&I se reconnaît d'abord dans son type de
// site, avant de penser en kWc. Une preuve concrète par carte.
// W335 — chaque carte segment porte désormais DEUX lignes : une ligne
// financière (l'argument CFO) et une ligne technique/opérationnelle (l'argument
// terrain) — aucun chiffre nouveau, seulement la même preuve déjà publiée
// scindée en deux angles de lecture.
const segments = [
  {
    n: '01', title: 'Entrepôt / usine',
    body: "Chaque kWh entre dans le prix de revient d'une pièce produite. Une toiture large et plane se rembourse en 3 à 5 ans et produit pile aux heures où les machines tournent — la production tombe quand la demande est là.",
    proof: 'Preuve : El Jadida, 17,04 kWc, 21 406 kWh/an',
    financier: 'Charge d’exploitation qui devient un actif amorti en 3 à 5 ans',
    technique: 'Toiture large et plane · pose sans arrêt de production',
  },
  {
    n: '02', title: 'Hangar agro-industriel',
    body: "Séchage, froid, transformation : un hangar agricole consomme en plein jour, exactement quand le soleil donne. La toiture, déjà là, ne coûte rien de plus à exploiter — elle porte les panneaux sans grignoter un mètre carré au sol.",
    proof: 'Preuve : structure acier galvanisé garantie 20 ans, posée sur toiture existante',
    financier: 'Zéro foncier supplémentaire immobilisé — la toiture existante finance la structure',
    technique: 'Structure acier galvanisé 20 ans · aucune surface au sol perdue',
  },
  {
    n: '03', title: 'Commerce / hôtellerie',
    body: "Climatisation l'après-midi, blanchisserie le matin, pompes de piscine en continu : la courbe d'un commerce ou d'un hôtel épouse celle du soleil, heure pour heure. Le solaire vient plafonner un poste qui grimpe chaque saison.",
    proof: 'Preuve : amortissement 3 à 5 ans, même logique de charge que l’industrie',
    financier: 'Plafonne un poste de charges qui grimpe chaque saison touristique',
    technique: 'Courbe de consommation calée sur l’ensoleillement, heure pour heure',
  },
  {
    n: '04', title: 'Collectivités',
    body: "Un bâtiment public ou une clinique ne tolère pas la coupure. Onduleurs hybrides plus batteries tiennent les équipements critiques pendant les creux du réseau, et en journée la facture baisse sur le reste du bâtiment.",
    proof: 'Preuve : onduleurs hybrides Deye/Huawei, garantie 10 ans',
    financier: 'Baisse la facture du bâtiment tout en sécurisant la continuité de service',
    technique: 'Onduleurs hybrides + batteries · continuité sur les équipements critiques',
  },
];

const PRIX_PAR_KWC = { bas: 8500, haut: 11000 };
const arrondi10k = (v: number) => Math.round(v / 10000) * 10000;
// W335 — « économie cumulée sur 20 ans » : dérivée des CONSTANTES déjà
// publiées (investissement par kWc + fourchette d'amortissement), aucun
// chiffre nouveau. Logique : une fois le payback atteint, l'installation
// continue de produire jusqu'à la garantie de 25 ans de performance ; on
// projette sur un horizon de 20 ans (le même horizon que la structure et
// l'amortissement comptable cités plus bas) le multiple investissement ×
// (20 ans / durée de payback) — un ordre de grandeur, jamais un chiffre
// d'étude.
const HORIZON_ANS = 20;
const economieCumulee = (investMin: number, investMax: number, paybackMinAns: number, paybackMaxAns: number) => {
  const bas = arrondi10k((investMin * HORIZON_ANS) / paybackMaxAns);
  const haut = arrondi10k((investMax * HORIZON_ANS) / paybackMinAns);
  return `${formatMAD(bas)} – ${formatMAD(haut)}`;
};

const proBrackets = (['5000-10000', 'gt10000'] as const).map((id) => {
  const band = localEstimateBand(id);
  const investMin = arrondi10k(band.kwcMin * PRIX_PAR_KWC.bas);
  const investMax = arrondi10k(band.kwcMax * PRIX_PAR_KWC.haut);
  return {
    bill: id === '5000-10000' ? '5 000 – 10 000 MAD / mois' : 'Plus de 10 000 MAD / mois',
    kwc: band.kwcLabel,
    invest:
      id === 'gt10000'
        ? `à partir de ${formatMAD(investMin)} — étude dédiée`
        : `${formatMAD(investMin)} – ${formatMAD(investMax)}`,
    payback: band.paybackLabel,
    // « 3 à 5 ans » / « 3 à 7 ans » → bornes numériques pour la projection 20 ans.
    economie20ans: economieCumulee(investMin, investMax, 3, 5),
    exemple: id === '5000-10000' ? 'Exemple réel : réf. 468 — 17,04 kWc, El Jadida, avril 2026' : null,
  };
});

// W335 — comparateur structurel Achat (CAPEX) / Leasing (OPEX) : qui possède,
// qui amortit, impact trésorerie jour 1. AUCUN taux ni banque nommés — les
// cases nommées (CAM, Maghrebail…) sont sur /financement (W258/WG11).
const capexOpex = [
  {
    critere: 'Qui possède l’installation',
    achat: 'Votre entreprise, dès la mise en service',
    leasing: 'Le bailleur pendant la durée du contrat ; option de levée en fin de contrat selon le montage',
  },
  {
    critere: 'Qui inscrit l’amortissement',
    achat: 'Votre entreprise, à l’actif de son bilan (voir la fiscalité ci-dessous)',
    leasing: 'Le bailleur ; vous inscrivez le loyer en charge d’exploitation',
  },
  {
    critere: 'Impact trésorerie jour 1',
    achat: 'Sortie de trésorerie immédiate (ou à l’encaissement du crédit si financé)',
    leasing: 'Aucune sortie de trésorerie initiale — un loyer périodique remplace la facture évitée',
  },
];
---

<Layout
  title="Solaire industriel, hôtelier et clinique au Maroc — amorti en 3 à 5 ans | Taqinor"
  description="17,04 kWc à El Jadida, 21 406 kWh par an : installations solaires moyenne tension dimensionnées sur vos courbes de charge, surplus valorisé sous loi 82-21, du raccordement (≤ 5 MW) à l'autorisation."
  ogSlug="professionnel"
>
  <div class="v2">
    <V2Enhance />
    <Article33Ribbon />

    <Breadcrumb items={[{ label: 'Accueil', href: '/' }, { label: 'Professionnel' }]} />

    {/* ── 1 · HÉROS CINÉMATOGRAPHIQUE (~92svh) — le couchant industriel protagoniste ── */}
    <section class="relative isolate flex min-h-[92svh] flex-col justify-end overflow-hidden text-white">
      <div class="v2-hero-media absolute inset-0 -z-10">
        {/* Affiche héro plein cadre (élément LCP) — JAMAIS de .v3-grade ici
            (protection LCP) : seul le scrim relevé porte la chaleur. */}
        <Picture name="industriel-couchant" alt="" widths={[2000, 1280, 768, 480]} ratio={16 / 9} sizes="100vw"
          loading="eager" fetchpriority="high" class="h-full w-full object-cover object-[70%_30%]" />
        {/* Scrim canonique relevé (.hero-scrim-v3 → --hero-scrim-strength 0.52) :
            compense la chaleur du couchant et garde le headline ≥ AA. */}
        <div class="hero-scrim hero-scrim-v3 absolute inset-0"></div>
      </div>

      {/* Chevron d'invitation au défilement — statique sous reduced-motion */}
      <div class="absolute bottom-6 left-1/2 -translate-x-1/2 scroll-chevron" aria-hidden="true">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="6 9 12 15 18 9" />
        </svg>
      </div>

      {/* Contenu ancré BAS — eyebrow rétrogradé en lune (discipline laiton) */}
      <div class="mx-auto w-full max-w-6xl px-4 pb-24 pt-32 sm:pb-32">
        <p class="tech-label v2-kicker rule-brass cine-in text-lune">Entrepôt · agro-industriel · commerce · collectivité</p>
        <h1 class="display v2-page-title cine-in cine-in-1 mt-5 max-w-[20ch]">Votre poste électricité, vous pouvez le piloter au lieu de le subir</h1>
        <p class="v2-lead cine-in cine-in-2 mt-6 max-w-xl text-white/85">
          Sur un site professionnel, le solaire n'est pas une vitrine : c'est un équipement de
          production, remboursé en 3 à 5 ans, qui débite ensuite plus de vingt ans. À El Jadida,
          17,04 kWc fournissent 21 406 kWh par an. Le dimensionnement, lui, part de vos courbes
          de charge — pas d'un gabarit.
        </p>
        <div class="cine-in cine-in-3 mt-10 flex flex-wrap items-center gap-3">
          {/* UN seul CTA brass (discipline laiton) — l'or est ici autorisé.
              W337 — reformulé en offre d'audit : même parcours, même webhook
              DiagnosticForm, seul le libellé change. */}
          <a href="/devis/mon-toit" class="glow-hero bg-brass-400 px-8 py-4 text-lg font-bold text-azur-950 transition-all hover:bg-brass-300">
            Audit énergétique gratuit de mon site →
          </a>
          {/* Ghost WhatsApp — contour blanc, aucun laiton */}
          <a href={waDirect} rel="noopener" class="inline-flex items-center gap-2 border border-white/40 px-6 py-3.5 text-base font-semibold text-white backdrop-blur-sm transition-colors hover:border-white hover:bg-white/10">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 0 0-8.6 15.1L2 22l5-1.3A10 10 0 1 0 12 2Zm5.4 14.1c-.2.6-1.3 1.2-1.8 1.2-.5.1-1 .2-3.3-.7-2.8-1.1-4.6-4-4.7-4.2-.1-.2-1.1-1.5-1.1-2.9s.7-2 1-2.3c.2-.3.5-.3.7-.3h.5c.2 0 .4 0 .6.4l.9 2.1c.1.2.1.4 0 .6l-.4.6-.5.5c-.2.2-.3.4-.1.7.2.3.9 1.4 1.9 2.3 1.3 1.1 2.3 1.5 2.6 1.6.3.1.5.1.7-.1l1-1.2c.2-.3.4-.2.7-.1l2 1c.3.1.5.2.6.4 0 .1 0 .7-.3 1.4Z"/></svg>
            WhatsApp direct
          </a>
        </div>
        {/* Chiffres clés du héros — l'or vit ici sur les .lum (discipline laiton) */}
        <dl class="cine-in cine-in-4 mt-10 grid max-w-2xl grid-cols-3 gap-3 border-t border-white/20 pt-6 sm:gap-6">
          <div>
            <dd class="fig lum text-base sm:text-4xl" data-tally>3–5 ans</dd>
            <dt class="tech-label mt-2 text-lune">Amortissement</dt>
          </div>
          <div>
            <dd class="fig lum text-base sm:text-4xl" data-tally>+20 ans</dd>
            <dt class="tech-label mt-2 text-lune">De production</dt>
          </div>
          <div>
            <dd class="fig lum text-base sm:text-4xl" data-tally>5 MW</dd>
            <dt class="tech-label mt-2 text-lune">Seuil d'autorisation</dt>
          </div>
        </dl>
      </div>
    </section>

    {/* W260 — Quatre cartes d'auto-identification par type de site */}
    <div class="seam-soft" aria-hidden="true"></div>
    <section class="section mx-auto max-w-6xl px-4">
      {/* W274 — Système de numérotation par chapitre (01/02…), même dispositif
          que l'accueil (index.astro) : étendu ici pour que le procédé éditorial
          soit cohérent sur tout le site plutôt qu'exclusif à l'accueil.
          Seuls les eyebrows qui ouvrent une section majeure (pas les
          sous-titres à l'intérieur d'une même section) portent un numéro. */}
      <p class="tech-label v2-kicker rule-brass text-lune"><span class="mr-2 font-display text-xs text-azur-200/80" aria-hidden="true">01</span>Vous vous reconnaissez où ?</p>
      <h2 class="display v2-section-title mt-5 text-white">Quatre types de site, une même logique de charge</h2>
      <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-4" data-stagger>
        {segments.map((s, i) => (
          <div class="v2-rise border-l-2 border-brass-400/60 pl-6" style={`--v2-i:${i}`}>
            <p class="fig lum text-2xl">{s.n}</p>
            <h2 class="display mt-2 text-xl text-white">{s.title}</h2>
            <p class="mt-3 text-sm leading-relaxed text-lune-soft">{s.body}</p>
            {/* W335 — deux lignes de lecture : financière (CFO) puis technique/opérationnelle */}
            <dl class="mt-4 space-y-2 border-t border-white/10 pt-3">
              <div>
                <dt class="tech-label text-brass-300">Ligne financière</dt>
                <dd class="mt-0.5 text-xs leading-relaxed text-lune-soft">{s.financier}</dd>
              </div>
              <div>
                <dt class="tech-label text-lune">Ligne technique</dt>
                <dd class="mt-0.5 text-xs leading-relaxed text-lune-soft">{s.technique}</dd>
              </div>
            </dl>
            <p class="tech-label mt-3 text-lune-faint">{s.proof}</p>
          </div>
        ))}
      </div>
    </section>

    {/* Ordres de grandeur pro — le grand livre, chiffres qui s'égrènent.
        Eyebrow rétrogradé en lune (discipline laiton). */}
    <div class="seam-soft" aria-hidden="true"></div>
    <section class="section px-4">
      <div class="mx-auto max-w-4xl">
        {/* W274 — Chapitre 02, même dispositif. Les eyebrows "Deux montages
            possibles" et "Ce que vérifie votre service achats" plus bas
            restent SANS numéro : ce sont des sous-titres à l'intérieur de
            cette même section, pas de nouvelles sections majeures. */}
        <p class="tech-label v2-kicker rule-brass text-lune"><span class="mr-2 font-display text-xs text-azur-200/80" aria-hidden="true">02</span>Transparence des prix</p>
        <h2 class="display v2-section-title mt-5 text-white">À quel budget s'attendre pour un site professionnel</h2>
        <p class="v2-lead mt-4 max-w-2xl text-lune-soft">
          Fourchettes indicatives en toiture professionnelle — <strong class="text-lune">jamais un devis</strong>.
          Le chiffrage réel se cale sur vos courbes de charge et sur les conditions de votre
          raccordement. Sur un grand toit de hangar, chaque kWc posé revient moins cher qu'en
          résidentiel : plus la surface est continue, plus le coût unitaire baisse, et la fourchette
          ci-dessous passe donc sous celle de la page Résidentiel.
        </p>
        <div class="mt-10 border-t-2 border-brass-400/60" data-stagger>
          {proBrackets.map((b, i) => (
            <div class="v2-rise border-b border-white/10 py-5" style={`--v2-i:${i}`}>
              <div class="grid gap-1.5 sm:grid-cols-[1fr_0.7fr_1.3fr_0.7fr] sm:items-baseline sm:gap-4">
                <span class="font-display text-base font-bold text-white">{b.bill}</span>
                <span class="fig lum text-xl sm:text-2xl" data-tally>{b.kwc}</span>
                <span class="fig text-lg text-lune sm:text-xl">{b.invest}</span>
                <span class="fig text-xl text-brass-300 sm:text-2xl" data-tally>{b.payback}</span>
              </div>
              {/* W335 — économie cumulée sur 20 ans, dérivée des colonnes ci-dessus (aucun chiffre nouveau) */}
              <p class="tech-label mt-2.5 text-lune-faint">
                Économie cumulée sur 20 ans (estimée) : <span class="text-brass-300">{b.economie20ans}</span>
              </p>
              {b.exemple && <p class="tech-label mt-1 text-lune-faint">{b.exemple}</p>}
            </div>
          ))}
        </div>

        {/* W335 — comparateur structurel Achat (CAPEX) / Leasing (OPEX) — pas de taux ni de banque nommés ici */}
        <div class="mt-14">
          <p class="tech-label v2-kicker rule-brass text-lune">Deux montages possibles</p>
          <h3 class="display mt-3 text-xl text-white">Achat (CAPEX) ou leasing (OPEX) : ce qui change structurellement</h3>
          <p class="v2-lead mt-3 max-w-2xl text-sm text-lune-soft">
            Les cases nommées (banques, taux, contrats) sont sur la page <a href="/financement" class="border-b border-white/40 pb-0.5 font-semibold text-white transition-colors hover:border-white">Financement &amp; rentabilité</a> une
            fois vérifiées. Ici, seulement la mécanique — qui possède, qui amortit, quel effet sur votre trésorerie du jour 1.
          </p>
          <div class="mt-6 overflow-x-auto">
            <table class="w-full min-w-[560px] border-collapse text-sm">
              <thead>
                <tr class="border-b-2 border-brass-400/60 text-left">
                  <th class="py-3 pr-4 font-display font-bold text-white">Critère</th>
                  <th class="py-3 pr-4 font-display font-bold text-white">Achat (CAPEX)</th>
                  <th class="py-3 font-display font-bold text-white">Leasing (OPEX)</th>
                </tr>
              </thead>
              <tbody data-stagger>
                {capexOpex.map((c, i) => (
                  <tr class="v2-rise border-b border-white/10" style={`--v2-i:${i}`}>
                    <td class="py-3 pr-4 font-semibold text-lune">{c.critere}</td>
                    <td class="py-3 pr-4 text-lune-soft">{c.achat}</td>
                    <td class="py-3 text-lune-soft">{c.leasing}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>

        {/* W337 — confiance achats/procurement, près du tableau de prix.
            CertLogoRow est déjà no-op-safe (WJ35) : n'affiche que des faits
            techniques déjà publiés. La ligne RC Pro / assurance reste un
            scaffold WG8 — elle ne rend RIEN tant que Reda n'a pas fourni le
            numéro de police réel. */}
        <div class="mt-14 border-t border-white/10 pt-10">
          <p class="tech-label v2-kicker rule-brass text-lune">Ce que vérifie votre service achats</p>
          <CertLogoRow />
          {RC_PRO_ASSURANCE && (
            <p class="tech-label mt-4 text-lune-faint">Assurance responsabilité civile professionnelle : {RC_PRO_ASSURANCE}</p>
          )}
        </div>
      </div>
    </section>

    {/* Précision du geste — photos de chantier légendées */}
    <div class="seam-soft" aria-hidden="true"></div>
    <section class="section mx-auto max-w-6xl px-4">
      <div class="grid gap-4 sm:grid-cols-2" data-stagger>
        <figure class="v2-rise cine-card group relative overflow-hidden" style="--v2-i:0">
          <Picture name="mesure-rails" alt="Traçage et mesure au mètre des rails de fixation sur toiture professionnelle"
            widths={[1600, 1024, 640]} ratio={4 / 3} sizes="(min-width: 640px) 50vw, 100vw"
            class="v3-grade w-full object-cover transition-transform duration-700 group-hover:scale-[1.04]" />
          <figcaption class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-nuit/95 to-transparent px-4 pb-3 pt-12">
            <span class="tech-label block text-brass-300">Nouaceur · 3,72 kWc · implantation</span>
            <span class="mt-0.5 block text-xs text-lune">Chaque rail est tracé et mesuré avant fixation</span>
          </figcaption>
        </figure>
        <figure class="v2-rise cine-card group relative overflow-hidden" style="--v2-i:1">
          <Picture name="equipe-trois" alt="Équipe Taqinor devant une longue rangée de panneaux en fin de chantier"
            widths={[1600, 1024, 640]} ratio={3 / 2} sizes="(min-width: 640px) 50vw, 100vw"
            class="v3-grade w-full object-cover transition-transform duration-700 group-hover:scale-[1.04]" />
          <figcaption class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-nuit/95 to-transparent px-4 pb-3 pt-12">
            <span class="tech-label block text-brass-300">El Jadida · 17,04 kWc · 21 406 kWh/an</span>
            <span class="mt-0.5 block text-xs text-lune">Fin de chantier · 24 × Canadian Solar 710 Wc · Deye 15 kW triphasé</span>
          </figcaption>
        </figure>
      </div>
    </section>

    <ZelligeDivider tone="white" />

    {/* Surplus + régimes MT — eyebrow rétrogradé en lune (discipline laiton) */}
    <section class="section px-4">
      <div class="mx-auto max-w-3xl">
        <div class="v2-rise">
          {/* W274 — Chapitre 03, même dispositif. L'eyebrow "Les deux leviers
              fiscaux…" plus bas reste SANS numéro : sous-titre à l'intérieur
              de cette même section. */}
          <p class="tech-label v2-kicker rule-brass text-lune"><span class="mr-2 font-display text-xs text-azur-200/80" aria-hidden="true">03</span>Loi 82-21 · moyenne tension</p>
          <h2 class="display v2-section-title mt-5 text-white">Faire payer chaque kilowattheure exporté</h2>
          <p class="v2-lead mt-5 text-lune-soft">
            La loi 82-21 fixe le cadre de l'autoproduction et de l'excédent renvoyé au réseau. En
            moyenne tension, l'étude distingue dès le départ ce que vous consommez sur place de ce
            que vous injectez, selon les termes de votre accord de raccordement. L'idée tient en une
            phrase : qu'un kilowattheure produit chez vous ne reparte jamais sans contrepartie.
          </p>
        </div>
        <div class="v2-rise">
          <h2 class="display v2-section-title mt-12 text-white">Sous quel régime loi 82-21 tombe votre site</h2>
          <p class="v2-lead mt-5 text-lune-soft">
