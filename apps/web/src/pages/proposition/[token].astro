      <!-- ── CTA COLLANT « Signer en ligne » (WJ34 — safe-area-inset-bottom pour
           les iPhone à encoche / barre de geste : le CTA ne se cache jamais
           derrière la zone système) ──────────────────────────────────────── -->
      <div
        id="sticky-cta"
        class="fixed inset-x-0 bottom-0 z-40 border-t border-white/10 bg-nuit-800/95 px-4 pt-3 backdrop-blur supports-[backdrop-filter]:bg-nuit-800/80"
        style="padding-bottom: max(0.75rem, env(safe-area-inset-bottom));"
      >
        <div class="mx-auto flex max-w-4xl items-center justify-between gap-4">
          <div class="min-w-0">
            <p class="truncate text-sm text-lune-soft">
              {twoOptions ? 'À partir de ' : ''}
              <span class="lum fig text-lg">{formatMAD(optionTtc(data!, reco ?? 'sans_batterie'))}</span>
              <span class="text-lune-faint"> TTC</span>
            </p>
            {validity.fromBackend && validity.label && !validity.expired && (
              <p class="truncate text-xs text-lune-faint">Valable jusqu’au {validity.label}</p>
            )}
