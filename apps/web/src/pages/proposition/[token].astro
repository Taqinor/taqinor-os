      <!-- ── WJ32 · FAQ OBJECTIONS (4–5 questions fréquentes) ────────────────
           <details> par item : accordéon accessible sans JS, zéro CLS. -->
      <section class="mx-auto max-w-4xl px-5 pt-16 sm:px-8">
        <p class="tech-label rule-brass text-brass-300" data-i18n data-fr="Vos questions, nos réponses" data-en="Your questions, our answers" data-ar="أسئلتكم، وأجوبتنا">Vos questions, nos réponses</p>
        <div class="mt-5 space-y-3">
          {faq.map((item) => (
            <details class="cine-card rounded-xl p-5">
              <summary class="cursor-pointer text-sm font-bold text-lune" data-i18n data-fr={item.question} data-en={item.questionEn} data-ar={item.questionAr}>{item.question}</summary>
              <p class="mt-3 text-sm text-lune-soft" data-i18n data-fr={item.answer} data-en={item.answerEn} data-ar={item.answerAr}>{item.answer}</p>
            </details>
          ))}
        </div>
      </section>

      <!-- ── WJ14 · IMPACT ENVIRONNEMENTAL (CO₂ ≈ arbres) — clôture émotion ── -->
      {enviro && (
        <section class="mx-auto max-w-4xl px-5 pt-14 sm:px-8">
          <p class="tech-label rule-brass text-brass-300" data-i18n data-fr="Votre impact, concrètement" data-en="Your impact, in real terms" data-ar="أثركم، بالأرقام">Votre impact, concrètement</p>
          <div class="cine-card mt-5 rounded-2xl p-6 sm:p-8">
            <div class="grid gap-6 sm:grid-cols-2 sm:items-center">
              <div>
                <p class="fig lum text-4xl sm:text-5xl" dir="ltr">{formatNumber(enviro.co2TonnesPerYear, 1)} <span class="text-2xl text-lune-soft">t CO₂ / an</span></p>
                <p class="v2-body mt-2 text-sm text-lune-soft" data-i18n
                  data-fr={`évités chaque année — l’équivalent de ${formatNumber(enviro.trees)} arbres qui absorberaient ce CO₂.`}
                  data-en={`avoided every year — the equivalent of ${formatNumber(enviro.trees)} trees absorbing that much CO₂.`}
                  data-ar={`تُتجنَّب كل سنة — أي ما يعادل ${formatNumber(enviro.trees)} شجرة قادرة على امتصاص هذا الكربون.`}>
                  évités chaque année — l’équivalent de
                  <strong class="text-brass-300"> {formatNumber(enviro.trees)} arbres</strong> qui absorberaient ce CO₂.
                </p>
              </div>
              <div class="text-sm text-lune-faint">
                <p data-i18n
                  data-fr={`Calcul transparent : production estimée × ${formatNumber(enviro.kgPerKwh, 2)} kg CO₂/kWh (facteur d’émission du réseau marocain), ramené à raison de ${formatNumber(enviro.kgPerTreeYear)} kg CO₂ absorbés par arbre et par an.`}
                  data-en={`Transparent calculation: estimated production × ${formatNumber(enviro.kgPerKwh, 2)} kg CO₂/kWh (Moroccan grid emission factor), converted at ${formatNumber(enviro.kgPerTreeYear)} kg CO₂ absorbed per tree per year.`}
                  data-ar={`حساب شفاف: الإنتاج المقدّر × ${formatNumber(enviro.kgPerKwh, 2)} كلغ CO₂/kWh (معامل انبعاث الشبكة المغربية)، مقارنة بمعدل ${formatNumber(enviro.kgPerTreeYear)} كلغ CO₂ تمتصه الشجرة الواحدة سنوياً.`}>Calcul transparent : production estimée × {formatNumber(enviro.kgPerKwh, 2)} kg CO₂/kWh (facteur d’émission du réseau marocain), ramené à raison de {formatNumber(enviro.kgPerTreeYear)} kg CO₂ absorbés par arbre et par an.</p>
              </div>
            </div>
          </div>
        </section>
      )}

      <!-- ── WJ28 · SIGNATURE ZELLIGE (pivot narratif avant l'appel au contact) -->
      <ZelligeSignature
        line="Chaque chiffre de cette proposition est mesuré, pas promis."
        sub="L'étude d'abord. Le chantier ensuite."
      />

      <!-- ── WJ12/WJ29 · CONTACT AU MOINDRE DOUTE (avant la signature) ─────── -->
      {/* WJ29 — les trois boutons gardent leur lien instantané (wa.me / tel:)
          intact, ET notifient l'équipe en interne via le proxy same-origin
          /api/proposition-contact (dégrade toujours proprement — voir script
          ci-dessous). `data-contact-channel` pilote le canal envoyé. */}
      <section class="mx-auto max-w-4xl px-5 pt-14 sm:px-8" data-contact-token={token}>
        <div class="cine-card rounded-2xl p-6 sm:p-7">
          <p class="v2-body text-lune" data-i18n
            data-fr="Une question avant de signer ? Parlons-en — sans engagement, et sans appel commercial non sollicité."
            data-en="A question before signing? Let's talk — no obligation, and no unsolicited sales call."
            data-ar="سؤال قبل التوقيع؟ لنتحدث — بدون التزام، وبدون مكالمات تجارية غير مرغوبة.">
            Une question avant de signer ? Parlons-en — sans engagement, et sans appel commercial non sollicité.
          </p>
          <!-- WJ58 — promesse de délai honnête near la CTA de contact (WG9
               résolu par le fondateur, 2026-07-03 : « sous 1 h, 7j/7 »). Badge
               statique, jamais un compte à rebours. L'icône reste HORS du
               nœud data-i18n (le tri-node FR/EN/AR ne préserve le markup
               imbriqué que côté FR — l'icône disparaîtrait en EN/AR sinon). -->
          <p class="mt-2 flex items-center gap-1.5 text-sm text-lune-faint">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="flex-none text-ok-600">
              <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
            </svg>
            <span data-i18n
              data-fr="Réponse WhatsApp sous 1 h, 7j/7"
              data-en="WhatsApp reply within 1 h, 7 days a week"
              data-ar="رد واتساب خلال ساعة واحدة، 7 أيام على 7">
              Réponse WhatsApp sous 1 h, 7j/7
            </span>
          </p>
          <div class="mt-4 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
            <!-- WJ85 — chaque bouton porte désormais un prérempli WhatsApp
                 DISTINCT (whatsappLinkForIntent) : "Discuter" et "Poser une
                 question" partageaient auparavant le même waLink générique —
                 deux boutons identiques au point de décision de la page. -->
            <a
              href={waLinkDiscuss}
              target="_blank"
              rel="noopener noreferrer"
              data-contact-channel="whatsapp"
              class="btn-pill inline-flex items-center justify-center gap-2"
              style="background: #25d366; color: #062b14; border-color: #25d366"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Zm0 18.1h-.01a8.2 8.2 0 0 1-4.18-1.15l-.3-.18-3.11.82.83-3.04-.2-.31a8.2 8.2 0 0 1-1.26-4.37c0-4.54 3.7-8.23 8.24-8.23 2.2 0 4.27.86 5.83 2.42a8.18 8.18 0 0 1 2.41 5.82c0 4.54-3.7 8.23-8.23 8.23Zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.16.25-.64.81-.78.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.01-.38.11-.51.11-.11.25-.29.37-.43.13-.14.17-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.35-.77-1.85-.2-.48-.41-.42-.56-.43l-.48-.01c-.17 0-.43.06-.66.31-.23.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.57.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.68-1.18.21-.58.21-1.07.14-1.18-.06-.1-.22-.16-.47-.28Z"/>
              </svg>
              <span data-i18n data-fr="Discuter sur WhatsApp" data-en="Chat on WhatsApp" data-ar="الدردشة على واتساب">Discuter sur WhatsApp</span>
            </a>
            {callbackHref ? (
              <a href={callbackHref} data-contact-channel="rappel" class="btn-pill inline-flex items-center justify-center gap-2">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92Z"/>
                </svg>
                <span data-i18n data-fr="Demander un rappel" data-en="Request a callback" data-ar="طلب معاودة الاتصال">Demander un rappel</span>
              </a>
            ) : null}
            <a href={waLinkQuestion} target="_blank" rel="noopener noreferrer" data-contact-channel="question" class="btn-pill inline-flex items-center justify-center gap-2">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5Z"/>
              </svg>
              <span data-i18n data-fr="Poser une question" data-en="Ask a question" data-ar="طرح سؤال">Poser une question</span>
            </a>
          </div>
          <!-- WJ85 — invitation à la note vocale : canal WhatsApp natif, souvent
               plus rapide à envoyer qu'un texte long pour expliquer un doute. -->
          <p class="mt-3 text-sm text-lune-faint">
            <a href={waLinkVoice} target="_blank" rel="noopener noreferrer" data-contact-channel="voice" class="inline-flex items-center gap-1.5 underline-offset-2 hover:underline">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3Z"/>
                <path d="M19 10v2a7 7 0 0 1-14 0v-2M12 19v4M8 23h8"/>
              </svg>
              <span data-i18n
                data-fr="Plus simple à l’oral ? Envoyez-nous une note vocale sur WhatsApp."
                data-en="Easier to say than type? Send us a voice note on WhatsApp."
                data-ar="أسهل بصوتكم؟ أرسلوا لنا رسالة صوتية على واتساب.">
                Plus simple à l’oral ? Envoyez-nous une note vocale sur WhatsApp.
              </span>
            </a>
          </p>
          <p id="contact-confirm" class="mt-3 text-sm text-brass-300" role="status" aria-live="polite" hidden></p>
        </div>
      </section>

      <!-- ── WJ54 · « Demander une modification » — révision structurée ─────
           Gâté sur `ok` (données chargées) : rien ne s'affiche tant que la
           proposition elle-même n'est pas disponible (pas de coquille vide).
           Poste vers le MÊME proxy /api/proposition-contact que WJ29 ci-dessus
           (canal `revision` distinct) — aucun nouvel endpoint. -->
      {ok && (
        <section class="mx-auto max-w-4xl px-5 pt-8 sm:px-8" data-revision-token={token}>
          <div class="cine-card rounded-2xl p-6 sm:p-7">
            <p class="tech-label rule-brass text-brass-300" data-i18n
              data-fr="Demander une modification" data-en="Request a change" data-ar="طلب تعديل">
              Demander une modification
            </p>
            <p class="v2-body mt-3 text-lune-soft" data-i18n
              data-fr="Pas encore convaincu par cette version ? Dites-nous ce que vous aimeriez ajuster — sans engagement."
              data-en="Not quite convinced by this version? Tell us what you'd like to adjust — no obligation."
              data-ar="لستم مقتنعين بعد بهذه النسخة؟ أخبرونا بما ترغبون في تعديله — بدون التزام.">
              Pas encore convaincu par cette version ? Dites-nous ce que vous aimeriez ajuster — sans engagement.
            </p>
            <form id="revision-form" class="mt-4">
              <div class="flex flex-wrap gap-2" role="radiogroup" aria-label="Type de modification">
                <button type="button" data-revision-kind="kwc" aria-pressed="false" class="btn-pill revision-kind-btn px-3 py-1.5 text-sm">
                  <span data-i18n data-fr="Ajuster la puissance (kWc)" data-en="Adjust the system size (kWc)" data-ar="تعديل القدرة (kWc)">Ajuster la puissance (kWc)</span>
                </button>
                <button type="button" data-revision-kind="batterie" aria-pressed="false" class="btn-pill revision-kind-btn px-3 py-1.5 text-sm">
                  <span data-i18n data-fr="Changer l’option batterie" data-en="Change the battery option" data-ar="تغيير خيار البطارية">Changer l’option batterie</span>
                </button>
                <button type="button" data-revision-kind="autre" aria-pressed="false" class="btn-pill revision-kind-btn px-3 py-1.5 text-sm">
                  <span data-i18n data-fr="Autre" data-en="Other" data-ar="أخرى">Autre</span>
                </button>
              </div>
              <label for="revision-detail" class="mt-4 block text-sm text-lune-soft" data-i18n
                data-fr="Précisez votre demande (facultatif, obligatoire pour « Autre »)"
                data-en="Describe your request (optional, required for “Other”)"
                data-ar="اشرحوا طلبكم (اختياري، وإلزامي عند اختيار «أخرى»)">
                Précisez votre demande (facultatif, obligatoire pour « Autre »)
              </label>
              <textarea
                id="revision-detail"
                name="detail"
                rows="3"
                maxlength="2000"
                class="mt-2 w-full rounded-xl border border-white/15 bg-nuit-800/60 p-3 text-sm text-lune placeholder:text-lune-faint"
                data-i18n-placeholder
                data-placeholder-fr="Ex. : pourriez-vous étudier une version sans batterie ?"
                data-placeholder-en="E.g.: could you study a version without a battery?"
                data-placeholder-ar="مثال: هل يمكنكم دراسة نسخة بدون بطارية؟"
                placeholder="Ex. : pourriez-vous étudier une version sans batterie ?"
              ></textarea>
              <p id="revision-error" class="mt-2 text-sm text-alert-300" role="alert" hidden></p>
              <div class="mt-4 flex items-center gap-3">
                <button
                  type="submit"
                  id="revision-submit"
                  class="btn-pill inline-flex items-center justify-center gap-2"
                  style="background: var(--color-brass-400); color: var(--color-nuit); border-color: var(--color-brass-400)"
                >
                  <span id="revision-submit-label" data-i18n data-fr="Envoyer ma demande" data-en="Send my request" data-ar="إرسال طلبي">Envoyer ma demande</span>
                </button>
                <p id="revision-confirm" class="text-sm text-brass-300" role="status" aria-live="polite" hidden></p>
              </div>
            </form>
          </div>
        </section>
      )}

      <!-- ── WJ57 · CONFIANCE AU MOMENT DE SIGNER — juste au-dessus du bloc
           e-sign (pas seulement dans la section « Pourquoi nous faire
           confiance » plus haut). Un slot vidéo est réservé pour quand WG6
           fournira de vrais témoignages filmés (no-op tant qu'absent — MÊME
           discipline que REAL_FOUNDER_QUOTE_AVAILABLE) ; en attendant, repli
           texte sur le même avis client réel (hasTestimonials()) que
           <TestimonialCarousel/> plus haut, jamais un second avis fabriqué.
           Les badges certifications/garanties (mêmes FAITS que CertLogoRow
           plus haut) sont TOUJOURS affichés ici, qu'un témoignage soit
           disponible ou non — ce sont des faits vérifiables, pas du contenu
           gated. -->
      <section class="mx-auto max-w-4xl px-5 pt-14 sm:px-8">
        <div class="cine-card rounded-2xl p-6 sm:p-7">
          {REAL_TESTIMONIAL_VIDEO_AVAILABLE ? (
            <!-- Slot vidéo réservé (WG6) : à remplir par Reda avec le vrai
                 témoignage filmé le jour où il devient disponible. -->
            <div class="video-testimonial-slot" data-testimonial-video></div>
          ) : signTestimonial ? (
            <blockquote class="v2-body text-lune">
              &ldquo;{signTestimonial.quote}&rdquo;
              <footer class="mt-3 text-sm text-lune-faint not-italic">
                <span class="font-bold text-lune">{signTestimonial.name}</span> · {signTestimonial.city} · {signTestimonial.system}
              </footer>
            </blockquote>
          ) : null}
          <div class={signTestimonial || REAL_TESTIMONIAL_VIDEO_AVAILABLE ? 'mt-5 border-t border-white/10 pt-5' : ''}>
            <CertLogoRow />
          </div>
        </div>
      </section>

      <!-- ── SIGNATURE EN LIGNE ───────────────────────────────────────────── -->
      <section id="signer" class="mx-auto max-w-4xl px-5 pt-16 sm:px-8">
        <div class="cine-card rounded-2xl p-6 sm:p-8">
          <!-- État confirmé (caché par défaut, affiché après signature ou si déjà accepté).
               WJ78 — le moment le plus « haute intention » de toute l'entreprise ne
               doit plus se contenter de démasquer un paragraphe : un accusé visuel
               (sceau ✓, reduced-motion-safe), l'écho de la signature manuscrite du
               client (ou un sceau textuel si non dessinée), le PDF et « Et après ? »
               vivent directement ICI, pas seulement plus bas dans la page. -->
          <div id="sign-success" class="result-fade" hidden>
            <div class="success-seal" aria-hidden="true">
              <svg viewBox="0 0 52 52" width="52" height="52" fill="none">
                <circle class="success-seal-ring" cx="26" cy="26" r="24" stroke="var(--color-brass-400)" stroke-width="2"/>
                <path class="success-seal-check" d="M15 27l7 7 16-16" stroke="var(--color-brass-400)" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
              </svg>
            </div>
            <p class="fig text-2xl text-brass-300" data-i18n data-fr="Devis accepté ✓" data-en="Quote accepted ✓" data-ar="تمت الموافقة على العرض ✓">Devis accepté ✓</p>
            <p class="v2-body mt-2" data-i18n
              data-fr="Merci — votre acceptation est bien enregistrée. Votre conseiller Taqinor revient vers vous très vite."
              data-en="Thank you — your acceptance has been recorded. Your Taqinor advisor will be in touch very soon."
              data-ar="شكراً — تم تسجيل موافقتكم بنجاح. سيتواصل معكم مستشار تاقينور قريباً جداً.">
              Merci <span id="sign-success-name" class="text-lune"></span> — votre acceptation est bien enregistrée.
              Votre conseiller Taqinor revient vers vous très vite.
            </p>
            <!-- WJ79 — « Réf. » passe par le data-i18n tri-node (comme #sign-stamp
                 plus bas) au lieu d'un texte français figé : sans ce wrapper, la
                 mention restait en FR même en mode arabe/anglais. Le suffixe
                 (#sign-success-time) est lui déjà une busy-label enregistrée
                 (renderSuccessTime), qui utilise localizedStamp → un timestamp
                 ar-MA/en-GB/fr-MA — jamais un fr-FR figé. -->
            <p id="sign-success-stamp" class="mt-3 text-sm text-lune-faint">
              <span data-i18n data-fr="Réf." data-en="Ref." data-ar="المرجع">Réf.</span> <span dir="ltr">{reference}</span><span id="sign-success-time"></span>.
            </p>

            <!-- WJ78 — écho de l'artefact du client : la signature manuscrite si
                 dessinée (image capturée par le pad, WJ11), sinon un sceau textuel
                 « signature enregistrée ✓ » — jamais un vide après un geste aussi
                 engageant. -->
            <div class="mt-5 rounded-xl border border-white/10 bg-nuit-800/60 p-4">
              <p class="tech-label text-lune-faint" data-i18n data-fr="Votre signature" data-en="Your signature" data-ar="توقيعكم">Votre signature</p>
              <img id="sign-success-echo-img" class="mt-2 h-16 w-auto" style="filter: invert(1) brightness(1.4);" alt="" hidden />
              <p id="sign-success-echo-seal" class="mt-2 fig text-lg text-lune" data-i18n
                data-fr="Signature enregistrée ✓" data-en="Signature recorded ✓" data-ar="تم تسجيل التوقيع ✓">
                Signature enregistrée ✓
              </p>
            </div>

            <!-- WJ78 — PDF + « Et après ? » directement dans le bloc de succès :
                 le client n'a plus besoin de chercher plus bas dans la page au
                 moment précis où il vient de s'engager. -->
            <div class="mt-6 flex flex-col gap-3 sm:flex-row">
              <a
                href={pdfUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="btn-pill glow-hero inline-flex items-center justify-center gap-2"
                style="background: var(--color-brass-400); color: var(--color-nuit); border-color: var(--color-brass-400)"
              >
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                  <polyline points="7 10 12 15 17 10" />
                  <line x1="12" y1="15" x2="12" y2="3" />
                </svg>
                <span data-i18n data-fr="Télécharger le devis (PDF)" data-en="Download the quote (PDF)" data-ar="تحميل العرض (PDF)">Télécharger le devis (PDF)</span>
              </a>
              <a href="#etapes-suivantes" class="btn-pill inline-flex items-center justify-center gap-2">
                <span data-i18n data-fr="Voir « Et après ? »" data-en="See “What happens next?”" data-ar="ماذا بعد؟">Voir « Et après ? »</span>
              </a>
            </div>
            <div class="mt-5 border-t border-white/10 pt-5">
              <p class="tech-label rule-brass text-brass-300" data-i18n data-fr="Et après ?" data-en="What happens next?" data-ar="ماذا بعد؟">Et après ?</p>
              <ol class="mt-4 grid gap-3 sm:grid-cols-2">
                {steps.map((s, i) => (
                  <li class="rounded-xl border border-white/10 bg-nuit-800/40 p-4">
                    <p class="fig text-brass-300">{i + 1}.</p>
                    <p class="mt-1 text-sm font-bold text-lune" data-i18n data-fr={s.title} data-en={s.titleEn} data-ar={s.titleAr}>{s.title}</p>
                    <p class="mt-1 text-sm text-lune-soft" data-i18n data-fr={s.body} data-en={s.bodyEn} data-ar={s.bodyAr}>{s.body}</p>
                  </li>
                ))}
              </ol>
            </div>

            <!-- ── W343 · « Partager avec un proche » (parrainage) ────────────
                 DISTINCT du partage WJ56 plus haut sur la page (qui partage CE
                 devis avec un co-décideur du MÊME foyer, avant signature) : ici
                 le client vient de SIGNER — le moment de satisfaction maximale
                 — et partage le programme de parrainage (/parrainage, W338)
                 avec un PROCHE différent. Lien tagué (utm_campaign = référence
                 de son devis) : zéro changement backend, même convention que
                 /parrainage.astro. -->
            <div class="mt-5 border-t border-white/10 pt-5">
              <p class="tech-label rule-brass text-brass-300" data-i18n
                data-fr="Partager avec un proche" data-en="Share with someone close to you" data-ar="شاركوا مع أحد المقربين">
                Partager avec un proche
              </p>
              <p class="v2-body mt-2 text-sm text-lune-soft" data-i18n
                data-fr="Un proche envisage aussi le solaire ? Partagez votre lien de parrainage — Taqinor vous en dit merci quand son projet se concrétise."
                data-en="Know someone else considering solar? Share your referral link — Taqinor says thank you once their project goes through."
                data-ar="هل يفكر أحد المقربين أيضاً في الطاقة الشمسية؟ شاركوا رابط الإحالة الخاص بكم — تشكركم تاقينور عندما يتحقق مشروعه.">
                Un proche envisage aussi le solaire ? Partagez votre lien de parrainage — Taqinor vous en dit merci quand son projet se concrétise.
              </p>
              <a
                id="referral-share-whatsapp"
                href={waLinkReferral}
                target="_blank"
                rel="noopener noreferrer"
                class="btn-pill mt-3 inline-flex items-center justify-center gap-2"
              >
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Zm0 18.1h-.01a8.2 8.2 0 0 1-4.18-1.15l-.3-.18-3.11.82.83-3.04-.2-.31a8.2 8.2 0 0 1-1.26-4.37c0-4.54 3.7-8.23 8.24-8.23 2.2 0 4.27.86 5.83 2.42a8.18 8.18 0 0 1 2.41 5.82c0 4.54-3.7 8.23-8.23 8.23Zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.16.25-.64.81-.78.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.01-.38.11-.51.11-.11.25-.29.37-.43.13-.14.17-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.35-.77-1.85-.2-.48-.41-.42-.56-.43l-.48-.01c-.17 0-.43.06-.66.31-.23.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.57.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.68-1.18.21-.58.21-1.07.14-1.18-.06-.1-.22-.16-.47-.28Z"/>
                </svg>
                <span data-i18n data-fr="Partager avec un proche" data-en="Share with someone close to you" data-ar="شاركوا مع أحد المقربين">
                  Partager avec un proche
                </span>
              </a>
            </div>
          </div>

          <!-- ── WJ82 · États explicites d'une offre morte (refusée/expirée/retirée) —
               masque le formulaire de signature et affiche un message localisé
               clair à la place, jamais un formulaire signable sur une offre morte. -->
          {offerState !== 'live' && offerState !== 'accepted' && (
            <div id="sign-dead-offer" class="result-fade">
              <p class="fig text-xl text-alert-300" data-i18n
                data-fr={offerState === 'expired' ? 'Offre échue' : 'Devis non disponible à la signature'}
                data-en={offerState === 'expired' ? 'Offer expired' : 'Quote not available for signature'}
                data-ar={offerState === 'expired' ? 'العرض منتهي' : 'العرض غير متاح للتوقيع'}>
                {offerState === 'expired' ? 'Offre échue' : 'Devis non disponible à la signature'}
              </p>
              <p class="v2-body mt-2" data-i18n
                data-fr={
                  offerState === 'expired'
                    ? 'La date de validité de cette proposition est dépassée. Demandez un devis actualisé à votre conseiller Taqinor — sans frais, en quelques minutes.'
                    : offerState === 'refused'
                      ? 'Ce devis a été marqué comme refusé. Si c’est une erreur ou si votre projet a évolué, contactez votre conseiller Taqinor pour une nouvelle proposition.'
                      : 'Ce devis a été retiré. Contactez votre conseiller Taqinor pour toute question.'
                }
                data-en={
                  offerState === 'expired'
                    ? 'This proposal\'s validity date has passed. Ask your Taqinor advisor for an updated quote — free of charge, in a few minutes.'
                    : offerState === 'refused'
                      ? 'This quote has been marked as declined. If this is an error or your project has changed, contact your Taqinor advisor for a new proposal.'
                      : 'This quote has been withdrawn. Contact your Taqinor advisor with any questions.'
                }
                data-ar={
                  offerState === 'expired'
                    ? 'تاريخ صلاحية هذا العرض قد انتهى. اطلبوا من مستشاركم في تاقينور عرضاً محدّثاً — مجاناً وفي دقائق معدودة.'
                    : offerState === 'refused'
                      ? 'تم رفض هذا العرض. إن كان هذا خطأً أو تغيّر مشروعكم، تواصلوا مع مستشاركم في تاقينور للحصول على عرض جديد.'
                      : 'تم سحب هذا العرض. تواصلوا مع مستشاركم في تاقينور لأي سؤال.'
                }>
                {offerState === 'expired'
                  ? 'La date de validité de cette proposition est dépassée. Demandez un devis actualisé à votre conseiller Taqinor — sans frais, en quelques minutes.'
                  : offerState === 'refused'
                    ? 'Ce devis a été marqué comme refusé. Si c’est une erreur ou si votre projet a évolué, contactez votre conseiller Taqinor pour une nouvelle proposition.'
                    : 'Ce devis a été retiré. Contactez votre conseiller Taqinor pour toute question.'}
              </p>
              <a
                href={waLink}
                target="_blank"
                rel="noopener noreferrer"
                class="btn-pill mt-5 inline-flex items-center justify-center gap-2"
                style="background: var(--color-brass-400); color: var(--color-nuit); border-color: var(--color-brass-400)"
                data-i18n
                data-fr="Demander un devis actualisé"
                data-en="Request an updated quote"
                data-ar="طلب عرض محدّث"
              >
                Demander un devis actualisé
              </a>
            </div>
          )}

          <!-- Formulaire de signature — masqué si l'offre est morte (WJ82) -->
          <form id="sign-form" novalidate hidden={offerState !== 'live'}>
            <!-- ── WJ44 · Bandeau d'offre échue, directement au-dessus du formulaire
                 de signature — le client ne doit jamais découvrir l'expiration
                 seulement après avoir rempli tout le formulaire. -->
            {offerState === 'expired' && (
              <div class="mb-6 rounded-xl border border-alert-300/40 bg-alert-300/10 p-4">
                <p class="text-sm font-bold text-alert-300" data-i18n
                  data-fr="Offre échue — demandez un devis actualisé"
                  data-en="Offer expired — request an updated quote"
                  data-ar="العرض منتهي — اطلبوا عرضاً محدّثاً">
                  Offre échue — demandez un devis actualisé
                </p>
                <p class="mt-1 text-xs text-lune-soft" data-i18n
                  data-fr="La date de validité de cette proposition est dépassée. Vous pouvez toujours contacter votre conseiller Taqinor pour une réactualisation rapide."
                  data-en="This proposal's validity date has passed. You can still contact your Taqinor advisor for a quick refresh."
                  data-ar="تاريخ صلاحية هذا العرض قد انتهى. لا يزال بإمكانكم التواصل مع مستشاركم في تاقينور لتحديث سريع.">
                  La date de validité de cette proposition est dépassée. Vous pouvez toujours contacter
                  votre conseiller Taqinor pour une réactualisation rapide.
                </p>
              </div>
            )}
            <p class="tech-label rule-brass text-brass-300" data-i18n data-fr="Signer en ligne" data-en="Sign online" data-ar="التوقيع إلكترونياً">Signer en ligne</p>
            <h2 class="display mt-3 text-2xl text-lune" data-i18n data-fr="Bon pour accord" data-en="Approved" data-ar="موافقة نهائية">Bon pour accord</h2>
            <p class="v2-body mt-2" data-i18n
              data-fr="Validez votre proposition en quelques secondes. Vous recevrez ensuite la confirmation de votre conseiller."
              data-en="Approve your proposal in a few seconds. You'll then receive confirmation from your advisor."
              data-ar="أكّدوا عرضكم في ثوانٍ معدودة. ستصلكم بعدها رسالة تأكيد من مستشاركم.">
              Validez votre proposition en quelques secondes. Vous recevrez ensuite la confirmation
              de votre conseiller.
            </p>

            <!-- WJ58 — promesse de délai honnête near la CTA de signature
                 (WG9 résolu, 2026-07-03 : « sous 1 h, 7j/7 »). Icône hors du
                 nœud data-i18n (voir note plus haut sur le tri-node). -->
            <p class="mt-2 flex items-center gap-1.5 text-sm text-lune-faint">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="flex-none text-ok-600">
                <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
              </svg>
              <span data-i18n
                data-fr="Réponse WhatsApp sous 1 h, 7j/7"
                data-en="WhatsApp reply within 1 h, 7 days a week"
                data-ar="رد واتساب خلال ساعة واحدة، 7 أيام على 7">
                Réponse WhatsApp sous 1 h, 7j/7
              </span>
            </p>

            {twoOptions && (
              <fieldset class="mt-6">
                <legend class="tech-label text-lune-faint" data-i18n data-fr="Votre choix" data-en="Your choice" data-ar="اختياركم">Votre choix</legend>
                <div class="mt-3 grid gap-3 sm:grid-cols-2">
                  {options.map((opt) => (
                    <label class="flex cursor-pointer items-center gap-3 rounded-xl border border-white/12 p-4 text-sm has-[:checked]:border-brass-400">
                      <input
                        type="radio"
                        name="option"
                        value={opt}
                        checked={opt === preselect}
                        class="h-4 w-4 accent-[var(--color-brass-400)]"
                      />
                      <span class="text-lune">
                        <span data-i18n data-fr={optionLabel(opt)} data-en={optionLabelEn(opt)} data-ar={optionLabelAr(opt)}>{optionLabel(opt)}</span>
                        {hasRealPrice(data!, opt) ? (
                          <span class="block text-lune-faint" dir="ltr">{formatMAD(optionTtc(data!, opt))} TTC</span>
                        ) : (
                          <span class="block text-lune-faint" data-i18n
                            data-fr="Prix communiqué par votre conseiller"
                            data-en="Price provided by your advisor"
                            data-ar="السعر يُبلَّغ من طرف مستشاركم">
                            Prix communiqué par votre conseiller
                          </span>
                        )}
                      </span>
                    </label>
                  ))}
                </div>
              </fieldset>
            )}

            <div class="mt-6">
              <label for="sign-nom" class="tech-label text-lune-faint" data-i18n data-fr="Votre nom complet" data-en="Your full name" data-ar="اسمكم الكامل">Votre nom complet</label>
              <input
                id="sign-nom"
                name="nom"
                type="text"
                autocomplete="name"
                required
                class="mt-2 w-full rounded-xl border border-white/15 bg-nuit-800 px-4 py-3 text-lune placeholder:text-lune-faint"
                placeholder="Prénom Nom"
              />
            </div>

            <!-- WJ11/WJ101 · SIGNATURE MANUSCRITE (canvas natif, tactile + souris)
                 — le canvas lui-même reste POINTEUR-SEUL (dessiner un trait au
                 clavier n'a pas de sens ergonomique), mais WJ101 rend l'étape
                 elle-même keyboard-OPÉRABLE : le canvas est focusable
                 (tabindex, annonce son statut facultatif au focus) et un
                 bouton dédié permet d'ignorer explicitement le dessin — le
                 flux légal fonctionne déjà uniquement par nom + cases à
                 cocher (voir plus bas), donc « ignorer » ne bloque jamais la
                 signature électronique. ── -->
            <div class="mt-6">
              <div class="flex items-baseline justify-between gap-3">
                <label for="sign-pad" class="tech-label text-lune-faint" data-i18n data-fr="Votre signature" data-en="Your signature" data-ar="توقيعكم">Votre signature</label>
                <button
                  id="sign-clear"
                  type="button"
                  class="py-2 px-3 text-xs text-lune-faint underline-offset-2 hover:underline"
                  data-i18n data-fr="Effacer" data-en="Clear" data-ar="مسح"
                >Effacer</button>
              </div>
              <div class="sign-pad-wrap mt-2 rounded-xl border border-white/15 bg-nuit-800">
                <canvas
                  id="sign-pad"
                  tabindex="0"
                  width="640"
                  height="180"
                  class="sign-pad block w-full touch-none rounded-xl"
                  role="img"
                  aria-label="Zone de signature manuscrite — dessinez votre signature au doigt ou à la souris. Facultative : utilisez le bouton « Signature non nécessaire » si vous êtes au clavier."
                  data-aria-label-fr="Zone de signature manuscrite — dessinez votre signature au doigt ou à la souris. Facultative : utilisez le bouton « Signature non nécessaire » si vous êtes au clavier."
                  data-aria-label-en="Handwritten signature area — draw your signature with your finger or mouse. Optional: use the “Signature not needed” button if you're on a keyboard."
                  data-aria-label-ar="منطقة التوقيع اليدوي — ارسموا توقيعكم بإصبعكم أو بالفأرة. اختيارية: استخدموا زر «لا حاجة للتوقيع» إذا كنتم تستخدمون لوحة المفاتيح."
                ></canvas>
              </div>
              <div class="mt-2 flex flex-wrap items-center justify-between gap-2">
                <p class="text-xs text-lune-faint" data-i18n
                  data-fr="Dessinez votre signature ci-dessus (facultatif mais recommandé). Votre nom et votre accord ci-dessous valent signature électronique (loi 53-05)."
                  data-en="Draw your signature above (optional but recommended). Your name and your agreement below constitute an electronic signature (law 53-05)."
                  data-ar="ارسموا توقيعكم أعلاه (اختياري لكن مستحسن). اسمكم وموافقتكم أدناه بمثابة توقيع إلكتروني (القانون 53-05).">Dessinez votre signature ci-dessus (facultatif mais recommandé). Votre nom et votre accord ci-dessous valent signature électronique (loi 53-05).</p>
                <!-- WJ101 — affordance clavier explicite : un visiteur au
                     clavier n'a pas à deviner qu'il peut passer cette étape
                     (le canvas ne peut pas se "remplir" au clavier). Cliquer
                     ce bouton avance simplement le focus vers le champ nom —
                     aucun état à gérer, la signature restait déjà facultative
                     côté backend/validation. -->
                <button
                  type="button"
                  id="sign-pad-skip"
                  class="flex-none py-2 px-3 text-xs font-semibold text-brass-300 underline-offset-2 hover:underline"
                  data-i18n data-fr="Signature non nécessaire — passer au nom" data-en="Signature not needed — skip to name" data-ar="لا حاجة للتوقيع — الانتقال إلى الاسم"
                >Signature non nécessaire — passer au nom</button>
              </div>
            </div>

            <!-- ── WJ87 · SIGNER AU NOM DU FOYER (optionnel) ─────────────────────
                 Le MRE qui signe pour ses parents, ou tout couple qui décide à
                 distance, n'avait aucun moyen honnête d'enregistrer une décision
                 déléguée/conjointe. Champ FACULTATIF, additif dans le payload
                 d'acceptation (le backend qui l'ignore continue de fonctionner
                 exactement comme avant) — formulation volontairement générique
                 (le libellé légal précis WG16 est encore en attente). -->
            <div class="mt-5">
              <label for="sign-on-behalf-of" class="tech-label text-lune-faint" data-i18n
                data-fr="Je signe au nom de (optionnel)"
                data-en="I am signing on behalf of (optional)"
                data-ar="أوقّع نيابة عن (اختياري)">
                Je signe au nom de (optionnel)
              </label>
              <input
                id="sign-on-behalf-of"
                name="on_behalf_of"
                type="text"
                autocomplete="off"
                class="mt-2 w-full rounded-xl border border-white/15 bg-nuit-800 px-4 py-3 text-lune placeholder:text-lune-faint"
                data-i18n-placeholder
                data-placeholder-fr="Ex. : mes parents, mon foyer"
                data-placeholder-en="E.g.: my parents, my household"
                data-placeholder-ar="مثال: والديّ، عائلتي"
                placeholder="Ex. : mes parents, mon foyer"
              />
              <p class="mt-1.5 text-xs text-lune-faint" data-i18n
                data-fr="Si vous signez pour le compte du propriétaire ou de votre foyer, précisez-le ici — votre nom ci-dessus reste le signataire enregistré."
                data-en="If you are signing on behalf of the owner or your household, note it here — your name above remains the recorded signatory."
                data-ar="إن كنتم توقّعون نيابة عن المالك أو عائلتكم، وضّحوا ذلك هنا — يبقى اسمكم أعلاه هو الموقّع المسجَّل.">
                Si vous signez pour le compte du propriétaire ou de votre foyer, précisez-le ici —
                votre nom ci-dessus reste le signataire enregistré.
              </p>
            </div>

            <label class="mt-5 flex cursor-pointer items-start gap-3 text-sm">
              <input id="sign-accord" name="accord" type="checkbox" required class="mt-1 h-4 w-4 accent-[var(--color-brass-400)]" />
              <span class="text-lune-soft" data-i18n
                data-fr="Je certifie « Bon pour accord » et j’accepte cette proposition aux conditions indiquées ci-dessus."
                data-en="I certify \"Approved\" and I accept this proposal under the conditions indicated above."
                data-ar="أشهد بـ«الموافقة النهائية» وأقبل هذا العرض وفق الشروط المذكورة أعلاه.">
                Je certifie « <strong class="text-lune">Bon pour accord</strong> » et j’accepte cette proposition
                aux conditions indiquées ci-dessus.
              </span>
            </label>

            <label class="mt-3 flex cursor-pointer items-start gap-3 text-sm">
              <input id="sign-consent" name="consent" type="checkbox" required class="mt-1 h-4 w-4 accent-[var(--color-brass-400)]" />
              <!-- W318 — précise que l'image de la signature dessinée ci-dessus
                   (quand elle est tracée) est elle aussi enregistrée avec le
                   nom, la date et l'heure — cohérent avec ce que le code
                   envoie réellement (signature_data_url, cf. plus bas dans ce
                   fichier) et avec la politique de confidentialité (W318). -->
              <span class="text-lune-soft" data-i18n
                data-fr="J’accepte de signer électroniquement cette proposition. Mon nom, l’image de ma signature dessinée ci-dessus (si tracée), et la date et l’heure de signature sont enregistrés avec mon accord."
                data-en="I agree to electronically sign this proposal. My name, the image of my signature drawn above (if drawn), and the date and time of signature are recorded with my consent."
                data-ar="أوافق على التوقيع إلكترونياً على هذا العرض. يتم تسجيل اسمي وصورة توقيعي المرسوم أعلاه (إن رُسم) وتاريخ ووقت التوقيع مع موافقتي.">
                J’accepte de <strong class="text-lune">signer électroniquement</strong> cette proposition.
                Mon nom, l’image de ma signature dessinée ci-dessus (si tracée), et la date et l’heure de
                signature sont enregistrés avec mon accord.
              </span>
            </label>

            <!-- Récapitulatif horodaté (réf + date/heure côté client) — le texte
                 initial (data-i18n) est le rendu AVANT JS ; dès l'hydratation,
                 renderStamp() (WJ42, script de fin de page) prend le relais et
                 régénère ce <p> ENTIER dans la langue courante à chaque bascule. -->
            <p id="sign-stamp" class="mt-4 text-xs text-lune-faint">
              <span data-i18n data-fr="Réf." data-en="Ref." data-ar="المرجع">Réf.</span> <span dir="ltr">{reference}</span> · <span data-i18n data-fr="l’horodatage de votre signature s’affichera ici." data-en="your signature's timestamp will appear here." data-ar="سيظهر توقيت توقيعكم هنا.">l’horodatage de votre signature s’affichera ici.</span>
            </p>

            <!-- WJ108 — étape OTP LATENTE : le backend porte un toggle
                 (ESIGN_OTP_ENABLED) qui, une fois activé côté ERP, exige un
                 code de confirmation avant l'acceptation — sans ce bloc web,
                 flipper ce toggle aurait BRIQUÉ toute signature publique (le
                 backend renvoie une erreur qu'aucun champ ne pouvait
                 satisfaire). Ce bloc reste MASQUÉ et n'affecte RIEN tant que
                 le toggle est OFF (comportement d'aujourd'hui, inchangé) : il
                 n'apparaît QUE si la réponse d'acceptation signale
                 explicitement un besoin d'OTP (isOtpRequiredDetail,
                 lib/proposition.ts), jamais de manière proactive. -->
            <div id="sign-otp-block" hidden class="mt-4 border border-brass-400/40 bg-brass-400/10 p-4">
              <label for="sign-otp-code" class="tech-label text-brass-300" data-i18n
                data-fr="Code de confirmation" data-en="Confirmation code" data-ar="رمز التأكيد">
                Code de confirmation
              </label>
              <p class="mt-1 text-xs text-lune-soft" data-i18n
                data-fr="Pour finaliser votre signature, saisissez le code à 6 chiffres envoyé par WhatsApp ou e-mail."
                data-en="To finalize your signature, enter the 6-digit code sent by WhatsApp or email."
                data-ar="لإتمام توقيعكم، أدخلوا الرمز المكون من 6 أرقام المُرسل عبر واتساب أو البريد الإلكتروني.">
                Pour finaliser votre signature, saisissez le code à 6 chiffres envoyé par WhatsApp ou e-mail.
              </p>
              <div class="mt-3 flex flex-wrap items-center gap-2">
                <input id="sign-otp-code" name="otp_code" type="text" inputmode="numeric" autocomplete="one-time-code"
                  maxlength="6" placeholder="123456"
                  class="w-32 border border-white/15 bg-nuit-800 px-3 py-2.5 text-base tracking-widest text-white outline-none focus:border-brass-400" />
                <button type="button" id="sign-otp-request"
                  class="py-2.5 px-4 text-sm font-semibold text-brass-300 underline-offset-2 hover:underline" data-i18n
                  data-fr="Envoyer le code" data-en="Send the code" data-ar="إرسال الرمز">
