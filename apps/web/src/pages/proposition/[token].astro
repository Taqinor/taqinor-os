  }
  @keyframes seal-check-draw {
    to { stroke-dashoffset: 0; opacity: 1; }
  }

  /* WJ84 — page imprimable propre. Ctrl-P est un réflexe naturel sur une
     proposition ; sans ces règles, le chrome flottant (bascule langue, CTA
