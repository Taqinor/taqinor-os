---
/**
 * /proposition/<token> — PROPOSITION CLIENT EN LIGNE (W116 + W117).
 *
 * La belle page « UI » que TAQINOR envoie au client (≠ PDF). Rendu côté serveur
 * (prerender=false) : le frontmatter lit la proposition depuis l'endpoint backend
 * public/token, et la page affiche un devis premium responsive + une signature en
 * ligne (CTA collant « Signer en ligne »). La signature passe par le proxy
 * same-origin /api/proposition-accept — le navigateur n'appelle jamais le backend
 * en cross-origin. Aucun prix d'achat / marge n'est jamais affiché (le backend ne
 * les envoie pas). noindex=true : page privée et tokenisée.
 *
 * Design : langage v2 (« cinéma du chantier »). Bleu Majorelle dominant, laiton
 * (.lum / CTA) réservé aux chiffres clés et au bouton principal, encres lune,
 * Archivo / Hanken. Zéro CLS, prefers-reduced-motion respecté, contraste AA.
 */
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import {
  type ProposalResponse,
  type OptionKey,
  formatMAD,
  formatNumber,
  formatPayback,
  hasTwoOptions,
  recommendedOption,
  optionTtc,
  optionItems,
  optionTotaux,
  optionLabel,
  defaultSelectedOption,
  isAccepted,
  proposalEndpoint,
  proposalPdfEndpoint,
  hasProductionSeries,
  resolveValidity,
  savingsHeadline,
  environmentalImpact,
  financingComparison,
  whatsappLink,
  parseRoofLayout,
  buildViewerModel,
  zoneAnnotations,
  walkthroughSteps,
} from '../../lib/proposition';
import { renderYearCurve } from '../../lib/proposalCurve';
import { renderProposalChart, resolveSeries } from '../../lib/proposalChart';

const API_BASE = (import.meta.env.PUBLIC_API_BASE as string | undefined) ?? 'https://api.taqinor.ma';
const { token } = Astro.params as { token: string };

// ── Lecture serveur de la proposition ────────────────────────────────────────
let data: ProposalResponse | null = null;
let errorDetail: string | null = null;
let httpStatus = 200;

if (!token || !token.trim()) {
  httpStatus = 404;
  errorDetail = 'Ce lien de proposition est introuvable ou a expiré.';
} else {
  try {
    const res = await fetch(proposalEndpoint(API_BASE, token), {
      headers: { accept: 'application/json' },
    });
    httpStatus = res.status;
    if (res.ok) {
      data = (await res.json()) as ProposalResponse;
    } else {
      let detail = '';
      try {
        const body = (await res.json()) as { detail?: string };
        detail = typeof body.detail === 'string' ? body.detail : '';
      } catch {
        detail = '';
      }
      errorDetail =
        detail ||
        (res.status === 404
          ? 'Ce lien de proposition est introuvable ou a expiré.'
          : 'Cette proposition n’est pas accessible pour le moment.');
    }
  } catch {
    httpStatus = 502;
    errorDetail = 'Proposition momentanément indisponible. Veuillez réessayer dans un instant.';
  }
}

// La page renvoie 404 quand le token est invalide/expiré : propre pour les bots
// comme pour les humains (Layout est de toute façon noindex).
if (!data && (httpStatus === 404 || httpStatus === 200)) {
  Astro.response.status = httpStatus === 200 ? 404 : httpStatus;
} else if (!data) {
  Astro.response.status = httpStatus;
}

// ── Préparation des données d'affichage (uniquement si OK) ───────────────────
const ok = !!data;
const q = data?.quote;
const twoOptions = ok ? hasTwoOptions(data!) : false;
const reco: OptionKey | null = ok ? recommendedOption(data!) : null;
const accepted = ok ? isAccepted(data!) : false;
const preselect: OptionKey | null = ok ? defaultSelectedOption(data!) : null;

const roofImg = data?.roof_image_url ?? null;
const clientName = data?.client_name || q?.client_name || 'Client';
const reference = data?.reference || q?.ref || '';
const proposalDate = data?.date || q?.date || '';

// Options à présenter (une ou deux), dans l'ordre Sans → Avec.
const options: OptionKey[] = ok
  ? twoOptions
    ? ['sans_batterie', 'avec_batterie']
    : q?.totaux_avec && !q?.totaux_sans
      ? ['avec_batterie']
      : ['sans_batterie']
  : [];

// Bloc énergie/économies (résidentiel/industriel). Pompage n'a pas ces champs.
const puissance = q?.puissance_kwc ?? null;
const nbPanneaux = q?.nb_panneaux ?? null;
const wattPanneau = q?.watt_par_panneau ?? null;
const prodKwh = q?.prod_kwh ?? null;
const ecoSans = q?.eco_s_ann ?? null;
const ecoAvec = q?.eco_a_ann ?? null;
const paybackSans = formatPayback(q?.roi_s);
const paybackAvec = formatPayback(q?.roi_a);
// Économie / payback « phares » : ceux de l'option recommandée.
const ecoHero = reco === 'avec_batterie' ? (ecoAvec ?? ecoSans) : (ecoSans ?? ecoAvec);
const paybackHero = reco === 'avec_batterie' ? (paybackAvec ?? paybackSans) : (paybackSans ?? paybackAvec);

const instLabel =
  q?.inst_type === 'agricole'
    ? 'Pompage solaire'
    : q?.inst_type === 'industriel' || q?.inst_type === 'commercial'
      ? 'Autoconsommation'
      : q?.inst_type
        ? String(q.inst_type)
        : 'Installation solaire';

// ── P2 — Graphe production estimée vs consommation (depuis les tableaux Q6) ──
// On ne dessine QUE les chiffres backend ; tableaux vides/absents → bloc masqué.
const chartSeries = ok ? resolveSeries(data?.monthly_production, data?.monthly_consumption) : { mode: 'none' as const, production: null, consumption: null };
const chartSvg = ok && chartSeries.mode !== 'none'
  ? renderProposalChart(data?.monthly_production, data?.monthly_consumption)
  : '';
const showChart = ok && hasProductionSeries(data!) && chartSvg.length > 0;
const chartHasConso = chartSeries.mode === 'comparison';

// ── WJ16 — Courbe journalière production vs consommation (lever → coucher) ────
// Calée sur la production annuelle RÉELLE backend si présente, sinon « année
// type » clairement libellée. Le visuel le plus persuasif ne disparaît jamais.
const dailyCurve = ok ? renderYearCurve(prodKwh) : { svg: '', hasRealScale: false };

// ── WJ15 — Fenêtre de validité honnête (date backend réelle, jamais inventée) ─
const validity = ok ? resolveValidity(data!) : { label: null, fromBackend: false, expired: false };

// ── WJ9 — Argent dans le temps : cumul 25 ans + payback + cadrage mensuel ────
const headline = ok ? savingsHeadline(data!, reco ?? 'sans_batterie') : null;

// ── WJ14 — Impact environnemental humain (CO₂ ≈ arbres), depuis la production ─
const enviro = ok ? environmentalImpact(prodKwh) : null;

// ── WJ10 — Comparatif de financement (cash backend + éco-prêt indicatif) ─────
const financing = ok ? financingComparison(data!, reco ?? 'sans_batterie') : null;

// ── WJ12 — Contact intégré : deep-link WhatsApp prérempli avec la réf devis ──
// « Demander un rappel » = appeler le numéro TAQINOR (NAP), jamais le numéro du
// client. Numéro réel (= lib/nap NAP.phone), affiché tel quel.
const waLink = ok ? whatsappLink(reference) : '';
const TAQINOR_TEL = '+212661850410';
const callbackHref = ok ? `tel:${TAQINOR_TEL}` : '';

// ── P3 — Lien public du devis PDF premium (même token, nouvel onglet) ────────
const pdfUrl = ok ? proposalPdfEndpoint(API_BASE, token) : '';

// ── WJ25 — visionneuse 3D en lecture seule (layout backend OPTIONNEL QJ26) ───
// Le backend n'expose pas encore `roof_layout` (PLAN2 QJ26) : le parse renvoie
// alors null et la page garde EXACTEMENT le héros statique d'aujourd'hui. Quand
// le champ arrivera, le modèle 3D (JSON pur) est calculé ICI côté serveur — le
// client ne charge que le rendu Three.js, en différé (jamais au premier paint).
const roofLayout = ok ? parseRoofLayout(data?.roof_layout) : null;
const viewerModel = roofLayout ? buildViewerModel(roofLayout) : null;
const show3d = !!viewerModel && viewerModel.totalPanels >= 0;
const viewerConfig = show3d ? JSON.stringify({ model: viewerModel }) : null;

// ── WJ26 — « Tout est expliqué » : légende par pan + visite guidée en 4 étapes.
// Chaque chiffre vient du layout serveur ou du payload quote (les fonctions
// renvoient null / « estimation indisponible » quand la donnée manque).
const annotations = show3d && roofLayout ? zoneAnnotations(roofLayout, q?.watt_par_panneau ?? null) : [];
const walkSteps = show3d && data ? walkthroughSteps(data) : [];

const pageTitle = ok ? `Proposition ${reference} — ${clientName} | Taqinor` : 'Proposition | Taqinor';

// Données passées au script de signature (sérialisées en JSON dans un data-attr).
const signConfig = ok
  ? JSON.stringify({ token, twoOptions, preselect, accepted, acceptedName: data?.accepte_par_nom ?? '', reference })
  : null;
---

<Layout title={pageTitle} description="Votre proposition solaire personnalisée Taqinor." noindex={true}>
  {!ok ? (
    <!-- ── État « lien expiré / introuvable » ─────────────────────────────── -->
    <section class="mx-auto flex min-h-[60vh] max-w-2xl flex-col items-center justify-center px-5 py-24 text-center">
      <div class="rule-brass mx-auto text-brass-300" aria-hidden="true"></div>
      <h1 class="display mt-6 text-3xl text-lune sm:text-4xl">Proposition indisponible</h1>
      <p class="v2-body mt-4 max-w-md">{errorDetail}</p>
      <p class="mt-8 text-sm text-lune-faint">
        Besoin d’un nouveau lien ? Contactez votre conseiller Taqinor.
      </p>
      <a href="/" class="btn-pill mt-8">Retour à l’accueil</a>
    </section>
  ) : (
    <div class="proposition pb-28" data-sign-config={signConfig}>
      <!-- ── HÉRO ────────────────────────────────────────────────────────── -->
      <section class="relative overflow-hidden">
        {roofImg ? (
          <img
            src={roofImg}
            alt={`Étude de toiture — ${clientName}`}
            width="1600"
            height="900"
            class="absolute inset-0 h-full w-full object-cover"
            loading="eager"
            decoding="async"
          />
        ) : (
          <div class="absolute inset-0 bg-azur-950" aria-hidden="true"></div>
        )}
        <!-- Scrim pour garantir le contraste AA du texte par-dessus la photo. -->
        <div class="hero-scrim absolute inset-0" aria-hidden="true"></div>
        <div class="relative mx-auto max-w-4xl px-5 pb-12 pt-24 sm:px-8 sm:pb-16 sm:pt-32">
          <p class="tech-label text-brass-300">{roofImg ? 'Votre installation · ' : 'Proposition · '}{instLabel}</p>
          <h1 class="display mt-3 text-4xl text-blanc sm:text-5xl">
            Bonjour {clientName},
          </h1>
          <p class="v2-body mt-4 max-w-xl text-lune">
            Voici votre proposition solaire personnalisée. Tout est détaillé ci-dessous —
            vous pouvez la signer en ligne en bas de page.
          </p>
          <dl class="mt-7 flex flex-wrap gap-x-8 gap-y-3 text-sm">
            {reference && (
              <div>
                <dt class="text-lune-faint">Référence</dt>
                <dd class="fig text-lg text-lune">{reference}</dd>
              </div>
            )}
            {proposalDate && (
              <div>
                <dt class="text-lune-faint">Date</dt>
                <dd class="fig text-lg text-lune">{proposalDate}</dd>
              </div>
            )}
            {/* WJ15 — Fenêtre de validité honnête : date backend réelle, sinon mention libellée. Jamais un compte-à-rebours. */}
            {validity.fromBackend && validity.label && !validity.expired && (
              <div>
                <dt class="text-lune-faint">Devis valable jusqu’au</dt>
                <dd class="fig text-lg text-brass-300">{validity.label}</dd>
              </div>
            )}
            {validity.fromBackend && validity.expired && (
              <div>
                <dt class="text-lune-faint">Validité</dt>
                <dd class="text-base text-lune-soft">Offre échue — demandez une réactualisation</dd>
              </div>
            )}
          </dl>
        </div>
      </section>

      <!-- ── BANDEAU « déjà signé » (si accepté au chargement) ─────────────── -->
      {accepted && (
        <section class="mx-auto max-w-4xl px-5 pt-8 sm:px-8">
          <div class="cine-card rounded-xl border-brass-400/40 p-5 sm:p-6" style="border-color: rgb(232 181 74 / 0.4)">
            <p class="fig text-xl text-brass-300">Devis accepté ✓</p>
            <p class="v2-body mt-1">
              Cette proposition a été acceptée
              {data?.accepte_par_nom ? <> par <strong class="text-lune">{data.accepte_par_nom}</strong></> : null}.
              Merci de votre confiance — votre conseiller Taqinor revient vers vous.
            </p>
          </div>
        </section>
      )}

      <!-- ── WJ25 · VOTRE TOIT EN 3D (lecture seule — layout backend optionnel) -->
      {/* Rendu UNIQUEMENT quand le backend fournit un roof_layout exploitable
          (QJ26). Sans layout : rien ici — le héros statique reste inchangé.
          Boîte à ratio RÉSERVÉ (zéro CLS) : poster (photo d'étude ou fond) puis
          canvas 3D par-dessus quand la visionneuse démarre. Three.js n'est
          JAMAIS dans le bundle initial (import() au scroll/tap — WJ27). */}
      {show3d && (
        <section id="roof3d" class="mx-auto max-w-4xl px-5 pt-12 sm:px-8 sm:pt-16" data-viewer-config={viewerConfig}>
          <p class="tech-label rule-brass text-brass-300">Votre toit en 3D</p>
          <div class="cine-card mt-5 overflow-hidden rounded-2xl p-0">
            <div id="roof3d-stage" class="roof3d-stage">
              {roofImg ? (
                <img
                  src={roofImg}
                  alt={`Étude de toiture — ${clientName}`}
                  width="1600"
                  height="1000"
                  class="absolute inset-0 h-full w-full object-cover"
                  loading="lazy"
                  decoding="async"
                />
              ) : (
                <div class="absolute inset-0 bg-azur-950" aria-hidden="true"></div>
              )}
              <div class="roof3d-scrim absolute inset-0" aria-hidden="true"></div>
              <div id="roof3d-overlay" class="absolute inset-0 flex flex-col items-center justify-center gap-3 px-6 text-center">
                <button
                  id="roof3d-start"
                  type="button"
                  class="btn-pill inline-flex items-center justify-center gap-2"
                  style="background: var(--color-brass-400); color: var(--color-nuit); border-color: var(--color-brass-400)"
                >
                  Explorer votre toit en 3D
                </button>
                <p id="roof3d-note" class="max-w-sm text-sm text-lune-soft">
                  Tournez, zoomez : ce sont votre toit et vos panneaux, tels qu’étudiés.
                </p>
              </div>
            </div>
            <p id="roof3d-hint" class="px-5 py-3 text-xs text-lune-faint" hidden>
              Faites glisser pour tourner · pincez ou molette pour zoomer · deux doigts pour déplacer.
            </p>
          </div>

          <!-- ── WJ26 · Légende : ce que vous voyez, pan par pan ─────────────── -->
          <div class="mt-4 flex flex-wrap items-center gap-x-6 gap-y-2 text-sm" aria-label="Légende de la vue 3D">
            <span class="inline-flex items-center gap-2 text-lune-soft">
              <span class="inline-block h-3 w-3 rounded-sm" style="background: #14263f; outline: 1px solid rgb(255 255 255 / 0.25)" aria-hidden="true"></span>
              Vos panneaux solaires
            </span>
            <span class="inline-flex items-center gap-2 text-lune-soft">
              <span class="inline-block h-3 w-3 rounded-sm" style="background: #b9bfca" aria-hidden="true"></span>
              Votre toiture
            </span>
            <span class="inline-flex items-center gap-2 text-lune-soft">
              <span class="inline-block h-3 w-3 rounded-sm" style="background: #9aa3b4" aria-hidden="true"></span>
              Obstacles (cheminée, cage d’escalier…)
            </span>
          </div>
          {annotations.length > 0 && (
            <div class={`mt-4 grid gap-3 ${annotations.length > 1 ? 'sm:grid-cols-2' : ''}`}>
              {annotations.map((a) => (
                <div class="cine-card rounded-xl p-4 text-sm">
                  <p class="tech-label text-lune-faint">{a.label} · {a.roofTypeLabel}</p>
                  <p class="mt-2 text-lune-soft">
                    Orientation <strong class="text-lune">{a.orientation}</strong>
                    {a.tiltDeg !== null ? <> · pente <strong class="text-lune">{a.tiltDeg}°</strong></> : null}
                    {a.panels !== null ? <> · <strong class="text-lune">{formatNumber(a.panels)} panneaux</strong></> : null}
                    {a.kwc !== null ? <> · <strong class="text-brass-300">{formatNumber(a.kwc, 2)} kWc</strong></> : null}
                  </p>
                </div>
              ))}
            </div>
          )}

          <!-- ── WJ26 · Visite guidée (4 étapes, skippable, sans mouvement) ──── -->
          {walkSteps.length > 0 && (
            <div id="roof3d-walk" class="mt-6" role="group" aria-label="Explication guidée de votre installation">
              <div class="flex items-baseline justify-between gap-3">
                <p class="tech-label text-lune-faint">Tout est expliqué, étape par étape</p>
                <a href="#options" class="text-xs text-lune-faint underline-offset-2 hover:underline">Passer l’explication</a>
              </div>
              <ol class="mt-3 space-y-3">
                {walkSteps.map((s, i) => (
                  <li
                    class="walk-step cine-card rounded-xl p-4"
                    data-walk-step={s.id}
                    aria-current={i === 0 ? 'step' : undefined}
                  >
                    <p class="flex items-baseline justify-between gap-3">
                      <span class="text-sm font-bold text-lune">
                        <span class="fig text-brass-300">{i + 1}.</span> {s.title}
                      </span>
                      <span dir="rtl" lang="ar" class="shrink-0 text-xs text-lune-faint">{s.titleAr}</span>
                    </p>
                    <p class="v2-body mt-1.5 text-sm text-lune-soft">{s.body}</p>
                  </li>
                ))}
              </ol>
              <div class="mt-3 flex items-center gap-3">
                <button id="roof3d-walk-prev" type="button" class="btn-pill px-4 py-1.5 text-sm" disabled>Précédent</button>
                <button id="roof3d-walk-next" type="button" class="btn-pill px-4 py-1.5 text-sm">Suivant</button>
                <span id="roof3d-walk-count" class="text-xs text-lune-faint" aria-live="polite">Étape 1 sur {walkSteps.length}</span>
              </div>
            </div>
          )}
        </section>
      )}

      <!-- ── WJ9 · ARGENT DANS LE TEMPS (cumul 25 ans + payback + /mois) ───── -->
      {headline && (headline.cumulative || headline.annual || paybackHero || prodKwh) && (
        <section class="mx-auto max-w-4xl px-5 pt-12 sm:px-8 sm:pt-16">
          {/* Accroche « coût de ne rien faire » : le cumul phare. */}
          {headline.cumulative ? (
            <div class="cine-card rounded-2xl p-6 sm:p-8" style="border-color: rgb(232 181 74 / 0.35)">
              <p class="tech-label text-lune-faint">
                Sans le solaire, votre facture continue de courir. Avec, vous économisez sur {headline.years} ans
              </p>
              <p class="fig lum mt-3 text-4xl sm:text-5xl">{formatMAD(headline.cumulative)}</p>
              <p class="v2-body mt-2 text-sm text-lune-soft">
                Économies cumulées estimées sur {headline.years} ans
                {headline.monthly ? <> — soit <span class="text-brass-300">≈ {formatMAD(headline.monthly)}/mois</span> qui restent dans votre poche</> : null}.
                {!headline.cumulativeFromBackend ? <span class="text-lune-faint"> Estimation à tarif constant (loi 82-21, autoconsommation).</span> : null}
              </p>
            </div>
          ) : null}

          <div class="mt-4 grid gap-4 sm:grid-cols-3">
            {headline.annual ? (
              <div class="cine-card rounded-xl p-5">
                <p class="tech-label text-lune-faint">Économies estimées / an</p>
                <p class="fig fig-md lum mt-2">{formatMAD(headline.annual)}</p>
                {headline.monthly ? <p class="mt-1 text-sm text-lune-faint">≈ {formatMAD(headline.monthly)}/mois</p> : null}
              </div>
            ) : null}
            {paybackHero ? (
              <div class="cine-card rounded-xl p-5">
                <p class="tech-label text-lune-faint">Rentabilisé en</p>
                <p class="fig fig-md mt-2 text-lune">{paybackHero}</p>
                <p class="mt-1 text-sm text-lune-faint">puis l’énergie est gratuite</p>
              </div>
            ) : null}
            {prodKwh ? (
              <div class="cine-card rounded-xl p-5">
                <p class="tech-label text-lune-faint">Production estimée / an</p>
                <p class="fig fig-md mt-2 text-lune">{formatNumber(prodKwh)} <span class="text-lg text-lune-soft">kWh</span></p>
              </div>
            ) : null}
          </div>
        </section>
      )}

      <!-- ── SYSTÈME : puissance / panneaux ───────────────────────────────── -->
      {(puissance || nbPanneaux) && (
        <section class="mx-auto max-w-4xl px-5 pt-12 sm:px-8">
          <p class="tech-label rule-brass text-brass-300">Votre système</p>
          <div class="mt-5 grid gap-4 sm:grid-cols-3">
            {puissance ? (
              <div class="cine-card rounded-xl p-5">
                <p class="tech-label text-lune-faint">Puissance</p>
                <p class="fig mt-2 text-2xl text-lune">{formatNumber(puissance, 2)} <span class="text-base text-lune-soft">kWc</span></p>
              </div>
            ) : null}
            {nbPanneaux ? (
              <div class="cine-card rounded-xl p-5">
                <p class="tech-label text-lune-faint">Panneaux</p>
                <p class="fig mt-2 text-2xl text-lune">
                  {formatNumber(nbPanneaux)}
                  {wattPanneau ? <span class="text-base text-lune-soft"> × {formatNumber(wattPanneau)} W</span> : null}
                </p>
              </div>
            ) : null}
            <div class="cine-card rounded-xl p-5">
              <p class="tech-label text-lune-faint">Type</p>
              <p class="fig mt-2 text-2xl text-lune">{instLabel}</p>
            </div>
          </div>
        </section>
      )}

      <!-- ── P2 · PRODUCTION ESTIMÉE vs CONSOMMATION (langage pro-11) ──────── -->
      {showChart && (
        <section class="mx-auto max-w-4xl px-5 pt-14 sm:px-8">
          <p class="tech-label rule-brass text-brass-300">
            {chartHasConso ? 'Production estimée vs votre consommation' : 'Production estimée'}
          </p>
          <div class="cine-card mt-5 rounded-2xl p-5 sm:p-6">
            <div class="chart-svg" set:html={chartSvg}></div>
            <div class="mt-4 flex flex-wrap items-center gap-x-6 gap-y-2 text-sm">
              <span class="inline-flex items-center gap-2 text-lune-soft">
                <span class="inline-block h-3 w-3 rounded-sm" style="background: var(--color-brass-400)" aria-hidden="true"></span>
                Production solaire estimée
              </span>
              {chartHasConso && (
                <span class="inline-flex items-center gap-2 text-lune-soft">
                  <span class="inline-block h-3 w-3 rounded-sm" style="background: var(--color-azur-300, #7fb4e8)" aria-hidden="true"></span>
                  Votre consommation
                </span>
              )}
              <span class="text-lune-faint">kWh par mois</span>
            </div>
            {(prodKwh || ecoHero) && (
              <p class="v2-body mt-4 text-sm text-lune-soft">
                {prodKwh ? <>Sur l’année, votre installation produit environ <strong class="text-lune">{formatNumber(prodKwh)} kWh</strong>.</> : null}
                {chartHasConso ? ' Plus la production (laiton) couvre votre consommation (azur), plus vous économisez.' : ''}
              </p>
            )}
          </div>
        </section>
      )}

      <!-- ── WJ16 · COURBE JOURNALIÈRE (lever → coucher) ───────────────────── -->
      {/* Visuel le plus persuasif : la cloche solaire couvre la conso du foyer.
          Calée sur la production RÉELLE si présente, sinon « année type » libellée.
          Animation gatée prefers-reduced-motion (voir <style>). */}
      {dailyCurve.svg && (
        <section class="mx-auto max-w-4xl px-5 pt-14 sm:px-8">
          <p class="tech-label rule-brass text-brass-300">Votre journée solaire</p>
          <div class="cine-card mt-5 rounded-2xl p-5 sm:p-6">
            <div class="daily-curve-wrap" set:html={dailyCurve.svg}></div>
            <div class="mt-4 flex flex-wrap items-center gap-x-6 gap-y-2 text-sm">
              <span class="inline-flex items-center gap-2 text-lune-soft">
                <span class="inline-block h-3 w-3 rounded-sm" style="background: var(--color-brass-400)" aria-hidden="true"></span>
                Production solaire
              </span>
              <span class="inline-flex items-center gap-2 text-lune-soft">
                <span class="inline-block h-3 w-3 rounded-sm" style="background: var(--color-azur-300, #7fb4e8)" aria-hidden="true"></span>
                Votre consommation
              </span>
              {!dailyCurve.hasRealScale && (
                <span class="text-lune-faint">profil — année type (forme indicative)</span>
              )}
            </div>
            <p class="v2-body mt-4 text-sm text-lune-soft">
              Le soleil produit en pleine journée : chaque kWh consommé à ce moment-là
              ne vient plus du réseau. {dailyCurve.hasRealScale
                ? 'Les repères sont calés sur votre production estimée.'
                : 'Cette courbe illustre une journée type — votre profil exact est précisé avec votre conseiller.'}
            </p>
          </div>
        </section>
      )}

      <!-- ── OPTIONS ──────────────────────────────────────────────────────── -->
      <section id="options" class="mx-auto max-w-4xl px-5 pt-14 sm:px-8">
        <p class="tech-label rule-brass text-brass-300">
          {twoOptions ? 'Vos deux options' : 'Votre proposition'}
        </p>
        <div class={`mt-5 grid gap-4 ${twoOptions ? 'sm:grid-cols-2' : ''}`}>
          {options.map((opt) => {
            const totaux = optionTotaux(data!, opt);
            const items = optionItems(data!, opt);
            const isReco = twoOptions && opt === reco;
            const eco = opt === 'avec_batterie' ? ecoAvec : ecoSans;
            return (
              <article
                class="cine-card relative flex flex-col rounded-2xl p-6"
                style={isReco ? 'border-color: rgb(232 181 74 / 0.45)' : undefined}
              >
                {isReco && (
                  <span class="absolute -top-3 left-6 rounded-full bg-brass-400 px-3 py-1 text-xs font-bold text-nuit">
                    Recommandé
                  </span>
                )}
                <h3 class="display text-xl text-lune">{optionLabel(opt)}</h3>
                <p class="fig fig-md lum mt-3">{formatMAD(optionTtc(data!, opt))}</p>
                <p class="text-sm text-lune-faint">TTC, clé en main</p>
                {eco ? (
                  <p class="mt-2 text-sm text-lune-soft">
                    Économies estimées : <span class="text-brass-300">{formatMAD(eco)}/an</span>
                  </p>
                ) : null}

                <!-- Équipement -->
                {items.length > 0 && (
                  <div class="mt-5 border-t border-white/10 pt-4">
                    <p class="tech-label text-lune-faint">Équipement</p>
                    <ul class="mt-3 space-y-2 text-sm text-lune-soft">
                      {items.map((it) => (
                        <li class="flex items-baseline justify-between gap-3">
                          <span>
                            <span class="text-lune">{it.designation}</span>
                            {it.marque ? <span class="text-lune-faint"> · {it.marque}</span> : null}
                          </span>
                          <span class="fig shrink-0 text-lune-faint">×{formatNumber(it.quantite)}</span>
                        </li>
                      ))}
                    </ul>
                  </div>
                )}

                <!-- Chaîne de prix explicite -->
                {totaux && (
                  <dl class="mt-5 space-y-1.5 border-t border-white/10 pt-4 text-sm">
                    <div class="flex justify-between">
                      <dt class="text-lune-faint">Sous-total HT</dt>
                      <dd class="fig text-lune-soft">{formatMAD(totaux.ht_brut)}</dd>
                    </div>
                    {totaux.remise > 0 && (
                      <div class="flex justify-between">
                        <dt class="text-lune-faint">Remise</dt>
                        <dd class="fig text-brass-300">−{formatMAD(totaux.remise)}</dd>
                      </div>
                    )}
                    <div class="flex justify-between">
                      <dt class="text-lune-faint">Total HT</dt>
                      <dd class="fig text-lune-soft">{formatMAD(totaux.ht_net)}</dd>
                    </div>
                    <div class="flex justify-between">
                      <dt class="text-lune-faint">TVA</dt>
                      <dd class="fig text-lune-soft">{formatMAD(totaux.tva)}</dd>
                    </div>
                    <div class="flex justify-between border-t border-white/10 pt-2">
                      <dt class="text-lune">Total TTC</dt>
                      <dd class="fig text-lg text-lune">{formatMAD(totaux.ttc)}</dd>
                    </div>
                  </dl>
                )}
              </article>
            );
          })}
        </div>
      </section>

      <!-- ── WJ10 · COMPARATIF DE FINANCEMENT (cash vs éco-prêt indicatif) ─── -->
      {financing && (
        <section class="mx-auto max-w-4xl px-5 pt-14 sm:px-8">
          <p class="tech-label rule-brass text-brass-300">Comment financer</p>
          <div class="mt-5 grid gap-4 sm:grid-cols-2">
            <div class="cine-card rounded-2xl p-6">
              <p class="tech-label text-lune-faint">Au comptant</p>
              <p class="fig fig-md lum mt-2">{formatMAD(financing.cash)}</p>
              <p class="mt-2 text-sm text-lune-soft">Prix clé en main, TTC. L’investissement le plus rentable sur la durée.</p>
            </div>
            <div class="cine-card rounded-2xl p-6">
              <p class="tech-label text-lune-faint">À crédit (éco-prêt)</p>
              <p class="fig fig-md mt-2 text-lune">
                ≈ {formatMAD(financing.monthlyLow)}<span class="text-lg text-lune-soft"> – {formatMAD(financing.monthlyHigh)}/mois</span>
              </p>
              <p class="mt-2 text-sm text-lune-soft">
                Sur {Math.round(financing.months / 12)} ans, fourchette indicative
                <span class="text-brass-300"> à confirmer</span> avec votre banque.
                {financing.beatsBill && financing.currentBillMonthly
                  ? <> Souvent <strong class="text-lune">moins que votre facture actuelle</strong> (≈ {formatMAD(financing.currentBillMonthly)}/mois).</>
                  : null}
              </p>
            </div>
          </div>
          <p class="mt-3 text-xs text-lune-faint">
            Mensualités calculées à titre indicatif (taux et durée non contractuels). Le montant exact dépend de l’offre bancaire retenue.
          </p>
        </section>
      )}

      <!-- ── WJ14 · IMPACT ENVIRONNEMENTAL (CO₂ ≈ arbres) — clôture émotion ── -->
      {enviro && (
        <section class="mx-auto max-w-4xl px-5 pt-14 sm:px-8">
          <p class="tech-label rule-brass text-brass-300">Votre impact, concrètement</p>
          <div class="cine-card mt-5 rounded-2xl p-6 sm:p-8">
            <div class="grid gap-6 sm:grid-cols-2 sm:items-center">
              <div>
                <p class="fig lum text-4xl sm:text-5xl">{formatNumber(enviro.co2TonnesPerYear, 1)} <span class="text-2xl text-lune-soft">t CO₂ / an</span></p>
                <p class="v2-body mt-2 text-sm text-lune-soft">
                  évités chaque année — l’équivalent de
                  <strong class="text-brass-300"> {formatNumber(enviro.trees)} arbres</strong> qui absorberaient ce CO₂.
                </p>
              </div>
              <div class="text-sm text-lune-faint">
                <p>Calcul transparent : production estimée × {formatNumber(enviro.kgPerKwh, 2)} kg CO₂/kWh (facteur d’émission du réseau marocain), ramené à raison de {formatNumber(enviro.kgPerTreeYear)} kg CO₂ absorbés par arbre et par an.</p>
              </div>
            </div>
          </div>
        </section>
      )}

      <!-- ── WJ12 · CONTACT AU MOINDRE DOUTE (avant la signature) ──────────── -->
      <section class="mx-auto max-w-4xl px-5 pt-14 sm:px-8">
        <div class="cine-card rounded-2xl p-6 sm:p-7">
          <p class="v2-body text-lune">
            Une question avant de signer ? Parlons-en — sans engagement, et sans appel commercial non sollicité.
          </p>
          <div class="mt-4 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
            <a
              href={waLink}
              target="_blank"
              rel="noopener noreferrer"
              class="btn-pill inline-flex items-center justify-center gap-2"
              style="background: #25d366; color: #062b14; border-color: #25d366"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Zm0 18.1h-.01a8.2 8.2 0 0 1-4.18-1.15l-.3-.18-3.11.82.83-3.04-.2-.31a8.2 8.2 0 0 1-1.26-4.37c0-4.54 3.7-8.23 8.24-8.23 2.2 0 4.27.86 5.83 2.42a8.18 8.18 0 0 1 2.41 5.82c0 4.54-3.7 8.23-8.23 8.23Zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.16.25-.64.81-.78.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.01-.38.11-.51.11-.11.25-.29.37-.43.13-.14.17-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.35-.77-1.85-.2-.48-.41-.42-.56-.43l-.48-.01c-.17 0-.43.06-.66.31-.23.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.57.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.68-1.18.21-.58.21-1.07.14-1.18-.06-.1-.22-.16-.47-.28Z"/>
              </svg>
              Discuter sur WhatsApp
            </a>
            {callbackHref ? (
              <a href={callbackHref} class="btn-pill inline-flex items-center justify-center gap-2">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92Z"/>
                </svg>
                Demander un rappel
              </a>
            ) : null}
            <a href={waLink} target="_blank" rel="noopener noreferrer" class="btn-pill inline-flex items-center justify-center gap-2">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5Z"/>
              </svg>
              Poser une question
            </a>
          </div>
        </div>
      </section>

      <!-- ── SIGNATURE EN LIGNE ───────────────────────────────────────────── -->
      <section id="signer" class="mx-auto max-w-4xl px-5 pt-16 sm:px-8">
        <div class="cine-card rounded-2xl p-6 sm:p-8">
          <!-- État confirmé (caché par défaut, affiché après signature ou si déjà accepté) -->
          <div id="sign-success" class="result-fade" hidden>
            <p class="fig text-2xl text-brass-300">Devis accepté ✓</p>
            <p class="v2-body mt-2">
              Merci <span id="sign-success-name" class="text-lune"></span> — votre acceptation est bien enregistrée.
              Votre conseiller Taqinor revient vers vous très vite.
            </p>
            <p id="sign-success-stamp" class="mt-3 text-sm text-lune-faint">
              Réf. {reference}<span id="sign-success-time"></span>.
            </p>
          </div>

          <!-- Formulaire de signature -->
          <form id="sign-form" novalidate>
            <p class="tech-label rule-brass text-brass-300">Signer en ligne</p>
            <h2 class="display mt-3 text-2xl text-lune">Bon pour accord</h2>
            <p class="v2-body mt-2">
              Validez votre proposition en quelques secondes. Vous recevrez ensuite la confirmation
              de votre conseiller.
            </p>

            {twoOptions && (
              <fieldset class="mt-6">
                <legend class="tech-label text-lune-faint">Votre choix</legend>
                <div class="mt-3 grid gap-3 sm:grid-cols-2">
                  {options.map((opt) => (
                    <label class="flex cursor-pointer items-center gap-3 rounded-xl border border-white/12 p-4 text-sm has-[:checked]:border-brass-400">
                      <input
                        type="radio"
                        name="option"
                        value={opt}
                        checked={opt === preselect}
                        class="h-4 w-4 accent-[var(--color-brass-400)]"
                      />
                      <span class="text-lune">
                        {optionLabel(opt)}
                        <span class="block text-lune-faint">{formatMAD(optionTtc(data!, opt))} TTC</span>
                      </span>
                    </label>
                  ))}
                </div>
              </fieldset>
            )}

            <div class="mt-6">
              <label for="sign-nom" class="tech-label text-lune-faint">Votre nom complet</label>
              <input
                id="sign-nom"
                name="nom"
                type="text"
                autocomplete="name"
                required
                class="mt-2 w-full rounded-xl border border-white/15 bg-nuit-800 px-4 py-3 text-lune placeholder:text-lune-faint"
                placeholder="Prénom Nom"
              />
            </div>

            <!-- WJ11 · SIGNATURE MANUSCRITE (canvas natif, tactile + souris) ── -->
            <div class="mt-6">
              <div class="flex items-baseline justify-between gap-3">
                <label for="sign-pad" class="tech-label text-lune-faint">Votre signature</label>
                <button
                  id="sign-clear"
                  type="button"
                  class="text-xs text-lune-faint underline-offset-2 hover:underline"
                >Effacer</button>
              </div>
              <div class="sign-pad-wrap mt-2 rounded-xl border border-white/15 bg-nuit-800">
                <canvas
                  id="sign-pad"
                  width="640"
                  height="180"
                  class="sign-pad block w-full touch-none rounded-xl"
                  role="img"
                  aria-label="Zone de signature manuscrite — dessinez votre signature au doigt ou à la souris"
                ></canvas>
              </div>
              <p class="mt-1.5 text-xs text-lune-faint">Dessinez votre signature ci-dessus (facultatif mais recommandé). Votre nom et votre accord ci-dessous valent signature électronique (loi 53-05).</p>
            </div>

            <label class="mt-5 flex cursor-pointer items-start gap-3 text-sm">
              <input id="sign-accord" name="accord" type="checkbox" required class="mt-1 h-4 w-4 accent-[var(--color-brass-400)]" />
              <span class="text-lune-soft">
                Je certifie « <strong class="text-lune">Bon pour accord</strong> » et j’accepte cette proposition
                aux conditions indiquées ci-dessus.
              </span>
            </label>

            <label class="mt-3 flex cursor-pointer items-start gap-3 text-sm">
              <input id="sign-consent" name="consent" type="checkbox" required class="mt-1 h-4 w-4 accent-[var(--color-brass-400)]" />
              <span class="text-lune-soft">
                J’accepte de <strong class="text-lune">signer électroniquement</strong> cette proposition.
                Mon nom, la date et l’heure de signature sont enregistrés avec mon accord.
              </span>
            </label>

            <!-- Récapitulatif horodaté (réf + date/heure côté client) -->
            <p id="sign-stamp" class="mt-4 text-xs text-lune-faint">
              Réf. {reference} · l’horodatage de votre signature s’affichera ici.
            </p>

            <p id="sign-error" class="mt-4 text-sm text-alert-300" role="alert" hidden></p>

            <button
              id="sign-submit"
              type="submit"
              class="btn-pill glow-hero mt-6 w-full justify-center bg-brass-400 px-6 py-3 text-base font-bold text-nuit sm:w-auto"
              style="background: var(--color-brass-400); color: var(--color-nuit); border-color: var(--color-brass-400)"
            >
              <span id="sign-submit-label">Signer en ligne</span>
              <span id="sign-spinner" class="spinner" hidden aria-hidden="true"></span>
            </button>
          </form>
        </div>

        <!-- ── P3 · TÉLÉCHARGER LE DEVIS PDF (même token, nouvel onglet) ───── -->
        <div class="mt-6 text-center">
          <a
            href={pdfUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-pill inline-flex items-center justify-center gap-2"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
              <polyline points="7 10 12 15 17 10" />
              <line x1="12" y1="15" x2="12" y2="3" />
            </svg>
            Télécharger le devis (PDF)
          </a>
        </div>

        <p class="mt-6 text-center text-xs text-lune-faint">
          Proposition Taqinor · réf. {reference}. Document non contractuel sans signature du devis officiel.
        </p>
      </section>

      <!-- ── WJ13 · BLOC CRÉDIBILITÉ (garanties · certifications · réassurance) -->
      {/* Aucune donnée chiffrée fabriquée : nombre de clients / avis / photos
          réelles marqués `pending real content` tant que Reda ne les fournit pas.
          Les garanties et normes ci-dessous sont des FAITS techniques vérifiables. */}
      <section class="mx-auto max-w-4xl px-5 pt-16 sm:px-8">
        <p class="tech-label rule-brass text-brass-300">Pourquoi nous faire confiance</p>
        <div class="mt-5 grid gap-4 sm:grid-cols-3">
          <div class="cine-card rounded-xl p-5">
            <p class="fig text-2xl text-lune">20–25 ans</p>
            <p class="mt-1 text-sm text-lune-soft">Garanties constructeur : 25 ans de performance sur les panneaux, 10 ans sur l’onduleur.</p>
          </div>
          <div class="cine-card rounded-xl p-5">
            <p class="fig text-xl text-lune">IEC 61215 / 61730</p>
            <p class="mt-1 text-sm text-lune-soft">Modules certifiés aux normes internationales. Conformité étude IRESEN / AMEE.</p>
          </div>
          <div class="cine-card rounded-xl p-5">
            <p class="fig text-xl text-lune">Loi 82-21</p>
            <p class="mt-1 text-sm text-lune-soft">Installation conforme au cadre marocain d’autoconsommation en basse tension.</p>
          </div>
        </div>

        <!-- Photos d'installations réelles — scaffold, à remplir par Reda. -->
        <div class="mt-4 cine-card rounded-xl p-5">
          <p class="tech-label text-lune-faint">Nos chantiers</p>
          <!-- pending real content from Reda : photos d'installations réelles + nombre de clients + villes -->
          <p class="mt-2 text-sm text-lune-soft">
            Des dizaines d’installations livrées partout au Maroc.
            <span class="text-lune-faint"> (Photos et références clients à venir.)</span>
          </p>
        </div>

        <!-- Mot du fondateur (FR + AR) — scaffold, contenu réel à confirmer. -->
        <div class="mt-4 cine-card rounded-xl p-6">
          <p class="tech-label text-lune-faint">Le mot du fondateur</p>
          <!-- pending real content from Reda : texte définitif du mot de bienvenue -->
          <blockquote class="mt-3 v2-body text-lune">
            « Chez Taqinor, nous traitons chaque toit comme le nôtre : une étude honnête,
            du matériel certifié, et un accompagnement après l’installation. Merci de votre confiance. »
          </blockquote>
          <blockquote dir="rtl" lang="ar" class="mt-3 text-right text-lune" style="line-height: 1.8">
            « في تاقينور، نتعامل مع كل سطح كأنه سطحنا: دراسة صادقة، معدات معتمدة، ومرافقة بعد التركيب. شكراً على ثقتكم. »
          </blockquote>
          <p class="mt-2 text-sm text-lune-faint">Reda Kasri — fondateur, Taqinor</p>
        </div>
      </section>

      <!-- ── CTA COLLANT « Signer en ligne » ──────────────────────────────── -->
      <div
        id="sticky-cta"
        class="fixed inset-x-0 bottom-0 z-40 border-t border-white/10 bg-nuit-800/95 px-4 py-3 backdrop-blur supports-[backdrop-filter]:bg-nuit-800/80"
      >
        <div class="mx-auto flex max-w-4xl items-center justify-between gap-4">
          <div class="min-w-0">
            <p class="truncate text-sm text-lune-soft">
              {twoOptions ? 'À partir de ' : ''}
              <span class="lum fig text-lg">{formatMAD(optionTtc(data!, reco ?? 'sans_batterie'))}</span>
              <span class="text-lune-faint"> TTC</span>
            </p>
            {validity.fromBackend && validity.label && !validity.expired && (
              <p class="truncate text-xs text-lune-faint">Valable jusqu’au {validity.label}</p>
            )}
          </div>
          <a
            href="#signer"
            class="btn-pill shrink-0 whitespace-nowrap"
            style="background: var(--color-brass-400); color: var(--color-nuit); border-color: var(--color-brass-400)"
          >
            Signer en ligne
          </a>
        </div>
      </div>
    </div>
  )}
</Layout>

<script>
  import {
    validateSign,
    buildAcceptBodyRich,
    type OptionKey,
    type SignFormState,
  } from '../../lib/proposition';

  interface SignConfig {
    token: string;
    twoOptions: boolean;
    preselect: OptionKey | null;
    accepted: boolean;
    acceptedName: string;
    reference: string;
  }

  const root = document.querySelector<HTMLElement>('.proposition');
  const raw = root?.dataset.signConfig;
  if (root && raw) {
    const cfg = JSON.parse(raw) as SignConfig;

    const form = document.getElementById('sign-form') as HTMLFormElement | null;
    const success = document.getElementById('sign-success');
    const successName = document.getElementById('sign-success-name');
    const successTime = document.getElementById('sign-success-time');
    const stampEl = document.getElementById('sign-stamp');
    const errorEl = document.getElementById('sign-error');
    const submitBtn = document.getElementById('sign-submit') as HTMLButtonElement | null;
    const submitLabel = document.getElementById('sign-submit-label');
    const spinner = document.getElementById('sign-spinner');
    const sticky = document.getElementById('sticky-cta');

    // ── WJ11 · Pad de signature manuscrite (canvas natif, tactile + souris) ──
    const canvas = document.getElementById('sign-pad') as HTMLCanvasElement | null;
    const clearBtn = document.getElementById('sign-clear');
    let hasInk = false;

    function setupSignaturePad(c: HTMLCanvasElement): void {
      // Adapte la résolution interne au DPR pour un trait net (sans CLS : la
      // hauteur CSS est fixée par .sign-pad, on n'ajuste que le bitmap).
      const ctx = c.getContext('2d');
      if (!ctx) return;
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      const resize = (): void => {
        const rect = c.getBoundingClientRect();
        if (rect.width === 0) return;
        c.width = Math.round(rect.width * dpr);
        c.height = Math.round(rect.height * dpr);
        ctx.scale(dpr, dpr);
        ctx.lineWidth = 2.2;
        ctx.lineJoin = 'round';
        ctx.lineCap = 'round';
        ctx.strokeStyle = '#f3cc66';
      };
      resize();
      window.addEventListener('resize', resize);

      let drawing = false;
      const pos = (e: PointerEvent): { x: number; y: number } => {
        const rect = c.getBoundingClientRect();
        return { x: e.clientX - rect.left, y: e.clientY - rect.top };
      };
      c.addEventListener('pointerdown', (e) => {
        drawing = true;
        hasInk = true;
        const p = pos(e);
        ctx.beginPath();
        ctx.moveTo(p.x, p.y);
        c.setPointerCapture(e.pointerId);
        e.preventDefault();
      });
      c.addEventListener('pointermove', (e) => {
        if (!drawing) return;
        const p = pos(e);
        ctx.lineTo(p.x, p.y);
        ctx.stroke();
        e.preventDefault();
      });
      const stop = (): void => { drawing = false; };
      c.addEventListener('pointerup', stop);
      c.addEventListener('pointercancel', stop);
      c.addEventListener('pointerleave', stop);
    }
    if (canvas) setupSignaturePad(canvas);

    function clearSignature(): void {
      if (!canvas) return;
      const ctx = canvas.getContext('2d');
      if (ctx) ctx.clearRect(0, 0, canvas.width, canvas.height);
      hasInk = false;
    }
    clearBtn?.addEventListener('click', clearSignature);

    // Horodatage local lisible (fr-MA) — affiché en direct dans le récap.
    function frenchStamp(d: Date): string {
      try {
        return d.toLocaleString('fr-MA', {
          dateStyle: 'long', timeStyle: 'short',
        });
      } catch {
        return d.toLocaleString('fr-FR');
      }
    }
    if (stampEl) {
      const now = new Date();
      stampEl.textContent = `Réf. ${cfg.reference} · signature horodatée le ${frenchStamp(now)} (heure de votre appareil).`;
    }

    function showError(msg: string): void {
      if (!errorEl) return;
      errorEl.textContent = msg;
      errorEl.hidden = false;
    }
    function clearError(): void {
      if (errorEl) errorEl.hidden = true;
    }
    function showSuccess(name: string, when?: string): void {
      if (form) form.hidden = true;
      if (sticky) sticky.hidden = true;
      if (successName) successName.textContent = name || '';
      if (successTime && when) successTime.textContent = ` · signé le ${when}`;
      if (success) success.hidden = false;
    }

    // Déjà accepté au chargement → affiche directement l'état confirmé.
    if (cfg.accepted) {
      showSuccess(cfg.acceptedName);
    }

    function selectedOption(): OptionKey | null {
      if (!cfg.twoOptions) return cfg.preselect;
      const checked = form?.querySelector<HTMLInputElement>('input[name="option"]:checked');
      return (checked?.value as OptionKey) ?? null;
    }

    let submitting = false;
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (submitting) return;
      clearError();

      const accord = (document.getElementById('sign-accord') as HTMLInputElement | null)?.checked;
      const consent = (document.getElementById('sign-consent') as HTMLInputElement | null)?.checked;
      const nom = (document.getElementById('sign-nom') as HTMLInputElement | null)?.value ?? '';
      const state: SignFormState = { nom, option: selectedOption() };

      const v = validateSign(state, cfg.twoOptions);
      if (!v.valid) {
        showError(v.error ?? 'Formulaire incomplet.');
        return;
      }
      if (!accord) {
        showError('Veuillez cocher « Bon pour accord » pour valider.');
        return;
      }
      if (!consent) {
        showError('Veuillez accepter de signer électroniquement pour continuer.');
        return;
      }

      // Capture la signature manuscrite (PNG data URL) UNIQUEMENT si dessinée.
      let signatureDataUrl = '';
      if (canvas && hasInk) {
        try {
          signatureDataUrl = canvas.toDataURL('image/png');
        } catch {
          signatureDataUrl = '';
        }
      }
      const signedAt = new Date();
      const signedAtIso = signedAt.toISOString();

      submitting = true;
      if (submitBtn) submitBtn.disabled = true;
      if (spinner) spinner.hidden = false;
      if (submitLabel) submitLabel.textContent = 'Signature…';

      try {
        // Corps RÉTRO-COMPATIBLE : base (token/nom/option) + champs optionnels
        // (signature, consentement, horodatage) que le backend peut ignorer.
        const richBody = buildAcceptBodyRich(state, cfg.twoOptions, {
          signature_data_url: signatureDataUrl,
          consent_esign: true,
          signed_at_client: signedAtIso,
        });
        const res = await fetch('/api/proposition-accept', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({
            token: cfg.token,
            twoOptions: cfg.twoOptions,
            ...richBody,
          }),
        });
        const data = (await res.json()) as {
          ok?: boolean;
          detail?: string;
          accepte_par_nom?: string;
        };
        if (res.ok && data.ok) {
          showSuccess(data.accepte_par_nom || nom.trim(), frenchStamp(signedAt));
          return;
        }
        // 400 / 409 / 404 : message backend inline. 409 = déjà accepté →
        // on bascule quand même sur l'état confirmé (double-clic sûr).
        if (res.status === 409) {
          showSuccess(data.accepte_par_nom || nom.trim());
          return;
        }
        showError(data.detail || 'Une erreur est survenue. Veuillez réessayer.');
      } catch {
        showError('Service momentanément indisponible. Veuillez réessayer.');
      } finally {
        submitting = false;
        if (submitBtn) submitBtn.disabled = false;
        if (spinner) spinner.hidden = true;
        if (submitLabel) submitLabel.textContent = 'Signer en ligne';
      }
    });
  }
</script>

<script>
  // ── WJ25/WJ27 — boot DIFFÉRÉ de la visionneuse 3D (jamais au premier paint).
  // Three.js est chargé par import() dynamique : au scroll (IntersectionObserver)
  // en conditions normales, UNIQUEMENT au tap en reduced-motion / Save-Data.
  // Échec WebGL / import → le poster (photo d'étude) reste, avec une note claire.
  import type { ViewerModel } from '../../lib/proposition';

  const section3d = document.getElementById('roof3d');
  const stage = document.getElementById('roof3d-stage');
  const overlay = document.getElementById('roof3d-overlay');
  const startBtn = document.getElementById('roof3d-start') as HTMLButtonElement | null;
  const noteEl = document.getElementById('roof3d-note');
  const hintEl = document.getElementById('roof3d-hint');

  if (section3d && stage && section3d.dataset.viewerConfig) {
    let model: ViewerModel | null = null;
    try {
      model = (JSON.parse(section3d.dataset.viewerConfig) as { model: ViewerModel }).model;
    } catch {
      model = null;
    }

    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const nav = navigator as Navigator & { deviceMemory?: number; connection?: { saveData?: boolean } };
    const lowEnd = (nav.deviceMemory != null && nav.deviceMemory <= 4) || (navigator.hardwareConcurrency || 8) <= 4;
    const saveData = nav.connection?.saveData === true;

    let booted = false;
    let handle: { dispose: () => void } | null = null;

    function showFallback(msg: string): void {
      if (startBtn) startBtn.hidden = true;
      if (noteEl) noteEl.textContent = msg;
    }

    async function boot(): Promise<void> {
      if (booted || !model || !stage) return;
      booted = true;
      if (startBtn) startBtn.disabled = true;
      try {
        const mod = await import('../../scripts/roofPro11/viewerOnly');
        if (!mod.webglAvailable()) {
          showFallback('Vue 3D indisponible sur cet appareil — voici la photo de votre étude.');
          return;
        }
        handle = mod.createRoofViewer(stage, model, {
          reducedMotion: reduced,
          lowEnd,
          onReady: () => {
            if (overlay) overlay.hidden = true;
            if (hintEl) hintEl.hidden = false;
          },
          onFail: () => {
            if (overlay) overlay.hidden = false;
            showFallback('Vue 3D interrompue — voici la photo de votre étude.');
          },
        });
        if (!handle) {
          showFallback('Vue 3D indisponible sur cet appareil — voici la photo de votre étude.');
        }
      } catch {
        // Réseau lent / import échoué : le poster reste, message honnête.
        showFallback('Vue 3D momentanément indisponible — voici la photo de votre étude.');
      }
    }

    startBtn?.addEventListener('click', () => void boot());

    // Conditions normales : pré-charge au scroll (proche du viewport). En
    // reduced-motion ou Save-Data : rien ne bouge/charge sans geste explicite.
    if (!reduced && !saveData && 'IntersectionObserver' in window) {
      const io = new IntersectionObserver(
        (entries) => {
          if (entries.some((e) => e.isIntersecting)) {
            io.disconnect();
            void boot();
          }
        },
        { rootMargin: '200px' },
      );
      io.observe(section3d);
    }

    // Libère le GPU au départ de la page (aucune fuite de contexte WebGL).
    window.addEventListener('pagehide', () => {
      handle?.dispose();
      handle = null;
    });
  }

  // ── WJ26 — visite guidée : surlignage d'étape (progressive enhancement).
  // Les 4 étapes sont TOUJOURS toutes visibles (zéro mouvement, zéro CLS,
  // lisible sans JS) ; Précédent/Suivant ne déplacent que le surlignage +
  // l'annonce aria-live. Rien n'anime la caméra 3D (reduced-motion-safe).
  const walk = document.getElementById('roof3d-walk');
  if (walk) {
    const steps = Array.from(walk.querySelectorAll<HTMLElement>('.walk-step'));
    const prev = document.getElementById('roof3d-walk-prev') as HTMLButtonElement | null;
    const next = document.getElementById('roof3d-walk-next') as HTMLButtonElement | null;
    const count = document.getElementById('roof3d-walk-count');
    let idx = 0;
    function setStep(i: number): void {
      idx = Math.max(0, Math.min(steps.length - 1, i));
      steps.forEach((s, j) => {
        if (j === idx) s.setAttribute('aria-current', 'step');
        else s.removeAttribute('aria-current');
      });
      if (prev) prev.disabled = idx === 0;
      if (next) next.disabled = idx === steps.length - 1;
      if (count) count.textContent = `Étape ${idx + 1} sur ${steps.length}`;
    }
    prev?.addEventListener('click', () => setStep(idx - 1));
    next?.addEventListener('click', () => setStep(idx + 1));
    setStep(0);
  }
</script>

<style>
  /* P2 — réserve le ratio du graphe (viewBox 360×150 = 2.4:1) AVANT le rendu du
     SVG inline pour garantir zéro CLS. Le SVG enfant occupe 100 % de la largeur,
     hauteur auto ; aucune transition (mouvement réduit respecté par construction). */
  .chart-svg {
    width: 100%;
    aspect-ratio: 360 / 150;
  }
  .chart-svg :global(svg) {
    display: block;
    width: 100%;
    height: 100%;
  }

  /* WJ16 — courbe journalière : ratio réservé AVANT rendu (viewBox 360×170)
     → zéro CLS. Le SVG enfant occupe 100 % de la largeur. */
  .daily-curve-wrap {
    width: 100%;
    aspect-ratio: 360 / 170;
  }
  .daily-curve-wrap :global(svg) {
    display: block;
    width: 100%;
    height: 100%;
  }

  /* WJ11 — pad de signature : hauteur fixe (zéro CLS) ; pas de débordement.
     touch-none (classe utilitaire) empêche le scroll pendant le tracé. */
  .sign-pad {
    height: 160px;
    cursor: crosshair;
  }

  /* WJ25/WJ27 — scène 3D : ratio RÉSERVÉ avant tout chargement (zéro CLS).
     Le poster occupe la boîte ; le canvas (créé par la visionneuse) la recouvre.
     touch-action: none sur le canvas = orbite/pinch sans scroller la page. */
  .roof3d-stage {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 10;
    background: var(--color-azur-950, #0a1a33);
  }
  .roof3d-stage :global(canvas) {
    touch-action: none;
    cursor: grab;
  }
  .roof3d-stage :global(canvas:active) {
    cursor: grabbing;
  }
  /* Scrim léger pour la lisibilité du bouton/note posés sur la photo. */
  .roof3d-scrim {
    background: linear-gradient(to top, rgb(7 11 29 / 0.55), rgb(7 11 29 / 0.15));
  }

  /* WJ26 — étape active de la visite guidée : simple surlignage laiton (aucun
     mouvement, aucune hauteur qui change → zéro CLS, reduced-motion-safe). */
  .walk-step[aria-current='step'] {
    border-color: rgb(232 181 74 / 0.45);
  }

  /* WJ16 — animation : tracé des courbes + lever de soleil, GATÉE derrière
     prefers-reduced-motion. Sans préférence de mouvement, les courbes sont
     dessinées statiquement (dasharray neutre) — jamais cachées. */
  @media (prefers-reduced-motion: no-preference) {
    /* La ligne de production est tracée (dasharray sur une ligne pleine). */
    .daily-curve-wrap :global(.curve-solar-line) {
      stroke-dasharray: 600;
      stroke-dashoffset: 600;
      animation: curve-draw 1.6s ease-out forwards;
    }
    /* La conso (pointillée 4 3) ne peut pas être « tracée » sans casser son
       motif : on la fait simplement apparaître en fondu, motif préservé. */
    .daily-curve-wrap :global(.curve-cons-line) {
      opacity: 0;
      animation: curve-fade 1s ease-out 0.6s forwards;
    }
    .daily-curve-wrap :global(.curve-solar-fill) {
      opacity: 0;
      animation: curve-fade 1.2s ease-out 0.8s forwards;
    }
    .daily-curve-wrap :global(.curve-sun) {
      transform-box: fill-box;
      transform-origin: center;
      opacity: 0;
      animation: sun-rise 1.4s ease-out 0.3s forwards;
    }
  }
  @keyframes curve-draw {
    to { stroke-dashoffset: 0; }
  }
  @keyframes curve-fade {
    to { opacity: 1; }
  }
  @keyframes sun-rise {
    from { opacity: 0; transform: translateY(10px) scale(0.6); }
    to { opacity: 0.9; transform: translateY(0) scale(1); }
  }
</style>
