      )}


      <!-- ── CTA COLLANT (WJ34 — safe-area-inset-bottom pour les iPhone à encoche
           / barre de geste : le CTA ne se cache jamais derrière la zone système).
           WJ82 — sur une offre morte (refusée/expirée/retirée), le CTA de
           signature devient « Demander un devis actualisé » pointant vers le
           contact WhatsApp plutôt que vers le formulaire supprimé.
           WJ56 — QA tablette/desktop (présentation en direct par un commercial) :
           les grilles passent en multi-colonnes dès `sm:` (640px, couvre tablette
           portrait/paysage ET desktop) ; le CTA collant reste `fixed inset-x-0`
           pleine largeur avec conteneur interne `max-w-4xl` centré à toutes les
           largeurs ; la bascule de langue (`fixed top-3 right-3`) et le bouton
           « Partager » (flux normal, jamais `fixed`) ne se chevauchent à aucune
           largeur testée. Aucune régression de layout introduite par WJ53/WJ56. -->
      <div
        id="sticky-cta"
        class="fixed inset-x-0 bottom-0 z-40 border-t border-white/10 bg-nuit-800/95 px-4 pt-3 backdrop-blur supports-[backdrop-filter]:bg-nuit-800/80"
        style="padding-bottom: max(0.75rem, env(safe-area-inset-bottom));"
      >
        <div class="mx-auto flex max-w-4xl items-center justify-between gap-4">
          <div class="min-w-0">
            {heroHasRealPrice ? (
              <p class="truncate text-sm text-lune-soft">
                <span data-i18n data-fr={twoOptions ? 'À partir de ' : ''} data-en={twoOptions ? 'From ' : ''} data-ar={twoOptions ? 'ابتداءً من ' : ''}>{twoOptions ? 'À partir de ' : ''}</span>
                <span class="lum fig text-lg" dir="ltr">{formatMAD(optionTtc(data!, reco ?? 'sans_batterie'))}</span>
                <span class="text-lune-faint" data-i18n data-fr=" TTC" data-en=" incl. tax" data-ar=" شامل الضريبة"> TTC</span>
              </p>
            ) : (
              <!-- WJ83 — garde-fou zéro-total : jamais "0 MAD TTC" comme un
                   vrai prix. -->
              <p class="truncate text-sm text-lune-soft" data-i18n
                data-fr="Prix communiqué par votre conseiller"
                data-en="Price provided by your advisor"
                data-ar="السعر يُبلَّغ من طرف مستشاركم">
                Prix communiqué par votre conseiller
              </p>
            )}
            {validity.fromBackend && validity.label && !validity.expired && (
              <p class="truncate text-xs text-lune-faint">
                <span data-i18n data-fr="Valable jusqu’au" data-en="Valid until" data-ar="صالح حتى">Valable jusqu’au</span> <span dir="ltr">{validity.label}</span>
              </p>
            )}
          </div>
          {isOfferDead(offerState) ? (
            <a
              href={waLink}
              target="_blank"
              rel="noopener noreferrer"
              class="btn-pill shrink-0 whitespace-nowrap"
              style="background: var(--color-brass-400); color: var(--color-nuit); border-color: var(--color-brass-400)"
              data-i18n data-fr="Demander un devis actualisé" data-en="Request an updated quote" data-ar="طلب عرض محدّث"
            >
              Demander un devis actualisé
            </a>
          ) : heroHasRealPrice ? (
            <a
              href="#signer"
              class="btn-pill shrink-0 whitespace-nowrap"
              style="background: var(--color-brass-400); color: var(--color-nuit); border-color: var(--color-brass-400)"
              data-i18n data-fr="Signer en ligne" data-en="Sign online" data-ar="التوقيع إلكترونياً"
            >
              Signer en ligne
            </a>
          ) : (
            <!-- WJ83 — sans prix réel, le CTA principal ne peut pas pointer vers
                 une signature à 0 MAD : on renvoie vers le conseiller (WhatsApp),
                 jamais vers un formulaire de signature sur un montant fabriqué. -->
            <a
              href={waLink}
              target="_blank"
              rel="noopener noreferrer"
              class="btn-pill shrink-0 whitespace-nowrap"
              style="background: var(--color-brass-400); color: var(--color-nuit); border-color: var(--color-brass-400)"
              data-i18n data-fr="Contacter mon conseiller" data-en="Contact my advisor" data-ar="التواصل مع مستشاري"
            >
              Contacter mon conseiller
            </a>
          )}
        </div>
      </div>
    </div>
  )}
</Layout>

<script>
  import {
    validateSign,
    buildAcceptBodyRich,
    signStampLabel,
    localizedStamp,
    isOtpRequiredDetail,
    isOtpIncorrectDetail,
    type OptionKey,
    type SignFormState,
    type PropLang as SignPropLang,
  } from '../../lib/proposition';

  interface SignConfig {
    token: string;
    twoOptions: boolean;
    preselect: OptionKey | null;
    accepted: boolean;
    acceptedName: string;
    reference: string;
    /** WJ55 — présent uniquement quand le devis porte un téléphone client. */
    clientPhone?: string;
  }

  // ── WJ17/WJ43 · bascule de langue FR/EN/عربي — MÊME mécanisme dual-node que
  // WJ33 (mon-toit.astro), élargi en TRI-node par WJ43 : `el.textContent = v`
  // APLATIRAIT toute balise imbriquée (ex. <strong> dans un data-i18n) à chaque
  // aller-retour. On enveloppe donc chaque élément `[data-i18n]` d'un TRIPLET de
  // nœuds show/hide au premier passage (FR = markup ORIGINAL capturé une fois
  // via innerHTML, EN = texte simple depuis data-en, AR = texte simple depuis
  // data-ar), puis on masque/affiche le bon nœud — aucune balise n'est jamais
  // perdue, quel que soit le nombre de bascules. Un élément SANS `data-en`
  // (ne devrait pas arriver — chaque data-i18n doit porter les 3 langues) replie
  // simplement sur le markup FR en mode EN plutôt que de planter.
  type PropLang = 'fr' | 'en' | 'ar';
  let currentLang: PropLang = 'fr';
  // WJ119 — variante de la courbe journalière (été/Ramadan, toggle discret,
  // résidentiel/commercial uniquement) : croisée avec currentLang ci-dessous
  // (un bloc n'est visible que si lang ET variante correspondent toutes deux).
  type CurveVariantId = 'normal' | 'ete' | 'ramadan';
  let currentCurveVariant: CurveVariantId = 'normal';
  /** Filtre lang+variant partagé par applyLang() et le toggle été/Ramadan. */
  function applyCurveVisibility(): void {
    document.querySelectorAll<HTMLElement>('[data-curve-lang]').forEach((el) => {
      const variant = (el.dataset.curveVariant as CurveVariantId | undefined) ?? 'normal';
      el.hidden = el.dataset.curveLang !== currentLang || variant !== currentCurveVariant;
    });
  }
  const i18nTriples: Array<{ fr: HTMLElement; en: HTMLElement; ar: HTMLElement }> = [];
  /** Registre des labels à retraduire à chaque bascule (busy-state, non couverts par data-i18n). */
  const propI18nBusyLabels: Array<(lang: PropLang) => void> = [];
  function prepareI18n(): void {
    document.querySelectorAll<HTMLElement>('[data-i18n]').forEach((el) => {
      const arText = el.dataset.ar;
      if (typeof arText !== 'string') return;
      const enText = typeof el.dataset.en === 'string' ? el.dataset.en : el.innerHTML;
      const frSpan = document.createElement('span');
      frSpan.innerHTML = el.innerHTML;
      const enSpan = document.createElement('span');
      enSpan.textContent = enText;
      enSpan.hidden = true;
      const arSpan = document.createElement('span');
      arSpan.textContent = arText;
      arSpan.hidden = true;
      el.textContent = '';
      el.append(frSpan, enSpan, arSpan);
      i18nTriples.push({ fr: frSpan, en: enSpan, ar: arSpan });
    });
  }
  function applyLang(lang: PropLang): void {
    const isAr = lang === 'ar';
    const isEn = lang === 'en';
    currentLang = lang;
    i18nTriples.forEach(({ fr, en, ar }) => {
      fr.hidden = isAr || isEn;
      en.hidden = !isEn;
      ar.hidden = !isAr;
    });
    // RTL/langue au niveau DOCUMENT (pas seulement un bloc local) : un lecteur
    // d'écran ou le rendu natif du navigateur doivent voir la vraie langue.
    document.documentElement.lang = isAr ? 'ar' : isEn ? 'en' : 'fr';
    document.documentElement.dir = isAr ? 'rtl' : 'ltr';
    const propRoot = document.querySelector<HTMLElement>('.proposition');
    if (propRoot) {
      propRoot.dir = isAr ? 'rtl' : 'ltr';
      propRoot.style.lineHeight = isAr ? '1.75' : '';
    }
    const frBtn = document.getElementById('prop-lang-fr');
    const enBtn = document.getElementById('prop-lang-en');
    const arBtn = document.getElementById('prop-lang-ar');
    frBtn?.setAttribute('aria-pressed', String(!isAr && !isEn));
    enBtn?.setAttribute('aria-pressed', String(isEn));
    arBtn?.setAttribute('aria-pressed', String(isAr));
    for (const [btn, on] of [[frBtn, !isAr && !isEn], [enBtn, isEn], [arBtn, isAr]] as const) {
      if (!btn) continue;
      btn.className = on
        ? 'px-2.5 py-1 text-xs font-semibold text-azur-950 bg-brass-400 transition-colors'
        : 'px-2.5 py-1 text-xs font-semibold text-lune-soft transition-colors hover:text-white';
    }
    // Labels pilotés par un état transitoire (ex. « Signature… », « Génération
    // du PDF… ») ne passent pas par prepareI18n (ils sont réécrits en JS APRÈS
    // le premier rendu) : on les retraduit ici, à chaque bascule ET après
    // chaque changement d'état, via un petit registre partagé.
    propI18nBusyLabels.forEach((fn) => fn(currentLang));
    // WJ80 — bascule des TROIS variantes langue pré-rendues du graphe
    // production-vs-consommation et de la courbe journalière (chacune posée
    // dans le DOM au premier rendu serveur, voir data-chart-lang/data-curve-lang) :
    // même logique show/hide que les triplets data-i18n ci-dessus.
    document.querySelectorAll<HTMLElement>('[data-chart-lang]').forEach((el) => {
      el.hidden = el.dataset.chartLang !== currentLang;
    });
    // WJ119 — les blocs `[data-curve-lang]` portent AUSSI `data-curve-variant`
    // (été/Ramadan) : le filtre partagé applyCurveVisibility() gère les deux.
    applyCurveVisibility();
    // WJ87 — les attributs `placeholder` ne sont pas couverts par le mécanisme
    // data-i18n (qui ne touche que le contenu affiché) : ce petit registre
    // dédié retraduit les placeholders posés via data-placeholder-{fr,en,ar}
    // à chaque bascule de langue.
    document.querySelectorAll<HTMLInputElement>('[data-i18n-placeholder]').forEach((el) => {
      const value = isAr ? el.dataset.placeholderAr : isEn ? el.dataset.placeholderEn : el.dataset.placeholderFr;
      if (typeof value === 'string') el.placeholder = value;
    });
    // WJ99 — même registre que les placeholders ci-dessus, mais pour
    // `aria-label` : cet attribut n'est PAS couvert par le mécanisme data-i18n
    // (qui ne touche que le contenu affiché des nœuds `data-i18n`) — sans ce
    // retraduction, un `aria-label` posé au premier rendu restait figé en
    // français même après bascule EN/AR (CertLogoRow.astro `data-aria-label-*`,
    // le canevas de signature `data-aria-label-*` ci-dessous).
    document.querySelectorAll<HTMLElement>('[data-aria-label-fr]').forEach((el) => {
      const value = isAr ? el.dataset.ariaLabelAr : isEn ? el.dataset.ariaLabelEn : el.dataset.ariaLabelFr;
      if (typeof value === 'string') el.setAttribute('aria-label', value);
    });
  }
  prepareI18n();
  document.getElementById('prop-lang-fr')?.addEventListener('click', () => applyLang('fr'));
  document.getElementById('prop-lang-en')?.addEventListener('click', () => applyLang('en'));
  document.getElementById('prop-lang-ar')?.addEventListener('click', () => applyLang('ar'));
  // WJ119 — toggle discret été/Ramadan de la courbe journalière (résidentiel/
  // commercial uniquement — absent du DOM sinon, la boucle ne trouve alors
  // aucun bouton et ne fait rien). Change UNIQUEMENT la silhouette affichée.
  function applyCurveVariant(variant: CurveVariantId): void {
    currentCurveVariant = variant;
    document.querySelectorAll<HTMLElement>('[data-curve-variant-btn]').forEach((btn) => {
      const on = btn.getAttribute('data-curve-variant-btn') === variant;
      btn.setAttribute('aria-pressed', String(on));
      btn.setAttribute(
        'style',
        on ? 'background: var(--color-brass-400); color: var(--color-nuit); border-color: var(--color-brass-400)' : '',
      );
    });
    applyCurveVisibility();
  }
  document.querySelectorAll<HTMLElement>('[data-curve-variant-btn]').forEach((btn) => {
    const variant = btn.getAttribute('data-curve-variant-btn') as CurveVariantId | null;
    if (variant) btn.addEventListener('click', () => applyCurveVariant(variant));
  });
  // Exposé aux AUTRES <script> de cette page (PDF affordance) — chaque bloc
  // <script> d'une île Astro est un module séparé, donc pas de portée
  // partagée native ; `window` est le pont volontairement minimal ici.
  (window as unknown as { __propApplyLang?: (l: PropLang) => void }).__propApplyLang = applyLang;
  (window as unknown as { __propCurrentLang?: () => PropLang }).__propCurrentLang = () => currentLang;
  (window as unknown as { __propRegisterBusyLabel?: (fn: (l: PropLang) => void) => void }).__propRegisterBusyLabel =
    (fn: (l: PropLang) => void) => propI18nBusyLabels.push(fn);

  // ——— WJ45 : bandeau hors-ligne (navigator.onLine + online/offline) ———
  // Une coupure réseau au moment de signer ne doit jamais ressembler à un
  // échec muet : le bandeau apparaît/disparaît en direct, indépendamment de
  // toute soumission. Exposé sur `window` pour que le formulaire de
  // signature (autre <script>/module plus bas) puisse re-vérifier l'état
  // au moment précis d'un échec fetch.
  const propOfflineBanner = document.getElementById('prop-offline-banner');
  function syncPropOfflineBanner(): void {
    if (propOfflineBanner) propOfflineBanner.hidden = navigator.onLine;
  }
  syncPropOfflineBanner();
  window.addEventListener('online', syncPropOfflineBanner);
  window.addEventListener('offline', syncPropOfflineBanner);
  (window as unknown as { __propSyncOfflineBanner?: () => void }).__propSyncOfflineBanner = syncPropOfflineBanner;

  const root = document.querySelector<HTMLElement>('.proposition');
  const raw = root?.dataset.signConfig;
  if (root && raw) {
    const cfg = JSON.parse(raw) as SignConfig;

    // ── WJ55 · Télémétrie de vue/engagement — proxy same-origin vers le fil
    // lead existant (voir lib/proposition.ts buildProposalTrackPayload pour le
    // garde-fou anti-pollution CRM : sans téléphone client, rien n'est posté).
    // Best-effort strict, `keepalive` pour survivre à une navigation immédiate.
    const sentTrackEvents = new Set<string>();
    function trackProposalEvent(event: 'proposal_first_view' | 'proposal_scrolled_financing'): void {
      if (sentTrackEvents.has(event)) return; // une fois par événement/session de page
      sentTrackEvents.add(event);
      fetch('/api/proposition-track', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        keepalive: true,
        body: JSON.stringify({
          token: cfg.token,
          reference: cfg.reference,
          clientPhone: cfg.clientPhone ?? '',
          event,
        }),
      }).catch(() => {
        // Jamais bloquant : une panne réseau ne doit rien changer côté client.
      });
    }
    trackProposalEvent('proposal_first_view');
    // Défilement jusqu'au bloc financement (« Argent dans le temps » — WJ9,
    // id="financing-headline") : le moment où le client regarde vraiment les
    // chiffres. Observé une seule fois (IntersectionObserver déconnecté après
    // le premier passage). Absent quand le backend ne fournit aucun chiffre
    // d'économie (headline vide) — rien à observer alors.
    const financingSection = document.getElementById('financing-headline');
    if (financingSection && 'IntersectionObserver' in window) {
      const financingIo = new IntersectionObserver(
        (entries) => {
          if (entries.some((e) => e.isIntersecting)) {
            financingIo.disconnect();
            trackProposalEvent('proposal_scrolled_financing');
          }
        },
        { threshold: 0.4 },
      );
      financingIo.observe(financingSection);
    }

    // ── WJ104 — DELTA d'instrumentation funnel : `proposal_viewed`/
    // `proposal_signed` via le MÊME beacon step-level que /devis/mon-toit
    // (WJ59 `pages/api/funnel-beacon.ts` → FUNNEL_WEBHOOK_URL, log-only sinon)
    // — jamais le fil lead (voir WJ109 ci-dessus pour la distinction), jamais
    // un second canal. Session token anonyme PAR ONGLET, même contrat privacy
    // que mon-toit.astro (lib/funnelBeacon.ts : 4 champs seulement, aucune PII).
    const PROPOSAL_FUNNEL_TOKEN_KEY = 'prop-funnel-token-v1';
    function getProposalFunnelToken(): string {
      try {
        let t = sessionStorage.getItem(PROPOSAL_FUNNEL_TOKEN_KEY);
        if (!t) {
          t = Math.random().toString(36).slice(2) + Date.now().toString(36);
          sessionStorage.setItem(PROPOSAL_FUNNEL_TOKEN_KEY, t);
        }
        return t;
      } catch {
        return Math.random().toString(36).slice(2);
      }
    }
    const proposalFunnelToken = getProposalFunnelToken();
    const proposalFunnelSent = new Set<string>();
    function sendProposalFunnelBeacon(action: 'viewed' | 'signed'): void {
      const key = `proposal:${action}`;
      if (proposalFunnelSent.has(key)) return;
      proposalFunnelSent.add(key);
      try {
        const payload = JSON.stringify({
          step: 'proposal',
          action,
          sessionToken: proposalFunnelToken,
          path: location.pathname,
        });
        if (navigator.sendBeacon) {
          navigator.sendBeacon('/api/funnel-beacon', new Blob([payload], { type: 'application/json' }));
        } else {
          void fetch('/api/funnel-beacon', { method: 'POST', headers: { 'content-type': 'application/json' }, body: payload, keepalive: true }).catch(() => {});
        }
      } catch {
        // Mesure best-effort seulement — ne doit jamais perturber le parcours.
      }
    }
    sendProposalFunnelBeacon('viewed');

    const form = document.getElementById('sign-form') as HTMLFormElement | null;
    const success = document.getElementById('sign-success');
    const successName = document.getElementById('sign-success-name');
    const successTime = document.getElementById('sign-success-time');
    // WJ78 — écho de l'artefact du client dans le bloc de succès.
    const successEchoImg = document.getElementById('sign-success-echo-img') as HTMLImageElement | null;
    const successEchoSeal = document.getElementById('sign-success-echo-seal');
    const stampEl = document.getElementById('sign-stamp');
    const errorEl = document.getElementById('sign-error');
    const submitBtn = document.getElementById('sign-submit') as HTMLButtonElement | null;
    const submitLabel = document.getElementById('sign-submit-label');
    const spinner = document.getElementById('sign-spinner');
    // ── WJ17/WJ43 — état « Signature… » n'est pas couvert par prepareI18n (il
    // écrase le libellé APRÈS le premier rendu) : on le pilote via un petit
    // état + le registre partagé, pour rester correct FR/EN/AR à chaque bascule.
    let submitBusy = false;
    const SUBMIT_LABEL = { fr: 'Signer en ligne', en: 'Sign online', ar: 'التوقيع إلكترونياً' } as const;
    const SUBMIT_LABEL_BUSY = { fr: 'Signature…', en: 'Signing…', ar: 'جارٍ التوقيع…' } as const;
    function renderSubmitLabel(lang: PropLang): void {
      if (!submitLabel) return;
      submitLabel.textContent = submitBusy ? SUBMIT_LABEL_BUSY[lang] : SUBMIT_LABEL[lang];
    }
    propI18nBusyLabels.push(renderSubmitLabel);
    const sticky = document.getElementById('sticky-cta');

    // ── WJ11 · Pad de signature manuscrite (canvas natif, tactile + souris) ──
    const canvas = document.getElementById('sign-pad') as HTMLCanvasElement | null;
    const clearBtn = document.getElementById('sign-clear');
    let hasInk = false;

    function setupSignaturePad(c: HTMLCanvasElement): void {
      // Adapte la résolution interne au DPR pour un trait net (sans CLS : la
      // hauteur CSS est fixée par .sign-pad, on n'ajuste que le bitmap).
      const ctx = c.getContext('2d');
      if (!ctx) return;
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      const resize = (): void => {
        const rect = c.getBoundingClientRect();
        if (rect.width === 0) return;
        c.width = Math.round(rect.width * dpr);
        c.height = Math.round(rect.height * dpr);
        ctx.scale(dpr, dpr);
        ctx.lineWidth = 2.2;
        ctx.lineJoin = 'round';
        ctx.lineCap = 'round';
        ctx.strokeStyle = '#f3cc66';
      };
      resize();
      window.addEventListener('resize', resize);

      let drawing = false;
      const pos = (e: PointerEvent): { x: number; y: number } => {
        const rect = c.getBoundingClientRect();
        return { x: e.clientX - rect.left, y: e.clientY - rect.top };
      };
      c.addEventListener('pointerdown', (e) => {
        drawing = true;
        hasInk = true;
        const p = pos(e);
        ctx.beginPath();
        ctx.moveTo(p.x, p.y);
        c.setPointerCapture(e.pointerId);
        e.preventDefault();
      });
      c.addEventListener('pointermove', (e) => {
        if (!drawing) return;
        const p = pos(e);
        ctx.lineTo(p.x, p.y);
        ctx.stroke();
        e.preventDefault();
      });
      const stop = (): void => { drawing = false; };
      c.addEventListener('pointerup', stop);
      c.addEventListener('pointercancel', stop);
      c.addEventListener('pointerleave', stop);
    }
    if (canvas) setupSignaturePad(canvas);

    function clearSignature(): void {
      if (!canvas) return;
      const ctx = canvas.getContext('2d');
      if (ctx) ctx.clearRect(0, 0, canvas.width, canvas.height);
      hasInk = false;
    }
    clearBtn?.addEventListener('click', clearSignature);

    // WJ101 — affordance clavier explicite : le canvas de signature reste
    // pointeur-seul (dessiner au clavier n'a pas de sens), mais un visiteur au
    // clavier ne doit pas rester bloqué à se demander comment continuer. Ce
    // bouton avance simplement le focus vers le champ nom — aucune signature
    // n'est requise : la validation (validateSign, lib/proposition.ts) n'a
    // jamais exigé de trait dessiné, seulement le nom + (si deux options)
    // l'option choisie.
    document.getElementById('sign-pad-skip')?.addEventListener('click', () => {
      (document.getElementById('sign-nom') as HTMLInputElement | null)?.focus();
    });

    // ── WJ108 · OTP e-signature — LATENT tant que le backend n'exige rien ────
    // (ESIGN_OTP_ENABLED côté ERP). Ce bloc reste masqué et n'affecte AUCUNE
    // soumission tant que /accept/ ne renvoie pas l'un des 3 messages
    // reconnus par isOtpRequiredDetail (lib/proposition.ts) — comportement
    // d'aujourd'hui inchangé.
    const otpBlock = document.getElementById('sign-otp-block');
    const otpCodeInput = document.getElementById('sign-otp-code') as HTMLInputElement | null;
    const otpRequestBtn = document.getElementById('sign-otp-request') as HTMLButtonElement | null;
    const otpStatusEl = document.getElementById('sign-otp-status');
    const OTP_SENT_MSG: Record<PropLang, string> = {
      fr: 'Code envoyé — vérifiez WhatsApp ou vos e-mails.',
      en: 'Code sent — check WhatsApp or your email.',
      ar: 'تم إرسال الرمز — تحققوا من واتساب أو بريدكم الإلكتروني.',
    };
    const OTP_SEND_FAILED_MSG: Record<PropLang, string> = {
      fr: 'Impossible d\'envoyer le code pour le moment. Réessayez.',
      en: 'Could not send the code right now. Please try again.',
      ar: 'تعذر إرسال الرمز حالياً. يرجى إعادة المحاولة.',
    };
    function revealOtpBlock(): void {
      if (otpBlock) otpBlock.hidden = false;
      otpCodeInput?.focus();
    }
    otpRequestBtn?.addEventListener('click', async () => {
      if (!otpRequestBtn) return;
      otpRequestBtn.disabled = true;
      try {
        const res = await fetch('/api/proposition-otp', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ token: cfg.token }),
        });
        const data = (await res.json().catch(() => ({}))) as { ok?: boolean };
        if (otpStatusEl) {
          otpStatusEl.textContent = data.ok ? OTP_SENT_MSG[currentLang] : OTP_SEND_FAILED_MSG[currentLang];
          otpStatusEl.hidden = false;
        }
      } catch {
        if (otpStatusEl) {
          otpStatusEl.textContent = OTP_SEND_FAILED_MSG[currentLang];
          otpStatusEl.hidden = false;
        }
      } finally {
        otpRequestBtn.disabled = false;
      }
    });

    // ── WJ42 — Horodatage localisé (FR/EN/AR), affiché en direct dans le récap.
    // AVANT : `stampEl.textContent = frenchStamp(now)` écrasait le markup
    // tri-node data-i18n du <p id="sign-stamp"> (ses deux <span data-i18n>
    // portant Réf./« l'horodatage s'affichera ici ») avec une chaîne FR figée,
    // JAMAIS ré-inscrite dans `propI18nBusyLabels` — résultat : au moindre
    // aller-retour de langue, cette seule ligne restait en français au beau
    // milieu d'une page par ailleurs pleinement AR (ou EN). Cette fonction est
    // désormais une busy-label REGISTRÉE (même discipline que
    // `renderSubmitLabel`) : elle régénère tout le texte, dans la langue
    // courante, à CHAQUE bascule — jamais un remplacement ponctuel figé.
    const signedAtLocal = new Date();
    function renderStamp(lang: PropLang): void {
      if (!stampEl) return;
      stampEl.textContent = signStampLabel(cfg.reference, signedAtLocal, lang as SignPropLang);
    }
    propI18nBusyLabels.push(renderStamp);
    renderStamp(currentLang);

    function showError(msg: string): void {
      if (!errorEl) return;
      errorEl.textContent = msg;
      errorEl.hidden = false;
    }
    function clearError(): void {
      if (errorEl) errorEl.hidden = true;
    }
    // ── WJ42 — `successTime` portait le même défaut que le stamp : une chaîne
    // FR figée (« · signé le … ») jamais ré-inscrite au registre. `signedWhen`
    // garde la Date brute ; `renderSuccessTime` (busy-label enregistrée) la
    // reformate dans la langue courante à chaque bascule.
    let signedWhen: Date | null = null;
    const SUCCESS_TIME_PREFIX = { fr: ' · signé le ', en: ' · signed on ', ar: ' · تم التوقيع بتاريخ ' } as const;
    function renderSuccessTime(lang: PropLang): void {
      if (!successTime) return;
      successTime.textContent = signedWhen
        ? `${SUCCESS_TIME_PREFIX[lang]}${localizedStamp(signedWhen, lang as SignPropLang)}`
        : '';
    }
    propI18nBusyLabels.push(renderSuccessTime);
    // WJ78 — « le moment après la signature » : accusé visuel + écho de
    // l'artefact du client + scroll dans la vue (reduced-motion-safe : le
    // scroll lui-même n'est pas une "animation" au sens strict, mais on lui
    // demande explicitement un comportement 'auto' — pas de smooth-scroll
    // forcé — quand le client préfère un mouvement réduit).
    function showSuccess(name: string, when?: Date, signatureDataUrl?: string, scrollIntoView = false): void {
      // WJ104 — « proposition signée » : émis à chaque affichage de l'état
      // confirmé (chargement déjà accepté OU signature qui vient d'aboutir),
      // dédupliqué comme les autres beacons (une fois par onglet/session).
      sendProposalFunnelBeacon('signed');
      if (form) form.hidden = true;
      if (sticky) sticky.hidden = true;
      if (successName) successName.textContent = name || '';
      if (when) {
        signedWhen = when;
        renderSuccessTime(currentLang);
      }
      // Écho de la signature manuscrite si dessinée, sinon le sceau textuel
      // « Signature enregistrée ✓ » reste affiché (déjà visible par défaut).
      if (signatureDataUrl && successEchoImg) {
        successEchoImg.src = signatureDataUrl;
        successEchoImg.hidden = false;
        if (successEchoSeal) successEchoSeal.hidden = true;
      }
      if (success) success.hidden = false;
      if (scrollIntoView && success) {
        const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        success.scrollIntoView({ behavior: reduced ? 'auto' : 'smooth', block: 'start' });
      }
    }

    // Déjà accepté au chargement → affiche directement l'état confirmé (pas de
    // scroll : le client arrive déjà sur une page qui affiche l'état confirmé,
    // rien à "faire défiler jusqu'à" au premier paint).
    if (cfg.accepted) {
      showSuccess(cfg.acceptedName);
    }

    function selectedOption(): OptionKey | null {
      if (!cfg.twoOptions) return cfg.preselect;
      const checked = form?.querySelector<HTMLInputElement>('input[name="option"]:checked');
      return (checked?.value as OptionKey) ?? null;
    }

    let submitting = false;
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (submitting) return;
      clearError();

      const accord = (document.getElementById('sign-accord') as HTMLInputElement | null)?.checked;
      const consent = (document.getElementById('sign-consent') as HTMLInputElement | null)?.checked;
      const nom = (document.getElementById('sign-nom') as HTMLInputElement | null)?.value ?? '';
      // WJ87 — facultatif : « je signe au nom de… » (MRE signant pour ses
      // parents, foyer, etc.). Le signataire enregistré reste `nom` ci-dessus.
      const onBehalfOf = (document.getElementById('sign-on-behalf-of') as HTMLInputElement | null)?.value ?? '';
      const state: SignFormState = { nom, option: selectedOption() };

      const v = validateSign(state, cfg.twoOptions);
      if (!v.valid) {
        showError(v.error ?? 'Formulaire incomplet.');
        return;
      }
      if (!accord) {
        showError('Veuillez cocher « Bon pour accord » pour valider.');
        return;
      }
      if (!consent) {
        showError('Veuillez accepter de signer électroniquement pour continuer.');
        return;
      }

      // Capture la signature manuscrite (PNG data URL) UNIQUEMENT si dessinée.
      let signatureDataUrl = '';
      if (canvas && hasInk) {
        try {
          signatureDataUrl = canvas.toDataURL('image/png');
        } catch {
          signatureDataUrl = '';
        }
      }
      const signedAt = new Date();
      const signedAtIso = signedAt.toISOString();

      submitting = true;
      if (submitBtn) submitBtn.disabled = true;
      if (spinner) spinner.hidden = false;
      submitBusy = true;
      renderSubmitLabel(currentLang);

      // WJ81 — jamais un « Signature… » désactivé pour l'éternité : une
      // connexion lente/un backend qui ne répond pas laissait auparavant ce
      // bouton bloqué SANS limite. 15 s est le seuil documenté par le
      // founder pour ce moment de très haute intention — au-delà, on annule
      // la requête et on rend la main avec un message honnête + un chemin de
      // repli (WhatsApp, déjà visible juste au-dessus dans « Une question
      // avant de signer ? »).
      const SIGN_SUBMIT_TIMEOUT_MS = 15000;
      const submitController = new AbortController();
      const submitTimer = window.setTimeout(() => submitController.abort(), SIGN_SUBMIT_TIMEOUT_MS);
      try {
        // WJ108 — code OTP OPTIONNEL : vide tant que le bloc n'a jamais été
        // révélé (backend/toggle OFF ignore le champ vide, comportement
        // inchangé). Une fois révélé, le client peut le remplir et resoumettre.
        const otpCode = otpCodeInput?.value.trim() ?? '';
        // Corps RÉTRO-COMPATIBLE : base (token/nom/option) + champs optionnels
        // (signature, consentement, horodatage, otp_code) que le backend peut ignorer.
        const richBody = buildAcceptBodyRich(state, cfg.twoOptions, {
          signature_data_url: signatureDataUrl,
          consent_esign: true,
          signed_at_client: signedAtIso,
          on_behalf_of: onBehalfOf,
          otp_code: otpCode,
        });
        const res = await fetch('/api/proposition-accept', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({
            token: cfg.token,
            twoOptions: cfg.twoOptions,
            ...richBody,
          }),
          signal: submitController.signal,
        });
        const data = (await res.json()) as {
          ok?: boolean;
          detail?: string;
          accepte_par_nom?: string;
        };
        if (res.ok && data.ok) {
          showSuccess(data.accepte_par_nom || nom.trim(), signedAt, signatureDataUrl, true);
          return;
        }
        // 400 / 409 / 404 : message backend inline. 409 = déjà accepté →
        // on bascule quand même sur l'état confirmé (double-clic sûr).
        if (res.status === 409) {
          showSuccess(data.accepte_par_nom || nom.trim(), undefined, signatureDataUrl, true);
          return;
        }
        // WJ108 — LATENT : ce chemin ne se déclenche QUE si le backend a le
        // toggle ESIGN_OTP_ENABLED actif et renvoie l'un des 3 messages OTP
        // reconnus (isOtpRequiredDetail) — jamais aujourd'hui (toggle OFF par
        // défaut). Révèle le bloc de saisie au lieu d'un message d'erreur
        // générique, et lance automatiquement l'envoi du code la première fois.
        if (isOtpRequiredDetail(data.detail)) {
          const firstReveal = otpBlock?.hidden !== false;
          revealOtpBlock();
          showError(
            isOtpIncorrectDetail(data.detail)
              ? (data.detail ?? '')
              : 'Un code de confirmation vous a été envoyé — saisissez-le ci-dessus pour finaliser votre signature.',
          );
          if (firstReveal) otpRequestBtn?.click();
          return;
        }
        showError(data.detail || 'Une erreur est survenue. Veuillez réessayer.');
      } catch (err) {
        // WJ45 — si le navigateur se sait hors-ligne au moment de l'échec, on
        // l'affirme explicitement (bandeau + message dédié, dans la langue
        // courante) plutôt que la formule générique de panne/lenteur : rien
        // n'a été soumis, le formulaire reste rempli tel quel.
        syncPropOfflineBanner();
        if (!navigator.onLine) {
          const OFFLINE_SIGN_MSG: Record<PropLang, string> = {
            fr: 'Pas de connexion — vos réponses sont conservées, on réessaie dès le retour du réseau.',
            en: "No connection — your answers are kept, we'll retry as soon as the network is back.",
            ar: 'لا يوجد اتصال — إجاباتكم محفوظة، سنعيد المحاولة فور عودة الشبكة.',
          };
          showError(OFFLINE_SIGN_MSG[currentLang]);
        } else {
          const timedOut = err instanceof Error && err.name === 'AbortError';
          showError(
            timedOut
              ? 'La connexion est lente — réessayez, ou contactez-nous sur WhatsApp ci-dessus.'
              : 'Service momentanément indisponible. Veuillez réessayer.',
          );
        }
      } finally {
        window.clearTimeout(submitTimer);
        submitting = false;
        if (submitBtn) submitBtn.disabled = false;
        if (spinner) spinner.hidden = true;
        submitBusy = false;
        renderSubmitLabel(currentLang);
      }
    });
  }
</script>

<script>
  // ── WJ25/WJ27 — boot DIFFÉRÉ de la visionneuse 3D (jamais au premier paint).
  // Three.js est chargé par import() dynamique : au scroll (IntersectionObserver)
  // en conditions normales, UNIQUEMENT au tap en reduced-motion / Save-Data.
  // Échec WebGL / import → le poster (photo d'étude) reste, avec une note claire.
  import type { ViewerModel } from '../../lib/proposition';
  import type { RoofImageSpec } from '../../scripts/roofPro11/viewerOnly';

  const section3d = document.getElementById('roof3d');
  const stage = document.getElementById('roof3d-stage');
  const overlay = document.getElementById('roof3d-overlay');
  const startBtn = document.getElementById('roof3d-start') as HTMLButtonElement | null;
  const noteEl = document.getElementById('roof3d-note');
  const hintEl = document.getElementById('roof3d-hint');

  if (section3d && stage && section3d.dataset.viewerConfig) {
    let model: ViewerModel | null = null;
    // WJ118 — contour [lat,lng] (calculé côté serveur par
    // roofLayoutOutlineLatLng, roof_layout.zones[].vertices aplati) pour la
    // photo satellite drapée sur la 3D ; vide si aucun roof_layout exploitable
    // (le client saute alors l'appel réseau de buildPublicRoofImageSpec).
    let roofOutlineLatLng: Array<[number, number]> = [];
    try {
      const parsed = JSON.parse(section3d.dataset.viewerConfig) as {
        model: ViewerModel;
        roofOutlineLatLng?: Array<[number, number]>;
      };
      model = parsed.model;
      roofOutlineLatLng = Array.isArray(parsed.roofOutlineLatLng) ? parsed.roofOutlineLatLng : [];
    } catch {
      model = null;
    }

    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const nav = navigator as Navigator & { deviceMemory?: number; connection?: { saveData?: boolean } };

    let booted = false;
    let handle: { dispose: () => void } | null = null;

    function showFallback(msg: string): void {
      if (startBtn) startBtn.hidden = true;
      if (noteEl) noteEl.textContent = msg;
    }

    async function boot(): Promise<void> {
      if (booted || !model || !stage) return;
      booted = true;
      if (startBtn) startBtn.disabled = true;
      try {
        // WJ27 — la décision device/réseau (bas de gamme, WebGL, repli) vit dans
        // viewerOnly.viewerBootStrategy (pure, testée) : même logique ici et en
        // test, une seule source de vérité.
        const mod = await import('../../scripts/roofPro11/viewerOnly');
        const strategy = mod.viewerBootStrategy({
          deviceMemory: nav.deviceMemory,
          hardwareConcurrency: navigator.hardwareConcurrency,
          reducedMotion: reduced,
          webglAvailable: mod.webglAvailable(),
        });
        if (!strategy.canBoot) {
          showFallback(strategy.fallbackMessage ?? 'Vue 3D indisponible sur cet appareil — voici la photo de votre étude.');
          return;
        }
        // WJ118 — photo satellite RÉELLE du toit du client (contrat viewerOnly
        // ci-dessus) : TOUT échec (pas de clé MAPTILER/MAPBOX, contour < 3
        // sommets, /api/roof-config en échec, image cassée/trop lente) → null,
        // jamais un throw — createRoofViewer traite alors roofImage absent/null
        // EXACTEMENT comme avant (rendu abstrait, aucune régression).
        let roofImage: RoofImageSpec | null = null;
        if (roofOutlineLatLng.length >= 3) {
          roofImage = await mod.buildPublicRoofImageSpec({ outline: roofOutlineLatLng }).catch(() => null);
        }
        handle = mod.createRoofViewer(stage, model, {
          reducedMotion: reduced,
          lowEnd: strategy.lowEnd,
          roofImage,
          onReady: () => {
            if (overlay) overlay.hidden = true;
            if (hintEl) hintEl.hidden = false;
            // WJ118 — bascule le fond en ciel clair/jour UNIQUEMENT quand la
            // photo a été réellement drapée ; sans elle, le fond nuit abstrait
            // actuel reste (aucune classe ajoutée = dégradation byte-identique).
            if (roofImage && stage) stage.classList.add('roof3d-stage--sky');
          },
          onFail: () => {
            if (overlay) overlay.hidden = false;
            showFallback('Vue 3D interrompue — voici la photo de votre étude.');
          },
        });
        if (!handle) {
          showFallback('Vue 3D indisponible sur cet appareil — voici la photo de votre étude.');
        }
      } catch {
        // Réseau lent / import échoué : le poster reste, message honnête.
        showFallback('Vue 3D momentanément indisponible — voici la photo de votre étude.');
      }
    }

    startBtn?.addEventListener('click', () => void boot());

    // Conditions normales : pré-charge au scroll (proche du viewport). En
    // reduced-motion ou Save-Data : rien ne bouge/charge sans geste explicite
    // (même règle que viewerBootStrategy.autoPreload, évaluée ici sans import
    // dynamique pour ne déclencher AUCUN chargement avant un vrai scroll).
    const saveData = nav.connection?.saveData === true;
    const autoPreload = !reduced && !saveData;
    if (autoPreload && 'IntersectionObserver' in window) {
      const io = new IntersectionObserver(
        (entries) => {
          if (entries.some((e) => e.isIntersecting)) {
            io.disconnect();
            void boot();
          }
        },
        { rootMargin: '200px' },
      );
      io.observe(section3d);
    }

    // Libère le GPU au départ de la page (aucune fuite de contexte WebGL).
    window.addEventListener('pagehide', () => {
      handle?.dispose();
      handle = null;
    });
  }

  // ── WJ26 — visite guidée : surlignage d'étape (progressive enhancement).
  // Les 4 étapes sont TOUJOURS toutes visibles (zéro mouvement, zéro CLS,
  // lisible sans JS) ; Précédent/Suivant ne déplacent que le surlignage +
  // l'annonce aria-live. Rien n'anime la caméra 3D (reduced-motion-safe).
  const walk = document.getElementById('roof3d-walk');
  if (walk) {
    const steps = Array.from(walk.querySelectorAll<HTMLElement>('.walk-step'));
    const prev = document.getElementById('roof3d-walk-prev') as HTMLButtonElement | null;
    const next = document.getElementById('roof3d-walk-next') as HTMLButtonElement | null;
    const count = document.getElementById('roof3d-walk-count');
    let idx = 0;
    function setStep(i: number): void {
      idx = Math.max(0, Math.min(steps.length - 1, i));
      steps.forEach((s, j) => {
        if (j === idx) s.setAttribute('aria-current', 'step');
        else s.removeAttribute('aria-current');
      });
      if (prev) prev.disabled = idx === 0;
      if (next) next.disabled = idx === steps.length - 1;
      if (count) count.textContent = `Étape ${idx + 1} sur ${steps.length}`;
    }
    prev?.addEventListener('click', () => setStep(idx - 1));
    next?.addEventListener('click', () => setStep(idx + 1));
    setStep(0);
  }
</script>

<script>
  // ── WJ29 — « Être contacté » / « Demander un rappel » : notifie l'équipe EN
  // PLUS du lien instantané (wa.me / tel:), sans jamais le bloquer. On laisse
  // le navigateur suivre le lien normalement (tel:/wa.me s'ouvrent tout de
  // suite) et on poste en parallèle vers le proxy same-origin — un échec ne
  // gêne jamais le client, il garde de toute façon son canal instantané.
  import { buildContactBody, type ContactChannel } from '../../lib/proposition';
  // WJ120 — moteur du simulateur batterie (PUR) importé ES pour un recalcul 100 %
  // local au curseur (aucun re-fetch). Regroupé dans CE script (cf. note WJ34/WJ53
  // ci-dessous) ; batterySim n'a aucune dépendance runtime lourde.
  import { simulateBattery, renderBatterySplitSvg } from '../../lib/batterySim';

  const contactSection = document.querySelector<HTMLElement>('[data-contact-token]');
  const confirmEl = document.getElementById('contact-confirm');
  const token = contactSection?.dataset.contactToken ?? '';

  if (contactSection && token) {
    let confirmTimer: number | undefined;
    function showConfirm(msg: string): void {
      if (!confirmEl) return;
      confirmEl.textContent = msg;
      confirmEl.hidden = false;
      window.clearTimeout(confirmTimer);
      confirmTimer = window.setTimeout(() => {
        confirmEl.hidden = true;
      }, 8000);
    }

    async function notifyTeam(channel: ContactChannel): Promise<void> {
      try {
        const body = buildContactBody({ channel });
        const res = await fetch('/api/proposition-contact', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ token, ...body }),
        });
        const data = (await res.json()) as { detail?: string };
        if (data.detail) showConfirm(data.detail);
      } catch {
        // Best-effort : le lien instantané (wa.me / tel:) a déjà fait son travail,
        // on ne montre rien d'alarmant si la notification interne échoue.
      }
    }

    contactSection.querySelectorAll<HTMLAnchorElement>('[data-contact-channel]').forEach((el) => {
      el.addEventListener('click', () => {
        const channel = (el.dataset.contactChannel as ContactChannel) || 'rappel';
        void notifyTeam(channel);
        if (channel === 'rappel') showConfirm('Merci — nous vous rappelons très vite.');
      });
    });
  }

  // ── WJ54 — « Demander une modification » : formulaire de révision
  // structurée, posté vers le MÊME proxy /api/proposition-contact que WJ29
  // ci-dessus (canal `revision` distinct) — jamais un nouvel endpoint. Le
  // formulaire est gâté côté serveur (rendu uniquement quand `ok`, voir
  // l'astro plus haut) : ce script ne fait qu'attacher son comportement s'il
  // est bien présent dans le DOM.
  (function setupRevisionForm(): void {
    const revisionSection = document.querySelector<HTMLElement>('[data-revision-token]');
    const revisionToken = revisionSection?.dataset.revisionToken ?? '';
    if (!revisionSection || !revisionToken) return;

    const form = document.getElementById('revision-form') as HTMLFormElement | null;
    const detailEl = document.getElementById('revision-detail') as HTMLTextAreaElement | null;
    const errorEl = document.getElementById('revision-error');
    const confirmEl = document.getElementById('revision-confirm');
    const submitBtn = document.getElementById('revision-submit') as HTMLButtonElement | null;
    const kindBtns = Array.from(revisionSection.querySelectorAll<HTMLButtonElement>('[data-revision-kind]'));
    if (!form) return;

    type RevisionKind = 'kwc' | 'batterie' | 'autre';
    let selectedKind: RevisionKind | null = null;

    function selectKind(kind: RevisionKind): void {
      selectedKind = kind;
      kindBtns.forEach((btn) => {
        const on = btn.dataset.revisionKind === kind;
        btn.setAttribute('aria-pressed', String(on));
        btn.setAttribute(
          'style',
          on
            ? 'background: var(--color-brass-400); color: var(--color-nuit); border-color: var(--color-brass-400)'
            : '',
        );
      });
    }
    kindBtns.forEach((btn) => {
      btn.addEventListener('click', () => selectKind((btn.dataset.revisionKind as RevisionKind) || 'autre'));
    });

    let submitting = false;
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      if (submitting) return;

      if (errorEl) errorEl.hidden = true;
      if (confirmEl) confirmEl.hidden = true;

      const detail = (detailEl?.value ?? '').trim();
      const kind = selectedKind;
      if (!kind) {
        if (errorEl) {
          errorEl.textContent = 'Veuillez choisir le type de modification souhaitée.';
          errorEl.hidden = false;
        }
        return;
      }
      if (kind === 'autre' && !detail) {
        if (errorEl) {
          errorEl.textContent = 'Merci de préciser votre demande en quelques mots.';
          errorEl.hidden = false;
        }
        return;
      }

      submitting = true;
      if (submitBtn) submitBtn.disabled = true;

      const labels: Record<RevisionKind, string> = {
        kwc: 'Ajuster la puissance (kWc)',
        batterie: 'Changer l’option batterie',
        autre: 'Autre modification',
      };
      const message = detail ? `${labels[kind]} — ${detail}` : labels[kind];

      void (async () => {
        try {
          const res = await fetch('/api/proposition-contact', {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify({
              token: revisionToken,
              channel: 'revision',
              revision_kind: kind,
              message,
            }),
          });
          const data = (await res.json()) as { detail?: string };
          if (confirmEl) {
            confirmEl.textContent = data.detail || 'Merci — votre demande a bien été transmise.';
            confirmEl.hidden = false;
          }
          form.reset();
          selectedKind = null;
          kindBtns.forEach((btn) => {
            btn.setAttribute('aria-pressed', 'false');
            btn.setAttribute('style', '');
          });
        } catch {
          if (confirmEl) {
            confirmEl.textContent = 'Merci — votre demande a bien été transmise.';
            confirmEl.hidden = false;
          }
        } finally {
          submitting = false;
          if (submitBtn) submitBtn.disabled = false;
        }
      })();
    });
  })();

  // ── WJ34 — affordance « génération du PDF… » sur le lien de téléchargement.
  // Le rendu backend (WeasyPrint) prend quelques secondes : sans signal, le
  // visiteur peut croire que le clic n'a rien fait. Le lien continue de
  // s'ouvrir normalement (target=_blank, jamais bloqué par preventDefault) ;
  // on affiche juste un état visuel temporaire, remis à zéro dès que
  // l'utilisateur revient sur cet onglet (le PDF est alors soit ouvert dans
  // un nouvel onglet, soit l'échec est visible là-bas) ou après un délai de
  // sécurité (le rendu le plus lent observé reste sous quelques secondes).
  // Regroupé dans CE script (au lieu d'un 5ᵉ <script> séparé) : un bundling
  // observé sur cette route perdait le chunk d'un <script> isolé sans import
  // ES — le manifeste SSR le référençait mais le fichier n'était jamais écrit
  // côté client. Même page, même effet, zéro risque de chunk manquant.
  const pdfLink = document.getElementById('pdf-download') as HTMLAnchorElement | null;
  const pdfIcon = document.getElementById('pdf-download-icon');
  const pdfSpinner = document.getElementById('pdf-download-spinner');
  const pdfLabel = document.getElementById('pdf-download-label');
  const PDF_LABEL_DEFAULT = { fr: 'Télécharger le devis (PDF)', en: 'Download the quote (PDF)', ar: 'تحميل العرض (PDF)' } as const;
  const PDF_LABEL_LOADING = { fr: 'Génération du PDF…', en: 'Generating the PDF…', ar: 'جارٍ إنشاء PDF…' } as const;
  // WJ17/WJ43 — le libellé bascule FR/EN/AR APRÈS le premier rendu (état
  // « génération »), donc hors du mécanisme tri-node data-i18n : on lit la
  // langue courante via le pont __propCurrentLang exposé par le script de
  // bascule (module séparé), et on se réinscrit pour être retraduit à chaque
  // clic FR/EN/عربي.
  type PropLang = 'fr' | 'en' | 'ar';
  const propWin = window as unknown as {
    __propCurrentLang?: () => PropLang;
    __propRegisterBusyLabel?: (fn: (l: PropLang) => void) => void;
  };
  const getLang = (): PropLang => propWin.__propCurrentLang?.() ?? 'fr';

  if (pdfLink && pdfLabel) {
    let pdfLoading = false;
    let pdfResetTimer: number | undefined;
    const renderPdfLabel = (lang: PropLang): void => {
      pdfLabel.textContent = pdfLoading ? PDF_LABEL_LOADING[lang] : PDF_LABEL_DEFAULT[lang];
    };
    const setPdfLoading = (loading: boolean): void => {
      pdfLoading = loading;
      if (pdfIcon) pdfIcon.toggleAttribute('hidden', loading);
      if (pdfSpinner) pdfSpinner.hidden = !loading;
      renderPdfLabel(getLang());
    };
    propWin.__propRegisterBusyLabel?.(renderPdfLabel);
    pdfLink.addEventListener('click', () => {
      setPdfLoading(true);
      window.clearTimeout(pdfResetTimer);
      pdfResetTimer = window.setTimeout(() => setPdfLoading(false), 6000);
    });
    // Dès que l'utilisateur revient sur CET onglet (après avoir consulté le
    // PDF dans le nouvel onglet), on considère la génération terminée.
    document.addEventListener('visibilitychange', () => {
      if (document.visibilityState === 'visible') setPdfLoading(false);
    });
  }

  // ── WJ53 — Toggle « payer comptant / paiement échelonné », recalcul en
  // direct (aucun appel réseau : simple division du TTC déjà connu côté
  // client via data-installment-ttc). Utilise installmentSplit (même fonction
  // PURE que testée sous vitest) pour garantir zéro divergence de calcul.
  // Regroupé dans CE script (voir la note WJ34 ci-dessus sur le 4ᵉ <script>
  // sans import ES qui perdait son chunk client) — un <script> supplémentaire
  // isolé sur cette route reste un risque connu, pas seulement historique.
  (function setupInstallmentToggle(): void {
    const installmentSection = document.querySelector<HTMLElement>('[data-installment-ttc]');
    if (!installmentSection) return;
    const ttc = Number(installmentSection.dataset.installmentTtc || '0');
    const cashBtn = document.getElementById('installment-cash-btn');
    const splitBtn = document.getElementById('installment-split-btn');
    const cashView = document.getElementById('installment-cash-view');
    const splitView = document.getElementById('installment-split-view');
    const monthsSelect = document.getElementById('installment-months') as HTMLSelectElement | null;
    const monthlyValueEl = document.getElementById('installment-monthly-value');

    function setMode(mode: 'cash' | 'split'): void {
      const isCash = mode === 'cash';
      if (cashView) cashView.hidden = !isCash;
      if (splitView) splitView.hidden = isCash;
      cashBtn?.setAttribute('aria-pressed', String(isCash));
      splitBtn?.setAttribute('aria-pressed', String(!isCash));
      if (cashBtn) {
        cashBtn.setAttribute(
          'style',
          isCash
            ? 'background: var(--color-brass-400); color: var(--color-nuit); border-color: var(--color-brass-400)'
            : '',
        );
      }
      if (splitBtn) {
        splitBtn.setAttribute(
          'style',
          !isCash
            ? 'background: var(--color-brass-400); color: var(--color-nuit); border-color: var(--color-brass-400)'
            : '',
        );
      }
    }
    cashBtn?.addEventListener('click', () => setMode('cash'));
    splitBtn?.addEventListener('click', () => setMode('split'));

    function recompute(): void {
      if (!monthsSelect || !monthlyValueEl) return;
      const months = (Number(monthsSelect.value) || 12) as InstallmentMonths;
      const split = installmentSplit(ttc, months);
      if (split) monthlyValueEl.textContent = formatMAD(split.monthly);
    }
    monthsSelect?.addEventListener('change', recompute);
    recompute();
  })();

  // ── WJ56 — « Partager sur WhatsApp » : Web Share API native quand disponible
  // (feuille de partage système — la meilleure expérience sur mobile/tablette,
  // laisse le client choisir WhatsApp OU tout autre canal), repli sur le lien
  // wa.me générique (déjà posé en `href`, fonctionne SANS JS) sinon. On ne
  // bloque JAMAIS le clic : navigator.share() réussi → preventDefault (évite
  // une double feuille de partage) ; échec/absence → le lien wa.me s'ouvre
  // normalement.
  (function setupShareWhatsapp(): void {
    const shareBtn = document.getElementById('prop-share-whatsapp') as HTMLAnchorElement | null;
    if (!shareBtn || typeof navigator.share !== 'function') return;
    shareBtn.addEventListener('click', (e) => {
      const url = shareBtn.dataset.shareUrl || shareBtn.href;
      const ref = shareBtn.dataset.shareRef || '';
      e.preventDefault();
      navigator
        .share({
          title: 'Proposition solaire Taqinor',
          text: ref ? `Voici ma proposition solaire Taqinor (réf. ${ref})` : 'Voici ma proposition solaire Taqinor',
          url,
        })
        .catch(() => {
          // Annulé par l'utilisateur ou API indisponible en pratique : on
          // rouvre le repli wa.me pour ne jamais laisser le clic sans effet.
          window.open(shareBtn.href, '_blank', 'noopener,noreferrer');
        });
    });
  })();

  // ── WJ80 — Tap-to-reveal des valeurs du graphe + de la courbe journalière.
  // Le `<title>` SVG (survol souris) est INVISIBLE au tactile — l'essentiel du
  // trafic de cette page. Délégation d'événement sur le conteneur visible
  // (peu importe la langue active) : un tap/clic/Entrée sur une barre ou le
  // repère pic/moyenne affiche son libellé déjà formaté (data-month/
  // data-value ou data-peak/data-avg, posés côté serveur — aucun recalcul).
  (function setupChartTapReveal(): void {
    function nearestTarget(el: EventTarget | null): HTMLElement | null {
      if (!(el instanceof Element)) return null;
      return el.closest<HTMLElement>('[data-chart-bar], [data-curve-scale]');
    }

    function reveal(target: HTMLElement): void {
      if (target.matches('[data-chart-bar]')) {
        const caption = document.getElementById('chart-tap-caption');
        if (!caption) return;
        const month = target.dataset.month ?? '';
        const value = target.dataset.value ?? '';
        caption.textContent = `${month} · ${value}`;
      } else if (target.matches('[data-curve-scale]')) {
        const caption = document.getElementById('curve-tap-caption');
        if (!caption) return;
        const peak = target.dataset.peak ?? '';
        const avg = target.dataset.avg ?? '';
        caption.textContent = [peak, avg].filter(Boolean).join(' · ');
      }
    }

    function wireTapReveal(container: HTMLElement | null): void {
      if (!container) return;
      container.addEventListener('click', (e) => {
        const target = nearestTarget(e.target);
        if (target) reveal(target);
      });
      container.addEventListener('keydown', (e) => {
        if (e.key !== 'Enter' && e.key !== ' ') return;
        const target = nearestTarget(e.target);
        if (target) {
          e.preventDefault();
          reveal(target);
        }
      });
    }

    document.querySelectorAll<HTMLElement>('.chart-svg, .daily-curve-wrap').forEach(wireTapReveal);
  })();

  // ── WJ120 — Simulateur « et avec N batteries ? » : recalcul EN DIRECT au
  // curseur, 100 % côté client (aucun re-fetch). Le moteur horaire glouton
  // (lib/batterySim, jour 2 simulé) tourne dans le navigateur à partir des
  // silhouettes + totaux déjà posés côté serveur (data-battery-sim-config).
  // Regroupé dans CE script (import ES → chunk garanti, cf. WJ34/WJ53). Les
  // nombres sont formatés localement (séparateur d'espace, virgule décimale —
  // même convention que proposition.formatNumber) pour ne dépendre d'aucun
  // import supplémentaire ; le prix batterie n'est JAMAIS inventé (prix réel du
  // devis quand N == offre, sinon « sur étude »).
  (function setupBatterySim(): void {
    type BsLang = 'fr' | 'en' | 'ar';
    interface BsConfig {
      consShape: number[];
      solarShape: number[];
      dailyConsKwh: number;
      dailyProdKwh: number;
      capacityPerUnit: number;
      maxUnits: number;
      initialN: number;
      offeredUnits: number;
      sansTtc: number | null;
      avecTtc: number | null;
    }
    const section = document.getElementById('battery-sim');
    if (!section) return;
    const raw = section.getAttribute('data-battery-sim-config');
    if (!raw) return;
    let cfg: BsConfig;
    try {
      cfg = JSON.parse(raw) as BsConfig;
    } catch {
      return;
    }

    const bsWin = window as unknown as {
      __propCurrentLang?: () => BsLang;
      __propRegisterBusyLabel?: (fn: (l: BsLang) => void) => void;
    };
    const curLang = (): BsLang => bsWin.__propCurrentLang?.() ?? 'fr';

    // Formatage local (aucun import) : espace de milliers, virgule décimale —
    // exactement proposition.formatNumber (virgule quelle que soit la langue).
    const group = (s: string): string => s.replace(/\B(?=(\d{3})+(?!\d))/g, ' ');
    function fmtNum(v: number, decimals: number): string {
      const n = Number.isFinite(v) ? v : 0;
      const factor = 10 ** decimals;
      const r = Math.round(n * factor) / factor;
      const sign = r < 0 ? '-' : '';
      const abs = Math.abs(r);
      const intPart = group(Math.trunc(abs).toString());
      if (decimals <= 0) return `${sign}${intPart}`;
      const frac = (abs - Math.trunc(abs)).toFixed(decimals).slice(2).replace(/0+$/, '');
      return frac ? `${sign}${intPart},${frac}` : `${sign}${intPart}`;
    }
    const fmtPct = (v: number): string => `${fmtNum(v, 0)} %`;
    const fmtMad = (v: number): string => `${fmtNum(Math.round(v), 0)} MAD`;
    const ON_STUDY: Record<BsLang, string> = {
      fr: 'Sur étude',
      en: 'On request',
      ar: 'حسب الدراسة',
    };

    const setText = (id: string, text: string): void => {
      const el = document.getElementById(id);
      if (el) el.textContent = text;
    };

    let currentN = Math.max(0, Math.min(cfg.maxUnits, Math.trunc(cfg.initialN)));
    let lastHourly: { direct: number[]; battery: number[]; grid: number[] } | null = null;

    function renderPrice(n: number): void {
      const el = document.getElementById('battery-sim-price');
      if (!el) return;
      if (n === cfg.offeredUnits && cfg.avecTtc != null) el.textContent = fmtMad(cfg.avecTtc);
      else if (n === 0 && cfg.sansTtc != null) el.textContent = fmtMad(cfg.sansTtc);
      else el.textContent = ON_STUDY[curLang()];
    }

    function update(n: number): void {
      currentN = n;
      const res = simulateBattery({
        consumptionShape: cfg.consShape,
        productionShape: cfg.solarShape,
        dailyConsumptionKwh: cfg.dailyConsKwh,
        dailyProductionKwh: cfg.dailyProdKwh,
        capacityKwhPerUnit: cfg.capacityPerUnit,
        units: n,
      });
      lastHourly = res.hourly;
      setText('battery-sim-units', String(n));
      setText('battery-sim-selfconso', fmtPct(res.selfConsumptionPct));
      setText('battery-sim-selfsuff', fmtPct(res.selfSufficiencyPct));
      setText('battery-sim-backup', fmtNum(res.backupHours, 0));
      setText('battery-sim-direct', fmtNum(res.directKwh, 1));
      setText('battery-sim-battery', fmtNum(res.fromBatteryKwh, 1));
      setText('battery-sim-grid', fmtNum(res.fromGridKwh, 1));
      const chart = document.getElementById('battery-sim-chart');
      if (chart) chart.innerHTML = renderBatterySplitSvg(res.hourly, undefined, curLang());
      renderPrice(n);
    }

    const slider = document.getElementById('battery-sim-slider') as HTMLInputElement | null;
    slider?.addEventListener('input', () => {
      const n = Math.max(0, Math.min(cfg.maxUnits, Number(slider.value) || 0));
      update(n);
    });

    // Re-localise le prix « sur étude » ET le SVG (title/desc) à chaque bascule
    // de langue — même registre que le libellé PDF (busy-label non couvert par
    // data-i18n car réécrit en JS après le premier rendu).
    bsWin.__propRegisterBusyLabel?.((l: BsLang) => {
      renderPrice(currentN);
      const chart = document.getElementById('battery-sim-chart');
      if (chart && lastHourly) chart.innerHTML = renderBatterySplitSvg(lastHourly, undefined, l);
    });

    // Recalcule une fois au chargement (idempotent avec le rendu serveur).
    update(currentN);
  })();
</script>

<style>
  /* P2 — réserve le ratio du graphe (viewBox 360×150 = 2.4:1) AVANT le rendu du
     SVG inline pour garantir zéro CLS. Le SVG enfant occupe 100 % de la largeur,
     hauteur auto ; aucune transition (mouvement réduit respecté par construction). */
  .chart-svg {
    width: 100%;
    aspect-ratio: 360 / 150;
  }
  .chart-svg :global(svg) {
    display: block;
    width: 100%;
    height: 100%;
  }
  /* WJ80 — affordance tap-to-reveal : curseur main sur les barres (souris) ;
     le tactile n'a pas besoin de curseur mais bénéficie du focus-visible
     ci-dessous (navigation clavier — les barres portent tabindex="0"). */
  .chart-svg :global([data-chart-bar]) {
    cursor: pointer;
  }
  .chart-svg :global([data-chart-bar]:focus-visible) {
    outline: 2px solid var(--color-brass-300, #f3cc66);
    outline-offset: 1px;
  }

  /* WJ16 — courbe journalière : ratio réservé AVANT rendu (viewBox 360×170)
     → zéro CLS. Le SVG enfant occupe 100 % de la largeur. */
  .daily-curve-wrap {
    width: 100%;
    aspect-ratio: 360 / 170;
  }
  .daily-curve-wrap :global(svg) {
    display: block;
    width: 100%;
    height: 100%;
  }

  /* WJ120 — aire empilée « direct/batterie/réseau » : ratio réservé AVANT rendu
     (viewBox 360×150) → zéro CLS ; le SVG (re-rendu au curseur) occupe la boîte. */
  .battery-split-wrap {
    width: 100%;
    aspect-ratio: 360 / 150;
  }
  .battery-split-wrap :global(svg) {
    display: block;
    width: 100%;
    height: 100%;
  }
  /* WJ80 — même affordance tap-to-reveal sur le repère pic/moyenne. */
  .daily-curve-wrap :global([data-curve-scale]) {
    cursor: pointer;
  }
  .daily-curve-wrap :global([data-curve-scale]:focus-visible) {
    outline: 2px solid var(--color-brass-300, #f3cc66);
    outline-offset: 1px;
  }

  /* WJ11 — pad de signature : hauteur fixe (zéro CLS) ; pas de débordement.
     touch-none (classe utilitaire) empêche le scroll pendant le tracé.
     WJ101 — le canvas est désormais focusable (tabindex="0") : un contour de
     focus visible est requis (WCAG 2.4.7), jamais un `outline: none` implicite. */
  .sign-pad {
    height: 160px;
    cursor: crosshair;
  }
  .sign-pad:focus-visible {
    outline: 2px solid var(--color-brass-400, #e8b54a);
    outline-offset: 2px;
  }

  /* WJ25/WJ27 — scène 3D : ratio RÉSERVÉ avant tout chargement (zéro CLS).
     Le poster occupe la boîte ; le canvas (créé par la visionneuse) la recouvre.
     touch-action: none sur le canvas = orbite/pinch sans scroller la page. */
  .roof3d-stage {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 10;
    background: var(--color-azur-950, #0a1a33);
  }
  /* WJ118 — la scène Three.js est transparente (setClearColor 0,0,
     roofPro11/viewerOnly.ts) : sans photo satellite, le fond nuit ci-dessus
     reste (rendu abstrait actuel, inchangé). Quand la photo est RÉELLEMENT
     drapée (roofImage résolu côté client, clé MAPTILER/MAPBOX configurée +
     contour ≥3 sommets + image chargée), la visionneuse ajoute cette classe :
     un ciel clair/jour, cohérent avec une vraie vue satellite plutôt qu'un
     vide bleu nuit. Même dégradé que mon-toit.astro (.mt-panels3d-stage). */
  .roof3d-stage.roof3d-stage--sky {
