           l'eau livrée + le carburant évité, pas un cumul de facture réseau ; le
           cadrage « économies cumulées 25 ans » est résidentiel/autoconso. -->
      {!isAgricole && headline && (headline.cumulative || headline.annual || paybackHero || prodKwh) && (
        <section id="financing-headline" class="mx-auto max-w-4xl px-5 pt-12 sm:px-8 sm:pt-16">
          {/* Accroche « coût de ne rien faire » : le cumul phare. */}
          {headline.cumulative ? (
            <div class="cine-card cine-in rounded-2xl p-6 shadow-premium sm:p-8" style="border-color: rgb(232 181 74 / 0.35)">
              <p class="tech-label text-lune-faint" data-i18n
                data-fr={`Sans le solaire, votre facture continue de courir. Avec, vous économisez sur ${headline.years} ans`}
                data-en={`Without solar, your bill keeps climbing. With it, you save over ${headline.years} years`}
                data-ar={`بدون الطاقة الشمسية، تستمر فاتورتكم في الارتفاع. معها، توفرون على مدى ${headline.years} سنة`}>
                Sans le solaire, votre facture continue de courir. Avec, vous économisez sur {headline.years} ans
              </p>
              <p class="fig lum mt-3 text-4xl sm:text-5xl" dir="ltr">{formatMAD(headline.cumulative)}</p>
              <!-- WJ75 — la mention « tarif constant » s'affiche désormais TOUJOURS,
                   que le taux vienne du backend ou du repli local : les deux
                   partagent la MÊME hypothèse 0 % d'escalade tarifaire (voir
                   savingsHeadline/BILL_INFLATION_RATE dans lib/proposition.ts —
                   vérifié dans le moteur PDF vendorisé, generate_devis_premium.py,
                   qui construit sa propre courbe cumulative par une simple
                   multiplication linéaire, sans terme de dérive). Avant ce
                   correctif, la mention disparaissait quand le taux venait du
                   backend, laissant croire — à tort — que ce chiffre intégrait
                   une hausse tarifaire que ni lui ni le PDF ne modélisent. -->
              <p class="v2-body mt-2 text-sm text-lune-soft" data-i18n
                data-fr={`Économies cumulées estimées sur ${headline.years} ans${headline.monthly ? ` — soit ≈ ${formatMAD(headline.monthly)}/mois qui restent dans votre poche` : ''}. Estimation à tarif constant (loi 82-21, autoconsommation) — même hypothèse que votre devis PDF.`}
                data-en={`Estimated cumulative savings over ${headline.years} years${headline.monthly ? ` — that's ≈ ${formatMAD(headline.monthly)}/month staying in your pocket` : ''}. Estimate at constant tariff (law 82-21, self-consumption) — the same assumption as your PDF quote.`}
                data-ar={`توفير تراكمي مقدّر على مدى ${headline.years} سنة${headline.monthly ? ` — أي ما يعادل ≈ ${formatMAD(headline.monthly)}/شهر تبقى في جيبكم` : ''}. تقدير بتعريفة ثابتة (القانون 82-21، الاستهلاك الذاتي) — نفس الافتراض المعتمد في عرض PDF الخاص بكم.`}>
                Économies cumulées estimées sur {headline.years} ans
                {headline.monthly ? <> — soit <span class="text-brass-300">≈ {formatMAD(headline.monthly)}/mois</span> qui restent dans votre poche</> : null}.
                <span class="text-lune-faint"> Estimation à tarif constant (loi 82-21, autoconsommation) — même hypothèse que votre devis PDF.</span>
              </p>
            </div>
          ) : null}

          <div class="mt-4 grid gap-4 sm:grid-cols-3">
            {headline.annual ? (
              <div class="cine-card rounded-xl p-5">
                <p class="tech-label text-lune-faint" data-i18n data-fr="Économies estimées / an" data-en="Estimated savings / year" data-ar="التوفير المقدّر / سنة">Économies estimées / an</p>
                <p class="fig fig-md lum mt-2" dir="ltr">{formatMAD(headline.annual)}</p>
                {headline.monthly ? <p class="mt-1 text-sm text-lune-faint" dir="ltr">≈ {formatMAD(headline.monthly)}/mois</p> : null}
              </div>
            ) : null}
            {paybackHero ? (
              <div class="cine-card rounded-xl p-5">
                <p class="tech-label text-lune-faint" data-i18n data-fr="Rentabilisé en" data-en="Paid back in" data-ar="يُسترد خلال">Rentabilisé en</p>
                <p class="fig fig-md mt-2 text-lune" dir="ltr">{paybackHero}</p>
                <p class="mt-1 text-sm text-lune-faint" data-i18n data-fr="puis l’énergie est gratuite" data-en="then energy is free" data-ar="ثم تصبح الطاقة مجانية">puis l’énergie est gratuite</p>
              </div>
            ) : null}
            {prodKwh ? (
              <div class="cine-card rounded-xl p-5">
                <p class="tech-label text-lune-faint" data-i18n data-fr="Production estimée / an" data-en="Estimated production / year" data-ar="الإنتاج المقدّر / سنة">Production estimée / an</p>
                <p class="fig fig-md mt-2 text-lune" dir="ltr">{formatNumber(prodKwh)} <span class="text-lg text-lune-soft">kWh</span></p>
              </div>
            ) : null}
          </div>
        </section>
      )}

      {/* W347 — « Compteur à zéro » : ne rend RIEN tant que le fondateur n'a
          pas fourni le vrai clip (src/lib/compteurVideo.ts, livré vide).
          Placé juste après les chiffres d'économies ci-dessus — le contexte
          le plus persuasif pour ce genre de clip. */}
      <VideoCompteur />

      <!-- ── SYSTÈME : puissance / panneaux ───────────────────────────────── -->
      {(puissance || nbPanneaux) && (
        <section class="mx-auto max-w-4xl px-5 pt-12 sm:px-8">
          <p class="tech-label rule-brass text-brass-300" data-i18n data-fr="Votre système" data-en="Your system" data-ar="نظامكم">Votre système</p>
          <div class="mt-5 grid gap-4 sm:grid-cols-3">
            {puissance ? (
              <div class="cine-card rounded-xl p-5">
                <p class="tech-label text-lune-faint" data-i18n data-fr="Puissance" data-en="Power" data-ar="القدرة">Puissance</p>
                <p class="fig mt-2 text-2xl text-lune" dir="ltr">{formatNumber(puissance, 2)} <span class="text-base text-lune-soft">kWc</span></p>
              </div>
