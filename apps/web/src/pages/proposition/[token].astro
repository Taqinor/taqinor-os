---
/**
 * /proposition/<token> — PROPOSITION CLIENT EN LIGNE (W116 + W117).
 *
 * La belle page « UI » que TAQINOR envoie au client (≠ PDF). Rendu côté serveur
 * (prerender=false) : le frontmatter lit la proposition depuis l'endpoint backend
 * public/token, et la page affiche un devis premium responsive + une signature en
 * ligne (CTA collant « Signer en ligne »). La signature passe par le proxy
 * same-origin /api/proposition-accept — le navigateur n'appelle jamais le backend
 * en cross-origin. Aucun prix d'achat / marge n'est jamais affiché (le backend ne
 * les envoie pas). noindex=true : page privée et tokenisée.
 *
 * Design : langage v2 (« cinéma du chantier »). Bleu Majorelle dominant, laiton
 * (.lum / CTA) réservé aux chiffres clés et au bouton principal, encres lune,
 * Archivo / Hanken. Zéro CLS, prefers-reduced-motion respecté, contraste AA.
 */
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import ZelligeSignature from '../../components/ZelligeSignature.astro';
import StarRating from '../../components/StarRating.astro';
import TestimonialCarousel from '../../components/TestimonialCarousel.astro';
import InstallCounter from '../../components/InstallCounter.astro';
import CertLogoRow from '../../components/CertLogoRow.astro';
// WJ35 — grade « heure dorée » v3 (.v3-grade / .photo-grade), importé ici car
// cette page ne monte pas <V2Enhance/> (qui l'importe pour les pages v2). La
// feuille est dédupliquée par Vite si une autre page l'importe déjà ailleurs.
import '../../styles/v3-photo-motion.css';
import {
  type ProposalResponse,
  type OptionKey,
  formatMAD,
  formatNumber,
  formatPayback,
  hasTwoOptions,
  recommendedOption,
  optionTtc,
  optionItems,
  optionTotaux,
  optionLabel,
  optionLabelAr,
  optionLabelEn,
  defaultSelectedOption,
  isAccepted,
  resolveOfferState,
  isOfferDead,
  proposalEndpoint,
  proposalPdfEndpoint,
  hasProductionSeries,
  resolveValidity,
  savingsHeadline,
  environmentalImpact,
  financingComparison,
  whatsappLink,
  parseRoofLayout,
  buildViewerModel,
  zoneAnnotations,
  walkthroughSteps,
  backendFinancing,
  proposalVariants,
  nextSteps,
  proposalAssumptions,
  monitoringPoints,
  objectionFaq,
} from '../../lib/proposition';
import { renderYearCurve } from '../../lib/proposalCurve';
import { renderProposalChart, resolveSeries } from '../../lib/proposalChart';

const API_BASE = (import.meta.env.PUBLIC_API_BASE as string | undefined) ?? 'https://api.taqinor.ma';
const { token } = Astro.params as { token: string };

// ── Lecture serveur de la proposition ────────────────────────────────────────
let data: ProposalResponse | null = null;
let errorDetail: string | null = null;
let httpStatus = 200;

if (!token || !token.trim()) {
  httpStatus = 404;
  errorDetail = 'Ce lien de proposition est introuvable ou a expiré.';
} else {
  try {
    const res = await fetch(proposalEndpoint(API_BASE, token), {
      headers: { accept: 'application/json' },
    });
    httpStatus = res.status;
    if (res.ok) {
      data = (await res.json()) as ProposalResponse;
    } else {
      let detail = '';
      try {
        const body = (await res.json()) as { detail?: string };
        detail = typeof body.detail === 'string' ? body.detail : '';
      } catch {
        detail = '';
      }
      errorDetail =
        detail ||
        (res.status === 404
          ? 'Ce lien de proposition est introuvable ou a expiré.'
          : 'Cette proposition n’est pas accessible pour le moment.');
    }
  } catch {
    httpStatus = 502;
    errorDetail = 'Proposition momentanément indisponible. Veuillez réessayer dans un instant.';
  }
}

// La page renvoie 404 quand le token est invalide/expiré : propre pour les bots
// comme pour les humains (Layout est de toute façon noindex).
if (!data && (httpStatus === 404 || httpStatus === 200)) {
  Astro.response.status = httpStatus === 200 ? 404 : httpStatus;
} else if (!data) {
  Astro.response.status = httpStatus;
}

// ── Préparation des données d'affichage (uniquement si OK) ───────────────────
const ok = !!data;
const q = data?.quote;
const twoOptions = ok ? hasTwoOptions(data!) : false;
const reco: OptionKey | null = ok ? recommendedOption(data!) : null;
const accepted = ok ? isAccepted(data!) : false;
const preselect: OptionKey | null = ok ? defaultSelectedOption(data!) : null;

// ── WJ82 — État explicite de l'offre (live/accepted/refused/expired/withdrawn).
// Calculé UNE fois côté serveur à partir du même statut backend + de la même
// fenêtre de validité que `resolveValidity` ci-dessous (pas de nouvelle donnée
// inventée) : pilote la suppression du formulaire de signature + du CTA collant
// pour toute offre qui n'est plus signable.
const offerState = ok ? resolveOfferState(data!) : 'live';

const roofImg = data?.roof_image_url ?? null;
const clientName = data?.client_name || q?.client_name || 'Client';
const reference = data?.reference || q?.ref || '';
const proposalDate = data?.date || q?.date || '';

// Options à présenter (une ou deux), dans l'ordre Sans → Avec.
const options: OptionKey[] = ok
  ? twoOptions
    ? ['sans_batterie', 'avec_batterie']
    : q?.totaux_avec && !q?.totaux_sans
      ? ['avec_batterie']
      : ['sans_batterie']
  : [];

// Bloc énergie/économies (résidentiel/industriel). Pompage n'a pas ces champs.
const puissance = q?.puissance_kwc ?? null;
const nbPanneaux = q?.nb_panneaux ?? null;
const wattPanneau = q?.watt_par_panneau ?? null;
const prodKwh = q?.prod_kwh ?? null;
const ecoSans = q?.eco_s_ann ?? null;
const ecoAvec = q?.eco_a_ann ?? null;
const paybackSans = formatPayback(q?.roi_s);
const paybackAvec = formatPayback(q?.roi_a);
// Économie / payback « phares » : ceux de l'option recommandée.
const ecoHero = reco === 'avec_batterie' ? (ecoAvec ?? ecoSans) : (ecoSans ?? ecoAvec);
const paybackHero = reco === 'avec_batterie' ? (paybackAvec ?? paybackSans) : (paybackSans ?? paybackAvec);

const instLabel =
  q?.inst_type === 'agricole'
    ? 'Pompage solaire'
    : q?.inst_type === 'industriel' || q?.inst_type === 'commercial'
      ? 'Autoconsommation'
      : q?.inst_type
        ? String(q.inst_type)
        : 'Installation solaire';

// ── P2 — Graphe production estimée vs consommation (depuis les tableaux Q6) ──
// On ne dessine QUE les chiffres backend ; tableaux vides/absents → bloc masqué.
const chartSeries = ok ? resolveSeries(data?.monthly_production, data?.monthly_consumption) : { mode: 'none' as const, production: null, consumption: null };
const chartSvg = ok && chartSeries.mode !== 'none'
  ? renderProposalChart(data?.monthly_production, data?.monthly_consumption)
  : '';
const showChart = ok && hasProductionSeries(data!) && chartSvg.length > 0;
const chartHasConso = chartSeries.mode === 'comparison';

// ── WJ16 — Courbe journalière production vs consommation (lever → coucher) ────
// Calée sur la production annuelle RÉELLE backend si présente, sinon « année
// type » clairement libellée. Le visuel le plus persuasif ne disparaît jamais.
const dailyCurve = ok ? renderYearCurve(prodKwh) : { svg: '', hasRealScale: false };

// ── WJ15 — Fenêtre de validité honnête (date backend réelle, jamais inventée) ─
const validity = ok ? resolveValidity(data!) : { label: null, fromBackend: false, expired: false };

// ── WJ9 — Argent dans le temps : cumul 25 ans + payback + cadrage mensuel ────
const headline = ok ? savingsHeadline(data!, reco ?? 'sans_batterie') : null;

// ── WJ14 — Impact environnemental humain (CO₂ ≈ arbres), depuis la production ─
const enviro = ok ? environmentalImpact(prodKwh) : null;

// ── WJ10 — Comparatif de financement (cash backend + éco-prêt indicatif) ─────
const financing = ok ? financingComparison(data!, reco ?? 'sans_batterie') : null;

// ── WJ12 — Contact intégré : deep-link WhatsApp prérempli avec la réf devis ──
// « Demander un rappel » = appeler le numéro TAQINOR (NAP), jamais le numéro du
// client. Numéro réel (= lib/nap NAP.phone), affiché tel quel.
const waLink = ok ? whatsappLink(reference) : '';
const TAQINOR_TEL = '+212661850410';
const callbackHref = ok ? `tel:${TAQINOR_TEL}` : '';

// ── P3 — Lien public du devis PDF premium (même token, nouvel onglet) ────────
const pdfUrl = ok ? proposalPdfEndpoint(API_BASE, token) : '';

// ── WJ25 — visionneuse 3D en lecture seule (layout backend OPTIONNEL QJ26) ───
// Le backend n'expose pas encore `roof_layout` (PLAN2 QJ26) : le parse renvoie
// alors null et la page garde EXACTEMENT le héros statique d'aujourd'hui. Quand
// le champ arrivera, le modèle 3D (JSON pur) est calculé ICI côté serveur — le
// client ne charge que le rendu Three.js, en différé (jamais au premier paint).
const roofLayout = ok ? parseRoofLayout(data?.roof_layout) : null;
const viewerModel = roofLayout ? buildViewerModel(roofLayout) : null;
const show3d = !!viewerModel && viewerModel.totalPanels >= 0;
const viewerConfig = show3d ? JSON.stringify({ model: viewerModel }) : null;

// ── WJ26 — « Tout est expliqué » : légende par pan + visite guidée en 4 étapes.
// Chaque chiffre vient du layout serveur ou du payload quote (les fonctions
// renvoient null / « estimation indisponible » quand la donnée manque).
const annotations = show3d && roofLayout ? zoneAnnotations(roofLayout, q?.watt_par_panneau ?? null) : [];
const walkSteps = show3d && data ? walkthroughSteps(data) : [];

// ── WJ32 — Complétude du contenu : financement backend réel, variantes,
// « Et après ? », « Nos hypothèses », accompagnement, FAQ objections. Chaque
// bloc dégrade proprement (masqué) quand sa donnée backend manque.
const financingBlock = ok ? backendFinancing(data!) : null;
const variants = ok ? proposalVariants(data!) : [];
const steps = nextSteps();
const assumptions = ok ? proposalAssumptions(data!) : [];
const monitoring = monitoringPoints();
const faq = objectionFaq();

const pageTitle = ok ? `Proposition ${reference} — ${clientName} | Taqinor` : 'Proposition | Taqinor';

// Données passées au script de signature (sérialisées en JSON dans un data-attr).
const signConfig = ok
  ? JSON.stringify({ token, twoOptions, preselect, accepted, acceptedName: data?.accepte_par_nom ?? '', reference })
  : null;
---

<Layout title={pageTitle} description="Votre proposition solaire personnalisée Taqinor." noindex={true}>
  {!ok ? (
    <!-- ── État « lien expiré / introuvable » ─────────────────────────────── -->
    <section class="mx-auto flex min-h-[60vh] max-w-2xl flex-col items-center justify-center px-5 py-24 text-center">
      <div class="rule-brass mx-auto text-brass-300" aria-hidden="true"></div>
      <h1 class="display mt-6 text-3xl text-lune sm:text-4xl">Proposition indisponible</h1>
      <p class="v2-body mt-4 max-w-md">{errorDetail}</p>
      <p class="mt-8 text-sm text-lune-faint">
        Besoin d’un nouveau lien ? Contactez votre conseiller Taqinor.
      </p>
      <a href="/" class="btn-pill mt-8">Retour à l’accueil</a>
    </section>
  ) : (
    <div class="proposition pb-28" data-sign-config={signConfig}>
      <!-- WJ17/WJ43 — bascule de langue FR/EN/عربي, flottante (ne perturbe aucun
           rythme existant, zéro CLS). Même mécanisme tri-node (dual-node élargi)
           que WJ33 (mon-toit.astro) : voir le <script> de fin de page. Le contenu
           reste TOUJOURS lisible FR sans JS (pas de gate v2-js ici, page déjà
           rendue serveur). WJ43 — EN ajouté comme 3ᵉ langue (segment
           marocains-du-monde), au même niveau que FR/AR, jamais un repli dégradé. -->
      <div class="prop-lang-switch fixed right-3 top-3 z-50 flex gap-1 rounded-sm border border-white/15 bg-nuit/80 p-0.5 backdrop-blur" role="group" aria-label="Langue / Language / اللغة">
        <button type="button" id="prop-lang-fr" aria-pressed="true"
          class="px-2.5 py-1 text-xs font-semibold text-azur-950 bg-brass-400 transition-colors">FR</button>
        <button type="button" id="prop-lang-en" aria-pressed="false"
          class="px-2.5 py-1 text-xs font-semibold text-lune-soft transition-colors hover:text-white">EN</button>
        <button type="button" id="prop-lang-ar" aria-pressed="false"
          class="px-2.5 py-1 text-xs font-semibold text-lune-soft transition-colors hover:text-white">عربي</button>
      </div>

      <!-- ── HÉRO (WJ28 — cinéma du chantier : ancré bas, entrée cine-in ; WJ35 —
           rythme rehaussé, cohérent avec l'accueil élevé v3, zéro CLS : min-h). -->
      <section class="relative min-h-[72vh] overflow-hidden sm:min-h-[78vh]">
        {roofImg ? (
          <>
            <!-- WJ34 — poster blur-up : la photo backend (URL dynamique, pas de
                 pipeline LQIP base64 disponible pour ces images) est servie par-
                 dessus un dégradé « heure dorée » qui tient le cadrage. On ne
                 masque JAMAIS l'image elle-même (LCP protégé) : seule son
                 opacité anime 0→1 au chargement, gated reduced-motion — un
                 navigateur avec l'image déjà en cache (retour visiteur) la
                 voit s'afficher instantanément (classe déjà posée par l'attribut
                 onload s'il a déjà `complete`). Zéro CLS : le dégradé occupe
                 EXACTEMENT le même cadre (absolute inset-0). -->
            <div class="hero-lqip absolute inset-0" aria-hidden="true"></div>
            <img
              src={roofImg}
              alt={`Étude de toiture — ${clientName}`}
              width="1600"
              height="900"
              class="hero-photo absolute inset-0 h-full w-full object-cover"
              loading="eager"
              decoding="async"
              onload="this.classList.add('is-loaded')"
            />
          </>
        ) : (
          <div class="absolute inset-0 bg-azur-950" aria-hidden="true"></div>
        )}
        <!-- Scrim pour garantir le contraste AA du texte par-dessus la photo. -->
        <div class="hero-scrim absolute inset-0" aria-hidden="true"></div>
        <div class="relative mx-auto flex min-h-[72vh] w-full max-w-4xl flex-col justify-end px-5 pb-12 pt-24 sm:min-h-[78vh] sm:px-8 sm:pb-16 sm:pt-32">
          <p class="tech-label rule-brass cine-in text-brass-300" data-i18n
            data-fr={`${roofImg ? 'Votre installation · ' : 'Proposition · '}${instLabel}`}
            data-en={`${roofImg ? 'Your installation · ' : 'Proposal · '}${instLabel}`}
            data-ar={`${roofImg ? 'تركيبكم · ' : 'العرض · '}${instLabel}`}>
            {roofImg ? 'Votre installation · ' : 'Proposition · '}{instLabel}
          </p>
          <h1 class="display cine-in cine-in-1 mt-4 text-4xl text-blanc sm:text-5xl" data-i18n
            data-fr={`Bonjour ${clientName},`} data-en={`Hello ${clientName},`} data-ar={`مرحباً ${clientName}،`}>
            Bonjour {clientName},
          </h1>
          <p class="v2-body cine-in cine-in-2 mt-4 max-w-xl text-lune" data-i18n
            data-fr="Voici votre proposition solaire personnalisée. Tout est détaillé ci-dessous — vous pouvez la signer en ligne en bas de page."
            data-en="Here is your personalized solar proposal. Everything is detailed below — you can sign it online at the bottom of the page."
            data-ar="إليكم عرضكم الشمسي الشخصي. كل التفاصيل أدناه — يمكنكم التوقيع إلكترونياً أسفل الصفحة.">
            Voici votre proposition solaire personnalisée. Tout est détaillé ci-dessous —
            vous pouvez la signer en ligne en bas de page.
          </p>
          <dl class="cine-in cine-in-3 mt-7 flex flex-wrap gap-x-8 gap-y-3 text-sm">
            {reference && (
              <div>
                <dt class="text-lune-faint" data-i18n data-fr="Référence" data-en="Reference" data-ar="المرجع">Référence</dt>
                <dd class="fig text-lg text-lune" dir="ltr">{reference}</dd>
              </div>
            )}
            {proposalDate && (
              <div>
                <dt class="text-lune-faint" data-i18n data-fr="Date" data-en="Date" data-ar="التاريخ">Date</dt>
                <dd class="fig text-lg text-lune" dir="ltr">{proposalDate}</dd>
              </div>
            )}
            {/* WJ15 — Fenêtre de validité honnête : date backend réelle, sinon mention libellée. Jamais un compte-à-rebours. */}
            {validity.fromBackend && validity.label && !validity.expired && (
              <div>
                <dt class="text-lune-faint" data-i18n data-fr="Devis valable jusqu’au" data-en="Quote valid until" data-ar="العرض صالح حتى">Devis valable jusqu’au</dt>
                <dd class="fig text-lg text-brass-300" dir="ltr">{validity.label}</dd>
              </div>
            )}
            {validity.fromBackend && validity.expired && (
              <div>
                <dt class="text-lune-faint" data-i18n data-fr="Validité" data-en="Validity" data-ar="الصلاحية">Validité</dt>
                <dd class="text-base text-lune-soft" data-i18n data-fr="Offre échue — demandez une réactualisation" data-en="Offer expired — request an updated quote" data-ar="العرض منتهي — اطلبوا تحديثاً">Offre échue — demandez une réactualisation</dd>
              </div>
            )}
          </dl>
        </div>
      </section>

      <!-- ── BANDEAU « déjà signé » (si accepté au chargement) ─────────────── -->
      {accepted && (
        <section class="mx-auto max-w-4xl px-5 pt-8 sm:px-8">
          <div class="cine-card rounded-xl border-brass-400/40 p-5 sm:p-6" style="border-color: rgb(232 181 74 / 0.4)">
            <p class="fig text-xl text-brass-300" data-i18n data-fr="Devis accepté ✓" data-en="Quote accepted ✓" data-ar="تمت الموافقة على العرض ✓">Devis accepté ✓</p>
            <p class="v2-body mt-1" data-i18n
              data-fr={`Cette proposition a été acceptée${data?.accepte_par_nom ? ` par ${data.accepte_par_nom}` : ''}. Merci de votre confiance — votre conseiller Taqinor revient vers vous.`}
              data-en={`This proposal has been accepted${data?.accepte_par_nom ? ` by ${data.accepte_par_nom}` : ''}. Thank you for your trust — your Taqinor advisor will be in touch.`}
              data-ar={`تمت الموافقة على هذا العرض${data?.accepte_par_nom ? ` من طرف ${data.accepte_par_nom}` : ''}. شكراً على ثقتكم — سيتواصل معكم مستشار تاقينور قريباً.`}>
              Cette proposition a été acceptée
              {data?.accepte_par_nom ? <> par <strong class="text-lune">{data.accepte_par_nom}</strong></> : null}.
              Merci de votre confiance — votre conseiller Taqinor revient vers vous.
            </p>
          </div>
        </section>
      )}

      <!-- ── WJ25 · VOTRE TOIT EN 3D (lecture seule — layout backend optionnel) -->
      {/* Rendu UNIQUEMENT quand le backend fournit un roof_layout exploitable
          (QJ26). Sans layout : rien ici — le héros statique reste inchangé.
          Boîte à ratio RÉSERVÉ (zéro CLS) : poster (photo d'étude ou fond) puis
          canvas 3D par-dessus quand la visionneuse démarre. Three.js n'est
          JAMAIS dans le bundle initial (import() au scroll/tap — WJ27). */}
      {show3d && (
        <>
        <div class="seam-soft" aria-hidden="true"></div>
        <section id="roof3d" class="mx-auto max-w-5xl px-5 pt-14 sm:px-8 sm:pt-20" data-viewer-config={viewerConfig}>
          <p class="tech-label rule-brass cine-in text-brass-300" data-i18n data-fr="Le centre de votre proposition" data-en="At the heart of your proposal" data-ar="جوهر عرضكم">Le centre de votre proposition</p>
          <h2 class="display cine-in cine-in-1 mt-3 text-2xl text-lune sm:text-3xl" data-i18n data-fr="Votre toit en 3D" data-en="Your roof in 3D" data-ar="سطحكم بتقنية ثلاثية الأبعاد">Votre toit en 3D</h2>
          <div class="cine-card cine-in cine-in-2 mt-5 overflow-hidden rounded-2xl p-0 shadow-premium">
            <div id="roof3d-stage" class="roof3d-stage">
              {roofImg ? (
                <img
                  src={roofImg}
                  alt={`Étude de toiture — ${clientName}`}
                  width="1600"
                  height="1000"
                  class="v3-grade absolute inset-0 h-full w-full object-cover"
                  loading="lazy"
                  decoding="async"
                />
              ) : (
                <div class="absolute inset-0 bg-azur-950" aria-hidden="true"></div>
              )}
              <div class="roof3d-scrim absolute inset-0" aria-hidden="true"></div>
              <div id="roof3d-overlay" class="absolute inset-0 flex flex-col items-center justify-center gap-3 px-6 text-center">
                <button
                  id="roof3d-start"
                  type="button"
                  class="btn-pill inline-flex items-center justify-center gap-2"
                  style="background: var(--color-brass-400); color: var(--color-nuit); border-color: var(--color-brass-400)"
                  data-i18n data-fr="Explorer votre toit en 3D" data-en="Explore your roof in 3D" data-ar="استكشفوا سطحكم بتقنية ثلاثية الأبعاد"
                >
                  Explorer votre toit en 3D
                </button>
                <p id="roof3d-note" class="max-w-sm text-sm text-lune-soft" data-i18n
                  data-fr="Tournez, zoomez : ce sont votre toit et vos panneaux, tels qu’étudiés."
                  data-en="Rotate, zoom: this is your roof and your panels, exactly as studied."
                  data-ar="دوّروا، قرّبوا: هذا سطحكم وألواحكم، كما تمت دراستهما.">
                  Tournez, zoomez : ce sont votre toit et vos panneaux, tels qu’étudiés.
                </p>
              </div>
            </div>
            <p id="roof3d-hint" class="px-5 py-3 text-xs text-lune-faint" hidden data-i18n
              data-fr="Faites glisser pour tourner · pincez ou molette pour zoomer · deux doigts pour déplacer."
              data-en="Drag to rotate · pinch or scroll to zoom · two fingers to pan."
              data-ar="اسحبوا للتدوير · قرّبوا بإصبعين أو بعجلة الفأرة · إصبعان للتحريك.">
              Faites glisser pour tourner · pincez ou molette pour zoomer · deux doigts pour déplacer.
            </p>
          </div>

          <!-- ── WJ26 · Légende : ce que vous voyez, pan par pan ─────────────── -->
          <div class="mt-4 flex flex-wrap items-center gap-x-6 gap-y-2 text-sm" aria-label="Légende de la vue 3D">
            <span class="inline-flex items-center gap-2 text-lune-soft">
              <span class="inline-block h-3 w-3 rounded-sm" style="background: #14263f; outline: 1px solid rgb(255 255 255 / 0.25)" aria-hidden="true"></span>
              <span data-i18n data-fr="Vos panneaux solaires" data-en="Your solar panels" data-ar="ألواحكم الشمسية">Vos panneaux solaires</span>
            </span>
            <span class="inline-flex items-center gap-2 text-lune-soft">
              <span class="inline-block h-3 w-3 rounded-sm" style="background: #b9bfca" aria-hidden="true"></span>
              <span data-i18n data-fr="Votre toiture" data-en="Your roof" data-ar="سطحكم">Votre toiture</span>
            </span>
            <span class="inline-flex items-center gap-2 text-lune-soft">
              <span class="inline-block h-3 w-3 rounded-sm" style="background: #9aa3b4" aria-hidden="true"></span>
              <span data-i18n data-fr="Obstacles (cheminée, cage d’escalier…)" data-en="Obstacles (chimney, stairwell…)" data-ar="عوائق (مدخنة، بيت الدرج…)">Obstacles (cheminée, cage d’escalier…)</span>
            </span>
          </div>
          {annotations.length > 0 && (
            <div class={`mt-4 grid gap-3 ${annotations.length > 1 ? 'sm:grid-cols-2' : ''}`}>
              {annotations.map((a) => (
                <div class="cine-card rounded-xl p-4 text-sm">
                  <p class="tech-label text-lune-faint">{a.label} · {a.roofTypeLabel}</p>
                  <p class="mt-2 text-lune-soft" data-i18n
                    data-fr={`Orientation ${a.orientation}${a.tiltDeg !== null ? ` · pente ${a.tiltDeg}°` : ''}${a.panels !== null ? ` · ${formatNumber(a.panels)} panneaux` : ''}${a.kwc !== null ? ` · ${formatNumber(a.kwc, 2)} kWc` : ''}`}
                    data-en={`Orientation ${a.orientation}${a.tiltDeg !== null ? ` · slope ${a.tiltDeg}°` : ''}${a.panels !== null ? ` · ${formatNumber(a.panels)} panels` : ''}${a.kwc !== null ? ` · ${formatNumber(a.kwc, 2)} kWc` : ''}`}
                    data-ar={`الاتجاه ${a.orientation}${a.tiltDeg !== null ? ` · الميل ${a.tiltDeg}°` : ''}${a.panels !== null ? ` · ${formatNumber(a.panels)} لوح` : ''}${a.kwc !== null ? ` · ${formatNumber(a.kwc, 2)} kWc` : ''}`}>
                    Orientation <strong class="text-lune">{a.orientation}</strong>
                    {a.tiltDeg !== null ? <> · pente <strong class="text-lune">{a.tiltDeg}°</strong></> : null}
                    {a.panels !== null ? <> · <strong class="text-lune">{formatNumber(a.panels)} panneaux</strong></> : null}
                    {a.kwc !== null ? <> · <strong class="text-brass-300">{formatNumber(a.kwc, 2)} kWc</strong></> : null}
                  </p>
                </div>
              ))}
            </div>
          )}

          <!-- ── WJ26 · Visite guidée (4 étapes, skippable, sans mouvement) ──── -->
          {walkSteps.length > 0 && (
            <div id="roof3d-walk" class="mt-6" role="group" aria-label="Explication guidée de votre installation">
              <div class="flex items-baseline justify-between gap-3">
                <p class="tech-label text-lune-faint" data-i18n data-fr="Tout est expliqué, étape par étape" data-en="Everything is explained, step by step" data-ar="كل شيء موضّح، خطوة بخطوة">Tout est expliqué, étape par étape</p>
                <a href="#options" class="text-xs text-lune-faint underline-offset-2 hover:underline" data-i18n data-fr="Passer l’explication" data-en="Skip the explanation" data-ar="تخطي الشرح">Passer l’explication</a>
              </div>
              <ol class="mt-3 space-y-3">
                {walkSteps.map((s, i) => (
                  <li
                    class="walk-step cine-card rounded-xl p-4"
                    data-walk-step={s.id}
                    aria-current={i === 0 ? 'step' : undefined}
                  >
                    <p class="text-sm font-bold text-lune" data-i18n data-fr={`${i + 1}. ${s.title}`} data-en={`${i + 1}. ${s.title}`} data-ar={`${i + 1}. ${s.titleAr}`}>
                      <span class="fig text-brass-300">{i + 1}.</span> {s.title}
                    </p>
                    <p class="v2-body mt-1.5 text-sm text-lune-soft">{s.body}</p>
                  </li>
                ))}
              </ol>
              <div class="mt-3 flex items-center gap-3">
                <button id="roof3d-walk-prev" type="button" class="btn-pill px-4 py-1.5 text-sm" disabled data-i18n data-fr="Précédent" data-en="Previous" data-ar="السابق">Précédent</button>
                <button id="roof3d-walk-next" type="button" class="btn-pill px-4 py-1.5 text-sm" data-i18n data-fr="Suivant" data-en="Next" data-ar="التالي">Suivant</button>
                <span id="roof3d-walk-count" class="text-xs text-lune-faint" aria-live="polite" data-i18n data-fr={`Étape 1 sur ${walkSteps.length}`} data-en={`Step 1 of ${walkSteps.length}`} data-ar={`الخطوة 1 من ${walkSteps.length}`}>Étape 1 sur {walkSteps.length}</span>
              </div>
            </div>
          )}
        </section>
        <div class="seam-soft" aria-hidden="true"></div>
        </>
      )}

      <!-- ── WJ9 · ARGENT DANS LE TEMPS (cumul 25 ans + payback + /mois) ───── -->
      {headline && (headline.cumulative || headline.annual || paybackHero || prodKwh) && (
        <section class="mx-auto max-w-4xl px-5 pt-12 sm:px-8 sm:pt-16">
          {/* Accroche « coût de ne rien faire » : le cumul phare. */}
          {headline.cumulative ? (
            <div class="cine-card cine-in rounded-2xl p-6 shadow-premium sm:p-8" style="border-color: rgb(232 181 74 / 0.35)">
              <p class="tech-label text-lune-faint" data-i18n
                data-fr={`Sans le solaire, votre facture continue de courir. Avec, vous économisez sur ${headline.years} ans`}
                data-en={`Without solar, your bill keeps climbing. With it, you save over ${headline.years} years`}
                data-ar={`بدون الطاقة الشمسية، تستمر فاتورتكم في الارتفاع. معها، توفرون على مدى ${headline.years} سنة`}>
                Sans le solaire, votre facture continue de courir. Avec, vous économisez sur {headline.years} ans
              </p>
              <p class="fig lum mt-3 text-4xl sm:text-5xl" dir="ltr">{formatMAD(headline.cumulative)}</p>
              <p class="v2-body mt-2 text-sm text-lune-soft" data-i18n
                data-fr={`Économies cumulées estimées sur ${headline.years} ans${headline.monthly ? ` — soit ≈ ${formatMAD(headline.monthly)}/mois qui restent dans votre poche` : ''}.${!headline.cumulativeFromBackend ? ' Estimation à tarif constant (loi 82-21, autoconsommation).' : ''}`}
                data-en={`Estimated cumulative savings over ${headline.years} years${headline.monthly ? ` — that's ≈ ${formatMAD(headline.monthly)}/month staying in your pocket` : ''}.${!headline.cumulativeFromBackend ? ' Estimate at constant tariff (law 82-21, self-consumption).' : ''}`}
                data-ar={`توفير تراكمي مقدّر على مدى ${headline.years} سنة${headline.monthly ? ` — أي ما يعادل ≈ ${formatMAD(headline.monthly)}/شهر تبقى في جيبكم` : ''}.${!headline.cumulativeFromBackend ? ' تقدير بتعريفة ثابتة (القانون 82-21، الاستهلاك الذاتي).' : ''}`}>
                Économies cumulées estimées sur {headline.years} ans
                {headline.monthly ? <> — soit <span class="text-brass-300">≈ {formatMAD(headline.monthly)}/mois</span> qui restent dans votre poche</> : null}.
                {!headline.cumulativeFromBackend ? <span class="text-lune-faint"> Estimation à tarif constant (loi 82-21, autoconsommation).</span> : null}
              </p>
            </div>
          ) : null}

          <div class="mt-4 grid gap-4 sm:grid-cols-3">
            {headline.annual ? (
              <div class="cine-card rounded-xl p-5">
                <p class="tech-label text-lune-faint" data-i18n data-fr="Économies estimées / an" data-en="Estimated savings / year" data-ar="التوفير المقدّر / سنة">Économies estimées / an</p>
                <p class="fig fig-md lum mt-2" dir="ltr">{formatMAD(headline.annual)}</p>
                {headline.monthly ? <p class="mt-1 text-sm text-lune-faint" dir="ltr">≈ {formatMAD(headline.monthly)}/mois</p> : null}
              </div>
            ) : null}
            {paybackHero ? (
              <div class="cine-card rounded-xl p-5">
                <p class="tech-label text-lune-faint" data-i18n data-fr="Rentabilisé en" data-en="Paid back in" data-ar="يُسترد خلال">Rentabilisé en</p>
                <p class="fig fig-md mt-2 text-lune" dir="ltr">{paybackHero}</p>
                <p class="mt-1 text-sm text-lune-faint" data-i18n data-fr="puis l’énergie est gratuite" data-en="then energy is free" data-ar="ثم تصبح الطاقة مجانية">puis l’énergie est gratuite</p>
              </div>
            ) : null}
            {prodKwh ? (
              <div class="cine-card rounded-xl p-5">
                <p class="tech-label text-lune-faint" data-i18n data-fr="Production estimée / an" data-en="Estimated production / year" data-ar="الإنتاج المقدّر / سنة">Production estimée / an</p>
                <p class="fig fig-md mt-2 text-lune" dir="ltr">{formatNumber(prodKwh)} <span class="text-lg text-lune-soft">kWh</span></p>
              </div>
            ) : null}
          </div>
        </section>
      )}

      <!-- ── SYSTÈME : puissance / panneaux ───────────────────────────────── -->
      {(puissance || nbPanneaux) && (
        <section class="mx-auto max-w-4xl px-5 pt-12 sm:px-8">
          <p class="tech-label rule-brass text-brass-300" data-i18n data-fr="Votre système" data-en="Your system" data-ar="نظامكم">Votre système</p>
          <div class="mt-5 grid gap-4 sm:grid-cols-3">
            {puissance ? (
              <div class="cine-card rounded-xl p-5">
                <p class="tech-label text-lune-faint" data-i18n data-fr="Puissance" data-en="Power" data-ar="القدرة">Puissance</p>
                <p class="fig mt-2 text-2xl text-lune" dir="ltr">{formatNumber(puissance, 2)} <span class="text-base text-lune-soft">kWc</span></p>
              </div>
            ) : null}
            {nbPanneaux ? (
              <div class="cine-card rounded-xl p-5">
                <p class="tech-label text-lune-faint" data-i18n data-fr="Panneaux" data-en="Panels" data-ar="الألواح">Panneaux</p>
                <p class="fig mt-2 text-2xl text-lune" dir="ltr">
                  {formatNumber(nbPanneaux)}
                  {wattPanneau ? <span class="text-base text-lune-soft"> × {formatNumber(wattPanneau)} W</span> : null}
                </p>
              </div>
            ) : null}
            <div class="cine-card rounded-xl p-5">
              <p class="tech-label text-lune-faint" data-i18n data-fr="Type" data-en="Type" data-ar="النوع">Type</p>
              <p class="fig mt-2 text-2xl text-lune">{instLabel}</p>
            </div>
          </div>
        </section>
      )}

      <!-- ── P2 · PRODUCTION ESTIMÉE vs CONSOMMATION (langage pro-11) ──────── -->
      {showChart && (
        <section class="mx-auto max-w-4xl px-5 pt-14 sm:px-8">
          <p class="tech-label rule-brass text-brass-300" data-i18n
            data-fr={chartHasConso ? 'Production estimée vs votre consommation' : 'Production estimée'}
            data-en={chartHasConso ? 'Estimated production vs your consumption' : 'Estimated production'}
            data-ar={chartHasConso ? 'الإنتاج المقدّر مقابل استهلاككم' : 'الإنتاج المقدّر'}>
            {chartHasConso ? 'Production estimée vs votre consommation' : 'Production estimée'}
          </p>
          <div class="cine-card mt-5 rounded-2xl p-5 sm:p-6">
            <div class="chart-svg" set:html={chartSvg}></div>
            <div class="mt-4 flex flex-wrap items-center gap-x-6 gap-y-2 text-sm">
              <span class="inline-flex items-center gap-2 text-lune-soft">
                <span class="inline-block h-3 w-3 rounded-sm" style="background: var(--color-brass-400)" aria-hidden="true"></span>
                <span data-i18n data-fr="Production solaire estimée" data-en="Estimated solar production" data-ar="الإنتاج الشمسي المقدّر">Production solaire estimée</span>
              </span>
              {chartHasConso && (
                <span class="inline-flex items-center gap-2 text-lune-soft">
                  <span class="inline-block h-3 w-3 rounded-sm" style="background: var(--color-azur-300, #7fb4e8)" aria-hidden="true"></span>
                  <span data-i18n data-fr="Votre consommation" data-en="Your consumption" data-ar="استهلاككم">Votre consommation</span>
                </span>
              )}
              <span class="text-lune-faint" data-i18n data-fr="kWh par mois" data-en="kWh per month" data-ar="كيلوواط ساعة شهرياً">kWh par mois</span>
            </div>
            {(prodKwh || ecoHero) && (
              <p class="v2-body mt-4 text-sm text-lune-soft" data-i18n
                data-fr={`${prodKwh ? `Sur l’année, votre installation produit environ ${formatNumber(prodKwh)} kWh.` : ''}${chartHasConso ? ' Plus la production (laiton) couvre votre consommation (azur), plus vous économisez.' : ''}`}
                data-en={`${prodKwh ? `Over the year, your installation produces around ${formatNumber(prodKwh)} kWh.` : ''}${chartHasConso ? ' The more production (brass) covers your consumption (blue), the more you save.' : ''}`}
                data-ar={`${prodKwh ? `على مدار السنة، ينتج تركيبكم حوالي ${formatNumber(prodKwh)} kWh.` : ''}${chartHasConso ? ' كلما غطى الإنتاج (الذهبي) استهلاككم (الأزرق)، كلما وفّرتم أكثر.' : ''}`}>
                {prodKwh ? <>Sur l’année, votre installation produit environ <strong class="text-lune">{formatNumber(prodKwh)} kWh</strong>.</> : null}
                {chartHasConso ? ' Plus la production (laiton) couvre votre consommation (azur), plus vous économisez.' : ''}
              </p>
            )}
          </div>
        </section>
      )}

      <!-- ── WJ16 · COURBE JOURNALIÈRE (lever → coucher) ───────────────────── -->
      {/* Visuel le plus persuasif : la cloche solaire couvre la conso du foyer.
          Calée sur la production RÉELLE si présente, sinon « année type » libellée.
          Animation gatée prefers-reduced-motion (voir <style>). */}
      {dailyCurve.svg && (
        <section class="mx-auto max-w-4xl px-5 pt-14 sm:px-8">
          <p class="tech-label rule-brass text-brass-300" data-i18n data-fr="Votre journée solaire" data-en="Your solar day" data-ar="يومكم الشمسي">Votre journée solaire</p>
          <div class="cine-card mt-5 rounded-2xl p-5 sm:p-6">
            <div class="daily-curve-wrap" set:html={dailyCurve.svg}></div>
            <div class="mt-4 flex flex-wrap items-center gap-x-6 gap-y-2 text-sm">
              <span class="inline-flex items-center gap-2 text-lune-soft">
                <span class="inline-block h-3 w-3 rounded-sm" style="background: var(--color-brass-400)" aria-hidden="true"></span>
                <span data-i18n data-fr="Production solaire" data-en="Solar production" data-ar="الإنتاج الشمسي">Production solaire</span>
              </span>
              <span class="inline-flex items-center gap-2 text-lune-soft">
                <span class="inline-block h-3 w-3 rounded-sm" style="background: var(--color-azur-300, #7fb4e8)" aria-hidden="true"></span>
                <span data-i18n data-fr="Votre consommation" data-en="Your consumption" data-ar="استهلاككم">Votre consommation</span>
              </span>
              {!dailyCurve.hasRealScale && (
                <span class="text-lune-faint" data-i18n data-fr="profil — année type (forme indicative)" data-en="profile — typical year (indicative shape)" data-ar="نمط — سنة نموذجية (شكل إرشادي)">profil — année type (forme indicative)</span>
              )}
            </div>
            <p class="v2-body mt-4 text-sm text-lune-soft" data-i18n
              data-fr={`Le soleil produit en pleine journée : chaque kWh consommé à ce moment-là ne vient plus du réseau. ${dailyCurve.hasRealScale ? 'Les repères sont calés sur votre production estimée.' : 'Cette courbe illustre une journée type — votre profil exact est précisé avec votre conseiller.'}`}
              data-en={`The sun produces during the day: every kWh consumed at that moment no longer comes from the grid. ${dailyCurve.hasRealScale ? 'The markers are calibrated on your estimated production.' : 'This curve illustrates a typical day — your exact profile is confirmed with your advisor.'}`}
              data-ar={`تنتج الشمس في وضح النهار: كل كيلوواط ساعة يُستهلك في تلك اللحظة لم يعد يأتي من الشبكة. ${dailyCurve.hasRealScale ? 'المعالم مضبوطة على إنتاجكم المقدّر.' : 'يوضّح هذا المنحنى يوماً نموذجياً — يُحدَّد ملفكم الدقيق مع مستشاركم.'}`}>
              Le soleil produit en pleine journée : chaque kWh consommé à ce moment-là
              ne vient plus du réseau. {dailyCurve.hasRealScale
                ? 'Les repères sont calés sur votre production estimée.'
                : 'Cette courbe illustre une journée type — votre profil exact est précisé avec votre conseiller.'}
            </p>
          </div>
        </section>
      )}

      <!-- ── OPTIONS ──────────────────────────────────────────────────────── -->
      <section id="options" class="mx-auto max-w-4xl px-5 pt-14 sm:px-8">
        <p class="tech-label rule-brass text-brass-300" data-i18n
          data-fr={twoOptions ? 'Vos deux options' : 'Votre proposition'}
          data-en={twoOptions ? 'Your two options' : 'Your proposal'}
          data-ar={twoOptions ? 'خياراكم' : 'عرضكم'}>
          {twoOptions ? 'Vos deux options' : 'Votre proposition'}
        </p>
        <div class={`mt-5 grid gap-4 ${twoOptions ? 'sm:grid-cols-2' : ''}`}>
          {options.map((opt) => {
            const totaux = optionTotaux(data!, opt);
            const items = optionItems(data!, opt);
            const isReco = twoOptions && opt === reco;
            const eco = opt === 'avec_batterie' ? ecoAvec : ecoSans;
            return (
              <article
                class="cine-card relative flex flex-col rounded-2xl p-6"
                style={isReco ? 'border-color: rgb(232 181 74 / 0.45)' : undefined}
              >
                {isReco && (
                  <span class="absolute -top-3 left-6 rounded-full bg-brass-400 px-3 py-1 text-xs font-bold text-nuit" data-i18n data-fr="Recommandé" data-en="Recommended" data-ar="موصى به">
                    Recommandé
                  </span>
                )}
                <h3 class="display text-xl text-lune" data-i18n data-fr={optionLabel(opt)} data-en={optionLabelEn(opt)} data-ar={optionLabelAr(opt)}>{optionLabel(opt)}</h3>
                <p class="fig fig-md lum mt-3" dir="ltr">{formatMAD(optionTtc(data!, opt))}</p>
                <p class="text-sm text-lune-faint" data-i18n data-fr="TTC, clé en main" data-en="incl. tax, turnkey" data-ar="شامل الضريبة، تسليم مفتاح في اليد">TTC, clé en main</p>
                {eco ? (
                  <p class="mt-2 text-sm text-lune-soft" data-i18n
                    data-fr={`Économies estimées : ${formatMAD(eco)}/an`}
                    data-en={`Estimated savings: ${formatMAD(eco)}/year`}
                    data-ar={`التوفير المقدّر: ${formatMAD(eco)}/سنة`}>
                    Économies estimées : <span class="text-brass-300">{formatMAD(eco)}/an</span>
                  </p>
                ) : null}

                <!-- Équipement (WJ32 : marque + garantie + description quand disponibles — jamais de lien fiche technique fabriqué, le backend n'expose pas encore cette URL publiquement) -->
                {items.length > 0 && (
                  <div class="mt-5 border-t border-white/10 pt-4">
                    <p class="tech-label text-lune-faint" data-i18n data-fr="Équipement" data-en="Equipment" data-ar="المعدات">Équipement</p>
                    <ul class="mt-3 space-y-3 text-sm text-lune-soft">
                      {items.map((it) => (
                        <li>
                          <div class="flex items-baseline justify-between gap-3">
                            <span>
                              <span class="text-lune">{it.designation}</span>
                              {it.marque ? <span class="text-lune-faint"> · {it.marque}</span> : null}
                            </span>
                            <span class="fig shrink-0 text-lune-faint" dir="ltr">×{formatNumber(it.quantite)}</span>
                          </div>
                          {it.description ? (
                            <p class="mt-0.5 text-xs text-lune-faint">{it.description}</p>
                          ) : null}
                          {it.garantie ? (
                            <p class="mt-0.5 text-xs text-brass-300" data-i18n
                              data-fr={`Garantie : ${it.garantie}`} data-en={`Warranty: ${it.garantie}`} data-ar={`الضمان: ${it.garantie}`}>Garantie : {it.garantie}</p>
                          ) : null}
                        </li>
                      ))}
                    </ul>
                  </div>
                )}

                <!-- Chaîne de prix explicite -->
                {totaux && (
                  <dl class="mt-5 space-y-1.5 border-t border-white/10 pt-4 text-sm">
                    <div class="flex justify-between">
                      <dt class="text-lune-faint" data-i18n data-fr="Sous-total HT" data-en="Subtotal excl. tax" data-ar="المجموع الفرعي (بدون ضريبة)">Sous-total HT</dt>
                      <dd class="fig text-lune-soft" dir="ltr">{formatMAD(totaux.ht_brut)}</dd>
                    </div>
                    {totaux.remise > 0 && (
                      <div class="flex justify-between">
                        <dt class="text-lune-faint" data-i18n data-fr="Remise" data-en="Discount" data-ar="التخفيض">Remise</dt>
                        <dd class="fig text-brass-300" dir="ltr">−{formatMAD(totaux.remise)}</dd>
                      </div>
                    )}
                    <div class="flex justify-between">
                      <dt class="text-lune-faint" data-i18n data-fr="Total HT" data-en="Total excl. tax" data-ar="المجموع (بدون ضريبة)">Total HT</dt>
                      <dd class="fig text-lune-soft" dir="ltr">{formatMAD(totaux.ht_net)}</dd>
                    </div>
                    <div class="flex justify-between">
                      <dt class="text-lune-faint" data-i18n data-fr="TVA" data-en="VAT" data-ar="الضريبة على القيمة المضافة">TVA</dt>
                      <dd class="fig text-lune-soft" dir="ltr">{formatMAD(totaux.tva)}</dd>
                    </div>
                    <div class="flex justify-between border-t border-white/10 pt-2">
                      <dt class="text-lune" data-i18n data-fr="Total TTC" data-en="Total incl. tax" data-ar="المجموع شامل الضريبة">Total TTC</dt>
                      <dd class="fig text-lg text-lune" dir="ltr">{formatMAD(totaux.ttc)}</dd>
                    </div>
                  </dl>
                )}
              </article>
            );
          })}
        </div>
      </section>

      <!-- ── WJ10/WJ32 · COMPARATIF DE FINANCEMENT ───────────────────────────
           Priorité au bloc BACKEND réel (QJ12, programme Tatwir/ISTIDAMA +
           comparaison ONEE déjà rédigée serveur) quand il est présent ; repli
           sur le calcul générique WJ10 sinon — jamais les deux à la fois. -->
      {financingBlock ? (
        <section class="mx-auto max-w-4xl px-5 pt-14 sm:px-8">
