      {/* ════════════════════════════════════════════════════════════════════
          WJ126 · VARIANTE AGRICOLE (pompage solaire) — héros pompe + eau/mois
          + bassin + FDA (sous réserve) + carburant évité. Chaque chiffre vient
          du bloc KPI backend (`agri`) ; un champ manquant est OMIS (jamais 0).
          Aucune carte batterie ici (pompage = pas de batterie, CLAUDE.md).
          ════════════════════════════════════════════════════════════════════ */}
      {isAgricole && agri && (
        <section class="mx-auto max-w-4xl px-5 pt-12 sm:px-8" id="mode-agricole">
          <p class="tech-label rule-brass text-brass-300" data-i18n data-fr="Votre pompage solaire" data-en="Your solar pumping" data-ar="ضخّكم الشمسي">Votre pompage solaire</p>
          <div class="mt-5 grid gap-4 sm:grid-cols-3">
            {(agri.pompe_cv || agri.pompe_kw) ? (
              <div class="cine-card rounded-xl p-5">
                <p class="tech-label text-lune-faint" data-i18n data-fr="Pompe" data-en="Pump" data-ar="المضخة">Pompe</p>
                <p class="fig mt-2 text-2xl text-lune" dir="ltr">
                  {agri.pompe_cv ? <>{formatNumber(agri.pompe_cv, 1)} <span class="text-base text-lune-soft">CV</span></> : null}
                  {agri.pompe_cv && agri.pompe_kw ? <span class="text-lune-faint"> · </span> : null}
                  {agri.pompe_kw ? <>{formatNumber(agri.pompe_kw, 1)} <span class="text-base text-lune-soft">kW</span></> : null}
                </p>
              </div>
            ) : null}
            {agri.m3_jour ? (
              <div class="cine-card rounded-xl p-5">
                <p class="tech-label text-lune-faint" data-i18n data-fr="Eau / jour" data-en="Water / day" data-ar="الماء / يوم">Eau / jour</p>
                <p class="fig mt-2 text-2xl text-lune" dir="ltr">{formatNumber(agri.m3_jour)} <span class="text-base text-lune-soft">m³</span></p>
                {agri.hmt_m ? (
                  <p class="mt-1 text-sm text-lune-faint" dir="ltr" data-i18n
                    data-fr={`à ${formatNumber(agri.hmt_m)} m HMT`}
                    data-en={`at ${formatNumber(agri.hmt_m)} m head`}
                    data-ar={`عند ${formatNumber(agri.hmt_m)} m (ع.ر.)`}>à {formatNumber(agri.hmt_m)} m HMT</p>
                ) : null}
              </div>
            ) : null}
            {agri.champ_kwc ? (
              <div class="cine-card rounded-xl p-5">
                <p class="tech-label text-lune-faint" data-i18n data-fr="Champ solaire" data-en="Solar array" data-ar="الحقل الشمسي">Champ solaire</p>
                <p class="fig mt-2 text-2xl text-lune" dir="ltr">{formatNumber(agri.champ_kwc, 2)} <span class="text-base text-lune-soft">kWc</span></p>
              </div>
            ) : null}
          </div>
          {/* Honnêteté : aucun KPI pompe exploitable → message d'omission clair. */}
          {(!agri.pompe_cv && !agri.pompe_kw && !agri.m3_jour && !agri.champ_kwc) ? (
            <p class="mt-4 text-sm text-lune-faint" data-i18n
              data-fr="Le dimensionnement précis de votre pompe est confirmé avec votre conseiller."
              data-en="The precise sizing of your pump is confirmed with your advisor."
              data-ar="يُحدَّد تحجيم مضختكم الدقيق مع مستشاركم.">Le dimensionnement précis de votre pompe est confirmé avec votre conseiller.</p>
          ) : null}
          {agri.debit_hmt_m3h ? (
            <p class="mt-4 text-sm text-lune-soft" data-i18n
              data-fr={`Débit estimé ≈ ${formatNumber(agri.debit_hmt_m3h)} m³/h à la hauteur de refoulement retenue.`}
              data-en={`Estimated flow ≈ ${formatNumber(agri.debit_hmt_m3h)} m³/h at the selected head.`}
              data-ar={`التدفق المقدّر ≈ ${formatNumber(agri.debit_hmt_m3h)} m³/h عند ارتفاع الرفع المعتمد.`}>Débit estimé ≈ {formatNumber(agri.debit_hmt_m3h)} m³/h à la hauteur de refoulement retenue.</p>
          ) : null}

          {/* Livraison d'eau mensuelle estimée — suit l'ensoleillement. Omise si
              m3_jour ou la production mensuelle manque (jamais une courbe besoin
              fabriquée : la série besoin/culture n'est pas dans ce payload). */}
          {waterDelivery && (
            <div class="cine-card mt-5 rounded-2xl p-5 sm:p-6">
              <p class="tech-label text-lune-faint" data-i18n data-fr="Votre eau au fil des mois" data-en="Your water month by month" data-ar="ماؤكم على مدار الأشهر">Votre eau au fil des mois</p>
              <div class="mt-4 flex items-end gap-1.5" dir="ltr" role="img"
                aria-label="Livraison d'eau estimée par mois, suivant l'ensoleillement">
                {waterDelivery.map((m) => (
                  <div class="flex flex-1 flex-col items-center gap-1">
                    <span class="w-full rounded-t" style={`height:${Math.max(4, Math.round((m.m3 / waterMax) * 72))}px; background: var(--color-azur-300, #7fb4e8)`}></span>
                    <span class="text-[10px] text-lune-faint">{MONTHS_SHORT.fr[m.monthIndex]}</span>
                  </div>
                ))}
              </div>
              <p class="mt-3 text-xs text-lune-faint" data-i18n
                data-fr="Capacité de livraison indicative — le pompage solaire suit l'ensoleillement (dérivée du débit journalier et de la production estimée, jamais un relevé mesuré)."
                data-en="Indicative delivery capacity — solar pumping follows the sun (derived from the daily flow and estimated production, never a measured reading)."
                data-ar="قدرة تسليم إرشادية — يتبع الضخّ الشمسي أشعة الشمس (مشتقّة من التدفق اليومي والإنتاج المقدّر، وليست قراءة مقيسة).">Capacité de livraison indicative — le pompage solaire suit l'ensoleillement (dérivée du débit journalier et de la production estimée, jamais un relevé mesuré).</p>
            </div>
          )}

          <div class="mt-5 grid gap-4 sm:grid-cols-2">
            {agri.bassin_m3 ? (
              <div class="cine-card rounded-xl p-5">
                <p class="tech-label text-lune-faint" data-i18n data-fr="Bassin recommandé" data-en="Recommended reservoir" data-ar="حوض موصى به">Bassin recommandé</p>
                <p class="fig mt-2 text-2xl text-lune" dir="ltr">{formatNumber(agri.bassin_m3)} <span class="text-base text-lune-soft">m³</span></p>
                <p class="mt-1 text-sm text-lune-faint" data-i18n
                  data-fr="≈ 2 jours d'autonomie d'eau : pompez au soleil, irriguez à la demande."
                  data-en="≈ 2 days of water autonomy: pump in the sun, irrigate on demand."
                  data-ar="≈ يومان من استقلالية الماء: اضخّوا تحت الشمس واسقوا عند الحاجة.">≈ 2 jours d'autonomie d'eau : pompez au soleil, irriguez à la demande.</p>
              </div>
            ) : null}
            {agri.fda_eligible ? (
              <div class="cine-card rounded-xl p-5">
                <p class="tech-label text-brass-300" data-i18n data-fr="Subvention FDA envisageable" data-en="FDA subsidy possible" data-ar="دعم FDA ممكن">Subvention FDA envisageable</p>
                <p class="mt-2 text-sm text-lune-soft" data-i18n
                  data-fr="Votre irrigation localisée (goutte-à-goutte) peut ouvrir droit à une aide du Fonds de Développement Agricole pouvant atteindre 30 %. Sous réserve d'éligibilité — votre conseiller vous accompagne dans le dossier."
                  data-en="Your localized (drip) irrigation may qualify for Agricultural Development Fund support of up to 30%. Subject to eligibility — your advisor guides you through the application."
                  data-ar="قد يؤهّل ريّكم الموضعي (بالتنقيط) للحصول على دعم من صندوق التنمية الفلاحية قد يصل إلى 30%. رهْن الأهلية — يرافقكم مستشاركم في الملف.">Votre irrigation localisée (goutte-à-goutte) peut ouvrir droit à une aide du Fonds de Développement Agricole pouvant atteindre 30 %. Sous réserve d'éligibilité — votre conseiller vous accompagne dans le dossier.</p>
              </div>
            ) : null}
          </div>

          {/* Carburant évité — QUALITATIF (aucun chiffre de gasoil dans le payload). */}
          <div class="cine-card mt-5 rounded-xl p-5">
            <p class="tech-label text-brass-300" data-i18n data-fr="Fini le carburant" data-en="No more fuel" data-ar="وداعاً للوقود">Fini le carburant</p>
            <p class="mt-2 text-sm text-lune-soft" data-i18n
              data-fr="Le pompage solaire tourne au soleil : plus de gasoil à acheter ni à transporter, plus de groupe à entretenir. Une pompe silencieuse, sans facture de carburant."
              data-en="Solar pumping runs on sunlight: no more diesel to buy or haul, no generator to service. A quiet pump, with no fuel bill."
              data-ar="يعمل الضخّ الشمسي بالطاقة الشمسية: لا مازوط للشراء أو النقل، ولا مولّد للصيانة. مضخة صامتة، بلا فاتورة وقود.">Le pompage solaire tourne au soleil : plus de gasoil à acheter ni à transporter, plus de groupe à entretenir. Une pompe silencieuse, sans facture de carburant.</p>
          </div>
        </section>
      )}

      {/* ════════════════════════════════════════════════════════════════════
          WJ126 · VARIANTE AUTOCONSOMMATION (industriel + commercial) — tuiles
          autoconso/couverture/économies/payback + injection 82-21 (si calculée,
          mention ANRE) + mini-cashflow 10 ans (même modèle linéaire que le PDF).
          ════════════════════════════════════════════════════════════════════ */}
      {isAutoconso && auto && (
        <section class="mx-auto max-w-4xl px-5 pt-12 sm:px-8" id="mode-autoconso">
          <p class="tech-label rule-brass text-brass-300" data-i18n
            data-fr={isCommercial ? 'Votre autoconsommation' : 'Votre autoconsommation industrielle'}
            data-en={isCommercial ? 'Your self-consumption' : 'Your industrial self-consumption'}
            data-ar={isCommercial ? 'استهلاككم الذاتي' : 'استهلاككم الذاتي الصناعي'}>{isCommercial ? 'Votre autoconsommation' : 'Votre autoconsommation industrielle'}</p>
          <div class="mt-5 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
            {auto.taux_autoconso !== null ? (
              <div class="cine-card rounded-xl p-5">
                <p class="tech-label text-lune-faint" data-i18n data-fr="Taux d'autoconsommation" data-en="Self-consumption rate" data-ar="نسبة الاستهلاك الذاتي">Taux d'autoconsommation</p>
                <p class="fig fig-md lum mt-2" dir="ltr">{formatNumber(auto.taux_autoconso)} %</p>
              </div>
            ) : null}
            {auto.taux_couverture !== null ? (
              <div class="cine-card rounded-xl p-5">
                <p class="tech-label text-lune-faint" data-i18n data-fr="Taux de couverture" data-en="Coverage rate" data-ar="نسبة التغطية">Taux de couverture</p>
                <p class="fig fig-md mt-2 text-lune" dir="ltr">{formatNumber(auto.taux_couverture)} %</p>
              </div>
            ) : null}
            {auto.economies_annuelles !== null ? (
              <div class="cine-card rounded-xl p-5">
                <p class="tech-label text-lune-faint" data-i18n data-fr="Économies estimées / an" data-en="Estimated savings / year" data-ar="التوفير المقدّر / سنة">Économies estimées / an</p>
                <p class="fig fig-md lum mt-2" dir="ltr">{formatMAD(auto.economies_annuelles)}</p>
              </div>
            ) : null}
            {auto.payback !== null ? (
              <div class="cine-card rounded-xl p-5">
                <p class="tech-label text-lune-faint" data-i18n data-fr="Rentabilisé en" data-en="Paid back in" data-ar="يُسترد خلال">Rentabilisé en</p>
                <p class="fig fig-md mt-2 text-lune" dir="ltr">{formatNumber(auto.payback, 1)} <span class="text-base text-lune-soft" data-i18n data-fr="ans" data-en="years" data-ar="سنة">ans</span></p>
              </div>
            ) : null}
          </div>
          {(auto.taux_autoconso === null && auto.taux_couverture === null && auto.economies_annuelles === null && auto.payback === null) ? (
            <p class="mt-4 text-sm text-lune-faint" data-i18n
              data-fr="Les indicateurs détaillés de votre étude sont confirmés avec votre conseiller."
              data-en="The detailed indicators of your study are confirmed with your advisor."
              data-ar="تُؤكَّد المؤشرات التفصيلية لدراستكم مع مستشاركم.">Les indicateurs détaillés de votre étude sont confirmés avec votre conseiller.</p>
          ) : null}

          {/* Injection 82-21 — UNIQUEMENT si réellement calculée. Mention ANRE
              obligatoire : l'autoconsommation reste prioritaire, l'injection du
              surplus dépend de la convention en vigueur (jamais promise). */}
          {autoHasInjection && auto.injection_kwh_an !== null && (
            <div class="cine-card mt-5 rounded-xl p-5">
              <p class="tech-label text-brass-300" data-i18n data-fr="Injection du surplus (loi 82-21)" data-en="Surplus injection (law 82-21)" data-ar="حقن الفائض (القانون 82-21)">Injection du surplus (loi 82-21)</p>
              <p class="mt-2 text-sm text-lune-soft" data-i18n
                data-fr={`≈ ${formatNumber(auto.injection_kwh_an)} kWh/an de surplus injectables${auto.injection_dh_an !== null ? `, soit ≈ ${formatMAD(auto.injection_dh_an)}/an` : ''}.`}
                data-en={`≈ ${formatNumber(auto.injection_kwh_an)} kWh/year of injectable surplus${auto.injection_dh_an !== null ? `, i.e. ≈ ${formatMAD(auto.injection_dh_an)}/year` : ''}.`}
                data-ar={`≈ ${formatNumber(auto.injection_kwh_an)} kWh/سنة من الفائض القابل للحقن${auto.injection_dh_an !== null ? `، أي ≈ ${formatMAD(auto.injection_dh_an)}/سنة` : ''}.`}>≈ {formatNumber(auto.injection_kwh_an)} kWh/an de surplus injectables{auto.injection_dh_an !== null ? <>, soit ≈ {formatMAD(auto.injection_dh_an)}/an</> : null}.</p>
              <p class="mt-1 text-xs text-lune-faint" data-i18n
                data-fr="Tarif ANRE valable 03/2026–02/2027, plafond en révision. Sous réserve de la convention d'injection ANRE/ONEE en vigueur — l'autoconsommation reste prioritaire (loi 82-21). Aucune revente n'est garantie."
                data-en="ANRE tariff valid 03/2026–02/2027, cap under revision. Subject to the applicable ANRE/ONEE injection agreement — self-consumption remains the priority (law 82-21). No resale is guaranteed."
                data-ar="تعريفة ANRE سارية 03/2026–02/2027، السقف قيد المراجعة. رهْن اتفاقية الحقن السارية لدى ANRE/ONEE — يبقى الاستهلاك الذاتي أولوية (القانون 82-21). لا يُضمن أي إعادة بيع.">Tarif ANRE valable 03/2026–02/2027, plafond en révision. Sous réserve de la convention d'injection ANRE/ONEE en vigueur — l'autoconsommation reste prioritaire (loi 82-21). Aucune revente n'est garantie.</p>
            </div>
          )}

          {/* Mini-cashflow 10 ans : investissement remboursé puis bénéfice net
              cumulé. Azur = encore en déficit, laiton = bénéfice. Même hypothèse
              tarif constant que le PDF (aucune dérive inventée). */}
          {autoCashflow && (
            <div class="cine-card mt-5 rounded-2xl p-5 sm:p-6">
              <p class="tech-label text-lune-faint" data-i18n data-fr="Votre trésorerie sur 10 ans" data-en="Your cash flow over 10 years" data-ar="خزينتكم على مدى 10 سنوات">Votre trésorerie sur 10 ans</p>
              <div class="mt-4 flex items-end gap-1.5" dir="ltr" role="img"
                aria-label="Trésorerie nette cumulée sur 10 ans">
                {autoCashflow.map((p) => (
                  <div class="flex flex-1 flex-col items-center gap-1">
                    <span class="w-full rounded-t" style={`height:${Math.max(3, Math.round((Math.abs(p.cumulative) / cashMaxAbs) * 60))}px; background: ${p.cumulative >= 0 ? 'var(--color-brass-400, #e8b54a)' : 'var(--color-azur-300, #7fb4e8)'}`}></span>
                    <span class="text-[10px] text-lune-faint" dir="ltr">{p.year}</span>
                  </div>
                ))}
              </div>
              <p class="mt-3 text-xs text-lune-faint" data-i18n
                data-fr={`Trésorerie nette cumulée, année après année${cashBreakEven !== null ? ` — au point mort dès l'année ${cashBreakEven}` : ''}. Azur : investissement pas encore remboursé ; laiton : bénéfice net. Estimation à tarif constant (même hypothèse que votre devis PDF).`}
                data-en={`Cumulative net cash flow, year after year${cashBreakEven !== null ? ` — breaks even by year ${cashBreakEven}` : ''}. Blue: investment not yet repaid; brass: net profit. Estimate at constant tariff (same assumption as your PDF quote).`}
                data-ar={`الخزينة الصافية التراكمية سنة بعد سنة${cashBreakEven !== null ? ` — تبلغ نقطة التعادل ابتداءً من السنة ${cashBreakEven}` : ''}. الأزرق: الاستثمار لم يُسترد بعد؛ الذهبي: ربح صافٍ. تقدير بتعريفة ثابتة (نفس افتراض عرض PDF).`}>Trésorerie nette cumulée, année après année{cashBreakEven !== null ? <> — au point mort dès l'année {cashBreakEven}</> : null}. Azur : investissement pas encore remboursé ; laiton : bénéfice net. Estimation à tarif constant (même hypothèse que votre devis PDF).</p>
            </div>
          )}

          {/* Industriel uniquement : tranches horaires + décarbonation/CBAM/ISO
              (qualitatif, aucun chiffre inventé). */}
          {installMode === 'industriel' && (
            <div class="mt-5 grid gap-4 sm:grid-cols-2">
              <div class="cine-card rounded-xl p-5">
                <p class="tech-label text-brass-300" data-i18n data-fr="Écrêter vos tranches horaires" data-en="Shave your time-of-use peaks" data-ar="تقليص فترات الذروة">Écrêter vos tranches horaires</p>
                <p class="mt-2 text-sm text-lune-soft" data-i18n
                  data-fr="Le solaire produit en pleine journée, aux heures où le tarif industriel est le plus cher : vous écrêtez vos pointes et lissez votre puissance souscrite."
                  data-en="Solar produces in the middle of the day, when industrial tariffs peak: you shave your peaks and smooth your subscribed power."
                  data-ar="تنتج الطاقة الشمسية في وضح النهار، حين يكون التعريف الصناعي في ذروته: تقلّصون ذرواتكم وتُنعّمون القدرة المكتتبة.">Le solaire produit en pleine journée, aux heures où le tarif industriel est le plus cher : vous écrêtez vos pointes et lissez votre puissance souscrite.</p>
              </div>
              <div class="cine-card rounded-xl p-5">
                <p class="tech-label text-brass-300" data-i18n data-fr="Décarbonation, CBAM et ISO" data-en="Decarbonation, CBAM and ISO" data-ar="إزالة الكربون، CBAM و ISO">Décarbonation, CBAM et ISO</p>
                <p class="mt-2 text-sm text-lune-soft" data-i18n
                  data-fr="Chaque kWh solaire autoconsommé retire du CO₂ de votre bilan — un atout pour vos clients européens (mécanisme d'ajustement carbone aux frontières, CBAM) et vos certifications ISO 14001/50001."
                  data-en="Every self-consumed solar kWh removes CO₂ from your footprint — an asset for your European customers (Carbon Border Adjustment Mechanism, CBAM) and your ISO 14001/50001 certifications."
                  data-ar="كل كيلوواط ساعة شمسي مستهلك ذاتياً يزيل CO₂ من حصيلتكم — ميزة لعملائكم الأوروبيين (آلية تعديل الكربون على الحدود، CBAM) ولشهادات ISO 14001/50001.">Chaque kWh solaire autoconsommé retire du CO₂ de votre bilan — un atout pour vos clients européens (mécanisme d'ajustement carbone aux frontières, CBAM) et vos certifications ISO 14001/50001.</p>
              </div>
            </div>
          )}
        </section>
      )}

      {/* ════════════════════════════════════════════════════════════════════
          WJ126 · BLOC CATÉGORIE COMMERCIALE — archétype par secteur (hôtel,
          restaurant/froid, école, bureau…), miroir QUALITATIF du backend
          (categories.py). Commercial uniquement ; `autre` en repli honnête.
          ════════════════════════════════════════════════════════════════════ */}
      {isCommercial && comArchetype && (
        <section class="mx-auto max-w-4xl px-5 pt-12 sm:px-8" id="mode-commercial-cat">
          <p class="tech-label rule-brass text-brass-300" data-i18n data-fr="Votre secteur" data-en="Your sector" data-ar="قطاعكم">Votre secteur</p>
          <div class="cine-card mt-5 rounded-2xl p-5 sm:p-6">
            <p class="text-2xl" aria-hidden="true">{comArchetype.icon}</p>
            <p class="fig mt-2 text-xl text-lune" data-i18n
              data-fr={comArchetype.labelFr} data-en={comArchetype.labelEn} data-ar={comArchetype.labelAr}>{comArchetype.labelFr}</p>
            <p class="mt-2 text-sm text-lune-soft" data-i18n
              data-fr={comArchetype.accrocheFr} data-en={comArchetype.accrocheEn} data-ar={comArchetype.accrocheAr}>{comArchetype.accrocheFr}</p>
          </div>
        </section>
      )}

      <!-- ── P2 · PRODUCTION ESTIMÉE vs CONSOMMATION (langage pro-11) ──────── -->
      {showChart && (
        <section class="mx-auto max-w-4xl px-5 pt-14 sm:px-8">
          <p class="tech-label rule-brass text-brass-300" data-i18n
            data-fr={chartHasConso ? 'Production estimée vs votre consommation' : 'Production estimée'}
            data-en={chartHasConso ? 'Estimated production vs your consumption' : 'Estimated production'}
            data-ar={chartHasConso ? 'الإنتاج المقدّر مقابل استهلاككم' : 'الإنتاج المقدّر'}>
            {chartHasConso ? 'Production estimée vs votre consommation' : 'Production estimée'}
          </p>
          <div class="cine-card mt-5 rounded-2xl p-5 sm:p-6">
            <!-- WJ80 — trois variantes langue pré-rendues (FR visible par
                 défaut) : le script de bascule de langue affiche la bonne au
                 lieu de réimporter la chaîne de rendu SVG côté client. -->
            <div class="chart-svg" data-chart-lang="fr" set:html={chartSvgFr}></div>
            <div class="chart-svg" data-chart-lang="en" hidden set:html={chartSvgEn}></div>
            <div class="chart-svg" data-chart-lang="ar" hidden set:html={chartSvgAr}></div>
            <!-- WJ80 — tap-to-reveal : le `<title>` SVG (survol souris) est
                 invisible au tactile — l'essentiel du trafic de cette page.
                 Un tap/clic sur une barre affiche ici son mois + sa valeur ;
                 câblé par le script de fin de page (délégation d'événement,
                 aucune dépendance au SVG choisi). -->
            <p id="chart-tap-caption" class="mt-2 min-h-[1.25rem] text-sm text-brass-300" aria-live="polite"></p>
            <div class="mt-4 flex flex-wrap items-center gap-x-6 gap-y-2 text-sm">
              <span class="inline-flex items-center gap-2 text-lune-soft">
                <span class="inline-block h-3 w-3 rounded-sm" style="background: var(--color-brass-400)" aria-hidden="true"></span>
                <span data-i18n data-fr="Production solaire estimée" data-en="Estimated solar production" data-ar="الإنتاج الشمسي المقدّر">Production solaire estimée</span>
              </span>
              {chartHasConso && (
                <span class="inline-flex items-center gap-2 text-lune-soft">
                  <span class="inline-block h-3 w-3 rounded-sm" style="background: var(--color-azur-300, #7fb4e8)" aria-hidden="true"></span>
                  <span data-i18n data-fr="Votre consommation" data-en="Your consumption" data-ar="استهلاككم">Votre consommation</span>
                </span>
              )}
              <span class="text-lune-faint" data-i18n data-fr="kWh par mois" data-en="kWh per month" data-ar="كيلوواط ساعة شهرياً">kWh par mois</span>
            </div>
            {/* WJ83 — `ecoHero` gardait le rôle d'un simple booléen dans ce
                `||` (jamais affiché lui-même) : la légende ne parlait QUE de
                production, jamais d'économie, alors même que le chiffre existe.
                On le SURFACE désormais explicitement quand présent — sinon la
                légende garde son texte production-only d'origine. */}
            {(prodKwh || ecoHero) && (
              <p class="v2-body mt-4 text-sm text-lune-soft" data-i18n
                data-fr={`${prodKwh ? `Sur l’année, votre installation produit environ ${formatNumber(prodKwh)} kWh.` : ''}${chartHasConso ? ' Plus la production (laiton) couvre votre consommation (azur), plus vous économisez.' : ''}${ecoHero ? ` Économie estimée : ${formatMAD(ecoHero)}/an.` : ''}`}
                data-en={`${prodKwh ? `Over the year, your installation produces around ${formatNumber(prodKwh)} kWh.` : ''}${chartHasConso ? ' The more production (brass) covers your consumption (blue), the more you save.' : ''}${ecoHero ? ` Estimated savings: ${formatMAD(ecoHero)}/year.` : ''}`}
                data-ar={`${prodKwh ? `على مدار السنة، ينتج تركيبكم حوالي ${formatNumber(prodKwh)} kWh.` : ''}${chartHasConso ? ' كلما غطى الإنتاج (الذهبي) استهلاككم (الأزرق)، كلما وفّرتم أكثر.' : ''}${ecoHero ? ` التوفير المقدّر: ${formatMAD(ecoHero)}/سنة.` : ''}`}>
                {prodKwh ? <>Sur l’année, votre installation produit environ <strong class="text-lune">{formatNumber(prodKwh)} kWh</strong>.</> : null}
                {chartHasConso ? ' Plus la production (laiton) couvre votre consommation (azur), plus vous économisez.' : ''}
                {ecoHero ? <> Économie estimée : <span class="text-brass-300">{formatMAD(ecoHero)}/an</span>.</> : null}
              </p>
            )}
          </div>
        </section>
      )}

      <!-- ── WJ16 · COURBE JOURNALIÈRE (lever → coucher) ───────────────────── -->
      {/* Visuel le plus persuasif : la cloche solaire couvre la conso du foyer.
          Calée sur la production RÉELLE si présente, sinon « année type » libellée.
          Animation gatée prefers-reduced-motion (voir <style>). */}
      {dailyCurve.svg && (
        <section class="mx-auto max-w-4xl px-5 pt-14 sm:px-8">
          <p class="tech-label rule-brass text-brass-300" data-i18n data-fr="Votre journée solaire" data-en="Your solar day" data-ar="يومكم الشمسي">Votre journée solaire</p>
          <div class="cine-card mt-5 rounded-2xl p-5 sm:p-6">
            <!-- WJ80 — mêmes trois variantes langue pré-rendues que le graphe
                 ci-dessus (FR visible par défaut). WJ119 — croisées avec la
                 variante été/Ramadan (normal/ete/ramadan) quand le toggle
                 s'applique (résidentiel/commercial, curveVariantToggle) ;
                 industriel/agricole n'ont que "normal" — zéro poids HTML en
                 plus quand le toggle ne s'applique pas. -->
            {CURVE_VARIANTS.map((variant) => (
              <div class="daily-curve-wrap" data-curve-lang="fr" data-curve-variant={variant} hidden={variant !== 'normal'} set:html={dailyCurvesByVariant.fr[variant]?.svg ?? ''}></div>
            ))}
            {CURVE_VARIANTS.map((variant) => (
              <div class="daily-curve-wrap" data-curve-lang="en" data-curve-variant={variant} hidden set:html={dailyCurvesByVariant.en[variant]?.svg ?? ''}></div>
            ))}
            {CURVE_VARIANTS.map((variant) => (
              <div class="daily-curve-wrap" data-curve-lang="ar" data-curve-variant={variant} hidden set:html={dailyCurvesByVariant.ar[variant]?.svg ?? ''}></div>
            ))}
            <!-- WJ80 — tap-to-reveal du repère pic/moyenne (même discipline que
                 le graphe ci-dessus — le survol est invisible au tactile). -->
            <p id="curve-tap-caption" class="mt-2 min-h-[1.25rem] text-sm text-brass-300" aria-live="polite"></p>
            <!-- WJ119 — toggle DISCRET été/Ramadan (résidentiel/commercial
                 uniquement — un poste industriel ou un pompage agricole ne
                 varient pas avec la clim/le jeûne). Change uniquement la
                 SILHOUETTE de consommation affichée ; jamais un chiffre. -->
            {curveVariantToggle && (
              <div class="mt-3 flex flex-wrap items-center gap-2" role="group" aria-label="Variante du profil de consommation">
                <button type="button" id="curve-variant-normal" data-curve-variant-btn="normal" aria-pressed="true"
                  class="btn-pill px-3 py-1 text-xs" style="background: var(--color-brass-400); color: var(--color-nuit); border-color: var(--color-brass-400)"
                  data-i18n data-fr="Standard" data-en="Standard" data-ar="عادي">Standard</button>
                <button type="button" id="curve-variant-ete" data-curve-variant-btn="ete" aria-pressed="false"
                  class="btn-pill px-3 py-1 text-xs"
                  data-i18n data-fr="Été (clim)" data-en="Summer (AC)" data-ar="الصيف (تكييف)">Été (clim)</button>
                <button type="button" id="curve-variant-ramadan" data-curve-variant-btn="ramadan" aria-pressed="false"
                  class="btn-pill px-3 py-1 text-xs"
                  data-i18n data-fr="Ramadan" data-en="Ramadan" data-ar="رمضان">Ramadan</button>
              </div>
            )}
            <div class="mt-4 flex flex-wrap items-center gap-x-6 gap-y-2 text-sm">
              <span class="inline-flex items-center gap-2 text-lune-soft">
                <span class="inline-block h-3 w-3 rounded-sm" style="background: var(--color-brass-400)" aria-hidden="true"></span>
                <span data-i18n data-fr="Production solaire" data-en="Solar production" data-ar="الإنتاج الشمسي">Production solaire</span>
              </span>
              <span class="inline-flex items-center gap-2 text-lune-soft">
                <span class="inline-block h-3 w-3 rounded-sm" style="background: var(--color-azur-300, #7fb4e8)" aria-hidden="true"></span>
                <span data-i18n data-fr="Votre consommation" data-en="Your consumption" data-ar="استهلاككم">Votre consommation</span>
              </span>
              {!dailyCurve.hasRealScale && (
                <span class="text-lune-faint" data-i18n data-fr="profil — année type (forme indicative)" data-en="profile — typical year (indicative shape)" data-ar="نمط — سنة نموذجية (شكل إرشادي)">profil — année type (forme indicative)</span>
              )}
            </div>
            <!-- WJ119 — libellé honnête : jamais « mesuré », toujours « type ». -->
            <p class="mt-1 text-xs text-lune-faint" data-i18n
              data-fr="Profil type au Maroc, ajusté à votre facture."
              data-en="Typical Moroccan profile, adjusted to your bill."
              data-ar="نمط نموذجي في المغرب، معدّل حسب فاتورتكم.">
              Profil type au Maroc, ajusté à votre facture.
            </p>
            <p class="v2-body mt-4 text-sm text-lune-soft" data-i18n
              data-fr={`Le soleil produit en pleine journée : chaque kWh consommé à ce moment-là ne vient plus du réseau. ${dailyCurve.hasRealScale ? 'Les repères sont calés sur votre production estimée.' : 'Cette courbe illustre une journée type — votre profil exact est précisé avec votre conseiller.'}`}
              data-en={`The sun produces during the day: every kWh consumed at that moment no longer comes from the grid. ${dailyCurve.hasRealScale ? 'The markers are calibrated on your estimated production.' : 'This curve illustrates a typical day — your exact profile is confirmed with your advisor.'}`}
              data-ar={`تنتج الشمس في وضح النهار: كل كيلوواط ساعة يُستهلك في تلك اللحظة لم يعد يأتي من الشبكة. ${dailyCurve.hasRealScale ? 'المعالم مضبوطة على إنتاجكم المقدّر.' : 'يوضّح هذا المنحنى يوماً نموذجياً — يُحدَّد ملفكم الدقيق مع مستشاركم.'}`}>
              Le soleil produit en pleine journée : chaque kWh consommé à ce moment-là
              ne vient plus du réseau. {dailyCurve.hasRealScale
                ? 'Les repères sont calés sur votre production estimée.'
                : 'Cette courbe illustre une journée type — votre profil exact est précisé avec votre conseiller.'}
            </p>
          </div>
        </section>
      )}

      <!-- ── WJ120 · SIMULATEUR « ET AVEC N BATTERIES ? » ──────────────────── -->
      {/* Moteur horaire glouton (lib/batterySim, jour 2 simulé) recalculé EN
          DIRECT au curseur, 100 % côté client (aucun re-fetch). Résidentiel +
          commercial uniquement. Capacité/unité = réf catalogue Deyness du devis ;
          aucun prix batterie inventé (prix réel du devis, sinon « sur étude »). */}
      {showBatterySim && batteryInitial && (
        <section class="mx-auto max-w-4xl px-5 pt-14 sm:px-8" id="battery-sim" data-battery-sim-config={batterySimConfig}>
          <p class="tech-label rule-brass text-brass-300" data-i18n data-fr="Et avec une batterie ?" data-en="And with a battery?" data-ar="وماذا مع بطارية؟">Et avec une batterie ?</p>
          <div class="cine-card mt-5 rounded-2xl p-5 sm:p-6">
            <p class="v2-body text-sm text-lune-soft" data-i18n
              data-fr="Déplacez le curseur : voyez ce qu’une ou plusieurs batteries changeraient — plus de solaire gardé chez vous, moins de réseau le soir, et des heures d’autonomie en cas de coupure."
              data-en="Move the slider: see what one or more batteries would change — more solar kept at home, less grid in the evening, and hours of backup during an outage."
              data-ar="حرّك المؤشر: شاهد ما ستغيّره بطارية واحدة أو أكثر — طاقة شمسية أكثر تبقى في منزلك، وشبكة أقل في المساء، وساعات استقلالية عند انقطاع التيار.">
              Déplacez le curseur : voyez ce qu’une ou plusieurs batteries changeraient — plus de solaire gardé chez vous, moins de réseau le soir, et des heures d’autonomie en cas de coupure.
            </p>

            <!-- Curseur 0/1/2/3 unités -->
            <div class="mt-5">
              <div class="flex items-center justify-between text-sm">
                <label for="battery-sim-slider" class="text-lune-soft" data-i18n data-fr="Nombre de batteries" data-en="Number of batteries" data-ar="عدد البطاريات">Nombre de batteries</label>
                <span class="font-semibold text-brass-300" dir="ltr"><span id="battery-sim-units">{batterySimInitialN}</span> × <span id="battery-sim-cap">{formatNumber(batteryUnitCapacityKwh, 0)}</span> kWh</span>
              </div>
              <input type="range" id="battery-sim-slider" min="0" max={BATTERY_SIM_MAX_UNITS} step="1" value={batterySimInitialN} class="mt-2 w-full accent-brass-400" aria-describedby="battery-sim-assumptions" />
              <div class="mt-1 flex justify-between text-xs text-lune-faint" aria-hidden="true">
                <span>0</span><span>1</span><span>2</span><span>3</span>
              </div>
            </div>

            <!-- 3 chiffres live : autoconsommation %, autosuffisance %, heures de secours -->
            <div class="mt-6 grid grid-cols-2 gap-4 sm:grid-cols-3">
              <div>
                <p class="text-2xl font-bold text-brass-300" id="battery-sim-selfconso" dir="ltr">{formatPercent(batteryInitial.selfConsumptionPct, 0)}</p>
                <p class="text-xs text-lune-soft" data-i18n data-fr="Autoconsommation" data-en="Self-consumption" data-ar="الاستهلاك الذاتي">Autoconsommation</p>
                <p class="text-[11px] text-lune-faint" data-i18n data-fr="du solaire produit, gardé chez vous" data-en="of the solar you produce, kept at home" data-ar="من الطاقة الشمسية المنتَجة، تبقى في منزلك">du solaire produit, gardé chez vous</p>
              </div>
              <div>
                <p class="text-2xl font-bold text-brass-300" id="battery-sim-selfsuff" dir="ltr">{formatPercent(batteryInitial.selfSufficiencyPct, 0)}</p>
                <p class="text-xs text-lune-soft" data-i18n data-fr="Autosuffisance" data-en="Self-sufficiency" data-ar="الاكتفاء الذاتي">Autosuffisance</p>
                <p class="text-[11px] text-lune-faint" data-i18n data-fr="de votre consommation couverte par le solaire" data-en="of your consumption covered by solar" data-ar="من استهلاككم مغطى بالطاقة الشمسية">de votre consommation couverte par le solaire</p>
              </div>
              <div>
                <p class="text-2xl font-bold text-brass-300" dir="ltr"><span id="battery-sim-backup">{formatNumber(batteryInitial.backupHours, 0)}</span> h</p>
                <p class="text-xs text-lune-soft" data-i18n data-fr="Heures de secours" data-en="Backup hours" data-ar="ساعات الطوارئ">Heures de secours</p>
                <p class="text-[11px] text-lune-faint" data-i18n data-fr="frigo + éclairage + box, batterie pleine" data-en="fridge + lighting + router, full battery" data-ar="ثلاجة + إنارة + راوتر، بطارية ممتلئة">frigo + éclairage + box, batterie pleine</p>
              </div>
            </div>

            <!-- Aire empilée style SolarEdge : direct / batterie / réseau, sur 24 h -->
            <div class="mt-6">
              <div class="battery-split-wrap" id="battery-sim-chart" set:html={batterySplitSvgInitial}></div>
              <div class="mt-3 flex flex-wrap items-center gap-x-5 gap-y-1 text-xs">
                <span class="inline-flex items-center gap-2 text-lune-soft">
                  <span class="inline-block h-3 w-3 rounded-sm" style="background: var(--color-brass-400)" aria-hidden="true"></span>
                  <span data-i18n data-fr="Solaire direct" data-en="Direct solar" data-ar="شمسي مباشر">Solaire direct</span>
                </span>
                <span class="inline-flex items-center gap-2 text-lune-soft">
                  <span class="inline-block h-3 w-3 rounded-sm" style="background: var(--color-azur-300, #7fb4e8)" aria-hidden="true"></span>
                  <span data-i18n data-fr="Batterie" data-en="Battery" data-ar="بطارية">Batterie</span>
                </span>
                <span class="inline-flex items-center gap-2 text-lune-soft">
                  <span class="inline-block h-3 w-3 rounded-sm" style="background: var(--color-lune-faint)" aria-hidden="true"></span>
                  <span data-i18n data-fr="Réseau" data-en="Grid" data-ar="الشبكة">Réseau</span>
                </span>
              </div>
              <p class="mt-3 text-sm text-lune-soft">
                <span data-i18n data-fr="Sur une journée type :" data-en="On a typical day:" data-ar="في يوم نموذجي:">Sur une journée type :</span>
                <span class="font-semibold text-brass-300" dir="ltr"><span id="battery-sim-direct">{formatNumber(batteryInitial.directKwh, 1)}</span> kWh</span> <span data-i18n data-fr="en direct" data-en="direct" data-ar="مباشرة">en direct</span>,
                <span class="font-semibold" style="color: var(--color-azur-300, #7fb4e8)" dir="ltr"><span id="battery-sim-battery">{formatNumber(batteryInitial.fromBatteryKwh, 1)}</span> kWh</span> <span data-i18n data-fr="via batterie" data-en="via battery" data-ar="عبر البطارية">via batterie</span>,
                <span class="font-semibold text-lune-faint" dir="ltr"><span id="battery-sim-grid">{formatNumber(batteryInitial.fromGridKwh, 1)}</span> kWh</span> <span data-i18n data-fr="du réseau" data-en="from the grid" data-ar="من الشبكة">du réseau</span>.
              </p>
            </div>

            <!-- Prix : réel du devis quand N correspond à l'offre, sinon « sur étude ». -->
            <p class="mt-4 text-sm">
              <span class="text-lune-soft" data-i18n data-fr="Prix de cette configuration :" data-en="Price for this configuration:" data-ar="سعر هذا التكوين:">Prix de cette configuration :</span>
              <span class="ms-1 font-semibold text-brass-300" id="battery-sim-price" dir="ltr">{batteryInitialPrice ?? 'Sur étude'}</span>
            </p>

            <!-- Hypothèses (DoD / rendement) + libellé honnête « jamais mesuré ». -->
            <p id="battery-sim-assumptions" class="mt-4 text-xs text-lune-faint" data-i18n
              data-fr="Hypothèses : batterie lithium LFP, décharge 90 %, rendement aller-retour ≈ 92 %. Profil type au Maroc ajusté à votre facture — jamais un chiffre mesuré. Le prix batterie affiché est celui de votre devis ; toute autre configuration est chiffrée sur étude."
              data-en="Assumptions: LFP lithium battery, 90% depth of discharge, round-trip efficiency ≈ 92%. Typical Moroccan profile adjusted to your bill — never a measured figure. The battery price shown is from your quote; any other configuration is priced on request."
              data-ar="الافتراضات: بطارية ليثيوم LFP، عمق تفريغ 90٪، كفاءة ذهاب وإياب ≈ 92٪. نمط نموذجي في المغرب معدّل حسب فاتورتكم — وليس رقماً مقيساً. السعر المعروض للبطارية هو سعر عرضكم؛ أي تكوين آخر يُسعّر حسب الدراسة.">
              Hypothèses : batterie lithium LFP, décharge 90 %, rendement aller-retour ≈ 92 %. Profil type au Maroc ajusté à votre facture — jamais un chiffre mesuré. Le prix batterie affiché est celui de votre devis ; toute autre configuration est chiffrée sur étude.
            </p>
          </div>
        </section>
      )}

      <!-- ── OPTIONS ──────────────────────────────────────────────────────── -->
      <section id="options" class="mx-auto max-w-4xl px-5 pt-14 sm:px-8">
        <p class="tech-label rule-brass text-brass-300" data-i18n
          data-fr={twoOptions ? 'Vos deux options' : 'Votre proposition'}
          data-en={twoOptions ? 'Your two options' : 'Your proposal'}
          data-ar={twoOptions ? 'خياراكم' : 'عرضكم'}>
          {twoOptions ? 'Vos deux options' : 'Votre proposition'}
        </p>
        <div class={`mt-5 grid gap-4 ${twoOptions ? 'sm:grid-cols-2' : ''}`}>
          {options.map((opt) => {
            const totaux = optionTotaux(data!, opt);
            const items = optionItems(data!, opt);
            const isReco = twoOptions && opt === reco;
            const eco = opt === 'avec_batterie' ? ecoAvec : ecoSans;
            // WJ83 — un payload totaux-less retombe sur `optionTtc() === 0` (le
            // `?? 0` défensif de la fonction) : sans ce garde-fou, "0 MAD TTC,
            // clé en main" s'affichait comme un VRAI prix. `realPrice` distingue
            // les deux cas ; sans prix réel on affiche un message honnête à la
            // place — jamais un chiffre fabriqué.
            const realPrice = hasRealPrice(data!, opt);
            return (
              <article
                class="cine-card relative flex flex-col rounded-2xl p-6"
                style={isReco ? 'border-color: rgb(232 181 74 / 0.45)' : undefined}
              >
                {isReco && (
                  <span class="absolute -top-3 left-6 rounded-full bg-brass-400 px-3 py-1 text-xs font-bold text-nuit" data-i18n data-fr="Recommandé" data-en="Recommended" data-ar="موصى به">
                    Recommandé
                  </span>
                )}
                <h3 class="display text-xl text-lune" data-i18n data-fr={optionLabel(opt)} data-en={optionLabelEn(opt)} data-ar={optionLabelAr(opt)}>{optionLabel(opt)}</h3>
                {realPrice ? (
                  <>
                    <p class="fig fig-md lum mt-3" dir="ltr">{formatMAD(optionTtc(data!, opt))}</p>
                    <p class="text-sm text-lune-faint" data-i18n data-fr="TTC, clé en main" data-en="incl. tax, turnkey" data-ar="شامل الضريبة، تسليم مفتاح في اليد">TTC, clé en main</p>
                  </>
                ) : (
                  <p class="v2-body mt-3 text-lune-soft" data-i18n
                    data-fr="Prix communiqué par votre conseiller"
                    data-en="Price provided by your advisor"
                    data-ar="السعر يُبلَّغ من طرف مستشاركم">
                    Prix communiqué par votre conseiller
                  </p>
                )}
                {eco ? (
                  <p class="mt-2 text-sm text-lune-soft" data-i18n
                    data-fr={`Économies estimées : ${formatMAD(eco)}/an`}
                    data-en={`Estimated savings: ${formatMAD(eco)}/year`}
                    data-ar={`التوفير المقدّر: ${formatMAD(eco)}/سنة`}>
                    Économies estimées : <span class="text-brass-300">{formatMAD(eco)}/an</span>
                  </p>
                ) : null}

                <!-- Équipement (WJ32 : marque + garantie + description quand disponibles — jamais de lien fiche technique fabriqué, le backend n'expose pas encore cette URL publiquement) -->
                {items.length > 0 && (
                  <div class="mt-5 border-t border-white/10 pt-4">
                    <p class="tech-label text-lune-faint" data-i18n data-fr="Équipement" data-en="Equipment" data-ar="المعدات">Équipement</p>
                    <ul class="mt-3 space-y-3 text-sm text-lune-soft">
                      {items.map((it) => (
                        <li>
                          <div class="flex items-baseline justify-between gap-3">
                            <span>
                              <span class="text-lune">{it.designation}</span>
                              {it.marque ? <span class="text-lune-faint"> · {it.marque}</span> : null}
                            </span>
                            <span class="fig shrink-0 text-lune-faint" dir="ltr">×{formatNumber(it.quantite)}</span>
                          </div>
                          {it.description ? (
                            <p class="mt-0.5 text-xs text-lune-faint">{it.description}</p>
                          ) : null}
                          {it.garantie ? (
                            <p class="mt-0.5 text-xs text-brass-300" data-i18n
                              data-fr={`Garantie : ${it.garantie}`} data-en={`Warranty: ${it.garantie}`} data-ar={`الضمان: ${it.garantie}`}>Garantie : {it.garantie}</p>
                          ) : null}
                        </li>
                      ))}
                    </ul>
                  </div>
                )}

                <!-- Chaîne de prix explicite -->
                {totaux && (
                  <dl class="mt-5 space-y-1.5 border-t border-white/10 pt-4 text-sm">
                    <div class="flex justify-between">
                      <dt class="text-lune-faint" data-i18n data-fr="Sous-total HT" data-en="Subtotal excl. tax" data-ar="المجموع الفرعي (بدون ضريبة)">Sous-total HT</dt>
                      <dd class="fig text-lune-soft" dir="ltr">{formatMAD(totaux.ht_brut)}</dd>
                    </div>
                    {totaux.remise > 0 && (
                      <div class="flex justify-between">
                        <dt class="text-lune-faint" data-i18n data-fr="Remise" data-en="Discount" data-ar="التخفيض">Remise</dt>
                        <dd class="fig text-brass-300" dir="ltr">−{formatMAD(totaux.remise)}</dd>
                      </div>
                    )}
                    <div class="flex justify-between">
                      <dt class="text-lune-faint" data-i18n data-fr="Total HT" data-en="Total excl. tax" data-ar="المجموع (بدون ضريبة)">Total HT</dt>
                      <dd class="fig text-lune-soft" dir="ltr">{formatMAD(totaux.ht_net)}</dd>
                    </div>
                    <div class="flex justify-between">
