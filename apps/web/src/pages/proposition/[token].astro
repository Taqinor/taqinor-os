          data-en={`Taqinor proposal · ref. ${reference}. Non-contractual document without signature of the official quote.`}
          data-ar={`عرض تاقينور · المرجع ${reference}. وثيقة غير تعاقدية بدون توقيع العرض الرسمي.`}>
