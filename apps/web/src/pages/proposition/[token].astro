      <!-- ── WJ32 · « NOS HYPOTHÈSES » — disclosure sourcée ──────────────────
           <details> natif : accessible sans JS, zéro CLS (rien ne bouge autour). -->
      {assumptions.length > 0 && (
        <section class="mx-auto max-w-4xl px-5 pt-16 sm:px-8">
          <details class="cine-card rounded-2xl p-6 sm:p-7">
            <summary class="tech-label cursor-pointer text-brass-300" data-i18n data-fr="Nos hypothèses" data-en="Our assumptions" data-ar="فرضياتنا">Nos hypothèses</summary>
            <dl class="mt-4 space-y-3 text-sm">
              {assumptions.map((a) => (
                <div>
                  <dt class="text-lune-faint" data-i18n data-fr={a.label} data-en={a.labelEn} data-ar={a.labelAr}>{a.label}</dt>
                  <dd class="mt-0.5 text-lune-soft" data-i18n data-fr={a.value} data-en={a.valueEn} data-ar={a.valueAr}>{a.value}</dd>
                </div>
              ))}
            </dl>
            <!-- W359 — lien vers la page de transparence méthodologique
                 (source PVGIS, pertes système, autoconsommation d'abord,
                 tarif BT ANRE non publié) : le détail de la méthode derrière
                 ces hypothèses. -->
            <p class="mt-4 text-xs">
              <a href="/methodologie-estimation" class="text-brass-300 underline-offset-2 hover:underline" data-i18n
                data-fr="En savoir plus sur notre méthode de calcul"
                data-en="Learn more about our calculation method"
                data-ar="اعرفوا المزيد عن منهجية حسابنا">
                En savoir plus sur notre méthode de calcul
              </a>
            </p>
          </details>
