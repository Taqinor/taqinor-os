---
/**
 * /proposition/<token> — PROPOSITION CLIENT EN LIGNE (W116 + W117).
 *
 * La belle page « UI » que TAQINOR envoie au client (≠ PDF). Rendu côté serveur
 * (prerender=false) : le frontmatter lit la proposition depuis l'endpoint backend
 * public/token, et la page affiche un devis premium responsive + une signature en
 * ligne (CTA collant « Signer en ligne »). La signature passe par le proxy
 * same-origin /api/proposition-accept — le navigateur n'appelle jamais le backend
 * en cross-origin. Aucun prix d'achat / marge n'est jamais affiché (le backend ne
 * les envoie pas). noindex=true : page privée et tokenisée.
 *
 * Design : langage v2 (« cinéma du chantier »). Bleu Majorelle dominant, laiton
 * (.lum / CTA) réservé aux chiffres clés et au bouton principal, encres lune,
 * Archivo / Hanken. Zéro CLS, prefers-reduced-motion respecté, contraste AA.
 */
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import ZelligeSignature from '../../components/ZelligeSignature.astro';
import StarRating from '../../components/StarRating.astro';
import TestimonialCarousel from '../../components/TestimonialCarousel.astro';
import InstallCounter from '../../components/InstallCounter.astro';
import CertLogoRow from '../../components/CertLogoRow.astro';
import VideoCompteur from '../../components/VideoCompteur.astro';
// WJ57 — « confiance au moment de la signature » : UN témoignage court (texte,
// slot vidéo réservé pour quand WG6 fournira de vrais témoignages filmés) +
// le bandeau certifications/garanties, juste au-dessus du bloc e-sign. Même
// source unique de vérité que <TestimonialCarousel/> (aucun avis fabriqué).
import { TESTIMONIALS, hasTestimonials } from '../../lib/testimonials';
// WJ35 — grade « heure dorée » v3 (.v3-grade / .photo-grade), importé ici car
// cette page ne monte pas <V2Enhance/> (qui l'importe pour les pages v2). La
// feuille est dédupliquée par Vite si une autre page l'importe déjà ailleurs.
import '../../styles/v3-photo-motion.css';
import {
  type ProposalResponse,
  type OptionKey,
  type InstallMode,
  type AgricoleKpis,
  type AutoconsoKpis,
  resolveInstallMode,
  agricoleKpis,
  autoconsoKpis,
  hasInjection,
  autoconsoCashflow,
  agricoleMonthlyDelivery,
  commercialArchetype,
  MONTHS_SHORT,
  formatMAD,
  formatNumber,
  formatPayback,
  hasTwoOptions,
  recommendedOption,
  optionTtc,
  hasRealPrice,
  optionItems,
  optionTotaux,
  optionLabel,
  optionLabelAr,
  optionLabelEn,
  defaultSelectedOption,
  isAccepted,
  resolveOfferState,
  isOfferDead,
  proposalEndpoint,
  proposalPdfEndpoint,
  hasProductionSeries,
  monthlySeries,
  formatPercent,
  resolveValidity,
  savingsHeadline,
  environmentalImpact,
  financingComparison,
  installmentSplit,
  INSTALLMENT_MONTH_OPTIONS,
  whatsappLink,
  whatsappLinkForIntent,
  whatsappShareLink,
  whatsappReferralLink,
  parseRoofLayout,
  buildViewerModel,
  roofLayoutOutlineLatLng,
  zoneAnnotations,
  walkthroughSteps,
  backendFinancing,
  proposalVariants,
  nextSteps,
  proposalAssumptions,
  monitoringPoints,
  objectionFaq,
  sellerNote,
} from '../../lib/proposition';
import {
  renderYearCurve,
  resolveProposalCurveMode,
  consumptionProfile,
  solarProfile,
  type ProposalCurveVariant,
  type ProposalCurveMode,
  type DailyCurve,
  type CurveLang,
} from '../../lib/proposalCurve';
// WJ120 — simulateur « et avec N batteries ? » (moteur horaire glouton PUR).
import {
  simulateBattery,
  resolveOfferBattery,
  renderBatterySplitSvg,
  DEFAULT_UNIT_CAPACITY_KWH,
  HOURS_PER_DAY,
} from '../../lib/batterySim';
import { renderProposalChart, resolveSeries } from '../../lib/proposalChart';
import { clientIpFromRequest, rateLimit } from '../../lib/rateLimit';
// W342 — « installation la plus proche » : haversine sur un point GPS réel
// (premier sommet du premier pan de toiture, quand roof_layout est exposé) ou,
// à défaut, correspondance texte sur le nom de ville dans l'adresse client.
import { nearestRealisation, nearestRealisationByCityText } from '../../lib/realisations';

const API_BASE = (import.meta.env.PUBLIC_API_BASE as string | undefined) ?? 'https://api.taqinor.ma';
const { token } = Astro.params as { token: string };

// ── Lecture serveur de la proposition ────────────────────────────────────────
// WJ81 — la page la plus commercialement critique du site ne doit JAMAIS
// rester blanche : un backend lent/qui ne répond pas bloquait auparavant ce
// `fetch` sans limite (le SSR pouvait pendre jusqu'au timeout de la
// plateforme, une page blanche générique plutôt qu'un message de marque). Un
// `AbortController` borne l'attente à SSR_FETCH_TIMEOUT_MS ; un timeout obtient
// désormais son PROPRE message honnête (« connexion lente ») distinct d'une
// vraie panne réseau, et l'état d'erreur porte un bouton « Réessayer » qui
// recharge la MÊME URL (lien pur, fonctionne même sans JS).
const SSR_FETCH_TIMEOUT_MS = 8000;
let data: ProposalResponse | null = null;
let errorDetail: string | null = null;
let httpStatus = 200;
let isTimeout = false;

// ── W316 — Rate-limit le SSR de cette page : un token de proposition est un
// identifiant devinable (chaîne opaque mais finie) ; sans garde-fou, un
// script pouvait bombarder /proposition/<token-aléatoire> pour sonder des
// tokens valides. Bucket DISTINCT et GÉNÉREUX (une famille entière peut relire
// la même proposition plusieurs fois depuis le même foyer/NAT) : on écrête le
// balayage automatisé, jamais une relecture humaine légitime.
const rl = rateLimit(`proposition-view:${clientIpFromRequest(Astro.request)}`, { limit: 60, windowMs: 60_000 });
if (!rl.allowed) {
  httpStatus = 429;
  errorDetail = 'Trop de tentatives depuis cette connexion — réessayez dans un instant.';
} else if (!token || !token.trim()) {
  httpStatus = 404;
  errorDetail = 'Ce lien de proposition est introuvable ou a expiré.';
} else {
  const controller = new AbortController();
  const timer = setTimeout(() => controller.abort(), SSR_FETCH_TIMEOUT_MS);
  try {
    const res = await fetch(proposalEndpoint(API_BASE, token), {
      headers: { accept: 'application/json' },
      signal: controller.signal,
    });
    httpStatus = res.status;
    if (res.ok) {
      data = (await res.json()) as ProposalResponse;
    } else {
      let detail = '';
      try {
        const body = (await res.json()) as { detail?: string };
        detail = typeof body.detail === 'string' ? body.detail : '';
      } catch {
        detail = '';
      }
      errorDetail =
        detail ||
        (res.status === 404
          ? 'Ce lien de proposition est introuvable ou a expiré.'
          : 'Cette proposition n’est pas accessible pour le moment.');
    }
  } catch (err) {
    httpStatus = 502;
    isTimeout = err instanceof Error && err.name === 'AbortError';
    errorDetail = isTimeout
      ? 'La connexion est lente — cette proposition met plus de temps que prévu à charger. Réessayez, ou contactez votre conseiller sur WhatsApp.'
      : 'Proposition momentanément indisponible. Veuillez réessayer dans un instant.';
  } finally {
    clearTimeout(timer);
  }
}

// La page renvoie 404 quand le token est invalide/expiré : propre pour les bots
// comme pour les humains (Layout est de toute façon noindex).
if (!data && (httpStatus === 404 || httpStatus === 200)) {
  Astro.response.status = httpStatus === 200 ? 404 : httpStatus;
} else if (!data) {
  Astro.response.status = httpStatus;
}

// ── Préparation des données d'affichage (uniquement si OK) ───────────────────
const ok = !!data;
const q = data?.quote;
const twoOptions = ok ? hasTwoOptions(data!) : false;
const reco: OptionKey | null = ok ? recommendedOption(data!) : null;
const accepted = ok ? isAccepted(data!) : false;
const preselect: OptionKey | null = ok ? defaultSelectedOption(data!) : null;
// WJ83 — le CTA collant montre le prix de l'option phare (reco/sans_batterie) :
// même garde-fou zéro-total que les cartes d'options plus bas.
const heroHasRealPrice = ok ? hasRealPrice(data!, reco ?? 'sans_batterie') : false;
// WJ114 — TTC « phare » du héros pour le bloc « décider en 10 secondes »
// (Storydoc : 31 % rebondissent en 10 s). Même chiffre/garde-fou que le CTA
// collant ci-dessus — jamais recalculé, jamais affiché à 0 MAD.
const heroTtc = ok && heroHasRealPrice ? optionTtc(data!, reco ?? 'sans_batterie') : null;
// WJ114 — note personnelle du vendeur (lecture défensive, backend pas encore
// livré aujourd'hui) : n'affiche RIEN tant que l'ERP ne fournit pas ce bloc.
const seller = ok ? sellerNote(data!) : null;

// ── WJ82 — État explicite de l'offre (live/accepted/refused/expired/withdrawn).
// Calculé UNE fois côté serveur à partir du même statut backend + de la même
// fenêtre de validité que `resolveValidity` ci-dessous (pas de nouvelle donnée
// inventée) : pilote la suppression du formulaire de signature + du CTA collant
// pour toute offre qui n'est plus signable.
const offerState = ok ? resolveOfferState(data!) : 'live';

const roofImg = data?.roof_image_url ?? null;
const clientName = data?.client_name || q?.client_name || 'Client';
const reference = data?.reference || q?.ref || '';
const proposalDate = data?.date || q?.date || '';

// Options à présenter (une ou deux), dans l'ordre Sans → Avec.
const options: OptionKey[] = ok
  ? twoOptions
    ? ['sans_batterie', 'avec_batterie']
    : q?.totaux_avec && !q?.totaux_sans
      ? ['avec_batterie']
      : ['sans_batterie']
  : [];

// ── WJ126 · Mode d'installation + KPI par mode (payload QX49) ─────────────────
// La page rend 4 variantes de la MÊME page selon `mode_installation` (clé machine
// minuscule QX49) — JAMAIS l'ancien `inst_type` (libellé capitalisé qui ne
// matchait aucun littéral). `agricoleKpis`/`autoconsoKpis` extraient les KPI
// typés (null hors de leur mode → zéro fuite inter-mode) ; chaque champ manquant
// devient null → omission honnête à l'écran (aucun chiffre inventé).
const installMode: InstallMode = ok ? resolveInstallMode(data!) : 'residentiel';
const isAgricole = installMode === 'agricole';
const isAutoconso = installMode === 'industriel' || installMode === 'commercial';
const isCommercial = installMode === 'commercial';
const agri: AgricoleKpis | null = ok ? agricoleKpis(data!) : null;
const auto: AutoconsoKpis | null = ok ? autoconsoKpis(data!) : null;
const autoHasInjection = hasInjection(auto);
// Mini-cashflow 10 ans (industriel/commercial) — même modèle linéaire que le PDF.
const autoCashflow = ok && isAutoconso ? autoconsoCashflow(data!, reco ?? 'sans_batterie', auto, 10) : null;
const cashMaxAbs = autoCashflow ? Math.max(...autoCashflow.map((p) => Math.abs(p.cumulative)), 1) : 1;
// Année du point mort (première année à trésorerie cumulée ≥ 0), pour le libellé.
const cashBreakEven = autoCashflow ? (autoCashflow.find((p) => p.cumulative >= 0)?.year ?? null) : null;
// Livraison d'eau mensuelle estimée (agricole) — dérivée de m3_jour + production
// mensuelle ; null (bloc omis) si l'une des deux manque. Jamais de courbe besoin.
const waterDelivery = ok && isAgricole ? agricoleMonthlyDelivery(data!, agri) : null;
const waterMax = waterDelivery ? Math.max(...waterDelivery.map((m) => m.m3), 1) : 1;
// Archétype de bloc commercial (miroir backend) — seulement en mode commercial.
const comArchetype = ok && isCommercial ? commercialArchetype(data?.categorie_commerciale) : null;

// Bloc énergie/économies (résidentiel/industriel). Pompage n'a pas ces champs.
const puissance = q?.puissance_kwc ?? null;
const nbPanneaux = q?.nb_panneaux ?? null;
const wattPanneau = q?.watt_par_panneau ?? null;
const prodKwh = q?.prod_kwh ?? null;
const ecoSans = q?.eco_s_ann ?? null;
const ecoAvec = q?.eco_a_ann ?? null;
const paybackSans = formatPayback(q?.roi_s);
const paybackAvec = formatPayback(q?.roi_a);
// Économie / payback « phares » : ceux de l'option recommandée.
const ecoHero = reco === 'avec_batterie' ? (ecoAvec ?? ecoSans) : (ecoSans ?? ecoAvec);
const paybackHero = reco === 'avec_batterie' ? (paybackAvec ?? paybackSans) : (paybackSans ?? paybackAvec);

// WJ126 — CORRECTIF : ce libellé branchait sur `q?.inst_type` en le comparant à
// des littéraux MINUSCULES ('agricole'…), alors que la vraie valeur runtime est
// un libellé CAPITALISÉ ('Agricole'/'Industrielle'…) — la comparaison ne matchait
// donc JAMAIS et retombait toujours sur le libellé brut. On branche désormais sur
// `installMode` (clé machine minuscule QX49, `resolveInstallMode`), qui distingue
// bien les 4 marchés.
const instLabel =
  installMode === 'agricole'
    ? 'Pompage solaire'
    : installMode === 'industriel'
      ? 'Autoconsommation industrielle'
      : installMode === 'commercial'
        ? 'Autoconsommation'
        : 'Installation solaire';

// WJ119 — mode de courbe journalière dérivé du MÊME champ backend (repli
// residentiel si absent/inconnu ; resolveProposalCurveMode documente les
// valeurs RÉELLEMENT observées aujourd'hui — "Résidentielle" / "Industrielle /
// Commerciale" / "Agricole", cf. quote_engine/builder.py).
// WJ126 finding 4 — préférer `mode_installation` (clé machine QX49, distingue
// commercial d'industriel) ; l'ancien `inst_type` portait le libellé combiné
// « Industrielle / Commerciale » qui privait le commercial du variant de courbe
// et du simulateur batterie. Repli sur inst_type pour les devis hérités.
const curveMode: ProposalCurveMode =
  installMode === 'residentiel' || installMode === 'industriel'
    || installMode === 'commercial' || installMode === 'agricole'
    ? installMode
    : resolveProposalCurveMode(q?.inst_type ?? null);
// Été/Ramadan n'ont de sens que pour un profil résidentiel/commercial (clim,
// horaires de jeûne) — jamais pour un poste industriel (équipes fixes) ou un
// pompage agricole (fenêtre solaire fixe, sans confort thermique à moduler).
const curveVariantToggle = curveMode === 'residentiel' || curveMode === 'commercial';
const CURVE_VARIANTS: readonly ProposalCurveVariant[] = curveVariantToggle
  ? (['normal', 'ete', 'ramadan'] as const)
  : (['normal'] as const);

// ── P2 — Graphe production estimée vs consommation (depuis les tableaux Q6) ──
// On ne dessine QUE les chiffres backend ; tableaux vides/absents → bloc masqué.
const chartSeries = ok ? resolveSeries(data?.monthly_production, data?.monthly_consumption) : { mode: 'none' as const, production: null, consumption: null };
// WJ80 — les DEUX graphes les plus persuasifs de la page restaient français-
// only (mois FR figés dans le SVG) même en mode EN/AR actif. Plutôt que de
// réimporter toute la chaîne de rendu SVG côté client (bundle supplémentaire),
// on PRÉ-RENDU les trois variantes langue côté serveur — même discipline
// tri-node que le texte (`data-i18n`/`prepareI18n`) : FR visible par défaut,
// EN/AR posés `hidden`, le script de bascule de langue montre la bonne.
const chartSvgFr = ok && chartSeries.mode !== 'none'
  ? renderProposalChart(data?.monthly_production, data?.monthly_consumption, undefined, 'fr')
  : '';
const chartSvgEn = ok && chartSeries.mode !== 'none'
  ? renderProposalChart(data?.monthly_production, data?.monthly_consumption, undefined, 'en')
  : '';
const chartSvgAr = ok && chartSeries.mode !== 'none'
  ? renderProposalChart(data?.monthly_production, data?.monthly_consumption, undefined, 'ar')
  : '';
const showChart = ok && hasProductionSeries(data!) && chartSvgFr.length > 0;
const chartHasConso = chartSeries.mode === 'comparison';

// ── WJ16 — Courbe journalière production vs consommation (lever → coucher) ────
// Calée sur la production annuelle RÉELLE backend si présente, sinon « année
// type » clairement libellée. Le visuel le plus persuasif ne disparaît jamais.
// WJ80 — même pré-rendu tri-langue que le graphe ci-dessus.
// WJ119 — la silhouette de consommation dépend maintenant du MODE (curveMode) ;
// résidentiel/commercial pré-rendent aussi été/Ramadan (toggle discret côté
// page, CURVE_VARIANTS) — industriel/agricole gardent une seule forme (aucun
// poids HTML supplémentaire quand le toggle ne s'applique pas).
const EMPTY_DAILY_CURVE: DailyCurve = { svg: '', hasRealScale: false };
const dailyCurvesByVariant: Record<CurveLang, Partial<Record<ProposalCurveVariant, DailyCurve>>> = {
  fr: {}, en: {}, ar: {},
};
if (ok) {
  for (const lang of ['fr', 'en', 'ar'] as const) {
    for (const variant of CURVE_VARIANTS) {
      dailyCurvesByVariant[lang][variant] = renderYearCurve(prodKwh, undefined, lang, { mode: curveMode, variant });
    }
  }
}
const dailyCurveFr = dailyCurvesByVariant.fr.normal ?? EMPTY_DAILY_CURVE;
const dailyCurveEn = dailyCurvesByVariant.en.normal ?? EMPTY_DAILY_CURVE;
const dailyCurveAr = dailyCurvesByVariant.ar.normal ?? EMPTY_DAILY_CURVE;
const dailyCurve = dailyCurveFr;

// ── WJ120 — Simulateur « et avec N batteries ? » (résidentiel + commercial) ──
// Moteur horaire glouton PUR (lib/batterySim, jour 2 simulé) : conso journalière
// RÉELLE du client (monthly_consumption /365) opposée à la production estimée
// (prod_kwh /365), réparties heure par heure (direct → surplus vers batterie →
// déficit depuis batterie puis réseau). Ne s'affiche QUE pour résidentiel/commercial
// (jamais agricole/pompage — aucune batterie en pompage, CLAUDE.md — ni industriel
// par défaut). La capacité par unité vient STRICTEMENT de la réf catalogue Deyness
// du devis (5/10 kWh), jamais inventée ; AUCUN prix batterie fabriqué (prix réel du
// devis quand N correspond à l'offre, sinon « sur étude »). Le recalcul au curseur
// est 100 % côté client (aucun re-fetch) : les silhouettes + totaux sont sérialisés.
const batterySimEligible = ok && (curveMode === 'residentiel' || curveMode === 'commercial');
const consMonthly = ok ? monthlySeries(data?.monthly_consumption) : null;
const annualConsKwh = consMonthly ? consMonthly.reduce((a, b) => a + b, 0) : 0;
const dailyConsKwh = annualConsKwh > 0 ? annualConsKwh / 365 : 0;
const dailyProdKwh = prodKwh && prodKwh > 0 ? prodKwh / 365 : 0;
// La batterie OFFERTE au devis (avec_items) : capacité/unité (réf catalogue) + nb
// d'unités. Sans batterie au devis → l'unité de base catalogue (BAT-DEY-5, 5 kWh).
const offerBattery = ok
  ? resolveOfferBattery(q?.avec_items ?? null)
  : { present: false, capacityKwhPerUnit: null, units: 0, designation: '' };
const batteryUnitCapacityKwh = offerBattery.capacityKwhPerUnit ?? DEFAULT_UNIT_CAPACITY_KWH;
const offeredUnits = offerBattery.present && offerBattery.units > 0 ? offerBattery.units : 0;
const BATTERY_SIM_MAX_UNITS = 3;
// Curseur au départ : les unités offertes (bornées à 3) si le devis porte une
// batterie, sinon 1 (« et avec 1 batterie ? »).
const batterySimInitialN = offeredUnits >= 1 ? Math.min(offeredUnits, BATTERY_SIM_MAX_UNITS) : 1;
// Prix RÉELS des options (jamais recalculés/inventés) : N=0 ↔ option sans batterie,
// N = unités offertes ↔ option avec batterie (cohérent avec totaux_sans/totaux_avec).
const sansTtc = ok && hasRealPrice(data!, 'sans_batterie') ? optionTtc(data!, 'sans_batterie') : null;
const avecTtc = ok && offerBattery.present && hasRealPrice(data!, 'avec_batterie')
  ? optionTtc(data!, 'avec_batterie')
  : null;
const showBatterySim = batterySimEligible && dailyConsKwh > 0 && dailyProdKwh > 0;
// Silhouettes horaires (mode courant, variante NORMALE) — passées au client pour un
// recalcul 100 % local au curseur (aucun re-fetch, aucun proposalCurve côté client).
const batteryConsShape = showBatterySim
  ? Array.from({ length: HOURS_PER_DAY }, (_, h) => consumptionProfile(h, { mode: curveMode, variant: 'normal' }))
  : [];
const batterySolarShape = showBatterySim
  ? Array.from({ length: HOURS_PER_DAY }, (_, h) => solarProfile(h))
  : [];
// Rendu SERVEUR initial (au N de départ) : le bloc n'est jamais vide avant hydratation.
const batteryInitial = showBatterySim
  ? simulateBattery({
      consumptionShape: batteryConsShape,
      productionShape: batterySolarShape,
      dailyConsumptionKwh: dailyConsKwh,
      dailyProductionKwh: dailyProdKwh,
      capacityKwhPerUnit: batteryUnitCapacityKwh,
      units: batterySimInitialN,
    })
  : null;
const batterySplitSvgInitial = batteryInitial ? renderBatterySplitSvg(batteryInitial.hourly, undefined, 'fr') : '';
// Prix affiché au N initial : réel si N == unités offertes (option avec batterie),
// sinon « sur étude » (jamais un prix batterie extrapolé/inventé).
const batteryInitialPrice = batterySimInitialN === offeredUnits && avecTtc !== null
  ? formatMAD(avecTtc)
  : batterySimInitialN === 0 && sansTtc !== null
    ? formatMAD(sansTtc)
    : null;
// Config sérialisée pour le script client (recalcul au curseur, sans réseau).
const batterySimConfig = showBatterySim
  ? JSON.stringify({
      consShape: batteryConsShape,
      solarShape: batterySolarShape,
      dailyConsKwh,
      dailyProdKwh,
      capacityPerUnit: batteryUnitCapacityKwh,
      maxUnits: BATTERY_SIM_MAX_UNITS,
      initialN: batterySimInitialN,
      offeredUnits,
      sansTtc,
      avecTtc,
    })
  : '';

// ── WJ15 — Fenêtre de validité honnête (date backend réelle, jamais inventée) ─
const validity = ok ? resolveValidity(data!) : { label: null, fromBackend: false, expired: false };

// ── WJ9 — Argent dans le temps : cumul 25 ans + payback + cadrage mensuel ────
const headline = ok ? savingsHeadline(data!, reco ?? 'sans_batterie') : null;

// ── WJ14 — Impact environnemental humain (CO₂ ≈ arbres), depuis la production ─
const enviro = ok ? environmentalImpact(prodKwh) : null;

// ── WJ10 — Comparatif de financement (cash backend + éco-prêt indicatif) ─────
const financing = ok ? financingComparison(data!, reco ?? 'sans_batterie') : null;

// ── WJ53 — Toggle « payer comptant / paiement échelonné » interactif ─────────
// Le TTC de départ vient de l'option retenue (reco, ou sans_batterie par
// défaut) ; le recalcul en direct (mois → mensualité) se fait CÔTÉ CLIENT via
// installmentSplit (script de fin de page) — ce bloc ne rend RIEN sans prix
// réel (même garde-fou zéro-total que le reste de la page).
const installmentTtc = ok ? optionTtc(data!, reco ?? 'sans_batterie') : 0;
const showInstallmentToggle = ok && Number.isFinite(installmentTtc) && installmentTtc > 0;
const defaultInstallment = showInstallmentToggle ? installmentSplit(installmentTtc, 12) : null;

// ── WJ12 — Contact intégré : deep-link WhatsApp prérempli avec la réf devis ──
// « Demander un rappel » = appeler le numéro TAQINOR (NAP), jamais le numéro du
// client. Numéro réel (= lib/nap NAP.phone), affiché tel quel.
const waLink = ok ? whatsappLink(reference) : '';
const TAQINOR_TEL = '+212661850410';
const callbackHref = ok ? `tel:${TAQINOR_TEL}` : '';
// WJ85 — « Discuter » et « Poser une question » pointaient vers le MÊME
// waLink (un seul message générique) : deux boutons faisant la même chose au
// point de décision de la page lisent comme du remplissage. Prérempli DISTINCT
// par intention (voir whatsappLinkForIntent) ; waLinkVoice sert l'invitation
// à la note vocale (canal natif WhatsApp, plus rapide pour beaucoup de clients).
const waLinkDiscuss = ok ? whatsappLinkForIntent(reference, 'discuss') : '';
const waLinkQuestion = ok ? whatsappLinkForIntent(reference, 'question') : '';
const waLinkVoice = ok ? whatsappLinkForIntent(reference, 'voice') : '';

// ── WJ56 — « Partager sur WhatsApp » : le lien TOKENISÉ lui-même (même page),
// pour qu'un conjoint/co-décideur le reçoive sans rien ressaisir. `Astro.url`
// est l'URL COMPLÈTE réellement servie (jamais reconstruite manuellement).
const shareUrl = ok ? Astro.url.href : '';
const waLinkShare = ok ? whatsappShareLink(shareUrl, reference) : '';

// ── W343 — « Partager avec un proche » (parrainage, état signé/merci) : lien
// TAGUÉ vers /parrainage (utm_campaign = référence du devis SIGNÉ), DISTINCT
// du partage WJ56 ci-dessus (qui partage CE devis avec un co-décideur du même
// foyer, pas le programme de parrainage avec un proche différent).
const waLinkReferral = ok ? whatsappReferralLink(Astro.url.origin, reference) : '';

// ── P3 — Lien public du devis PDF premium (même token, nouvel onglet) ────────
const pdfUrl = ok ? proposalPdfEndpoint(API_BASE, token) : '';

// ── WJ25 — visionneuse 3D en lecture seule (layout backend QJ26) ────────────
// Le backend expose `roof_layout` depuis QJ26 (_safe_roof_layout,
// apps/ventes/public_views.py) : quand le devis porte un layout exploitable,
// le modèle 3D (JSON pur) est calculé ICI côté serveur — le client ne charge
// que le rendu Three.js, en différé (jamais au premier paint). Layout
// absent/invalide → le parse renvoie null et la page garde EXACTEMENT le héros
// statique d'aujourd'hui.
const roofLayout = ok ? parseRoofLayout(data?.roof_layout) : null;
const viewerModel = roofLayout ? buildViewerModel(roofLayout) : null;
const show3d = !!viewerModel && viewerModel.totalPanels >= 0;
// WJ118 — contour aplati [lat,lng] (roof_layout.zones[].vertices, [lng,lat] →
// [lat,lng] — même convention que captureOutline) transmis au client pour
// draper la VRAIE photo satellite sur la 3D (buildPublicRoofImageSpec) ; vide
// si aucun roof_layout exploitable, le client saute alors l'appel réseau.
const roofOutlineLatLng = roofLayout ? roofLayoutOutlineLatLng(roofLayout) : [];
const viewerConfig = show3d ? JSON.stringify({ model: viewerModel, roofOutlineLatLng }) : null;

// ── W342 — « L'installation la plus proche de chez vous » ────────────────────
// Priorité au VRAI GPS du toit (premier sommet du premier pan de
// roofLayout — [lng, lat]) quand le backend l'expose (QJ26) ; à défaut,
// correspondance texte du nom de ville dans `client_addr` (déjà exposé).
// Honnêtement scopé aux villes réelles de REALISATIONS (nearestRealisation
// borne à 80 km) — jamais une ville devinée.
const roofPinLngLat = roofLayout?.zones?.[0]?.vertices?.[0] ?? null;
const nearestInstall = ok
  ? (roofPinLngLat ? nearestRealisation(roofPinLngLat[1], roofPinLngLat[0])?.realisation ?? null : null) ??
    (q?.client_addr ? nearestRealisationByCityText(q.client_addr) : null)
  : null;
const nearestInstallHref = nearestInstall ? `/realisations/${nearestInstall.slug}` : '';

// ── WJ26 — « Tout est expliqué » : légende par pan + visite guidée en 4 étapes.
// Chaque chiffre vient du layout serveur ou du payload quote (les fonctions
// renvoient null / « estimation indisponible » quand la donnée manque).
const annotations = show3d && roofLayout ? zoneAnnotations(roofLayout, q?.watt_par_panneau ?? null) : [];
const walkSteps = show3d && data ? walkthroughSteps(data) : [];

// ── WJ32 — Complétude du contenu : financement backend réel, variantes,
// « Et après ? », « Nos hypothèses », accompagnement, FAQ objections. Chaque
// bloc dégrade proprement (masqué) quand sa donnée backend manque.
const financingBlock = ok ? backendFinancing(data!) : null;
const variants = ok ? proposalVariants(data!) : [];
const steps = nextSteps();
const assumptions = ok ? proposalAssumptions(data!) : [];
const monitoring = monitoringPoints();
const faq = objectionFaq();

// ── WJ86 — « Nos chantiers » (photos réelles) et « Le mot du fondateur »
// n'ont AUCUNE source de données réelle aujourd'hui (WG5/WG6, toujours GATED
// dans docs/WEB_PLAN.md) : « (Photos à venir.) » et la citation-scaffold du
// fondateur s'affichaient comme du contenu FINI sur un document commercial —
// « bientôt disponible » sur sa propre proposition lit comme un produit
// inachevé au moment le plus critique pour la confiance. Même discipline
// « no-op » que <TestimonialCarousel/>/<InstallCounter/> (hasTestimonials()) :
// tant que ces constantes restent `false`, les deux blocs ne rendent RIEN —
// pas de squelette vide, pas de mention "à venir". Basculer à `true` (et
// fournir le VRAI contenu ci-dessous) le jour où Reda livre WG5/WG6.
const REAL_PROJECT_PHOTOS_AVAILABLE = false;
const REAL_FOUNDER_QUOTE_AVAILABLE = false;

// ── WJ57 — « confiance au moment de la signature ». Même discipline no-op :
// tant qu'aucun témoignage FILMÉ réel n'existe (WG6), le slot vidéo ne rend
// RIEN (pas de player vide, pas de mention "bientôt") ; le repli texte réutilise
// la MÊME source unique de vérité (`TESTIMONIALS`) que <TestimonialCarousel/> —
// jamais un avis fabriqué pour ce placement. `signTestimonial` = le premier avis
// réel disponible (le plus court à lire juste avant de signer).
const REAL_TESTIMONIAL_VIDEO_AVAILABLE = false;
const signTestimonial = hasTestimonials() ? TESTIMONIALS[0] : null;

const pageTitle = ok ? `Proposition ${reference} — ${clientName} | Taqinor` : 'Proposition | Taqinor';
// WJ76 — fuite de confidentialité de l'aperçu de partage : cette page est un
// lien tokenisé PRIVÉ que le client transfère lui-même (WhatsApp, SMS, email)
// à sa famille/son entourage pour discuter du projet. `pageTitle` ci-dessus
// (référence + nom du client) reste dans l'onglet du navigateur — utile au
// client — mais NE DOIT JAMAIS apparaître dans la carte de partage
// (og:title/twitter:title), affichée à TOUTE personne qui reçoit le lien
// transféré, au-dessus de l'image d'accueil générique par défaut. Titre de
// partage neutre + image OG dédiée (public/og/proposition.png, aucune photo
// de chantier client, aucune donnée personnelle) — la page reste noindex.
const ogTitle = 'Votre proposition solaire | Taqinor';

// ── WJ81 — Lien WhatsApp de repli utilisable MÊME quand la proposition n'a pas
// pu être chargée (`!ok` : timeout, panne, lien invalide). `whatsappLink('')`
// dégrade déjà proprement sur un message générique sans référence.
const waLinkFallback = whatsappLink(reference || '');

// Données passées au script de signature (sérialisées en JSON dans un data-attr).
// WJ55 — `clientPhone` est AJOUTÉ ici (jamais un nouvel attribut DOM) pour que
// le script de télémétrie de vue/engagement puisse construire un événement
// corrélable côté CRM (voir buildProposalTrackPayload) sans jamais fabriquer
// de lead fantôme quand le devis n'a pas de téléphone client.
const signConfig = ok
  ? JSON.stringify({
      token,
      twoOptions,
      preselect,
      accepted,
      acceptedName: data?.accepte_par_nom ?? '',
      reference,
      clientPhone: q?.client_phone ?? '',
    })
  : null;
---

<Layout
  title={pageTitle}
  description="Votre proposition solaire personnalisée Taqinor."
  noindex={true}
  ogTitle={ogTitle}
  ogSlug="proposition"
  ogImageAlt="Taqinor — votre proposition solaire"
>
  {!ok ? (
    <!-- ── État « lien expiré / introuvable » ─────────────────────────────── -->
    <!-- WJ81 — la page ne reste JAMAIS blanche : ce cadre de marque (rappel
         visuel Taqinor, jamais une page d'erreur générique du navigateur/
         plateforme) affiche un message honnête. Pour un TIMEOUT (backend
         lent) spécifiquement, un bouton « Réessayer » (recharge la MÊME URL,
         lien pur — fonctionne sans JS) et un repli WhatsApp direct sont
         proposés, plutôt que le seul lien « Retour à l'accueil ». W316 — un
         429 (rate-limit) est tout aussi RETRYABLE (relire dans un instant) :
         même bouton « Réessayer », jamais un cul-de-sac. -->
    <section class="mx-auto flex min-h-[60dvh] max-w-2xl flex-col items-center justify-center px-5 py-24 text-center">
      <div class="rule-brass mx-auto text-brass-300" aria-hidden="true"></div>
      <h1 class="display mt-6 text-3xl text-lune sm:text-4xl">Proposition indisponible</h1>
      <p class="v2-body mt-4 max-w-md">{errorDetail}</p>
      {(isTimeout || httpStatus === 429) ? (
        <>
          <div class="mt-8 flex flex-col gap-3 sm:flex-row">
            <a href={Astro.url.href} class="btn-pill" style="background: var(--color-brass-400); color: var(--color-nuit); border-color: var(--color-brass-400)">
              Réessayer
            </a>
            <a href={waLinkFallback} target="_blank" rel="noopener noreferrer" class="btn-pill">
              Contacter sur WhatsApp
            </a>
          </div>
          <a href="/" class="mt-4 text-sm text-lune-faint underline-offset-2 hover:underline">Retour à l’accueil</a>
        </>
      ) : (
        <>
          <p class="mt-8 text-sm text-lune-faint">
            Besoin d’un nouveau lien ? Contactez votre conseiller Taqinor.
          </p>
          <a href="/" class="btn-pill mt-8">Retour à l’accueil</a>
        </>
      )}
    </section>
  ) : (
    <div class="proposition pb-28" data-sign-config={signConfig}>
      <!-- WJ84 — imprimable proprement : invisible à l'écran (print:block only),
           rappelle qu'un Ctrl-P sur cette page « UI » n'est pas le document
           officiel — le PDF premium (même token) est le document contractuel.
           Le reste du chrome (bascule langue, CTA collant, overlay 3D) est
           masqué en impression par les règles @media print ci-dessous. -->
      <p class="print-hint hidden">
        <span data-i18n
          data-fr="Pour un PDF officiel, utilisez « Télécharger le devis (PDF) » — cette page imprimée est une vue d'écran, pas le document contractuel."
          data-en="For an official PDF, use “Download the quote (PDF)” — this printed page is a screen view, not the contractual document."
          data-ar="للحصول على PDF رسمي، استخدموا «تحميل العرض (PDF)» — هذه الصفحة المطبوعة عرض شاشة، وليست الوثيقة التعاقدية.">
          Pour un PDF officiel, utilisez « Télécharger le devis (PDF) » — cette page imprimée est une vue d'écran, pas le document contractuel.
        </span>
      </p>

      <!-- WJ45 — bandeau hors-ligne (navigator.onLine + online/offline) : une
           coupure réseau au moment de signer ne doit jamais ressembler à un
           échec muet. Le formulaire de signature reste rempli (aucune
           soumission n'a eu lieu) : on prévient explicitement ET on rassure
           que rien n'est perdu, plutôt que le message générique de panne. -->
      <div id="prop-offline-banner" hidden role="status" aria-live="polite"
        class="mx-auto mt-4 flex max-w-4xl items-start gap-2 border border-brass-400/40 bg-brass-400/10 p-3 text-sm text-white sm:px-8">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="mt-0.5 flex-none text-brass-300">
          <line x1="1" y1="1" x2="23" y2="23"/><path d="M16.72 11.06A10.94 10.94 0 0 1 19 12.55"/><path d="M5 12.55a10.94 10.94 0 0 1 5.17-2.39"/><path d="M10.71 5.05A16 16 0 0 1 22.58 9"/><path d="M1.42 9a15.91 15.91 0 0 1 4.7-2.88"/><path d="M8.53 16.11a6 6 0 0 1 6.95 0"/><line x1="12" y1="20" x2="12.01" y2="20"/>
        </svg>
        <span data-i18n
          data-fr="Pas de connexion — vos réponses sont conservées, on réessaie dès le retour du réseau."
          data-en="No connection — your answers are kept, we'll retry as soon as the network is back."
          data-ar="لا يوجد اتصال — إجاباتكم محفوظة، سنعيد المحاولة فور عودة الشبكة.">
          Pas de connexion — vos réponses sont conservées, on réessaie dès le retour du réseau.
        </span>
      </div>

      <!-- WJ17/WJ43 — bascule de langue FR/EN/عربي, flottante (ne perturbe aucun
           rythme existant, zéro CLS). Même mécanisme tri-node (dual-node élargi)
           que WJ33 (mon-toit.astro) : voir le <script> de fin de page. Le contenu
           reste TOUJOURS lisible FR sans JS (pas de gate v2-js ici, page déjà
           rendue serveur). WJ43 — EN ajouté comme 3ᵉ langue (segment
           marocains-du-monde), au même niveau que FR/AR, jamais un repli dégradé. -->
      <div class="prop-lang-switch fixed right-3 z-50 flex gap-1 rounded-sm border border-white/15 bg-nuit/80 p-0.5 backdrop-blur" style="top: calc(0.75rem + env(safe-area-inset-top));" role="group" aria-label="Langue / Language / اللغة">
        <button type="button" id="prop-lang-fr" aria-pressed="true"
          class="min-h-11 px-2.5 py-2.5 text-xs font-semibold text-azur-950 bg-brass-400 transition-colors">FR</button>
        <button type="button" id="prop-lang-en" aria-pressed="false"
          class="min-h-11 px-2.5 py-2.5 text-xs font-semibold text-lune-soft transition-colors hover:text-white">EN</button>
        <button type="button" id="prop-lang-ar" aria-pressed="false"
          class="min-h-11 px-2.5 py-2.5 text-xs font-semibold text-lune-soft transition-colors hover:text-white">عربي</button>
      </div>

      <!-- ── HÉRO (WJ28 — cinéma du chantier : ancré bas, entrée cine-in ; WJ35 —
           rythme rehaussé, cohérent avec l'accueil élevé v3, zéro CLS : min-h). -->
      <section class="relative min-h-[72dvh] overflow-hidden sm:min-h-[78dvh]">
        {roofImg ? (
          <>
            <!-- WJ34 — poster blur-up : la photo backend (URL dynamique, pas de
                 pipeline LQIP base64 disponible pour ces images) est servie par-
                 dessus un dégradé « heure dorée » qui tient le cadrage. On ne
                 masque JAMAIS l'image elle-même (LCP protégé) : seule son
                 opacité anime 0→1 au chargement, gated reduced-motion — un
                 navigateur avec l'image déjà en cache (retour visiteur) la
                 voit s'afficher instantanément (classe déjà posée par l'attribut
                 onload s'il a déjà `complete`). Zéro CLS : le dégradé occupe
                 EXACTEMENT le même cadre (absolute inset-0). -->
            <div class="hero-lqip absolute inset-0" aria-hidden="true"></div>
            <img
              src={roofImg}
              alt={`Étude de toiture — ${clientName}`}
              width="1600"
              height="900"
              class="hero-photo absolute inset-0 h-full w-full object-cover"
              loading="eager"
              decoding="async"
              onload="this.classList.add('is-loaded')"
            />
          </>
        ) : (
          <div class="absolute inset-0 bg-azur-950" aria-hidden="true"></div>
        )}
        <!-- Scrim pour garantir le contraste AA du texte par-dessus la photo. -->
        <div class="hero-scrim absolute inset-0" aria-hidden="true"></div>
        <div class="relative mx-auto flex min-h-[72dvh] w-full max-w-4xl flex-col justify-end px-5 pb-12 pt-24 sm:min-h-[78dvh] sm:px-8 sm:pb-16 sm:pt-32">
          <p class="tech-label rule-brass cine-in text-brass-300" data-i18n
            data-fr={`${roofImg ? 'Votre installation · ' : 'Proposition · '}${instLabel}`}
            data-en={`${roofImg ? 'Your installation · ' : 'Proposal · '}${instLabel}`}
            data-ar={`${roofImg ? 'تركيبكم · ' : 'العرض · '}${instLabel}`}>
            {roofImg ? 'Votre installation · ' : 'Proposition · '}{instLabel}
          </p>
          <h1 class="display cine-in cine-in-1 mt-4 text-4xl text-blanc sm:text-5xl" data-i18n
            data-fr={`Bonjour ${clientName},`} data-en={`Hello ${clientName},`} data-ar={`مرحباً ${clientName}،`}>
            Bonjour {clientName},
          </h1>
          <p class="v2-body cine-in cine-in-2 mt-4 max-w-xl text-lune" data-i18n
            data-fr="Voici votre proposition solaire personnalisée. Tout est détaillé ci-dessous — vous pouvez la signer en ligne en bas de page."
            data-en="Here is your personalized solar proposal. Everything is detailed below — you can sign it online at the bottom of the page."
            data-ar="إليكم عرضكم الشمسي الشخصي. كل التفاصيل أدناه — يمكنكم التوقيع إلكترونياً أسفل الصفحة.">
            Voici votre proposition solaire personnalisée. Tout est détaillé ci-dessous —
            vous pouvez la signer en ligne en bas de page.
          </p>

          <!-- ── WJ114 · « DÉCIDER EN 10 SECONDES » ───────────────────────────
               Storydoc (1,3 M sessions) : 31 % rebondissent en 10 s ; 82 % de
               ceux qui atteignent la section 4 vont au bout ; le prix est la
               section la plus regardée ; la personnalisation complète relève
               l'engagement de +47 %. Mobile-first, ZÉRO scroll requis : nom du
               client (déjà affiché ci-dessus), les 4 chiffres phares CANONIQUES
               (mêmes valeurs que le CTA collant / les cartes plus bas — jamais
               recalculées) + UN CTA principal. Note personnelle du vendeur
               rendue UNIQUEMENT si le backend la fournit (WJ114 — lecture
               défensive, `sellerNote`) : rien n'est affiché en son absence. -->
          <div id="prop-fold-figures" class="cine-in cine-in-3 mt-6 grid grid-cols-2 gap-3 sm:mt-7 sm:grid-cols-4 sm:gap-4">
            {puissance ? (
              <div class="cine-card rounded-xl p-3 sm:p-4">
                <p class="tech-label text-lune-faint" data-i18n data-fr="Puissance" data-en="Power" data-ar="القدرة">Puissance</p>
                <p class="fig mt-1 text-xl text-lune sm:text-2xl" dir="ltr">{formatNumber(puissance, 2)} <span class="text-sm text-lune-soft">kWc</span></p>
              </div>
            ) : null}
            {prodKwh ? (
              <div class="cine-card rounded-xl p-3 sm:p-4">
                <p class="tech-label text-lune-faint" data-i18n data-fr="Production / an" data-en="Production / year" data-ar="الإنتاج / سنة">Production / an</p>
                <p class="fig mt-1 text-xl text-lune sm:text-2xl" dir="ltr">{formatNumber(prodKwh)} <span class="text-sm text-lune-soft">kWh</span></p>
              </div>
            ) : null}
            {heroTtc !== null ? (
              <div class="cine-card rounded-xl p-3 sm:p-4">
                <p class="tech-label text-lune-faint" data-i18n data-fr="Total TTC" data-en="Total (incl. tax)" data-ar="المجموع شامل الضريبة">Total TTC</p>
                <p class="fig lum mt-1 text-xl sm:text-2xl" dir="ltr">{formatMAD(heroTtc)}</p>
              </div>
            ) : null}
            {(ecoHero || paybackHero) ? (
              <div class="cine-card rounded-xl p-3 sm:p-4">
                <p class="tech-label text-lune-faint" data-i18n data-fr="Économie / an" data-en="Savings / year" data-ar="التوفير / سنة">Économie / an</p>
                <p class="fig mt-1 text-xl text-lune sm:text-2xl" dir="ltr">
                  {ecoHero ? formatMAD(ecoHero) : paybackHero}
                </p>
                {ecoHero && paybackHero ? (
                  <p class="mt-0.5 text-xs text-lune-faint" data-i18n
                    data-fr={`Rentabilisé en ${paybackHero}`} data-en={`Paid back in ${paybackHero}`} data-ar={`يُسترد خلال ${paybackHero}`}>
                    Rentabilisé en {paybackHero}
                  </p>
                ) : null}
              </div>
            ) : null}
          </div>

          <!-- WJ114 — UN CTA principal au-dessus du pli (même destination que le
               CTA collant : #signer si un prix réel existe, sinon le conseiller
               WhatsApp — jamais un devis à 0 MAD). -->
          <div class="cine-in cine-in-3 mt-5">
            {heroHasRealPrice ? (
              <a
                id="prop-fold-cta"
                href="#signer"
                class="btn-pill inline-flex w-full items-center justify-center sm:w-auto"
                style="background: var(--color-brass-400); color: var(--color-nuit); border-color: var(--color-brass-400)"
                data-i18n data-fr="Signer en ligne" data-en="Sign online" data-ar="التوقيع إلكترونياً"
              >
                Signer en ligne
              </a>
            ) : (
              <a
                id="prop-fold-cta"
                href={waLink}
                target="_blank"
                rel="noopener noreferrer"
                class="btn-pill inline-flex w-full items-center justify-center sm:w-auto"
                style="background: var(--color-brass-400); color: var(--color-nuit); border-color: var(--color-brass-400)"
                data-i18n data-fr="Contacter mon conseiller" data-en="Contact my advisor" data-ar="التواصل مع مستشاري"
              >
                Contacter mon conseiller
              </a>
            )}
          </div>

          <!-- WJ114 — note personnelle du vendeur : dégrade à RIEN si absente. -->
          {seller ? (
            <div id="prop-seller-note" class="cine-in cine-in-3 mt-5 flex items-start gap-3 rounded-xl border border-white/10 bg-white/5 p-3.5 sm:p-4">
              {seller.photoUrl ? (
                <img
                  src={seller.photoUrl}
                  alt={seller.name ?? ''}
                  width="40"
                  height="40"
                  loading="lazy"
                  decoding="async"
                  class="h-10 w-10 flex-none rounded-full object-cover"
                />
              ) : null}
              <div class="min-w-0">
                {seller.note ? <p class="v2-body text-sm text-lune italic">“{seller.note}”</p> : null}
                {seller.name ? <p class="mt-1 text-xs text-lune-faint">— {seller.name}</p> : null}
              </div>
            </div>
          ) : null}

          <dl class="cine-in cine-in-3 mt-7 flex flex-wrap gap-x-8 gap-y-3 text-sm">
            {reference && (
              <div>
                <dt class="text-lune-faint" data-i18n data-fr="Référence" data-en="Reference" data-ar="المرجع">Référence</dt>
                <dd class="fig text-lg text-lune" dir="ltr">{reference}</dd>
              </div>
            )}
            {proposalDate && (
              <div>
                <dt class="text-lune-faint" data-i18n data-fr="Date" data-en="Date" data-ar="التاريخ">Date</dt>
                <dd class="fig text-lg text-lune" dir="ltr">{proposalDate}</dd>
              </div>
            )}
            {/* WJ15 — Fenêtre de validité honnête : date backend réelle, sinon mention libellée. Jamais un compte-à-rebours. */}
            {validity.fromBackend && validity.label && !validity.expired && (
              <div>
                <dt class="text-lune-faint" data-i18n data-fr="Devis valable jusqu’au" data-en="Quote valid until" data-ar="العرض صالح حتى">Devis valable jusqu’au</dt>
                <dd class="fig text-lg text-brass-300" dir="ltr">{validity.label}</dd>
              </div>
            )}
            {validity.fromBackend && validity.expired && (
              <div>
                <dt class="text-lune-faint" data-i18n data-fr="Validité" data-en="Validity" data-ar="الصلاحية">Validité</dt>
