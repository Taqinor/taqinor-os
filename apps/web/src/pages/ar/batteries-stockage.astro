---
/**
 * AR — Batteries & storage (W67, RTL). Faithful Arabic translation of
 * /batteries-stockage ; EVERY spec/figure (6 000 cycles, 90 % DoD, 5 kWh
 * modules, 5–15 kWh, CE/IEC 62619/UN38.3, 10 years, 15/10/5 kWh, refs
 * 468/400/236) kept EXACT in Latin digits. Internal links via localizeNavHref.
 * FR untouched.
 */
import Layout from '../../layouts/Layout.astro';
import V2Enhance from '../../components/V2Enhance.astro';
import Article33Ribbon from '../../components/Article33Ribbon.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CtaBand from '../../components/CtaBand.astro';
import StickyCta from '../../components/StickyCta.astro';
import Faq from '../../components/Faq.astro';
import { getLocaleFromPath } from '../../i18n/utils';
import { localizeNavHref } from '../../i18n/pages';

const locale = getLocaleFromPath(Astro.url.pathname);
const L = (href: string) => localizeNavHref(href, locale);
const contactSim = L('/contact') + '#simulateur';

const specs = [
  { item: 'كيمياء ليثيوم-حديد-فوسفات (LFP)', detail: 'Dyness DL5.0C / DL5.0C PRO' },
  { item: 'العمر الافتراضي', detail: '6 000 دورة عند عمق تفريغ 90 % (DoD)' },
  { item: 'سعة قابلة للتوسيع', detail: 'وحدات 5 kWh قابلة للتوسيع: من 5 إلى 15 kWh وأكثر' },
  { item: 'التواصل', detail: 'CAN BMS مدمج مع عاكسات Deye الهجينة' },
  { item: 'الشهادات', detail: 'CE · IEC 62619 · UN38.3' },
  { item: 'الضمان', detail: '10 سنوات، مع الاحتفاظ بـ ≥ 70 % من السعة' },
];

const cas = [
  {
    k: 'بدون تخزين',
    title: 'استهلاك نهاري أساساً',
    body: 'حين يقع جلّ استهلاكك نهاراً، أفضل kWh هو الذي تغذّيه ألواحك في اللحظة نفسها — دون مرور عبر بطارية، دون خسائر شحن أو تفريغ. هذه حال البيوت النشطة نهاراً والمواقع التي يتبع نشاطها الشمس: مضخّة، تبريد، آلات، تكييف.',
  },
  {
    k: 'مع تخزين',
    title: 'استهلاك ليلي أو استمرارية الخدمة',
    body: 'تصبح البطارية مفيدة حين تأتي ذروة استهلاكك بعد غروب الشمس، أو حين يجب ألا يوقف الانقطاع شيئاً. الفائض المُنتَج ظهراً يُدّخَر ويُستعاد مساءً، في الساعة التي تُفوتر فيها الشبكة بالثمن المرتفع.',
  },
];

const installs = [
  { kwh: '15 kWh', where: 'El Jadida', ref: '468' },
  { kwh: '10 kWh', where: 'Casablanca', ref: '400' },
  { kwh: '5 kWh', where: 'El Jadida', ref: '236' },
];

// FAQ مرئية — schema={false} حتى تبقى /faq هي الصفحة الوحيدة الحاملة لـ FAQPage.
const faqItems = [
  {
    q: 'هل أحتاج فعلاً إلى بطارية مع ألواحي الشمسية؟',
    a: 'ليس بالضرورة. إذا كنت تستهلك جلّ كهربائك نهاراً — أجهزة تبريد، مضخّة، تكييف، آلات — فألواحك تغذّي أحمالك مباشرة، ولن تضيف البطارية سوى كلفة وخسائر تحويل. تصبح مفيدة إذا وقعت ذروة استهلاكك مساءً، أو إذا احتجت استمرارية الخدمة أثناء الانقطاعات. نحلّل منحنى استهلاكك ساعة بساعة قبل أي توصية.',
  },
  {
    q: 'كم تدوم بطارية LFP؟',
    a: 'على الورق، تتحمّل Dyness LFP عدد 6 000 دورة عند عمق تفريغ 90 %، بضمان 10 سنوات مع الاحتفاظ بـ ≥ 70 % من السعة. احسب دورة في اليوم: هذه الـ 6 000 دورة وحدها تغطّي أكثر من ستّ عشرة سنة. لكن البطارية تشيخ كذلك وهي متوقّفة — نحو 1 إلى 2 % من السعة تُفقد سنوياً، حتى دون استعمال. هذا التقادم الزمني هو ما يحسم غالباً في الأخير، وهو ما يردّ العمر النافع الحقيقي إلى 12-15 سنة تحت المناخ المغربي. والتصرّف السليم لكسب هذه السنوات: بطارية في الظل، مهوّاة، تبقى بين 15 و35 °C.',
  },
  {
    q: 'أي حجم بطارية أختار؟ (5–10 kWh أو 10–20 kWh أو 20 kWh+)',
    a: 'تقابل الدرجات حاجات مختلفة. من 5 إلى 10 kWh: طاقة احتياطية ليلية أساسية أو شحن بضعة أجهزة ضرورية أثناء انقطاع. من 10 إلى 20 kWh: استهلاك ذاتي مسائي كامل لبيت متوسط — يغطّي فائض النهار الشمسي معظم استهلاك الليل. ومن 20 kWh فأكثر: شبه استقلالية، مواقع نائية أو حاجة إلى يومين أو ثلاثة من الاستقلالية دون شمس. تتراكم وحدات Dyness لدينا بشرائح من 5 kWh — نضبط السعة على فترة المساء الواجب تغطيتها، لا على درجة تجارية. ويفصّل دليل مخصّص طريقة الحساب.',
  },
  {
    q: 'هل تحميني البطارية من انقطاعات التيار؟',
    a: 'نعم، إذا ضُبط العاكس الهجين على وضع EPS (تزويد طاقة طارئة). تضمن عاكسات Deye من سلسلة SG تحوّلاً شبه فوري (نحو 4 ms) دون صندوق إضافي — أشبه بعاكس UPS. وتتوقّف القدرة المتاحة أثناء الانقطاع على السعة المركَّبة والأحمال الموصولة على دائرة الطوارئ. لا تخلطه بعاكس شبكة بسيط (on-grid) يفصل هو أيضاً عند الانقطاع، لأسباب أمان.',
  },
  {
    q: 'هل الأفضل تخزين الفائض أم بيعه للشبكة بالمغرب؟',
    a: 'بالمغرب، يحدّ القانون 82-21 (الساري منذ يونيو 2026) الحقن في 20 % من الإنتاج السنوي، وتعريفة شراء ANRE تتراوح بين 0,18 و0,21 DH/kWh حسب الساعة. في حين أن kWh مشترى من الشبكة يكلّفك بين 0,90 DH (الشريحة الأولى) و1,66 DH (الاستهلاك المرتفع). بعبارة أخرى، kWh مخزَّن ومُستهلَك ذاتياً مساءً يساوي 4 إلى 9 مرّات أكثر من kWh مبيع للشبكة. فترتيب الأولويات إذن: (1) الاستهلاك المباشر نهاراً، (2) التخزين للمساء، (3) تصدير الباقي المحدود في 20 %. لا تُفرط في حجم بطارياتك لتصدّر أكثر — فذلك غير مربح.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Batteries & storage',
  serviceType: 'تخزين الطاقة الشمسية',
  description: 'تخزين شمسي بالمغرب: بطاريات Dyness ليثيوم-حديد-فوسفات (LFP)، مُحدَّدة المقاس بالدراسة حسب ملمح الاستهلاك — استهلاك ذاتي نهاري أو استمرارية الخدمة.',
  provider: { '@type': 'Organization', name: 'Taqinor', url: 'https://taqinor.ma' },
  areaServed: { '@type': 'Country', name: 'Maroc' },
};
---

<Layout
  title="بطاريات Dyness LFP الشمسية بالمغرب: 6 000 دورة، 90 % DoD | Taqinor"
  description="تخزين شمسي بالمغرب: بطاريات Dyness ليثيوم-حديد-فوسفات، أكثر من 6 000 دورة عند 90 % من عمق التفريغ، وحدات 5 kWh قابلة للتوسيع، حوار CAN BMS مدمج مع عاكسات Deye الهجينة، ضمان 10 سنوات. يبقى أن نعرف هل يبرّر ملمح استهلاكك بطارية — وغالباً، نهاراً، لا."
  ogSlug="equipement"
>
  <div class="v2">
    <V2Enhance />
    <Article33Ribbon />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <Breadcrumb items={[{ label: 'الرئيسية', href: L('/') }, { label: 'البطاريات والتخزين' }]} />

    <section class="px-4 pb-10 pt-16 text-white sm:pt-20">
      <div class="mx-auto max-w-3xl">
        <p class="tech-label v2-kicker rule-brass cine-in text-brass-300">تخزين الطاقة</p>
        <h1 class="display v2-page-title cine-in mt-5 [animation-delay:120ms]">البطاريات والتخزين</h1>
        <p class="v2-lead cine-in mt-6 max-w-xl text-white/85 [animation-delay:240ms]">
          بطارية Dyness LFP تتحمّل أكثر من 6 000 دورة عند 90 % من عمق التفريغ — ما يكفي لتدوم سنوات.
          لكن يبقى أن تكون مفيدة. السؤال الحقيقي ليس أي بطارية، بل <em>متى</em> تستهلك: نهاراً، نادراً
          ما تكون الكلفة الإضافية لبنك تخزين أفضل استثمار.
        </p>
      </div>
    </section>

    <!-- متى يُبرَّر التخزين / ومتى لا -->
    <section class="px-4 pb-20 sm:pb-24">
      <div class="mx-auto max-w-6xl">
        <p class="tech-label v2-kicker rule-brass text-brass-300">المفاضلة الصحيحة</p>
        <h2 class="display v2-section-title mt-5 text-white">متى تُبرَّر بطارية — ومتى لا</h2>
        <div class="mt-10 grid gap-6 md:grid-cols-2" data-stagger>
          {cas.map((c, i) => (
            <div class="v2-rise cine-card flex flex-col p-7" style={`--v2-i:${i}`}>
              <p class="tech-label text-brass-300">{c.k}</p>
              <h3 class="display mt-2 text-2xl text-white">{c.title}</h3>
              <p class="mt-3 flex-1 text-sm leading-relaxed text-lune-soft">{c.body}</p>
            </div>
          ))}
        </div>
        <p class="mt-8 max-w-2xl border-s-4 border-brass-400 ps-4 text-sm leading-relaxed text-lune-soft">
          بيع بطارية سهل؛ والقول إنها بلا فائدة أقل سهولة. نقرأ أولاً منحنى استهلاكك، ساعة بساعة: هو
          من يقول هل يدفع التخزين، وكم kWh يكفي. إضافة المعدات ليست أبداً الهدف.
          <a href={L('/guides/faut-il-des-batteries')} class="border-b-2 border-brass-400 pb-0.5 font-bold text-brass-300 transition-colors hover:text-brass-200">اقرأ الدليل الكامل →</a>
        </p>
      </div>
    </section>

    <!-- معدات التخزين المركَّبة — Dyness LFP -->
    <div class="v2-seam" aria-hidden="true"></div>
    <section class="bg-blanc-azur px-4 pb-20 pt-10 text-encre sm:pb-28">
      <div class="mx-auto max-w-3xl">
        <p class="tech-label v2-kicker rule-brass text-azur-600">المعدات المركَّبة</p>
        <h2 class="display v2-section-title mt-5">بطاريات Dyness ليثيوم-حديد-فوسفات</h2>
        <p class="v2-lead mt-4 text-encre-soft">
          حين يُبرَّر التخزين، نركّب بطاريات Dyness LFP. كيمياء ليثيوم-حديد-فوسفات لا تنفلت حرارياً
          كبعض أنواع الليثيوم الأخرى وتقبل تفريغها إلى 90 % في كل دورة دون أن تتلف. يتحاور الـ BMS عبر
          CAN مع العاكس الهجين Deye، الذي يدير الشحن والتفريغ بدقة. معدات مصدرها موزّعون رسميون
          بالمغرب، ضمان قابل للتفعيل محلياً.
        </p>
        <div class="mt-10 border-t-2 border-azur-900 bg-blanc" data-stagger>
          {specs.map((s, i) => (
            <div class="v2-rise flex items-baseline justify-between gap-4 border-b border-azur-900/15 px-5 py-4" style={`--v2-i:${i}`}>
              <span class="text-sm font-semibold">{s.item}</span>
              <span class="whitespace-normal text-end text-sm text-azur-600" dir="ltr">{s.detail}</span>
            </div>
          ))}
        </div>
        <p class="mx-auto mt-6 max-w-xl border-s-4 border-azur-600 ps-4 text-sm leading-relaxed text-encre-soft">
          تتراكم الوحدات بشرائح من 5 kWh: نضبط السعة على فترة المساء الواجب تغطيتها، لا أكثر ولا أقل.
          الحجم يتبع الحاجة المحسوبة، لا درجة تجارية.
          <a href={L('/équipement')} class="border-b border-azur-600 pb-0.5 font-semibold text-azur-600 transition-colors hover:text-azur-700">انظر كل المعدات المركَّبة →</a>
        </p>

        <!-- تركيبات حقيقية بتخزين -->
        <h3 class="display mt-14 text-xl">تخزين موجود بالفعل على أسطحنا</h3>
        <p class="mt-3 text-sm leading-relaxed text-encre-soft">
          من 5 kWh إلى 15 kWh: عدة بيوت تشتغل بالفعل ببطاريات Dyness، كل سعة مضبوطة على ملمح البيت
          الذي تلقّاها.
        </p>
        <div class="mt-6 grid gap-4 sm:grid-cols-3" data-stagger>
          {installs.map((inst, i) => (
            <div class="v2-rise border-s-2 border-azur-600 bg-blanc px-4 py-4" style={`--v2-i:${i}`}>
              <p class="fig whitespace-nowrap text-2xl text-azur-600" dir="ltr" data-tally>{inst.kwh}</p>
              <p class="tech-label mt-2 text-encre-faint">Dyness · {inst.where} · réf. {inst.ref}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- FAQ مرئية — schema={false}: تبقى /faq هي صفحة FAQPage الوحيدة (W130) -->
    <Faq
      schema={false}
      heading="أسئلة متكررة حول التخزين الشمسي"
      items={faqItems}
    />

    <!-- أدلة ومصادر داخلية — بطاقات البطاريات (W130) -->
    <section class="px-4 pb-20 pt-16 sm:pb-24">
      <div class="mx-auto max-w-6xl">
        <p class="tech-label v2-kicker rule-brass text-brass-300">للتعمّق أكثر</p>
        <h2 class="display v2-section-title mt-5 text-white">أدلة البطاريات والتخزين</h2>
        <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3" data-stagger>
          <a href={L('/guides/faut-il-des-batteries')} class="v2-rise cine-card flex flex-col p-6 transition-colors hover:border-brass-400/60" style="--v2-i:0">
            <p class="tech-label text-brass-300">الكيمياء</p>
            <h3 class="display mt-2 text-lg text-white">ليثيوم أم جل: أي كيمياء تختار؟</h3>
            <p class="mt-3 flex-1 text-sm leading-relaxed text-lune-soft">LFP وAGM/GEL وNMC — العمر الافتراضي، عمق التفريغ، الأمان الحراري: المقارنة من أجل المغرب.</p>
            <span class="mt-4 text-sm font-bold text-brass-300">اقرأ الدليل →</span>
          </a>
          <a href={L('/guides/faut-il-des-batteries')} class="v2-rise cine-card flex flex-col p-6 transition-colors hover:border-brass-400/60" style="--v2-i:1">
            <p class="tech-label text-brass-300">تحديد المقاس</p>
            <h3 class="display mt-2 text-lg text-white">أي حجم بطارية يناسب بيتي؟</h3>
            <p class="mt-3 flex-1 text-sm leading-relaxed text-lune-soft">طريقة حساب خطوة بخطوة: قِس فترة المساء عندك، واختر بين الدرجات 5–10 / 10–20 / 20+ kWh.</p>
            <span class="mt-4 text-sm font-bold text-brass-300">اقرأ الدليل →</span>
          </a>
          <a href={L('/guides/faut-il-des-batteries')} class="v2-rise cine-card flex flex-col p-6 transition-colors hover:border-brass-400/60" style="--v2-i:2">
            <p class="tech-label text-brass-300">استمرارية الخدمة</p>
            <h3 class="display mt-2 text-lg text-white">كهرباء أثناء الانقطاعات</h3>
            <p class="mt-3 flex-1 text-sm leading-relaxed text-lune-soft">وضع EPS، تحوّل ≈ 4 ms، دوائر الطوارئ: كيف تصمد تركيبة هجينة أمام الانقطاعات.</p>
            <span class="mt-4 text-sm font-bold text-brass-300">اقرأ الدليل →</span>
          </a>
        </div>
      </div>
    </section>

    <!-- روابط الختام -->
    <section class="px-4 pb-20 sm:pb-24">
      <div class="mx-auto max-w-6xl">
        <p class="tech-label v2-kicker rule-brass text-brass-300">للمزيد</p>
        <h2 class="display v2-section-title mt-5 text-white">التخزين في مشروعك</h2>
        <div class="mt-10 flex flex-wrap gap-3">
          <a href={L('/équipement')} class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">كل المعدات →</a>
          <a href={L('/résidentiel')} class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">الطاقة الشمسية السكنية →</a>
          <a href={L('/guides/faut-il-des-batteries')} class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">دليل: هل تلزم البطاريات؟ →</a>
          <a href={L('/realisations')} class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">إنجازاتنا →</a>
        </div>
      </div>
    </section>

    <CtaBand title="تخزين أم لا؟ منحنى استهلاكك سيقول — تشخيص مجاني." href={contactSim} />

    <StickyCta />
  </div>
</Layout>
