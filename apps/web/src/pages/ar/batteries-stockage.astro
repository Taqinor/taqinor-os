---
/**
 * AR — Batteries & storage (W67, RTL). Faithful Arabic translation of
 * /batteries-stockage ; EVERY spec/figure (6 000 cycles, 90 % DoD, 5 kWh
 * modules, 5–15 kWh, CE/IEC 62619/UN38.3, 10 years, 15/10/5 kWh, refs
 * 468/400/236) kept EXACT in Latin digits. Internal links via localizeNavHref.
 * FR untouched.
 *
 * ÉLÉVATION (W241) — mirrors the FR batteries-stockage.astro elevation:
 *  1. brass discipline: eyebrows text-lune (not text-brass-300) on dark sections;
 *  2. .section-lg + .section tokens for rhythm;
 *  3. seam-soft seams;
 *  4. card label demoted from text-brass-300 → text-lune;
 *  5. guide links demoted to text-lune / text-azur-200;
 *  6. spec table detail: text-right → text-end (RTL-logical);
 *  7. install cards: border-l-2 → border-s-2 (RTL-logical);
 *  8. outro eyebrow: text-brass-300 → text-lune.
 */
import Layout from '../../layouts/Layout.astro';
import V2Enhance from '../../components/V2Enhance.astro';
import Article33Ribbon from '../../components/Article33Ribbon.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CtaBand from '../../components/CtaBand.astro';
import StickyCta from '../../components/StickyCta.astro';
import Faq from '../../components/Faq.astro';
import ServiceWarrantyTable from '../../components/ServiceWarrantyTable.astro';
import RelatedLinks from '../../components/RelatedLinks.astro';
import { getLocaleFromPath } from '../../i18n/utils';
import { localizeNavHref } from '../../i18n/pages';
import { serviceFaqItems } from '../../lib/serviceFaq';

const locale = getLocaleFromPath(Astro.url.pathname);
const L = (href: string) => localizeNavHref(href, locale);
const devisHref = L('/devis/mon-toit');

const specs = [
  { item: 'كيمياء ليثيوم-حديد-فوسفات (LFP)', detail: 'Dyness DL5.0C / DL5.0C PRO' },
  { item: 'العمر الافتراضي', detail: '6 000 دورة عند عمق تفريغ 90 % (DoD)' },
  { item: 'سعة قابلة للتوسيع', detail: 'وحدات 5 kWh قابلة للتوسيع: من 5 إلى 15 kWh وأكثر' },
  { item: 'التواصل', detail: 'CAN BMS مدمج مع عاكسات Deye الهجينة' },
  { item: 'الشهادات', detail: 'CE · IEC 62619 · UN38.3' },
  { item: 'الضمان', detail: '10 سنوات، مع الاحتفاظ بـ ≥ 70 % من السعة' },
];

const cas = [
  {
    k: 'بدون تخزين',
    title: 'استهلاك نهاري أساساً',
    body: 'حين يقع جلّ استهلاكك نهاراً، أفضل kWh هو الذي تغذّيه ألواحك في اللحظة نفسها — دون مرور عبر بطارية، دون خسائر شحن أو تفريغ. هذه حال البيوت النشطة نهاراً والمواقع التي يتبع نشاطها الشمس: مضخّة، تبريد، آلات، تكييف.',
  },
  {
    k: 'مع تخزين',
    title: 'استهلاك ليلي أو استمرارية الخدمة',
    body: 'تصبح البطارية مفيدة حين تأتي ذروة استهلاكك بعد غروب الشمس، أو حين يجب ألا يوقف الانقطاع شيئاً. الفائض المُنتَج ظهراً يُدّخَر ويُستعاد مساءً، في الساعة التي تُفوتر فيها الشبكة بالثمن المرتفع.',
  },
];

const installs = [
  { kwh: '15 kWh', where: 'El Jadida', ref: '468' },
  { kwh: '10 kWh', where: 'Casablanca', ref: '400' },
  { kwh: '5 kWh', where: 'El Jadida', ref: '236' },
];

// W334 — 4 لوحات نهار/مساء/انقطاع/ليل: تكرار حرفي للمنطق المنشور أعلاه (حالتا
// «بدون تخزين» / «مع تخزين») ودليل «هل تلزم البطاريات؟» — لا تدفق جديد ولا رقم
// جديد، فقط التمثيل البصري يتغيّر. كل تدفق نشِط مذكور بالنص أيضاً لإتاحة
// الوصول (تبقى الصورة مقروءة دون SVG).
const flowPanels = [
  {
    k: 'نهاراً',
    title: 'الشمس تغذّي البيت',
    flows: ['شمسي ← استهلاك', 'شمسي ← بطارية (الفائض)'],
    note: 'أفضل kWh هو الذي يذهب مباشرة من الألواح إلى أجهزتك، دون التفاف.',
  },
  {
    k: 'مساءً',
    title: 'البطارية تأخذ المُقود',
    flows: ['بطارية ← استهلاك'],
    note: 'الفائض المخزَّن ظهراً يغطّي ذروة المساء، في الساعة التي تُفوتر فيها الشبكة بأعلى سعر.',
  },
  {
    k: 'انقطاع',
    title: 'دائرة الطوارئ تصمد',
    flows: ['شمسي ← بطارية (إن كان نهاراً)', 'بطارية ← استهلاك (دوائر EPS)'],
    note: 'العاكس الهجين يعزل دائرة طوارئ؛ الشبكة مقطوعة، والبيت ليس كذلك.',
  },
  {
    k: 'ليلاً',
    title: 'ما تبقّى يُوزَّع',
    flows: ['بطارية ← استهلاك', 'شبكة ← استهلاك (إن فرغت البطارية)'],
    note: 'حين تنفد البطارية، تعود الشبكة لتأخذ المُقود — لا شيء استثنائي، مجرّد المسار المنطقي التالي.',
  },
];

// FAQ مرئية — schema={false} حتى تبقى /faq هي الصفحة الوحيدة الحاملة لـ FAQPage.
// W263 — الأسئلة الخمس أدناه تحمل الآن مجموعة (cluster) مخصّصة («اختيار البطارية
// المناسبة»)؛ البنك المشترك (صيانة/ثمن/مُدرَج-مُستثنى/آجال/ضمانات، انظر
// lib/serviceFaq.ts) يُلحَق بنفس كتلة <Faq> لتفادي قسم أسئلة شائعة ثانٍ في الصفحة.
const usageCluster = 'اختيار البطارية المناسبة';
const faqItems = [
  {
    cluster: usageCluster,
    q: 'هل أحتاج فعلاً إلى بطارية مع ألواحي الشمسية؟',
    a: 'ليس بالضرورة. إذا كنت تستهلك جلّ كهربائك نهاراً — أجهزة تبريد، مضخّة، تكييف، آلات — فألواحك تغذّي أحمالك مباشرة، ولن تضيف البطارية سوى كلفة وخسائر تحويل. تصبح مفيدة إذا وقعت ذروة استهلاكك مساءً، أو إذا احتجت استمرارية الخدمة أثناء الانقطاعات. نحلّل منحنى استهلاكك ساعة بساعة قبل أي توصية.',
  },
  {
    cluster: usageCluster,
    q: 'كم تدوم بطارية LFP؟',
    a: 'على الورق، تتحمّل Dyness LFP عدد 6 000 دورة عند عمق تفريغ 90 %، بضمان 10 سنوات مع الاحتفاظ بـ ≥ 70 % من السعة. احسب دورة في اليوم: هذه الـ 6 000 دورة وحدها تغطّي أكثر من ستّ عشرة سنة. لكن البطارية تشيخ كذلك وهي متوقّفة — نحو 1 إلى 2 % من السعة تُفقد سنوياً، حتى دون استعمال. هذا التقادم الزمني هو ما يحسم غالباً في الأخير، وهو ما يردّ العمر النافع الحقيقي إلى 12-15 سنة تحت المناخ المغربي. والتصرّف السليم لكسب هذه السنوات: بطارية في الظل، مهوّاة، تبقى بين 15 و35 °C.',
  },
  {
    cluster: usageCluster,
    q: 'أي حجم بطارية أختار؟ (5–10 kWh أو 10–20 kWh أو 20 kWh+)',
    a: 'تقابل الدرجات حاجات مختلفة. من 5 إلى 10 kWh: طاقة احتياطية ليلية أساسية أو شحن بضعة أجهزة ضرورية أثناء انقطاع. من 10 إلى 20 kWh: استهلاك ذاتي مسائي كامل لبيت متوسط — يغطّي فائض النهار الشمسي معظم استهلاك الليل. ومن 20 kWh فأكثر: شبه استقلالية، مواقع نائية أو حاجة إلى يومين أو ثلاثة من الاستقلالية دون شمس. تتراكم وحدات Dyness لدينا بشرائح من 5 kWh — نضبط السعة على فترة المساء الواجب تغطيتها، لا على درجة تجارية. ويفصّل دليل مخصّص طريقة الحساب.',
  },
  {
    cluster: usageCluster,
    q: 'هل تحميني البطارية من انقطاعات التيار؟',
    a: 'نعم، إذا ضُبط العاكس الهجين على وضع EPS (تزويد طاقة طارئة). تضمن عاكسات Deye من سلسلة SG تحوّلاً شبه فوري (نحو 4 ms) دون صندوق إضافي — أشبه بعاكس UPS. وتتوقّف القدرة المتاحة أثناء الانقطاع على السعة المركَّبة والأحمال الموصولة على دائرة الطوارئ. لا تخلطه بعاكس شبكة بسيط (on-grid) يفصل هو أيضاً عند الانقطاع، لأسباب أمان.',
  },
  {
    cluster: usageCluster,
    q: 'هل الأفضل تخزين الفائض أم بيعه للشبكة بالمغرب؟',
    a: 'بالمغرب، يحدّ القانون 82-21 (الساري منذ يونيو 2026) الحقن في 20 % من الإنتاج السنوي، وتعريفة شراء ANRE تتراوح بين 0,18 و0,21 DH/kWh حسب الساعة. في حين أن kWh مشترى من الشبكة يكلّفك بين 0,90 DH (الشريحة الأولى) و1,66 DH (الاستهلاك المرتفع). بعبارة أخرى، kWh مخزَّن ومُستهلَك ذاتياً مساءً يساوي 4 إلى 9 مرّات أكثر من kWh مبيع للشبكة. فترتيب الأولويات إذن: (1) الاستهلاك المباشر نهاراً، (2) التخزين للمساء، (3) تصدير الباقي المحدود في 20 %. لا تُفرط في حجم بطارياتك لتصدّر أكثر — فذلك غير مربح.',
  },
  ...serviceFaqItems('batteries-stockage', 'ar'),
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Batteries & storage',
  serviceType: 'تخزين الطاقة الشمسية',
  description: 'تخزين شمسي بالمغرب: بطاريات Dyness ليثيوم-حديد-فوسفات (LFP)، مُحدَّدة المقاس بالدراسة حسب ملمح الاستهلاك — استهلاك ذاتي نهاري أو استمرارية الخدمة.',
  provider: { '@type': 'Organization', name: 'Taqinor', url: 'https://taqinor.ma' },
  areaServed: { '@type': 'Country', name: 'Maroc' },
};
---

<Layout
  title="بطاريات Dyness LFP الشمسية بالمغرب: 6 000 دورة، 90 % DoD | Taqinor"
  description="تخزين شمسي بالمغرب: بطاريات Dyness ليثيوم-حديد-فوسفات، أكثر من 6 000 دورة عند 90 % من عمق التفريغ، وحدات 5 kWh قابلة للتوسيع، حوار CAN BMS مدمج مع عاكسات Deye الهجينة، ضمان 10 سنوات. يبقى أن نعرف هل يبرّر ملمح استهلاكك بطارية — وغالباً، نهاراً، لا."
  ogSlug="batteries-stockage"
>
  <div class="v2">
    <V2Enhance />
    <Article33Ribbon />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <Breadcrumb items={[{ label: 'الرئيسية', href: L('/') }, { label: 'البطاريات والتخزين' }]} />

    {/* ── HÉROS ÉDITORIAL — eyebrow مُخفَّض إلى lune (انضباط النحاس) ── */}
    <section class="section-lg px-4 pb-10 text-white">
      <div class="mx-auto max-w-3xl">
        <p class="tech-label v2-kicker rule-brass cine-in text-lune">تخزين الطاقة</p>
        <h1 class="display v2-page-title cine-in cine-in-1 mt-6">البطاريات والتخزين</h1>
        <p class="v2-lead cine-in cine-in-2 mt-6 max-w-xl text-white/85">
          بطارية Dyness LFP تتحمّل أكثر من 6 000 دورة عند 90 % من عمق التفريغ — ما يكفي لتدوم سنوات.
          لكن يبقى أن تكون مفيدة. السؤال الحقيقي ليس أي بطارية، بل <em>متى</em> تستهلك: نهاراً، نادراً
          ما تكون الكلفة الإضافية لبنك تخزين أفضل استثمار.
        </p>
      </div>
    </section>

    <!-- متى يُبرَّر التخزين / ومتى لا -->
    <section class="section px-4">
      <div class="mx-auto max-w-6xl">
        {/* eyebrow مُخفَّض إلى lune */}
        <p class="tech-label v2-kicker rule-brass text-lune">المفاضلة الصحيحة</p>
        <h2 class="display v2-section-title mt-5 text-white">متى تُبرَّر بطارية — ومتى لا</h2>
        <div class="mt-12 grid gap-6 md:grid-cols-2" data-stagger>
          {cas.map((c, i) => (
            <div class="v2-rise cine-card flex flex-col p-7" style={`--v2-i:${i}`}>
              {/* تسمية بطاقة مُخفَّضة إلى lune (الذهب يبقى للأرقام/CTA) */}
              <p class="tech-label text-lune">{c.k}</p>
              <h3 class="display mt-2 text-2xl text-white">{c.title}</h3>
              <p class="mt-3 flex-1 text-sm leading-relaxed text-lune-soft">{c.body}</p>
            </div>
          ))}
        </div>
        {/* خط azur + رابط ثانوي lune/azur */}
        <p class="mt-8 max-w-2xl border-s-4 border-azur-200/50 ps-4 text-sm leading-relaxed text-lune-soft">
          بيع بطارية سهل؛ والقول إنها بلا فائدة أقل سهولة. نقرأ أولاً منحنى استهلاكك، ساعة بساعة: هو
          من يقول هل يدفع التخزين، وكم kWh يكفي. إضافة المعدات ليست أبداً الهدف.
          <a href={L('/guides/faut-il-des-batteries')} class="border-b-2 border-azur-200/60 pb-0.5 font-bold text-azur-200 transition-colors hover:text-white">اقرأ الدليل الكامل <span class="inline-block rtl:-scale-x-100">→</span></a>
        </p>
      </div>
    </section>

    <!-- W334 — مخطط تدفق 24 ساعة: نهار/مساء/انقطاع/ليل (شمسي ← استهلاك ← بطارية ← شبكة) -->
    <section class="section px-4">
      <div class="mx-auto max-w-6xl">
        <p class="tech-label v2-kicker rule-brass text-lune">بالصورة</p>
        <h2 class="display v2-section-title mt-5 text-white">يوم مع بطارية، في أربع لحظات</h2>
        <p class="v2-lead mt-4 max-w-2xl text-lune-soft">
          نفس المبدأ يتكرّر أربع مرات في اليوم: الإنتاج، الاستهلاك، تخزين الفائض، ثم إعادته عند
          الحاجة.
        </p>
        <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4" data-stagger>
          {flowPanels.map((p, i) => (
            <figure class="v2-rise cine-card flex flex-col p-6" style={`--v2-i:${i}`}>
              <figcaption>
                <p class="tech-label text-lune">{p.k}</p>
                <h3 class="display mt-2 text-lg text-white">{p.title}</h3>
              </figcaption>
              <svg
                class="mt-5 w-full"
                viewBox="0 0 220 200"
                dir="ltr"
                role="img"
                aria-label={`${p.title} — التدفقات: ${p.flows.join('، ')}`}
              >
                {/* الشمس */}
                <g transform="translate(110,30)" opacity={p.k === 'ليلاً' ? '0.28' : '1'}>
                  <circle r="14" fill="none" stroke="#e8b54a" stroke-width="2.5" />
                  {Array.from({ length: 8 }).map((_, r) => (
                    <line
                      x1="0" y1="-20" x2="0" y2="-26"
                      stroke="#e8b54a" stroke-width="2.5" stroke-linecap="round"
                      transform={`rotate(${r * 45})`}
                    />
                  ))}
                </g>
                {/* البيت (الاستهلاك) */}
                <g transform="translate(30,100)">
                  <path d="M-16 8 L-16 -6 L0 -18 L16 -6 L16 8 Z" fill="none" stroke="white" stroke-width="2.5" stroke-linejoin="round" />
                </g>
                {/* البطارية */}
                <g transform="translate(110,100)">
                  <rect x="-14" y="-14" width="28" height="28" rx="3" fill="none" stroke="white" stroke-width="2.5" />
                  <rect x="-6" y="-19" width="12" height="5" rx="1" fill="white" />
                  <rect x="-8" y="-6" width="16" height="12" fill={p.k === 'ليلاً' ? 'rgb(255 255 255 / 0.25)' : '#e8b54a'} />
                </g>
                {/* الشبكة (عمود) */}
                <g transform="translate(190,100)" opacity={p.k === 'انقطاع' ? '0.3' : '1'}>
                  <path d="M0 -16 L0 14 M-10 -6 L10 -6 M-13 4 L13 4" stroke="white" stroke-width="2.5" stroke-linecap="round" />
                  {p.k === 'انقطاع' && <path d="M-10 -18 L10 18" stroke="#e8b54a" stroke-width="2.5" stroke-linecap="round" />}
                </g>
                {/* أسهم التدفق — موصوفة في aria-label أعلاه، زخرفية هنا */}
                <g stroke="#7fa8ff" stroke-width="2" fill="none" opacity="0.85" aria-hidden="true">
                  {p.k !== 'ليلاً' && <path d="M104 44 L40 88" marker-end="url(#arrow-ar)" />}
                  {(p.k === 'نهاراً' || p.k === 'انقطاع') && <path d="M116 44 L110 84" marker-end="url(#arrow-ar)" />}
                  {(p.k === 'مساءً' || p.k === 'انقطاع' || p.k === 'ليلاً') && <path d="M96 100 L46 100" marker-end="url(#arrow-ar)" />}
                  {p.k === 'ليلاً' && <path d="M174 100 L124 100" marker-end="url(#arrow-ar)" />}
                </g>
                <defs>
                  <marker id="arrow-ar" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
                    <path d="M0 0 L6 3 L0 6 Z" fill="#7fa8ff" />
                  </marker>
                </defs>
                <text x="30" y="130" text-anchor="middle" class="fill-lune-soft" font-size="9">بيت</text>
                <text x="110" y="132" text-anchor="middle" class="fill-lune-soft" font-size="9">بطارية</text>
                <text x="190" y="130" text-anchor="middle" class="fill-lune-soft" font-size="9">شبكة</text>
              </svg>
              <ul class="mt-2 space-y-1 text-xs leading-relaxed text-lune-soft">
                {p.flows.map((f) => (<li>{f}</li>))}
              </ul>
              <p class="mt-3 flex-1 text-sm leading-relaxed text-lune-soft">{p.note}</p>
            </figure>
          ))}
        </div>
      </div>
    </section>

    <!-- معدات التخزين المركَّبة — Dyness LFP -->
    <div class="v2-seam" aria-hidden="true"></div>
    <section class="section bg-blanc-azur px-4 text-encre">
      <div class="mx-auto max-w-3xl">
        <p class="tech-label v2-kicker rule-brass text-azur-600">المعدات المركَّبة</p>
        <h2 class="display v2-section-title mt-5">بطاريات Dyness ليثيوم-حديد-فوسفات</h2>
        <p class="v2-lead mt-4 text-encre-soft">
          حين يُبرَّر التخزين، نركّب بطاريات Dyness LFP. كيمياء ليثيوم-حديد-فوسفات لا تنفلت حرارياً
          كبعض أنواع الليثيوم الأخرى وتقبل تفريغها إلى 90 % في كل دورة دون أن تتلف. يتحاور الـ BMS عبر
          CAN مع العاكس الهجين Deye، الذي يدير الشحن والتفريغ بدقة. معدات مصدرها موزّعون رسميون
          بالمغرب، ضمان قابل للتفعيل محلياً.
        </p>
        <div class="mt-10 border-t-2 border-azur-900 bg-blanc" data-stagger>
          {specs.map((s, i) => (
            <div class="v2-rise flex items-baseline justify-between gap-4 border-b border-azur-900/15 px-5 py-4" style={`--v2-i:${i}`}>
              <span class="text-sm font-semibold">{s.item}</span>
              <span class="whitespace-normal text-end text-sm text-azur-600" dir="ltr">{s.detail}</span>
            </div>
          ))}
        </div>
