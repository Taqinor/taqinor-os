                  aria-describedby="mt-puissance-kva-err" placeholder="مثال: 160" dir="ltr" class={`${inputClass} mt-1`} />
                <span id="mt-puissance-kva-err" hidden role="alert" class="mt-1 block text-xs text-alert-300"></span>
              </label>
            </div>

            <!-- (c) Profil d'activité — pilote le taux d'autoconsommation -->
            <fieldset>
              <legend class="text-sm text-lune-soft">نشاطكم</legend>
              <div class="mt-2 grid grid-cols-1 gap-2 sm:grid-cols-3">
                <button type="button" class="mt-activity cine-card border p-3 text-center text-sm text-white transition-colors" data-value="day" aria-pressed="false">نهاراً (8h–18h)</button>
                <button type="button" class="mt-activity cine-card border p-3 text-center text-sm text-white transition-colors" data-value="day_evening" aria-pressed="false">نهار + مساء</button>
                <button type="button" class="mt-activity cine-card border p-3 text-center text-sm text-white transition-colors" data-value="continuous" aria-pressed="false">24/24 · 7/7</button>
              </div>
