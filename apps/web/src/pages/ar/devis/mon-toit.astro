---
/**
 * AR — « Mon toit » CAPTURE CLIENT (WJ38, RTL-native). Traduction fidèle du
 * parcours FR (src/pages/devis/mon-toit.astro) : MÊME contrat de soumission
 * /api/capture-lead (validateLead, seuil 1 000 MAD, roofPoint/roofOutline/
 * profil énergétique facultatifs), MÊME logique client (assistant 3 étapes,
 * estimation instantanée, WhatsApp-first, récupération d'abandon) — seul le
 * texte visible change de langue par défaut.
 *
 * Réutilise le MÊME markup dual-node `data-i18n`/`data-fr`/`data-ar` établi
 * par WJ33/WJ17 : cette route affiche simplement la paire AR par défaut au
 * lieu de FR (le sélecteur FR/عربي en page est masqué ici — l'URL /ar/
 * déclare déjà la langue, cohérent avec les autres pages /ar/*). `dir="rtl"`
 * est déjà posé au niveau <html> par Layout.astro via Astro.currentLocale ;
 * on applique en plus le même mécanisme RTL-natif (line-height, mirroring)
 * que le reste du parcours.
 */
import Layout from '../../../layouts/Layout.astro';
import { BILL_RANGES } from '../../../lib/billRange';
import { ROOF_TYPES } from '../../../lib/lead';
import { NAP, WHATSAPP_LEADS } from '../../../lib/nap';
import { whatsappLink } from '../../../lib/whatsapp';
import StarRating from '../../../components/StarRating.astro';
import CertLogoRow from '../../../components/CertLogoRow.astro';
import InstallCounter from '../../../components/InstallCounter.astro';
import ZelligeSignature from '../../../components/ZelligeSignature.astro';

const inputClass =
  'w-full border border-white/15 bg-white/5 px-3 py-3 text-base text-white placeholder:text-lune-faint outline-none transition-colors focus:border-brass-400 focus:ring-2 focus:ring-brass-400/30 aria-[invalid=true]:border-alert-300 aria-[invalid=true]:ring-2 aria-[invalid=true]:ring-alert-300/30';
// BILL_RANGES / ROOF_TYPES sont partagés (contrat lead.ts INCHANGÉ) : les
// `id` restent identiques FR/AR, seul le libellé affiché est traduit ici
// (lib/billRange.ts et lib/lead.ts ne sont pas modifiés — hors périmètre).
const BILL_RANGE_LABEL_AR: Record<string, string> = {
  lt800: 'أقل من 800 درهم',
  '800-1000': '800 – 1 000 درهم',
  '1000-1500': '1 000 – 1 500 درهم',
  '1500-3000': '1 500 – 3 000 درهم',
  '3000-5000': '3 000 – 5 000 درهم',
  '5000-10000': '5 000 – 10 000 درهم',
  gt10000: 'أكثر من 10 000 درهم',
};
const ROOF_TYPE_LABEL_AR: Record<string, string> = {
  villa: 'فيلا',
  hangar: 'مستودع صناعي',
  toit_plat: 'سطح مسطح',
  autre: 'أخرى',
};
const roofTypes = ROOF_TYPES.map((r) => ({ ...r, label: ROOF_TYPE_LABEL_AR[r.id] ?? r.label }));
const billRanges = BILL_RANGES.map((b) => ({ ...b, label: BILL_RANGE_LABEL_AR[b.id] ?? b.label }));

// WJ6 — étapes de l'assistant (libellés FR + AR). data-i18n pour bascule de langue.
const STEPS = [
  { fr: 'Votre toit', ar: 'سطحك' },
  { fr: 'Votre facture', ar: 'فاتورتك' },
  { fr: 'Votre estimation', ar: 'تقديرك' },
];

// WJ6 — sélecteur de mode (résidentiel / professionnel / agricole), FR + AR.
const MODES = [
  { id: 'residentiel', fr: 'Résidentiel', ar: 'سكني', desc_fr: 'Villa, appartement', desc_ar: 'فيلا، شقة' },
  { id: 'professionnel', fr: 'Professionnel', ar: 'مهني', desc_fr: 'Industrie, commerce', desc_ar: 'صناعة، تجارة' },
  { id: 'agricole', fr: 'Agricole', ar: 'فلاحي', desc_fr: 'Pompage, ferme', desc_ar: 'ضخ، مزرعة' },
];

// WJ8 — villes desservies (réelles, NAP) pour la preuve de proximité.
const TOWNS = ['Casablanca', 'Rabat', 'Marrakech', 'Tanger', 'Agadir', 'Kénitra', 'Fès', 'Settat'];

// WJ65 — sortie honnête sans JavaScript : ce formulaire dépend entièrement du
// script (calcul d'estimation, soumission fetch) — sans JS, rien ne fonctionne.
// Plutôt qu'une page muette, un lien wa.me + tel: statique (aucun JS requis).
const noscriptWaHref = whatsappLink(
  WHATSAPP_LEADS,
  'مرحباً، أرغب في استلام تقديري الشمسي من taqinor.ma (متصفحي لا يفعّل جافاسكريبت).',
);
const noscriptTelHref = `tel:${NAP.phone}`;
---

<Layout
  title="استلموا تقديركم الشمسي — سطحكم | Taqinor"
  description="العنوان + الفاتورة: استلموا فوراً تقديراً شمسياً (القدرة، التوفير، استرداد التكلفة)، ثم دراستكم الشخصية على واتساب."
  noindex={true}
>
  <section class="bg-nuit px-4 py-8 sm:py-12">
    <div class="mx-auto max-w-2xl">
      <!-- WJ65 — سطر خروج صادق بدون جافاسكريبت: هذه الصفحة مدفوعة بالكامل
           بالسكربت (الخريطة، الحساب، الإرسال) — بدونه ستبقى صامتة. نوفر هنا
           مخرجاً لا يحتاج أي جافاسكريبت على الإطلاق. -->
      <noscript>
        <div class="cine-card mb-6 border border-brass-400/40 p-5 text-sm text-white">
          <p class="font-semibold">تحتاج هذه الصفحة إلى جافاسكريبت لحساب تقديركم.</p>
          <p class="mt-1 text-lune-soft">
            لا مشكلة: تواصلوا معنا مباشرة، مجاناً وبدون التزام.
          </p>
          <div class="mt-4 flex flex-col gap-2 sm:flex-row">
            <a href={noscriptWaHref} target="_blank" rel="noopener"
              class="inline-flex flex-1 items-center justify-center gap-2 bg-ok-600 px-5 py-3 text-base font-bold text-white transition-opacity hover:opacity-90">
              الكتابة على واتساب
            </a>
            <a href={noscriptTelHref}
              class="inline-flex flex-1 items-center justify-center gap-2 border border-white/25 px-5 py-3 text-base font-bold text-white transition-colors hover:border-brass-400 hover:text-brass-300">
              الاتصال بـ {NAP.phoneDisplayIntl}
            </a>
          </div>
        </div>
      </noscript>

      <!-- En-tête + bascule de langue FR/AR (WJ6) -->
      <div class="flex items-start justify-between gap-3">
        <div>
          <p class="tech-label rule-brass text-brass-300" data-i18n data-fr="Estimation solaire · gratuit · sans engagement" data-ar="تقدير شمسي · مجاني · بدون التزام">
            Estimation solaire · gratuit · sans engagement
          </p>
          <h1 class="display mt-4 text-2xl text-white sm:text-3xl" data-i18n data-fr="Recevez votre estimation solaire" data-ar="استلم تقديرك الشمسي">
            Recevez votre estimation solaire
          </h1>
        </div>
        <div class="flex flex-none gap-1 rounded-sm border border-white/15 p-0.5" role="group" aria-label="اللغة">
          <button type="button" id="mt-lang-fr" aria-pressed="true"
            class="px-3 py-1.5 text-sm font-semibold text-azur-950 bg-brass-400 transition-colors">FR</button>
          <button type="button" id="mt-lang-ar" aria-pressed="false"
            class="px-3 py-1.5 text-sm font-semibold text-lune-soft transition-colors hover:text-white">عربي</button>
        </div>
      </div>

      <!-- WJ6 — microcopie « pas de pression » -->
      <p class="mt-3 text-sm text-lune-soft" data-i18n
        data-fr="Réponse sous 24–48 h · on vous répond sur WhatsApp, pas d'appels commerciaux."
        data-ar="رد خلال 24–48 ساعة · نجيبك على واتساب، بدون مكالمات تجارية.">
        Réponse sous 24–48 h · on vous répond sur WhatsApp, pas d'appels commerciaux.
      </p>

      <!-- WJ6 — barre de progression étiquetée -->
      <ol id="mt-progress" class="mt-6 grid grid-cols-3 gap-2" aria-label="التقدم">
        {STEPS.map((s, i) => (
          <li class="mt-step flex flex-col gap-1.5" data-step={i}>
            <span class="h-1.5 w-full rounded-full bg-white/10 mt-step-bar transition-colors"></span>
            <span class="text-xs text-lune-faint mt-step-label" data-i18n data-fr={s.fr} data-ar={s.ar}>{s.fr}</span>
          </li>
        ))}
      </ol>

      <!-- ============ ÉTAPE 0/1 — VOTRE TOIT (mode + carte/repère) ============ -->
      <div id="mt-panel-0" class="mt-step-panel">
        <!-- WJ6 — sélecteur de mode -->
        <fieldset class="mt-6">
          <legend class="text-sm text-lune-soft" data-i18n data-fr="Votre type de projet" data-ar="نوع مشروعك">Votre type de projet</legend>
          <!-- WJ65 — sur les tout petits écrans (≲360 px), 3 colonnes serrent trop
               le texte (troncature/chevauchement) : on empile en 1 colonne, puis
               3 dès `sm:` (640 px), cohérent avec le reste de la page. -->
          <div class="mt-3 grid grid-cols-1 gap-2 sm:grid-cols-3">
            {MODES.map((m, i) => (
              <button type="button" class="mt-mode cine-card flex flex-col items-start gap-0.5 border p-3 text-left transition-colors"
                data-mode={m.id} aria-pressed={i === 0 ? 'true' : 'false'}>
                <span class="text-sm font-semibold text-white" data-i18n data-fr={m.fr} data-ar={m.ar}>{m.fr}</span>
                <span class="text-xs text-lune-faint" data-i18n data-fr={m.desc_fr} data-ar={m.desc_ar}>{m.desc_fr}</span>
              </button>
            ))}
          </div>
        </fieldset>

        <p class="mt-5 text-lune-soft" data-i18n
          data-fr="Cherchez votre adresse et posez un repère sur votre toit. C'est facultatif — vous pouvez aussi continuer avec votre adresse seule."
          data-ar="ابحث عن عنوانك وضع علامة على سطحك. هذا اختياري — يمكنك أيضاً المتابعة بعنوانك فقط.">
          Cherchez votre adresse et posez un repère sur votre toit. C'est facultatif —
          vous pouvez aussi continuer avec votre adresse seule.
        </p>

        <!-- Repli sans JavaScript / sans clé carte (WJ4) : on demande l'adresse en clair
             et on AUTORISE la suite (plus de cul-de-sac sur le repère). -->
        <div id="mt-fallback" hidden class="cine-card mt-5 border-l-4 border-alert-300 p-5">
          <p class="font-semibold text-white" data-i18n data-fr="Carte momentanément indisponible" data-ar="الخريطة غير متوفرة مؤقتاً">Carte momentanément indisponible</p>
          <p class="mt-2 text-sm text-lune-soft" data-i18n
            data-fr="Pas de souci : indiquez votre adresse complète ci-dessous et continuez. Nous localiserons votre toit pour vous."
            data-ar="لا مشكلة: أدخل عنوانك الكامل أدناه وتابع. سنحدد موقع سطحك من أجلك.">
            Pas de souci : indiquez votre adresse complète ci-dessous et continuez. Nous
            localiserons votre toit pour vous.
          </p>
          <label class="mt-3 block text-sm text-lune-soft">
            <span data-i18n data-fr="Adresse complète" data-ar="العنوان الكامل">Adresse complète</span>
            <input id="mt-fallback-address" type="text" autocomplete="street-address"
              placeholder="مثال: تجزئة الوفاق، حي الرياض، الرباط" class={`${inputClass} mt-1`} />
          </label>
        </div>

        <!-- CARTE — recherche d'adresse + repère (ids rp9-* câblés par captureBoot). -->
        <div id="mt-stage" class="cine-card mt-5 overflow-hidden">
          <form id="rp9-search" class="flex flex-col gap-3 border-b border-white/10 p-4 sm:flex-row">
            <label for="rp9-address" class="sr-only">عنوانكم</label>
            <div class="relative flex-1">
              <input id="rp9-address" name="address" type="text" autocomplete="off"
                role="combobox" aria-autocomplete="list" aria-expanded="false"
                aria-controls="rp9-suggestions" aria-haspopup="listbox"
                placeholder="العنوان، الحي أو المدينة (مثال: الدار البيضاء، المعاريف)" class={inputClass} />
              <ul id="rp9-suggestions" role="listbox" aria-label="اقتراحات العناوين" hidden
                class="absolute left-0 right-0 top-full z-20 mt-1 max-h-72 overflow-auto border border-white/15 bg-nuit-900 shadow-xl">
              </ul>
            </div>
            <button type="submit"
              class="flex-none bg-brass-400 px-6 py-3 text-base font-bold text-azur-950 transition-colors hover:bg-brass-300">
              تحديد الموقع
            </button>
          </form>

          <div id="rp9-map" class="mt-skeleton-shimmer mt-0 h-[44vh] min-h-[280px] w-full bg-nuit-700"
            role="application" aria-label="خريطة الأقمار الصناعية لتحديد سطحكم"></div>

          <div class="flex flex-wrap items-center gap-3 border-t border-white/10 p-4">
            <button type="button" id="rp9-finish" disabled
              class="border border-white/25 px-4 py-2.5 text-sm font-semibold text-white transition-colors hover:border-brass-400 hover:text-brass-300 disabled:cursor-not-allowed disabled:opacity-40">
              إنهاء الرسم
            </button>
            <button type="button" id="rp9-undo-point" hidden
              class="border border-white/25 px-4 py-2.5 text-sm font-semibold text-lune-soft transition-colors hover:border-brass-400 hover:text-brass-300">
              التراجع عن آخر نقطة
            </button>
            <button type="button" id="rp9-clear"
              class="border border-white/25 px-4 py-2.5 text-sm font-semibold text-lune-soft transition-colors hover:border-white/50 hover:text-white">
              مسح
            </button>
            <p class="ml-auto text-sm text-lune-faint">
              <span>العلامة&nbsp;: </span><span id="rp9-area-value" class="text-white" dir="ltr">—</span>
            </p>
          </div>
          <p id="rp9-status" class="border-t border-white/10 px-4 py-3 text-sm text-lune-faint" aria-live="polite">
            ابحثوا عن عنوانكم، ثم ضعوا علامة على سطحكم (اختياري).
          </p>
        </div>

        <div class="mt-5 flex justify-end">
          <button type="button" id="mt-next-0"
            class="inline-flex items-center justify-center gap-2 bg-brass-400 px-6 py-3 text-base font-bold text-azur-950 transition-colors hover:bg-brass-300">
            <span data-i18n data-fr="Continuer" data-ar="متابعة">Continuer</span>
            <!-- WJ89 — chevron SVG auto-retourné en RTL (règle globale.css
                 `[dir="rtl"] button svg[aria-hidden="true"]`), plus jamais un
                 glyphe « → » littéral figé dans le sens LTR (illisible en RTL). -->
            <svg aria-hidden="true" width="10" height="10" viewBox="0 0 10 10" fill="none">
              <polyline points="3,1 7,5 3,9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </button>
        </div>
      </div>

      <!-- ============ ÉTAPE 2 — VOTRE FACTURE (+ profil énergétique) ============ -->
      <div id="mt-panel-1" class="mt-step-panel" hidden>
        <p class="mt-6 text-lune-soft" data-i18n
          data-fr="Indiquez votre facture pour calculer votre estimation. Le montant exact donne le chiffre le plus juste."
          data-ar="أدخل فاتورتك لحساب تقديرك. المبلغ الدقيق يعطي الرقم الأصح.">
          Indiquez votre facture pour calculer votre estimation. Le montant exact donne le
          chiffre le plus juste.
        </p>

        <div class="cine-card mt-5 space-y-4 p-5 sm:p-6">
          <label class="block text-sm text-lune-soft">
            <span data-i18n data-fr="Facture mensuelle exacte (MAD)" data-ar="الفاتورة الشهرية الدقيقة (درهم)">Facture mensuelle exacte (MAD)</span>
            <input id="mt-facture-hiver" name="factureHiver" type="number" step="any" inputmode="decimal"
              placeholder="مثال: 1 200" dir="ltr" class={`${inputClass} mt-1`} />
            <span id="mt-facture-hiver-err" hidden class="mt-1 block text-xs text-alert-300"></span>
            <!-- WJ67 — micro-transparence « pourquoi on vous demande ça » : copie
                 seule, repliée par défaut (native <details>, aucun JS requis). -->
            <details class="mt-1.5">
              <summary class="cursor-pointer select-none text-xs text-lune-faint hover:text-lune-soft" data-i18n
                data-fr="Pourquoi on vous demande ça ?" data-ar="لماذا نطلب منكم هذا؟">
                Pourquoi on vous demande ça&nbsp;?
              </summary>
              <p class="mt-1 text-xs text-lune-faint" data-i18n
                data-fr="Le montant exact permet un calcul juste — jamais partagé."
                data-ar="المبلغ الدقيق يتيح حساباً صحيحاً — لا يُشارَك أبداً.">
                Le montant exact permet un calcul juste — jamais partagé.
              </p>
            </details>
          </label>

          <label class="block text-sm text-lune-soft">
            <span data-i18n data-fr="…ou choisissez une tranche" data-ar="…أو اختر شريحة">…ou choisissez une tranche</span>
            <select id="mt-bill" name="billRange" class={`${inputClass} mt-1`}>
              <option value="">اختر…</option>
              {billRanges.map((b) => <option value={b.id}>{b.label}</option>)}
            </select>
            <span id="mt-bill-err" hidden class="mt-1 block text-xs text-alert-300"></span>
          </label>

          <div class="grid gap-4 sm:grid-cols-2">
            <label class="block text-sm text-lune-soft">
              <span data-i18n data-fr="Type de toit" data-ar="نوع السطح">Type de toit</span>
              <select id="mt-roof" name="roofType" class={`${inputClass} mt-1`}>
                <option value="">اختر…</option>
                {roofTypes.map((r) => <option value={r.id}>{r.label}</option>)}
              </select>
              <span id="mt-roof-err" hidden class="mt-1 block text-xs text-alert-300"></span>
            </label>
            <label class="block text-sm text-lune-soft">
              <span data-i18n data-fr="Raccordement" data-ar="نوع الربط">Raccordement</span>
              <select id="mt-raccordement" name="raccordement" class={`${inputClass} mt-1`}>
                <option value="">اختر…</option>
                <option value="monophase">أحادي الطور</option>
                <option value="triphase">ثلاثي الطور</option>
                <option value="inconnu">لا أعرف</option>
              </select>
            </label>
          </div>

          <label class="flex items-start gap-3 text-sm text-lune-soft">
            <input id="mt-ete-differente" name="eteDifferente" type="checkbox" class="mt-1 h-5 w-5 flex-none accent-brass-400" />
            <span data-i18n data-fr="L'été est différent de l'hiver ? (climatisation, pompage…)" data-ar="الصيف مختلف عن الشتاء؟ (تكييف، ضخ…)">L'été est différent de l'hiver&nbsp;? (climatisation, pompage…)</span>
          </label>

          <label id="mt-facture-ete-wrap" hidden class="block text-sm text-lune-soft">
            <span data-i18n data-fr="Facture été (MAD)" data-ar="فاتورة الصيف (درهم)">Facture été (MAD)</span>
            <input id="mt-facture-ete" name="factureEte" type="number" step="any" inputmode="decimal"
              placeholder="مثال: 2 500" dir="ltr" class={`${inputClass} mt-1`} />
          </label>
        </div>

        <!-- ===== WJ31 — questions best-in-world, TOUTES facultatives, repliées par défaut ===== -->
        <details id="mt-more" class="cine-card mt-4 p-5 sm:p-6">
          <summary class="cursor-pointer select-none text-sm font-semibold text-brass-300" data-i18n
            data-fr="Affiner mon estimation (facultatif, 1 minute)" data-ar="تحسين تقديري (اختياري، دقيقة واحدة)">
            Affiner mon estimation (facultatif, 1 minute)
          </summary>

          <div class="mt-4 grid gap-4 sm:grid-cols-2">
            <label class="block text-sm text-lune-soft">
              <span data-i18n data-fr="Distributeur d'électricité" data-ar="موزع الكهرباء">Distributeur d'électricité</span>
              <select id="mt-distributeur" name="distributeur" class={`${inputClass} mt-1`}>
                <option value="">اختر…</option>
                <option value="onee">المكتب الوطني (ONEE)</option>
                <option value="lydec">ليديك (Lydec)</option>
                <option value="redal">ريضال (Redal)</option>
                <option value="inconnu">لا أعرف</option>
              </select>
            </label>
            <label class="block text-sm text-lune-soft">
              <span data-i18n data-fr="Consommation (kWh/mois, si connue)" data-ar="الاستهلاك (كيلوواط ساعة/شهر، إن عُرف)">Consommation (kWh/mois, si connue)</span>
              <input id="mt-bill-kwh" name="billKwh" type="number" step="any" inputmode="decimal"
                placeholder="مثال: 850" dir="ltr" class={`${inputClass} mt-1`} />
            </label>
          </div>

          <!-- Photo compteur/facture — capturée EN LOCAL, jamais uploadée (pas d'endpoint aujourd'hui). -->
          <div class="mt-4">
            <label class="block text-sm text-lune-soft" for="mt-meter-photo" data-i18n
              data-fr="Photo du compteur ou de la facture" data-ar="صورة العداد أو الفاتورة">
              Photo du compteur ou de la facture
            </label>
            <input id="mt-meter-photo" type="file" accept="image/*" capture="environment"
              class="mt-1 block w-full text-sm text-lune-soft file:mr-3 file:border-0 file:bg-white/10 file:px-3 file:py-2 file:text-sm file:font-semibold file:text-white" />
            <p id="mt-meter-photo-note" class="mt-1 text-xs text-lune-faint" data-i18n
              data-fr="Ou envoyez-la nous directement sur WhatsApp après l'envoi du formulaire — c'est souvent plus rapide."
              data-ar="أو أرسلها لنا مباشرة على واتساب بعد إرسال النموذج — غالباً أسرع.">
              Ou envoyez-la nous directement sur WhatsApp après l'envoi du formulaire — c'est
              souvent plus rapide.
            </p>
          </div>

          <fieldset class="mt-4">
            <legend class="text-sm text-lune-soft" data-i18n data-fr="Ombrage sur le toit" data-ar="التظليل على السطح">Ombrage sur le toit</legend>
            <div class="mt-2 grid grid-cols-3 gap-2">
              <button type="button" class="mt-ombrage cine-card border p-2.5 text-center text-sm text-white transition-colors" data-value="aucun" aria-pressed="false" data-i18n data-fr="Aucun" data-ar="لا يوجد">Aucun</button>
              <button type="button" class="mt-ombrage cine-card border p-2.5 text-center text-sm text-white transition-colors" data-value="partiel" aria-pressed="false" data-i18n data-fr="Partiel" data-ar="جزئي">Partiel</button>
              <button type="button" class="mt-ombrage cine-card border p-2.5 text-center text-sm text-white transition-colors" data-value="important" aria-pressed="false" data-i18n data-fr="Important" data-ar="كبير">Important</button>
            </div>
          </fieldset>

          <label class="mt-4 block text-sm text-lune-soft">
            <span data-i18n data-fr="Âge approximatif du toit (années)" data-ar="عمر السطح التقريبي (سنوات)">Âge approximatif du toit (années)</span>
            <input id="mt-roof-age" name="roofAgeYears" type="number" step="1" min="0" inputmode="numeric"
              placeholder="مثال: 10" dir="ltr" class={`${inputClass} mt-1`} />
          </label>

          <fieldset class="mt-4">
            <legend class="text-sm text-lune-soft" data-i18n data-fr="Charges futures envisagées" data-ar="أحمال مستقبلية متوقعة">Charges futures envisagées</legend>
            <div class="mt-2 flex flex-wrap gap-2">
              <button type="button" class="mt-future-load cine-card border px-3 py-2 text-sm text-white transition-colors" data-value="clim" aria-pressed="false" data-i18n data-fr="Climatisation" data-ar="تكييف">Climatisation</button>
              <button type="button" class="mt-future-load cine-card border px-3 py-2 text-sm text-white transition-colors" data-value="ve" aria-pressed="false" data-i18n data-fr="Voiture électrique" data-ar="سيارة كهربائية">Voiture électrique</button>
              <button type="button" class="mt-future-load cine-card border px-3 py-2 text-sm text-white transition-colors" data-value="pompe" aria-pressed="false" data-i18n data-fr="Pompage" data-ar="ضخ">Pompage</button>
            </div>
          </fieldset>

          <label class="mt-4 flex items-start gap-3 text-sm text-lune-soft">
            <input id="mt-battery-interest" name="batteryInterest" type="checkbox" class="mt-1 h-5 w-5 flex-none accent-brass-400" />
            <span data-i18n data-fr="Intéressé(e) par une batterie de stockage" data-ar="مهتم بتخزين البطارية">Intéressé(e) par une batterie de stockage</span>
          </label>

          <div class="mt-4 grid gap-4 sm:grid-cols-2">
            <label class="block text-sm text-lune-soft">
              <span data-i18n data-fr="Vous êtes…" data-ar="أنتم…">Vous êtes…</span>
              <select id="mt-occupant-type" name="occupantType" class={`${inputClass} mt-1`}>
                <option value="">اختر…</option>
                <option value="proprietaire">مالك</option>
                <option value="locataire">مستأجر</option>
                <option value="decideur">صاحب القرار (شركة)</option>
              </select>
            </label>
            <label class="block text-sm text-lune-soft">
              <span data-i18n data-fr="Votre projet, c'est pour…" data-ar="مشروعكم من أجل…">Votre projet, c'est pour…</span>
              <select id="mt-project-timing" name="projectTiming" class={`${inputClass} mt-1`}>
                <option value="">اختر…</option>
                <option value="maintenant">الآن</option>
                <option value="3mois">خلال ~3 أشهر</option>
                <option value="renseignement">مجرد استعلام</option>
              </select>
            </label>
          </div>

          <label class="mt-4 block text-sm text-lune-soft">
            <span data-i18n data-fr="Mode de financement envisagé" data-ar="طريقة التمويل المتوقعة">Mode de financement envisagé</span>
            <select id="mt-financing-intent" name="financingIntent" class={`${inputClass} mt-1`}>
              <option value="">اختر…</option>
              <option value="comptant">نقداً</option>
              <option value="financement">تمويل / قرض</option>
              <option value="indecis">لم أقرر بعد</option>
            </select>
          </label>
        </details>

        <div class="mt-5 flex items-center justify-between gap-3">
          <button type="button" id="mt-back-1"
            class="inline-flex items-center gap-1 px-2 py-3 text-base font-semibold text-lune-soft transition-colors hover:text-white">
            <svg aria-hidden="true" width="10" height="10" viewBox="0 0 10 10" fill="none">
              <polyline points="7,1 3,5 7,9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            <span data-i18n data-fr="Retour" data-ar="رجوع">Retour</span>
          </button>
          <button type="button" id="mt-estimate"
            class="inline-flex items-center justify-center gap-2 bg-brass-400 px-6 py-3 text-base font-bold text-azur-950 transition-colors hover:bg-brass-300">
            <span data-i18n data-fr="Voir mon estimation" data-ar="عرض تقديري">Voir mon estimation</span>
            <svg aria-hidden="true" width="10" height="10" viewBox="0 0 10 10" fill="none">
              <polyline points="3,1 7,5 3,9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </button>
        </div>
      </div>

      <!-- ============ ÉTAPE 3 — VOTRE ESTIMATION (WJ1) + CONTACT (WJ3) ============ -->
      <div id="mt-panel-2" class="mt-step-panel" hidden>
        <!-- WJ1 — l'estimation instantanée AVANT la porte de contact -->
        <div id="mt-estimate-card" class="cine-card mt-6 border border-brass-400/30 p-5 sm:p-6" aria-live="polite">
          <p class="tech-label text-brass-300" data-i18n data-fr="Votre estimation instantanée" data-ar="تقديرك الفوري">Votre estimation instantanée</p>
          <div id="mt-estimate-body" class="mt-4 grid grid-cols-1 gap-4 sm:grid-cols-3">
            <div>
              <p class="text-3xl font-bold text-white"><span id="mt-est-kwc">—</span> <span class="text-base font-normal text-lune-soft">kWc</span></p>
              <p class="text-xs text-lune-faint" data-i18n data-fr="Puissance recommandée" data-ar="القدرة الموصى بها">Puissance recommandée</p>
            </div>
            <div>
              <p class="text-3xl font-bold text-ok-400"><span id="mt-est-savings">—</span></p>
              <p class="text-xs text-lune-faint" data-i18n data-fr="Économies estimées / mois" data-ar="التوفير المقدّر / شهر">Économies estimées / mois</p>
            </div>
            <div>
              <p class="text-3xl font-bold text-white" id="mt-est-payback">—</p>
              <p class="text-xs text-lune-faint" data-i18n data-fr="Amortissement" data-ar="استرداد التكلفة">Amortissement</p>
            </div>
          </div>
          <p id="mt-estimate-note" class="mt-4 text-xs text-lune-faint" data-i18n
            data-fr="Fourchette préliminaire calculée à partir de votre facture (autoconsommation, loi 82-21). Le chiffrage exact est établi après visite technique — sans engagement."
            data-ar="شريحة أولية محسوبة من فاتورتك (الاستهلاك الذاتي، القانون 82-21). يُحدَّد التقدير الدقيق بعد زيارة تقنية — بدون التزام.">
            Fourchette préliminaire calculée à partir de votre facture (autoconsommation, loi
            82-21). Le chiffrage exact est établi après visite technique — sans engagement.
          </p>
          <!-- WJ1 — quand l'estimation est indisponible (facture absente/non chiffrable) -->
          <p id="mt-estimate-unavailable" hidden class="mt-4 text-sm text-alert-300" data-i18n
            data-fr="Estimation indisponible : indiquez votre facture mensuelle pour la calculer. Nous l'affinons ensemble sur WhatsApp."
            data-ar="التقدير غير متاح: أدخل فاتورتك الشهرية لحسابه. نحدّده معاً على واتساب.">
            Estimation indisponible : indiquez votre facture mensuelle pour la calculer. Nous
            l'affinons ensemble sur WhatsApp.
          </p>
          <!-- WJ65 — plafond de bon sens (MAX_BILL) : un montant absurde (faute de
               frappe, ex. un zéro en trop) ne doit jamais produire un chiffre
               chiffré avec assurance — on demande de vérifier plutôt. -->
          <p id="mt-estimate-toolarge" hidden class="mt-4 text-sm text-alert-300" data-i18n
            data-fr="Estimation indisponible — vérifiez le montant saisi." data-ar="التقدير غير متاح — تحقّقوا من المبلغ المُدخل.">
            Estimation indisponible — vérifiez le montant saisi.
          </p>

          <!-- ===== WJ2 — « voir les panneaux sur votre toit » (facultatif, lazy) =====
               Affiché UNIQUEMENT quand un contour (≥3 sommets) a été tracé à l'étape 1
               ET qu'une estimation kWc est disponible. Bouton = geste explicite ; le
               moteur 3D (Three.js + viewerOnly) n'est importé qu'au tap. Boîte à hauteur
               RÉSERVÉE (zéro CLS) : le bouton occupe déjà la même zone que le canvas. -->
          <div id="mt-panels3d" hidden class="mt-5 border-t border-white/10 pt-5">
            <div id="mt-panels3d-stage" class="mt-panels3d-stage cine-card relative overflow-hidden rounded-lg">
              <div id="mt-panels3d-overlay" class="absolute inset-0 flex flex-col items-center justify-center gap-2 px-4 text-center">
                <button type="button" id="mt-panels3d-start"
                  class="btn-pill inline-flex items-center justify-center gap-2"
                  style="background: var(--color-brass-400); color: var(--color-nuit); border-color: var(--color-brass-400)">
                  <span data-i18n data-fr="Voir les panneaux sur votre toit" data-ar="مشاهدة الألواح على سطحك">Voir les panneaux sur votre toit</span>
                </button>
                <p class="max-w-xs text-xs text-lune-faint" data-i18n
                  data-fr="Aperçu illustratif — l'implantation exacte est confirmée après visite technique."
                  data-ar="معاينة توضيحية — يُؤكَّد التوضع الدقيق بعد زيارة تقنية.">
                  Aperçu illustratif — l'implantation exacte est confirmée après visite technique.
                </p>
              </div>
            </div>
            <p id="mt-panels3d-hint" hidden class="mt-2 text-xs text-lune-faint" data-i18n
              data-fr="Faites glisser pour tourner · pincez ou molette pour zoomer."
              data-ar="اسحب للتدوير · قرّب بإصبعين أو بعجلة الفأرة.">
              Faites glisser pour tourner · pincez ou molette pour zoomer.
            </p>
          </div>
        </div>

        <!-- Formulaire de contact (la porte vient APRÈS l'estimation). -->
        <form id="mt-form" novalidate class="cine-card mt-5 space-y-4 p-5 sm:p-6">
          <p class="tech-label rule-brass text-brass-300" data-i18n data-fr="Pour recevoir votre étude" data-ar="لاستلام دراستك">Pour recevoir votre étude</p>

          <div class="grid gap-4 sm:grid-cols-2">
            <label class="block text-sm text-lune-soft">
              <span data-i18n data-fr="Nom complet" data-ar="الاسم الكامل">Nom complet</span>
              <input id="mt-name" name="fullName" type="text" autocomplete="name" required aria-required="true" class={`${inputClass} mt-1`} />
              <span id="mt-name-err" hidden class="mt-1 block text-xs text-alert-300"></span>
            </label>
            <label class="block text-sm text-lune-soft">
              <span data-i18n data-fr="Téléphone / WhatsApp" data-ar="الهاتف / واتساب">Téléphone / WhatsApp</span>
              <input id="mt-phone" name="phone" type="tel" inputmode="tel" autocomplete="tel" required aria-required="true"
                placeholder="06 XX XX XX XX" dir="ltr" class={`${inputClass} mt-1`} />
              <span id="mt-phone-err" hidden class="mt-1 block text-xs text-alert-300"></span>
            </label>
          </div>

          <label class="block text-sm text-lune-soft">
            <span data-i18n data-fr="Adresse / ville" data-ar="العنوان / المدينة">Adresse / ville</span>
            <input id="mt-city" name="city" type="text" autocomplete="address-level2" required aria-required="true"
              placeholder="تُقرأ من الخريطة — قابلة للتعديل عند الحاجة" class={`${inputClass} mt-1`} />
            <span id="mt-city-err" hidden class="mt-1 block text-xs text-alert-300"></span>
          </label>

          <!-- WJ3 — e-mail (facultatif) + opt-in WhatsApp -->
          <label class="block text-sm text-lune-soft">
            <span data-i18n data-fr="E-mail (facultatif)" data-ar="البريد الإلكتروني (اختياري)">E-mail (facultatif)</span>
            <input id="mt-email" name="email" type="email" inputmode="email" autocomplete="email"
              placeholder="you@example.com" dir="ltr" class={`${inputClass} mt-1`} />
          </label>

          <!-- WJ51 — préférence de contact EXPLICITE (remplace la case unique
               « je préfère WhatsApp ») : un choix nommé, jamais une case cochée
               par défaut sans qu'on la voie. Forwardé en `contactPreference`
               (facultatif) + dérive `whatsappOptIn` pour garder le contrat webhook
               inchangé. -->
          <fieldset class="mt-1">
            <legend class="text-sm text-lune-soft" data-i18n data-fr="Comment préférez-vous qu'on vous recontacte ?" data-ar="كيف تفضّلون أن نتواصل معكم؟">Comment préférez-vous qu'on vous recontacte&nbsp;?</legend>
            <div class="mt-2 grid grid-cols-1 gap-2 sm:grid-cols-2">
              <label class="mt-contact-pref cine-card flex cursor-pointer items-center gap-2 border border-white/15 p-3 text-sm text-white transition-colors has-[:checked]:border-ok-600">
                <input id="mt-contact-whatsapp" name="contactPreference" type="radio" value="whatsapp_only" checked
                  class="h-4 w-4 flex-none accent-ok-600" />
                <span data-i18n data-fr="Uniquement sur WhatsApp" data-ar="فقط عبر واتساب">Uniquement sur WhatsApp</span>
              </label>
              <label class="mt-contact-pref cine-card flex cursor-pointer items-center gap-2 border border-white/15 p-3 text-sm text-white transition-colors has-[:checked]:border-brass-400">
                <input id="mt-contact-phone" name="contactPreference" type="radio" value="phone_ok"
                  class="h-4 w-4 flex-none accent-brass-400" />
                <span data-i18n data-fr="Un conseiller peut m'appeler" data-ar="يمكن لمستشار الاتصال بي">Un conseiller peut m'appeler</span>
              </label>
            </div>
          </fieldset>

          <label class="flex items-start gap-3 text-sm text-lune-soft">
            <input id="mt-consent" name="consent" type="checkbox" required aria-required="true" class="mt-1 h-5 w-5 flex-none accent-brass-400" />
            <span data-i18n data-fr="J'accepte d'être recontacté(e) par Taqinor au sujet de mon projet solaire." data-ar="أوافق على أن تتواصل معي تاكينور بخصوص مشروعي الشمسي.">
              J'accepte d'être recontacté(e) par Taqinor au sujet de mon projet solaire.
            </span>
          </label>
          <span id="mt-consent-err" hidden class="block text-xs text-alert-300"></span>

          <p id="mt-error" hidden class="text-sm text-alert-300" aria-live="polite"></p>

          <!-- WJ3 — CTA PRIMAIRE WhatsApp-first. WJ60 — libellé « Envoi en cours… »
               pendant l'attente réseau (bascule via #mt-submit-label/#mt-submit-pending,
               même mécanisme dual-node data-i18n que le reste de la page). -->
          <button type="submit" id="mt-submit"
            class="inline-flex w-full items-center justify-center gap-2 bg-ok-600 px-6 py-4 text-base font-bold text-white transition-opacity hover:opacity-90 disabled:cursor-not-allowed disabled:opacity-50">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true" class="flex-none"><path d="M.057 24l1.687-6.163a11.867 11.867 0 0 1-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.817 11.817 0 0 1 8.413 3.488 11.824 11.824 0 0 1 3.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 0 1-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 0 0 1.512 5.26l-.999 3.648 3.736-.979z"/></svg>
            <span id="mt-submit-label" data-i18n data-fr="Recevoir mon estimation sur WhatsApp" data-ar="استلام تقديري على واتساب">Recevoir mon estimation sur WhatsApp</span>
            <span id="mt-submit-pending" hidden data-i18n data-fr="Envoi en cours…" data-ar="جارٍ الإرسال…">Envoi en cours…</span>
          </button>

          <div class="flex items-center justify-between gap-3">
            <button type="button" id="mt-back-2"
              class="inline-flex items-center gap-1 px-2 py-2 text-sm font-semibold text-lune-soft transition-colors hover:text-white">
              <svg aria-hidden="true" width="10" height="10" viewBox="0 0 10 10" fill="none">
                <polyline points="7,1 3,5 7,9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              <span data-i18n data-fr="Retour" data-ar="رجوع">Retour</span>
            </button>
          </div>

          <!-- WJ5 — succès qualifié (≥ 1 000 MAD : la demande atteint le CRM) -->
          <div id="mt-success" hidden class="border border-ok-600/40 bg-ok-600/10 p-4 text-sm text-white">
            <p class="font-semibold" data-i18n data-fr="Merci ! Votre demande est enregistrée." data-ar="شكراً! تم تسجيل طلبك.">Merci ! Votre demande est enregistrée.</p>
            <p class="mt-1 text-lune-soft" data-i18n data-fr="Notre équipe prépare votre étude et vous recontacte très vite — souvent sur WhatsApp." data-ar="فريقنا يُعدّ دراستك ويتواصل معك قريباً — غالباً عبر واتساب.">Notre équipe prépare votre étude et vous recontacte très vite — souvent sur WhatsApp.</p>
            <!-- WJ52 — référence courte : comble le vide post-soumission (24–48 h
                 d'attente) par un artefact concret à mentionner sur WhatsApp. -->
            <p class="mt-2 text-lune-soft">
              <span data-i18n data-fr="Votre référence :" data-ar="مرجعكم:">Votre référence&nbsp;:</span>
              {' '}<strong id="mt-client-ref" class="font-mono text-white" dir="ltr">—</strong>
              <br />
              <span class="text-xs" data-i18n
                data-fr="Mentionnez ce code sur WhatsApp pour retrouver votre dossier plus vite."
                data-ar="اذكروا هذا الرمز على واتساب لإيجاد ملفكم بسرعة أكبر.">
                Mentionnez ce code sur WhatsApp pour retrouver votre dossier plus vite.
              </span>
            </p>
            <a id="mt-success-wa" href="#" target="_blank" rel="noopener"
              class="mt-3 inline-flex items-center gap-2 bg-ok-600 px-4 py-2.5 text-sm font-bold text-white transition-opacity hover:opacity-90">
              <span data-i18n data-fr="Ouvrir WhatsApp maintenant" data-ar="افتح واتساب الآن">Ouvrir WhatsApp maintenant</span>
            </a>
          </div>

          <!-- WJ5 — chemin HONNÊTE sous le seuil 1 000 MAD (jamais un faux « enregistré ») -->
          <div id="mt-belowthreshold" hidden class="border border-brass-400/40 bg-brass-400/10 p-4 text-sm text-white">
            <p class="font-semibold" data-i18n data-fr="Le solaire n'est pas encore rentable à votre échelle." data-ar="الطاقة الشمسية ليست بعدُ مربحة على نطاقك.">Le solaire n'est pas encore rentable à votre échelle.</p>
            <p class="mt-1 text-lune-soft" data-i18n
              data-fr="En dessous de ~1 000 MAD/mois, l'investissement met trop longtemps à se rentabiliser pour qu'on vous le recommande honnêtement. Gardons le contact : dès que votre facture augmente, ou pour des conseils gratuits d'efficacité énergétique, écrivez-nous sur WhatsApp."
              data-ar="تحت ~1000 درهم/شهر، يستغرق الاستثمار وقتاً طويلاً ليصبح مربحاً بما يكفي لننصحك به بصدق. لنبقَ على تواصل: بمجرد ارتفاع فاتورتك، أو لنصائح مجانية حول كفاءة الطاقة، راسلنا على واتساب.">
              En dessous de ~1 000 MAD/mois, l'investissement met trop longtemps à se rentabiliser
              pour qu'on vous le recommande honnêtement. Gardons le contact : dès que votre facture
              augmente, ou pour des conseils gratuits d'efficacité énergétique, écrivez-nous sur
              WhatsApp.
            </p>
            <a id="mt-belowthreshold-wa" href="#" target="_blank" rel="noopener"
              class="mt-3 inline-flex items-center gap-2 bg-ok-600 px-4 py-2.5 text-sm font-bold text-white transition-opacity hover:opacity-90">
              <span data-i18n data-fr="Discuter sur WhatsApp" data-ar="الدردشة على واتساب">Discuter sur WhatsApp</span>
            </a>
          </div>
        </form>
      </div>

      <!-- ============ WJ8/WJ35 — CONFIANCE AU POINT DE CAPTURE ============ -->
      <aside class="mt-8 border-t border-white/10 pt-6">
        <!-- pending real content from Reda : photos d'installations réelles.
             On NE FABRIQUE PAS de chiffre ni d'avis : on affiche des faits vérifiables (loi
             82-21, garanties constructeur standard, zone de service réelle) + un emplacement
             scaffoldé pour les photos. Le compteur d'installations (4ᵉ tuile) est désormais
             RÉEL — dérivé de src/lib/realisations.ts (WJ35, InstallCounter). -->
        <div class="grid grid-cols-2 gap-3 sm:grid-cols-4">
          <div class="cine-card p-3 text-center">
            <p class="text-sm font-bold text-white" data-i18n data-fr="Conforme loi 82-21" data-ar="مطابق للقانون 82-21">Conforme loi 82-21</p>
            <p class="text-xs text-lune-faint" data-i18n data-fr="Autoproduction déclarée" data-ar="إنتاج ذاتي مُصرَّح">Autoproduction déclarée</p>
          </div>
          <div class="cine-card p-3 text-center">
            <p class="text-sm font-bold text-white" data-i18n data-fr="Garantie 25 ans" data-ar="ضمان 25 سنة">Garantie 25 ans</p>
