                <option value="lydec">ليديك (Lydec)</option>
                <option value="redal">ريضال (Redal)</option>
                <option value="inconnu">لا أعرف</option>
              </select>
              <!-- WJ70 — هذا الاختيار لا يغيّر أي رقم معروض اليوم (ليديك/ريضال
                   لا تزالان مساويتين لتعريفة المكتب الوطني المتحفظة). -->
              <p class="mt-1 text-xs text-lune-faint" data-i18n
                data-fr="Estimation basée sur le barème ONEE (conservateur) pour tous les distributeurs, en attendant les grilles réelles par distributeur."
                data-ar="التقدير يعتمد على تعريفة المكتب الوطني (ONEE) المتحفظة لجميع الموزعين، إلى حين توفر شبكات أسعار حقيقية لكل موزع.">
                التقدير يعتمد على تعريفة المكتب الوطني (ONEE) المتحفظة لجميع الموزعين، إلى حين
                توفر شبكات أسعار حقيقية لكل موزع.
              </p>
            </label>
            <label class="block text-sm text-lune-soft">
              <span data-i18n data-fr="Consommation (kWh/mois, si connue)" data-ar="الاستهلاك (كيلوواط ساعة/شهر، إن عُرف)">Consommation (kWh/mois, si connue)</span>
              <input id="mt-bill-kwh" name="billKwh" type="number" step="any" inputmode="decimal"
