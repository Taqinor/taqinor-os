                <span id="mt-pro-bill-err" hidden role="alert" class="mt-1 block text-xs text-alert-300"></span>
              </label>
            </div>

            <!-- (b) Raccordement BT / MT (+ kVA si MT) -->
            <div id="mt-tension-raccordement">
              <p class="text-sm text-lune-soft">الربط</p>
              <div class="mt-2 grid grid-cols-2 gap-2" role="group" aria-label="نوع الربط">
                <button type="button" id="mt-tension-bt" class="mt-tension cine-card border p-2.5 text-center text-sm text-white transition-colors" data-value="bt" aria-pressed="true">الجهد المنخفض</button>
