<style>
  /* WJ2 — boîte à hauteur RÉSERVÉE (zéro CLS) : le bouton « voir les panneaux »
     et le canvas 3D qui le remplace ensuite occupent EXACTEMENT la même zone. */
  .mt-panels3d-stage {
    height: 320px;
    background: linear-gradient(160deg, rgb(20 38 63 / 0.9), rgb(7 11 29 / 0.95));
  }
  @media (min-width: 640px) {
    .mt-panels3d-stage {
      height: 380px;
    }
  }

  /* ===== WJ34 — squelettes de performance perçue (zéro CLS : la zone occupe
     déjà sa hauteur finale — bg-nuit-700/min-h existants — on n'ajoute qu'un
     effet de « chargement » par-dessus, retiré au premier rendu réel). ===== */
  .mt-skeleton-shimmer {
    background-image: linear-gradient(
      100deg,
      transparent 30%,
      rgb(255 255 255 / 0.06) 50%,
      transparent 70%
    );
    background-size: 200% 100%;
  }
  @media (prefers-reduced-motion: no-preference) {
    .mt-skeleton-shimmer {
      animation: mt-shimmer 1.6s ease-in-out infinite;
    }
  }
  @keyframes mt-shimmer {
    from { background-position: 200% 0; }
    to { background-position: -200% 0; }
  }

  /* Squelettes des 3 chiffres d'estimation — mêmes proportions que le texte
     final (text-3xl), donc AUCUN CLS quand les vrais chiffres les remplacent. */
  .mt-est-skeleton {
    display: inline-block;
    height: 2.25rem;
    width: 4.5rem;
    border-radius: 0.25rem;
    background: rgb(255 255 255 / 0.08);
    vertical-align: middle;
  }
</style>

<script>
  import { estimateFromBill, formatMadRange } from '../../../lib/billEstimate';
  import { captureWhatsappText, whatsappLink } from '../../../lib/whatsapp';
  import { WHATSAPP_LEADS } from '../../../lib/nap';
  import { buildClientRef, validateLead } from '../../../lib/lead';
  import { type CaptureStrings } from '../../../scripts/roofPro11/mapDraw';

  // WJ41 — رسائل نظام الخريطة/محدد المواقع (roofPro11/mapDraw.ts + captureBoot.ts
  // تكون افتراضياً بالفرنسية) — هذه الصفحة تمرر نصوصاً عربية حتى لا تتحدث اللحظة
  // الأكثر تفاعلاً في المسار بالفرنسية مع الزوار الناطقين بالعربية.
  const ROOF_TOOL_STRINGS_AR: CaptureStrings = {
    searchAddressThenPin: 'ابحثوا عن عنوانكم، ثم ضعوا علامة على سطحكم.',
    pinPlaced: 'تم وضع العلامة. يمكنكم تعديلها، أو رسم محيط السطح (اختياري)، ثم ملء بياناتكم.',
    outlineTraced: 'تم رسم المحيط. املؤوا بياناتكم أدناه، ثم أرسلوا.',
    traceOutline: 'ارسموا محيط سطحكم. انقروا نقراً مزدوجاً للإغلاق (اختياري).',
    outlineCrosses: 'رسمكم يتقاطع مع نفسه — صححوه (« مسح ») قبل الإغلاق.',
    pointWouldCross: 'هذه النقطة ستقاطع رسمكم — ضعوها في مكان آخر للحفاظ على محيط بسيط.',
    doubleClickToClose: 'انقروا نقراً مزدوجاً (أو « إنهاء ») لإغلاق السطح وبدء الحساب.',
    cornerPlaced: (n) => `تم وضع الزاوية ${n} — واصلوا رسم المحيط.`,
    lastPointUndone: (n) => `تم التراجع عن آخر نقطة — ${n} زاوية (زوايا) متبقية. واصلوا الرسم.`,
    clickCornersToClose: 'انقروا زوايا سطحكم. انقروا نقراً مزدوجاً للإغلاق وبدء الحساب.',
    searchingAddress: 'جارٍ البحث عن العنوان…',
    addressNotFound: 'العنوان غير موجود. حددوا المدينة أو حرّكوا الخريطة يدوياً.',
    chooseFromList: 'اختاروا عنوانكم من القائمة، ثم انقروا زوايا سطحكم.',
    searchUnavailable: 'البحث غير متوفر. حرّكوا الخريطة يدوياً للعثور على سطحكم.',
  };

  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const $ = (id: string) => document.getElementById(id);
  const fallback = $('mt-fallback');
  const cityEl = $('mt-city') as HTMLInputElement | null;
  const addressEl = $('rp9-address') as HTMLInputElement | null;
  const fallbackAddrEl = $('mt-fallback-address') as HTMLInputElement | null;

  // ——— état capture (repère / contour) tenu par onCaptureChange ———
  let capturePin: { lat: number; lng: number } | null = null;
  let captureOutline: Array<[number, number]> = [];
  let cityTouched = false;
  cityEl?.addEventListener('input', () => { cityTouched = true; });

  // ——— WJ6/WJ33 : bascule de langue FR/AR (data-i18n) ———
  // WJ30 — la langue active est transmise au webhook (langue_preferee).
  //
  // WJ33 — FIX : `el.textContent = v` APLATISSAIT toute balise imbriquée à
  // l'intérieur d'un élément `data-i18n` (ex. un futur <strong>/<a> perdu au
  // premier passage AR→FR→AR). On bascule désormais par PAIRE DE NŒUDS
  // show/hide : au premier appel, chaque élément `data-i18n` est ENVELOPPÉ de
  // deux <span> — un FR (markup ORIGINAL, capturé une fois via innerHTML avant
  // toute mutation) et un AR (texte simple depuis data-ar, car les libellés AR
  // du DOM sont aujourd'hui du texte brut) — puis on masque/affiche la bonne
  // paire. Aucune balise n'est plus jamais perdue, quel que soit le nombre
  // d'allers-retours FR↔AR.
  let currentLang: 'fr' | 'ar' = 'fr';
  const i18nPairs: Array<{ fr: HTMLElement; ar: HTMLElement }> = [];
  function prepareI18n() {
    document.querySelectorAll<HTMLElement>('[data-i18n]').forEach((el) => {
      const arText = el.dataset.ar;
      if (typeof arText !== 'string') return;
      const frSpan = document.createElement('span');
      // Le markup FR ORIGINAL (pouvant contenir des balises imbriquées) est
      // préservé tel quel — capturé UNE SEULE fois, avant toute mutation.
      frSpan.innerHTML = el.innerHTML;
      const arSpan = document.createElement('span');
      arSpan.textContent = arText;
      arSpan.hidden = true;
      el.textContent = '';
      el.append(frSpan, arSpan);
      i18nPairs.push({ fr: frSpan, ar: arSpan });
    });
  }
  function applyLang(lang: 'fr' | 'ar') {
    const isAr = lang === 'ar';
    currentLang = lang;
    i18nPairs.forEach(({ fr, ar }) => {
      fr.hidden = isAr;
      ar.hidden = !isAr;
    });
    // WJ33 — RTL/langue au niveau DOCUMENT (pas seulement un bloc local) :
    // un lecteur d'écran ou le rendu natif du navigateur doivent voir la vraie
    // langue de la page, pas seulement une classe locale.
    document.documentElement.lang = isAr ? 'ar' : 'fr';
    document.documentElement.dir = isAr ? 'rtl' : 'ltr';
    const root = document.querySelector('section') as HTMLElement | null;
    if (root) {
      root.dir = isAr ? 'rtl' : 'ltr';
      root.style.lineHeight = isAr ? '1.75' : '';
    }
    const frBtn = $('mt-lang-fr');
    const arBtn = $('mt-lang-ar');
    frBtn?.setAttribute('aria-pressed', String(!isAr));
    arBtn?.setAttribute('aria-pressed', String(isAr));
    for (const [btn, on] of [[frBtn, !isAr], [arBtn, isAr]] as const) {
      if (!btn) continue;
      btn.className = on
        ? 'px-3 py-1.5 text-sm font-semibold text-azur-950 bg-brass-400 transition-colors'
        : 'px-3 py-1.5 text-sm font-semibold text-lune-soft transition-colors hover:text-white';
    }
  }
  prepareI18n();
  // WJ38 — cette route /ar/devis/mon-toit affiche l'arabe PAR DÉFAUT (l'URL
  // déclare déjà la langue) ; le sélecteur reste câblé pour un retour ponctuel
  // au FR, MÊME mécanisme dual-node que la route FR.
  applyLang('ar');
  $('mt-lang-fr')?.addEventListener('click', () => applyLang('fr'));
  $('mt-lang-ar')?.addEventListener('click', () => applyLang('ar'));

  // ——— WJ61 : l'état de l'assistant survit à un rafraîchissement/retour ———
  // Un appel téléphonique ou un balayage arrière accidentel détruisait TOUT ce
  // qui avait été tapé, en silence — l'échec UX le plus coûteux du tunnel. On
  // persiste un instantané minimal (étape/mode/facture/repère-contour/réponses
  // facultatives) dans sessionStorage (par onglet, jamais partagé entre
  // visiteurs) : réhydraté au chargement, effacé au succès. Ne bloque JAMAIS la
  // soumission si sessionStorage est indisponible (navigation privée stricte…).
  const WIZARD_STORAGE_KEY = 'mt-wizard-v1';
  interface WizardSnapshot {
    step?: number;
    mode?: string;
    ombrage?: string;
    futureLoads?: string[];
    capturePin?: { lat: number; lng: number } | null;
    captureOutline?: Array<[number, number]>;
    fields?: Record<string, string>;
    checks?: Record<string, boolean>;
  }
  const PERSISTED_TEXT_FIELDS = [
    'mt-name', 'mt-phone', 'mt-city', 'mt-email', 'mt-facture-hiver', 'mt-facture-ete',
    'mt-bill', 'mt-roof', 'mt-raccordement', 'mt-distributeur', 'mt-bill-kwh', 'mt-roof-age',
    'mt-occupant-type', 'mt-project-timing', 'mt-financing-intent', 'mt-fallback-address',
    'rp9-address',
  ];
  const PERSISTED_CHECK_FIELDS = ['mt-ete-differente', 'mt-contact-whatsapp', 'mt-contact-phone', 'mt-consent', 'mt-battery-interest'];
  let restoring = false; // WJ61 — évite de ré-enregistrer PENDANT la réhydratation elle-même.
  function saveWizardState() {
    if (restoring) return;
    try {
      const fields: Record<string, string> = {};
      for (const id of PERSISTED_TEXT_FIELDS) {
        const v = val(id);
        if (v) fields[id] = v;
      }
      const checks: Record<string, boolean> = {};
      for (const id of PERSISTED_CHECK_FIELDS) {
        const el = $(id) as HTMLInputElement | null;
        if (el) checks[id] = el.checked;
      }
      const snapshot: WizardSnapshot = {
        step, mode, ombrage,
        futureLoads: Array.from(futureLoads),
        capturePin, captureOutline,
        fields, checks,
      };
      sessionStorage.setItem(WIZARD_STORAGE_KEY, JSON.stringify(snapshot));
    } catch {
      // sessionStorage indisponible (navigation privée stricte, quota…) : la
      // persistance est un CONFORT, jamais un blocage de la saisie/l'envoi.
    }
  }
  function loadWizardState(): WizardSnapshot | null {
    try {
      const raw = sessionStorage.getItem(WIZARD_STORAGE_KEY);
      return raw ? (JSON.parse(raw) as WizardSnapshot) : null;
    } catch {
      return null;
    }
  }
  function clearWizardState() {
    try { sessionStorage.removeItem(WIZARD_STORAGE_KEY); } catch { /* confort seulement */ }
  }
  // WJ61 — garde-fou de sortie : une fois que le visiteur a commencé à saisir
  // quelque chose, un rafraîchissement/fermeture ACCIDENTEL affiche l'invite de
  // confirmation native du navigateur (texte non personnalisable par spec).
  let hasEnteredData = false;
  function markDataEntered() { hasEnteredData = true; }
  window.addEventListener('beforeunload', (e) => {
    if (!hasEnteredData || submitted) return;
    e.preventDefault();
    e.returnValue = '';
  });

  const savedWizard = loadWizardState();

  // ——— WJ6 : sélecteur de mode ———
  let mode = savedWizard?.mode || 'residentiel';
  document.querySelectorAll<HTMLButtonElement>('.mt-mode').forEach((btn) => {
    btn.addEventListener('click', () => {
      mode = btn.dataset.mode || 'residentiel';
      document.querySelectorAll<HTMLButtonElement>('.mt-mode').forEach((b) => {
        const on = b === btn;
        b.setAttribute('aria-pressed', String(on));
        b.classList.toggle('border-brass-400', on);
        b.classList.toggle('border-white/15', !on);
      });
      markDataEntered();
      saveWizardState();
    });
  });
  // état initial : marquer le mode sélectionné (réhydraté ou résidentiel par défaut).
  document.querySelectorAll<HTMLButtonElement>('.mt-mode').forEach((b) => {
    const on = (b.dataset.mode || 'residentiel') === mode;
    b.setAttribute('aria-pressed', String(on));
    b.classList.toggle('border-brass-400', on);
    b.classList.toggle('border-white/15', !on);
  });

  // ——— WJ31 : puce à bascule unique (ombrage) — un seul choix actif à la fois ———
  let ombrage = savedWizard?.ombrage || '';
  document.querySelectorAll<HTMLButtonElement>('.mt-ombrage').forEach((btn) => {
    btn.addEventListener('click', () => {
      const same = ombrage === btn.dataset.value;
      ombrage = same ? '' : (btn.dataset.value || '');
      document.querySelectorAll<HTMLButtonElement>('.mt-ombrage').forEach((b) => {
        const on = !same && b === btn;
        b.setAttribute('aria-pressed', String(on));
        b.classList.toggle('border-brass-400', on);
        b.classList.toggle('border-white/15', !on);
      });
      markDataEntered();
      saveWizardState();
    });
  });
  if (ombrage) {
    document.querySelectorAll<HTMLButtonElement>('.mt-ombrage').forEach((b) => {
      const on = b.dataset.value === ombrage;
      b.setAttribute('aria-pressed', String(on));
      b.classList.toggle('border-brass-400', on);
      b.classList.toggle('border-white/15', !on);
    });
  }

  // ——— WJ31 : puces multi-sélection (charges futures) ———
  const futureLoads = new Set<string>(savedWizard?.futureLoads ?? []);
  document.querySelectorAll<HTMLButtonElement>('.mt-future-load').forEach((btn) => {
    const preOn = futureLoads.has(btn.dataset.value || '');
    if (preOn) {
      btn.setAttribute('aria-pressed', 'true');
      btn.classList.add('border-brass-400');
      btn.classList.remove('border-white/15');
    }
    btn.addEventListener('click', () => {
      const v = btn.dataset.value || '';
      const on = !futureLoads.has(v);
      if (on) futureLoads.add(v); else futureLoads.delete(v);
      btn.setAttribute('aria-pressed', String(on));
      btn.classList.toggle('border-brass-400', on);
      btn.classList.toggle('border-white/15', !on);
      markDataEntered();
      saveWizardState();
    });
  });

  // ——— WJ31 : photo compteur/facture — capturée EN LOCAL, JAMAIS uploadée ———
  // Pas d'endpoint d'upload aujourd'hui (cf. PLAN2 QK6 OCR) : on garde un simple
  // signal booléen (hasMeterPhoto) et on encourage l'envoi direct sur WhatsApp.
  // WJ61 — non persisté : un fichier local ne survit pas à sessionStorage (ni ne
  // le devrait — aucune donnée binaire n'est sérialisée ici).
  let hasMeterPhoto = false;
  const meterPhotoInput = $('mt-meter-photo') as HTMLInputElement | null;
  meterPhotoInput?.addEventListener('change', () => {
    hasMeterPhoto = !!(meterPhotoInput.files && meterPhotoInput.files.length > 0);
  });

  // ——— WJ6 : assistant multi-étapes + barre de progression ———
  // WJ61 — l'étape initiale reprend l'instantané sessionStorage s'il existe
  // (rafraîchissement/retour en cours de parcours), sinon 0 comme avant.
  let step = savedWizard?.step != null ? Math.max(0, Math.min(2, savedWizard.step)) : 0;
  const panels = [0, 1, 2].map((i) => $(`mt-panel-${i}`));
  let firstRender = true;
  function renderStep() {
    panels.forEach((p, i) => { if (p) p.hidden = i !== step; });
    document.querySelectorAll<HTMLElement>('.mt-step').forEach((li, i) => {
      const bar = li.querySelector<HTMLElement>('.mt-step-bar');
      const label = li.querySelector<HTMLElement>('.mt-step-label');
      const active = i <= step;
      if (bar) bar.className = `h-1.5 w-full rounded-full mt-step-bar transition-colors ${active ? 'bg-brass-400' : 'bg-white/10'}`;
      if (label) label.classList.toggle('text-white', i === step);
    });
    // WJ61 — au tout premier rendu (chargement/réhydratation), ne pas imposer de
    // défilement : le visiteur vient d'arriver/de revenir, la page n'a pas
    // encore bougé sous lui. Le défilement reste pour chaque étape SUIVANTE.
    if (firstRender) { firstRender = false; return; }
    const root = document.querySelector('section');
    root?.scrollIntoView({ behavior: reducedMotion ? 'auto' : 'smooth', block: 'start' });
  }
  // WJ61 — pushState PAR ÉTAPE : le bouton précédent du navigateur recule d'une
  // étape de l'assistant au lieu de quitter carrément la page (l'échec le plus
  // fréquent d'un « retour » accidentel). `fromPopstate` évite de repousser un
  // état pendant qu'on réagit déjà à un `popstate`.
  function goStep(n: number, fromPopstate = false) {
    step = Math.max(0, Math.min(2, n));
    renderStep();
    saveWizardState();
    if (!fromPopstate) {
      history.pushState({ mtStep: step }, '', location.href);
    }
  }
  window.addEventListener('popstate', (e) => {
    const st = (e.state as { mtStep?: number } | null)?.mtStep;
    goStep(st != null ? st : Math.max(0, step - 1), true);
  });
  $('mt-next-0')?.addEventListener('click', () => goStep(1));
  $('mt-back-1')?.addEventListener('click', () => goStep(0));
  $('mt-back-2')?.addEventListener('click', () => goStep(1));
  // WJ61 — pose une première entrée d'historique dès le chargement pour que le
  // tout premier « retour » ait un état `mtStep` à consulter.
  history.replaceState({ mtStep: step }, '', location.href);
  renderStep();

  // ——— boot carte (captureOnly). Repli sans clé carte AUTORISE la suite (WJ4) ———
  let started = false;
  const mapEl = $('rp9-map');
  // WJ34 — retire le squelette de chargement dès que la carte annonce son
  // premier rendu (onReady) ou dès qu'on bascule sur le repli sans carte.
  function clearMapSkeleton() { mapEl?.classList.remove('mt-skeleton-shimmer'); }
  async function boot(key: string, mapboxToken: string) {
    if (started) return;
    started = true;
    try {
      // WJ47 — يستورد roofPro11/captureBoot مباشرة (وليس كل roof-tool-pro11.ts):
      // الإقلاع الكامل يجرّ scene3d/optimizer/matrix (Three.js + محرك التوضيب)،
      // وهو كود داخلي للأداة لا تُشغّله هذه الصفحة العامة للالتقاط أبداً. هذا
      // الجزء الكسول يحمّل الآن فقط MapLibre + محدد المواقع + العلامة/المحيط.
      const { bootCaptureOnly } = await import('../../../scripts/roofPro11/captureBoot');
      bootCaptureOnly({
        maptilerKey: key,
        mapboxToken: mapboxToken || undefined,
        reducedMotion,
        // WJ41 — رسائل الخريطة/محدد المواقع بالعربية (الافتراضي بالفرنسية). هذا
        // المسار يعرض العربية افتراضياً (applyLang('ar') عند التحميل).
        strings: ROOF_TOOL_STRINGS_AR,
        // WJ62 — هذا المسار يعرض العربية (RTL) افتراضياً: أدوات التحكم بالخريطة
        // (تكبير، تحديد الموقع) تنتقل إلى أعلى اليسار بدل تداخلها مع اتجاه
        // القراءة/أزرار اللغة في تلك الزاوية.
        dir: 'rtl',
        geolocateErrorMsg: 'تم رفض تحديد الموقع — ابحثوا عن عنوانكم أو ضعوا العلامة يدوياً.',
        onReady: clearMapSkeleton,
        // WJ61 — إعادة زرع علامة/محيط مستعادين من sessionStorage (تحديث الصفحة
        // أو زر الرجوع في المتصفح أثناء المسار) مباشرة عند إقلاع الخريطة، بنفس
        // آلية التغذية من عرض موجود مسبقاً (W113): لا يحتاج الزائر لإعادة وضع
        // العلامة.
        hydrate: capturePin
          ? { lead: { roof_point: capturePin, roof_outline: captureOutline.length >= 3 ? captureOutline : null } }
          : undefined,
        onCaptureChange: (s) => {
          capturePin = s.pin;
          captureOutline = s.outline;
          if (cityEl && !cityTouched) {
            const fromMap = (s.address && s.address.trim()) || addressEl?.value.trim() || '';
            if (fromMap) cityEl.value = fromMap;
          }
          // WJ2 — le contour peut arriver/changer APRÈS le calcul d'estimation :
          // on ré-évalue l'éligibilité du bouton « voir les panneaux » à chaque
          // changement de tracé (fonction déclarée plus bas, hissée par `function`).
          updatePanels3dVisibility();
        },
      });
    } catch {
      started = false;
      showFallback();
    }
  }
  // WJ4 — repli carte : on montre le champ d'adresse en clair ET on garde la suite ouverte.
  function showFallback() { if (fallback) fallback.hidden = false; clearMapSkeleton(); }

  // WJ60 — sur 3G lente, un fetch sans délai peut rester en attente indéfiniment
  // (l'UI restait bloquée sur le squelette de la carte). 10 s laisse largement le
  // temps à une connexion lente de répondre tout en bornant l'attente ; l'échec
  // (timeout inclus) tombe dans le repli adresse existant (WJ4), jamais un blocage.
  const FETCH_TIMEOUT_MS = 10_000;
  (async () => {
    try {
      const res = await fetch('/api/roof-config', { signal: AbortSignal.timeout(FETCH_TIMEOUT_MS) });
      const cfg = (await res.json()) as { available?: boolean; maptilerKey?: string; mapboxToken?: string };
      if (!cfg.available || !cfg.maptilerKey) { showFallback(); return; }
      void boot(cfg.maptilerKey, cfg.mapboxToken || '');
    } catch {
      showFallback();
    }
  })();

  // ——— helpers de saisie ———
  const val = (id: string) => (($(id) as HTMLInputElement | HTMLSelectElement | null)?.value ?? '');
  const num = (id: string): number | null => {
    const raw = val(id).trim();
    if (raw === '') return null;
    const n = Number(raw);
    return Number.isFinite(n) ? n : null;
  };

  // toggle été ≠ hiver
  const eteToggle = $('mt-ete-differente') as HTMLInputElement | null;
  const eteWrap = $('mt-facture-ete-wrap') as HTMLElement | null;
  const eteInput = $('mt-facture-ete') as HTMLInputElement | null;
  eteToggle?.addEventListener('change', () => {
    const on = eteToggle.checked === true;
    if (eteWrap) eteWrap.hidden = !on;
    if (!on && eteInput) eteInput.value = '';
  });

  // WJ61 — réhydratation des champs de saisie + du repère/contour de carte à
  // partir de l'instantané (AVANT le boot de la carte : `hydrate` plus bas sème
  // le pin/contour directement dans captureBoot, sans attendre un premier
  // clic). `restoring` empêche saveWizardState() de s'auto-déclencher pendant
  // qu'on peuple les champs (les événements `input`/`change` natifs se
  // déclenchent en JS lors d'une affectation `.value`/`.checked`).
  if (savedWizard) {
    restoring = true;
    for (const [id, v] of Object.entries(savedWizard.fields ?? {})) {
      const el = $(id) as HTMLInputElement | HTMLSelectElement | null;
      if (el) el.value = v;
    }
    for (const [id, v] of Object.entries(savedWizard.checks ?? {})) {
      const el = $(id) as HTMLInputElement | null;
      if (el) el.checked = v;
    }
    // WJ61 — une ville restaurée compte comme « déjà touchée » : affecter
    // `.value` par script ne déclenche pas l'événement `input` natif qui pose
    // normalement `cityTouched`, et sans ce garde-fou le prochain repère posé
    // sur la carte écraserait silencieusement la ville qu'on vient de restaurer.
    if (savedWizard.fields?.['mt-city']) cityTouched = true;
    if (eteToggle?.checked && eteWrap) eteWrap.hidden = false;
    if (savedWizard.capturePin) capturePin = savedWizard.capturePin;
    if (savedWizard.captureOutline?.length) captureOutline = savedWizard.captureOutline;
    if (Object.keys(savedWizard.fields ?? {}).length > 0 || savedWizard.capturePin) markDataEntered();
    restoring = false;
  }
  // WJ61 — persiste sur toute frappe/changement des champs texte/select/case à
  // cocher restants (au-delà des puces déjà câblées plus haut).
  const PERSIST_ON_INPUT_IDS = [...PERSISTED_TEXT_FIELDS, ...PERSISTED_CHECK_FIELDS];
  for (const id of PERSIST_ON_INPUT_IDS) {
    const el = $(id);
    el?.addEventListener('input', () => { markDataEntered(); saveWizardState(); });
    el?.addEventListener('change', () => { markDataEntered(); saveWizardState(); });
  }

  // ——— WJ1 : résoudre la facture mensuelle (montant exact prioritaire, sinon tranche) ———
  /** Milieu indicatif d'une tranche (MAD) — uniquement pour ESTIMER quand le montant
   *  exact est absent ; ne sert jamais au seuil (le seuil reste sur billRange/qualifies). */
  const RANGE_MIDPOINT: Record<string, number> = {
    'lt800': 600, '800-1000': 900, '1000-1500': 1250, '1500-3000': 2250,
    '3000-5000': 4000, '5000-10000': 7500, 'gt10000': 12000,
  };
  // WJ65 — plafond de bon sens sur la facture EXACTE saisie : au-delà, une faute
  // de frappe (ex. un zéro en trop) produirait un chiffre estimé avec la même
  // assurance qu'un vrai gros compte pro — on préfère demander de vérifier.
  // 200 000 MAD/mois est déjà bien au-delà des plus gros clients industriels
  // réels de Taqinor ; ne s'applique qu'au montant EXACT, jamais aux tranches.
  const MAX_BILL = 200_000;
  function resolveMonthlyBill(): number | null {
    const exact = num('mt-facture-hiver');
    if (exact != null && exact > 0) return exact;
    const range = val('mt-bill');
    if (range && RANGE_MIDPOINT[range] != null) return RANGE_MIDPOINT[range];
    return null;
  }

  // ——— WJ1 : calculer + afficher l'estimation instantanée ———
  let lastKwcLabel = '';
  let lastSavingsLabel = '';
  let lastKwc: number | null = null;
  function computeEstimate() {
    const exact = num('mt-facture-hiver');
    const bill = resolveMonthlyBill();
    const card = $('mt-estimate-body');
    const note = $('mt-estimate-note');
    const unavail = $('mt-estimate-unavailable');
    const toolarge = $('mt-estimate-toolarge');
    // WJ65 — montant exact au-delà du plafond : message honnête dédié (jamais un
    // chiffre confiant sur une saisie probablement erronée) + erreur inline sur
    // le champ concerné, sans jamais BLOQUER l'étape (le visiteur peut corriger
    // ou repartir sur une tranche).
    if (exact != null && exact > MAX_BILL) {
      if (card) card.hidden = true;
      if (note) note.hidden = true;
      if (unavail) unavail.hidden = true;
      if (toolarge) toolarge.hidden = false;
      setFieldError('mt-facture-hiver', 'mt-facture-hiver-err', currentLang === 'ar' ? 'تحقّقوا من المبلغ المُدخل.' : 'Vérifiez le montant saisi.');
      lastKwcLabel = '';
      lastSavingsLabel = '';
      lastKwc = null;
      updatePanels3dVisibility();
      return;
    }
    setFieldError('mt-facture-hiver', 'mt-facture-hiver-err', null);
    if (toolarge) toolarge.hidden = true;
    const lat = capturePin?.lat;
    const city = (val('mt-city') || addressEl?.value || '').trim() || undefined;
    const est = bill != null ? estimateFromBill(bill, { lat, city }) : null;
    if (!est) {
      if (card) card.hidden = true;
      if (note) note.hidden = true;
      if (unavail) unavail.hidden = false;
      lastKwcLabel = '';
      lastSavingsLabel = '';
      lastKwc = null;
      updatePanels3dVisibility();
      return;
    }
    if (card) card.hidden = false;
    if (note) note.hidden = false;
    if (unavail) unavail.hidden = true;
    const kwcEl = $('mt-est-kwc');
    const savEl = $('mt-est-savings');
    const payEl = $('mt-est-payback');
    if (kwcEl) kwcEl.textContent = String(est.kwc);
    const monthly = formatMadRange(est.savingsMonthlyLow, est.savingsMonthlyHigh);
    if (savEl) savEl.textContent = monthly;
    if (payEl) payEl.textContent = est.paybackLabel;
    lastKwcLabel = `${est.kwc} kWc`;
    lastSavingsLabel = `${monthly}/mois`;
    lastKwc = est.kwc;
    updatePanels3dVisibility();
  }
  // WJ34 — squelette bref pendant le calcul (performance perçue) : les 3
  // chiffres passent en squelette shimmer AVANT le calcul, puis
  // requestAnimationFrame laisse peindre ce squelette une fois avant de
  // révéler les vrais chiffres — sensation de « calcul », zéro CLS (mêmes
  // dimensions text-3xl), et prêt à absorber un futur calcul plus lourd
  // (PVGIS réseau) sans changement d'UX.
  function showEstimateSkeleton() {
    const card = $('mt-estimate-body');
    const unavail = $('mt-estimate-unavailable');
    const toolarge = $('mt-estimate-toolarge');
    if (unavail) unavail.hidden = true;
    if (toolarge) toolarge.hidden = true;
    if (card) card.hidden = false;
    for (const id of ['mt-est-kwc', 'mt-est-savings']) {
      const el = $(id);
      if (el) el.innerHTML = '<span class="mt-est-skeleton mt-skeleton-shimmer"></span>';
    }
    const payEl = $('mt-est-payback');
    if (payEl) payEl.innerHTML = '<span class="mt-est-skeleton mt-skeleton-shimmer"></span>';
  }
  $('mt-estimate')?.addEventListener('click', () => {
    showEstimateSkeleton();
    goStep(2);
    requestAnimationFrame(() => computeEstimate());
  });
  // recalcule à la volée si l'utilisateur revient corriger sa facture
  $('mt-facture-hiver')?.addEventListener('input', computeEstimate);
  $('mt-bill')?.addEventListener('change', computeEstimate);

  // ——— WJ2 : « voir les panneaux sur votre toit » — facultatif, lazy, dégrade
  // proprement (pas de WebGL / pas de contour tracé → le bloc reste masqué). ———
  const panels3dBlock = $('mt-panels3d') as HTMLElement | null;
  const panels3dStage = $('mt-panels3d-stage') as HTMLElement | null;
  const panels3dOverlay = $('mt-panels3d-overlay') as HTMLElement | null;
  const panels3dStart = $('mt-panels3d-start') as HTMLButtonElement | null;
  const panels3dHint = $('mt-panels3d-hint') as HTMLElement | null;
  let panels3dStarted = false;

  /** Le bouton n'apparaît QUE si un contour (≥3 sommets) a été tracé ET qu'un
   *  kWc est disponible — sinon rien de significatif à montrer (pas de faux
   *  aperçu sur un simple repère). */
  function updatePanels3dVisibility() {
    if (!panels3dBlock) return;
    const eligible = captureOutline.length >= 3 && lastKwc != null;
    panels3dBlock.hidden = !eligible;
  }

  async function startPanels3d() {
    if (panels3dStarted || !panels3dStage || lastKwc == null) return;
    panels3dStarted = true;
    try {
      const [{ capturePreviewLayout, buildViewerModel }, { createRoofViewer }] = await Promise.all([
        import('../../../lib/proposition'),
        import('../../../scripts/roofPro11/viewerOnly'),
      ]);
      const layout = capturePreviewLayout(captureOutline, lastKwc);
      const model = layout ? buildViewerModel(layout) : null;
      if (!model) throw new Error('modèle indisponible');
      const nav = navigator as Navigator & { deviceMemory?: number; connection?: { saveData?: boolean } };
      const lowEnd = (nav.deviceMemory != null && nav.deviceMemory <= 4) || (navigator.hardwareConcurrency || 8) <= 4;
      const handle = createRoofViewer(panels3dStage, model, {
        reducedMotion,
        lowEnd,
        onReady: () => {
          if (panels3dOverlay) panels3dOverlay.hidden = true;
          if (panels3dHint) panels3dHint.hidden = false;
        },
        onFail: () => { panels3dStarted = false; },
      });
      if (!handle) throw new Error('WebGL indisponible');
    } catch {
      // Repli gracieux : le bouton reste, avec un message sobre — jamais de blocage.
      panels3dStarted = false;
      if (panels3dOverlay) {
        const btn = panels3dStart;
        if (btn) {
          btn.disabled = true;
          btn.textContent = currentLang === 'ar' ? 'المعاينة ثلاثية الأبعاد غير متوفرة' : 'Aperçu 3D indisponible sur cet appareil';
        }
      }
    }
  }
  panels3dStart?.addEventListener('click', () => { void startPanels3d(); });

  // ——— WJ4 : validation INLINE alignée sur validateLead (avant le round-trip) ———
  function setFieldError(inputId: string, errId: string, message: string | null) {
    const input = $(inputId) as HTMLInputElement | null;
    const err = $(errId);
    if (input) input.setAttribute('aria-invalid', message ? 'true' : 'false');
    if (err) {
      err.textContent = message || '';
      err.hidden = !message;
    }
  }
  // ——— WJ52 : référence client courte, générée UNE FOIS côté navigateur ———
  // Stable sur des soumissions répétées (ex. échec réseau puis nouvel essai) :
  // générée à la première tentative, réutilisée telle quelle ensuite — jamais
  // régénérée en silence, jamais une clé d'unicité serveur (cf. lib/lead.ts).
  let clientRef = '';
  function getOrCreateClientRef(): string {
    if (!clientRef) clientRef = buildClientRef();
    return clientRef;
  }

  /** Construit le corps de lead + renvoie les erreurs client (miroir validateLead). */
  function buildBody(): { body: Record<string, unknown>; errors: Record<string, string> } {
    const eteDifferente = eteToggle?.checked === true;
    const consent = ($('mt-consent') as HTMLInputElement | null)?.checked === true;
    // WJ51 — préférence de contact EXPLICITE (radio « Uniquement WhatsApp » vs
    // « Un conseiller peut m'appeler ») : `whatsappOptIn` reste dérivé pour ne
    // rien casser côté CRM/webhook, `contactPreference` part en plus (mappé
    // sur le champ `canal`).
    const contactPreference = (($('mt-contact-phone') as HTMLInputElement | null)?.checked === true)
      ? 'phone_ok'
      : 'whatsapp_only';
    const whatsappOptIn = contactPreference === 'whatsapp_only';
    const adresse = (val('mt-city') || addressEl?.value.trim() || fallbackAddrEl?.value.trim() || '').trim();
    const body: Record<string, unknown> = {
      fullName: val('mt-name'),
      phone: val('mt-phone'),
      city: adresse,
      billRange: val('mt-bill'),
      roofType: val('mt-roof'),
      consent,
      whatsappOptIn,
      contactPreference,
      email: val('mt-email') || undefined,
      factureHiver: num('mt-facture-hiver'),
      factureEte: eteDifferente ? num('mt-facture-ete') : null,
      eteDifferente,
      raccordement: val('mt-raccordement'),
      adresse,
      // WJ30 — le type de projet et la langue active partent aussi au webhook.
      mode,
      langue_preferee: currentLang,
      // WJ31 — questions de capture élargies, TOUTES facultatives (déjà validées
      // une à une côté serveur : un champ vide/malformé est simplement écarté).
      distributeur: val('mt-distributeur') || undefined,
      billKwh: num('mt-bill-kwh'),
      ombrage: ombrage || undefined,
      roofAgeYears: num('mt-roof-age'),
      futureLoads: futureLoads.size > 0 ? Array.from(futureLoads) : undefined,
      batteryInterest: ($('mt-battery-interest') as HTMLInputElement | null)?.checked === true,
      occupantType: val('mt-occupant-type') || undefined,
      projectTiming: val('mt-project-timing') || undefined,
      financingIntent: val('mt-financing-intent') || undefined,
      hasMeterPhoto,
      // WJ52 — référence courte pour l'artefact post-soumission (échoée telle
      // quelle, jamais une clé d'unicité serveur — cf. lib/lead.ts).
      clientRef: getOrCreateClientRef(),
    };
    // WJ4 — repère FACULTATIF : on le joint s'il existe, on ne BLOQUE jamais sans lui.
    if (capturePin) {
      body.roofPoint = capturePin;
      body.gpsLat = capturePin.lat;
      body.gpsLng = capturePin.lng;
    }
    if (captureOutline.length >= 3) body.roofOutline = captureOutline;
    const v = validateLead(body);
    const errors: Record<string, string> = v.ok ? {} : { ...v.errors };
    // WJ65 — validateLead (lib/lead.ts, hors périmètre de cette page) n'exige
    // qu'une longueur ≥ 2 : un nom fait uniquement d'emojis/symboles (ex. « 😀😀 »)
    // passait donc silencieusement. On exige ICI au moins UNE lettre (tout
    // alphabet — \p{L} couvre le latin ET l'arabe) avant l'envoi.
    if (!errors.fullName && !/\p{L}/u.test(val('mt-name'))) {
      errors.fullName = currentLang === 'ar' ? 'الاسم الكامل مطلوب' : 'Nom complet requis';
    }
    return { body, errors };
  }

  function showInlineErrors(errors: Record<string, string>) {
    setFieldError('mt-name', 'mt-name-err', errors.fullName ?? null);
    setFieldError('mt-phone', 'mt-phone-err', errors.phone ?? null);
    setFieldError('mt-city', 'mt-city-err', errors.city ?? null);
    setFieldError('mt-roof', 'mt-roof-err', errors.roofType ?? null);
    setFieldError('mt-bill', 'mt-bill-err', errors.billRange ?? null);
    const cErr = $('mt-consent-err');
    if (cErr) { cErr.textContent = errors.consent ?? ''; cErr.hidden = !errors.consent; }
  }

  // ——— WJ3 : deeplink WhatsApp prérempli avec l'estimation ———
  function buildWaUrl(): string {
    const text = captureWhatsappText({
      fullName: val('mt-name'),
      city: (val('mt-city') || addressEl?.value || '').trim(),
      kwcLabel: lastKwcLabel || undefined,
      savingsLabel: lastSavingsLabel || undefined,
    });
    return whatsappLink(WHATSAPP_LEADS, text);
  }

  // ——— soumission → /api/capture-lead (contrat INCHANGÉ) ———
  const form = $('mt-form') as HTMLFormElement | null;
  const errEl = $('mt-error');
  const okEl = $('mt-success');
  const belowEl = $('mt-belowthreshold');
  const submitBtn = $('mt-submit') as HTMLButtonElement | null;
  const submitLabelEl = $('mt-submit-label');
  const submitPendingEl = $('mt-submit-pending');
  let submitted = false;

  // WJ60 — bascule le CTA sur « Envoi en cours… » pendant l'attente réseau (jamais
  // de bouton muet sur 3G lente) ; restaurée à la fin quel que soit le résultat
  // (sauf succès, où le formulaire entier se désactive juste après).
  function setSubmitPending(pending: boolean) {
    if (submitBtn) submitBtn.disabled = pending;
    if (submitLabelEl) submitLabelEl.hidden = pending;
    if (submitPendingEl) submitPendingEl.hidden = !pending;
  }

  // WJ63 — cette page bascule FR/عربي en direct (data-i18n) : les messages
  // d'erreur suivent désormais `currentLang` plutôt qu'un texte figé en arabe —
  // sinon un visiteur qui a basculé en FR verrait soudain de l'arabe à l'échec.
  function serverErrorMsg(): string {
    return currentLang === 'ar'
      ? 'مشكلة تقنية من جانبنا — يرجى إعادة المحاولة.'
      : 'Un problème technique de notre côté — réessayez.';
  }
  function fieldsHighlightedMsg(): string {
    return currentLang === 'ar' ? 'يرجى مراجعة الحقول المُبرزة أعلاه.' : 'Vérifiez les champs surlignés ci-dessus.';
  }
  function missingFieldMsg(): string {
    return currentLang === 'ar' ? 'حقل ناقص أو غير صالح. يرجى مراجعة معلوماتكم.' : 'Un champ est manquant ou invalide. Vérifiez vos informations.';
  }
  // WJ60 — 15 s laisse le temps à une connexion lente de répondre, sans
  // laisser le CTA « Envoi en cours… » indéfiniment (l'échec, timeout inclus,
  // retombe dans le message honnête ci-dessus — jamais un blocage silencieux).
  const SUBMIT_TIMEOUT_MS = 15_000;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (errEl) errEl.hidden = true;
    const { body, errors } = buildBody();
    if (Object.keys(errors).length > 0) {
      showInlineErrors(errors);
      if (errEl) {
        errEl.textContent = fieldsHighlightedMsg();
        errEl.hidden = false;
      }
      // amène l'utilisateur au premier champ en erreur
      const firstId = ['mt-name', 'mt-phone', 'mt-city', 'mt-roof', 'mt-bill']
        .find((id) => $(id)?.getAttribute('aria-invalid') === 'true');
      if (firstId) ($(firstId) as HTMLElement | null)?.focus();
      return;
    }
    showInlineErrors({});

    setSubmitPending(true);
    try {
      const res = await fetch('/api/capture-lead', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify(body),
        signal: AbortSignal.timeout(SUBMIT_TIMEOUT_MS),
      });
      // WJ60/WJ63 — une réponse JSON malformée (corps vide/illisible) est traitée
      // comme une panne serveur, jamais silencieusement comme « aucune erreur ».
      let malformed = false;
      const data = (await res.json().catch(() => {
        malformed = true;
        return {};
      })) as { ok?: boolean; qualified?: boolean; errors?: Record<string, string> };
      if (res.ok && !malformed && data.ok) {
        submitted = true;
        hasEnteredData = false; // WJ61 — succès : plus besoin du garde-fou beforeunload.
        clearWizardState(); // WJ61 — la demande a abouti : l'instantané n'a plus lieu d'être.
        const waUrl = buildWaUrl();
        // WJ5 — réponse HONNÊTE selon le seuil 1 000 MAD (qualified renvoyé par le serveur).
        if (data.qualified) {
          if (okEl) okEl.hidden = false;
          // WJ52 — affiche la référence générée dans buildBody() (déjà incluse
          // dans le body envoyé — on la relit ici via getOrCreateClientRef()
          // pour rester la MÊME valeur, jamais régénérée).
          const refEl = $('mt-client-ref');
          if (refEl) refEl.textContent = getOrCreateClientRef();
          const waLink = $('mt-success-wa') as HTMLAnchorElement | null;
          if (waLink) waLink.href = waUrl;
          // WJ3/WJ51 — sur mobile, on propose WhatsApp tout de suite quand la
          // préférence de contact est « Uniquement sur WhatsApp » (option cochée par défaut).
          const wantsWa = ($('mt-contact-phone') as HTMLInputElement | null)?.checked !== true;
          if (wantsWa && /Mobi|Android|iPhone/i.test(navigator.userAgent) && !reducedMotion) {
            setTimeout(() => { window.location.href = waUrl; }, 900);
          }
        } else {
          // sous le seuil : PAS de faux « enregistré » — message adapté + WhatsApp.
          if (belowEl) belowEl.hidden = false;
          const belowWa = $('mt-belowthreshold-wa') as HTMLAnchorElement | null;
          if (belowWa) belowWa.href = waUrl;
        }
        // désactive les champs après envoi (sauf les liens WhatsApp).
        Array.from(form.elements).forEach((el) => ((el as HTMLInputElement).disabled = true));
        return;
      }
      // WJ60/WJ63 — ≥500 ou JSON malformé : panne CÔTÉ SERVEUR, jamais un message
      // qui blâme les champs. Sous 500 avec des erreurs de champ exploitables
      // (4xx de validation), on les réaffiche inline comme avant — mais jamais un
      // texte serveur brut (ex. le 429 rate-limit) n'écrase notre copie honnête.
      const isServerError = malformed || res.status >= 500 || (!!data.errors && 'rate' in data.errors);
      if (!isServerError && data.errors) showInlineErrors(data.errors);
      const firstFieldErr = !isServerError && data.errors ? Object.values(data.errors)[0] : null;
      if (errEl) {
        errEl.textContent = isServerError ? serverErrorMsg() : (firstFieldErr || missingFieldMsg());
        errEl.hidden = false;
      }
      setSubmitPending(false);
    } catch {
      // WJ60 — englobe le timeout (AbortSignal.timeout) et toute coupure réseau :
      // même message honnête, jamais un blocage silencieux du CTA.
      if (errEl) {
        errEl.textContent = serverErrorMsg();
        errEl.hidden = false;
      }
      setSubmitPending(false);
    }
  });

  // ——— WJ7/WJ33 : récupération d'abandon (exit-intent desktop + retour/onglet caché mobile) ———
  const exitModal = $('mt-exit') as HTMLElement | null;
  const exitPhoneInput = $('mt-exit-phone') as HTMLInputElement | null;
  const exitWaLink = $('mt-exit-wa') as HTMLAnchorElement | null;
  let exitShown = false;
  let exitTriggerEl: HTMLElement | null = null; // WJ33 — pour restaurer le focus à la fermeture

  /** WJ33 — construit (ou reconstruit) le lien WhatsApp d'abandon depuis l'état actuel. */
  function buildExitWaHref(): string {
    const phone = exitPhoneInput?.value.trim() || '';
    const text = captureWhatsappText({
      fullName: '',
      city: (val('mt-city') || addressEl?.value || '').trim(),
      kwcLabel: lastKwcLabel || undefined,
      savingsLabel: lastSavingsLabel || undefined,
    }) + (phone.length >= 6 ? ` Mon numéro : ${phone}.` : '');
    return whatsappLink(WHATSAPP_LEADS, text);
  }

  function maybeShowExit(triggerEl: HTMLElement | null = null) {
    if (exitShown || submitted) return;
    // ne déranger que si l'utilisateur a au moins commencé (mode/facture ou step > 0)
    const started2 = step > 0 || resolveMonthlyBill() != null || (capturePin != null);
    if (!started2) return;
    exitShown = true;
    exitTriggerEl = triggerEl ?? (document.activeElement as HTMLElement | null);
    if (exitWaLink) exitWaLink.href = buildExitWaHref();
    if (exitModal) {
      exitModal.hidden = false;
      // WJ33 — focus initial DANS la modale (premier champ interactif).
      exitPhoneInput?.focus();
    }
  }
  function closeExit() {
    if (!exitModal || exitModal.hidden) return;
    exitModal.hidden = true;
    // WJ33 — restauration du focus vers l'élément qui a déclenché l'ouverture
    // (ou, à défaut, un point d'ancrage stable de la page).
    (exitTriggerEl && document.contains(exitTriggerEl) ? exitTriggerEl : $('mt-lang-fr'))?.focus();
    exitTriggerEl = null;
  }
  // desktop : la souris quitte par le haut
  document.addEventListener('mouseout', (e) => {
    if (!e.relatedTarget && (e as MouseEvent).clientY <= 0) maybeShowExit();
  });
  // mobile : l'onglet passe en arrière-plan
  document.addEventListener('visibilitychange', () => {
    if (document.visibilityState === 'hidden') maybeShowExit();
  });
  $('mt-exit-close')?.addEventListener('click', () => closeExit());
  exitModal?.addEventListener('click', (e) => { if (e.target === exitModal) closeExit(); });

  // WJ33 — clavier : Esc ferme + focus trap (Tab/Shift+Tab restent DANS la modale).
  exitModal?.addEventListener('keydown', (e) => {
    const ke = e as KeyboardEvent;
    if (ke.key === 'Escape') { closeExit(); return; }
    if (ke.key !== 'Tab' || !exitModal) return;
    const focusable = Array.from(
      exitModal.querySelectorAll<HTMLElement>('a[href], button:not([disabled]), input:not([disabled]), [tabindex]:not([tabindex="-1"])'),
    ).filter((el) => el.offsetParent !== null || el === document.activeElement);
    if (focusable.length === 0) return;
    const first = focusable[0];
    const last = focusable[focusable.length - 1];
    const active = document.activeElement as HTMLElement | null;
    if (ke.shiftKey && active === first) {
      ke.preventDefault();
      last.focus();
    } else if (!ke.shiftKey && active === last) {
      ke.preventDefault();
      first.focus();
    }
  });

  // WJ33 — le CTA WhatsApp d'abandon : le lien `href` est reconstruit à CHAQUE
  // saisie (pas seulement au clic), pour rester correct si l'utilisateur
  // ouvre WhatsApp via un clic droit / « copier le lien » avant de finir de taper.
  exitPhoneInput?.addEventListener('input', () => {
    const err = $('mt-exit-err');
    if (err) err.hidden = true;
    if (exitWaLink) exitWaLink.href = buildExitWaHref();
  });
  exitWaLink?.addEventListener('click', (e) => {
    const phone = exitPhoneInput?.value.trim() || '';
    const err = $('mt-exit-err');
    if (phone.length < 6) {
      e.preventDefault();
      // WJ63 — suit `currentLang` (bascule FR/عربي en direct) plutôt qu'un
      // texte figé en arabe.
      if (err) {
        err.textContent = currentLang === 'ar' ? 'يرجى إدخال رقم للرد عليكم.' : 'Indiquez un numéro pour qu\'on vous réponde.';
        err.hidden = false;
      }
      return;
    }
    if (err) err.hidden = true;
  });
</script>
