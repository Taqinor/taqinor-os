          <p class="mt-2 flex items-center justify-center gap-1.5 text-center text-xs text-lune-faint">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="flex-none text-ok-600">
              <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
            </svg>
            <span data-i18n data-fr="Réponse WhatsApp sous 1 h, 7j/7" data-ar="رد واتساب خلال ساعة واحدة، 7 أيام على 7">Réponse WhatsApp sous 1 h, 7j/7</span>
          </p>

          <div class="flex items-center justify-between gap-3">
            <button type="button" id="mt-back-2"
              class="inline-flex items-center gap-1 px-2 py-2 text-sm font-semibold text-lune-soft transition-colors hover:text-white">
              <svg aria-hidden="true" width="10" height="10" viewBox="0 0 10 10" fill="none">
