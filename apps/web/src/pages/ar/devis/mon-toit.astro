                <button type="button" class="mt-equipes cine-card border p-3 text-center text-sm text-white transition-colors" data-value="2x8" aria-pressed="false">2×8</button>
                <button type="button" class="mt-equipes cine-card border p-3 text-center text-sm text-white transition-colors" data-value="3x8" aria-pressed="false">3×8 متواصل</button>
                <button type="button" class="mt-equipes cine-card border p-3 text-center text-sm text-white transition-colors" data-value="continu" aria-pressed="false">متواصل 24/7</button>
              </div>
              <label class="mt-3 flex items-start gap-3 text-sm text-lune-soft">
                <input id="mt-weekend" name="weekend" type="checkbox" class="mt-1 h-5 w-5 flex-none accent-brass-400" />
                <span>إنتاج في عطلة نهاية الأسبوع أيضاً</span>
              </label>
              <p class="mt-2 text-xs text-lune-faint">
                الطاقة الشمسية تُزيح ساعاتكم المُمتلئة (~1.01 درهم/ك.و.س) ؛ ساعة الذروة
                لا تُغطّى إلا ببطارية — لا العكس أبداً. كلما أنتجتم ليلاً أكثر (3×8،
                متواصل)، غطّت الشمس وحدها أقل — تقدير صادق يُدقَّق بعد الدراسة.
              </p>
            </fieldset>

            <!-- WJ123 — معامل القدرة cos φ (اختياري) : معطى حقيقي لموقع جهد متوسط/صناعي. -->
            <label class="block text-sm text-lune-soft">
              <span>معامل القدرة cos φ (إن عُرف) — اختياري</span>
              <input id="mt-cos-phi" name="cosPhiConnu" type="number" step="any" inputmode="decimal"
                aria-describedby="mt-cos-phi-err" dir="ltr" placeholder="مثال: 0.92" class={`${inputClass} mt-1`} />
              <span id="mt-cos-phi-err" hidden role="alert" class="mt-1 block text-xs text-alert-300"></span>
            </label>

