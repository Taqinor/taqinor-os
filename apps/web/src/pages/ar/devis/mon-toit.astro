                <input id="mt-contact-whatsapp" name="contactPreference" type="radio" value="whatsapp_only" checked
                  class="h-4 w-4 flex-none accent-ok-600" />
                <span data-i18n data-fr="Uniquement sur WhatsApp" data-ar="فقط عبر واتساب">Uniquement sur WhatsApp</span>
              </label>
              <label class="mt-contact-pref cine-card flex cursor-pointer items-center gap-2 border border-white/15 p-3 text-sm text-white transition-colors has-[:checked]:border-brass-400">
                <input id="mt-contact-phone" name="contactPreference" type="radio" value="phone_ok"
                  class="h-4 w-4 flex-none accent-brass-400" />
                <span data-i18n data-fr="Un conseiller peut m'appeler" data-ar="يمكن لمستشار الاتصال بي">Un conseiller peut m'appeler</span>
              </label>
            </div>
            <!-- WJ105 — SLA concret, affiché UNIQUEMENT quand « Un conseiller peut m'appeler » est choisi. -->
            <p id="mt-callback-sla" hidden class="mt-2 flex items-center gap-1.5 text-xs text-brass-300" data-i18n
              data-fr="Un conseiller vous rappelle sous ~1 h ouvrée. Choisissez aussi un créneau préféré ci-dessous."
              data-ar="سيتصل بكم مستشار خلال حوالي ساعة عمل واحدة. اختاروا أيضاً الوقت المفضل أدناه.">
              Un conseiller vous rappelle sous ~1 h ouvrée. Choisissez aussi un créneau préféré ci-dessous.
            </p>
          </fieldset>

          <!-- W353/WJ105 — « Réserver un créneau de visite technique » v1 : préférence
               STATIQUE et FACULTATIVE (moment + semaine), forwardée telle quelle. -->
          <fieldset class="mt-1">
            <legend id="mt-visit-legend" class="text-sm text-lune-soft" data-i18n
              data-fr="Créneau de visite technique préféré (facultatif)"
              data-ar="الوقت المفضل للزيارة التقنية (اختياري)">
              Créneau de visite technique préféré (facultatif)
            </legend>
            <p id="mt-visit-help" class="mt-1 text-xs text-lune-faint" data-i18n
              data-fr="Une préférence, pas une réservation — nous confirmons le créneau exact avec vous."
              data-ar="تفضيل وليس حجزاً — سنؤكد الموعد الدقيق معكم.">
              Une préférence, pas une réservation — nous confirmons le créneau exact avec vous.
            </p>
            <div class="mt-2 grid grid-cols-2 gap-2">
              <button type="button" class="mt-visit-part cine-card border p-2.5 text-center text-sm text-white transition-colors" data-value="matin" aria-pressed="false" data-i18n data-fr="Matin" data-ar="صباحاً">Matin</button>
              <button type="button" class="mt-visit-part cine-card border p-2.5 text-center text-sm text-white transition-colors" data-value="apres_midi" aria-pressed="false" data-i18n data-fr="Après-midi" data-ar="بعد الظهر">Après-midi</button>
            </div>
            <div class="mt-2 grid grid-cols-2 gap-2">
              <button type="button" class="mt-visit-week cine-card border p-2.5 text-center text-sm text-white transition-colors" data-value="cette_semaine" aria-pressed="false" data-i18n data-fr="Cette semaine" data-ar="هذا الأسبوع">Cette semaine</button>
              <button type="button" class="mt-visit-week cine-card border p-2.5 text-center text-sm text-white transition-colors" data-value="semaine_prochaine" aria-pressed="false" data-i18n data-fr="La semaine prochaine" data-ar="الأسبوع المقبل">La semaine prochaine</button>
            </div>
          </fieldset>

          <label class="flex items-start gap-3 text-sm text-lune-soft">
            <input id="mt-consent" name="consent" type="checkbox" required aria-required="true"
              aria-describedby="mt-consent-err" class="mt-1 h-5 w-5 flex-none accent-brass-400" />
            <span data-i18n data-fr="J'accepte d'être recontacté(e) par Taqinor au sujet de mon projet solaire." data-ar="أوافق على أن تتواصل معي تاكينور بخصوص مشروعي الشمسي.">
              J'accepte d'être recontacté(e) par Taqinor au sujet de mon projet solaire.
            </span>
          </label>
          <span id="mt-consent-err" hidden role="alert" class="block text-xs text-alert-300"></span>

          <p id="mt-error" hidden class="text-sm text-alert-300" aria-live="polite"></p>

          <!-- WJ3 — CTA PRIMAIRE WhatsApp-first. WJ60 — libellé « Envoi en cours… ». -->
          <button type="submit" id="mt-submit"
            class="inline-flex w-full items-center justify-center gap-2 bg-ok-600 px-6 py-4 text-base font-bold text-white transition-opacity hover:opacity-90 disabled:cursor-not-allowed disabled:opacity-50">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true" class="flex-none"><path d="M.057 24l1.687-6.163a11.867 11.867 0 0 1-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.817 11.817 0 0 1 8.413 3.488 11.824 11.824 0 0 1 3.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 0 1-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 0 0 1.512 5.26l-.999 3.648 3.736-.979z"/></svg>
            <span id="mt-submit-label" data-i18n data-fr="Recevoir mon estimation sur WhatsApp" data-ar="استلام تقديري على واتساب">Recevoir mon estimation sur WhatsApp</span>
            <span id="mt-submit-pending" hidden data-i18n data-fr="Envoi en cours…" data-ar="جارٍ الإرسال…">Envoi en cours…</span>
          </button>

          <!-- WJ58 — promesse de délai honnête près de la CTA de capture (badge statique). -->
          <p class="mt-2 flex items-center justify-center gap-1.5 text-center text-xs text-lune-faint">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="flex-none text-ok-600">
              <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
            </svg>
            <span data-i18n data-fr="Réponse WhatsApp sous 1 h, 7j/7" data-ar="رد واتساب خلال ساعة واحدة، 7 أيام على 7">Réponse WhatsApp sous 1 h, 7j/7</span>
          </p>

          <div class="flex items-center justify-between gap-3">
            <button type="button" id="mt-back-2"
              class="inline-flex items-center gap-1 px-2 py-2 text-sm font-semibold text-lune-soft transition-colors hover:text-white">
              <svg aria-hidden="true" width="10" height="10" viewBox="0 0 10 10" fill="none">
                <polyline points="7,1 3,5 7,9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              <span data-i18n data-fr="Retour" data-ar="رجوع">Retour</span>
            </button>
          </div>

          <!-- WJ5 — succès qualifié (≥ 1 000 MAD : la demande atteint le CRM) -->
          <div id="mt-success" hidden class="border border-ok-600/40 bg-ok-600/10 p-4 text-sm text-white">
            <p class="font-semibold" data-i18n data-fr="Merci ! Votre demande est enregistrée." data-ar="شكراً! تم تسجيل طلبك.">Merci ! Votre demande est enregistrée.</p>
            <p class="mt-1 text-lune-soft" data-i18n data-fr="Notre équipe prépare votre étude et vous recontacte très vite — souvent sur WhatsApp." data-ar="فريقنا يُعدّ دراستك ويتواصل معك قريباً — غالباً عبر واتساب.">Notre équipe prépare votre étude et vous recontacte très vite — souvent sur WhatsApp.</p>
            <!-- WJ52 — référence courte : comble le vide post-soumission. -->
            <p class="mt-2 text-lune-soft">
              <span data-i18n data-fr="Votre référence :" data-ar="مرجعكم:">Votre référence&nbsp;:</span>
              {' '}<strong id="mt-client-ref" class="font-mono text-white" dir="ltr">—</strong>
              <br />
              <span class="text-xs" data-i18n
                data-fr="Mentionnez ce code sur WhatsApp pour retrouver votre dossier plus vite."
                data-ar="اذكروا هذا الرمز على واتساب لإيجاد ملفكم بسرعة أكبر.">
                Mentionnez ce code sur WhatsApp pour retrouver votre dossier plus vite.
              </span>
            </p>
            <a id="mt-success-wa" href="#" target="_blank" rel="noopener"
              class="mt-3 inline-flex items-center gap-2 bg-ok-600 px-4 py-2.5 text-sm font-bold text-white transition-opacity hover:opacity-90">
              <span data-i18n data-fr="Ouvrir WhatsApp maintenant" data-ar="افتح واتساب الآن">Ouvrir WhatsApp maintenant</span>
            </a>
          </div>

          <!-- WJ5 — chemin HONNÊTE sous le seuil 1 000 MAD (jamais un faux « enregistré ») -->
          <div id="mt-belowthreshold" hidden class="border border-brass-400/40 bg-brass-400/10 p-4 text-sm text-white">
            <p class="font-semibold" data-i18n data-fr="Le solaire n'est pas encore rentable à votre échelle." data-ar="الطاقة الشمسية ليست بعدُ مربحة على نطاقك.">Le solaire n'est pas encore rentable à votre échelle.</p>
            <p class="mt-1 text-lune-soft" data-i18n
              data-fr="En dessous de ~1 000 MAD/mois, l'investissement met trop longtemps à se rentabiliser pour qu'on vous le recommande honnêtement. Gardons le contact : dès que votre facture augmente, ou pour des conseils gratuits d'efficacité énergétique, écrivez-nous sur WhatsApp."
              data-ar="تحت ~1000 درهم/شهر، يستغرق الاستثمار وقتاً طويلاً ليصبح مربحاً بما يكفي لننصحك به بصدق. لنبقَ على تواصل: بمجرد ارتفاع فاتورتك، أو لنصائح مجانية حول كفاءة الطاقة، راسلنا على واتساب.">
              En dessous de ~1 000 MAD/mois, l'investissement met trop longtemps à se rentabiliser
              pour qu'on vous le recommande honnêtement. Gardons le contact : dès que votre facture
              augmente, ou pour des conseils gratuits d'efficacité énergétique, écrivez-nous sur
              WhatsApp.
            </p>
            <a id="mt-belowthreshold-wa" href="#" target="_blank" rel="noopener"
              class="mt-3 inline-flex items-center gap-2 bg-ok-600 px-4 py-2.5 text-sm font-bold text-white transition-opacity hover:opacity-90">
              <span data-i18n data-fr="Discuter sur WhatsApp" data-ar="الدردشة على واتساب">Discuter sur WhatsApp</span>
            </a>
          </div>
        </form>
      </div>
      <!-- ============ WJ8/WJ35 — CONFIANCE AU POINT DE CAPTURE ============ -->
      <aside class="mt-8 border-t border-white/10 pt-6">
        <!-- On NE FABRIQUE PAS de chiffre ni d'avis : faits vérifiables (loi 82-21,
             garanties constructeur standard, zone de service réelle) + compteur RÉEL. -->
        <div class="grid grid-cols-2 gap-3 sm:grid-cols-4">
          <div class="cine-card p-3 text-center">
            <p class="text-sm font-bold text-white" data-i18n data-fr="Conforme loi 82-21" data-ar="مطابق للقانون 82-21">Conforme loi 82-21</p>
            <p class="text-xs text-lune-faint" data-i18n data-fr="Autoproduction déclarée" data-ar="إنتاج ذاتي مُصرَّح">Autoproduction déclarée</p>
          </div>
          <div class="cine-card p-3 text-center">
            <p class="text-sm font-bold text-white" data-i18n data-fr="Garantie 25 ans" data-ar="ضمان 25 سنة">Garantie 25 ans</p>
            <p class="text-xs text-lune-faint" data-i18n data-fr="Panneaux (constructeur)" data-ar="الألواح (المُصنّع)">Panneaux (constructeur)</p>
          </div>
          <div class="cine-card p-3 text-center">
            <p class="text-sm font-bold text-white" data-i18n data-fr="Matériel certifié" data-ar="معدات معتمدة">Matériel certifié</p>
            <p class="text-xs text-lune-faint" dir="ltr">IEC 61215 / 61730</p>
          </div>
          <div class="cine-card p-3 text-center">
            <p class="text-sm font-bold text-white" data-i18n data-fr="Partout au Maroc" data-ar="في كل المغرب">Partout au Maroc</p>
            <p class="text-xs text-lune-faint" data-i18n data-fr="Étude locale" data-ar="دراسة محلية">Étude locale</p>
          </div>
        </div>

        <!-- WJ8 — villes desservies (réelles) -->
        <p class="mt-4 text-center text-xs text-lune-faint">
          <span data-i18n data-fr="Installations et études à" data-ar="تركيبات ودراسات في">Installations et études à</span>
          {' '}<span dir="ltr">{TOWNS.join(' · ')}</span>
        </p>

        <!-- QX — l'ancien scaffold #mt-install-photos (mort) est retiré. -->

        <!-- WJ35 — preuve sociale premium : compteur réel + note Google + certifications. -->
        <div class="mt-6 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
          <InstallCounter />
          <StarRating compact />
        </div>
        <div class="mt-5">
          <CertLogoRow />
        </div>
      </aside>

      <!-- WJ35 — signature zellige de clôture -->
      <ZelligeSignature
        line="كل رقم في هذه الصفحة مقيس، لا موعود."
        sub="تقديركم أولاً. الدراسة بعد ذلك."
      />
    </div>
  </section>

  <!-- ============ WJ7 — RÉCUPÉRATION D'ABANDON (exit-intent / sortie mobile) ============ -->
  <div id="mt-exit" hidden class="fixed inset-0 z-50 flex items-end justify-center bg-black/60 p-4 sm:items-center"
    style="padding-bottom: max(1rem, env(safe-area-inset-bottom));"
    role="dialog" aria-modal="true" aria-labelledby="mt-exit-title">
    <div class="cine-card w-full max-w-md border border-brass-400/40 p-5">
      <div class="flex items-start justify-between gap-3">
        <p id="mt-exit-title" class="display text-lg text-white" data-i18n data-fr="Recevez votre estimation sur WhatsApp" data-ar="استلم تقديرك على واتساب">Recevez votre estimation sur WhatsApp</p>
        <!-- WJ88/WA29 — cible tactile ≥44px pour fermer vite. -->
        <button type="button" id="mt-exit-close" aria-label="إغلاق"
          class="flex-none min-h-11 min-w-11 inline-flex items-center justify-center text-lune-faint hover:text-white">✕</button>
      </div>
      <p class="mt-2 text-sm text-lune-soft" data-i18n
        data-fr="Laissez juste votre numéro — on vous envoie votre estimation et on répond à vos questions. Gratuit, sans engagement."
        data-ar="اترك رقمك فقط — نرسل لك تقديرك ونجيب عن أسئلتك. مجاناً، بدون التزام.">
        Laissez juste votre numéro — on vous envoie votre estimation et on répond à vos
        questions. Gratuit, sans engagement.
      </p>
      <div class="mt-4 flex flex-col gap-2 sm:flex-row">
        <input id="mt-exit-phone" type="tel" inputmode="tel" autocomplete="tel"
          placeholder="06 XX XX XX XX" dir="ltr" class={inputClass} />
        <a id="mt-exit-wa" href="#" target="_blank" rel="noopener"
          class="inline-flex flex-none items-center justify-center gap-2 bg-ok-600 px-5 py-3 text-base font-bold text-white transition-opacity hover:opacity-90">
          <span data-i18n data-fr="Envoyer" data-ar="إرسال">Envoyer</span>
        </a>
      </div>
      <p id="mt-exit-err" hidden class="mt-2 text-xs text-alert-300" aria-live="polite"></p>
    </div>
  </div>
</Layout>

<style>
  /* WJ2 — boîte à hauteur RÉSERVÉE (zéro CLS). QX — fond « ciel de jour ». */
  .mt-panels3d-stage {
    height: 320px;
    background: linear-gradient(180deg, #b9d7ee 0%, #dcebf7 55%, #f2ecdf 100%);
  }
  @media (min-width: 640px) {
    .mt-panels3d-stage {
      height: 380px;
    }
  }

  /* ===== WJ34 — squelettes de performance perçue (zéro CLS). ===== */
  .mt-skeleton-shimmer {
    background-image: linear-gradient(
      100deg,
      transparent 30%,
      rgb(255 255 255 / 0.06) 50%,
      transparent 70%
    );
    background-size: 200% 100%;
  }
  @media (prefers-reduced-motion: no-preference) {
    .mt-skeleton-shimmer {
      animation: mt-shimmer 1.6s ease-in-out infinite;
    }
  }
  @keyframes mt-shimmer {
    from { background-position: 200% 0; }
    to { background-position: -200% 0; }
  }

  .mt-est-skeleton {
    display: inline-block;
    height: 2.25rem;
    width: 4.5rem;
    border-radius: 0.25rem;
    background: rgb(255 255 255 / 0.08);
    vertical-align: middle;
  }

  @media (prefers-reduced-motion: no-preference) {
    .mt-thinking-dot {
      animation: mt-thinking-pulse 1s ease-in-out infinite;
    }
  }
  @keyframes mt-thinking-pulse {
    0%, 100% { opacity: 0.35; transform: scale(0.85); }
    50% { opacity: 1; transform: scale(1); }
  }

  /* ===== WJ125 — carte teaser verrouillée. Le flou n'est qu'un habillage : les
     barres/graphe ci-dessous ne contiennent AUCUN chiffre (le vrai masquage des
     valeurs se fait côté JS — les zones chiffrées ne sont jamais peuplées dans le
     parcours public). ===== */
  .mt-teaser-preview {
    filter: blur(7px);
    opacity: 0.4;
    pointer-events: none;
    user-select: none;
  }
  .mt-teaser-kpis {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem;
  }
  .mt-teaser-bar {
    display: block;
    height: 2.5rem;
    border-radius: 0.375rem;
    background: rgb(255 255 255 / 0.12);
  }
  .mt-teaser-chart {
    margin-top: 0.75rem;
    height: 4.5rem;
    border-radius: 0.375rem;
    background: repeating-linear-gradient(
      90deg,
      rgb(255 255 255 / 0.12) 0 14px,
      transparent 14px 26px
    );
  }
  .mt-teaser-lock {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    padding: 1rem;
    text-align: center;
    background: rgb(10 15 26 / 0.55);
  }
  .mt-teaser-lock-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 9999px;
    border: 1px solid var(--color-brass-400, #f5a623);
    color: var(--color-brass-300, #f7c66a);
  }
  .mt-teaser-hook {
    font-size: 0.95rem;
    font-weight: 600;
    color: #ffffff;
    max-width: 30ch;
  }
  .mt-teaser-headline {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-brass-300, #f7c66a);
  }
  .mt-teaser-sub {
    font-size: 0.8rem;
    color: var(--color-lune-soft, #c7cdd6);
    max-width: 34ch;
  }
</style>

<!-- ===== QX — LE DOCUMENT D'ESTIMATION : styles GLOBAUX (is:global). Tokens = le
     thème RÉEL du moteur premium : navy #1A2B4A, or #F5A623, vert #16A34A. Polices :
     DM Serif Display + DM Sans — les MÊMES woff2 que le PDF. AR : le document hérite
     `dir=rtl` du document ; propriétés logiques (border-inline-start, text-align:end)
     et valeurs numériques isolées `direction:ltr` pour lire correctement en RTL. ===== -->
<style is:global>
  @font-face {
    font-family: 'DM Serif Display';
    src: url('/fonts/dm-serif-display-400.woff2') format('woff2');
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }
  @font-face {
    font-family: 'DM Sans';
    src: url('/fonts/dm-sans-400.woff2') format('woff2');
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }
  @font-face {
    font-family: 'DM Sans';
    src: url('/fonts/dm-sans-700.woff2') format('woff2');
    font-weight: 700;
    font-style: normal;
    font-display: swap;
  }

  .mt-doc {
    max-width: 800px;
    margin-inline: auto;
    background: #ffffff;
    color: #1f2937;
    font-family: 'DM Sans', 'Hanken Grotesk', system-ui, sans-serif;
    font-size: 13.5px;
    line-height: 1.55;
    border-radius: 6px;
    overflow: hidden;
    box-shadow: 0 1px 3px rgb(0 0 0 / 0.4), 0 14px 44px rgb(0 0 0 / 0.5);
  }
  .mt-doc-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 16px;
    background: #1a2b4a;
    border-bottom: 2.5px solid #f5a623;
    padding: 20px 26px 16px;
  }
  .mt-doc-title {
    font-family: 'DM Serif Display', Georgia, serif;
    font-size: 25px;
    line-height: 1.15;
    color: #ffffff;
    margin-top: 8px;
  }
  .mt-doc-subtitle {
    color: #f5a623;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    margin-top: 2px;
  }
  .mt-doc-headmeta {
    text-align: end;
    font-size: 10.5px;
    color: #cdd5e2;
    line-height: 1.7;
    flex: none;
  }
  .mt-doc-body {
    padding: 20px 26px 24px;
    display: grid;
    gap: 16px;
  }
  .mt-doc-meta {
    font-size: 12px;
    color: #6b7280;
    border-bottom: 1px solid #eff1f4;
    padding-bottom: 10px;
  }
  .mt-doc-roof {
    justify-self: start;
  }
  .mt-doc-roof img {
    width: 180px;
    height: 180px;
    max-width: 100%;
    object-fit: cover;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
  }
  .mt-doc-roof figcaption {
    font-size: 10px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #9ba3ae;
