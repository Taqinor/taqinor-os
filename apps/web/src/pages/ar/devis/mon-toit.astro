        <!-- ===== QX — SOUS-PANNEAU PROFESSIONNEL : énergie du site, raccordement
             BT/MT, profil d'activité, surface & contexte facultatifs. ===== -->
        <div id="mt-sub-professionnel" hidden>
          <p class="mt-6 text-lune-soft">
            أخبرونا عن طاقة موقعكم — جوابان يكفيان لتقدير أولي، والباقي يحسّنه.
          </p>

          <div class="cine-card mt-5 space-y-5 p-5 sm:p-6">
            <!-- (a) Facture mensuelle — bascule MAD ⇄ kWh, UN seul champ -->
            <div>
              <p class="text-sm text-lune-soft">استهلاككم الشهري</p>
              <div class="mt-2 grid grid-cols-2 gap-2" role="group" aria-label="وحدة الاستهلاك">
                <button type="button" id="mt-pro-unit-mad" class="mt-pro-unit cine-card border p-2.5 text-center text-sm text-white transition-colors" data-value="mad" aria-pressed="true">درهم / شهر</button>
                <button type="button" id="mt-pro-unit-kwh" class="mt-pro-unit cine-card border p-2.5 text-center text-sm text-white transition-colors" data-value="kwh" aria-pressed="false">kWh / شهر</button>
