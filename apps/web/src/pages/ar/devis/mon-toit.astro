      if (note) note.hidden = true;
      setFieldError('mt-facture-hiver', 'mt-facture-hiver-err', null);
      return computeProEstimate();
    }
    // ——— RÉSIDENTIEL (défaut) — moteur billEstimate inchangé (WJ1/WJ112) ———
    if (exact != null && exact > maxBillFor('residentiel')) {
      if (card) card.hidden = true;
      if (note) note.hidden = true;
      if (unavail) unavail.hidden = true;
      if (toolarge) toolarge.hidden = false;
      setFieldError('mt-facture-hiver', 'mt-facture-hiver-err', 'تحققوا من المبلغ المُدخَل.');
      lastKwcLabel = '';
      lastSavingsLabel = '';
      lastKwc = null;
      estimateShown = null;
      if (printBtn) printBtn.hidden = true;
      fillDocChrome();
      updatePanels3dVisibility();
      announceEstimate('التقدير غير متوفر — تحققوا من المبلغ المُدخَل.');
      return false;
    }
    setFieldError('mt-facture-hiver', 'mt-facture-hiver-err', null);
    if (toolarge) toolarge.hidden = true;
    const lat = capturePin?.lat;
    const city = (val('mt-city') || addressEl?.value || '').trim() || undefined;
    const exactKwhMonthly = num('mt-bill-kwh') ?? undefined;
    const est = bill != null ? estimateFromBill(bill, { lat, city, exactKwhMonthly, ombrage: ombrage || undefined }) : null;
    if (!est) {
      if (card) card.hidden = true;
      if (note) note.hidden = true;
      if (unavail) unavail.hidden = false;
      lastKwcLabel = '';
      lastSavingsLabel = '';
      lastKwc = null;
      estimateShown = null;
      if (printBtn) printBtn.hidden = true;
      fillDocChrome();
      updatePanels3dVisibility();
      announceEstimate('التقدير غير متوفر: أدخلوا فاتورتكم الشهرية لحسابه.');
      return false;
    }
    // WJ125 — chiffres calculés (payload lead) + labels (deeplink WhatsApp / CRM),
    // construits AVANT tout rendu ; puis, en parcours public gaté, on s'arrête ici
    // SANS écrire le moindre chiffre à l'écran (la carte teaser est déjà affichée).
    lastKwc = est.kwc;
    lastKwcLabel = `${formatKwc(est.kwc)} kWc`;
    lastSavingsLabel = `${formatMadRange(est.savingsMonthlyLow, est.savingsMonthlyHigh)}/mois`;
    estimateShown = {
      kwc: est.kwc,
      prodKwh: est.productionKwhYr,
      ecoMadMonthLow: est.savingsMonthlyLow,
      ecoMadMonthHigh: est.savingsMonthlyHigh,
      paybackLabel: est.paybackLabel,
    };
    if (hasReachedConsentStep()) sendFunnelBeacon('estimation', 'viewed');
    if (PUBLIC_ESTIMATE_GATED) {
      updatePanels3dVisibility();
      if (hasReachedConsentStep()) sendFunnelBeacon('contact', 'reached');
      announceEstimate(GATED_ANNOUNCE);
      return true;
    }
    if (card) card.hidden = false;
    if (note) note.hidden = false;
    {
      const hypWrap = $('mt-doc-hypo-wrap');
      if (hypWrap) hypWrap.hidden = false;
      const hypDyn = $('mt-doc-hypotheses');
      if (hypDyn) hypDyn.hidden = true;
    }
    if (unavail) unavail.hidden = true;
    if (hasReachedConsentStep()) sendFunnelBeacon('estimation', 'viewed');
    const kwcEl = $('mt-est-kwc');
    const savEl = $('mt-est-savings');
    const payEl = $('mt-est-payback');
    if (kwcEl) kwcEl.textContent = formatKwc(est.kwc);
    setText('mt-est-prod', formatMad(est.productionKwhYr));
    const monthly = formatMadRange(est.savingsMonthlyLow, est.savingsMonthlyHigh);
    if (savEl) savEl.textContent = monthly;
    if (payEl) payEl.textContent = est.paybackLabel;
    lastKwcLabel = `${formatKwc(est.kwc)} kWc`;
    lastSavingsLabel = `${monthly}/شهر`;
    lastKwc = est.kwc;
    if (climateBandEl) {
      const climateBandValueEl = $('mt-climate-band-value');
      const showBand = est.savingsLowBand < est.savingsHigh;
      climateBandEl.hidden = !showBand;
      if (showBand && climateBandValueEl) {
        climateBandValueEl.textContent = formatMadRange(est.savingsLowBand, est.savingsLowBand);
      }
    }
    estimateShown = {
      kwc: est.kwc,
      prodKwh: est.productionKwhYr,
      ecoMadMonthLow: est.savingsMonthlyLow,
      ecoMadMonthHigh: est.savingsMonthlyHigh,
      paybackLabel: est.paybackLabel,
    };
    const nearestEl = $('mt-nearest-install');
    if (nearestEl && capturePin) {
      const near = nearestRealisation(capturePin.lat, capturePin.lng);
      if (near) {
        const { realisation: r, distanceKm } = near;
        const textEl = $('mt-nearest-install-text');
        const linkEl = $('mt-nearest-install-link') as HTMLAnchorElement | null;
        const km = Math.round(distanceKm);
        if (textEl) textEl.textContent = `${r.ville} — ${r.kwc} — على بعد حوالي ${km} كلم منكم`;
        if (linkEl) linkEl.href = `/realisations/${r.slug}`;
        nearestEl.hidden = false;
      } else {
        nearestEl.hidden = true;
      }
    } else if (nearestEl) {
      nearestEl.hidden = true;
    }
    if (cowEl) {
      const costEl = $('mt-cost-of-waiting-value');
      if (costEl) costEl.textContent = `${formatMad(est.savingsMonthlyLow)} MAD`;
      cowEl.hidden = est.savingsMonthlyLow <= 0;
    }
    renderMonthlyChart(est.productionKwhYr);
    if (printBtn) printBtn.hidden = false;
    fillDocChrome();
    updatePanels3dVisibility();
    if (hasReachedConsentStep()) sendFunnelBeacon('contact', 'reached');
    announceEstimate(`تقديركم: ${formatKwc(est.kwc)} kWc، توفير مقدَّر ${monthly}/شهر، استرداد التكلفة ${est.paybackLabel}.`);
    return true;
  }
  // WJ34 — squelette bref pendant le calcul (performance perçue).
  function showEstimateSkeleton() {
    if (mode && mode !== 'residentiel') return;
    const card = $('mt-estimate-body');
    const unavail = $('mt-estimate-unavailable');
    const toolarge = $('mt-estimate-toolarge');
    if (unavail) unavail.hidden = true;
    if (toolarge) toolarge.hidden = true;
    if (card) card.hidden = false;
    for (const id of ['mt-est-kwc', 'mt-est-prod', 'mt-est-savings']) {
      const el = $(id);
      if (el) el.innerHTML = '<span class="mt-est-skeleton mt-skeleton-shimmer"></span>';
    }
    const payEl = $('mt-est-payback');
    if (payEl) payEl.innerHTML = '<span class="mt-est-skeleton mt-skeleton-shimmer"></span>';
  }
  // WJ48/WJ112 — anticipation BRANDÉE, ≤500 ms (reduced-motion → instantané).
  const THINKING_MIN_MS = 250;
  const THINKING_MAX_MS = 450;
  function thinkingDelayMs(): number {
    if (reducedMotion) return 0;
    return THINKING_MIN_MS + Math.random() * (THINKING_MAX_MS - THINKING_MIN_MS);
  }
  $('mt-estimate')?.addEventListener('click', (e) => {
    if (!validateStep1()) return;
    showEstimateSkeleton();
    const thinkingEl = $('mt-estimate-thinking');
    if (thinkingEl) thinkingEl.hidden = false;
    goStep(2);
    const triggerEl = e.currentTarget as HTMLElement | null;
    requestAnimationFrame(() => {
      setTimeout(() => {
        if (thinkingEl) thinkingEl.hidden = true;
        const hasEstimate = computeEstimate();
        // QX — miroir du fix FR : le document doit RESPIRER 12 s avant l'offre
        // WhatsApp automatique, et un visiteur déjà engagé (formulaire/print)
        // n'est jamais interrompu — l'exit-intent reste actif.
        if (hasEstimate) {
          setTimeout(() => {
            if (!docEngaged) showWhatsappOffer(triggerEl);
          }, 12_000);
        }
      }, thinkingDelayMs());
    });
  });
  // QX — « engagé » : le visiteur remplit le formulaire ou imprime — l'offre
  // WhatsApp automatique ne l'interrompt jamais (miroir du fix FR).
  let docEngaged = false;
  $('mt-form')?.addEventListener('focusin', () => { docEngaged = true; });
  $('mt-print-estimate')?.addEventListener('click', () => { docEngaged = true; }, { capture: true });
  // recalcule à la volée si l'utilisateur revient corriger sa facture.
  $('mt-facture-hiver')?.addEventListener('input', () => {
    syncBillRangeFromExact();
    computeEstimate();
  });
  $('mt-bill')?.addEventListener('change', computeEstimate);
  $('mt-bill-kwh')?.addEventListener('input', computeEstimate);
  // ——— WJ2 : « voir les panneaux sur votre toit » — facultatif, lazy. ———
  const panels3dBlock = $('mt-panels3d') as HTMLElement | null;
  const panels3dStage = $('mt-panels3d-stage') as HTMLElement | null;
  const panels3dOverlay = $('mt-panels3d-overlay') as HTMLElement | null;
  const panels3dStart = $('mt-panels3d-start') as HTMLButtonElement | null;
  const panels3dHint = $('mt-panels3d-hint') as HTMLElement | null;
  let panels3dStarted = false;

  function updatePanels3dVisibility() {
    if (!panels3dBlock) return;
    // WJ125 — la scène 3D dessine EXACTEMENT le nombre de panneaux
    // (nb × 720 Wc = kWc), valeur dimensionnante interdite avant l'envoi du
    // lien par la règle anti-concurrent. Parcours public gaté → bloc masqué ;
    // l'aperçu dimensionné vit sur /proposition/<token>. Drapeau OFF (futur) →
    // comportement byte-identique.
    if (PUBLIC_ESTIMATE_GATED) { panels3dBlock.hidden = true; return; }
    const eligible = captureOutline.length >= 3 && lastKwc != null;
    panels3dBlock.hidden = !eligible;
  }

  async function startPanels3d() {
    if (panels3dStarted || !panels3dStage || lastKwc == null) return;
    panels3dStarted = true;
    try {
      const [{ capturePreviewLayout, buildViewerModel }, { createRoofViewer }] = await Promise.all([
        import('../../../lib/proposition'),
        import('../../../scripts/roofPro11/viewerOnly'),
      ]);
      const layout = capturePreviewLayout(captureOutline, lastKwc);
      const model = layout ? buildViewerModel(layout) : null;
      if (!model) throw new Error('modèle indisponible');
      const roofImage = await fetchRoofImageSpec().catch(() => null);
      const nav = navigator as Navigator & { deviceMemory?: number; connection?: { saveData?: boolean } };
      const lowEnd = (nav.deviceMemory != null && nav.deviceMemory <= 4) || (navigator.hardwareConcurrency || 8) <= 4;
      const handle = createRoofViewer(panels3dStage, model, {
        reducedMotion,
        lowEnd,
        roofImage,
        onReady: () => {
          if (panels3dOverlay) panels3dOverlay.hidden = true;
          if (panels3dHint) panels3dHint.hidden = false;
        },
        onFail: () => { panels3dStarted = false; },
      });
      if (!handle) throw new Error('WebGL indisponible');
    } catch {
      panels3dStarted = false;
      if (panels3dOverlay) {
        const btn = panels3dStart;
        if (btn) {
          btn.disabled = true;
          btn.textContent = currentLang === 'ar' ? 'المعاينة ثلاثية الأبعاد غير متوفرة' : 'Aperçu 3D indisponible sur cet appareil';
        }
      }
    }
  }
  panels3dStart?.addEventListener('click', () => { void startPanels3d(); });

  // ——— QX : « Imprimer / Enregistrer en PDF » — le document s'imprime tel quel. ———
  $('mt-print-estimate')?.addEventListener('click', () => {
    window.print();
  });

  // ——— WJ4 : validation INLINE alignée sur validateLead (avant le round-trip) ———
  function setFieldError(inputId: string, errId: string, message: string | null) {
    const input = $(inputId) as HTMLInputElement | null;
    const err = $(errId);
    if (input) input.setAttribute('aria-invalid', message ? 'true' : 'false');
    if (err) {
      err.textContent = message || '';
      err.hidden = !message;
    }
  }

  // ——— QX : VALIDATION EN DIRECT (blur par champ + « Continuer » valide son étape). ———
  function scrollToInvalid(el: HTMLElement | null) {
    if (!el) return;
    el.scrollIntoView({ behavior: reducedMotion ? 'auto' : 'smooth', block: 'center' });
    if (typeof el.focus === 'function') el.focus({ preventScroll: true });
  }
  /** Champ numérique FACULTATIF : vide = OK ; non-numérique ou négatif = erreur. */
  function checkOptionalNumber(id: string, label: string): boolean {
    const raw = val(id).trim();
    if (raw === '') {
      setFieldError(id, `${id}-err`, null);
      return true;
    }
    const n = num(id);
    if (n == null || n < 0) {
      setFieldError(id, `${id}-err`, `${label}: أرقام فقط.`);
      return false;
    }
    setFieldError(id, `${id}-err`, null);
    return true;
  }
  const OPTIONAL_NUMBER_FIELDS: Array<[string, string]> = [
    ['mt-puissance-kva', 'القدرة المكتتبة'],
    ['mt-surface-m2', 'المساحة'],
    ['mt-profondeur', 'العمق'],
    ['mt-hmt', 'HMT'],
    ['mt-water-need', 'الحاجة إلى الماء'],
    ['mt-surface-ha', 'المساحة'],
    ['mt-pompe-cv', 'القدرة (CV)'],
    ['mt-fuel-spend', 'نفقة الوقود'],
  ];
  for (const [id, label] of OPTIONAL_NUMBER_FIELDS) {
    $(id)?.addEventListener('blur', () => {
      checkOptionalNumber(id, label);
    });
  }
  /** Facture exacte résidentielle au blur : format + plafond de bon sens. */
  function checkFactureHiver(): boolean {
    const raw = val('mt-facture-hiver').trim();
    if (raw === '') {
      setFieldError('mt-facture-hiver', 'mt-facture-hiver-err', null);
      return true;
    }
    const n = num('mt-facture-hiver');
    if (n == null || n <= 0) {
      setFieldError('mt-facture-hiver', 'mt-facture-hiver-err', 'مبلغ غير صالح — أرقام فقط.');
      return false;
    }
    if (n > maxBillFor('residentiel')) {
      setFieldError('mt-facture-hiver', 'mt-facture-hiver-err', 'تحققوا من المبلغ المُدخَل.');
      return true;
    }
    setFieldError('mt-facture-hiver', 'mt-facture-hiver-err', null);
    return true;
  }
  $('mt-facture-hiver')?.addEventListener('blur', () => {
    checkFactureHiver();
  });
  $('mt-pro-bill')?.addEventListener('blur', () => {
    const raw = val('mt-pro-bill').trim();
    if (raw === '') {
      setFieldError('mt-pro-bill', 'mt-pro-bill-err', null);
      return;
    }
    const n = num('mt-pro-bill');
    setFieldError('mt-pro-bill', 'mt-pro-bill-err', n == null || n <= 0 ? 'مبلغ غير صالح — أرقام فقط.' : null);
  });
  // WJ122 — même validation légère de perte de focus pour la facture COMMERCIALE.
  $('mt-cc-bill')?.addEventListener('blur', () => {
    const raw = val('mt-cc-bill').trim();
    if (raw === '') {
      setFieldError('mt-cc-bill', 'mt-cc-bill-err', null);
      return;
    }
    const n = num('mt-cc-bill');
    setFieldError('mt-cc-bill', 'mt-cc-bill-err', n == null || n <= 0 ? 'مبلغ غير صالح — أرقام فقط.' : null);
  });
  // Contact : chaque champ se valide dès la perte de focus (miroir léger de validateLead).
  $('mt-name')?.addEventListener('blur', () => {
    const v = val('mt-name').trim();
    setFieldError('mt-name', 'mt-name-err', v !== '' && (v.length < 2 || !/\p{L}/u.test(v)) ? 'الاسم الكامل مطلوب' : null);
  });
  $('mt-phone')?.addEventListener('blur', () => {
    const digits = val('mt-phone').replace(/\D/g, '');
    setFieldError('mt-phone', 'mt-phone-err', val('mt-phone').trim() !== '' && digits.length < 9 ? 'رقم هاتف غير صالح' : null);
  });
  $('mt-city')?.addEventListener('blur', () => {
    const v = val('mt-city').trim();
    setFieldError('mt-city', 'mt-city-err', v !== '' && v.length < 2 ? 'العنوان / المدينة مطلوب' : null);
