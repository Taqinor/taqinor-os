  const fallbackAddrEl = $('mt-fallback-address') as HTMLInputElement | null;

  // ——— WJ59 : beacon de funnel étape par étape (privacy-light, aucune PII) ———
  const FUNNEL_TOKEN_KEY = 'mt-funnel-token-v1';
  function getFunnelToken(): string {
    try {
      let t = sessionStorage.getItem(FUNNEL_TOKEN_KEY);
      if (!t) {
        t = Math.random().toString(36).slice(2) + Date.now().toString(36);
        sessionStorage.setItem(FUNNEL_TOKEN_KEY, t);
      }
      return t;
    } catch {
      return Math.random().toString(36).slice(2);
    }
  }
  const funnelToken = getFunnelToken();
  const funnelStepReached = new Set<string>();
  // WB30 — le consentement n'existe QUE dans le panneau 2 : aucun signal
  // comportemental avant que le visiteur ait atteint ce panneau.
  function hasReachedConsentStep(): boolean {
    return step >= 2;
