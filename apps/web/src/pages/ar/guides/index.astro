---
/**
 * AR — Guides & resources hub (W67, RTL). Faithful Arabic translation of
 * /guides ; no new figure or price claim. Card links use localizeNavHref
 * (EN/AR if available, else the existing FR page — never a dead link). FR
 * untouched.
 */
import Layout from '../../../layouts/Layout.astro';
import V2Enhance from '../../../components/V2Enhance.astro';
import Article33Ribbon from '../../../components/Article33Ribbon.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import CtaBand from '../../../components/CtaBand.astro';
import StickyCta from '../../../components/StickyCta.astro';
import { getLocaleFromPath } from '../../../i18n/utils';
import { localizeNavHref } from '../../../i18n/pages';

const locale = getLocaleFromPath(Astro.url.pathname);
const L = (href: string) => localizeNavHref(href, locale);

const guides = [
  {
    href: '/guides/combien-de-panneaux-pour-ma-maison',
    title: 'كم لوحاً وأي قدرة (kWc)؟',
    summary: 'المنهجية للانتقال من فاتورتكم إلى عدد الألواح: kWh سنوية، kWc، مساحة السقف. ما يكفي لفهم التحجيم قبل الدراسة.',
  },
  {
    href: '/guides/on-grid-off-grid-ou-hybride',
    title: 'مربوط بالشبكة، مستقل أم هجين؟',
    summary: 'أي نوع نظام لأي حاجة — ولماذا ينقطع نظام مربوط بالشبكة أثناء عطب (منع الجزيرة الكهربائية)، إلا بالتحوّل إلى هجين ببطارية.',
  },
  {
    href: '/guides/orientation-inclinaison-ombrage',
    title: 'الاتجاه، الميلان والتظليل',
    summary: 'جنوب تام، شرق-غرب، زاوية الميلان وأثر الظلّ غير المتناسب على سقف مغربي: كيف تجنون أقصى قدر من الإنتاج.',
  },
  {
    href: '/guides/entretien-et-duree-de-vie-des-panneaux',
    title: 'صيانة وعمر الألواح',
    summary: 'الغبار والرمل بالمغرب، التنظيف، الحرارة، التدهور: كم تدوم الألواح فعلاً وكيف تحافظون على إنتاجها.',
  },
  {
    href: '/guides/monocristallin-ou-polycristallin',
    title: 'أحادي أم متعدّد البلورة؟ String أم ميكرو-عاكسات؟',
    summary: 'اختيار العتاد دون مصطلحات: نوع اللوح ونوع العاكس، وما يُغيّره كل منهما فعلياً على سقف.',
  },
  {
    href: '/guides/loi-82-21-expliquee',
    title: 'القانون 82-21 ببساطة',
    summary: 'تصريح، اتفاق ربط أو ترخيص: الأنظمة الثلاثة للإنتاج الذاتي مفكوكة، مع عتبة 11 kW التي تضع كل الفيلات تقريباً في الجهة الصحيحة.',
  },
  {
    href: '/guides/onduleur-hybride-ou-reseau',
    title: 'عاكس هجين أم عاكس شبكة؟',
    summary: 'Deye هجين أم Huawei SUN2000 شبكة: كل الاختيار يُختزل في سؤال واحد — هل تخزّن الطاقة، نعم أم لا؟',
  },
  {
    href: '/guides/mon-toit-peut-il-supporter-des-panneaux',
    title: 'هل يتحمّل سقفي الألواح؟',
    summary: 'الوزن الفعلي للوح شمسي لكل م²، سقفاً بسقف (دالة خرسانية، قرميد، صفيح مموّج، سقف مسطّح)، ومتى يلزم فحص هيكلي.',
  },
  {
    href: '/guides/faut-il-des-batteries',
    title: 'هل تحتاج بطاريات؟',
    summary: 'غالباً لا. كل شيء يتوقّف على الساعة التي تستهلك فيها: نُريك متى يُربِح التخزين، ومتى لا يفعل سوى إثقال الفاتورة.',
  },
  {
    href: '/guides/batterie-lithium-ou-gel',
    title: 'ليثيوم LiFePO4 (LFP) أم GEL/رصاص (وNMC)',
    summary: 'لماذا يفرض LFP نفسه بالمغرب: العمر، عمق التفريغ، المردودية، تحمّل الحرارة والسلامة أمام NMC.',
  },
  {
    href: '/guides/quelle-taille-de-batterie',
    title: 'أي حجم بطارية (kWh)؟ تخزين أم بيع؟',
    summary: 'مراحل التحجيم، kWh الفعلية مقابل الاسمية، ولماذا التخزين للمساء يربح أكثر بكثير من تصدير فائضكم بالمغرب.',
  },
  {
    href: '/guides/electricite-pendant-les-coupures',
    title: 'الحفاظ على الكهرباء أثناء الانقطاعات',
    summary: 'النجدة ≠ off-grid: مخارج EPS، عاكس هجين وبطارية، ولماذا يتوقّف نظام شبكة قياسي أثناء عطب.',
  },
  {
    // W293 — pillar الأثمنة الدائم، مختلف عن دليل منهجية التحجيم أعلاه.
    href: '/prix-panneaux-solaires-maroc',
    title: 'أثمنة الألواح الشمسية بالمغرب',
    summary: 'هوامش استرشادية حسب القدرة (kWc)، تكاليف السقف والبطارية، الضريبة — تُراجَع كل سنة، دون وعد بثمن نهائي أبداً.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'أدلّة وموارد شمسية — Taqinor',
  hasPart: guides.map((g) => ({ '@type': 'Article', headline: g.title, url: new URL(g.href, Astro.site).href })),
};
---

<Layout
  title="أدلّة شمسية بالمغرب — القانون 82-21، البطاريات، العاكسات | Taqinor"
  description="ثلاثة أسئلة تتكرّر قبل التوقيع، مُعالَجة دون مصطلحات: أي نظام للقانون 82-21 يعنيك، هل يبرّر ملفّك بطاريات، وما يفصل عاكساً هجيناً عن عاكس شبكة. ما يكفي للقرار عن بيّنة."
  ogSlug="accueil"
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <div class="v2">
    <V2Enhance />
    <Article33Ribbon />

    <Breadcrumb items={[{ label: 'الرئيسية', href: L('/') }, { label: 'الأدلّة' }]} />

    <section class="px-4 pb-10 pt-16 text-white sm:pt-20">
      <div class="mx-auto max-w-3xl">
        <p class="tech-label v2-kicker rule-brass cine-in text-lune">أدلّة وموارد</p>
        <h1 class="display v2-page-title cine-in mt-5 [animation-delay:120ms]">افهم قبل أن توقّع</h1>
        <p class="v2-lead cine-in mt-6 max-w-xl text-white/85 [animation-delay:240ms]">
          ثلاثة أسئلة تتكرّر في كل تبادلاتنا تقريباً. بدل الإجابة عنها هاتفياً، كتبناها هنا، دون
          مصطلحات ودون رقم سعر يُلقى في الهواء. ما يكفي للوصول إلى الدراسة والأسئلة الصحيحة حاضرة
          في الذهن.
        </p>
      </div>
    </section>

    <section class="px-4 pb-24 sm:pb-32">
      <div class="mx-auto grid max-w-6xl gap-6 md:grid-cols-3" data-stagger>
        {guides.map((g, i) => (
          <a href={L(g.href)} class="v2-rise cine-card flex flex-col p-7" style={`--v2-i:${i}`}>
            <p class="tech-label text-lune">دليل</p>
            <h2 class="display mt-2 text-xl text-white">{g.title}</h2>
            <p class="mt-3 flex-1 text-sm leading-relaxed text-lune-soft">{g.summary}</p>
            <span class="mt-5 inline-block border-b-2 border-azur-200/60 pb-0.5 text-sm font-bold text-white">اقرأ الدليل <span class="inline-block rtl:-scale-x-100">→</span></span>
          </a>
        ))}
      </div>
    </section>

    <CtaBand title="حالتك ليست في الأدلّة؟ اعرضها على الدراسة — إنها مجانية." href={L('/devis/mon-toit')} />

    <StickyCta />
  </div>
</Layout>
