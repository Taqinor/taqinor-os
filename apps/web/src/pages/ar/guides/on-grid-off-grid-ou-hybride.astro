 * translation of /guides/on-grid-off-grid-ou-hybride. No new figures beyond
 * the FR's own (4–10 ms switchover, 5–10 kWh battery). Internal links use
 * localizeNavHref (EN/AR if available, else the existing FR page — never a
 * dead link). FR untouched.
 */
import Layout from '../../../layouts/Layout.astro';
import V2Enhance from '../../../components/V2Enhance.astro';
import Article33Ribbon from '../../../components/Article33Ribbon.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import CtaBand from '../../../components/CtaBand.astro';
import StickyCta from '../../../components/StickyCta.astro';
import { NAP } from '../../../lib/nap';
import RelatedLinks from '../../../components/RelatedLinks.astro';
import { getLocaleFromPath } from '../../../i18n/utils';
