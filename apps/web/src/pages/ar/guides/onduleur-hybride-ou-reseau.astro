---
/**
 * AR — Guide (W67, RTL): Hybrid inverter or grid-tied inverter? Faithful Arabic
 * translation of /guides/onduleur-hybride-ou-reseau, including the loi 82-21
 * section the FR added (20 % injection cap, 0,18–0,21 DH/kWh buy-back vs
 * 0,90–1,66 DH/kWh grid) plus the 5–30 kW ranges. Internal links use
 * localizeNavHref (EN/AR if available, else the existing FR page — never a dead
 * link). FR untouched.
 */
import Layout from '../../../layouts/Layout.astro';
import V2Enhance from '../../../components/V2Enhance.astro';
import Article33Ribbon from '../../../components/Article33Ribbon.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import CtaBand from '../../../components/CtaBand.astro';
import StickyCta from '../../../components/StickyCta.astro';
import { NAP } from '../../../lib/nap';
import { getLocaleFromPath } from '../../../i18n/utils';
import { localizeNavHref } from '../../../i18n/pages';

const locale = getLocaleFromPath(Astro.url.pathname);
const L = (href: string) => localizeNavHref(href, locale);

const url = new URL(Astro.url.pathname, Astro.site).href;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'عاكس هجين أم عاكس شبكة؟',
  description: 'عاكس Deye هجين أم عاكس Huawei شبكة: الفرق يعود إلى سؤال بسيط — هل تخزّن الطاقة، نعم أم لا؟',
  about: { '@type': 'Thing', name: 'العاكسات الشمسية' },
  author: { '@type': 'Organization', name: NAP.name, url: NAP.url },
  publisher: { '@type': 'Organization', name: NAP.name, url: NAP.url },
  mainEntityOfPage: url,
};
---

<Layout
  title="عاكس هجين أم عاكس شبكة؟ | Taqinor"
  description="عاكس Deye هجين (مع تخزين، استمرارية خدمة) أم عاكس Huawei SUN2000 شبكة (استهلاك ذاتي دون بطارية): كيف يُتّخذ الاختيار، مشروحاً ببساطة."
  ogSlug="equipement"
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <div class="v2">
    <V2Enhance />
    <Article33Ribbon />

    <Breadcrumb items={[{ label: 'الرئيسية', href: L('/') }, { label: 'الأدلّة', href: L('/guides') }, { label: 'عاكس هجين أم شبكة؟' }]} />

    <article class="mx-auto max-w-3xl px-4 pb-24 pt-12 sm:pb-28">
      <p class="tech-label v2-kicker rule-brass text-lune">دليل · العتاد</p>
      <h1 class="display v2-page-title mt-5 text-white">عاكس هجين أم عاكس شبكة؟</h1>
      <p class="v2-lead mt-6 text-lune-soft">
        العاكس هو القطعة التي تحوّل التيار المستمر للألواح إلى تيار قابل للاستعمال عندك: بدونه، لا
        شيء يعمل. النقاش بين
        <strong class="text-lune">الهجين</strong> و <strong class="text-lune">الشبكة</strong> قد
        يبدو تقنياً، لكنه يُختزل في سؤال واحد: هل تخزّن الطاقة، نعم أم لا؟
      </p>

      <h2 class="display v2-section-title mt-12 text-white">العاكس الهجين (Deye)</h2>
      <p class="v2-lead mt-5 text-lune-soft">
        أجِب «نعم» للتخزين، وأنت على هجين. عاكسات Deye (أحادية وثلاثية الطور، من 5 إلى 30 kW) تقود
        في الوقت نفسه الألواح وبطارية، بحوار رقمي مباشر مع نظام إدارة البطارية (BMS) يضبط الشحن
        باستمرار. لها معنى حين تريد ادّخار طاقة النهار لاستهلاكها مساءً، أو إبقاء التيار أثناء انقطاع.
      </p>

      <h2 class="display v2-section-title mt-12 text-white">عاكس الشبكة (Huawei SUN2000)</h2>
      <p class="v2-lead mt-5 text-lune-soft">
        أجِب «لا»، وعاكس الشبكة يكفي. عاكسات Huawei SUN2000 (من نوع string) مُفصّلة للاستهلاك الذاتي
        دون بطارية، من السكني إلى أسطح القطاع الثالث. إنه الخيار حين يكون استهلاكك أساساً نهارياً:
        لا تخزين تؤدّي ثمنه لطاقة تستعملها أصلاً على إيقاع الشمس.
      </p>

      <h2 class="display v2-section-title mt-12 text-white">أين يدخل القانون 82-21</h2>
      <p class="v2-lead mt-5 text-lune-soft">
        قد يُظَنّ أن عاكس الشبكة «يُعوّض» ببيع كل الفائض. القانون 82-21 يقول العكس. فالحقن في الشبكة
        مسقوف عند 20 % من إنتاجك السنوي، وهذا الفائض لا يُشترى إلا بتعريفة تحدّدها ANRE (قرار 04/26) —
        <strong class="text-lune"> 0,18 إلى 0,21 درهم/kWh للتوتر المتوسط/العالي؛ أمّا تعريفة نظام
        التصريح للتوتر المنخفض (أقلّ من 11 kW، وهي حالة أغلب البيوت) فلم تُنشَر بعد</strong>. الأكيد
        هو أنك تشتري نفس الـ kWh من الشبكة بين 0,90 و1,66 درهم/kWh، وهو سعر أعلى بكثير من أي تعريفة
        شراء أُعلنت حتى الآن. أي أن الطاقة التي لا تستهلكها في عين المكان قيمتها ضئيلة، أياً كان الرقم
        النهائي للتوتر المنخفض. وهنا يتّضح دور كلّ عاكس: إن كان استهلاكك نهارياً، يكفيك عاكس الشبكة،
        إذ يلتقط جلّ هذه القيمة عبر الاستهلاك الذاتي المباشر؛ وإن كان مسائياً، يأتي دور العاكس الهجين،
        الذي يخزّن فائض النهار ويردّه إلى ساعات ذروتك بدل تصديره بثمن بخس.
      </p>

      <h2 class="display v2-section-title mt-12 text-white">كيف نختار</h2>
      <p class="v2-lead mt-5 text-lune-soft">
        اختيار العاكس إذن ليس الأول، بل الأخير: ينبثق من قرار التخزين، الذي ينبثق بدوره من ملمح
        استهلاكك ومن استقرار شبكتك. نرتّب القرار من أوّله — فاتورتك وساعات استهلاكك أولاً،
        العتاد بعدها — بدل الانطلاق من طراز مُقرَّر سلفاً.
      </p>
      <div class="mt-10 flex flex-wrap gap-3">
        <a href={L('/guides/faut-il-des-batteries')} class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">هل تحتاج بطاريات؟ <span class="inline-block rtl:-scale-x-100">→</span></a>
        <a href={L('/équipement')} class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">شاهد العتاد <span class="inline-block rtl:-scale-x-100">→</span></a>
        <a href={L('/guides')} class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">كل الأدلّة <span class="inline-block rtl:-scale-x-100">→</span></a>
      </div>
    </article>

    <CtaBand title="نحسم هجين أم شبكة في الدراسة — وهي مجانية." href={L('/devis/mon-toit')} />

    <StickyCta />
  </div>
</Layout>
