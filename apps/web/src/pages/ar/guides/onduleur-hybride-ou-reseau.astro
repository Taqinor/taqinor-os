---
/**
 * AR — Guide (W67, RTL): Hybrid inverter or grid-tied inverter? Faithful Arabic
 * translation of /guides/onduleur-hybride-ou-reseau, including the loi 82-21
 * section the FR added (20 % injection cap, 0,18–0,21 DH/kWh buy-back vs
 * 0,90–1,66 DH/kWh grid) plus the 5–30 kW ranges. Internal links use
 * localizeNavHref (EN/AR if available, else the existing FR page — never a dead
 * link). FR untouched.
 */
import Layout from '../../../layouts/Layout.astro';
import V2Enhance from '../../../components/V2Enhance.astro';
import Article33Ribbon from '../../../components/Article33Ribbon.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import CtaBand from '../../../components/CtaBand.astro';
import StickyCta from '../../../components/StickyCta.astro';
import { NAP } from '../../../lib/nap';
import { getLocaleFromPath } from '../../../i18n/utils';
import { localizeNavHref } from '../../../i18n/pages';

const locale = getLocaleFromPath(Astro.url.pathname);
const L = (href: string) => localizeNavHref(href, locale);

const url = new URL(Astro.url.pathname, Astro.site).href;
// W291 — صورة OG (نفس الرابط المُمرَّر إلى ogSlug أدناه)، لأهلية Article rich results.
const schemaImageUrl = new URL('/og/equipement.png', Astro.site).href;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'عاكس هجين أم عاكس شبكة؟',
  description: 'عاكس Deye هجين أم عاكس Huawei شبكة: الفرق يعود إلى سؤال بسيط — هل تخزّن الطاقة، نعم أم لا؟',
  image: schemaImageUrl,
  about: { '@type': 'Thing', name: 'العاكسات الشمسية' },
  author: { '@type': 'Organization', name: NAP.name, url: NAP.url },
  publisher: { '@type': 'Organization', name: NAP.name, url: NAP.url },
  mainEntityOfPage: url,
};
---

<Layout
  title="عاكس هجين أم عاكس شبكة؟ | Taqinor"
  description="عاكس Deye هجين (مع تخزين، استمرارية خدمة) أم عاكس Huawei SUN2000 شبكة (استهلاك ذاتي دون بطارية): كيف يُتّخذ الاختيار، مشروحاً ببساطة."
  ogSlug="guides"
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <div class="v2">
    <V2Enhance />
    <Article33Ribbon />

    <Breadcrumb items={[{ label: 'الرئيسية', href: L('/') }, { label: 'الأدلّة', href: L('/guides') }, { label: 'عاكس هجين أم شبكة؟' }]} />

    <article class="mx-auto max-w-3xl px-4 pb-24 pt-12 sm:pb-28">
      <p class="tech-label v2-kicker rule-brass text-lune">دليل · العتاد</p>
      <h1 class="display v2-page-title mt-5 text-white">عاكس هجين أم عاكس شبكة؟</h1>
      <p class="v2-lead mt-6 text-lune-soft">
        العاكس هو القطعة التي تحوّل التيار المستمر للألواح إلى تيار قابل للاستعمال عندك: بدونه، لا
        شيء يعمل. النقاش بين
        <strong class="text-lune">الهجين</strong> و <strong class="text-lune">الشبكة</strong> قد
        يبدو تقنياً، لكنه يُختزل في سؤال واحد: هل تخزّن الطاقة، نعم أم لا؟
      </p>

      <h2 class="display v2-section-title mt-12 text-white">العاكس الهجين (Deye)</h2>
      <p class="v2-lead mt-5 text-lune-soft">
        أجِب «نعم» للتخزين، وأنت على هجين. عاكسات Deye (أحادية وثلاثية الطور، من <span dir="ltr">5</span> إلى <span dir="ltr">30 kW</span>) تقود
        في الوقت نفسه الألواح وبطارية، بحوار رقمي مباشر مع نظام إدارة البطارية (BMS) يضبط الشحن
        باستمرار. لها معنى حين تريد ادّخار طاقة النهار لاستهلاكها مساءً، أو إبقاء التيار أثناء انقطاع —
        ما لا يفعله عاكس الشبكة أبداً (السبب بالتفصيل أسفله).
      </p>

      <h2 class="display v2-section-title mt-12 text-white">عاكس الشبكة (Huawei <span dir="ltr">SUN2000</span>)</h2>
      <p class="v2-lead mt-5 text-lune-soft">
        أجِب «لا»، وعاكس الشبكة يكفي. عاكسات Huawei <span dir="ltr">SUN2000</span> (من نوع string) مُفصّلة للاستهلاك الذاتي
        دون بطارية، من السكني إلى أسطح القطاع الثالث. إنه الخيار حين يكون استهلاكك أساساً نهارياً:
        لا تخزين تؤدّي ثمنه لطاقة تستعملها أصلاً على إيقاع الشمس. العيب معروف — لا كهرباء أثناء
        الانقطاع (السبب الدقيق موجود في دليلنا
        <a href={L('/guides/on-grid-off-grid-ou-hybride')} class="border-b border-azur-200/60 pb-0.5 font-semibold text-lune transition-colors hover:text-white">شبكي أم منعزل أم هجين</a>).
      </p>

      <p class="v2-lead mt-5 text-lune-soft">
        فائض الحقن في الشبكة قيمته ضئيلة مقارنة بتعريفة التجزئة على أي حال — تفاصيل الأرقام (سقف
        <span dir="ltr">20 %</span>، تعريفة الشراء <span dir="ltr">ANRE</span>) محدَّثة في دليلنا
        <a href={L('/guides/loi-82-21-expliquee')} class="border-b border-azur-200/60 pb-0.5 font-semibold text-lune transition-colors hover:text-white">القانون <span dir="ltr">82-21</span> ببساطة</a>.
        وهنا يتّضح دور كلّ عاكس: إن كان استهلاكك نهارياً، يكفيك عاكس الشبكة، إذ يلتقط جلّ هذه القيمة
        عبر الاستهلاك الذاتي المباشر؛ وإن كان مسائياً، يأتي دور العاكس الهجين، الذي يخزّن فائض النهار
        ويردّه إلى ساعات ذروتك بدل تصديره بثمن بخس.
      </p>

      <h2 class="display v2-section-title mt-12 text-white">كيف نختار</h2>
      <p class="v2-lead mt-5 text-lune-soft">
        اختيار العاكس إذن ليس الأول، بل الأخير: ينبثق من قرار التخزين، الذي ينبثق بدوره من ملمح
        استهلاكك ومن استقرار شبكتك. نرتّب القرار من أوّله — فاتورتك وساعات استهلاكك أولاً،
        العتاد بعدها — بدل الانطلاق من طراز مُقرَّر سلفاً.
      </p>
      <div class="mt-10 flex flex-wrap gap-3">
        <a href={L('/guides/on-grid-off-grid-ou-hybride')} class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">شبكي أم منعزل أم هجين؟ <span class="inline-block rtl:-scale-x-100">→</span></a>
        <a href={L('/guides/electricite-pendant-les-coupures')} class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">الكهرباء أثناء الانقطاعات <span class="inline-block rtl:-scale-x-100">→</span></a>
        <a href={L('/guides/faut-il-des-batteries')} class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">هل تحتاج بطاريات؟ <span class="inline-block rtl:-scale-x-100">→</span></a>
        <a href={L('/équipement')} class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">شاهد العتاد <span class="inline-block rtl:-scale-x-100">→</span></a>
        <a href={L('/guides')} class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">كل الأدلّة <span class="inline-block rtl:-scale-x-100">→</span></a>
      </div>
    </article>

    <CtaBand title="نحسم هجين أم شبكة في الدراسة — وهي مجانية." href={L('/devis/mon-toit')} />

    <StickyCta />
  </div>
</Layout>
