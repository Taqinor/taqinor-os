---
/**
 * AR — Guide (W67, RTL): Law 82-21 explained simply. Faithful Arabic
 * translation of /guides/loi-82-21-expliquee ; no figure beyond the law's own
 * thresholds (11 kW, 5 MW) and the date (9 June 2026), no price/cost claim,
 * Latin digits. Internal links use localizeNavHref (EN/AR if available, else
 * the existing FR page — never a dead link). FR untouched.
 */
import Layout from '../../../layouts/Layout.astro';
import V2Enhance from '../../../components/V2Enhance.astro';
import Article33Ribbon from '../../../components/Article33Ribbon.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import CtaBand from '../../../components/CtaBand.astro';
import StickyCta from '../../../components/StickyCta.astro';
import Faq from '../../../components/Faq.astro';
import { NAP } from '../../../lib/nap';
import { getLocaleFromPath } from '../../../i18n/utils';
import { localizeNavHref } from '../../../i18n/pages';

const locale = getLocaleFromPath(Astro.url.pathname);
const L = (href: string) => localizeNavHref(href, locale);

const url = new URL(Astro.url.pathname, Astro.site).href;
// W291 — صورة OG (نفس الرابط المُمرَّر إلى ogSlug أدناه)، لأهلية Article rich results.
const schemaImageUrl = new URL('/og/loi-82-21.png', Astro.site).href;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'القانون 82-21 ببساطة',
  description: 'الأنظمة الثلاثة للإنتاج الذاتي للكهرباء بالمغرب (تصريح، اتفاق ربط، ترخيص) مشروحة بلغة واضحة.',
  image: schemaImageUrl,
  about: { '@type': 'Thing', name: 'القانون 82-21 — الإنتاج الذاتي للطاقة الكهربائية' },
  author: { '@type': 'Organization', name: NAP.name, url: NAP.url },
  publisher: { '@type': 'Organization', name: NAP.name, url: NAP.url },
  mainEntityOfPage: url,
};

// W297 — تمريرة AEO/GEO: أسئلة وأجوبة مستقلّة تُعيد استعمال الحقائق المذكورة أعلاه،
// كي تتمكّن مساعدات الذكاء الاصطناعي من الاستشهاد بجواب كامل مباشرة.
// schema={false}: تبقى /faq الصفحة الوحيدة الحاملة لـFAQPage في الموقع.
const faq = [
  {
    q: 'أي نظام من القانون 82-21 يخصّ فيلا بالمغرب؟',
    a: 'دون 11 kW في الجهد المنخفض، يكفي تصريح مسبق بسيط — حالة جلّ الفيلات. فوق هذه العتبة وحتى 5 MW، يلزم اتفاق ربط؛ ابتداءً من 5 MW، ترخيص.',
  },
  {
    q: 'منذ متى يسري القانون 82-21؟',
    a: 'يُطبَّق المرسوم التطبيقي 2-25-100 منذ 9 يونيو 2026.',
  },
  {
    q: 'ماذا أفعل إن كانت تركيبتي الشمسية الحالية غير مُصرَّح بها؟',
    a: 'يفتح الفصل 33، منذ 9 يونيو 2026، فترة 18 شهراً لتسويتها. بعد هذا الأجل، تبقى في وضعية غير قانونية تجاه القانون، بالعقوبات التي يستوجبها ذلك.',
  },
];

const regimes = [
  {
    n: '01',
    title: 'التصريح',
    body: 'دون 11 kW في الجهد المنخفض — أو خارج الشبكة، في موقع معزول — ليس عليك إخضاع أي شيء للمصادقة: تصريح مسبق، يُودَع قبل التشغيل، يكفي. إنه إجراء شكلي، لا طلب ترخيص، وهي حالة الأغلبية الساحقة من الفيلات.',
  },
  {
    n: '02',
    title: 'اتفاق الربط',
    body: 'فوق عتبة التصريح وحتى 5 MW، بمجرّد الحقن في الشبكة بالجهد المنخفض أو المتوسط، يجب الحصول على اتفاق ربط من المدبّر — ONEE في أغلب الجهات، أو الوكالة المحلية: Lydec بالدار البيضاء، Redal بالرباط، Amendis بطنجة — قبل الانطلاق. إنه المجال المعتاد للمواقع المهنية.',
  },
  {
    n: '03',
    title: 'الترخيص',
    body: 'ابتداءً من 5 MW، في الجهد المتوسط أو العالي أو العالي جداً، تتغيّر الكتلة: يجب الحصول على ترخيص في حلّة قانونية قبل أول ضربة معول. قليل من الأسطح الخاصة معنيّة.',
  },
];
---

<Layout
  title="القانون 82-21 ببساطة — الأنظمة الثلاثة | Taqinor"
  description="عتبة 11 kW تقرّر كل شيء تقريباً: دونها، في الجهد المنخفض، يكفي تصريح بسيط، وهي حالة معظم الفيلات. فوقها، اتفاق ربط، ثم ترخيص ابتداءً من 5 MW. الأنظمة الثلاثة بوضوح، وكيف تموضع نفسك."
  ogSlug="loi-82-21"
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <div class="v2">
    <V2Enhance />
    <Article33Ribbon />

    <Breadcrumb items={[{ label: 'الرئيسية', href: L('/') }, { label: 'الأدلّة', href: L('/guides') }, { label: 'القانون 82-21 ببساطة' }]} />

    <article class="mx-auto max-w-3xl px-4 pb-24 pt-12 sm:pb-28">
      <p class="tech-label v2-kicker rule-brass text-lune">دليل · القانون 82-21</p>
      <h1 class="display v2-page-title mt-5 text-white">القانون 82-21 ببساطة</h1>
      <p class="v2-lead mt-6 text-lune-soft">
        منذ 9 يونيو 2026، يُطبَّق القانون 82-21 حول الإنتاج الذاتي للطاقة الكهربائية ومرسومه
        2-25-100. القاعدة أبسط ممّا تبدو: رقمان — قدرتك ومستوى ربطك — يكفيان لوضعك في أحد الأنظمة
        الثلاثة أدناه، سواء كانت تركيبتك جديدة أو قائمة بالفعل. إليك كيف تموضع نفسك، دون مصطلحات.
      </p>

      <!-- W259 — «أين وصل القانون؟»: يميّز بين السّاري (MT/HT) والمنتظَر (BT سكني). -->
      <div class="v2-rise mt-10 border-2 border-brass-400/50 bg-nuit-800/60 p-6 sm:p-8">
        <p class="tech-label v2-kicker text-brass-300">أين وصل القانون؟ · تم التحقّق في 3 يوليوز 2026</p>
        <div class="mt-4 grid gap-5 sm:grid-cols-2">
          <div>
            <p class="tech-label text-lune">ساري المفعول</p>
            <p class="mt-2 text-sm leading-relaxed text-lune-soft">
              المرسوم <strong class="text-white">2-25-100</strong> (الجريدة الرسمية بتاريخ 9 مارس 2026،
              ساري منذ 9 يونيو 2026) وقرار ANRE رقم <strong class="text-white">04/26</strong>:
              <strong class="text-white"> 0,18–0,21 درهم/kWh</strong> لشراء الفائض، لكن فقط لنظامَي
              اتفاق الربط والترخيص، في <strong class="text-white">التوتر المتوسط والعالي
              (MT/HT)</strong>.
            </p>
          </div>
          <div>
            <p class="tech-label text-lune">لم يُنشَر بعد</p>
            <p class="mt-2 text-sm leading-relaxed text-lune-soft">
              تعريفة الشراء لنظام <strong class="text-white">التصريح في التوتر المنخفض
              (BT)</strong> — حالة أغلب الفيلات — لم تُنشَر بعد، مع أجل يُتداوَل في حدود
              <strong class="text-white"> 2027</strong>، غير مؤكَّد إلى حدود اليوم.
            </p>
          </div>
        </div>
        <p class="mt-5 text-xs leading-relaxed text-lune-faint">
          تركيبتك قائمة بالفعل؟ نافذة تسوية المادة 33 مفتوحة منذ اليوم، بصرف النظر عن هذه التعريفة —
          <a href={L('/regularization-article-33')} class="border-b border-brass-300/60 pb-0.5 font-semibold text-brass-300 transition-colors hover:text-brass-200">سوِّ تركيبتك القائمة <span class="inline-block rtl:-scale-x-100">→</span></a>.
        </p>
      </div>

      <div class="mt-12 grid gap-6" data-stagger>
        {regimes.map((r, i) => (
          <div class="v2-rise cine-card grid gap-4 p-6 sm:grid-cols-[auto_1fr] sm:p-7" style={`--v2-i:${i}`}>
            <span class="fig lum text-4xl" aria-hidden="true">{r.n}</span>
            <div>
              <h2 class="display text-xl text-white">{r.title}</h2>
              <p class="mt-2 text-sm leading-relaxed text-lune-soft">{r.body}</p>
            </div>
          </div>
        ))}
      </div>

      <h2 class="display v2-section-title mt-14 text-white">وإن كانت تركيبتي قائمة بالفعل؟</h2>
      <p class="v2-lead mt-5 text-lune-soft">
        القانون لا ينسى التركيبات المُركّبة قبله. تفتح مادته 33، منذ 9 يونيو 2026، نافذة من 18 شهراً
        لجعلها في وضع قانوني: إنه الأجل المتاح لك لإيداع الملف الناقص — تصريح أو اتفاق ربط أو ترخيص،
        حسب النظام الذي يعنيك أعلاه. تركيبة قائمة سُوّيت داخل هذا الأجل تلتحق بالإطار القانوني كأنها
        جديدة. وبعد انقضاء النافذة، تبقى في وضعية غير قانونية إزاء القانون 82-21، بما يستتبعه ذلك من
        عقوبات. فلا فائدة من الانتظار، والمسطرة تنطلق منذ اليوم.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href={L('/loi-82-21')} class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">حدّد نظامي في 3 أسئلة <span class="inline-block rtl:-scale-x-100">→</span></a>
        <a href={L('/regularization-article-33')} class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">سوِّ تركيبتي <span class="inline-block rtl:-scale-x-100">→</span></a>
        <a href={L('/guides')} class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">كل الأدلّة <span class="inline-block rtl:-scale-x-100">→</span></a>
      </div>
    </article>

    <!-- W297 — FAQ مرئية: schema={false}، تبقى /faq الصفحة الوحيدة الحاملة لـFAQPage -->
    <Faq items={faq} heading="القانون 82-21 — أسئلة متكرّرة" schema={false} />

    <CtaBand title="هذه الصفحة هي النظرية. ملفّكم يُودَع مع الدراسة المجانية." buttonLabel="تحقّقوا من ملفّي" href={L('/devis/mon-toit')} />

    <StickyCta />
  </div>
</Layout>
