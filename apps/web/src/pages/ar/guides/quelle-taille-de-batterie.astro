        { href: L('/guides/loi-82-21-expliquee'), label: 'القانون 82-21 ببساطة' },
        { href: L('/guides'), label: 'كل الأدلّة' },
      ]} />
    </article>

    <CtaBand title="بيتكم لا يشبه المثال؟ أرسلوا لنا قراءاتكم، نُحجّم السعة على ملفّكم الحقيقي." href={L('/devis/mon-toit')} />

    <StickyCta />
  </div>
</Layout>
