---
/**
 * AR — Guide (W294, RTL): How many panels for my house? Faithful Arabic
 * translation of /guides/combien-de-panneaux-pour-ma-maison, every figure
 * kept in Latin digits (6 000 kWh example, 1 500–1 800 kWh/kWc, 700 Wc panels,
 * 5–6 m²/kWc). Includes the FR's HowTo schema (W290) alongside Article.
 * Internal links use localizeNavHref (EN/AR if available, else the existing
 * FR page — never a dead link). FR untouched.
 */
import Layout from '../../../layouts/Layout.astro';
import V2Enhance from '../../../components/V2Enhance.astro';
import Article33Ribbon from '../../../components/Article33Ribbon.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import CtaBand from '../../../components/CtaBand.astro';
import StickyCta from '../../../components/StickyCta.astro';
import { NAP } from '../../../lib/nap';
import RelatedLinks from '../../../components/RelatedLinks.astro';
import { getLocaleFromPath } from '../../../i18n/utils';
import { localizeNavHref } from '../../../i18n/pages';

const locale = getLocaleFromPath(Astro.url.pathname);
const L = (href: string) => localizeNavHref(href, locale);

const url = new URL(Astro.url.pathname, Astro.site).href;
const schemaImageUrl = new URL('/og/residentiel.png', Astro.site).href;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'كم لوحاً شمسياً وأي قدرة (kWc) لبيتي؟',
  description: 'المنهجية خطوة بخطوة لتحجيم تركيبتكم الشمسية بالمغرب: قراءة فاتورة ONEE/Lydec، التحويل إلى kWh سنوية، اختيار القدرة بـkWc، وتقدير عدد الألواح.',
  image: schemaImageUrl,
  about: { '@type': 'Thing', name: 'تحجيم التركيبة الشمسية' },
  author: { '@type': 'Organization', name: NAP.name, url: NAP.url },
  publisher: { '@type': 'Organization', name: NAP.name, url: NAP.url },
  mainEntityOfPage: url,
};

// W290 — HowTo schema، إضافة إلى Article أعلاه (الخطوات الثلاث منشورة أصلاً في المقال).
const howToLd = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'كم لوحاً وأي قدرة (kWc) لبيتي؟',
  description: 'المنهجية خطوة بخطوة للانتقال من فاتورة الكهرباء إلى عدد الألواح الشمسية.',
  step: [
    {
      '@type': 'HowToStep',
      position: 1,
      name: 'إيجاد kWh على فاتورتكم',
      text: 'اجمعوا قراءات ONEE/Lydec/Redal/Amendis الثنائية الشهرية للسنة للحصول على استهلاككم السنوي بـkWh — أو اضربوا القراءة الثنائية المتوسطة في ستة.',
      url: `${url}#etape-1`,
    },
    {
      '@type': 'HowToStep',
      position: 2,
      name: 'من kWh إلى kWc',
      text: 'اقسموا الاستهلاك السنوي بـkWh على الإنتاج المتوقّع لـkWc واحد في منطقتكم (مرجع: 1 500 إلى 1 800 kWh لكل kWc في السنة بالمغرب) للحصول على القدرة الواجب تركيبها بـkWc.',
      url: `${url}#etape-2`,
    },
    {
      '@type': 'HowToStep',
      position: 3,
      name: 'من kWc إلى عدد الألواح',
      text: 'اقسموا القدرة بـkWc على قدرة اللوح الواحد (حوالي 700 Wc للألواح عالية القدرة الحالية) للحصول على عدد الألواح، بمعدّل حوالي 4,3 إلى 4,4 م² من السقف لكل kWc.',
      url: `${url}#etape-3`,
    },
  ],
};
---

<Layout
  title="كم لوحاً شمسياً لبيتي؟ منهجية kWc | Taqinor"
  description="فاتورة ONEE أو Lydec ← kWh سنوية ← kWc ← عدد الألواح: منهجية التحجيم مشروحة ببساطة. مراجع استرشادية للمغرب، دون أي رقم مُختلَق."
  ogSlug="residentiel"
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(howToLd)} />
  <div class="v2">
    <V2Enhance />
    <Article33Ribbon />

    <Breadcrumb items={[{ label: 'الرئيسية', href: L('/') }, { label: 'الأدلّة', href: L('/guides') }, { label: 'كم لوحاً لبيتي؟' }]} />

    <article class="mx-auto max-w-[68ch] px-4 pb-24 pt-12 sm:pb-28">
      <p class="tech-label v2-kicker rule-brass text-lune">دليل · التحجيم</p>
      <h1 class="display v2-page-title mt-5 text-white">كم لوحاً وأي قدرة؟</h1>

      <p class="v2-lead mt-6 text-lune-soft">
        السؤال يتكرّر عند كل اتصال أول: «كم لوحاً أحتاج؟». الجواب لا يُقرَأ على لوح، بل على فاتورة.
        لنأخذ فاتورة حقيقية ونتتبّعها حتى عدد الوحدات. مثالنا: فيلا بالدار البيضاء تُظهر قراءة Lydec
        <strong class="text-white"> 6 000 kWh في السنة</strong>. سنصعد من هذا الرقم نحو القدرة الواجب
        تركيبها، ثم نحو عدد الألواح.
      </p>

      <h2 id="etape-1" class="display v2-section-title mt-12 text-white">الخطوة 1 — إيجاد kWh على فاتورتكم</h2>
      <p class="v2-lead mt-5 text-lune-soft">
        المعطى الأول هو الاستهلاك السنوي بالكيلوواط ساعة (kWh). يظهر على القراءة الثنائية الشهرية
        لـONEE، أو في فضاء زبناء مُوزِّعكم: Lydec بالدار البيضاء، Redal بالرباط، Amendis بطنجة. الانعكاس
        هو جمع القراءات الثنائية الشهرية الست للسنة، أو ضرب القراءة الثنائية المتوسطة في ستة. بالنسبة
        لفيلانا، يعطي مجموع القراءات 6 000 kWh — هذا الرقم بالذات، المقروء على الورق، هو الذي يُوجّه
        كل الباقي.
      </p>
      <p class="v2-lead mt-5 text-lune-soft">
        دون قراءات في متناول اليد — بيت جديد، أول تجهيز — نُقدّر انطلاقاً من الأجهزة الكبيرة: المكيّفات،
        سخّانات الماء، الأجهزة المنزلية، الإضاءة. فيلا مغربية مُكيَّفة تدور عادة بين 4 000 و10 000 kWh
        في السنة، لكنها فترة، لا معدّلاً يُنسَخ. انطلقوا من واقعكم.
      </p>

      <h2 id="etape-2" class="display v2-section-title mt-12 text-white">الخطوة 2 — من kWh إلى kWc</h2>
      <p class="v2-lead mt-5 text-lune-soft">
        نقسم الاستهلاك السنوي على الإنتاج المتوقّع لـkWc واحد في منطقتكم. بالمغرب، المرجع هو
        <strong class="text-white"> 1 500 إلى 1 800 kWh مُنتَجة لكل kWc مُركَّب في السنة</strong> حسب
        المنطقة، أي حوالي 5 إلى 5,5 ساعات شمس مفيدة يومياً كمعدّل سنوي (المصدر: PVGIS / Global Solar
        Atlas).
      </p>
      <p class="v2-lead mt-5 text-lune-soft">
        مُطبَّقاً على فيلانا: 6 000 kWh مقسومة على حوالي 1 600 kWh/kWc تعطي تقريباً
        <strong class="text-white"> 4 kWc</strong>. بشكل أعمّ، استهلاك
        <strong class="text-white"> 4 000 إلى 6 000 kWh/سنة</strong> يوجّه نحو
        <strong class="text-white"> 3 إلى 5 kWc</strong>، و<strong class="text-white">6 000 إلى
        10 000 kWh/سنة</strong> نحو <strong class="text-white">5 إلى 8 kWc</strong>. هذه مراجع:
        اتجاه السقف، التظليل، معدّل الاستهلاك الذاتي المستهدَف وسقف الحقن بـ20 % الخاص بالقانون 82-21
        تُحرِّك النتيجة في اتجاه أو آخر.
      </p>

      <h2 id="etape-3" class="display v2-section-title mt-12 text-white">الخطوة 3 — من kWc إلى عدد الألواح</h2>
      <p class="v2-lead mt-5 text-lune-soft">
        الوحدات التي نُركّبها اليوم ألواح عالية القدرة بحوالي <strong class="text-white"> 700 Wc</strong>
        (Canadian Solar وJinko بـ710 Wc، أحادية البلورة). بهذه القدرة، يقابل kWc الواحد حوالي
        <strong class="text-white"> 1,4 إلى 1,5 لوح</strong>: سبعة وحدات بـ710 Wc تصنع تقريباً 5 kWc.
        فيلانا بـ4 kWc تحتاج إذن <strong class="text-white"> 6 ألواح</strong>؛ تركيبة بـ5 kWc تحتاج 7،
        وأخرى بـ3 kWc تحتاج 4 إلى 5.
      </p>
      <p class="v2-lead mt-5 text-lune-soft">
        على السقف، يشغل كل لوح حوالي <strong class="text-white"> 3,1 م²</strong> (لوح 710 Wc، 2 384 ×
        1 303 مم)، وهو ما يعود دائماً إلى نفس المرجع المساحي، حوالي <strong class="text-white"> 4,3 إلى
        4,4 م² من السقف لكل kWc</strong> مُركَّب: ارتفاع قدرة الوحدات يُقلّل عددها، لا المساحة الإجمالية
        التي تشغلها. فيلانا بـ4 kWc تحتاج إذن حوالي 17 إلى 18 م² من مساحة خالية، جيدة الاتجاه ودون
        تظليل ملحوظ.
      </p>

      <h2 class="display v2-section-title mt-12 text-white">حيث لم تعد فاتورتكم كافية</h2>
      <p class="v2-lead mt-5 text-lune-soft">
        هذا المسار فاتورة ← kWc ← ألواح يُعطي أمر حجم موثوقاً، وهذا بالضبط ما يُفيد فيه. لكنه يتوقّف
        عند باب سقفكم. الاتجاه والميلان الفعليان يُحرِّكان الإنتاج: سقف مسطّح مُتّجه شمالاً وسقف مائل
        متّجه جنوباً تماماً لا يُعطيان نفس عدد kWh لكل kWc. معدّل الاستهلاك الذاتي المستهدَف يُحرّك أيضاً
        الحجم الأمثل — تغطية 80 % من استهلاككم لا تتطلّب نفس التركيبة لتغطية 60 %. وسقف الحقن بـ20 %
        يعني أنه بعد نقطة معيّنة، إضافة ألواح لم تعد تُترجَم إلى قيمة.
      </p>
      <p class="v2-lead mt-5 text-lune-soft">
        هنا يستعيد المسح الميداني زمام الأمور: ننطلق من قراءاتكم الحقيقية، نقيس الاتجاه والحواجز،
        ونُخرج التحجيم الدقيق — kWc، عدد الألواح، المساحة — لبيتكم لا لفيلا المثال.
      </p>

      <RelatedLinks links={[
        { href: L('/guides/orientation-inclinaison-ombrage'), label: 'الاتجاه، الميلان، التظليل' },
        { href: L('/guides/monocristallin-ou-polycristallin'), label: 'أحادي أم متعدّد البلورة؟' },
        { href: L('/résidentiel'), label: 'الطاقة الشمسية السكنية' },
        { href: L('/prix-panneaux-solaires-maroc'), label: 'أسعار الألواح الشمسية بالمغرب' },
        { href: L('/guides'), label: 'كل الأدلّة' },
      ]} />
    </article>

    <CtaBand title="أعطونا استهلاككم السنوي بـkWh، نُخرج العدد الدقيق من الألواح لسقفكم." href={L('/devis/mon-toit')} />

    <StickyCta />
  </div>
</Layout>
