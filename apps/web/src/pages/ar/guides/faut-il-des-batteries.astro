---
/**
 * AR — Guide (W67, RTL): Do you need batteries? Faithful Arabic translation of
 * /guides/faut-il-des-batteries, including the figures the FR added (LFP cost,
 * surplus buy-back vs grid tariff under loi 82-21, payback, LFP cycles/warranty).
 * Internal links use localizeNavHref (EN/AR if available, else the existing FR
 * page — never a dead link). FR untouched.
 */
import Layout from '../../../layouts/Layout.astro';
import V2Enhance from '../../../components/V2Enhance.astro';
import Article33Ribbon from '../../../components/Article33Ribbon.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import CtaBand from '../../../components/CtaBand.astro';
import StickyCta from '../../../components/StickyCta.astro';
import { NAP } from '../../../lib/nap';
import { getLocaleFromPath } from '../../../i18n/utils';
import { localizeNavHref } from '../../../i18n/pages';
// W310 — يعيد كتلتَي KeyFigure و Callout الموجودتين في النسخة الفرنسية
// (إحصائية 6000 دورة + نصيحة «الانعكاس الصحيح») واللتين سقطتا صامتتين من هذه المرآة.
import Callout from '../../../components/Callout.astro';
import KeyFigure from '../../../components/KeyFigure.astro';

const locale = getLocaleFromPath(Astro.url.pathname);
const L = (href: string) => localizeNavHref(href, locale);

const url = new URL(Astro.url.pathname, Astro.site).href;
// W291 — صورة OG (نفس الرابط المُمرَّر إلى ogSlug أدناه)، لأهلية Article rich results.
const schemaImageUrl = new URL('/og/equipement.png', Astro.site).href;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'هل تحتاج بطاريات لتركيبتك الشمسية؟',
  description: 'استهلاك ذاتي نهاري أو تخزين: متى تُبرَّر البطاريات في تركيبة شمسية، مشروحاً ببساطة.',
  image: schemaImageUrl,
  about: { '@type': 'Thing', name: 'بطاريات التخزين الشمسي' },
  author: { '@type': 'Organization', name: NAP.name, url: NAP.url },
  publisher: { '@type': 'Organization', name: NAP.name, url: NAP.url },
  mainEntityOfPage: url,
};
---

<Layout
  title="هل تحتاج بطاريات لتركيبتك الشمسية؟ | Taqinor"
  description="غالباً لا. إن كنت تستهلك أساساً في النهار، فالاستهلاك الذاتي المباشر يُربِح أكثر من أي بطارية؛ التخزين يُبرَّر للّيل أو لاستمرارية الخدمة. كل شيء يتوقّف على الساعة التي يدور فيها عدّادك."
  ogSlug="guides"
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <div class="v2">
    <V2Enhance />
    <Article33Ribbon />

    <Breadcrumb items={[{ label: 'الرئيسية', href: L('/') }, { label: 'الأدلّة', href: L('/guides') }, { label: 'هل تحتاج بطاريات؟' }]} />

    <article class="mx-auto max-w-3xl px-4 pb-24 pt-12 sm:pb-28">
      <p class="tech-label v2-kicker rule-brass text-lune">دليل · العتاد</p>
      <h1 class="display v2-page-title mt-5 text-white">هل تحتاج بطاريات؟</h1>
      <p class="v2-lead mt-6 text-lune-soft">
        الجواب القصير: غالباً لا. إنه السؤال الأكثر تكراراً، وكثيرون يطرحونه مقلوباً — البطارية ليست
        قلب التركيبة، بل خيار. ما يبرّرها من عدمه هو <em>الساعة</em> التي تستهلك فيها كهرباءك.
      </p>

      <h2 class="display v2-section-title mt-12 text-white">إن كنت تستهلك أساساً في النهار</h2>
      <p class="v2-lead mt-5 text-lune-soft">
        حين يقع جلّ استهلاكك في عزّ النهار، تذهب كهرباء ألواحك مباشرة إلى أجهزتك، في اللحظة التي
        تُنتَج فيها، دون مرور عبر بطارية. لا خسارة تخزين، ولا عتاد إضافي يُستهلَك: إنه السيناريو
        الأكثر ربحاً. يناسب البيوت التي تُعاش نهاراً والمواقع المهنية التي يتبع نشاطها الشمس.
      </p>

      <h2 class="display v2-section-title mt-12 text-white">متى يصبح التخزين مفيداً</h2>
      <p class="v2-lead mt-5 text-lune-soft">
        ينقلب الحساب بمجرّد أن تصل ذروة استهلاكك بعد غروب الشمس: هناك، التخزين نهاراً لإعادة
        الاستخدام مساءً له معنى اقتصادي. الحالة الثانية، استمرارية الخدمة — إبقاء بعض المعدات
        مُغذّاة أثناء انقطاع. في هاتين الحالتين، تكفّ البطارية عن كونها كماليّة لتصبح بنداً
        يسترجع كلفته.
      </p>

      <h2 class="display v2-section-title mt-12 text-white">كم تكلّف البطارية، وكم يساوي kWh مخزَّن</h2>
      <p class="v2-lead mt-5 text-lune-soft">
        «غالباً لا» ليست تحفّظاً، بل خلاصة تُحسَب بالأرقام. في السوق المغربية، تتراوح كلفة
        بطارية LFP — وهي الكيمياء الموصى بها لمناخنا — حوالي <span dir="ltr">3 000</span> إلى <span dir="ltr">4 000</span> درهم لكل <span dir="ltr">kWh</span> من السعة
        المُركّبة. وعليه، تمثّل مجموعة بسعة مفيدة قدرها <span dir="ltr">10 kWh</span> نحو <span dir="ltr">30 000</span> إلى <span dir="ltr">40 000</span> درهم، فوق ثمن
        الألواح والعاكس الهجين. هذا البند لا يُبرَّر إلا إن وفّر لك أكثر ممّا يكلّفك.
      </p>
      <p class="v2-lead mt-5 text-lune-soft">
        وهنا بالضبط يُحسَم الأمر. منذ القانون <span dir="ltr">82-21</span>، يُشترى الفائض المُعاد إلى الشبكة بتعريفة تحدّدها
        <span dir="ltr">ANRE</span> (قرار <span dir="ltr">04/26</span>) — <strong class="text-white"><span dir="ltr">0,18</span> إلى <span dir="ltr">0,21</span> درهم/<span dir="ltr">kWh</span> للتوتر المتوسط/العالي؛
        أمّا تعريفة نظام التصريح للتوتر المنخفض (أقلّ من <span dir="ltr">11 kW</span>، وهي حالة أغلب البيوت) فلم تُنشَر
        بعد</strong>، لكن لا سبب يجعلها أفضل. بينما <em>تشتري</em> أنت نفس الـ <span dir="ltr">kWh</span> بين <span dir="ltr">0,90</span> و<span dir="ltr">1,66</span>
        درهم/<span dir="ltr">kWh</span> حسب شطرك — وهذا رقم معروف، وهو أعلى بكثير من أي تعريفة شراء أُعلنت حتى الآن. ومن ثَمّ
        فإن kWh تستهلكه عندك — مباشرة نهاراً، أو مخزَّناً للمساء — يساوي أضعاف kWh مُصدَّر. للبطارية
        قيمة فقط حين تنقل استهلاكك من النهار إلى المساء: أمّا بيت نهاري أصلاً، فلا يكاد يوجد فيه ما
        يُنقَل، فيؤدّي التخزين ثمنه دون مردود.
      </p>

      <h2 class="display v2-section-title mt-12 text-white">كم تستغرق حتى تسترجع كلفتها</h2>
      <p class="v2-lead mt-5 text-lune-soft">
        عملياً، تركيبة سكنية مُحسَنة الحجم تسترجع كلفتها في <span dir="ltr">5</span> إلى <span dir="ltr">7</span> سنوات دون تخزين. إضافة بطارية
        تطيل هذا الأجل بـ <span dir="ltr">1</span> إلى <span dir="ltr">3</span> سنوات، حسب ملفّك والسعة المختارة. لاستهلاك ليلي حقيقي، تُسترجَع
        هذه الزيادة وتنتهي البطارية رابحة؛ أمّا لبيت يُعاش نهاراً، فتُضاف دون مقابل. والخبر الطيّب
        أن العتاد يساعد على ذلك: بطارية LFP تصمد لنحو <span dir="ltr">6 000</span> دورة، مضمونة <span dir="ltr">10</span> سنوات عند <span dir="ltr">70 %</span> على الأقل من
        سعتها — عمرٌ يكفي لاسترجاع كلفة تخزين <em>مضبوط</em> الحجم، لا لتربيح مجموعة مُبالَغ في
        حجمها «احتياطاً».
      </p>

      <KeyFigure value="6 000" unit="دورة" label="عمر بطارية LFP">
        مضمونة <span dir="ltr">10</span> سنوات عند <span dir="ltr">70 %</span> من السعة — يكفي لاسترجاع كلفة تخزين مضبوط الحجم.
      </KeyFigure>

      <Callout type="tip" title="الانعكاس الصحيح">
        قبل إضافة بطارية، اسأل نفسك: في أي ساعة تستهلك أكثر؟ إن كان ذلك نهاراً،
        فالاستهلاك الذاتي المباشر يسترجع كلفته أسرع — دون أي تخزين.
      </Callout>

      <h2 class="display v2-section-title mt-12 text-white">ما يقوله منحنى استهلاكك</h2>
      <p class="v2-lead mt-5 text-lune-soft">
        الجواب إذن ليس في كاطالوݣ، بل في قراءة عدّادك. ننظر في الساعات التي يدور فيها عدّادك أكثر،
        وهذا المنحنى هو الذي يعيّن — أو لا — بطارية. إضافة تخزين «حتى تطمئن» مُكلفة دون أي مردود إن
        كان استهلاكك نهارياً؛ الانعكاس الصحيح هو تغطية جلّ الفاتورة بأقل استثمار.
      </p>
      <div class="mt-10 flex flex-wrap gap-3">
        <a href={L('/équipement')} class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">شاهد العتاد <span class="inline-block rtl:-scale-x-100">→</span></a>
        <a href={L('/guides/onduleur-hybride-ou-reseau')} class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">عاكس هجين أم عاكس شبكة؟ <span class="inline-block rtl:-scale-x-100">→</span></a>
        <a href={L('/guides')} class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">كل الأدلّة <span class="inline-block rtl:-scale-x-100">→</span></a>
      </div>
    </article>

    <CtaBand title="للحسم في حالتك بالضبط، أطلِق الدراسة المجانية." href={L('/devis/mon-toit')} />

    <StickyCta />
  </div>
</Layout>
