const locale = getLocaleFromPath(Astro.url.pathname);
const L = (href: string) => localizeNavHref(href, locale);

const pubDate = new Date('2026-06-21');
const dateFmt = new Intl.DateTimeFormat('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });

const bodyText = `
PVOUT حسب المدينة يتراوح من 1500 إلى 1950 kWh لكل kWc سنوياً، مراكش مؤكّدة عند 1779. تعريفات ONEE من
0,90 إلى 1,66 درهم لكل kWh، الفوترة الانتقائية فوق 150 kWh شهرياً تُفوتِر الشهر كلّه بالشطر الهامشي.
الاسترجاع 5 إلى 7 سنوات في السكني، إجماع بين المُركِّبين. ما يؤثّر على الاسترجاع: شطركم التعريفي
الحالي، كلفة التركيبة 10000 إلى 14000 درهم لكل kWc، معدّل الاستهلاك الذاتي، والبطارية تُضيف 1 إلى 3
سنوات للاسترجاع.
`;
const readingMinutes = estimateReadingTime(bodyText);

const url = new URL(Astro.url.pathname, Astro.site).href;
