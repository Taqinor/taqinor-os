  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'الرئيسية', item: new URL(L('/'), Astro.site).href },
    { '@type': 'ListItem', position: 2, name: 'المدوّنة', item: new URL(L('/blog'), Astro.site).href },
    { '@type': 'ListItem', position: 3, name: 'الربحية الشمسية حسب المدينة المغربية' },
  ],
};

const pvout = [
  { city: 'طنجة', value: '~1 550 – 1 650', tilt: '31°', confidence: 'مُقدَّرة' },
  { city: 'الدار البيضاء', value: '~1 620 – 1 700', tilt: '29°', confidence: 'مُقدَّرة' },
  { city: 'الرباط-سلا', value: '~1 620 – 1 700', tilt: '29°', confidence: 'مُقدَّرة' },
  { city: 'فاس', value: '~1 650 – 1 750', tilt: '~32°', confidence: 'مُقدَّرة' },
  { city: 'مراكش', value: '1 779 (نقطة مؤكَّدة)', tilt: '28°', confidence: 'عالية' },
  { city: 'أكادير', value: '~1 750 – 1 820', tilt: '27°', confidence: 'مُقدَّرة' },
  { city: 'ورزازات', value: '~1 850 – 1 950', tilt: '~28–30°', confidence: 'مُقدَّرة' },
