---
/**
 * AR — Financing & returns (W67, RTL). Faithful Arabic translation of
 * /financement ; EVERY figure (≈80 000 MAD, 3–7 yrs, 25 yrs, 60–90 %, 0 MAD,
 * 4–6 yrs, 3–5 yrs, 1 000 MAD, 84.8 %, ONEE) kept EXACT in Latin digits, and
 * the hard honesty constraints preserved: not a lender, no residential subsidy,
 * no residential VAT exemption, no bank named. Internal links via
 * localizeNavHref. FR untouched.
 */
import Layout from '../../layouts/Layout.astro';
import V2Enhance from '../../components/V2Enhance.astro';
import Article33Ribbon from '../../components/Article33Ribbon.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CtaBand from '../../components/CtaBand.astro';
import StickyCta from '../../components/StickyCta.astro';
import { getLocaleFromPath } from '../../i18n/utils';
import { localizeNavHref } from '../../i18n/pages';

const locale = getLocaleFromPath(Astro.url.pathname);
const L = (href: string) => localizeNavHref(href, locale);
const devisHref = L('/devis/mon-toit');

const chiffres = [
  { v: '3–7 سنوات', label: 'العائد على الاستثمار النموذجي' },
  { v: '25 سنة', label: 'ضمان أداء الألواح' },
  { v: '60–90 %', label: 'من الفاتورة مُغطّاة' },
  { v: '0 MAD', label: 'الدراسة والتشخيص' },
];

const moyens = [
  {
    k: '01',
    title: 'نقداً',
    body: 'معظم زبنائنا يؤدّون ثمن التركيبة دفعة واحدة. ابتداءً من التشغيل، تُسدّد نفسها بنفسها: كل kWh مُنتَج هو kWh لم تعد تشتريه من الشبكة، مُقيَّماً بتعريفة المكتب الوطني ONEE.',
  },
  {
    k: '02',
    title: 'قرض استهلاكي بنكي كلاسيكي',
    body: 'آخرون يمرّون عبر قرض استهلاكي كلاسيكي، يُكتتَب مباشرة لدى بنكهم. الترتيب يتم بينك وبين مؤسستك — لا نتدخّل فيه ولا نأخذ عنه أي عمولة.',
  },
  {
    k: '03',
    title: 'تمويل أخضر (للمقاولات)',
    body: 'للمقاولات، توجد بالمغرب خطوط تمويل أخضر للطاقات المتجددة. الاتفاق والشروط من اختصاص بنكك وملفك؛ لا نبيع أي قرض أو منتج بنكي، ولا نضمن أياً منها.',
  },
];

// W258 — آليات مُسمّاة ومُتحقَّق منها حسب القطاع. كل مُدخَل يذكر مصدره؛ لا شيء
// يُنشر بدونه. يبقى السكني عمداً بدون بنك مُسمّى (غير قابل للتحقق وقت البناء).
const mecanismes = [
  {
    segment: 'الفلاحة',
    items: [
      {
        nom: 'CAM «Saquii Solaire»',
        body: 'عرض مُسمّى من القرض الفلاحي للمغرب مُخصّص لتمويل الضخ الشمسي الفلاحي. السعر والشروط الدقيقة تتوقّف على ملفك — اسأل مباشرة في وكالة CAM.',
        source: 'creditagricole.ma',
      },
      {
        nom: 'FDA — إعانة الضخ الشمسي ≈ 30 %',
        body: 'يُعين صندوق التنمية الفلاحية بنحو 30 % من تكلفة اقتناء وتركيب عدّة الضخ الشمسي الفلاحي (ألواح، مجموعة مضخة، هيكل، ملحقات)، تُصرف بعد الفاتورة — الملف يودَع لدى المديرية الإقليمية للفلاحة (DPA) أو المكتب الجهوي (ORMVA). قابلة للتراكم مع إعانة التنقيط القائمة.',
        source: 'دليل FDA (agrimaroc.ma / casainvest.ma)',
      },
    ],
  },
  {
    segment: 'المقاولات',
    items: [
      {
        nom: 'إعفاء من الضريبة على القيمة المضافة عند الاستيراد — المادة 123-22° من المدونة العامة للضرائب',
        body: 'تُعفى تجهيزات الاستثمار المُسجَّلة في الأصول الثابتة، والمستوردة من طرف مقاولة خاضعة للضريبة على القيمة المضافة خلال 36 شهراً من بداية النشاط — رهن تكوين الضمانات التي تطلبها الإدارة الضريبية. التفصيل الكامل أدناه.',
        source: 'المدونة العامة للضرائب، المادة 123-22°',
      },
      {
        nom: 'ليزينغ من نوع «Energy Lease» لدى Maghrebail',
        body: 'منتج ائتمان إيجاري مُسمّى، يُغطّي صراحةً التركيبات الكهروضوئية، مع إعانة استثمار مُدمَجة لمشاريع الطاقة المتجددة. الشروط والسقوف يحدّدها Maghrebail — لا نضمن أي شرط بنكي.',
        source: 'maghrebail.ma',
      },
    ],
  },
  {
    segment: 'السكني',
    items: [
      {
        nom: 'قروض بنكية خضراء',
        body: 'تقترح بعض البنوك المغربية، حالة بحالة، خطوط ائتمان تُسمّى «خضراء» قد تُغطّي مشروعاً شمسياً سكنياً. لم نتمكّن حتى اليوم من التحقق من أن مؤسسة مُسمّاة تُقدّم عرضاً مخصّصاً للسكني الشمسي — لذا لا نُسمّي أي بنك هنا: استفسر مباشرة لدى بنكك.',
        source: 'غير مُتحقَّق منه — لا بنك مُسمّى إلى أن يُؤكَّد',
      },
    ],
  },
];
---

<Layout
  title="مردودية وتمويل الطاقة الشمسية بالمغرب: عائد في 3–7 سنوات | Taqinor"
  description="ما تدرّه فعلاً تركيبة شمسية بالمغرب: تُسدَّد تقريباً في 3 إلى 7 سنوات بفضل الكهرباء التي تتوقف عن شرائها (تعريفة ONEE)، ثم 25 سنة من الأداء المضمون و60 إلى 90 % من الفاتورة مغطّاة. كيف تموّلها دون التواء — تاكينور تركّب وتضمن، لكنها ليست مُقرضاً."
  ogSlug="accueil"
>
  <div class="v2">
    <V2Enhance />
    <Article33Ribbon />

    <Breadcrumb items={[{ label: 'الرئيسية', href: L('/') }, { label: 'التمويل والمردودية' }]} />

    <!-- الفصل الأول — استهلال داكن: الاستثمار الذي يُسدّد نفسه -->
    <section class="px-4 pb-10 pt-16 text-white sm:pt-20">
      <div class="mx-auto max-w-3xl">
        <p class="tech-label v2-kicker rule-brass cine-in text-lune">المردودية</p>
        <h1 class="display v2-page-title cine-in mt-5 [animation-delay:120ms]">الاستثمار الذي يُسدّد نفسه، ثم يدفع لك</h1>
        <p class="v2-lead cine-in mt-6 max-w-xl text-white/85 [animation-delay:240ms]">
          التركيبة في حدود 80 000 درهم لفيلا — استثمار حقيقي، لا أداة ترفيه. حين تُحدَّد بدقة،
          <strong class="text-white">تُستهلَك تقريباً في 3 إلى 7 سنوات</strong> بفضل الكهرباء التي
          تتوقف عن شرائها من الشبكة، مُقيَّمة بتعريفة المكتب الوطني ONEE. بعد هذه النقطة، تبقى خمس عشرة
          سنة تقريباً من أصل 25 سنة مضمونة يكون فيها تيارك <strong class="text-white">شبه مجاني</strong>.
        </p>
      </div>
    </section>

    <!-- الاستثمار بالأرقام -->
    <section class="px-4 pb-20 sm:pb-24">
      <div class="mx-auto max-w-6xl">
        <p class="tech-label v2-kicker rule-brass text-lune">الاستثمار بالأرقام</p>
        <h2 class="display v2-section-title mt-5 text-white">أرتاب حجم — لا عرض ثمن أبداً</h2>
        <p class="v2-lead mt-4 max-w-2xl text-lune-soft">
          الشرائح أدناه هي نفسها الموجودة في صفحتي السكني والمهني — لا واحدة منها مُضخَّمة لهذه الصفحة.
          أما الرقم الدقيق لمردوديتك <em>أنت</em> فيُحتسب على فاتورتك الفعلية؛ وإن لم تكن الطاقة الشمسية
          الاستثمار الصحيح لملمحك، سنخبرك دون التواء.
        </p>
        <dl class="mt-10 grid grid-cols-2 gap-x-6 gap-y-10 border-s-2 border-brass-400/60 ps-6 sm:grid-cols-4 sm:ps-10" data-stagger>
          {chiffres.map((c, i) => (
            <div class="v2-rise" style={`--v2-i:${i}`}>
              <dd class="fig lum whitespace-nowrap text-3xl sm:text-4xl" dir="ltr" data-tally>{c.v}</dd>
              <dt class="tech-label mt-2 text-lune-faint">{c.label}</dt>
            </div>
          ))}
        </dl>
        <p class="mt-8 max-w-2xl text-sm leading-relaxed text-lune-soft">
          كلما ثقُلت الفاتورة، أسرع العائد. لفيلا نموذجية، احسب في حدود
          <a href={L('/résidentiel')} class="border-b border-white/40 pb-0.5 font-semibold text-white transition-colors hover:border-white">4 إلى 6 سنوات في السكني</a>؛
          على مستودع، يضيّق أثر الحجم العائد إلى
          <a href={L('/professionnel')} class="border-b border-white/40 pb-0.5 font-semibold text-white transition-colors hover:border-white">3 إلى 5 سنوات لموقع مهني</a>.
          أما تحت 1 000 درهم من الفاتورة الشهرية، فيتجاوز العائد غالباً 7 سنوات — وسنخبرك بصراحة عوض
          أن نبيعك ما لا فائدة منه.
        </p>
      </div>
    </section>

    <!-- كيف تموّل — قسم واضح، صدق تام -->
    <div class="v2-seam" aria-hidden="true"></div>
    <section class="bg-blanc-azur px-4 pb-20 pt-10 text-encre sm:pb-24">
      <div class="mx-auto max-w-6xl">
        <p class="tech-label v2-kicker rule-brass text-azur-600">دون التواء</p>
        <h2 class="display v2-section-title mt-5">كيف تموّل — بكل شفافية</h2>
        <p class="v2-lead mt-4 max-w-2xl text-encre-soft">
          لنوضّح أمراً من البداية: نركّب ونضمن الطاقة الشمسية، ولا نبيع أي منتج مالي. إليك، دون تجميل،
          الطرق الثلاث التي يؤدّي بها زبناؤنا فعلاً ثمن تركيبتهم.
        </p>
        <div class="mt-10 grid gap-6 md:grid-cols-3" data-stagger>
          {moyens.map((m, i) => (
            <div class="v2-rise flex flex-col border-t-2 border-azur-900 bg-blanc p-7" style={`--v2-i:${i}`}>
              <p class="fig text-3xl text-azur-600" dir="ltr">{m.k}</p>
              <h3 class="display mt-2 text-xl">{m.title}</h3>
              <p class="mt-3 flex-1 text-sm leading-relaxed text-encre-soft">{m.body}</p>
            </div>
          ))}
        </div>

        <!-- التوضيحات الصادقة -->
        <div class="mt-10 max-w-3xl border-s-4 border-azur-600 bg-blanc px-5 py-5 text-sm leading-relaxed text-encre-soft">
          <p class="tech-label text-azur-600">ما ينبغي معرفته، بالأبيض والأسود</p>
          <ul class="mt-4 space-y-2.5">
            <li><strong class="text-encre">تاكينور ليست هيئة قرض</strong> ولا مُقرضاً: لا نمنح أي تمويل ولا نتقاضى أي عمولة بنكية.</li>
            <li><strong class="text-encre">لا توجد أي إعانة سكنية خاصة</strong> لتركيبة شمسية لفرد بالمغرب — احذر أي وعد من هذا النوع.</li>
            <li><strong class="text-encre">لا إعفاء من الضريبة على القيمة المضافة في السكني</strong>: تُطبَّق الضريبة على تركيبة كاملة جاهزة بالمفتاح. لن نَعِدك بعكس ذلك.</li>
            <li>للمقاولات، توجد بالمغرب <strong class="text-encre">خطوط تمويل أخضر</strong> لمشاريع الطاقات المتجددة، لكن بنكك هو من يقرّر — لا نسمّي أي مؤسسة ولا نضمن أي شروط.</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- W258 — آليات مُسمّاة ومُتحقَّق منها حسب القطاع (WG11) -->
    <div class="v2-seam" aria-hidden="true"></div>
    <section class="px-4 py-20 sm:py-24">
      <div class="mx-auto max-w-6xl">
        <p class="tech-label v2-kicker rule-brass text-lune">ما يوجد فعلاً، مُسمّى</p>
        <h2 class="display v2-section-title mt-5 text-white">الآليات المغربية المُتحقَّق منها، حسب الملمح</h2>
        <p class="v2-lead mt-4 max-w-2xl text-lune-soft">
          كل اسم مذكور أدناه تم التحقق منه لدى مصدر أساسي وقت نشر هذه الصفحة — لا شراكة أبداً لا نملكها
          فعلياً. ما لم نتمكّن من التحقق منه لا يظهر هنا.
        </p>
        <div class="mt-10 grid gap-8 md:grid-cols-3" data-stagger>
          {mecanismes.map((seg, i) => (
            <div class="v2-rise border-t-2 border-brass-400/60 pt-5" style={`--v2-i:${i}`}>
              <h3 class="display text-xl text-white">{seg.segment}</h3>
              <div class="mt-4 space-y-5">
                {seg.items.map((it) => (
                  <div>
                    <p class="font-display text-base font-bold text-white">{it.nom}</p>
                    <p class="mt-1.5 text-sm leading-relaxed text-lune-soft">{it.body}</p>
                    <p class="tech-label mt-1.5 text-lune-faint">المصدر: {it.source}</p>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- W336 — رافعتان ضريبيتان: المادة 123-22° للضريبة على القيمة المضافة +
         الإهلاك. WG16 (المراجعة القانونية) لا تزال جارية: ملاحظة «رهن التحقق»
         ظاهرة. للمقاولات (السكني يبقى بدون إعفاء ضريبي — التوضيح منشور أعلاه). -->
    <div class="v2-seam" aria-hidden="true"></div>
    <section class="bg-blanc-azur px-4 pb-20 pt-16 text-encre sm:pb-24">
      <div class="mx-auto max-w-4xl">
        <p class="tech-label v2-kicker rule-brass text-azur-600">للمقاولات · الرافعتان اللتان لا يذكرهما أحد</p>
        <h2 class="display v2-section-title mt-5">الضريبة على القيمة المضافة عند الاستيراد والإهلاك: ما تقوله المدونة</h2>
        <p class="v2-lead mt-4 max-w-2xl text-encre-soft">
          مادتان قانونيتان حقيقيتان وقابلتان للتحقق تصبّان في صالح تركيبة شمسية مهنية مُسجَّلة في أصول
          شركتكم — ليست شروطاً تفاوضت عليها تاكينور، بل أحكام مفتوحة في المدونة العامة للضرائب.
        </p>
        <div class="mt-8 grid gap-6 sm:grid-cols-2">
          <div class="border-t-2 border-azur-900 bg-blanc p-6">
            <p class="fig text-lg text-azur-600">المدونة العامة للضرائب · المادة 123-22°</p>
            <h3 class="display mt-2 text-lg">إعفاء من الضريبة على القيمة المضافة عند الاستيراد</h3>
            <p class="mt-3 text-sm leading-relaxed text-encre-soft">
              يُعفى من الضريبة على القيمة المضافة تجهيز استثماري مُسجَّل في الأصول الثابتة، مستورَد من
              طرف شركة خاضعة للضريبة خلال 36 شهراً من بداية نشاطها — رهن تكوين الضمانات التي تطلبها
              الإدارة الضريبية.
            </p>
          </div>
          <div class="border-t-2 border-azur-900 bg-blanc p-6">
            <p class="fig text-lg text-azur-600">الإهلاك</p>
            <h3 class="display mt-2 text-lg">20 سنة، خطي، 5 % في السنة</h3>
            <p class="mt-3 text-sm leading-relaxed text-encre-soft">
              تُهلَك التركيبة الشمسية محاسبياً كمعدّة إنتاج عادية: بشكل خطي على مدى 20 سنة، أي 5 % من
              قيمتها كل سنة تُخصَم من النتيجة الخاضعة للضريبة.
            </p>
          </div>
        </div>
        <p class="mx-auto mt-8 max-w-2xl border-s-4 border-azur-600 ps-4 text-sm leading-relaxed text-encre-soft">
          <strong class="text-encre">رهن التحقق (مراجعة قانونية جارية):</strong> يُمدّد قانون المالية
          الأحدث، بالنسبة لبعض الشركات المرتبطة باتفاقية مع الدولة، مدة إعفاء الضريبة على القيمة
          المضافة عند الاستيراد إلى ما بعد 36 شهراً القياسية — نقطة لا تنطبق بنفس الشكل على كل
          الشركات. تأكّدوا من وضعيتكم الدقيقة مع خبيركم المحاسبي قبل أي قرار.
        </p>
      </div>
    </section>

    <!-- الدراسة تحتسب مردوديتك أنت -->
    <section class="px-4 py-20 sm:py-28">
      <div class="mx-auto grid max-w-6xl gap-10 lg:grid-cols-[1.1fr_1fr] lg:items-center">
        <div class="v2-rise">
          <p class="tech-label v2-kicker rule-brass text-lune">مردوديتك، لا معدّل</p>
          <h2 class="display v2-section-title mt-5 text-white">الدراسة تحتسب مردودية فاتورتك</h2>
          <p class="v2-lead mt-5 text-lune-soft">
            كل ما سبق يبقى أرتاب حجم. رقمك — ما توفّره كل شهر، والسنة التي سدّدت فيها التركيبة نفسها —
            يخرج من ثلاث معطيات لا تخصّ سواك: فاتورتك، ملمح استهلاكك، سطحك. نُمرّرها في الحساب، والنتيجة
            لك، لا معدّل مطوية.
          </p>
          <a href={devisHref} class="mt-8 inline-block bg-brass-400 px-7 py-3.5 text-base font-bold text-azur-950 transition-colors hover:bg-brass-300">احسب مردوديتي — دراسة بـ 0 درهم</a>
        </div>
        <dl class="grid grid-cols-2 gap-x-6 gap-y-10 border-s-2 border-brass-400/60 ps-6 sm:ps-10" data-stagger>
          <div class="v2-rise" style="--v2-i:0">
            <dd class="fig lum whitespace-nowrap text-3xl sm:text-5xl" dir="ltr" data-tally>0 MAD</dd>
            <dt class="tech-label mt-2 text-lune-faint">الدراسة والتشخيص</dt>
          </div>
          <div class="v2-rise" style="--v2-i:1">
            <dd class="fig lum whitespace-nowrap text-3xl sm:text-5xl" dir="ltr" data-tally>25 سنة</dd>
            <dt class="tech-label mt-2 text-lune-faint">أداء مضمون (≥ 84.8 %)</dt>
          </div>
          <div class="v2-rise" style="--v2-i:2">
            <dd class="fig lum whitespace-nowrap text-3xl sm:text-5xl" dir="ltr" data-tally>3–7 سنوات</dd>
            <dt class="tech-label mt-2 text-lune-faint">العائد على الاستثمار النموذجي</dt>
          </div>
          <div class="v2-rise" style="--v2-i:3">
            <dd class="font-display text-xl font-bold text-white">تعريفة ONEE</dd>
            <dt class="tech-label mt-2 text-lune-faint">أساس حساب الكهرباء المُتجنَّبة</dt>
          </div>
        </dl>
      </div>
    </section>

    <!-- روابط سياقية -->
    <section class="border-t border-white/10 px-4 py-16">
      <div class="mx-auto flex max-w-6xl flex-wrap gap-3">
