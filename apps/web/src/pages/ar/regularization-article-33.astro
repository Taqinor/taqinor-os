---
/**
 * AR — Article 33 regularization (W67, RTL). Faithful Arabic translation of
 * /regularization-article-33 ; no new figure or claim (law number 82-21,
 * Article 33, decree 2-25-100, date 9 June 2026 and all amounts kept exact, in
 * Latin digits). Internal links use localizeNavHref (EN/AR if available, else
 * the existing FR page — never a dead link). FR untouched.
 *
 * ÉLÉVATION (W241) — mirrors the FR regularization-article-33.astro elevation:
 *  1. brass discipline: eyebrow text-lune (not text-brass-300);
 *  2. timeline steps: solid brass discs → fig lum numbers in azur rings (bg-nuit);
 *  3. timeline rail: border-brass-400/60 → border-white/15;
 *  4. diamond bullets: border-brass-400 → border-azur-200/70;
 *  5. .section + seam-soft tokens;
 *  6. glow on primary CTA WhatsApp button;
 *  7. RTL structural fixes preserved from original AR page.
 */
import Layout from '../../layouts/Layout.astro';
import V2Enhance from '../../components/V2Enhance.astro';
import Article33Ribbon from '../../components/Article33Ribbon.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import StickyCta from '../../components/StickyCta.astro';
import ZelligeDivider from '../../components/ZelligeDivider.astro';
import { WHATSAPP_LEADS } from '../../lib/nap';
import { whatsappLink, regularizationWhatsappText } from '../../lib/whatsapp';
import { getLocaleFromPath } from '../../i18n/utils';
import { localizeNavHref } from '../../i18n/pages';

const locale = getLocaleFromPath(Astro.url.pathname);
const L = (href: string) => localizeNavHref(href, locale);

const waFallback = whatsappLink(WHATSAPP_LEADS, regularizationWhatsappText());

const steps = [
  { title: 'الجرد التقني', body: 'معاينة التركيبة القائمة: القدرة المُركّبة، نمط الربط، مستوى الجهد، معدات الحماية والعدّ.' },
  { title: 'تحديد النظام', body: 'حسب القدرة والربط، تندرج التركيبة ضمن التصريح أو اتفاق الربط أو الترخيص (مرسوم 2-25-100).' },
  { title: 'تكوين الملف', body: 'بطاقات تقنية، مخطط أحادي الخط، شهادات المطابقة واستمارات النظام المطبَّق — مُعدّة من طرفنا.' },
  { title: 'إيداع طلب التسوية', body: 'الإيداع لدى مدبّر الشبكة أو السلطة المختصة، في إطار النافذة التي تفتحها المادة 33.' },
  { title: 'المتابعة حتى المطابقة', body: 'متابعة الدراسة، الردّ على المستندات التكميلية المطلوبة، وعند الاقتضاء تحيين تقني للتركيبة.' },
];

const sanctions = [
  { title: 'وضعية غير قانونية', body: 'تركيبة قائمة غير مُسوّاة هي في وضعية غير قانونية إزاء القانون 82-21، الساري المفعول الآن.' },
  { title: 'غرامات — المادة 28', body: 'من 2 000 إلى 5 000 MAD للاستغلال دون التصريح المطلوب.' },
  { title: 'غرامات — المادة 29', body: 'من 100 000 إلى 1 000 000 MAD للاستغلال دون اتفاق ربط أو دون ترخيص.' },
  { title: 'الإنذار والإيقاف — المادة 25', body: 'خطر إنذار ثم أمر بإيقاف التركيبة.' },
  { title: 'الفصل عن الشبكة — المادة 32', body: 'يمكن لمدبّر الشبكة فصل تركيبة غير مطابقة.' },
];
---

<Layout
  title="تسوية المادة 33 — التركيبات الشمسية القائمة | Taqinor"
  description="القانون 82-21 ساري المفعول منذ 9 يونيو 2026. المادة 33 تفتح نافذة من 18 شهراً لتسوية التركيبات الشمسية القائمة: مسطرة من 5 مراحل، العقوبات المحتملة، وتكفّل كامل بالملف."
  ogSlug="article-33"
>
  <div class="v2">
    <V2Enhance />
    <Article33Ribbon />

    <Breadcrumb items={[{ label: 'الرئيسية', href: L('/') }, { label: 'تسوية المادة 33' }]} />

    <section class="section px-4 text-white">
      <div class="mx-auto max-w-6xl">
        {/* eyebrow مُخفَّض إلى lune (انضباط النحاس) */}
        <p class="tech-label v2-kicker rule-brass cine-in text-lune">القانون 82-21 — المادة 33</p>
        <h1 class="display v2-page-title cine-in cine-in-1 mt-5 max-w-3xl">تركيبتك الشمسية قائمة بالفعل؟ سوّها الآن.</h1>
        <p class="v2-lead cine-in cine-in-2 mt-6 max-w-xl text-white/85">
          المرسوم 2-25-100، الذي نُشِر بالجريدة الرسمية في 9 مارس 2026، دخل حيّز التنفيذ في
          9 يونيو 2026، وقرار ANRE يحدّد تعريفة شراء الفائض؛ ومنذ ذلك التاريخ يُطبَّق نظام
          القانون 82-21 على جميع تركيبات الإنتاج الذاتي — حتى تلك المُركّبة قبل صدور النص بزمن.
        </p>
      </div>
    </section>

    <div class="seam-soft" aria-hidden="true"></div>
    <section class="section mx-auto max-w-3xl px-4">
      <div class="v2-rise">
        {/* eyebrow مُخفَّض إلى lune */}
        <p class="tech-label v2-kicker rule-brass text-lune">النص</p>
        <h2 class="display v2-section-title mt-4 text-white">ما تقوله المادة 33</h2>
        <p class="v2-lead mt-5 text-lune-soft">
          المادة 33 من القانون 82-21 تمنح مستغلّي التركيبات القائمة
          نافذة من <strong class="fig lum text-xl">18 شهراً</strong> لإيداع طلب تسوية.
          هذه النافذة مفتوحة منذ 9 يونيو 2026: أودِع الآن. تركيبة مُسوّاة مؤمَّنة قانونياً؛
          تركيبة غير مُسوّاة في وضعية غير قانونية.
        </p>
      </div>

      <h2 class="display v2-section-title v2-rise mt-14 text-white">من المعني؟</h2>
      {/* معيّنات بحدود azur (الذهب يبقى للأرقام/CTA) */}
      <ul class="v2-rise mt-5 space-y-2.5 text-sm leading-relaxed text-lune-soft">
        <li class="flex gap-2.5"><span class="mt-1.5 inline-block h-1.5 w-1.5 flex-none rotate-45 border border-azur-200/70" aria-hidden="true"></span><span>كل تركيبة شمسية للإنتاج الذاتي شُغّلت قبل دخول النظام حيّز التنفيذ — فيلا، مستودع، فندق، ضيعة فلاحية.</span></li>
        <li class="flex gap-2.5"><span class="mt-1.5 inline-block h-1.5 w-1.5 flex-none rotate-45 border border-azur-200/70" aria-hidden="true"></span><span>مربوطة بالشبكة أو في موقع معزول، أياً كانت القدرة.</span></li>
        <li class="flex gap-2.5"><span class="mt-1.5 inline-block h-1.5 w-1.5 flex-none rotate-45 border border-azur-200/70" aria-hidden="true"></span><span>دون تصريح، دون اتفاق ربط أو دون ترخيص إزاء النظام المطبَّق.</span></li>
      </ul>

      <h2 class="display v2-section-title v2-rise mt-14 text-white">التسوية في 5 مراحل</h2>
      {/* خط الجدول الزمني خُفِّف؛ أرقام الخطوات .lum في حلقة azur — لا قرص نحاسي */}
      <ol class="mt-8 border-s-2 border-white/15 ar-timeline" data-stagger>
        {steps.map((s, i) => (
          <li class="v2-rise relative pb-8 ps-8 last:pb-0" style={`--v2-i:${i}`}>
            <span class="fig lum ar-timeline-step absolute flex h-10 w-10 items-center justify-center rounded-full border border-azur-200/40 bg-nuit text-lg">{i + 1}</span>
            <h3 class="display pt-1.5 text-lg text-white">{s.title}</h3>
            <p class="mt-1.5 text-sm leading-relaxed text-lune-soft">{s.body}</p>
          </li>
        ))}
      </ol>

      <h2 class="display v2-section-title v2-rise mt-14 text-white">ما تخاطر به إن لم تفعل شيئاً</h2>
      <p class="v2-rise mt-2 text-sm text-lune-soft">العقوبات المنصوص عليها في القانون 82-21:</p>
      <div class="mt-5 grid gap-4 sm:grid-cols-2" data-stagger>
        {sanctions.map((s, i) => (
          <div class="v2-rise cine-card border-alert-300/30 p-5" style={`--v2-i:${i}`}>
            <h3 class="font-display text-sm font-bold text-alert-300">{s.title}</h3>
            <p class="mt-1.5 text-sm leading-relaxed text-lune-soft">{s.body}</p>
          </div>
        ))}
      </div>

      <div class="mt-8 flex flex-wrap gap-3">
        <a href={L('/loi-82-21')} class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">الأنظمة الثلاثة للقانون 82-21 <span class="inline-block rtl:-scale-x-100">→</span></a>
        <a href={L('/professionnel')} class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">تسوية موقع مهني <span class="inline-block rtl:-scale-x-100">→</span></a>
      </div>
    </section>

    <!-- ACTE FINAL — le dossier se confie en pleine lumière -->
    <div class="v2-seam" aria-hidden="true"></div>
    <section class="bg-blanc-azur px-4 pb-16 pt-4 text-encre">
      <div class="mx-auto max-w-3xl">
        <ZelligeDivider />
        <div class="v2-rise mt-6 border-2 border-azur-600 bg-blanc p-8 sm:p-10">
          <p class="tech-label text-azur-600">تكفّل كامل</p>
          <h2 class="display v2-section-title mt-2">اعهد إلينا بالملف</h2>
          <p class="mt-4 max-w-md text-sm leading-relaxed text-encre-soft">
            سؤالان، ورسالة واتساب تنطلق كاملة بالفعل — نحدّد النظام المطبَّق ونكوّن الملف.
          </p>
          <div class="mt-6 grid gap-4 sm:grid-cols-2">
            <div>
              <label for="rg33-kwc" class="mb-1 block text-sm font-semibold">القدرة التقريبية (kWc)</label>
              <input id="rg33-kwc" type="number" min="0" step="0.1" inputmode="decimal" placeholder="مثلاً 5"
                class="w-full border border-azur-900/20 bg-blanc px-3 py-2.5 text-sm outline-none transition-colors focus:border-azur-600 focus:ring-2 focus:ring-azur-600/25" />
              <label class="mt-2 flex items-center gap-2 text-xs text-encre-soft">
                <input id="rg33-unknown" type="checkbox" class="accent-azur-600" />
                لا أعرف القدرة
              </label>
            </div>
            <div>
              <label for="rg33-ville" class="mb-1 block text-sm font-semibold">مدينة التركيبة</label>
              <input id="rg33-ville" type="text" autocomplete="address-level2" placeholder="مثلاً الدار البيضاء"
                class="w-full border border-azur-900/20 bg-blanc px-3 py-2.5 text-sm outline-none transition-colors focus:border-azur-600 focus:ring-2 focus:ring-azur-600/25" />
            </div>
          </div>
          <a id="rg33-go" href={waFallback} rel="noopener"
            class="glow mt-6 inline-block bg-brass-400 px-7 py-3.5 text-base font-bold text-azur-950 transition-colors hover:bg-brass-300"
          >ابدأ على واتساب</a>
        </div>
      </div>
    </section>

    <StickyCta />
  </div>
</Layout>

<style>
  /*
   * W214 — RTL structural fix: timeline dots.
   * In RTL, the inline-start side is the RIGHT. The timeline rail uses
   * border-s-2 (logical = border-inline-start = right in RTL).
   * The step circle is positioned absolutely at the inline-start edge.
   */
  [dir="rtl"] .ar-timeline {
    /* border-inline-start already correct via border-s-2 */
  }
  [dir="rtl"] .ar-timeline > li {
    padding-inline-start: 2rem; /* ps-8 = 2rem */
  }
  [dir="rtl"] .ar-timeline .ar-timeline-step {
    /* position at inline-start edge (right in RTL), inset -1.25rem */
    inset-inline-start: -1.25rem;
    inset-inline-end: auto;
  }
  /* LTR fallback */
  [dir="ltr"] .ar-timeline .ar-timeline-step {
    left: -1.25rem;
  }
</style>

<script>
  import { whatsappLink, regularizationWhatsappText } from '../../lib/whatsapp';
  import { WHATSAPP_LEADS } from '../../lib/nap';

  // Le lien se met à jour en direct : le client n'édite JAMAIS le message.
  const kwcEl = document.getElementById('rg33-kwc') as HTMLInputElement;
  const unknownEl = document.getElementById('rg33-unknown') as HTMLInputElement;
  const villeEl = document.getElementById('rg33-ville') as HTMLInputElement;
  const goEl = document.getElementById('rg33-go') as HTMLAnchorElement;

  function refresh() {
    kwcEl.disabled = unknownEl.checked;
    if (unknownEl.checked) kwcEl.value = '';
    goEl.href = whatsappLink(
      WHATSAPP_LEADS,
      regularizationWhatsappText({
        kwc: unknownEl.checked ? '' : kwcEl.value,
        ville: villeEl.value,
      }),
    );
  }
  for (const el of [kwcEl, unknownEl, villeEl]) el.addEventListener('input', refresh);
  refresh();
</script>
