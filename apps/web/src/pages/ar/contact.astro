---
/**
 * AR — Contact (W67). Faithful Arabic (RTL) translation of /contact ; FR
 * untouched. The lead form keeps an IDENTICAL data flow in every locale: same
 * payload, same /api/simulate endpoint, same 1 000 MAD threshold, same WhatsApp
 * deeplink — only the VISIBLE labels are localised. Latin brand names, phone
 * and email stay LTR via dir="ltr" spans inside the RTL page.
 */
import Layout from '../../layouts/Layout.astro';
import V2Enhance from '../../components/V2Enhance.astro';
import Article33Ribbon from '../../components/Article33Ribbon.astro';
import DiagnosticForm from '../../components/DiagnosticForm.astro';
import StarRating from '../../components/StarRating.astro';
import { NAP, WHATSAPP_LEADS } from '../../lib/nap';
import { whatsappLink, regularizationWhatsappText } from '../../lib/whatsapp';

// Deeplinks built server-side with the SAME WhatsApp leads number; the
// pre-filled text stays French (it reaches the French-speaking sales team).
const waGeneral = whatsappLink(WHATSAPP_LEADS, 'Bonjour, je souhaite une étude pour une installation solaire.');
const waRegul = whatsappLink(WHATSAPP_LEADS, regularizationWhatsappText());

// W285 — «زيارة ورش» تصبح فعلاً: نفس دعوة pourquoi-taqinor.astro، هنا في
// شكل رابط واتساب مباشر بدل رابط بسيط نحو /realisations. النص المُعبَّأ
// مسبقاً يبقى بالفرنسية (نفس فريق البيع يقرأ كل روابط واتساب في الموقع).
const waVisite = whatsappLink(
  WHATSAPP_LEADS,
  'Bonjour, je souhaite visiter une installation réelle Taqinor avant de me décider.',
);

// W339 — باب SAV/الأعطال «هل أنت زبون بالفعل؟»، منفصل عن ويبهوك العملاء
// المحتملين التجاري (DiagnosticForm أعلاه، دون تغيير). النص مُعبَّأ مسبقاً
// يبقى بالفرنسية (نفس فريق البيع/الصيانة) لكنه يحدد صراحة بلاغ عطل على
// تركيبة قائمة، ليُوجَّه بشكل مختلف عن طلب عرض ثمن.
const waSav = whatsappLink(
  WHATSAPP_LEADS,
  'Bonjour, je suis déjà client Taqinor et je signale un problème sur mon installation existante (SAV). Merci de me recontacter.',
);
---

<Layout
  title="اتصال — دراسة شمسية مجانية | Taqinor"
  description="اطلب دراستك الشمسية المجانية: نموذج تقدير فوري، واتساب مباشر، تدخّل في كامل المغرب. رد خلال 48 ساعة عمل."
  ogSlug="contact"
>
  <div class="v2">
    <V2Enhance />
    <Article33Ribbon />

    <section class="px-4 py-20 text-white">
      <div class="mx-auto max-w-6xl">
        <p class="tech-label v2-kicker rule-brass cine-in text-brass-300">رد خلال 48 ساعة عمل</p>
        <h1 class="display v2-page-title cine-in mt-5 max-w-2xl [animation-delay:120ms]">لنتحدّث عن تركيبتك</h1>
        <p class="v2-lead cine-in mt-5 max-w-xl text-white/85 [animation-delay:240ms]">
          يمنحك النموذج شريحة فورية. وللذهاب أسرع، راسلنا مباشرة عبر واتساب.
        </p>
        {/* W280 — StarRating: تقييم Google حقيقي فقط، آمن بدون بيانات (لا
            يعرض شيئاً حتى يوفّر المؤسّس تقييماً حقيقياً). */}
        <div class="cine-in mt-6 [animation-delay:320ms]">
          <StarRating />
        </div>
      </div>
    </section>

    <DiagnosticForm heading="تشخيص شمسي — تقدير فوري" />

    <!-- لا نزال في الفصل المضيء: اختصارات واتساب وبطاقة NAP -->
    <section class="bg-blanc-azur px-4 pb-16 text-encre">
      <div class="mx-auto max-w-3xl">
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3" data-stagger>
          <a href={waGeneral} rel="noopener"
            class="v2-rise group border border-azur-900/15 bg-blanc p-6 text-center transition-all hover:-translate-y-0.5 hover:border-azur-600 hover:shadow-[0_14px_40px_-16px_rgb(15_28_84/0.4)]" style="--v2-i:0">
            <p class="tech-label text-azur-600">مشروع جديد</p>
            <p class="mt-2 font-display font-bold">واتساب — تركيبة جديدة</p>
            <p class="mt-1 text-sm text-encre-soft">دراسة وعرض ثمن لمشروع جديد</p>
          </a>
          <a href={waRegul} rel="noopener"
            class="v2-rise group border border-azur-900/15 bg-blanc p-6 text-center transition-all hover:-translate-y-0.5 hover:border-azur-600 hover:shadow-[0_14px_40px_-16px_rgb(15_28_84/0.4)]" style="--v2-i:1">
            <p class="tech-label text-azur-600">المادة 33</p>
            <p class="mt-2 font-display font-bold">واتساب — التسوية</p>
            <p class="mt-1 text-sm text-encre-soft">تركيبة قائمة لتسويتها قانونياً</p>
          </a>
          {/* W285 — «زيارة ورش» تصبح فعلاً: نفس دعوة pourquoi-taqinor.astro،
              في شكل رابط واتساب مباشر. */}
          <a href={waVisite} rel="noopener"
            class="v2-rise group border border-azur-900/15 bg-blanc p-6 text-center transition-all hover:-translate-y-0.5 hover:border-azur-600 hover:shadow-[0_14px_40px_-16px_rgb(15_28_84/0.4)]" style="--v2-i:2">
            <p class="tech-label text-azur-600">اطّلع قبل أن توقّع</p>
            <p class="mt-2 font-display font-bold">واتساب — زيارة ورش</p>
            <p class="mt-1 text-sm text-encre-soft">أرغب في زيارة تركيبة حقيقية</p>
          </a>
        </div>

        <div class="v2-rise mt-8 border border-azur-900/15 bg-blanc-azur p-7 text-center text-sm">
          <p class="font-display text-lg font-bold" dir="ltr">{NAP.name}</p>
          <p class="mt-2">
            <a href={`tel:${NAP.phone}`} dir="ltr" class="font-semibold underline decoration-azur-600 decoration-2 underline-offset-4">{NAP.phoneDisplayIntl}</a>
            &nbsp;·&nbsp;
            <a href={`mailto:${NAP.email}`} dir="ltr" class="underline decoration-azur-600 decoration-2 underline-offset-4">{NAP.email}</a>
          </p>
          <p class="mt-3 text-encre-soft">
            منطقة التدخل: محور الدار البيضاء–الرباط، و{NAP.serviceArea.slice(2, -1).join('، ')} على الطلب.
          </p>
          <p class="mt-1 text-xs text-encre-faint">زيارات ميدانية فقط — لا استقبال للعموم في وكالة.</p>
        </div>
      </div>
    </section>

    <!-- W339 — باب SAV/الأعطال «هل أنت زبون بالفعل؟»، منفصل بصرياً ووظيفياً
         عن قسم الدراسة أعلاه. واتساب مُعبَّأ مسبقاً يُبلّغ عن عطل، مُوجَّه إلى
         فريق الصيانة — أبداً ويبهوك العملاء المحتملين التجاري. -->
    <section id="deja-client" class="border-t border-azur-900/10 bg-blanc px-4 py-16 text-encre">
      <div class="mx-auto max-w-2xl">
        <div class="v2-rise border-2 border-azur-600/40 bg-blanc-azur p-7 text-center sm:p-9">
          <p class="tech-label text-azur-600">هل أنت زبون بالفعل؟</p>
          <h2 class="display mt-2 text-2xl font-bold sm:text-3xl">مشكل في تركيبتك؟</h2>
          <p class="mt-3 text-sm leading-relaxed text-encre-soft">
            ماذا تفعل إذا ظهر خطأ على شاشة العاكس (onduleur)؟ صوّر الشاشة وراسلنا عبر واتساب —
            أسرع طريقة للوصول إلى فريق الصيانة (SAV)، الذي يعالج بلاغك بشكل منفصل عن أي طلب جديد
            لعرض ثمن.
          </p>
          <div class="mt-6 flex flex-wrap items-center justify-center gap-3">
            <a
              href={waSav}
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 bg-brass-400 px-6 py-3 text-sm font-bold text-azur-950 transition-colors hover:bg-brass-300"
            >
              واتساب — الإبلاغ عن عطل (SAV)
            </a>
            <a
              href={`tel:${NAP.phone}`}
              dir="ltr"
              class="inline-flex items-center gap-2 border border-azur-900/25 px-6 py-3 text-sm font-semibold text-encre transition-colors hover:border-azur-600"
            >
              {NAP.phoneDisplayIntl}
            </a>
          </div>
        </div>
      </div>
    </section>
  </div>
</Layout>
