---
/**
 * AR — Solutions hub (W67, RTL). Faithful Arabic translation of /nos-solutions ;
 * no new figure or claim. Solution-card links use localizeNavHref (EN/AR if
 * available, else the existing FR page — never a dead link). FR untouched.
 *
 * W256/W262 — mirrors the FR additions: dedicated "free study" hub card +
 * section, honest "areas served" block.
 *
 * W253 — يرفع هذه الصفحة إلى مركز خدمات حقيقي: بطاقة شحن السيارة الكهربائية
 * مضافة (الصفحة موجودة لكنها كانت غير مرئية هنا)؛ شريط «كيف تموّل مشروعك»
 * (الأرقام مُعاد استخدامها حرفياً من /financement، دون أي مبلغ جديد)؛ روابط
 * متقاطعة مرئية نحو المعدات + الضمانات («ما الذي تحصل عليه»)؛ أيقونات + سطر
 * واحد «متى تختارها» لكل بطاقة؛ نص «ستة أوراش» + `hasPart` في JSON-LD أُعيد
 * حسابهما من العدد الحقيقي (`solutions.length`).
 */
import Layout from '../../layouts/Layout.astro';
import V2Enhance from '../../components/V2Enhance.astro';
import Article33Ribbon from '../../components/Article33Ribbon.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CtaBand from '../../components/CtaBand.astro';
import StickyCta from '../../components/StickyCta.astro';
import { getLocaleFromPath } from '../../i18n/utils';
import { localizeNavHref } from '../../i18n/pages';
import { NAP } from '../../lib/nap';

const locale = getLocaleFromPath(Astro.url.pathname);
const L = (href: string) => localizeNavHref(href, locale);
const devisHref = L('/devis/mon-toit');

// W262 — نفس مصدر NAP.serviceArea، دون 'Maroc' العامة في النهاية.
const villesDesservies = NAP.serviceArea.slice(0, -1);

const solutions = [
  {
    href: '/devis/mon-toit',
    title: 'الدراسة والتشخيص المجاني',
    summary:
      'مجاني، دون أي التزام: تصميم ثلاثي الأبعاد لسطحك مُقدَّم، ومقاس محسوب على فاتورتك الحقيقية — نقطة انطلاق كل حلولنا.',
    qualifier: 'اختر هذا أولاً — فهو الذي يحدّد كل الحلول الأخرى.',
    highlight: true,
  },
  {
    // W348 — مدخل مُسمّى «فاتورة» لنفس مسار الدراسة، مُهيَّأ مسبقاً على خطوة
    // الفاتورة عبر ?etape=facture (يُضاف بعد localizeNavHref حتى يبقى البحث
    // دوماً على المسار الجذري النظيف).
    // TODO(متابعة، خارج نطاق هذه المهمة): /devis/mon-toit لا تقرأ بعد
    // ?etape=facture لفتح لوحة الفاتورة مباشرة (انظر
    // apps/web/src/pages/devis/mon-toit.astro — `step` المُستعادة من
    // sessionStorage فقط). الرابط يصل اليوم إلى خطوة السطح (0) كأي رابط آخر
    // نحو هذا المسار؛ ربط هذا المُعامل مهمة منفصلة لأن هذا الملف خارج نطاق
    // هذه المهمة.
    href: '/devis/mon-toit',
    query: '?etape=facture',
    title: 'تحليل مجاني لفاتورتك',
    summary:
      'أدخل مبلغ فاتورة الكهرباء: نستخرج منه استهلاكك الحقيقي وشريحة فورية مُقدَّرة، دون المرور أولاً عبر معاينة السطح.',
    qualifier: 'اختر هذا إن لم تقس سطحك بعد، لكن فاتورتك في متناول يدك.',
  },
  {
    href: '/résidentiel',
    title: 'الطاقة الشمسية السكنية',
    summary:
      'فيلا أو شقة: نُحدّد المقاس حسب فاتورتك، لا حسب طقم جاهز، ويُرسَل تصريح القانون 82-21 مع الورش.',
    qualifier: 'لسكن — تصريح القانون 82-21 مشمول.',
  },
  {
    href: '/professionnel',
    title: 'الطاقة الشمسية المهنية والصناعية',
    summary:
      'مستودعات، مصانع، فنادق، عيادات: نهاجم بند الكهرباء، بالجهد المتوسط عند الحاجة، وفق قواعد القانون 82-21.',
    qualifier: 'لموقع مهني — حتى الجهد المتوسط عند الحاجة.',
  },
  {
    href: '/pompage-solaire',
    title: 'الضخ الشمسي',
    summary:
      'سقي على إيقاع الشمس، غالباً دون بطاريات، مضبوط على الصبيب والارتفاع المانومتري — ومُعفى من الضريبة في الفلاحة.',
    qualifier: 'للسقي الفلاحي — مقاس على صبيبك وارتفاعك المانومتري الحقيقيين.',
  },
  {
    href: '/batteries-stockage',
    title: 'البطاريات والتخزين',
    summary:
      'بطاريات Dyness LFP لفترة المساء أو استمرارية الخدمة، حين يبرّر منحنى استهلاكك ذلك.',
    qualifier: 'أضِفها إذا كان استهلاكك ليلياً بالأساس، أو إذا كان انقطاع التيار مكلفاً.',
  },
  {
    // W253 — صفحة موجودة لكن دون رابط وارد من هذا المركز.
    href: '/recharge-voiture-electrique-solaire',
    title: 'شحن السيارة الكهربائية بالطاقة الشمسية',
    summary:
      'اشحن سيارتك الكهربائية بالطاقة المنتجة على سطحك أنت، بدل السعر الكامل للشبكة.',
    qualifier: 'لبيت يقود (أو سيقود قريباً) سيارة كهربائية.',
  },
  {
    href: '/maintenance-monitoring',
    title: 'الصيانة والمراقبة',
    summary:
      'متابعة الإنتاج في الوقت الحقيقي مع ولوج للزبون عبر تطبيق، خدمة ما بعد البيع تتحرّك عند التنبيه وملف تقني كامل — الحياة بعد التركيب.',
    qualifier: 'مشمولة بعد التركيب — تستحق النظر أيضاً لتركيبة قائمة غير مُراقَبة.',
  },
  {
    href: '/regularization-article-33',
    title: 'تسوية القانون 82-21',
    summary:
      'تركيبة قائمة تُعاد إلى القانون عبر المادة 33.',
    qualifier: 'إذا لم تُصرَّح تركيبتك القائمة أبداً.',
  },
];

// W253 — نفس مجموعة الأيقونات (index.astro `solutionIcons`)، مفهرسة بالمسار
// الجذري حتى تُحلّ متغيرات سلسلة الاستعلام (مثل ?etape=facture) أيضاً.
const solutionIcons: Record<string, string> = {
  '/devis/mon-toit': '<path d="M4 13 12 5l8 8" /><path d="M6 11v8h12v-8" /><path d="M10 19v-4h4v4" /><path d="M9 9.5 12 8l3 1.5" />',
  '/résidentiel': '<path d="M4 13 12 5l8 8" /><path d="M6 11v8h12v-8" /><path d="M10 19v-4h4v4" />',
  '/professionnel': '<path d="M4 21V8l7-3v4l7-3v15" /><path d="M4 21h16" /><path d="M8 12h0M8 16h0M14 12h0M14 16h0" />',
  '/pompage-solaire': '<path d="M12 3v6" /><path d="M5 21c1.6-2 3.2-2 4.8 0s3.2 2 4.8 0 3.2-2 4.4 0" /><path d="M8 9h8l-2 6H10z" />',
  '/batteries-stockage': '<path d="M5 8h14v11H5z" /><path d="M9 5h6v3H9z" /><path d="M12 11v5" /><path d="M9.5 13.5h5" />',
  '/maintenance-monitoring': '<path d="M4 18 9 12l3 3 4-6 4 5" /><path d="M4 21h16" /><circle cx="9" cy="12" r="0.6" /><circle cx="16" cy="9" r="0.6" />',
  '/regularization-article-33': '<path d="M7 4h7l4 4v12H7z" /><path d="M14 4v4h4" /><path d="M9.5 14l1.5 1.5 3-3.5" />',
};
function iconFor(href: string): string {
  if (solutionIcons[href]) return solutionIcons[href];
  if (href === '/recharge-voiture-electrique-solaire') {
    return '<path d="M4 17V9a2 2 0 0 1 2-2h6l3 4h3a2 2 0 0 1 2 2v4" /><circle cx="7.5" cy="17.5" r="1.6" /><circle cx="16.5" cy="17.5" r="1.6" /><path d="M11 12v-5" /><path d="M9.5 7.5h3" />';
  }
  return '';
}

// W253 — العدد مُشتقّ من `solutions.length` (مصدر الحقيقة الوحيد)، لا يُنسخ يدوياً.
const solutionsCount = solutions.length;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'حلولنا الشمسية — Taqinor',
  hasPart: solutions.map((s) => ({
    '@type': 'Service',
    name: s.title,
    url: new URL(s.href, Astro.site).href,
  })),
};
---

<Layout
  title="حلولنا الشمسية بالمغرب | Taqinor"
  description={`${solutionsCount} مهن شمسية عند تاكينور — سكنية، مهنية وصناعية، ضخ فلاحي، شحن سيارة كهربائية، بطاريات وتخزين LFP، صيانة ومتابعة الإنتاج في الوقت الحقيقي، تسوية القانون 82-21 — كلها محسوبة من نفس التشخيص المجاني على فاتورتكم الحقيقية.`}
  ogSlug="nos-solutions"
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <div class="v2">
    <V2Enhance />
    <Article33Ribbon />

    <Breadcrumb items={[{ label: 'الرئيسية', href: L('/') }, { label: 'حلولنا' }]} />

    <section class="px-4 pb-10 pt-16 text-white sm:pt-20">
      <div class="mx-auto max-w-3xl">
        <p class="tech-label v2-kicker rule-brass cine-in text-lune">حلولنا</p>
        <h1 class="display v2-page-title cine-in mt-5 [animation-delay:120ms]">عرض شمسي لكل حاجة</h1>
        {/* W253 — العدد مُشتقّ من `solutions.length`، لا يُنسخ يدوياً. */}
        <p class="v2-lead cine-in mt-6 max-w-xl text-white/85 [animation-delay:240ms]">
          الفيلا والمستودع لا يُحدّد مقاسهما بنفس الطريقة؛ والضخ الفلاحي وتسوية تركيبة قائمة أقل من
          ذلك بكثير. {solutionsCount} حلول مختلفة إذن، لكن نقطة انطلاق واحدة: وضعك، مقيساً، قبل أي
          اختيار للمعدات. إليك الصورة كاملة.
        </p>
      </div>
    </section>

    <section class="px-4 pb-24 sm:pb-32">
      <div class="mx-auto grid max-w-6xl gap-6 md:grid-cols-3" data-stagger>
        {solutions.map((s, i) => (
          <a href={`${L(s.href)}${s.query ?? ''}`} class={`v2-rise cine-card group flex flex-col p-7 ${s.highlight ? 'border-2 border-brass-400/70' : ''}`} style={`--v2-i:${i}`}>
            <svg class="h-9 w-9 text-brass-400 transition-colors group-hover:text-brass-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={iconFor(s.href)} />
            <p class="tech-label mt-5 text-lune">{s.highlight ? 'مجاني · دون التزام' : 'حل'}</p>
            <h2 class="display mt-2 text-xl text-white">{s.title}</h2>
            <p class="mt-3 flex-1 text-sm leading-relaxed text-lune-soft">{s.summary}</p>
            <p class="mt-4 border-t border-white/10 pt-3 text-xs text-brass-300/90">{s.qualifier}</p>
            <span class="mt-5 inline-flex items-center gap-1 border-b-2 border-white/30 pb-0.5 text-sm font-bold text-white">اكتشف <span class="motion-safe:transition-transform motion-safe:duration-200 motion-safe:group-hover:translate-x-1 inline-block rtl:-scale-x-100" aria-hidden="true">→</span></span>
          </a>
        ))}
      </div>
    </section>

    {/* W256 — الدراسة كمنتج قائم بذاته، لا كخطوة إجرائية */}
    <section class="border-y border-white/10 px-4 py-16 sm:py-20">
      <div class="mx-auto max-w-3xl text-center">
        <p class="tech-label v2-kicker rule-brass text-lune">نقطة الانطلاق، مجاناً</p>
        <h2 class="display v2-section-title mt-5 text-white">الدراسة والتشخيص مجانيان — ودون أي التزام</h2>
        <p class="v2-lead mt-5 text-lune-soft">
          قبل أي اختيار للمعدات، ننطلق من فاتورتك الحقيقية ومن سطحك الفعلي. التصميم ثلاثي الأبعاد
          لسطحك مُقدَّم، والشريحة الفورية المحسوبة أيضاً: لا شيء يُلزمك بالمتابعة.
        </p>
        <div class="mx-auto mt-10 grid max-w-2xl gap-4 sm:grid-cols-3" data-stagger>
          <div class="v2-rise border-t-2 border-brass-400/60 pt-4" style="--v2-i:0">
            <p class="fig lum text-2xl">مجاني</p>
            <p class="mt-1 text-sm text-lune-soft">بدون أي رسوم، بدون مفاجآت</p>
          </div>
          <div class="v2-rise border-t-2 border-brass-400/60 pt-4" style="--v2-i:1">
            <p class="fig lum text-2xl">دون التزام</p>
            <p class="mt-1 text-sm text-lune-soft">أنت من يقرّر بعد، لا قبل</p>
          </div>
          <div class="v2-rise border-t-2 border-brass-400/60 pt-4" style="--v2-i:2">
            <p class="fig lum text-2xl">تصميم ثلاثي الأبعاد مُقدَّم</p>
            <p class="mt-1 text-sm text-lune-soft">لسطحك أنت، لا لنموذج عام</p>
          </div>
        </div>
        <a href={devisHref} class="mt-10 inline-block bg-brass-400 px-7 py-3.5 text-base font-bold text-azur-950 transition-colors hover:bg-brass-300">ابدأ تشخيصي المجاني</a>
        <p class="mt-6 text-sm text-lune-faint">
          هل تقود سيارة كهربائية؟ اكتشف أيضاً كيفية
          <a href={L('/recharge-voiture-electrique-solaire')} class="text-white underline underline-offset-2 hover:text-lune">شحن سيارتك بالطاقة الشمسية</a>،
          كم تكلفة <a href={L('/prix-panneaux-solaires-maroc')} class="text-white underline underline-offset-2 hover:text-lune">الألواح الشمسية بالمغرب</a>،
          أو تصفّح كل <a href={L('/guides')} class="text-white underline underline-offset-2 hover:text-lune">أدلّتنا</a> و<a href={L('/blog')} class="text-white underline underline-offset-2 hover:text-lune">مدوّنتنا</a>.
        </p>
      </div>
    </section>

    {/* W253 — «كيف تموّل مشروعك»: الأرقام مُعاد استخدامها حرفياً من
        /financement — لا مبلغ جديد هنا، فقط تذكير + رابط نحو التفاصيل الكاملة. */}
    <section class="section px-4">
      <div class="mx-auto max-w-4xl text-center">
        <p class="tech-label v2-kicker rule-brass text-lune">كيف تموّل مشروعك</p>
        <h2 class="display v2-section-title mt-5 text-white">ثلاث طرق للدفع، لا نفرض أياً منها</h2>
        <p class="v2-lead mt-5 text-lune-soft">
          نقداً، عبر قرض استهلاك بنكي كلاسيكي، أو تمويل أخضر للمقاولات — التفاوض يتم بينك وبين بنكك،
          ونحن لا نأخذ أي عمولة على أي منها.
        </p>
        <dl class="mx-auto mt-10 grid max-w-2xl grid-cols-2 gap-x-6 gap-y-8 sm:grid-cols-4" data-stagger>
          <div class="v2-rise min-w-0" style="--v2-i:0">
            <dd class="fig fig-md lum whitespace-nowrap"><span dir="ltr" style="unicode-bidi:isolate">3–7</span> سنوات</dd>
            <dt class="tech-label mt-2 text-lune-faint">عائد الاستثمار النموذجي</dt>
          </div>
          <div class="v2-rise min-w-0" style="--v2-i:1">
            <dd class="fig fig-md lum whitespace-nowrap"><span dir="ltr" style="unicode-bidi:isolate">30</span> سنة</dd>
            <dt class="tech-label mt-2 text-lune-faint">ضمان أداء الألواح</dt>
          </div>
          <div class="v2-rise min-w-0" style="--v2-i:2">
            <dd class="fig fig-md lum whitespace-nowrap"><span dir="ltr" style="unicode-bidi:isolate">50–100 %</span></dd>
            <dt class="tech-label mt-2 text-lune-faint">من الفاتورة مُغطّاة <span class="normal-case font-normal">(حسب عدد البطاريات والاستعمال نهارًا/ليلاً)</span></dt>
          </div>
          <div class="v2-rise min-w-0" style="--v2-i:3">
            <dd class="fig fig-md lum whitespace-nowrap"><span dir="ltr" style="unicode-bidi:isolate">0</span> درهم</dd>
            <dt class="tech-label mt-2 text-lune-faint">الدراسة والتشخيص</dt>
          </div>
        </dl>
        <a href={L('/financement')} class="v2-rise group mt-10 inline-flex items-center gap-1 border-b-2 border-white/30 pb-0.5 text-sm font-bold text-white transition-colors hover:border-white">
          شاهد تفاصيل التمويل الكاملة <span class="motion-safe:transition-transform motion-safe:duration-200 motion-safe:group-hover:translate-x-1 inline-block rtl:-scale-x-100" aria-hidden="true">→</span>
        </a>
      </div>
    </section>

    {/* W253 — روابط متقاطعة «ما الذي تحصل عليه»: المعدات + الضمانات المكتوبة،
        غائبة عن هذا المركز حتى الآن رغم أنها تجيب مباشرة على «ماذا سأحصل عليه فعلياً؟». */}
    <div class="seam-soft" aria-hidden="true"></div>
    <section class="px-4 py-14 sm:py-16">
      <div class="mx-auto max-w-6xl">
        <p class="tech-label v2-kicker rule-brass text-lune">ما الذي تحصل عليه</p>
        <h2 class="display v2-section-title mt-5 max-w-xl text-white">المعدات المُركَّبة والضمانات المكتوبة</h2>
        <div class="mt-8 grid gap-6 sm:grid-cols-2" data-stagger>
          <a href={L('/équipement')} class="v2-rise cine-card group flex flex-col p-7" style="--v2-i:0">
            <p class="tech-label text-lune">المعدات</p>
            <h3 class="display mt-2 text-xl text-white">المعدات المُركَّبة</h3>
            <p class="mt-3 flex-1 text-sm leading-relaxed text-lune-soft">
              ألواح، عاكسات، بطاريات: الماركات من الفئة الأولى المُركَّبة فعلياً في أوراشنا، بطاقة تقنية
              تلو الأخرى.
            </p>
            <span class="mt-5 inline-flex items-center gap-1 border-b-2 border-white/30 pb-0.5 text-sm font-bold text-white">شاهد المعدات <span class="motion-safe:transition-transform motion-safe:duration-200 motion-safe:group-hover:translate-x-1 inline-block rtl:-scale-x-100" aria-hidden="true">→</span></span>
          </a>
          <a href={L('/garanties')} class="v2-rise cine-card group flex flex-col p-7" style="--v2-i:1">
            <p class="tech-label text-lune">الضمانات</p>
            <h3 class="display mt-2 text-xl text-white">ضماناتنا المكتوبة</h3>
            <p class="mt-3 flex-1 text-sm leading-relaxed text-lune-soft">
              <span dir="ltr" style="unicode-bidi:isolate">30</span> سنة ضمان أداء على الألواح، وتفاصيل مكتوبة لما هو مُغطّى في باقي المعدات والتركيب.
            </p>
            <span class="mt-5 inline-flex items-center gap-1 border-b-2 border-white/30 pb-0.5 text-sm font-bold text-white">شاهد الضمانات <span class="motion-safe:transition-transform motion-safe:duration-200 motion-safe:group-hover:translate-x-1 inline-block rtl:-scale-x-100" aria-hidden="true">→</span></span>
          </a>
        </div>
      </div>
    </section>

    {/* W262 — مناطق التدخّل بصدق: محور الدار البيضاء-الرباط + المدن الأخرى
        المسمّاة، دون أي وعد ضمني بتغطية وطنية. */}
    <div class="v2-seam" aria-hidden="true"></div>
    <section class="bg-blanc-azur px-4 py-16 text-encre sm:py-20">
      <div class="mx-auto max-w-3xl text-center">
        <p class="tech-label v2-kicker rule-brass eyebrow-light">مناطق التدخّل</p>
        <h2 class="display v2-section-title mt-5">محور الدار البيضاء–الرباط، وأبعد على الطلب</h2>
        <p class="v2-lead mt-5 text-encre-soft">
