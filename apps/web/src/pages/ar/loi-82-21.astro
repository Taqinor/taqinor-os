---
/**
 * AR — القانون 82-21: الأنظمة الثلاثة للإنتاج الذاتي (W67, RTL). ترجمة أمينة
 * لـ /loi-82-21 ؛ بدون أي رقم أو ادعاء جديد. كل واقعة قانونية تبقى دقيقة: رقم
 * القانون 82-21، المرسوم 2-25-100، الساري منذ 9 يونيو 2026، والعتبات
 * (< 11 kW جهد منخفض، حتى 5 MW، ≥ 5 MW) و ANRE. بيانات الأنظمة من
 * regimesFor('ar'). الروابط الداخلية عبر localizeNavHref (AR إن وُجدت، وإلا
 * صفحة FR — أبداً رابط ميّت). FR دون تغيير.
 */
import Layout from '../../layouts/Layout.astro';
import V2Enhance from '../../components/V2Enhance.astro';
import Article33Ribbon from '../../components/Article33Ribbon.astro';
import RegimeSelector from '../../components/RegimeSelector.astro';
import CtaBand from '../../components/CtaBand.astro';
import StickyCta from '../../components/StickyCta.astro';
import ZelligeDivider from '../../components/ZelligeDivider.astro';
import { regimesFor } from '../../lib/regime';
import { getLocaleFromPath } from '../../i18n/utils';
import { localizeNavHref } from '../../i18n/pages';

const locale = getLocaleFromPath(Astro.url.pathname);
const L = (href: string) => localizeNavHref(href, locale);
const REGIMES = regimesFor(locale);
---

<Layout
  title="القانون 82-21: الأنظمة الثلاثة للإنتاج الذاتي بالمغرب | Taqinor"
  description="تصريح، اتفاق ربط أم ترخيص؟ في 3 أسئلة، حدّد نظام القانون 82-21 (المرسوم 2-25-100) المنطبق على تركيبتك الشمسية، الساري منذ 9 يونيو 2026."
  ogSlug="loi-82-21"
>
  <div class="v2">
    <V2Enhance />
    <Article33Ribbon />

    <section class="px-4 py-20 text-white sm:py-28">
      <div class="mx-auto max-w-6xl">
        <p class="tech-label v2-kicker rule-brass cine-in text-brass-300">القانون 82-21 · المرسوم 2-25-100</p>
        <h1 class="display v2-page-title cine-in mt-5 max-w-3xl [animation-delay:120ms]">ثلاثة أنظمة، واحد فقط يعنيك</h1>
        <p class="v2-lead cine-in mt-6 max-w-xl text-white/85 [animation-delay:240ms]">
          القانون 82-21 المتعلق بالإنتاج الذاتي للطاقة الكهربائية ومرسومه التطبيقي 2-25-100 ساريان
          منذ 9 يونيو 2026. كل تركيبة للإنتاج الذاتي — جديدة كانت أو قائمة — تندرج من الآن تحت أحد
          الأنظمة الثلاثة أدناه، حسب استطاعتها وربطها.
        </p>
      </div>
    </section>

    <!-- الأداة المُضاءة: المُحدِّد، وثيقة بيضاء على الليل -->
    <section class="mx-auto max-w-4xl px-4 py-14">
      <div class="v2-rise [&>div]:shadow-[0_40px_90px_-30px_rgb(0_0_0/0.85)]">
        <RegimeSelector />
      </div>
    </section>

    <ZelligeDivider tone="white" />

    <section class="mx-auto max-w-4xl px-4 py-16">
      <p class="tech-label v2-kicker rule-brass text-brass-300">مرجع</p>
      <h2 class="display v2-section-title mt-4 text-white">الأنظمة الثلاثة بالتفصيل</h2>
      <div class="mt-10 grid gap-6" data-stagger>
        {Object.values(REGIMES).map((r, i) => (
          <div class="v2-rise cine-card grid gap-4 p-6 sm:grid-cols-[auto_1fr] sm:p-7" style={`--v2-i:${i}`}>
            <span class="fig lum text-4xl" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
            <div>
              <h3 class="display text-xl text-white">{r.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-lune-soft">{r.summary}</p>
              <ul class="mt-4 space-y-2 text-sm text-lune">
                {r.obligations.map((o) => (
                  <li class="flex gap-2.5"><span class="mt-1.5 inline-block h-1.5 w-1.5 flex-none rotate-45 border border-brass-400" aria-hidden="true"></span><span>{o}</span></li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href={L('/professionnel')} class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">الأنظمة لموقع مهني →</a>
        <a href={L('/guides/loi-82-21-expliquee')} class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">القانون 82-21 مشروحاً ببساطة →</a>
      </div>
    </section>

    <!-- الفصل الأخير — التسوية تُعالَج في وضح النهار -->
    <div class="v2-seam" aria-hidden="true"></div>
    <section class="bg-blanc-azur px-4 pb-4 pt-2 text-encre">
      <div class="mx-auto max-w-4xl border-2 border-azur-600 bg-blanc p-7">
        <p class="tech-label text-azur-600">التركيبات القائمة</p>
        <h2 class="display v2-section-title mt-2">هل لديك تركيبة غير مصرّح بها؟</h2>
        <p class="mt-4 max-w-xl text-sm leading-relaxed text-encre-soft">
          تفتح المادة 33 من القانون نافذة من 18 شهراً لتسوية التركيبات القائمة. النافذة مفتوحة — والمسطرة
          والعقوبات في حال التقاعس مفصّلة في الصفحة المخصّصة.
        </p>
        <a href={L('/regularization-article-33')} class="mt-5 inline-block bg-brass-400 px-6 py-3 text-sm font-bold text-azur-950 transition-colors hover:bg-brass-300">
          تسوية تركيبتي
        </a>
      </div>
    </section>

    <CtaBand title="لديك شك في نظامك؟ نتحقّق منه مجاناً." buttonLabel="تحقّقوا من ملفي" seam={false} />

    <StickyCta />
  </div>
</Layout>
