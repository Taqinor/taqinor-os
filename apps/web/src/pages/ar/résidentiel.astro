---
/**
 * AR — Residential solar (W67, RTL). Faithful Arabic translation of
 * /résidentiel ; EVERY figure kept EXACT in Latin digits (11,36 kWc,
 * 50–100 %, 3–7 years, 30 years, < 11 kW, 1 000 / 2 000 / 10 000 MAD,
 * ref. 400/236/468/NC-10/25, Canadian Solar 710 Wc, Deye, Dyness LFP,
 * real-time monitoring, ONEE, law 82-21). WB — fabricated annual kWh production
 * figures removed (no real Deye reading backed them); production is
 * monitored via real-time production monitoring, never promised. The price-bracket data + solar math
 * (BILL_RANGES / localEstimateBand / formatMAD) are reused UNCHANGED — only
 * visible labels are translated. Internal links via localizeNavHref. Shared
 * components auto-detect locale. FR untouched.
 *
 * W249 — قناة واحدة: الفعل الختامي لم يعد DiagnosticForm بل عنصر التقدير
 * الفوري المشترك مع الصفحة الرئيسية (InstantEstimator، W250 — نفس محرك
 * billEstimate.ts، نفس رابط CTA نحو مسار عرض الثمن). DiagnosticForm يبقى
 * سليماً في الكود كحل احتياطي موثّق.
 *
 * ÉLÉVATION (W241) — mirrors the FR résidentiel.astro elevation:
 *  1. cinematic hero (~92svh), scrim relevé, scroll chevron, CTAs anchored bottom;
 *  2. brass discipline: eyebrows text-lune, gold only on .lum + primary CTA;
 *  3. v3-grade on content photos;
 *  4. .section / .section-tight tokens + seam-soft seams;
 *  5. study card moved below hero as section-tight block;
 *  6. RTL-logical classes preserved throughout.
 */
import Layout from '../../layouts/Layout.astro';
import V2Enhance from '../../components/V2Enhance.astro';
import Article33Ribbon from '../../components/Article33Ribbon.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import InstantEstimator from '../../components/InstantEstimator.astro';
import CtaBand from '../../components/CtaBand.astro';
import Picture from '../../components/Picture.astro';
import StickyCta from '../../components/StickyCta.astro';
import ZelligeDivider from '../../components/ZelligeDivider.astro';
import GarantiesTeaser from '../../components/GarantiesTeaser.astro';
import Testimonials from '../../components/Testimonials.astro';
import Faq from '../../components/Faq.astro';
import ServiceWarrantyTable from '../../components/ServiceWarrantyTable.astro';
import RelatedLinks from '../../components/RelatedLinks.astro';
import { BILL_RANGES, localEstimateBand } from '../../lib/billRange';
import { formatMAD } from '../../lib/format';
import { WHATSAPP_LEADS } from '../../lib/nap';
import { whatsappLink } from '../../lib/whatsapp';
import { getLocaleFromPath } from '../../i18n/utils';
import { localizeNavHref } from '../../i18n/pages';
import { serviceFaqItems } from '../../lib/serviceFaq';
import { PANEL_PERFORMANCE_WARRANTY_YEARS } from '../../lib/warranty';
import { realisationByRef } from '../../lib/realisations';

const locale = getLocaleFromPath(Astro.url.pathname);
const L = (href: string) => localizeNavHref(href, locale);

const waDirect = whatsappLink(WHATSAPP_LEADS, 'مرحباً، أرغب في دراسة لتركيبة شمسية.');

// WB4 (2026-07-04) — مدة ضمان الألواح مُشتقّة من warranty.ts (المصدر الوحيد)
// بدل رقم «30» مكتوب يدوياً.
const panelWarrantyLabel = `${PANEL_PERFORMANCE_WARRANTY_YEARS} سنة`;
const PAYBACK_LOW_YEARS = 4;
const PAYBACK_HIGH_YEARS = 6;
const remainingLowYears = PANEL_PERFORMANCE_WARRANTY_YEARS - PAYBACK_HIGH_YEARS;
const remainingHighYears = PANEL_PERFORMANCE_WARRANTY_YEARS - PAYBACK_LOW_YEARS;
const YEARS_WORDS_AR: Record<number, string> = {
  24: 'الأربع والعشرين', 25: 'الخمس والعشرين', 26: 'الست والعشرين', 27: 'السبع والعشرين', 28: 'الثماني والعشرين',
};
const remainingYearsLabel =
  `${YEARS_WORDS_AR[remainingLowYears] ?? remainingLowYears} إلى ${YEARS_WORDS_AR[remainingHighYears] ?? remainingHighYears}`;

// WB4 (2026-07-04) — figcaptions kWc/production مُشتقّة من realisations.ts
// (المصدر الوحيد) بدل أرقام مكتوبة يدوياً.
const figRef134 = realisationByRef('134');
const figRef236 = realisationByRef('236');
const CITY_AR_MAP: Record<string, string> = { Casablanca: 'الدار البيضاء', 'El Jadida': 'الجديدة' };

// W263 — بنك أسئلة شائعة مشترك + ضمان حسب المكوّن، بالعربية.
const faqItems = serviceFaqItems('residentiel', 'ar');

const PRIX_PAR_KWC = { bas: 10000, haut: 12500 };
const arrondi5k = (v: number) => Math.round(v / 5000) * 5000;

const EXEMPLES_REELS: Record<string, string> = {
  '1000-1500': 'مثال حقيقي: مرجع NC-10/25 — 3,72 kWc، النواصر، أكتوبر 2025',
  '1500-3000': 'مثال حقيقي: مرجع 236 — 5,68 kWc، الجديدة، مارس 2026',
  '3000-5000': 'مثال حقيقي: مرجع 400 — 11,36 kWc، الدار البيضاء، أبريل 2026',
  '5000-10000': 'مثال حقيقي: مرجع 468 — 17,04 kWc، الجديدة، أبريل 2026',
};

const brackets = BILL_RANGES.filter((r) => r.qualifies && r.id !== 'gt10000').map((r) => {
  const band = localEstimateBand(r.id);
  return {
    bill: r.label,
    kwc: band.kwcLabel,
    payback: band.paybackLabel,
    investLow: arrondi5k(band.kwcMin * PRIX_PAR_KWC.bas),
    investHigh: arrondi5k(band.kwcMax * PRIX_PAR_KWC.haut),
    invest: `${formatMAD(arrondi5k(band.kwcMin * PRIX_PAR_KWC.bas))} – ${formatMAD(arrondi5k(band.kwcMax * PRIX_PAR_KWC.haut))}`,
    exemple: EXEMPLES_REELS[r.id] ?? null,
  };
});

// القاعدة ب14 (2026-07-04) — الحدود مُشتقّة من جدول brackets أعلاه (منشور
// أصلاً) للإجابة القابلة للاستخراج (AEO)؛ لا رقم جديد.
const investRangeLow = formatMAD(Math.min(...brackets.map((b) => b.investLow)));
const investRangeHigh = formatMAD(Math.max(...brackets.map((b) => b.investHigh)));
---

<Layout
  title="الطاقة الشمسية للفيلات والشقق بالمغرب — مُسعّرة على فاتورتك | Taqinor"
  description="11,36 kWc بالدار البيضاء، مُتابَعة بمراقبة الإنتاج في الوقت الحقيقي: تركيباتنا السكنية مُحدّدة المقاس على فاتورتك الحقيقية، بأوامر مقدار صادقة، عائد في 3 إلى 7 سنوات وتصريح القانون 82-21."
  ogSlug="residentiel"
>
  <div class="v2">
    <V2Enhance />
    <Article33Ribbon />

    <Breadcrumb items={[{ label: 'الرئيسية', href: L('/') }, { label: 'سكني' }]} />

    {/* ── 1 · HÉROS CINÉMATOGRAPHIQUE (~92svh) — الصورة هي النور ── */}
    <section class="relative isolate flex min-h-[92svh] flex-col justify-end overflow-hidden text-white">
      <div class="v2-hero-media absolute inset-0 -z-10">
        {/* عنصر LCP — لا v3-grade هنا أبداً */}
        <Picture name="crepuscule-penthouse" alt="" widths={[1600, 1024, 640]} ratio={4 / 3} sizes="100vw"
          loading="eager" fetchpriority="high" class="h-full w-full object-cover object-[65%_40%]" />
        {/* Scrim relevé */}
        <div class="hero-scrim hero-scrim-v3 absolute inset-0"></div>
      </div>

      {/* Chevron دعوة للتمرير */}
      <div class="absolute bottom-6 left-1/2 -translate-x-1/2 scroll-chevron" aria-hidden="true">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="6 9 12 15 18 9" />
        </svg>
      </div>

      {/* المحتوى مُثبَّت أسفل — eyebrow مُخفَّض إلى lune (انضباط النحاس) */}
      <div class="mx-auto w-full max-w-6xl px-4 pb-24 pt-32 sm:pb-32">
        <p class="tech-label v2-kicker rule-brass cine-in text-lune">فيلات · شقق</p>
        <h1 class="display v2-page-title cine-in cine-in-1 mt-5 max-w-[18ch]">فيلا، فاتورتها، سطحها: ثلاث معطيات، تحديد مقاس واحد</h1>
        <p class="v2-lead cine-in cine-in-2 mt-6 max-w-xl text-white/85">
          حين تُحدّد بإحكام، تغطّي التركيبة <span dir="ltr">50 إلى 100 %</span> مما تستهلكه الفيلا،
          حسب عدد البطاريات والاستعمال نهارًا/ليلاً.
          هذه الأرقام الثلاثة — قراءة عدّاد ONEE، ساعات الذروة، توجيه السطح —
          هي التي تحدّد القدرة. نحن نقرأها؛ ولا نركّب شيئاً لم يُبرّره الحساب.
        </p>
        <div class="cine-in cine-in-3 mt-10 flex flex-wrap items-center gap-3">
          {/* CTA نحاسي وحيد */}
          <a href={L('/devis/mon-toit')} class="glow-hero bg-brass-400 px-8 py-4 text-lg font-bold text-azur-950 transition-all hover:bg-brass-300">
            احصل على دراستي المجانية ←
          </a>
          {/* Ghost WhatsApp */}
          <a href={waDirect} rel="noopener" class="inline-flex items-center gap-2 border border-white/40 px-6 py-3.5 text-base font-semibold text-white backdrop-blur-sm transition-colors hover:border-white hover:bg-white/10">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 0 0-8.6 15.1L2 22l5-1.3A10 10 0 1 0 12 2Zm5.4 14.1c-.2.6-1.3 1.2-1.8 1.2-.5.1-1 .2-3.3-.7-2.8-1.1-4.6-4-4.7-4.2-.1-.2-1.1-1.5-1.1-2.9s.7-2 1-2.3c.2-.3.5-.3.7-.3h.5c.2 0 .4 0 .6.4l.9 2.1c.1.2.1.4 0 .6l-.4.6-.5.5c-.2.2-.3.4-.1.7.2.3.9 1.4 1.9 2.3 1.3 1.1 2.3 1.5 2.6 1.6.3.1.5.1.7-.1l1-1.2c.2-.3.4-.2.7-.1l2 1c.3.1.5.2.6.4 0 .1 0 .7-.3 1.4Z"/></svg>
            واتساب مباشر
          </a>
        </div>
      </div>
    </section>

    {/* مقتطف دراسة — بطاقة تحت البطل */}
    <div class="seam-soft" aria-hidden="true"></div>
    <section class="section-tight px-4">
      <aside class="v2-rise mx-auto max-w-3xl border-t-4 border-brass-400 bg-blanc p-6 text-encre shadow-premium sm:p-8">
        <p class="tech-label text-brass-600">مقتطف دراسة — مرجع 400 · الدار البيضاء · أبريل 2026</p>
        <div class="mt-5 grid grid-cols-2 gap-x-4 gap-y-6 sm:grid-cols-4">
          <div><p class="fig text-3xl text-azur-600 sm:text-4xl" dir="ltr">11,36 <span class="text-base">kWc</span></p><p class="tech-label mt-1.5 text-encre-faint">القدرة المركّبة</p></div>
          <div><p class="fig text-3xl text-azur-600 sm:text-4xl" dir="ltr">16 <span class="text-base">ألواح</span></p><p class="tech-label mt-1.5 text-encre-faint">Canadian Solar 710 Wc</p></div>
          <div><p class="fig text-3xl text-azur-600 sm:text-4xl" dir="ltr">10 <span class="text-base">kWh</span></p><p class="tech-label mt-1.5 text-encre-faint">تخزين Dyness LFP</p></div>
          <div><p class="fig text-3xl text-azur-600 sm:text-4xl">متابعة <span class="text-base">فورية</span></p><p class="tech-label mt-1.5 text-encre-faint">مراقبة، بولوج الزبون</p></div>
        </div>
        <p class="mt-5 border-t border-azur-900/10 pt-3 text-xs text-encre-soft">الإنتاج يُتابَع باستمرار، متابعة الإنتاج في الوقت الحقيقي، بولوج الزبون عبر تطبيق.</p>
      </aside>
    </section>

    {/* شفافية الأسعار — eyebrow مُخفَّض إلى lune —
        W274: نظام ترقيم الفصول (01/02…)، نفس آلية الصفحة الرئيسية
        (index.astro/ar)، ممتد هنا لاتّساق العملية التحريرية على الموقع كله.
        ms-2 (منطقي) مثل ar/index.astro — لا mr-2 فيزيائي. */}
    <section class="section mx-auto max-w-4xl px-4">
      <p class="tech-label v2-kicker rule-brass text-lune"><span class="ms-2 font-display text-xs text-azur-200/80" aria-hidden="true">01</span>شفافية الأسعار</p>
      <h2 class="display v2-section-title mt-5 text-white">كم تكلّف الطاقة الشمسية لفيلا، وفي كم من الوقت تُسترجع كلفتها؟</h2>
      <p class="v2-lead mt-4 max-w-2xl font-bold text-white">
        بالنسبة لفاتورة سكنية نموذجية (<span dir="ltr" style="unicode-bidi:isolate">1 000</span> إلى <span dir="ltr" style="unicode-bidi:isolate">10 000 درهم/شهرياً</span>)، تتكلّف التركيبة عادةً بين
        <span dir="ltr" style="unicode-bidi:isolate">{investRangeLow}</span> و<span dir="ltr" style="unicode-bidi:isolate">{investRangeHigh}</span> وتُسترجع كلفتها خلال <span dir="ltr" style="unicode-bidi:isolate">3</span> إلى <span dir="ltr" style="unicode-bidi:isolate">7 سنوات</span>، للجزء المُستهلَك
        ذاتياً — بعدها، لا تكاد الكهرباء المُنتَجة تكلّف شيئاً طوال باقي سنوات ضمان الأداء الثلاثين.
      </p>
      <p class="v2-lead mt-4 max-w-2xl text-lune-soft">
        إليك أوامر المقدار المسجَّلة على أوراشنا السكنية — <strong class="text-lune">لا تكون أبداً
        ثمناً نهائياً</strong>. الرقم الدقيق يأتي بعد الزيارة التقنية؛ وإن كان ملفك لا
        يجعل الطاقة الشمسية مربحة، سنقول لك ذلك قبل أن توقّع أي شيء على الإطلاق.
      </p>
      <div class="mt-10 border-t-2 border-brass-400/60" data-stagger>
        <div class="tech-label hidden grid-cols-[1.1fr_0.8fr_1.2fr_0.8fr] gap-4 border-b border-white/10 py-3 text-lune-faint sm:grid">
          <span>الفاتورة الشهرية</span><span>القدرة</span><span>الاستثمار (أمر مقدار)</span><span>العائد</span>
        </div>
        {brackets.map((b, i) => (
          <div class="v2-rise border-b border-white/10 py-5" style={`--v2-i:${i}`}>
            <div class="grid gap-1.5 sm:grid-cols-[1.1fr_0.8fr_1.2fr_0.8fr] sm:items-baseline sm:gap-4">
              <span class="font-display text-base font-bold text-white">{b.bill}</span>
              <span class="fig lum text-xl sm:text-2xl" dir="ltr" data-tally>{b.kwc}</span>
              <span class="fig text-lg text-lune sm:text-xl" dir="ltr">{b.invest}</span>
              <span class="fig text-xl text-brass-300 sm:text-2xl" dir="ltr" data-tally>{b.payback}</span>
            </div>
            {b.exemple && <p class="tech-label mt-2.5 text-lune-faint">{b.exemple}</p>}
          </div>
        ))}
      </div>
      <p class="mt-5 max-w-2xl text-xs leading-relaxed text-lune-soft">
        تحت <span dir="ltr" style="unicode-bidi:isolate">1 000 MAD</span> في الشهر، يتجاوز العائد غالباً <span dir="ltr" style="unicode-bidi:isolate">7 سنوات</span>: نقولها
        بدل أن نفرض البيع. فوق <span dir="ltr" style="unicode-bidi:isolate">10 000 MAD</span>، يخرج الاستهلاك من الإطار
        السكني ويستدعي دراسة مخصّصة — انظر مهني.
      </p>
    </section>

    <ZelligeDivider tone="white" />

    {/* توضيح الـ30 سنة — eyebrow مُخفَّض إلى lune */}
    <div class="seam-soft" aria-hidden="true"></div>
    <section class="section px-4">
      <div class="mx-auto grid max-w-6xl gap-12 lg:grid-cols-[1.1fr_1fr] lg:items-center">
        <div class="v2-rise">
          {/* W274 — الفصل 02 */}
          <p class="tech-label v2-kicker rule-brass text-lune"><span class="ms-2 font-display text-xs text-azur-200/80" aria-hidden="true">02</span>أفق الاستثمار</p>
          <h2 class="display v2-section-title mt-5 text-white">ما تعطيه الـ{PANEL_PERFORMANCE_WARRANTY_YEARS} سنة، عاماً بعد عام</h2>
          <p class="v2-lead mt-5 text-lune-soft">
            يضمن الصانع أداء الألواح على مدى {PANEL_PERFORMANCE_WARRANTY_YEARS} سنة (ضمان خطي). خذ فيلا بفاتورة
            شهرية قدرها <span dir="ltr" style="unicode-bidi:isolate">2 000 MAD</span>: <span dir="ltr" style="unicode-bidi:isolate">6 kWc</span> تُقدَّر بنحو <span dir="ltr" style="unicode-bidi:isolate">60 000</span> إلى <span dir="ltr" style="unicode-bidi:isolate">75 000 MAD</span>
            وتمحو كل سنة نحو <span dir="ltr" style="unicode-bidi:isolate">12 000</span> إلى <span dir="ltr" style="unicode-bidi:isolate">16 000 MAD</span> من الكهرباء (بتعريفة المكتب ONEE)، للجزء
            المُستهلَك ذاتياً — إذ لا توجد بعد تعريفة إعادة شراء منزلية (BT) منشورة، فالفائض
            المُصدَّر لا يساوي شيئاً ما دامت هذه التعريفة غير موجودة.
            من أربع إلى ست سنوات لتسديدها؛ ثم، على مدى {remainingYearsLabel} سنة
            المتبقية، لا يكلّف الكيلوواط-ساعة شيئاً تقريباً — ليس هناك سوى عاكس واحد
            يُستبدَل مرة واحدة على طول المدة.
          </p>
          <dl class="mt-10 grid grid-cols-1 gap-4 sm:grid-cols-3 border-s-2 border-brass-400/60 ps-6" data-stagger>
            <div class="v2-rise" style="--v2-i:0">
              <dd class="fig lum whitespace-nowrap text-2xl sm:text-4xl" dir="ltr" data-tally>{panelWarrantyLabel}</dd>
              <dt class="tech-label mt-1.5 text-lune-faint">ضمان الألواح</dt>
            </div>
            <div class="v2-rise" style="--v2-i:1">
              <dd class="fig lum whitespace-nowrap text-2xl sm:text-4xl" dir="ltr" data-tally>3–7 سنوات</dd>
              <dt class="tech-label mt-1.5 text-lune-faint">العائد النموذجي</dt>
            </div>
            <div class="v2-rise" style="--v2-i:2">
              <dd class="fig lum whitespace-nowrap text-2xl sm:text-4xl" dir="ltr" data-tally>&lt; 11 kW</dd>
              <dt class="tech-label mt-1.5 text-lune-faint">تصريح بسيط</dt>
            </div>
          </dl>
        </div>
        <div class="grid gap-4">
          <figure class="v2-rise cine-card group relative overflow-hidden">
            <Picture name="pose-134" alt="فريق تاكينور يميل لوحاً أثناء التركيب على فيلا بالدار البيضاء"
              widths={[1600, 1024, 640]} ratio={4 / 3} sizes="(min-width: 1024px) 40vw, 100vw"
              class="v3-grade w-full object-cover transition-transform duration-700 group-hover:scale-[1.04]" />
            <figcaption class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-nuit/95 to-transparent px-4 pb-3 pt-12">
              <span class="tech-label block text-brass-300">{CITY_AR_MAP[figRef134?.ville ?? ''] ?? figRef134?.ville} · {figRef134?.kwc} · {figRef134?.production}</span>
              <span class="mt-0.5 block text-xs text-lune">تركيب جارٍ · {figRef134?.panneaux} · {figRef134?.date}</span>
            </figcaption>
          </figure>
          <figure class="v2-rise cine-card group relative overflow-hidden">
            <Picture name="champ-villa" alt="حقل من ثمانية ألواح على سطح فيلا مسطّح بالجديدة، سماء زرقاء"
              widths={[1600, 1024, 640]} ratio={3 / 2} sizes="(min-width: 1024px) 40vw, 100vw"
              class="v3-grade w-full object-cover transition-transform duration-700 group-hover:scale-[1.04]" />
            <figcaption class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-nuit/95 to-transparent px-4 pb-3 pt-12">
              <span class="tech-label block text-brass-300">{CITY_AR_MAP[figRef236?.ville ?? ''] ?? figRef236?.ville} · {figRef236?.kwc} · {figRef236?.production}</span>
              <span class="mt-0.5 block text-xs text-lune">
                {figRef236?.panneaux} · {figRef236?.onduleur} · {figRef236?.productionEstimated ? 'إنتاج مُقدَّر (عائد مقاس)' : 'إنتاج مقيس'}
              </span>
            </figcaption>
          </figure>
        </div>
      </div>
    </section>

    {/* روابط سياقية — عنقود السعر/السكني (W299) */}
    <div class="seam-soft" aria-hidden="true"></div>
    <section class="section-tight px-4">
      <div class="mx-auto max-w-6xl">
        <RelatedLinks mt="mt-0" links={[
          { href: L('/realisations'), label: 'إنجازاتنا السكنية' },
