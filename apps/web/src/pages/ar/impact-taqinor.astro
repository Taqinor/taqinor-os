---
/**
 * AR — أثر Taqinor (W279, RTL). ترجمة أمينة لـ /impact-taqinor؛ كل رقم مُشتَق
 * حياً من realisations.ts (قراءة فقط) تماماً كالصفحة الفرنسية — لا رقم يُكتب
 * يدوياً أو يُعاد ترجمته يدوياً. الروابط الداخلية عبر localizeNavHref (AR إن
 * وُجدت، وإلا صفحة FR — أبداً رابط ميّت). FR دون تغيير.
 *
 * ملاحظة: هذا المسار العربي غير مسجَّل بعد في src/i18n/pages.ts
 * (STATIC_TRANSLATED) — هذا الملف خارج نطاق هذه المهمة، لذا لا يظهر بعد في
 * مبدّل اللغة / hreflang. المسار نفسه يعمل بشكل صحيح وهو صفحة حقيقية قابلة
 * للفهرسة.
 */
import Layout from '../../layouts/Layout.astro';
import V2Enhance from '../../components/V2Enhance.astro';
import Article33Ribbon from '../../components/Article33Ribbon.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import KeyFigure from '../../components/KeyFigure.astro';
import Callout from '../../components/Callout.astro';
import CtaBand from '../../components/CtaBand.astro';
import StickyCta from '../../components/StickyCta.astro';
import { getLocaleFromPath } from '../../i18n/utils';
import { localizeNavHref } from '../../i18n/pages';
import { REALISATIONS } from '../../lib/realisations';
import { CO2_KG_PER_KWH, CO2_KG_PER_TREE_YEAR } from '../../lib/proposition';

const locale = getLocaleFromPath(Astro.url.pathname);
const L = (href: string) => localizeNavHref(href, locale);
const devisHref = L('/devis/mon-toit');

// ── أرقام مُشتَقّة — لا شيء مكتوب يدوياً ─────────────────────────────────────
const installCount = REALISATIONS.length;

const kwcTotal = REALISATIONS.reduce((sum, r) => sum + r.kwcNum, 0);
const kwcTotalLabel = kwcTotal.toLocaleString('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });

const withMeasuredProduction = REALISATIONS.filter((r) => r.productionNum !== null);
const productionTotal = withMeasuredProduction.reduce((sum, r) => sum + (r.productionNum ?? 0), 0);
const productionTotalLabel = productionTotal.toLocaleString('fr-FR');

const co2KgTotal = productionTotal * CO2_KG_PER_KWH;
const co2TonnesTotal = Math.round((co2KgTotal / 1000) * 10) / 10;
const co2TonnesLabel = co2TonnesTotal.toLocaleString('fr-FR', { minimumFractionDigits: 1, maximumFractionDigits: 1 });

const treesEquivalent = Math.round(co2KgTotal / CO2_KG_PER_TREE_YEAR);
const treesLabel = treesEquivalent.toLocaleString('fr-FR');

const battersInstalls = REALISATIONS.filter((r) => r.batterie !== null);
const batteryKwhTotal = battersInstalls.reduce((sum, r) => {
  const m = /([\d.,]+)\s*kWh/.exec(r.batterie ?? '');
  return sum + (m ? parseFloat(m[1].replace(',', '.')) : 0);
}, 0);

const villesUniques = [...new Set(REALISATIONS.map((r) => r.ville))];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'أثر Taqinor',
  description: `أثر Taqinor التراكمي، المقيس والصادق: ${kwcTotalLabel} kWc مركَّبة، ${productionTotalLabel} kWh/سنة إنتاج مقيس، ${co2TonnesLabel} طن CO₂ متجنَّبة سنوياً.`,
  isPartOf: { '@type': 'WebSite', name: 'Taqinor', url: 'https://taqinor.ma' },
};
---

<Layout
  title="أثر Taqinor: أرقامنا الحقيقية، التراكمية والقابلة للتحقّق | Taqinor"
  description={`${kwcTotalLabel} kWc مركَّبة، ${productionTotalLabel} kWh/سنة مقيسة، ${co2TonnesLabel} طن CO₂ متجنَّبة: الحصيلة الصادقة لتركيباتنا، مُشتقّة من إنجازاتنا المنشورة — لا شيء مُقدَّر أو مُقرَّب نحو الأعلى.`}
  ogSlug="equipement"
>
  <div class="v2">
    <V2Enhance />
    <Article33Ribbon />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <Breadcrumb items={[{ label: 'الرئيسية', href: L('/') }, { label: 'أثر Taqinor' }]} />

    <section class="section-lg px-4 pb-10 text-white">
      <div class="mx-auto max-w-3xl">
        <p class="tech-label v2-kicker rule-brass cine-in text-lune">مساءلة وشفافية</p>
        <h1 class="display v2-page-title cine-in cine-in-1 mt-6">أثر Taqinor</h1>
        <p class="v2-lead cine-in cine-in-2 mt-6 max-w-xl text-white/85">
          ليست توقّعاً ولا هدفاً: ما تنتجه فعلاً تركيباتنا الـ{installCount} المنشورة، مجموعةً.
          هذه الصفحة تكبر مشروعاً بعد مشروع — اليوم هي صغيرة، عن قصد، لأنها لا تقول إلا ما
          يمكننا إثباته.
        </p>
      </div>
    </section>

    <!-- أرقام رئيسية — مُشتقّة حياً من realisations.ts -->
    <section class="section px-4">
      <div class="mx-auto max-w-6xl">
        <p class="tech-label v2-kicker rule-brass text-lune">الحصيلة اليوم</p>
        <h2 class="display v2-section-title mt-5 text-white">{installCount} تركيبات، حصيلة واحدة</h2>
        <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4" data-stagger>
          <KeyFigure value={kwcTotalLabel} unit="kWc" label="القدرة المركَّبة">
            مجموع {installCount} تركيبات في {villesUniques.join('، ')}.
          </KeyFigure>
          <KeyFigure value={productionTotalLabel} unit="kWh/سنة" label="الإنتاج المقيس">
            على {withMeasuredProduction.length} تركيبات متابَعة (Deye Cloud) — المشاريع التي لا
            إنتاج منشوراً لها لا تُحتسَب.
          </KeyFigure>
          <KeyFigure value={co2TonnesLabel} unit="طن CO₂/سنة" label="CO₂ متجنَّب">
            محسوب بمعدَّل {CO2_KG_PER_KWH} كلغ CO₂/kWh، عامل انبعاث الشبكة المغربية المستخدَم
            بالفعل في دراساتنا المُسعَّرة.
          </KeyFigure>
          <KeyFigure value={String(batteryKwhTotal).replace('.', ',')} unit="kWh" label="التخزين التراكمي">
            سعة بطاريات مركَّبة على {battersInstalls.length} من أصل {installCount} مشاريع.
          </KeyFigure>
        </div>
        <Callout type="info" title="كيف يُحسَب هذا الرقم">
          <p>
            CO₂ المتجنَّب = الإنتاج السنوي المقيس × {CO2_KG_PER_KWH} كلغ/kWh (متوسط عامل انبعاث
            شبكة الكهرباء المغربية، مزيج كربوني كثيف — نفس الثابت المعروض في كل دراسة مُسعَّرة لدى
            Taqinor). المعادل بالأشجار: تمتصّ الشجرة الناضجة نحو {CO2_KG_PER_TREE_YEAR} كلغ من
            CO₂ سنوياً، أي ما يعادل هنا نحو <strong>{treesLabel} شجرة</strong> تُغرَس كل سنة. لا
            رقم هنا مُقرَّب نحو الأعلى أو مُستقرَأ أو مُقدَّر خارج التركيبات المنشورة فعلاً.
          </p>
        </Callout>
      </div>
    </section>

    <!-- التفصيل، مشروعاً بمشروع -->
    <div class="v2-seam" aria-hidden="true"></div>
    <section class="section bg-blanc-azur px-4 text-encre">
      <div class="mx-auto max-w-3xl">
        <p class="tech-label v2-kicker rule-brass text-azur-600">التفصيل</p>
        <h2 class="display v2-section-title mt-5">مشروعاً بمشروع</h2>
        <p class="v2-lead mt-4 text-encre-soft">
          كل سطر في الحصيلة أعلاه يقابل تركيبة حقيقية، موثَّقة على صفحة إنجازاتنا.
        </p>
        <div class="mt-10 border-t-2 border-azur-900 bg-blanc" data-stagger>
          {REALISATIONS.map((r, i) => (
            <div class="v2-rise flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1 border-b border-azur-900/15 px-5 py-4" style={`--v2-i:${i}`}>
              <span class="text-sm font-semibold" dir="ltr">{r.ville} · {r.kwc} · réf. {r.ref}</span>
              <span class="whitespace-normal text-end text-sm text-azur-600" dir="ltr">
                {r.production ? `${r.production} مقيسة` : 'إنتاج غير منشور'}
                {r.batterie ? ` · ${r.batterie}` : ''}
              </span>
            </div>
          ))}
        </div>
        <p class="mx-auto mt-6 max-w-xl border-s-4 border-azur-600 ps-4 text-sm leading-relaxed text-encre-soft">
          <a href={L('/realisations')} class="border-b border-azur-600 pb-0.5 font-semibold text-azur-600 transition-colors hover:text-azur-700">شاهد كل إنجازاتنا بالتفصيل <span class="inline-block rtl:-scale-x-100">→</span></a>
        </p>
      </div>
    </section>

    <!-- لماذا تبقى هذه الصفحة صغيرة -->
    <section class="section px-4 text-white">
      <div class="mx-auto max-w-3xl">
        <p class="tech-label v2-kicker rule-brass text-lune">لماذا القليل فقط</p>
        <h2 class="display v2-section-title mt-5 text-white">صغيرة الآن، صادقة دائماً</h2>
        <p class="v2-lead mt-5 text-lune-soft">
          كان بإمكاننا تضخيم هذه الحصيلة بتقديرات نظرية أو مردوديات الكتالوج أو توقّعات على خمس
          سنوات. نفضّل أن نحتسب فقط ما هو مركَّب ومتابَع ومنشور بالفعل — ما يجعل هذا الرقم أصغر
          مما قد يبدو، لكنه قابل للتحقّق سطراً بسطر على صفحة إنجازاتنا. كل مشروع جديد موثَّق يدفع
          هذا المجموع قُدُماً؛ هذه هي الطريقة الوحيدة التي سينمو بها.
        </p>
      </div>
    </section>

    <section class="section-tight px-4 pb-20 sm:pb-24">
      <div class="mx-auto max-w-6xl">
        <p class="tech-label v2-kicker rule-brass text-lune">للتعمّق أكثر</p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a href={L('/realisations')} class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">إنجازاتنا <span class="inline-block rtl:-scale-x-100">→</span></a>
          <a href={L('/batteries-stockage')} class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">البطاريات والتخزين <span class="inline-block rtl:-scale-x-100">→</span></a>
          <a href={L('/garanties')} class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">الضمانات <span class="inline-block rtl:-scale-x-100">→</span></a>
          <a href={L('/à-propos')} class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">عن Taqinor <span class="inline-block rtl:-scale-x-100">→</span></a>
        </div>
      </div>
    </section>

    <CtaBand title="مشروع قد يُضاف لهذه الحصيلة؟ ابدأ التشخيص المجاني." href={devisHref} />

    <StickyCta />
  </div>
</Layout>
