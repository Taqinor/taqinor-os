---
/**
 * AR — Our warranties (W67, RTL). Faithful Arabic translation of /garanties ;
 * EVERY figure (12/30/10/20/2 years, 87.4 %) kept EXACT in Latin digits. No
 * invented SLA. Internal links use localizeNavHref (FR fallback). FR untouched.
 *
 * W331 — three honest additions: (1) a "what isn't covered" clause (WG16 still
 * in progress: GENERIC exclusions, marked "to confirm"); (2) a concrete
 * scenario if performance falls under the guaranteed floor; (3) a claim step
 * list with the response window resolved by the founder (WG9: "within 1 h,
 * 7 days a week").
 *
 * W352 — "Taqinor Production Guarantee" scaffold: same `pending founder
 * commitment` framing as FR/EN, no floor % until WG12 lands — see
 * productionGuarantee below.
 */
import Layout from '../../layouts/Layout.astro';
import V2Enhance from '../../components/V2Enhance.astro';
import Article33Ribbon from '../../components/Article33Ribbon.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CtaBand from '../../components/CtaBand.astro';
import StickyCta from '../../components/StickyCta.astro';
import ZelligeDivider from '../../components/ZelligeDivider.astro';
import InstallCounter from '../../components/InstallCounter.astro';
import CertLogoRow from '../../components/CertLogoRow.astro';
import { getLocaleFromPath } from '../../i18n/utils';
import { localizeNavHref } from '../../i18n/pages';
import { WHATSAPP_LEADS } from '../../lib/nap';
import { whatsappLink } from '../../lib/whatsapp';

const locale = getLocaleFromPath(Astro.url.pathname);
const L = (href: string) => localizeNavHref(href, locale);
const devisHref = L('/devis/mon-toit');
const waClaim = whatsappLink(WHATSAPP_LEADS, 'مرحباً، أرغب في تفعيل ضمان تاكينور الخاص بي.');

const warranties = [
  { item: 'الألواح الكهروضوئية (المنتج)', years: '12 سنة' },
  { item: 'الألواح الكهروضوئية (الأداء)', years: '30 سنة', note: 'خطي، ≥ 87.4 % من القدرة الأولية عند 30 سنة' },
  { item: 'العاكسات (Deye، Huawei)', years: '10 سنوات' },
  { item: 'بطاريات Dyness LFP', years: '10 سنوات', note: '≥ 70 % من السعة — حسب وثيقة الضمان الصادرة عن الموزّع (بعض الإصدارات الإقليمية تُظهر 7 سنوات)' },
  { item: 'الهيكل من الفولاذ المجلفن', years: '20 سنة' },
  { item: 'التركيب واليد العاملة لتاكينور', years: 'سنتان' },
];

const engagements = [
  {
    title: 'ننظر إلى منحناك، لا إلى منحانا فقط',
    body: 'كل تركيبة ترفع بياناتها إلى Deye Cloud: إنتاج في الزمن الحقيقي، سجلات، تنبيهات تلقائية. تتلقّى ولوجك الشخصي عبر التطبيق المحمول — ترى تماماً ما نراه، يوماً بعد يوم.',
  },
  {
    title: 'نحن من يرصد الخلل، لا أنت',
    body: 'نُبقي عيناً على كامل الأسطول المركَّب. حين ينطلق تنبيه، يصلنا — الفكرة أن نتحرك على انحراف قبل أن تلاحظ أي شيء في بيتك.',
  },
  {
    title: 'الملف يبقى بين يديك',
    body: 'عند التسليم، تغادر بكل شيء: مخططات أحادية الخط، حساب الكوابل، لائحة الحمايات، مسطرة التشغيل وولوج مراقبة Deye Cloud. ما يكفي لاستدعاء أي تقني، يوم تشاء.',
  },
];

// W331 — استثناءات عامة (على مستوى القطاع) لضمان كهروضوئي قياسي، وليست
// اللائحة التعاقدية النهائية لتاكينور. بوابة WG16 لا تزال مفتوحة: على رضا
// تأكيدها أو تعديلها قبل أن تصبح المرجع التعاقدي.
const exclusions = [
  'ضرر عرضي أو صدمة خارجية (سقوط جسم، برَد استثنائي، تخريب)',
  'تعديل أو إزالة أو تدخّل من طرف ثالث غير معتمد من تاكينور',
  'إهمال صيانة واضح (اتساخ لم يُعالَج، نباتات لم تُزَل)',
  'حدث قوة قاهرة (صاعقة مباشرة، حريق، كارثة طبيعية) — يخص تأمين سكنك، لا ضمان معداتنا',
  'تآكل عادي يتجاوز عتبات الأداء المضمونة (انظر الجدول أعلاه)',
];

// W331 — لائحة خطوات ملموسة لتفعيل الضمان. نافذة الاستجابة حُسمت من طرف
// المؤسس (WG9، 2026-07-03): «خلال ساعة واحدة، 7 أيام على 7».
const claimSteps = [
  {
    n: '01',
    title: 'تواصلوا معنا عبر واتساب',
    body: 'نفس القناة المستعملة لدراستكم — صفوا ما تلاحظونه (انخفاض إنتاج، تنبيه، ضرر ظاهر).',
  },
  {
    n: '02',
    title: 'أعطونا مرجع ورشكم',
    body: 'مرجع تركيبتكم (ظاهر في الملف التقني المُسلَّم عند التسليم) يتيح إيجاد معداتكم فوراً، وتاريخ تركيبها وضمانها.',
  },
  {
    n: '03',
    title: 'أرفقوا صورة إن كان العطب ظاهراً',
    body: 'لوح أو عاكس أو تثبيت به مشكل مادي ظاهر — الصورة تُسرّع التشخيص حتى قبل تنقّلنا.',
  },
  {
    n: '04',
    title: 'نجيب خلال ساعة واحدة، 7 أيام على 7',
    body: 'التزامنا بالاستجابة — ليس أجل حل، بل إشعار استلام بشري يُطلق معالجة ملفكم.',
  },
];

// W352 — «ضمان إنتاج تاكينور»: scaffold `pending founder commitment`. تبقى
// floorPct/remedy فارغة (null) إلى أن توفر WG12 (بوابة المؤسس) العتبة
// السنوية والحل — إلى ذلك الحين لا يُعرض سوى الإطار، أبداً نسبة مخترعة.
const productionGuarantee = {
  floorPct: null as number | null,
  remedy: null as string | null,
};
---

<Layout
  title="ضماناتنا — ما الذي يُغطّى، ولكم من السنوات | Taqinor"
  description="تركيبة تاكينور تلتزم على المدى الطويل: 30 سنة أداء خطي و12 سنة منتج على الألواح (≥ 87.4 % من القدرة عند 30 سنة)، 10 سنوات للعاكسات والبطاريات، 20 سنة للهيكل، سنتان للتركيب. ومراقبة ترصد الخلل قبلك، على Deye Cloud."
  ogSlug="garanties"
>
  <div class="v2">
    <V2Enhance />
    <Article33Ribbon />

    <Breadcrumb items={[{ label: 'الرئيسية', href: L('/') }, { label: 'ضماناتنا' }]} />

    <section class="px-4 pb-10 pt-16 text-white sm:pt-20">
      <div class="mx-auto max-w-3xl">
        <p class="tech-label v2-kicker rule-brass cine-in text-lune">التزامات تعاقدية</p>
        <h1 class="display v2-page-title cine-in mt-5 [animation-delay:120ms]">ما نلتزم به</h1>
        <p class="v2-lead cine-in mt-6 max-w-xl text-white/85 [animation-delay:240ms]">
          الضمان لا قيمة له إلا إذا كان مكتوباً وقابلاً للتفعيل. ضماناتنا كذلك، مكوّناً بمكوّن، من
          سنتين إلى 30 سنة — والذي يهم فعلاً في استثمار طويل الأمد هو الأداء: ينبغي لألواحك أن تُعيد
          <strong class="text-white">87.4 % على الأقل من قدرتها عند 30 سنة</strong> (ضمان خطي). الجدول أدناه
          لا يخفي أي سطر.
        </p>
      </div>
    </section>

    {/* W280 — InstallCounter: أرقام إنجازات حقيقية، مُشتقة من realisations.ts
        (لا رقم مُختلَق). آمن بدون بيانات. */}
    <section class="px-4 pb-4 sm:pb-6">
      <div class="mx-auto max-w-3xl">
        <InstallCounter />
      </div>
    </section>

    <!-- جدول الضمانات -->
    <div class="v2-seam" aria-hidden="true"></div>
    <section class="bg-blanc-azur px-4 pb-20 pt-10 text-encre sm:pb-24">
      <div class="mx-auto max-w-3xl">
        <p class="tech-label v2-kicker rule-brass text-azur-600">مدد الضمان</p>
        <h2 class="display v2-section-title mt-5">كل مكوّن يحمل ضمانه</h2>
        <div class="mt-10 border-t-2 border-azur-900 bg-blanc" data-stagger>
          {warranties.map((w, i) => (
            <div class="v2-rise flex items-baseline justify-between gap-4 border-b border-azur-900/15 px-5 py-4" style={`--v2-i:${i}`}>
              <span class="text-sm font-semibold">{w.item}{w.note && <span class="block text-xs font-normal text-encre-faint">{w.note}</span>}</span>
              <span class="fig whitespace-nowrap text-2xl text-azur-600" dir="ltr" data-tally>{w.years}</span>
            </div>
          ))}
        </div>
        <p class="mx-auto mt-6 max-w-xl border-s-4 border-azur-600 ps-4 text-sm leading-relaxed text-encre-soft">
          التفصيل الذي يغيّر كل شيء: هذه العلامات من الصف الأول مصدرها موزّعون رسميون بالمغرب. الضمان
          لا قيمة له إلا إذا أمكن تفعيله دون إرجاع لوح إلى الطرف الآخر من العالم — وهذه تُفعَّل محلياً.
          <a href={L('/équipement')} class="border-b border-azur-600 pb-0.5 font-semibold text-azur-600 transition-colors hover:text-azur-700">انظر المعدات المركَّبة <span class="inline-block rtl:-scale-x-100">→</span></a>
        </p>

        {/* W280 — CertLogoRow: معايير/ضمانات منشورة أعلاه، آمن بدون بيانات
            (لا شعار مُختلَق). */}
        <div class="mx-auto mt-10 max-w-xl">
          <CertLogoRow />
        </div>

        <!-- W331 — «ما لا يُغطّى»: ذكر الاستثناءات يجعل الضمان أكثر مصداقية، لا
             أقل. عام على مستوى القطاع، WG16-pending. -->
        <div class="mx-auto mt-14 max-w-xl">
          <p class="tech-label text-azur-600">قيل أيضاً بوضوح</p>
          <h3 class="display mt-2 text-lg">ما لا يُغطّى</h3>
          <p class="mt-3 text-sm leading-relaxed text-encre-soft">
            الضمان الصادق يذكر أيضاً حدوده. إليكم، على سبيل الاستدلال، الاستثناءات القياسية لضمان
            معدات كهروضوئية في القطاع:
          </p>
          <ul class="mt-4 space-y-2 border-t border-azur-900/15 pt-4 text-sm leading-relaxed text-encre-soft">
            {exclusions.map((ex) => (
              <li class="flex gap-2"><span class="text-azur-600" aria-hidden="true">–</span><span>{ex}</span></li>
            ))}
          </ul>
          <p class="mt-4 text-xs italic text-encre-faint">
            رهن التأكيد: اللائحة الدقيقة قيد المصادقة من طرف تاكينور — النسخة التعاقدية التي تُسلَّم
            لكم عند التوقيع هي المرجع.
          </p>
        </div>

        <!-- W331 — سيناريو ملموس إن انخفض الأداء دون العتبة المضمونة -->
        <div class="mx-auto mt-14 max-w-xl border-t-2 border-azur-900 bg-blanc p-6">
          <p class="tech-label text-azur-600">سيناريو ملموس</p>
          <h3 class="display mt-2 text-lg">إن انخفض الأداء دون العتبة الخطية المضمونة</h3>
          <p class="mt-3 text-sm leading-relaxed text-encre-soft">
            تُقاس ألواحكم باستمرار على Deye Cloud. إن أثبت فحص، خلال فترة 30 سنة، أن القدرة المُعادة
            انخفضت دون العتبة الخطية المضمونة (≥ 87.4 % من القدرة الأولية عند 30 سنة) — خارج الاستثناءات أعلاه — يُطبَّق
            ضمان الصانع: تعويض أو تبديل اللوح المعني، وفق شروط الصانع. لهذا بالضبط تعمل المراقبة باستمرار
            — لرصد هذا النوع من الانحراف مبكراً، حتى قبل أن تلاحظوه في فاتورتكم.
          </p>
        </div>

        <!-- W352 — «ضمان إنتاج تاكينور»: قسم مستقل، `pending founder
             commitment`. يشرح الإطار (كيف تُقاس عتبة إنتاج سنوية، من أي
             بيانات) دون عرض أي نسبة إلى أن تحسم WG12 — انظر
             productionGuarantee أعلاه. -->
        <div class="mx-auto mt-14 max-w-xl border-2 border-brass-400/50 bg-blanc p-6">
          <p class="tech-label text-azur-600">ما تجعله بياناتنا ممكناً</p>
          <h3 class="display mt-2 text-lg">ضمان إنتاج تاكينور</h3>
          {productionGuarantee.floorPct ? (
            <p class="mt-3 text-sm leading-relaxed text-encre-soft">
              نلتزم بعتبة قدرها <strong>{productionGuarantee.floorPct} %</strong> من الإنتاج السنوي
              المقدَّر (منهجية PVGIS)، مقيسةً على مراقبة Deye Cloud الخاصة بكم.
              {productionGuarantee.remedy ? ` ${productionGuarantee.remedy}` : ''}
            </p>
          ) : (
            <>
              <p class="mt-3 text-sm leading-relaxed text-encre-soft">
                كل تركيبة تاكينور ترفع إنتاجها الحقيقي، باستمرار، على Deye Cloud — هذه البيانات المقيسة
                بالذات، على أسطول يُتابَع منذ أكثر من سنة (انظر
                {' '}<a href={L('/realisations')} class="font-semibold text-azur-600 underline decoration-azur-600/40 underline-offset-2 hover:decoration-azur-600">إنجازاتنا</a>)،
                هي ما يجعل التزاماً رقمياً ذا مصداقية: عتبة إنتاج سنوية (كنسبة من تقدير PVGIS المعتمد
                عند الدراسة) دونها يُطبَّق حل محدد.
              </p>
              <p class="mt-3 text-sm leading-relaxed text-encre-soft">
                هذه العتبة وحلّها لم يُحسما بعد — لا ننشر أي نسبة إلى أن يُحسم الالتزام. سيُستكمل هذا
                القسم بمجرد ذلك.
              </p>
              <p class="mt-4 text-xs italic text-encre-faint">
                في انتظار التزام من المؤسس — لا يُنشر أي رقم قبل التأكيد.
              </p>
            </>
          )}
        </div>
      </div>
    </section>

    <!-- التزامات المتابعة -->
    <section class="px-4 py-20 sm:py-28">
      <div class="mx-auto max-w-6xl">
        <p class="tech-label v2-kicker rule-brass text-lune">أبعد من المعدات</p>
        <h2 class="display v2-section-title mt-5 text-white">المتابعة التي تُطيل الضمان</h2>
        <div class="mt-10 grid gap-6 md:grid-cols-3" data-stagger>
          {engagements.map((e, i) => (
            <div class="v2-rise cine-card p-7" style={`--v2-i:${i}`}>
              <h3 class="display text-xl text-white">{e.title}</h3>
              <p class="mt-3 text-sm leading-relaxed text-lune-soft">{e.body}</p>
            </div>
          ))}
        </div>
        <div class="mt-10 flex flex-wrap gap-3">
          <a href={L('/résidentiel')} class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">الطاقة الشمسية السكنية <span class="inline-block rtl:-scale-x-100">→</span></a>
          <a href={L('/professionnel')} class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">الطاقة الشمسية المهنية <span class="inline-block rtl:-scale-x-100">→</span></a>
          <a href={L('/realisations')} class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">إنجازاتنا <span class="inline-block rtl:-scale-x-100">→</span></a>
        </div>
      </div>
    </section>

    <!-- W331 — كيف تُفعّلون ضمانكم، لائحة خطوات ملموسة -->
    <ZelligeDivider tone="white" />
    <section class="section px-4">
      <div class="mx-auto max-w-4xl">
        <p class="tech-label v2-kicker rule-brass text-lune">اليوم الذي تحتاجونه فيه</p>
        <h2 class="display v2-section-title mt-5 text-white">كيف تُفعّلون ضمانكم</h2>
        <p class="v2-lead mt-4 max-w-2xl text-lune-soft">
          الضمان المكتوب لا يفيد شيئاً إن تحوّل تفعيله إلى مسار معقّد. إليكم بالضبط ما ينبغي فعله.
        </p>
        <ol class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4" data-stagger>
          {claimSteps.map((s, i) => (
            <li class="v2-rise border-s-2 border-brass-400/60 ps-6" style={`--v2-i:${i}`}>
              <p class="fig lum text-2xl">{s.n}</p>
              <h3 class="display mt-2 text-lg text-white">{s.title}</h3>
              <p class="mt-3 text-sm leading-relaxed text-lune-soft">{s.body}</p>
            </li>
          ))}
        </ol>
        <a href={waClaim} rel="noopener" class="mt-10 inline-flex items-center gap-2 bg-brass-400 px-7 py-3.5 text-base font-bold text-azur-950 transition-colors hover:bg-brass-300">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 0 0-8.6 15.1L2 22l5-1.3A10 10 0 1 0 12 2Zm5.4 14.1c-.2.6-1.3 1.2-1.8 1.2-.5.1-1 .2-3.3-.7-2.8-1.1-4.6-4-4.7-4.2-.1-.2-1.1-1.5-1.1-2.9s.7-2 1-2.3c.2-.3.5-.3.7-.3h.5c.2 0 .4 0 .6.4l.9 2.1c.1.2.1.4 0 .6l-.4.6-.5.5c-.2.2-.3.4-.1.7.2.3.9 1.4 1.9 2.3 1.3 1.1 2.3 1.5 2.6 1.6.3.1.5.1.7-.1l1-1.2c.2-.3.4-.2.7-.1l2 1c.3.1.5.2.6.4 0 .1 0 .7-.3 1.4Z"/></svg>
          فعّلوا ضماني عبر واتساب
        </a>
      </div>
    </section>

    <CtaBand title="ضمان 30 سنة يُكتسب بدراسة جادة. ودراستنا مجانية." href={devisHref} />

    <StickyCta />
  </div>
</Layout>
