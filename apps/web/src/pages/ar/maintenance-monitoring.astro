---
/**
 * AR — Maintenance & monitoring (W67, RTL). Faithful Arabic translation of
 * /maintenance-monitoring ; no invented SLA. Internal links via localizeNavHref.
 * FR untouched.
 *
 * ÉLÉVATION (W241) — mirrors the FR maintenance-monitoring.astro elevation:
 *  1. brass discipline: eyebrows text-lune (not text-brass-300) on dark sections;
 *  2. .section + seam-soft tokens for rhythm;
 *  3. following link demoted: border-brass-400 → border-lune/40, text-brass-300 → text-lune;
 *  4. light section eyebrow uses eyebrow-light class;
 *  5. glow on primary CTA in light section;
 *  6. RTL-logical border-s-2 for the follow-up note.
 *
 * W255 — خدمة ما بعد البيع الاستباقية تصبح عنواناً قائماً بذاته (عنوان مشترك
 * مع المراقبة)، مع 3 مستويات عقد صيانة مُسمّاة (Essentiel/Confort/Premium):
 * محتويات مبنية على ما هو منشور فعلاً.
 * WN4 (2026-07-05) — مهلة الرد والسعر لم يصادق عليهما المؤسس بعد (WG10):
 * بدل عرض عنصر نائب "في انتظار مصادقة المؤسس" على الزبون، يُحذَف هذان الحقلان
 * ويُحال كل مستوى إلى عرض سعر شخصي عبر زر واتساب مُعبَّأ مسبقاً.
 *
 * W257 — المراقبة مُقدَّمة بالنتائج (3 محاكاة هاتف صادقة — دون أي لقطة Deye
 * Cloud مُلفَّقة، فقط الوعود الثلاثة المنشورة أعلاه) + تذكير بتنبيه واتساب عند
 * أي خلل.
 *
 * W340 — «بعد تركيبكم» + باب الفضاء الخاص. قسم سردي في 4 خطوات (تشغيل ←
 * متابعة الإنتاج ← فتح تذكرة خدمة ما بعد البيع ← الضمانات)، مؤسَّس على
 * القدرات الحقيقية المنشورة أدناه فعلاً (لا شيء جديد يُختلَق هنا، فقط السرد
 * يتغيّر): DEYE_CLOUD_URL يُحيل إلى بوابة Deye Cloud العمومية الحقيقية
 * (www.deyecloud.com/login — الولوج الشخصي المذكور أعلاه)، تذكرة خدمة ما بعد
 * البيع تُحيل إلى الباب الحقيقي W339 (/contact#deja-client)، والضمانات إلى
 * /garanties. محتوى فقط: لا يوجد ولا يُخطَّط لأي فضاء خاص مُخصَّص هنا — سيكون
 * ذلك عملاً خلفياً، خارج النطاق.
 */
import Layout from '../../layouts/Layout.astro';
import V2Enhance from '../../components/V2Enhance.astro';
import Article33Ribbon from '../../components/Article33Ribbon.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CtaBand from '../../components/CtaBand.astro';
import StickyCta from '../../components/StickyCta.astro';
import { getLocaleFromPath } from '../../i18n/utils';
import { localizeNavHref } from '../../i18n/pages';
import { DEYE_CLOUD_URL, WHATSAPP_LEADS } from '../../lib/nap';
import { whatsappLink } from '../../lib/whatsapp';

const locale = getLocaleFromPath(Astro.url.pathname);
const L = (href: string) => localizeNavHref(href, locale);
const devisHref = L('/devis/mon-toit');

// W340 — الخطوات الأربع لما بعد التركيب، بترتيب المسار الحقيقي. كل خطوة
// تستند إلى قدرة منشورة فعلاً في هذه الصفحة (المتابعة) أو في مكان آخر من
// الموقع (الضمانات، خدمة ما بعد البيع W339) — لا وعد جديد.
const apresInstallation = [
  {
    k: '01',
    title: 'التشغيل',
    body: 'تُربَط التركيبة وتُختبَر، ويُسجَّل دونݣل المراقبة لمتابعة الإنتاج في الوقت الحقيقي. يُسلَّم الملف التقني الكامل (مخططات، حمايات، مسطرة) في اليوم نفسه.',
  },
  {
    k: '02',
    title: 'متابعة الإنتاج',
    body: 'ابتداءً من اليوم الموالي، يعرض ولوجكم الشخصي الإنتاج الحقيقي، يوماً بعد يوم. هو المعطى نفسه الذي تستند إليه ضماناتنا المكتوبة — لا أكثر ولا أقل.',
  },
  {
    k: '03',
    title: 'فتح تذكرة خدمة ما بعد البيع',
    body: 'تنبيه من جهتكم أو من مراقبتنا الآنية؟ بلاغ عبر واتساب يفتح تذكرة في وحدة خدمة ما بعد البيع لدينا، تُتابَع حتى إغلاقها — نفس باب «هل أنتم زبون بالفعل؟» في صفحة الاتصال.',
  },
  {
    k: '04',
    title: 'الضمانات',
    body: 'تسري الضمانات المكتوبة (المعدات، اليد العاملة) بالتوازي، مع الإنتاج المقيس كمرجع مشترك عند أي نزاع.',
  },
];

// W255/WN4 — 3 مستويات عقد صيانة مُسمّاة: المحتويات مأخوذة مما هو منشور فعلاً
// (مراقبة/خدمة ما بعد البيع/ملف تقني). مهلة الرد والسعر لم يصادق عليهما
// المؤسس بعد (WG10): بدل عنصر نائب يظهر للزبون، يُحذَف هذان الحقلان ويُحال كل
// مستوى إلى عرض سعر شخصي عبر واتساب.
const entretienTiers = [
  {
    name: 'Essentiel',
    body: 'متابعة الإنتاج في الوقت الحقيقي مُضمَّنة وإشراف على كامل الأسطول: هذا هو الأساس المُسلَّم فعلاً مع كل تركيبة.',
    inclusions: ['ولوج شخصي إلى متابعة الإنتاج', 'تنبيه تلقائي عند العطل', 'ملف تقني كامل'],
  },
  {
    name: 'Confort',
    body: 'أساس Essentiel، بالإضافة إلى زيارة صيانة مُبرمجة للحفاظ على أفضل مردود للتركيبة.',
    inclusions: ['كل ما في Essentiel', 'زيارة صيانة مُبرمجة', 'تنظيف الألواح'],
  },
  {
    name: 'Premium',
    body: 'المستوى الأكثر اكتمالاً: صيانة معزَّزة وتدخّل ذو أولوية عند التنبيه.',
    inclusions: ['كل ما في Confort', 'زيارات صيانة معزَّزة', 'تدخّل ذو أولوية عند التنبيه'],
  },
];

const waTier = (tierName: string) =>
  whatsappLink(WHATSAPP_LEADS, `Bonjour, je souhaite en savoir plus sur le contrat d’entretien ${tierName}.`);

// W257 — 3 محاكاة هاتف توضيحية (لا لقطة Deye Cloud حقيقية، لا رقم مُختلَق):
// الإنتاج المباشر، التنبيه، متابعة الاقتصاد حتى تاريخه. تسميات عامة فقط.
const phoneVues = [
  {
    appLabel: 'متابعة الإنتاج',
    headline: '3.2 kW',
    accent: 'text-brass-300',
    sub: 'إنتاج مباشر',
    caption: 'إنتاجك، مقروء في الزمن الحقيقي — نفس المعطى الذي تستند إليه ضماناتنا المكتوبة.',
  },
  {
    appLabel: 'متابعة الإنتاج',
    headline: 'تنبيه',
    accent: 'text-white',
    sub: 'عاكس · رمز عطل',
    caption: 'خلل يُطلق تنبيه واتساب عندنا قبل أن تلاحظه أنت.',
  },
  {
    appLabel: 'متابعة الإنتاج',
    headline: 'سجل',
    accent: 'text-brass-300',
    sub: 'الاقتصاد حتى تاريخه',
    caption: 'مجموع الإنتاج يومياً وشهرياً، لمتابعة ما أعطته التركيبة فعلاً.',
  },
];

const suivi = [
  {
    title: 'متابعة الإنتاج في الوقت الحقيقي مُضمَّنة',
    body: 'كل تركيبة تخضع لمتابعة الإنتاج في الوقت الحقيقي: إنتاج في الزمن الحقيقي، سجلات يومية وشهرية، تنبيهات تلقائية عند العطل. تتلقّى ولوجك الشخصي على التطبيق المحمول، وترى تماماً ما يراه المركّب.',
  },
  {
    title: 'خدمة ما بعد البيع الاستباقية',
    body: 'نُبقي عيناً على كامل الأسطول المركَّب. حين ترفع مراقبتنا الآنية تنبيهاً، فهو ليس مجرّد ضوء أحمر: يُسمّي العاكس المعنيّ، ورمز العطل المُبلَّغ، والساعة التي تراجع فيها الإنتاج. وغالباً ما نكون قد حدّدنا السبب قبل أن يلاحظ الزبون أيّ شيء.',
  },
  {
    title: 'ملف تقني كامل',
    body: 'تغادر التركيبة بملفها: مخططات أحادية الخط، حساب مقطع الكوابل، لائحة الحمايات، مسطرة التشغيل وولوج متابعة الإنتاج في الوقت الحقيقي. ما يكفي ليتولّى كهربائي آخر المهمة عند الحاجة.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Maintenance & monitoring',
  serviceType: 'صيانة وإشراف على التركيبات الشمسية',
  provider: { '@type': 'Organization', name: 'Taqinor', url: 'https://taqinor.ma' },
  areaServed: { '@type': 'Country', name: 'Maroc' },
  description:
    'إشراف في الوقت الحقيقي مُضمَّن على كل تركيبة شمسية بالمغرب: إنتاج في الزمن الحقيقي، تنبيهات تلقائية وخدمة ما بعد البيع استباقية، مع ولوج للزبون عبر التطبيق المحمول وملف تقني كامل يُسلَّم.',
};
---

<Layout
  title="الصيانة وخدمة ما بعد البيع والمراقبة الشمسية: إشراف في الوقت الحقيقي مُضمَّن | Taqinor"
  description="كل تركيبة تاكينور تخضع لمتابعة الإنتاج في الوقت الحقيقي — إنتاج في الزمن الحقيقي، سجلات، تنبيهات تلقائية — مع ولوج للزبون على التطبيق المحمول. خدمة ما بعد البيع الاستباقية تتحرّك عند التنبيه، قبل الشكاية، وتمتدّ إلى عقود صيانة مُسمّاة. ملف تقني كامل يُسلَّم مع الورش."
  ogSlug="maintenance-monitoring"
>
  <div class="v2">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <V2Enhance />
    <Article33Ribbon />

    <Breadcrumb items={[{ label: 'الرئيسية', href: L('/') }, { label: 'الصيانة والمراقبة' }]} />

    {/* ── HÉROS SOMBRE — W255: خدمة ما بعد البيع عنوان مشترك مع المراقبة ── */}
    <section class="px-4 pb-12 pt-16 text-white sm:pt-20">
      <div class="mx-auto max-w-3xl">
        <p class="tech-label v2-kicker rule-brass cine-in text-lune">بعد التركيب</p>
        <h1 class="display v2-page-title cine-in cine-in-1 mt-5">المراقبة وخدمة ما بعد البيع الاستباقية</h1>
        <p class="v2-lead cine-in cine-in-2 mt-6 max-w-xl text-white/85">
          يوم تُشغَّل التركيبة، تبدأ في الكلام. بفضل متابعة الإنتاج في الوقت الحقيقي، كل سطح تاكينور يرفع إنتاجه باستمرار —
          إنتاجك مقروء على هاتفك، وإنتاجنا مُراقب على كامل الأسطول. خلل يُطلق تنبيهاً؛ تنطلق خدمة ما
          بعد البيع من هناك، قبل الشكاية — وحدة مخصَّصة في نظامنا الداخلي تتبّع كل تدخّل حتى إغلاقه.
        </p>
      </div>
    </section>

    {/* ── W340 — بعد تركيبكم + الفضاء الخاص ──
        سرد في 4 خطوات للمسار الحقيقي (تشغيل ← متابعة الإنتاج ← فتح تذكرة
        خدمة ما بعد البيع ← الضمانات)، ثم باب الفضاء الخاص: بوابة Deye Cloud
        الحقيقية (ولوج شخصي مُسلَّم فعلاً لكل زبون) + مسار تذكرة خدمة ما بعد
        البيع الحقيقي (/contact#deja-client، W339) + الضمانات المكتوبة. محتوى
        فقط، دون أي فضاء خاص مُختلَق. */}
    <div class="seam-soft" aria-hidden="true"></div>
    <section class="section px-4">
      <div class="mx-auto max-w-6xl">
        <p class="tech-label v2-kicker rule-brass text-lune">ما يحدث بعد ذلك</p>
        <h2 class="display v2-section-title mt-5 text-white">بعد تركيبكم</h2>
        <p class="v2-lead mt-5 max-w-2xl text-lune-soft">
          التركيب ليس نهاية العلاقة، بل بدايتها. إليكم، بالترتيب، ما ينتظركم بمجرّد انتهاء الورش.
        </p>
        <ol class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4" data-stagger>
          {apresInstallation.map((s, i) => (
            <li class="v2-rise cine-card flex flex-col p-6" style={`--v2-i:${i}`}>
              <span class="fig lum text-2xl" aria-hidden="true" dir="ltr">{s.k}</span>
              <h3 class="display mt-3 text-lg text-white">{s.title}</h3>
              <p class="mt-3 flex-1 text-sm leading-relaxed text-lune-soft">{s.body}</p>
            </li>
          ))}
        </ol>

        {/* باب الفضاء الخاص — زر نحاسي وحيد (بوابة متابعة الإنتاج الحقيقية)،
            رابطان ثانويان (تذكرة خدمة ما بعد البيع الحقيقية، الضمانات). */}
        <div class="v2-rise mt-12 border-t-2 border-white/15 bg-white/[0.03] p-7 sm:p-9" style="--v2-i:4">
          <p class="tech-label text-lune">الفضاء الخاص</p>
          <h3 class="display mt-2 text-xl text-white">ولوجكم الشخصي إلى متابعة الإنتاج</h3>
          <p class="mt-3 max-w-xl text-sm leading-relaxed text-lune-soft">
            يتلقّى كل زبون، عند التشغيل، ولوجه الخاص إلى متابعة الإنتاج في الوقت الحقيقي عبر تطبيق مخصّص —
            وليست فضاءً منفصلاً خاصاً بتاكينور. هناك تتابعون إنتاجكم، يوماً بعد يوم.
          </p>
          <div class="mt-6 flex flex-wrap gap-3">
            <a
              href={DEYE_CLOUD_URL}
              rel="noopener noreferrer"
              target="_blank"
              class="glow inline-flex items-center gap-2 bg-brass-400 px-6 py-3 text-sm font-bold text-azur-950 transition-colors hover:bg-brass-300"
            >
              افتحوا فضائي الخاص <span class="inline-block rtl:-scale-x-100">→</span>
            </a>
            <a href={`${L('/contact')}#deja-client`} class="inline-flex items-center gap-2 border border-white/40 px-6 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">
              افتحوا تذكرة خدمة ما بعد البيع
            </a>
            <a href={L('/garanties')} class="inline-flex items-center gap-2 border border-white/40 px-6 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">
              شاهدوا ضماناتي
            </a>
          </div>
        </div>
      </div>
    </section>

    {/* ── ما تشمله المتابعة — .section + eyebrow lune ── */}
    <div class="seam-soft" aria-hidden="true"></div>
    <section class="section px-4">
      <div class="mx-auto max-w-6xl">
        <p class="tech-label v2-kicker rule-brass text-lune">مُضمَّن مع كل تركيبة</p>
        <h2 class="display v2-section-title mt-5 text-white">ما تشمله المتابعة</h2>
        <div class="mt-12 grid gap-6 md:grid-cols-3" data-stagger>
          {suivi.map((s, i) => (
            <div class="v2-rise cine-card p-7" style={`--v2-i:${i}`}>
              <h3 class="display text-xl text-white">{s.title}</h3>
              <p class="mt-3 text-sm leading-relaxed text-lune-soft">{s.body}</p>
            </div>
          ))}
        </div>
        {/* خط azur، رابط lune */}
        <p class="v2-rise mt-12 max-w-xl border-s-2 border-azur-200/40 ps-4 text-sm leading-relaxed text-lune-soft">
          من ناحية المعدات، يمرّ رفع البيانات عبر دونݣل WiFi أو Ethernet موصول بالعاكس؛ هو من يرسل كل
          قياس إلى متابعة الإنتاج في الوقت الحقيقي. التفصيل موجود في بطاقة المعدات.
          <a href={L('/équipement')} class="border-b border-lune/40 pb-0.5 font-semibold text-lune transition-colors hover:border-lune hover:text-white">انظر متابعة الإنتاج <span class="inline-block rtl:-scale-x-100">→</span></a>
        </p>
      </div>
    </section>

    {/* ── W257 — ما تراه على هاتفك (نتائج، لا مواصفات) ──
        3 محاكاة هاتف CSS صادقة: لا لقطة Deye Cloud مُلفَّقة، فقط الوعود الثلاثة
        المنشورة أعلاه مُصوَّرة على إطار هاتف. */}
    <div class="seam-soft" aria-hidden="true"></div>
    <section class="section px-4">
      <div class="mx-auto max-w-6xl">
        <p class="tech-label v2-kicker rule-brass text-lune">على هاتفك</p>
        <h2 class="display v2-section-title mt-5 text-white">ما تراه، لا ما نَعِدك به</h2>
        <p class="v2-lead mt-5 max-w-2xl text-lune-soft">
          ثلاثة أسئلة تتكرّر قبل حتى الحديث عن البروتوكول أو تردّد القياس: هل أرى إنتاجي على هاتفي، هل
          أُنبَّه إن وقعت مشكلة، وأين وصل اقتصادي. وها هي الأجوبة الثلاثة.
        </p>
        <div class="mt-12 grid gap-6 md:grid-cols-3" data-stagger>
          {phoneVues.map((v, i) => (
            <div class="v2-rise flex flex-col items-center p-4" style={`--v2-i:${i}`}>
              <div class="phone-frame">
                <div class="phone-notch" aria-hidden="true"></div>
                <div class="phone-screen">
                  <p class="phone-app-label" dir="ltr">{v.appLabel}</p>
                  <p class={`phone-headline ${v.accent}`} dir="ltr">{v.headline}</p>
                  <p class="phone-sub">{v.sub}</p>
                </div>
              </div>
              <p class="mt-5 text-center text-sm leading-relaxed text-lune-soft">{v.caption}</p>
            </div>
          ))}
        </div>
        <p class="v2-rise mx-auto mt-10 max-w-xl text-center text-sm leading-relaxed text-lune-faint">
          هذه الرؤى توضّح مبدأ تطبيق متابعة الإنتاج — وليست لقطة شاشة رسمية. ما سيعرضه تطبيقك يتوقّف على
          تركيبتك الفعلية.
        </p>
      </div>
    </section>

    {/* ── W255 — خدمة ما بعد البيع: عقود صيانة مُسمّاة (سقالة، مهلة/سعر مُغلَقان WG10) ── */}
    <div class="v2-seam" aria-hidden="true"></div>
    <section class="bg-blanc-azur px-4 py-16 text-encre sm:py-20">
      <div class="mx-auto max-w-6xl">
        <p class="tech-label v2-kicker rule-brass eyebrow-light">خدمة ما بعد البيع الاستباقية، في صيغ</p>
        <h2 class="display v2-section-title mt-5">عقود الصيانة لدينا</h2>
        <p class="v2-lead mt-5 max-w-2xl text-encre-soft">
          أساس Essentiel مُضمَّن فعلاً مع كل تركيبة؛ Confort وPremium يضيفان الصيانة المُبرمجة وتدخّلاً
