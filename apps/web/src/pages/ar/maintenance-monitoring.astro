---
/**
 * AR — Maintenance & monitoring (W67, RTL). Faithful Arabic translation of
 * /maintenance-monitoring ; no invented SLA. Internal links via localizeNavHref.
 * FR untouched.
 */
import Layout from '../../layouts/Layout.astro';
import V2Enhance from '../../components/V2Enhance.astro';
import Article33Ribbon from '../../components/Article33Ribbon.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CtaBand from '../../components/CtaBand.astro';
import StickyCta from '../../components/StickyCta.astro';
import { getLocaleFromPath } from '../../i18n/utils';
import { localizeNavHref } from '../../i18n/pages';

const locale = getLocaleFromPath(Astro.url.pathname);
const L = (href: string) => localizeNavHref(href, locale);
const contactSim = L('/contact') + '#simulateur';

const suivi = [
  {
    title: 'مراقبة Deye Cloud مُضمَّنة',
    body: 'كل تركيبة ترفع بياناتها إلى Deye Cloud: إنتاج في الزمن الحقيقي، سجلات يومية وشهرية، تنبيهات تلقائية عند العطل. تتلقّى ولوجك الشخصي على التطبيق المحمول، وترى تماماً ما يراه المركّب.',
  },
  {
    title: 'خدمة ما بعد البيع الاستباقية',
    body: 'نُبقي عيناً على كامل الأسطول المركَّب. تنبيه Deye Cloud — عاكس في حالة عطل، إنتاج يتراجع — يصلنا قبل أن تلاحظ أي شيء. ننطلق من التشخيص، لا من مكالمتك.',
  },
  {
    title: 'ملف تقني كامل',
    body: 'تغادر التركيبة بملفها: مخططات أحادية الخط، حساب مقطع الكوابل، لائحة الحمايات، مسطرة التشغيل وولوج مراقبة Deye Cloud. ما يكفي ليتولّى كهربائي آخر المهمة عند الحاجة.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Maintenance & monitoring',
  serviceType: 'صيانة وإشراف على التركيبات الشمسية',
  provider: { '@type': 'Organization', name: 'Taqinor', url: 'https://taqinor.ma' },
  areaServed: { '@type': 'Country', name: 'Maroc' },
  description:
    'إشراف Deye Cloud مُضمَّن على كل تركيبة شمسية بالمغرب: إنتاج في الزمن الحقيقي، تنبيهات تلقائية وخدمة ما بعد البيع استباقية، مع ولوج للزبون عبر التطبيق المحمول وملف تقني كامل يُسلَّم.',
};
---

<Layout
  title="الصيانة والمراقبة الشمسية: إشراف Deye Cloud مُضمَّن | Taqinor"
  description="كل تركيبة تاكينور ترفع بياناتها إلى Deye Cloud — إنتاج في الزمن الحقيقي، سجلات، تنبيهات تلقائية — مع ولوج للزبون على التطبيق المحمول. تنبيه يصلنا قبلك: خدمة ما بعد البيع استباقية، وملف تقني كامل يُسلَّم مع الورش."
  ogSlug="equipement"
>
  <div class="v2">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <V2Enhance />
    <Article33Ribbon />

    <Breadcrumb items={[{ label: 'الرئيسية', href: L('/') }, { label: 'الصيانة والمراقبة' }]} />

    <!-- استهلال داكن -->
    <section class="px-4 pb-10 pt-16 text-white sm:pt-20">
      <div class="mx-auto max-w-3xl">
        <p class="tech-label v2-kicker rule-brass cine-in text-brass-300">بعد التركيب</p>
        <h1 class="display v2-page-title cine-in mt-5 [animation-delay:120ms]">الصيانة والمراقبة</h1>
        <p class="v2-lead cine-in mt-6 max-w-xl text-white/85 [animation-delay:240ms]">
          يوم تُشغَّل التركيبة، تبدأ في الكلام. على Deye Cloud، كل سطح تاكينور يرفع إنتاجه باستمرار —
          إنتاجك مقروء على هاتفك، وإنتاجنا مُراقب على كامل الأسطول. خلل يُطلق تنبيهاً؛ ننطلق من هناك،
          قبل الشكاية.
        </p>
      </div>
    </section>

    <!-- ما تشمله المتابعة -->
    <section class="px-4 pb-20 sm:pb-24">
      <div class="mx-auto max-w-6xl">
        <p class="tech-label v2-kicker rule-brass text-brass-300">مُضمَّن مع كل تركيبة</p>
        <h2 class="display v2-section-title mt-5 text-white">ما تشمله المتابعة</h2>
        <div class="mt-10 grid gap-6 md:grid-cols-3" data-stagger>
          {suivi.map((s, i) => (
            <div class="v2-rise cine-card p-7" style={`--v2-i:${i}`}>
              <h3 class="display text-xl text-white">{s.title}</h3>
              <p class="mt-3 text-sm leading-relaxed text-lune-soft">{s.body}</p>
            </div>
          ))}
        </div>
        <p class="mt-10 max-w-xl border-s-4 border-brass-400/60 ps-4 text-sm leading-relaxed text-lune-soft">
          من ناحية المعدات، يمرّ رفع البيانات عبر دونݣل WiFi أو Ethernet موصول بالعاكس؛ هو من يرسل كل
          قياس إلى Deye Cloud. التفصيل موجود في بطاقة المعدات.
          <a href={L('/équipement')} class="border-b border-brass-400 pb-0.5 font-semibold text-brass-300 transition-colors hover:text-brass-200">انظر مراقبة Deye Cloud →</a>
        </p>
      </div>
    </section>

    <!-- إنتاج مقيس، لا موعود (خلفية فاتحة) -->
    <div class="v2-seam" aria-hidden="true"></div>
    <section class="bg-blanc-azur px-4 pb-20 pt-10 text-encre sm:pb-24">
      <div class="mx-auto max-w-3xl">
        <div class="v2-rise">
          <p class="tech-label v2-kicker rule-brass text-azur-600">أرقام مقروءة</p>
          <h2 class="display v2-section-title mt-5">ما يقوله العدّاد، لا المطوية</h2>
          <p class="v2-lead mt-5 text-encre-soft">
            الـ kWh التي تعرضها تركيبة تاكينور لا تأتي من منشور: Deye Cloud يقرأها يوماً بعد يوم،
            وهذه القراءة هي الحجّة. ضماناتنا المكتوبة تستند إلى المعطى نفسه — ما يسجّله العدّاد، لا ما
            نودّ الإعلان عنه.
          </p>
          <p class="mt-5 text-sm leading-relaxed text-encre-soft">
            ولوحة القيادة لك أيضاً: ولوجك الشخصي على التطبيق المحمول يُظهر لك، في الزمن الحقيقي، ما
            يُنتجه سطحك — دون وسيط.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href={L('/garanties')} class="inline-block bg-brass-400 px-7 py-3.5 text-base font-bold text-azur-950 transition-colors hover:bg-brass-300">انظر ضماناتنا المكتوبة</a>
            <a href={L('/realisations')} class="inline-block border-b-2 border-azur-600 pb-0.5 text-base font-bold text-azur-600 transition-colors hover:text-azur-700">انظر إنجازاتنا →</a>
          </div>
        </div>
      </div>
    </section>

    <!-- كتلة روابط الختام -->
    <section class="px-4 py-20 sm:py-28">
      <div class="mx-auto max-w-6xl">
        <p class="tech-label v2-kicker rule-brass text-brass-300">للمزيد</p>
        <h2 class="display v2-section-title mt-5 text-white">المتابعة، بالتفصيل</h2>
        <p class="mt-5 max-w-xl text-sm leading-relaxed text-lune-soft">
          المراقبة وخدمة ما بعد البيع الاستباقية لا تصمدان إلا لأنهما تستندان إلى معدات مُسمّاة
          وضمانات مكتوبة بالأبيض والأسود. وها هما بالتفصيل.
        </p>
        <div class="mt-10 flex flex-wrap gap-3">
          <a href={L('/garanties')} class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">ضماناتنا →</a>
          <a href={L('/équipement')} class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">المعدات المركَّبة →</a>
          <a href={contactSim} class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">تشخيصي المجاني →</a>
        </div>
      </div>
    </section>

    <CtaBand title="سطح يراقب نفسه يُحضَّر منذ الدراسة." href={contactSim} />

    <StickyCta />
  </div>
</Layout>
