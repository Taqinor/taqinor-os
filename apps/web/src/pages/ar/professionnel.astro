---
/**
 * AR — Business & industrial solar (W67, RTL). Faithful Arabic translation of
 * /professionnel ; EVERY figure kept EXACT in Latin digits (3–5 years, +20 years,
 * 5 MW, 17,04 kWc, 3,72 kWc, ref. 468, Canadian Solar 710 Wc,
 * Deye 15 kW, law 82-21). WB — fabricated annual kWh production figures
 * removed (no real Deye reading backed them); production is monitored via
 * real-time production monitoring, never promised. Price-bracket data + solar math (localEstimateBand /
 * formatMAD) reused UNCHANGED — only visible labels translated. Internal links
 * via localizeNavHref. Shared components auto-detect locale. FR untouched.
 *
 * W249 — قناة واحدة: الفعل الختامي لم يعد DiagnosticForm بل عنصر التقدير
 * الفوري المشترك مع الصفحة الرئيسية (InstantEstimator، W250). DiagnosticForm
 * يبقى سليماً في الكود كحل احتياطي موثّق.
 *
 * ÉLÉVATION (W241) — mirrors the FR professionnel.astro elevation:
 *  1. cinematic hero (~92svh), scrim relevé, scroll chevron, CTAs anchored bottom;
 *  2. brass discipline: eyebrows text-lune, gold only on .lum + primary CTA;
 *  3. v3-grade on content photos;
 *  4. .section / .section-tight tokens + seam-soft seams;
 *  5. RTL-logical classes preserved throughout.
 */
import Layout from '../../layouts/Layout.astro';
import V2Enhance from '../../components/V2Enhance.astro';
import Article33Ribbon from '../../components/Article33Ribbon.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import InstantEstimator from '../../components/InstantEstimator.astro';
import CtaBand from '../../components/CtaBand.astro';
import Picture from '../../components/Picture.astro';
import StickyCta from '../../components/StickyCta.astro';
import ZelligeDivider from '../../components/ZelligeDivider.astro';
import GarantiesTeaser from '../../components/GarantiesTeaser.astro';
import Testimonials from '../../components/Testimonials.astro';
import CertLogoRow from '../../components/CertLogoRow.astro';
import Faq from '../../components/Faq.astro';
import ServiceWarrantyTable from '../../components/ServiceWarrantyTable.astro';
import RelatedLinks from '../../components/RelatedLinks.astro';
import { localEstimateBand } from '../../lib/billRange';
import { formatMAD } from '../../lib/format';
import { WHATSAPP_LEADS } from '../../lib/nap';
import { whatsappLink } from '../../lib/whatsapp';
import { getLocaleFromPath } from '../../i18n/utils';
import { localizeNavHref } from '../../i18n/pages';
import { serviceFaqItems } from '../../lib/serviceFaq';

const locale = getLocaleFromPath(Astro.url.pathname);
const L = (href: string) => localizeNavHref(href, locale);

const waDirect = whatsappLink(WHATSAPP_LEADS, 'مرحباً، أرغب في دراسة لتركيبة شمسية.');

// W263 — بنك أسئلة شائعة مشترك + ضمان حسب المكوّن، بالعربية.
const faqItems = serviceFaqItems('professionnel', 'ar');
// W337 — دعوة «زيارة ورش حقيقي»، نفس آلية pourquoi-taqinor.astro
const waVisite = whatsappLink(WHATSAPP_LEADS, 'مرحباً، أرغب في زيارة تركيبة مهنية حقيقية.');

// W337 — التأمين على المسؤولية المدنية المهنية: scaffold آمن بدون تأثير (WG8).
// لا توجد بعد بيانات حقيقية من المؤسس ← تبقى `null` ولا يُعرض القسم بتاتاً حتى
// تُقدَّم القيمة. لا تختلقوا أبداً رقم بوليصة.
const RC_PRO_ASSURANCE: string | null = null;

// W260 — بطاقات تعريف ذاتي حسب نوع المبنى، بدل كتلة واحدة عامة: المشتري
// المهني يتعرّف أولاً على نوع موقعه قبل أن يفكّر بالـ kWc. دليل واحد ملموس لكل بطاقة.
// W335 — كل بطاقة قطاع تحمل الآن سطرين: سطر مالي (حجة المدير المالي) وسطر
// تقني/تشغيلي (حجة الميدان) — لا رقم جديد، فقط نفس الدليل المنشور مقسّماً
// إلى زاويتي قراءة.
const segments = [
  {
    n: '01', title: 'مستودع / مصنع',
    body: "كل kWh يدخل في سعر تكلفة قطعة مُنتَجة. سطح عريض ومستوٍ يُسدّد نفسه في 3 إلى 5 سنوات وينتج بالضبط في الساعات التي تشتغل فيها الآلات — يأتي الإنتاج حين يكون الطلب حاضراً.",
    proof: 'دليل: الجديدة، 17,04 kWc، مُتابَعة بمراقبة الإنتاج في الوقت الحقيقي',
    financier: 'عبء تشغيلي يتحوّل إلى أصل مُسدَّد في 3 إلى 5 سنوات',
    technique: 'سطح عريض ومستوٍ · تركيب دون توقيف الإنتاج',
  },
  {
    n: '02', title: 'حظيرة فلاحية-صناعية',
    body: "تجفيف، تبريد، تحويل: الحظيرة الفلاحية تستهلك في وضح النهار، بالضبط حين تعطي الشمس. السطح، الموجود أصلاً، لا يكلّف شيئاً إضافياً — يحمل الألواح دون أن يأكل متراً مربعاً من الأرض.",
    proof: 'دليل: هيكل فولاذي مُجلفن بضمان 20 سنة، مُركَّب على السطح القائم',
    financier: 'صفر عقار إضافي مُجمَّد — السطح القائم يموّل الهيكل',
    technique: 'هيكل فولاذي مُجلفن بضمان 20 سنة · لا خسارة لمساحة أرضية',
  },
  {
    n: '03', title: 'تجارة / فندقة',
    body: "تكييف بعد الظهر، مغسلة في الصباح، مضخّات مسبح بلا انقطاع: منحنى المتجر أو الفندق يعانق منحنى الشمس، ساعة بساعة. تأتي الطاقة الشمسية لتسقّف بنداً يتسلّق كل موسم.",
    proof: 'دليل: تسديد في 3 إلى 5 سنوات، نفس منطق الحمولة الصناعي',
    financier: 'يُسقّف بند تكاليف يتصاعد كل موسم سياحي',
    technique: 'منحنى استهلاك مُطابق لسطوع الشمس، ساعة بساعة',
  },
  {
    n: '04', title: 'مرافق جماعية',
    body: "مبنى عمومي أو عيادة لا يتحمّل الانقطاع. عاكسات هجينة مع بطاريات تُبقي المعدات الحرجة قائمة خلال هبوط الشبكة، وفي النهار تنخفض الفاتورة على باقي البناية.",
    proof: 'دليل: عاكسات هجينة Deye/Huawei، ضمان 10 سنوات',
    financier: 'يخفّض فاتورة المبنى مع تأمين استمرارية الخدمة',
    technique: 'عاكسات هجينة + بطاريات · استمرارية على المعدات الحرجة',
  },
];

const PRIX_PAR_KWC = { bas: 8500, haut: 11000 };
const arrondi10k = (v: number) => Math.round(v / 10000) * 10000;
// W335 — «الاقتصاد التراكمي على 20 سنة»: مُشتقّ من الثوابت المنشورة أصلاً
// (استثمار لكل kWc + مجال التسديد)، لا رقم جديد. المنطق: بعد بلوغ التسديد،
// تستمر التركيبة في الإنتاج حتى ضمان الأداء لـ30 سنة؛ نُسقط على أفق 20 سنة
// (نفس أفق الهيكل والإهلاك المحاسبي المذكور أدناه) مضاعف الاستثمار ×
// (20 سنة / مدة التسديد) — مجرد ترتيب حجم، وليس رقم دراسة.
const HORIZON_ANS = 20;
const economieCumulee = (investMin: number, investMax: number, paybackMinAns: number, paybackMaxAns: number) => {
  const bas = arrondi10k((investMin * HORIZON_ANS) / paybackMaxAns);
  const haut = arrondi10k((investMax * HORIZON_ANS) / paybackMinAns);
  return `${formatMAD(bas)} – ${formatMAD(haut)}`;
};

const proBrackets = (['5000-10000', 'gt10000'] as const).map((id) => {
  const band = localEstimateBand(id);
  const investMin = arrondi10k(band.kwcMin * PRIX_PAR_KWC.bas);
  const investMax = arrondi10k(band.kwcMax * PRIX_PAR_KWC.haut);
  return {
    bill: id === '5000-10000' ? '5 000 – 10 000 MAD / شهر' : 'أكثر من 10 000 MAD / شهر',
    kwc: band.kwcLabel,
    investMin,
    invest:
      id === 'gt10000'
        ? `ابتداءً من ${formatMAD(investMin)} — دراسة مخصّصة`
        : `${formatMAD(investMin)} – ${formatMAD(investMax)}`,
    payback: band.paybackLabel,
    economie20ans: economieCumulee(investMin, investMax, 3, 5),
    exemple: id === '5000-10000' ? 'مثال حقيقي: مرجع 468 — 17,04 kWc، الجديدة، أبريل 2026' : null,
  };
});

// القاعدة ب14 (2026-07-04) — إجابة AEO قابلة للاستخراج، مُشتقّة من أول عتبة
// مهنية أعلاه؛ لا رقم جديد.
const proInvestFromLabel = formatMAD(proBrackets[0]?.investMin ?? 0);
const proPaybackLabel = proBrackets[0]?.payback ?? '3–5 سنوات';

// W335 — مقارنة هيكلية شراء (CAPEX) / ليزينغ (OPEX): من يملك، من يُهلك، أثر
// اليوم الأول على الخزينة. لا سعر فائدة ولا بنك مُسمّى هنا — الخانات المُسمّاة
// (CAM، Maghrebail…) موجودة في صفحة /financement (W258/WG11).
const capexOpex = [
  {
    critere: 'من يملك التركيبة',
    achat: 'شركتكم، ابتداءً من التشغيل',
    leasing: 'المؤجِّر خلال مدة العقد؛ خيار الشراء في نهاية العقد حسب الصيغة',
  },
  {
    critere: 'من يُسجّل الإهلاك',
    achat: 'شركتكم، كأصل ثابت في ميزانيتها (انظر الجباية أدناه)',
    leasing: 'المؤجِّر؛ تُسجّلون الكراء كعبء تشغيلي',
  },
  {
    critere: 'أثر اليوم الأول على الخزينة',
    achat: 'خروج فوري للخزينة (أو عند صرف القرض إن كان مموَّلاً)',
    leasing: 'لا خروج مسبق للخزينة — كراء دوري يحل محل الفاتورة المُتجنَّبة',
  },
];
---

<Layout
  title="الطاقة الشمسية الصناعية والفندقية والطبية بالمغرب — مُسدَّدة في 3 إلى 5 سنوات | Taqinor"
  description="17,04 kWc بالجديدة، مُتابَعة بمراقبة الإنتاج في الوقت الحقيقي: تركيبات شمسية بالجهد المتوسط مُحدّدة المقاس على منحنيات حمولتك، الفائض مُقيَّم وفق القانون 82-21، من الربط بالشبكة (≤ 5 MW) إلى الترخيص."
  ogSlug="professionnel"
>
  <div class="v2">
    <V2Enhance />
    <Article33Ribbon />

    <Breadcrumb items={[{ label: 'الرئيسية', href: L('/') }, { label: 'مهني' }]} />

    {/* ── 1 · HÉROS CINÉMATOGRAPHIQUE (~92svh) — الغروب الصناعي كبطل ── */}
    <section class="relative isolate flex min-h-[92svh] flex-col justify-end overflow-hidden text-white">
      <div class="v2-hero-media absolute inset-0 -z-10">
        {/* عنصر LCP — لا v3-grade هنا أبداً */}
        <Picture name="industriel-couchant" alt="" widths={[2000, 1280, 768, 480]} ratio={16 / 9} sizes="100vw"
          loading="eager" fetchpriority="high" class="h-full w-full object-cover object-[70%_30%]" />
        {/* Scrim relevé */}
        <div class="hero-scrim hero-scrim-v3 absolute inset-0"></div>
      </div>

      {/* Chevron دعوة للتمرير */}
      <div class="absolute bottom-6 left-1/2 -translate-x-1/2 scroll-chevron" aria-hidden="true">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="6 9 12 15 18 9" />
        </svg>
      </div>

      {/* المحتوى مُثبَّت أسفل — eyebrow مُخفَّض إلى lune */}
      <div class="mx-auto w-full max-w-6xl px-4 pb-24 pt-32 sm:pb-32">
        <p class="tech-label v2-kicker rule-brass cine-in text-lune">مستودع · فلاحي-صناعي · تجارة · مرافق جماعية</p>
        <h1 class="display v2-page-title cine-in cine-in-1 mt-5 max-w-[20ch]">بند الكهرباء عندك، يمكنك قيادته بدل أن تخضع له</h1>
        <p class="v2-lead cine-in cine-in-2 mt-6 max-w-xl text-white/85">
          على موقع مهني، ليست الطاقة الشمسية واجهة: إنها معدّة إنتاج، تُسدَّد في <span dir="ltr" style="unicode-bidi:isolate">3</span> إلى
          <span dir="ltr" style="unicode-bidi:isolate">5 سنوات</span>، ثم تشتغل بعدها أكثر من عشرين سنة. بالجديدة،
          <span dir="ltr" style="unicode-bidi:isolate">17,04 kWc</span> مُتابَعة باستمرار بمراقبة الإنتاج في الوقت الحقيقي. أما تحديد المقاس، فينطلق من منحنيات
          حمولتك — لا من قالب جاهز.
        </p>
        <div class="cine-in cine-in-3 mt-10 flex flex-wrap items-center gap-3">
          {/* CTA نحاسي وحيد. W337 — مُعاد صياغته كعرض تدقيق: نفس المسار،
              نفس webhook DiagnosticForm، يتغيّر فقط النص. */}
          <a href={L('/devis/mon-toit')} class="glow-hero bg-brass-400 px-8 py-4 text-lg font-bold text-azur-950 transition-all hover:bg-brass-300">
            تدقيق طاقي مجاني لموقعي ←
          </a>
          {/* Ghost WhatsApp */}
          <a href={waDirect} rel="noopener" class="inline-flex items-center gap-2 border border-white/40 px-6 py-3.5 text-base font-semibold text-white backdrop-blur-sm transition-colors hover:border-white hover:bg-white/10">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 0 0-8.6 15.1L2 22l5-1.3A10 10 0 1 0 12 2Zm5.4 14.1c-.2.6-1.3 1.2-1.8 1.2-.5.1-1 .2-3.3-.7-2.8-1.1-4.6-4-4.7-4.2-.1-.2-1.1-1.5-1.1-2.9s.7-2 1-2.3c.2-.3.5-.3.7-.3h.5c.2 0 .4 0 .6.4l.9 2.1c.1.2.1.4 0 .6l-.4.6-.5.5c-.2.2-.3.4-.1.7.2.3.9 1.4 1.9 2.3 1.3 1.1 2.3 1.5 2.6 1.6.3.1.5.1.7-.1l1-1.2c.2-.3.4-.2.7-.1l2 1c.3.1.5.2.6.4 0 .1 0 .7-.3 1.4Z"/></svg>
            واتساب مباشر
          </a>
        </div>
        {/* أرقام الغطاء — .lum يحمل الذهب (انضباط النحاس) */}
        <dl class="cine-in cine-in-4 mt-10 grid max-w-2xl grid-cols-3 gap-3 border-t border-white/20 pt-6 sm:gap-6">
          <div>
            <dd class="fig lum text-base sm:text-4xl" dir="ltr" data-tally>3–5 سنوات</dd>
            <dt class="tech-label mt-2 text-lune">التسديد</dt>
          </div>
          <div>
            <dd class="fig lum text-base sm:text-4xl" dir="ltr" data-tally>+20 سنة</dd>
            <dt class="tech-label mt-2 text-lune">من الإنتاج</dt>
          </div>
          <div>
            <dd class="fig lum text-base sm:text-4xl" dir="ltr" data-tally>5 MW</dd>
            <dt class="tech-label mt-2 text-lune">عتبة الترخيص</dt>
          </div>
        </dl>
      </div>
    </section>

    {/* W260 — أربع بطاقات تعريف ذاتي حسب نوع الموقع */}
    <div class="seam-soft" aria-hidden="true"></div>
    <section class="section mx-auto max-w-6xl px-4">
      {/* W274 — نظام ترقيم الفصول (01/02…)، نفس آلية index.astro/ar، ممتد هنا
          لاتّساق العملية التحريرية على الموقع كله. فقط الـeyebrows التي تفتح
          قسماً رئيسياً تحمل رقماً (العناوين الفرعية داخل نفس القسم لا). */}
      <p class="tech-label v2-kicker rule-brass text-lune"><span class="ms-2 font-display text-xs text-azur-200/80" aria-hidden="true">01</span>أين تتعرّف على نفسك؟</p>
      <h2 class="display v2-section-title mt-5 text-white">أربعة أنواع مواقع، نفس منطق الحمولة</h2>
      <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-4" data-stagger>
        {segments.map((s, i) => (
          <div class="v2-rise border-s-2 border-brass-400/60 ps-6" style={`--v2-i:${i}`}>
            <p class="fig lum text-2xl">{s.n}</p>
            <h2 class="display mt-2 text-xl text-white">{s.title}</h2>
            <p class="mt-3 text-sm leading-relaxed text-lune-soft">{s.body}</p>
            {/* W335 — سطرا قراءة: مالي (المدير المالي) ثم تقني/تشغيلي */}
            <dl class="mt-4 space-y-2 border-t border-white/10 pt-3">
              <div>
                <dt class="tech-label text-brass-300">السطر المالي</dt>
                <dd class="mt-0.5 text-xs leading-relaxed text-lune-soft">{s.financier}</dd>
              </div>
              <div>
                <dt class="tech-label text-lune">السطر التقني</dt>
                <dd class="mt-0.5 text-xs leading-relaxed text-lune-soft">{s.technique}</dd>
              </div>
            </dl>
            <p class="tech-label mt-3 text-lune-faint">{s.proof}</p>
          </div>
        ))}
      </div>
    </section>

    {/* أوامر مقدار مهنية — eyebrow مُخفَّض إلى lune */}
    <div class="seam-soft" aria-hidden="true"></div>
    <section class="section px-4">
      <div class="mx-auto max-w-4xl">
        {/* W274 — الفصل 02. "صيغتان ممكنتان" و"ما تتحقّق منه مصلحة المشتريات"
            أدناه تبقيان دون رقم: عناوين فرعية داخل نفس هذا القسم. */}
        <p class="tech-label v2-kicker rule-brass text-lune"><span class="ms-2 font-display text-xs text-azur-200/80" aria-hidden="true">02</span>شفافية الأسعار</p>
        <h2 class="display v2-section-title mt-5 text-white">أي ميزانية تتوقّعها لموقع مهني</h2>
        <p class="v2-lead mt-4 max-w-2xl font-bold text-white">
          بالنسبة لموقع مهني، يبدأ الاستثمار من حوالي <span dir="ltr" style="unicode-bidi:isolate">{proInvestFromLabel}</span> ويُسترجع خلال
          <span dir="ltr" style="unicode-bidi:isolate">{proPaybackLabel}</span>، للجزء المُستهلَك ذاتياً — ويعود كل kWc مركّب هناك أرخص عادةً منه في
          السكني بفضل استمرارية سطح البناية.
        </p>
        <p class="v2-lead mt-4 max-w-2xl text-lune-soft">
          مجالات إرشادية لسطح مهني — <strong class="text-lune">لا تكون أبداً ثمناً نهائياً</strong>.
          التسعير الحقيقي يتموضع على منحنيات حمولتك وعلى شروط
          ربطك. على سطح مستودع كبير، يعود كل kWc مركّب أرخص منه في
          السكني: كلما كان السطح متّصلاً أكثر، انخفضت التكلفة الواحدة، وبذلك يمرّ المجال
          أدناه تحت ذاك الموجود في صفحة سكني.
        </p>
        <div class="mt-10 border-t-2 border-brass-400/60" data-stagger>
          {proBrackets.map((b, i) => (
            <div class="v2-rise border-b border-white/10 py-5" style={`--v2-i:${i}`}>
              <div class="grid gap-1.5 sm:grid-cols-[1fr_0.7fr_1.3fr_0.7fr] sm:items-baseline sm:gap-4">
                <span class="font-display text-base font-bold text-white">{b.bill}</span>
                <span class="fig lum text-xl sm:text-2xl" dir="ltr" data-tally>{b.kwc}</span>
                <span class="fig text-lg text-lune sm:text-xl" dir="ltr">{b.invest}</span>
                <span class="fig text-xl text-brass-300 sm:text-2xl" dir="ltr" data-tally>{b.payback}</span>
              </div>
              {/* W335 — اقتصاد تراكمي على 20 سنة، مُشتقّ من الأعمدة أعلاه (لا رقم جديد) */}
              <p class="tech-label mt-2.5 text-lune-faint">
