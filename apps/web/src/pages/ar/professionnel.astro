---
/**
 * AR — Business & industrial solar (W67, RTL). Faithful Arabic translation of
 * /professionnel ; EVERY figure kept EXACT in Latin digits (3–5 years, +20 years,
 * 5 MW, 17,04 kWc, 21 406 kWh/an, 3,72 kWc, ref. 468, Canadian Solar 710 Wc,
 * Deye 15 kW, law 82-21). Price-bracket data + solar math (localEstimateBand /
 * formatMAD) reused UNCHANGED — only visible labels translated. Internal links
 * via localizeNavHref. Shared components auto-detect locale. FR untouched.
 *
 * ÉLÉVATION (W241) — mirrors the FR professionnel.astro elevation:
 *  1. cinematic hero (~92svh), scrim relevé, scroll chevron, CTAs anchored bottom;
 *  2. brass discipline: eyebrows text-lune, gold only on .lum + primary CTA;
 *  3. v3-grade on content photos;
 *  4. .section / .section-tight tokens + seam-soft seams;
 *  5. RTL-logical classes preserved throughout.
 */
import Layout from '../../layouts/Layout.astro';
import V2Enhance from '../../components/V2Enhance.astro';
import Article33Ribbon from '../../components/Article33Ribbon.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import DiagnosticForm from '../../components/DiagnosticForm.astro';
import CtaBand from '../../components/CtaBand.astro';
import Picture from '../../components/Picture.astro';
import StickyCta from '../../components/StickyCta.astro';
import ZelligeDivider from '../../components/ZelligeDivider.astro';
import GarantiesTeaser from '../../components/GarantiesTeaser.astro';
import Testimonials from '../../components/Testimonials.astro';
import { localEstimateBand } from '../../lib/billRange';
import { formatMAD } from '../../lib/format';
import { WHATSAPP_LEADS } from '../../lib/nap';
import { whatsappLink } from '../../lib/whatsapp';
import { getLocaleFromPath } from '../../i18n/utils';
import { localizeNavHref } from '../../i18n/pages';

const locale = getLocaleFromPath(Astro.url.pathname);
const L = (href: string) => localizeNavHref(href, locale);

const waDirect = whatsappLink(WHATSAPP_LEADS, 'مرحباً، أرغب في دراسة لتركيبة شمسية.');

const segments = [
  { n: '01', title: 'الصناعيون', body: "كل kWh يدخل في سعر تكلفة قطعة مُنتَجة. سطح مستودع، عريض ومستوٍ، يُسدّد نفسه في 3 إلى 5 سنوات وينتج بالضبط في الساعات التي تشتغل فيها الآلات — يأتي الإنتاج حين يكون الطلب حاضراً." },
  { n: '02', title: 'الفنادق', body: "تكييف بعد الظهر، مغسلة في الصباح، مضخّات مسبح بلا انقطاع: منحنى الفندق يعانق منحنى الشمس، ساعة بساعة. تأتي الطاقة الشمسية لتسقّف بنداً يتسلّق كل موسم." },
  { n: '03', title: 'العيادات', body: "غرفة العمليات لا تتحمّل الانقطاع. عاكسات هجينة مع بطاريات تُبقي المعدات الحرجة قائمة خلال هبوط الشبكة، وفي النهار تنخفض الفاتورة على باقي البناية." },
];

const PRIX_PAR_KWC = { bas: 8500, haut: 11000 };
const arrondi10k = (v: number) => Math.round(v / 10000) * 10000;
const proBrackets = (['5000-10000', 'gt10000'] as const).map((id) => {
  const band = localEstimateBand(id);
  return {
    bill: id === '5000-10000' ? '5 000 – 10 000 MAD / شهر' : 'أكثر من 10 000 MAD / شهر',
    kwc: band.kwcLabel,
    invest:
      id === 'gt10000'
        ? `ابتداءً من ${formatMAD(arrondi10k(band.kwcMin * PRIX_PAR_KWC.bas))} — دراسة مخصّصة`
        : `${formatMAD(arrondi10k(band.kwcMin * PRIX_PAR_KWC.bas))} – ${formatMAD(arrondi10k(band.kwcMax * PRIX_PAR_KWC.haut))}`,
    payback: band.paybackLabel,
    exemple: id === '5000-10000' ? 'مثال حقيقي: مرجع 468 — 17,04 kWc، الجديدة، أبريل 2026' : null,
  };
});
---

<Layout
  title="الطاقة الشمسية الصناعية والفندقية والطبية بالمغرب — مُسدَّدة في 3 إلى 5 سنوات | Taqinor"
  description="17,04 kWc بالجديدة، 21 406 kWh في السنة: تركيبات شمسية بالجهد المتوسط مُحدّدة المقاس على منحنيات حمولتك، الفائض مُقيَّم وفق القانون 82-21، من الربط بالشبكة (≤ 5 MW) إلى الترخيص."
  ogSlug="professionnel"
>
  <div class="v2">
    <V2Enhance />
    <Article33Ribbon />

    <Breadcrumb items={[{ label: 'الرئيسية', href: L('/') }, { label: 'مهني' }]} />

    {/* ── 1 · HÉROS CINÉMATOGRAPHIQUE (~92svh) — الغروب الصناعي كبطل ── */}
    <section class="relative isolate flex min-h-[92svh] flex-col justify-end overflow-hidden text-white">
      <div class="v2-hero-media absolute inset-0 -z-10">
        {/* عنصر LCP — لا v3-grade هنا أبداً */}
        <Picture name="industriel-couchant" alt="" widths={[2000, 1280, 768, 480]} ratio={16 / 9} sizes="100vw"
          loading="eager" fetchpriority="high" class="h-full w-full object-cover object-[70%_30%]" />
        {/* Scrim relevé */}
        <div class="hero-scrim hero-scrim-v3 absolute inset-0"></div>
      </div>

      {/* Chevron دعوة للتمرير */}
      <div class="absolute bottom-6 left-1/2 -translate-x-1/2 scroll-chevron" aria-hidden="true">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="6 9 12 15 18 9" />
        </svg>
      </div>

      {/* المحتوى مُثبَّت أسفل — eyebrow مُخفَّض إلى lune */}
      <div class="mx-auto w-full max-w-6xl px-4 pb-24 pt-32 sm:pb-32">
        <p class="tech-label v2-kicker rule-brass cine-in text-lune">صناعيون · فنادق · عيادات</p>
        <h1 class="display v2-page-title cine-in cine-in-1 mt-5 max-w-[20ch]">بند الكهرباء عندك، يمكنك قيادته بدل أن تخضع له</h1>
        <p class="v2-lead cine-in cine-in-2 mt-6 max-w-xl text-white/85">
          على موقع مهني، ليست الطاقة الشمسية واجهة: إنها معدّة إنتاج، تُسدَّد في 3 إلى
          5 سنوات، ثم تشتغل بعدها أكثر من عشرين سنة. بالجديدة،
          17,04 kWc توفّر 21 406 kWh في السنة. أما تحديد المقاس، فينطلق من منحنيات
          حمولتك — لا من قالب جاهز.
        </p>
        <div class="cine-in cine-in-3 mt-10 flex flex-wrap items-center gap-3">
          {/* CTA نحاسي وحيد */}
          <a href={L('/devis/mon-toit')} class="glow-hero bg-brass-400 px-8 py-4 text-lg font-bold text-azur-950 transition-all hover:bg-brass-300">
            احصل على دراستي المجانية ←
          </a>
          {/* Ghost WhatsApp */}
          <a href={waDirect} rel="noopener" class="inline-flex items-center gap-2 border border-white/40 px-6 py-3.5 text-base font-semibold text-white backdrop-blur-sm transition-colors hover:border-white hover:bg-white/10">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 0 0-8.6 15.1L2 22l5-1.3A10 10 0 1 0 12 2Zm5.4 14.1c-.2.6-1.3 1.2-1.8 1.2-.5.1-1 .2-3.3-.7-2.8-1.1-4.6-4-4.7-4.2-.1-.2-1.1-1.5-1.1-2.9s.7-2 1-2.3c.2-.3.5-.3.7-.3h.5c.2 0 .4 0 .6.4l.9 2.1c.1.2.1.4 0 .6l-.4.6-.5.5c-.2.2-.3.4-.1.7.2.3.9 1.4 1.9 2.3 1.3 1.1 2.3 1.5 2.6 1.6.3.1.5.1.7-.1l1-1.2c.2-.3.4-.2.7-.1l2 1c.3.1.5.2.6.4 0 .1 0 .7-.3 1.4Z"/></svg>
            واتساب مباشر
          </a>
        </div>
        {/* أرقام الغطاء — .lum يحمل الذهب (انضباط النحاس) */}
        <dl class="cine-in cine-in-4 mt-10 grid max-w-2xl grid-cols-3 gap-3 border-t border-white/20 pt-6 sm:gap-6">
          <div>
            <dd class="fig lum text-base sm:text-4xl" data-tally>3–5 سنوات</dd>
            <dt class="tech-label mt-2 text-lune">التسديد</dt>
          </div>
          <div>
            <dd class="fig lum text-base sm:text-4xl" data-tally>+20 سنة</dd>
            <dt class="tech-label mt-2 text-lune">من الإنتاج</dt>
          </div>
          <div>
            <dd class="fig lum text-base sm:text-4xl" data-tally>5 MW</dd>
            <dt class="tech-label mt-2 text-lune">عتبة الترخيص</dt>
          </div>
        </dl>
      </div>
    </section>

    {/* ثلاثة قطاعات */}
    <div class="seam-soft" aria-hidden="true"></div>
    <section class="section mx-auto max-w-6xl px-4">
      <div class="grid gap-6 md:grid-cols-3" data-stagger>
        {segments.map((s, i) => (
          <div class="v2-rise border-s-2 border-brass-400/60 ps-6" style={`--v2-i:${i}`}>
            <p class="fig lum text-2xl">{s.n}</p>
            <h2 class="display mt-2 text-2xl text-white">{s.title}</h2>
            <p class="mt-3 text-sm leading-relaxed text-lune-soft">{s.body}</p>
          </div>
        ))}
      </div>
    </section>

    {/* أوامر مقدار مهنية — eyebrow مُخفَّض إلى lune */}
    <div class="seam-soft" aria-hidden="true"></div>
    <section class="section px-4">
      <div class="mx-auto max-w-4xl">
        <p class="tech-label v2-kicker rule-brass text-lune">شفافية الأسعار</p>
        <h2 class="display v2-section-title mt-5 text-white">أي ميزانية تتوقّعها لموقع مهني</h2>
        <p class="v2-lead mt-4 max-w-2xl text-lune-soft">
          مجالات إرشادية لسطح مهني — <strong class="text-lune">لا تكون أبداً ثمناً نهائياً</strong>.
          التسعير الحقيقي يتموضع على منحنيات حمولتك وعلى شروط
          ربطك. على سطح مستودع كبير، يعود كل kWc مركّب أرخص منه في
          السكني: كلما كان السطح متّصلاً أكثر، انخفضت التكلفة الواحدة، وبذلك يمرّ المجال
          أدناه تحت ذاك الموجود في صفحة سكني.
        </p>
        <div class="mt-10 border-t-2 border-brass-400/60" data-stagger>
          {proBrackets.map((b, i) => (
            <div class="v2-rise border-b border-white/10 py-5" style={`--v2-i:${i}`}>
              <div class="grid gap-1.5 sm:grid-cols-[1fr_0.7fr_1.3fr_0.7fr] sm:items-baseline sm:gap-4">
                <span class="font-display text-base font-bold text-white">{b.bill}</span>
                <span class="fig lum text-xl sm:text-2xl" data-tally>{b.kwc}</span>
                <span class="fig text-lg text-lune sm:text-xl">{b.invest}</span>
                <span class="fig text-xl text-brass-300 sm:text-2xl" data-tally>{b.payback}</span>
              </div>
              {b.exemple && <p class="tech-label mt-2.5 text-lune-faint">{b.exemple}</p>}
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* دقّة الصنعة — صور ورش مع v3-grade */}
    <div class="seam-soft" aria-hidden="true"></div>
    <section class="section mx-auto max-w-6xl px-4">
      <div class="grid gap-4 sm:grid-cols-2" data-stagger>
        <figure class="v2-rise cine-card group relative overflow-hidden" style="--v2-i:0">
          <Picture name="mesure-rails" alt="تخطيط وقياس بالمتر لقضبان التثبيت على سطح مهني"
            widths={[1600, 1024, 640]} ratio={4 / 3} sizes="(min-width: 640px) 50vw, 100vw"
            class="v3-grade w-full object-cover transition-transform duration-700 group-hover:scale-[1.04]" />
          <figcaption class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-nuit/95 to-transparent px-4 pb-3 pt-12">
            <span class="tech-label block text-brass-300">النواصر · 3,72 kWc · توزيع</span>
            <span class="mt-0.5 block text-xs text-lune">كل قضيب يُخطَّط ويُقاس قبل التثبيت</span>
          </figcaption>
        </figure>
        <figure class="v2-rise cine-card group relative overflow-hidden" style="--v2-i:1">
          <Picture name="equipe-trois" alt="فريق تاكينور أمام صفّ طويل من الألواح في نهاية الورش"
            widths={[1600, 1024, 640]} ratio={3 / 2} sizes="(min-width: 640px) 50vw, 100vw"
            class="v3-grade w-full object-cover transition-transform duration-700 group-hover:scale-[1.04]" />
          <figcaption class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-nuit/95 to-transparent px-4 pb-3 pt-12">
            <span class="tech-label block text-brass-300">الجديدة · 17,04 kWc · 21 406 kWh/an</span>
            <span class="mt-0.5 block text-xs text-lune">نهاية الورش · 24 × Canadian Solar 710 Wc · Deye 15 kW ثلاثي الطور</span>
          </figcaption>
        </figure>
      </div>
    </section>

    <ZelligeDivider tone="white" />

    {/* الفائض + أنظمة الجهد المتوسط — eyebrow مُخفَّض إلى lune */}
    <section class="section px-4">
      <div class="mx-auto max-w-3xl">
        <div class="v2-rise">
          <p class="tech-label v2-kicker rule-brass text-lune">القانون 82-21 · الجهد المتوسط</p>
          <h2 class="display v2-section-title mt-5 text-white">للفائض قيمة، لا تسرّب</h2>
          <p class="v2-lead mt-5 text-lune-soft">
            يحدّد القانون 82-21 إطار الإنتاج الذاتي والفائض المُعاد إلى الشبكة. منذ
            الدراسة، بالجهد المتوسط، نفصل ما تستهلكه في المكان عمّا
            تحقنه، حسب اتفاق ربطك. الهدف بسيط: ألّا يغادر أي
            كيلوواط-ساعة مُنتَج دون مقابل.
          </p>
        </div>
        <div class="v2-rise">
          <h2 class="display v2-section-title mt-12 text-white">تحت أي نظام للقانون 82-21 يقع موقعك</h2>
          <p class="v2-lead mt-5 text-lune-soft">
            القدرة هي الحاسم. حتى 5 MW بالجهد المنخفض أو المتوسط، يكفي
            <strong class="text-lune">اتفاق ربط</strong> مع مدبّر الشبكة. وإذا تجاوزت
            عتبة 5 MW — جهد متوسط أو عالٍ أو عالٍ جداً — فإنك تنتقل إلى نظام
            <strong class="text-lune">الترخيص</strong>. في الحالتين، نجهّز الملف التقني
            ونحمله حتى التشغيل.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href={L('/loi-82-21')} class="inline-block border border-white/40 px-6 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">
              حدّد نظامي في 3 أسئلة
            </a>
            <a href={L('/équipement')} class="inline-block border border-white/40 px-6 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">
              شاهد المعدات المركّبة
            </a>
          </div>
        </div>
      </div>
    </section>

    {/* روابط سياقية */}
    <div class="seam-soft" aria-hidden="true"></div>
    <section class="section-tight px-4">
      <div class="mx-auto flex max-w-6xl flex-wrap gap-3">
        <a href={L('/realisations')} class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">إنجازاتنا <span class="inline-block rtl:-scale-x-100">→</span></a>
        <a href={L('/équipement')} class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">المعدات المركّبة <span class="inline-block rtl:-scale-x-100">→</span></a>
        <a href={L('/pompage-solaire')} class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">الضخ الشمسي <span class="inline-block rtl:-scale-x-100">→</span></a>
        <a href={L('/financement')} class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">التمويل والمردودية <span class="inline-block rtl:-scale-x-100">→</span></a>
        <a href={L('/pourquoi-taqinor')} class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">لماذا تاكينور <span class="inline-block rtl:-scale-x-100">→</span></a>
      </div>
    </section>

    <!-- W62 — آراء الزبناء (فارغة → لا تَرسم شيئاً ما لم يوجد رأي حقيقي) -->
    <Testimonials />

    <!-- طمأنة: الضمانات المكتوبة، باختصار (إحالة إلى /garanties) -->
    <GarantiesTeaser />

    <!-- الفصل الأخير — الغرفة البيضاء -->
    <DiagnosticForm heading="تشخيص لموقعك المهني" />

    <CtaBand
      title="سؤال حول موقعك قبل أن تلتزم؟ تحدّث مع إنسان."
      buttonLabel="واتساب مباشر مع مستشار"
      href={waDirect}
      seam={false}
    />

    <StickyCta />
  </div>
</Layout>

<style>
  .hero-scrim-v3 {
    --hero-scrim-strength: 0.52;
  }
</style>
