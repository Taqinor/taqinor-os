---
/**
 * AR — FAQ (W67, RTL). Faithful Arabic translation of /faq ; EVERY figure (MAD,
 * kWc, kW, MW, %, years, 18 months, 9 June 2026, fines, 84.8 %) kept EXACT in
 * Latin digits. The Faq component emits one FAQPage for this locale. FR
 * untouched.
 */
import Layout from '../../layouts/Layout.astro';
import V2Enhance from '../../components/V2Enhance.astro';
import Article33Ribbon from '../../components/Article33Ribbon.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import Faq from '../../components/Faq.astro';
import CtaBand from '../../components/CtaBand.astro';
import StickyCta from '../../components/StickyCta.astro';
import { getLocaleFromPath } from '../../i18n/utils';
import { localizeNavHref } from '../../i18n/pages';

const locale = getLocaleFromPath(Astro.url.pathname);
const L = (href: string) => localizeNavHref(href, locale);
const contactSim = L('/contact') + '#simulateur';

const faq = [
  // — الثمن وأرتاب الحجم —
  {
    q: 'كم يكلّف تركيب شمسي سكني؟',
    a: 'لا يوجد ثمن للمتر المربع: كل شيء ينطلق من فاتورتك وسطحك. لتقريب الصورة، فيلا تؤدي حوالي 1 500 درهم شهرياً تُجهَّز غالباً بـ 4 إلى 6 kWc. يعيد لك التشخيص عبر الإنترنت شريحة في بضع ثوانٍ؛ أما الرقم الحقيقي فيأتي بعد الزيارة التقنية.',
  },
  {
    q: 'كيف يُحتسب ثمن تركيبة؟',
    a: 'الثمن يتبع القدرة، والقدرة تتبع استهلاكك. رتبة حجم لا عرض ثمن: فيلا بفاتورة شهرية حوالي 2 000 درهم تستهدف عموماً 6 kWc، أي استثمار في حدود 60 000 إلى 75 000 درهم. ما يصير إليه هذا الرقم بالنسبة لك يتوقف على السطح والمعدات المختارة — وهذا هو موضوع الزيارة التقنية.',
  },
  {
    q: 'ابتداءً من أي فاتورة تصبح الطاقة الشمسية مجدية؟',
    a: 'تحت حوالي 1 000 درهم شهرياً، يتجاوز العائد على الاستثمار عادةً عتبة 7 سنوات، وسنخبرك بصراحة عوض تجهيزك بلا فائدة. فوق 10 000 درهم شهرياً، لم نعد في الباقة السكنية: حالتك تستحق دراسة خاصة (انظر صفحة المهنيين).',
  },
  // — القانون 82-21 —
  {
    q: 'ماذا يقول القانون 82-21 للأفراد؟',
    a: 'بالنسبة للغالبية العظمى من الفيلات، إنه خبر سار: في الجهد المنخفض وتحت 11 kW، تندرج تحت أخف نظام، وهو التصريح. إجراء يُودَع قبل التشغيل، لا رخصة تُنتزع. ونحن من يُعدّه ويُودِعه نيابةً عنك.',
  },
  {
    q: 'ما هي أنظمة القانون 82-21 الثلاثة؟',
    a: 'كل شيء يتوقف على قدرتك. التصريح: تحت 11 kW في الجهد المنخفض، أو موقع معزول غير موصول. اتفاق الربط: من عتبة التصريح حتى 5 MW، في الجهد المنخفض أو المتوسط. الترخيص: ابتداءً من 5 MW، في الجهد المتوسط أو العالي أو العالي جداً. مرسوم التطبيق 2-25-100 سارٍ منذ 9 يونيو 2026.',
  },
  // — المادة 33 —
  {
    q: 'تركيبتي القائمة غير مصرَّح بها. ماذا أفعل؟',
    a: 'لا تنتظر. تمنحك المادة 33 نافذة من 18 شهراً، فُتحت في 9 يونيو 2026، لتسوية تركيبة قائمة بالفعل — بعد هذا الأجل تُغلق. الأبسط أن تطلق المسطرة الآن؛ صفحة التسوية تفصّل الإجراء في 5 خطوات.',
  },
  {
    q: 'ماذا تخاطر به تركيبة غير مسوّاة؟',
    a: 'ما دامت غير مسوّاة، فإن تركيبة قائمة تُعدّ، في نظر القانون 82-21، في وضعية غير قانونية. عملياً، يتراوح ذلك من غرامة — من 2 000 إلى 5 000 درهم للاستغلال دون التصريح المطلوب، ومن 100 000 إلى 1 000 000 درهم دون اتفاق ربط أو ترخيص — إلى الإنذار، وإيقاف التركيبة، بل فصلها عن الشبكة. أسباب كثيرة للاستفادة من نافذة المادة 33.',
  },
  // — البطاريات / الاستهلاك الذاتي —
  {
    q: 'هل تلزم البطاريات؟',
    a: 'غالباً لا، ونادراً ما يكون هذا الجواب المنتظر. إذا كنت تستهلك أساساً نهاراً، تذهب الطاقة مباشرة إلى أجهزتك، والاستهلاك الذاتي المباشر يربح أكثر من أي تخزين. تُبرَّر البطارية للاستعمال الليلي أو استمرارية الخدمة عند الانقطاع — منحنى استهلاكك هو من يقول ذلك، ونحن ننظر فيه ضمن الدراسة.',
  },
  // — الضمانات —
  {
    q: 'ما هي الضمانات؟',
    a: 'مكوّن بمكوّن. الألواح: 12 سنة على المنتج و25 سنة على الأداء (84.8 % على الأقل من القدرة الأولية بعد 25 سنة). عاكسات Deye و Huawei وبطاريات Dyness LFP: 10 سنوات. الهيكل من الفولاذ المجلفن: 20 سنة. التركيب واليد العاملة لتاكينور: سنتان. التفاصيل، مع ما يغطّيه كل ضمان، في صفحة ضماناتنا.',
  },
  {
    q: 'كم تدوم الألواح؟',
    a: 'اللوح لا «يموت» في تاريخ محدّد: يفقد مردوديته ببطء، والضمان يؤطّر هذا التراجع. ألواحنا مضمونة لتُعيد 84.8 % على الأقل من قدرتها الأولية بعد 25 سنة. أما العاكس فهو قطعة إلكترونية: توقّع عموماً استبدالاً واحداً خلال عمر التركيبة.',
  },
  // — الآجال والمسار —
  {
    q: 'كيف يتم تركيب، خطوة بخطوة؟',
    a: 'ثلاث مراحل، دون التواء. أولاً تشخيص من 60 ثانية يعيد لك شريحة أولى. ثم تبادل مباشر عبر واتساب مع تقني، مع صور السطح. وأخيراً الزيارة التقنية، والدراسة الكاملة المجانية، وعرض الثمن. تتحدث إلى من يحدّد المقاس، لا إلى مقسّم سيعاود الاتصال.',
  },
  // — المراقبة / خدمة ما بعد البيع —
  {
    q: 'كيف تتابعون الإنتاج بعد التركيب؟',
    a: 'يربط دونݣل صغير WiFi/Ethernet تركيبتك بـ Deye Cloud: إنتاج في الزمن الحقيقي، تنبيهات تلقائية، سجلات. تتلقّى ولوجك الشخصي على التطبيق المحمول، ومن جهتنا نراقب كامل الأسطول — الفكرة أن نرصد انحرافاً قبل أن تضطر إلى ملاحظته في بيتك.',
  },
];
---

<Layout
  title="أسئلة متكررة حول الطاقة الشمسية بالمغرب — الأثمنة، القانون، الضمانات | Taqinor"
  description="الأسئلة التي تُطرح علينا قبل التوقيع، بأجوبة مرقّمة وصادقة: كم يكلّف فعلاً، ابتداءً من أي فاتورة يصبح مجدياً، أي نظام للقانون 82-21 يعنيك، ماذا تخاطر به تركيبة غير مسوّاة، وإلى أين تصل الضمانات."
  ogSlug="accueil"
>
  <div class="v2">
    <V2Enhance />
    <Article33Ribbon />

    <Breadcrumb items={[{ label: 'الرئيسية', href: L('/') }, { label: 'أسئلة متكررة' }]} />

    <section class="px-4 pb-10 pt-16 text-white sm:pt-20">
      <div class="mx-auto max-w-3xl">
        <p class="tech-label v2-kicker rule-brass cine-in text-brass-300">FAQ</p>
        <h1 class="display v2-page-title cine-in mt-5 [animation-delay:120ms]">أسئلتك، أجوبتنا</h1>
        <p class="v2-lead cine-in mt-6 max-w-xl text-white/85 [animation-delay:240ms]">
          هنا، دون مواربة، ما يسألنا عنه المشترون قبل التوقيع: كم يكلّف، متى يصبح مجدياً، ماذا يقول
          القانون 82-21، ماذا تغطّي الضمانات وكيف نتابع الإنتاج. هل سؤالك غائب؟
          <a href={L('/contact')} class="border-b border-brass-400 pb-0.5 font-semibold text-brass-300 transition-colors hover:text-brass-200">اكتب إلينا.</a>
        </p>
      </div>
    </section>

    <Faq items={faq} heading="الأسئلة المتكررة" />

    <CtaBand title="سؤال أخير؟ دراسة مجانية تجيب عنه." href={contactSim} seam={false} />

    <StickyCta />
  </div>
</Layout>
