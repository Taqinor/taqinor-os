---
/**
 * AR — Privacy policy (W67, RTL). Faithful Arabic translation of
 * /politique-de-confidentialite ; the data-flow facts (what the form collects,
 * fbclid/UTM, law 09-08) are unchanged. FR untouched.
 *
 * W318 — same real-field-set widening + GDPR addendum as FR/EN; see the FR
 * file's comment for the full rationale and source files.
 */
import Layout from '../../layouts/Layout.astro';
import { NAP } from '../../lib/nap';
import { getLocaleFromPath } from '../../i18n/utils';
import { localizeNavHref } from '../../i18n/pages';

const legalHref = localizeNavHref('/mentions-legales', getLocaleFromPath(Astro.url.pathname));

const sections = [
  {
    t: 'ما الذي نجمعه',
    p: 'عند ملء التشخيص الشمسي (/devis/mon-toit)، نجمع: اسمك الكامل، رقم هاتفك، بريدك الإلكتروني (اختياري)، مدينتك أو جماعتك وعنوانك الكامل، موقع GPS الذي تضعه على سطحك، وإن رسمته، محيط سطحك (كلاهما اختياري — يمكنك المتابعة بالعنوان فقط)، نوع سطحك، ملفك الطاقي (شريحة الفاتورة، مبالغ فواتير الصيف/الشتاء عند توفرها، الاستهلاك بالكيلوواط ساعة)، وإن حددته، طريقة التمويل التي تفكر فيها (نقداً، قرضاً، أو غير ذلك). كما تختار ما إذا كنت تفضّل التواصل عبر واتساب. إذا أفضى تشخيصك إلى عرض توقّعه إلكترونياً، تُسجَّل أيضاً صورة توقيعك المرسوم يدوياً على الشاشة، وتاريخ وساعة التوقيع، بموافقتك.',
  },
  {
    t: 'لماذا نجمعها',
    p: 'لإعداد دراستك الشمسية الأولية وإرسالها إليك، ثم معاودة الاتصال بك — عبر واتساب والبريد الإلكتروني — فقط إذا أشّرت على خانة الموافقة. يُستخدم موقع GPS ومحيط السطح فقط للتحجيم (الاتجاه، المساحة القابلة للاستغلال، التظليل). تُستخدم طريقة التمويل التي تفكر فيها لتوجيه نصيحتنا، ولا تُشارَك أبداً مع طرف ثالث دون موافقتك. لا استخدام آخر.',
  },
  {
    t: 'قياس الإعلانات (fbclid و UTM)',
    p: 'إذا وصلت إلى الموقع من إعلان، قد يحتوي الرابط على معطيات تقنية (fbclid, utm_source, utm_medium, utm_campaign, utm_content, utm_term). نحتفظ بها مع طلبك لقياس فعالية حملاتنا — لمعرفة أي إعلان أدى إلى أي طلب. لا تحتوي على اسمك ولا رقمك وتُستخدم لهذا القياس فقط.',
  },
  {
    t: 'قياس استخدام المسار (الخطوات المُنجَزة/المتروكة)',
    p: 'أثناء تصفحك للتشخيص الشمسي، تُرسَل إشارة تقنية مجهولة الهوية تُخبرنا بالخطوة التي بلغتها في الاستمارة، وعند الاقتضاء، بالخطوة التي غادرت عندها دون إتمامها. لا تحتوي هذه الإشارة على اسم أو هاتف أو بريد إلكتروني أو أي معطية تُعرّف بك — تُستخدم فقط لقياس وتحسين سهولة استخدام المسار (معرفة أين يتوقف الزوار لتبسيط تلك الخطوات).',
  },
  {
    t: 'من يطّلع عليها، وأين تذهب',
    p: 'بياناتك متاحة لفريق تاكينور فقط. لا تُباع أو تُؤجَّر أو تُحال إلى أطراف ثالثة أبداً. الموقع مستضاف على بنية Cloudflare. عندما يُصنَّف طلبك كمؤهَّل، يُحال إلى أداتنا لإدارة علاقات الزبناء (CRM)، المستضافة على خادم موجود في ألمانيا، ليتمكن فريقنا من معالجته؛ كما تُرسَل بعض الحقول، في شكل قيم مُشفَّرة (غير قابلة للقراءة كما هي)، إلى واجهة Meta Conversions API، لقياس فعالية حملاتنا الإعلانية على Meta (فيسبوك/إنستغرام) — أبداً اسمك أو رقمك بشكل واضح.',
  },
  {
    t: 'مدة الحفظ',
    p: 'نحتفظ بطلبك طوال مدة معالجته التجارية، ثم، إن لم تنشأ علاقة زبون، لمدة 3 سنوات بعد آخر اتصال بيننا — وبعد ذلك يُحذف. إذا أصبحت زبوناً، تُحفظ بياناتك طوال مدة العلاقة التعاقدية (الضمان، خدمة ما بعد البيع)، ثم للمدة التي تقتضيها التزاماتنا القانونية والمحاسبية. يمكنك طلب حذف بياناتك في أي وقت (انظر أدناه).',
  },
  {
    t: 'حقوقك',
    p: `وفقاً للقانون 09-08 المتعلق بحماية الأشخاص الذاتيين تجاه معالجة المعطيات ذات الطابع الشخصي، لك حق الولوج والتصحيح والحذف لبياناتك. لممارسة ذلك، اكتب إلى ${NAP.email} — نرد ضمن آجال معقولة.`,
  },
  {
    t: 'الموافقة',
    p: 'خانة التأشير في التشخيص تشكّل موافقتك الصريحة على معاودة الاتصال بك. يُسجَّل تاريخها وساعتها مع طلبك. سحب موافقتك بسيط كمنحها: رسالة واحدة تكفي.',
  },
  {
    t: 'التصريح لدى CNDP',
    p: 'هذه المعالجة للمعطيات ذات الطابع الشخصي هي موضوع تصريح قيد الإنجاز لدى اللجنة الوطنية لمراقبة حماية المعطيات ذات الطابع الشخصي (CNDP). سيُضاف رقم التصريح هنا فور صدوره.',
  },
];

// W318 — ملحق RGPD لزبائن الاتحاد الأوروبي (بمن فيهم المغاربة المقيمون
// بالخارج المقيمون في الاتحاد الأوروبي/المنطقة الاقتصادية الأوروبية).
const gdprSection = {
  t: 'المقيمون في الاتحاد الأوروبي (RGPD)',
  p: `إذا كنتم مقيمين في الاتحاد الأوروبي أو المنطقة الاقتصادية الأوروبية — بمن فيهم زبائننا المغاربة المقيمون بالخارج — تُطبَّق اللائحة العامة لحماية المعطيات (RGPD) إضافة إلى القانون المغربي 09-08 أعلاه. الأساس القانوني للمعالجة: موافقتكم الصريحة (خانة التأشير عند التشخيص أو عند التوقيع)، وبمجرد بدء العقد، تنفيذ ذلك العقد. لكم نفس الحقوق كالمقيم بالمغرب — الولوج والتصحيح والحذف — إضافة إلى الحق في تقييد المعالجة والحق في تقديم شكوى لدى السلطة الرقابية لبلد إقامتكم. لممارسة أي من هذه الحقوق، اكتبوا إلى ${NAP.email} مع تحديد طلبكم؛ نرد ضمن أجل معقول وفي جميع الأحوال خلال شهر واحد.`,
};
---

<Layout
  title="سياسة الخصوصية | Taqinor"
  description="ما الذي يجمعه التشخيص الشمسي من تاكينور، ولماذا، ومن يطّلع عليه، وحقوقك (القانون 09-08) — بلغة واضحة."
  ogSlug="accueil"
>
  <section class="px-4 py-14 text-white">
    <div class="mx-auto max-w-3xl">
      <p class="tech-label rule-brass cine-in text-brass-300">القانون 09-08 · لغة واضحة</p>
      <h1 class="display cine-in mt-4 text-4xl [animation-delay:120ms]">سياسة الخصوصية</h1>
      <p class="cine-in mt-4 max-w-xl leading-relaxed text-white/85 [animation-delay:240ms]">
        ما نجمعه، ولماذا، وما الذي يمكنك المطالبة به — دون مصطلحات معقّدة.
      </p>
    </div>
  </section>

  <!-- الوثيقة، في كامل الضوء -->
  <div class="seam-lumiere" aria-hidden="true"></div>
  <section class="bg-blanc-azur px-4 pb-16 pt-6 text-encre"
    ><div class="mx-auto max-w-3xl">
    {sections.map((s, i) => (
      <div class="border-b border-azur-900/15 py-7 first:pt-0">
        <h2 class="display flex items-baseline gap-4 text-xl">
          <span class="fig text-lg text-azur-600" dir="ltr">{String(i + 1).padStart(2, '0')}</span>
          {s.t}
        </h2>
        <p class="mt-3 ps-10 text-sm leading-relaxed text-encre-soft">{s.p}</p>
      </div>
    ))}
    <!-- W318 — ملحق RGPD (المغاربة المقيمون بالخارج / المقيمون بالاتحاد الأوروبي) -->
    <div class="border-b border-azur-900/15 py-7">
      <h2 class="display flex items-baseline gap-4 text-xl">
        <span class="fig text-lg text-azur-600" dir="ltr">{String(sections.length + 1).padStart(2, '0')}</span>
        {gdprSection.t}
      </h2>
      <p class="mt-3 ps-10 text-sm leading-relaxed text-encre-soft">{gdprSection.p}</p>
    </div>
    <p class="mt-7 text-xs text-encre-faint">
      آخر تحديث: يوليوز 2026 — TAQINOR Solutions SARLAU، RC 691213 (الدار البيضاء).
      انظر أيضاً <a href={legalHref} class="underline decoration-azur-600 underline-offset-2">الإشعار القانوني</a>.
    </p>
    </div>
  </section>
</Layout>
