// الختامية. مُشتقّة بالفرز على kwcNum، وليست مرجعًا منسوخًا يدويًا.
const featured = [...REALISATIONS].sort((a, b) => b.kwcNum - a.kwcNum)[0];
// اسم المدينة بالعربية للعرض فقط (الأرقام تبقى اللاتينية من REALISATIONS) —
// نفس أسماء المدن المستخدمة أسفله في `gallery`.
