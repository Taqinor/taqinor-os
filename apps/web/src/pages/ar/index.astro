// W276 — « محرّكنا، مصمَّم في المغرب » : قصة هندسة داخلية صادقة، تُروى عبر
// الأدوات الثلاث المبنية فعليًا والمُستخدمة سلفًا على الموقع (لا برنامج خارجي،
// لا ادّعاء مُختلَق):
//   1. المُقدِّر المُوجَّه بالفاتورة (محرّك تقدير داخلي — موضع الشمس
//      محسوب داخليًا، تباعد الصفوف مُشتق من قاعدة تظليل الانقلاب الشتوي).
//   2. محرّك السطح ثلاثي الأبعاد (/devis/mon-toit — تتبّع حقيقي للسطح،
//      اتجاه وميل حقيقيان، لا جدول عام جاهز).
//   3. محرّك عرض الأسعار (apps/ventes/quote_engine، PDF مُوقَّع إلكترونيًا)
//      الذي يُصدر العرض النهائي.
// لا رقم مُختلَق هنا: الرابط يقود مباشرة إلى المسار الحقيقي (/devis/mon-toit)
// ليتحقق منه الزائر بنفسه خلال 60 ثانية.
const engineeringPillars = [
  {
    title: 'المُقدِّر المُوجَّه بالفاتورة',
    body: 'فاتورة الكهرباء وحدها تكفي: محرّكنا يحسب موضع الشمس وتباعد صفوف الألواح انطلاقًا من قاعدة تظليل عند الانقلاب الشتوي — لا جدول عام مستورد.',
  },
  {
    title: 'محرّك السطح ثلاثي الأبعاد',
    body: 'ارسم سطح منزلك، حدّد اتجاهه، ويتكيّف التحجيم مع الهندسة الحقيقية لمنزلك — نفس التقنية التي جرّبتها للتو في التشخيص أعلاه.',
  },
  {
    title: 'محرّك عرض الأسعار',
    body: 'العرض الناتج يُوقَّع إلكترونيًا، عبر الإنترنت — بلا إعادة إدخال يدوية بين الدراسة والوثيقة التي توقّعها.',
  },
];
---

<Layout
  title="Taqinor — تركيبات الطاقة الشمسية في المغرب، مطابقة للقانون 82-21"
  description="تصميم وتركيب والتصريح بتركيبات الطاقة الشمسية للفيلات والصناعة والفنادق في المغرب. دراسة مجانية، تحجيم بالهندسة، ومطابقة القانون 82-21."
  ogSlug="accueil"
  preloadHeroPoster
>
  <div class="v2">
    <V2Enhance />
    <Article33Ribbon />

    {/* ── 1 · القاعة المظلمة السينمائية (~100svh) — الصورة هي البطل ── */}
    <section class="relative isolate flex min-h-[100svh] flex-col justify-end overflow-hidden text-white">
      <div class="v2-hero-media absolute inset-0 -z-10">
        {/* بوستر البطل بملء الإطار (عنصر LCP) — Ken Burns موروث من طبقة الصورة.
            لا .v3-grade هنا أبدًا (حماية LCP): وحده الـ scrim، المرفوع على هذه
            الصفحة، يحمل الدفء دون المساس بتباين النص. W155 — قصّ بورتريه: في
            الوضع العمودي (هاتف ممسوك عموديًا) تُنتقى مصادر البورتريه أولًا،
            ويعيد object-position توسيط الألواح (center 20%). */}
        <picture>
          <source type="image/avif" media="(orientation: portrait)" sizes="100vw"
            srcset="/videos/hero-poster-540.avif 540w, /videos/hero-poster-720.avif 720w, /videos/hero-poster-1080.avif 1080w" />
          <source type="image/webp" media="(orientation: portrait)" sizes="100vw"
            srcset="/videos/hero-poster-540.webp 540w, /videos/hero-poster-720.webp 720w, /videos/hero-poster-1080.webp 1080w" />
          <source type="image/avif" sizes="100vw"
            srcset="/videos/hero-poster-540.avif 540w, /videos/hero-poster-720.avif 720w, /videos/hero-poster-1080.avif 1080w, /videos/hero-poster-1600.avif 1600w" />
          <source type="image/webp" sizes="100vw"
            srcset="/videos/hero-poster-540.webp 540w, /videos/hero-poster-720.webp 720w, /videos/hero-poster-1080.webp 1080w, /videos/hero-poster-1600.webp 1600w" />
          <img src="/videos/hero-poster-1600.webp" alt="" width="1600" height="900"
            loading="eager" decoding="async" fetchpriority="high"
            class="h-full w-full object-cover hero-portrait-img" />
        </picture>
        <video id="hero-video" muted loop playsinline preload="none" aria-hidden="true" tabindex="-1"
          class="absolute inset-0 h-full w-full object-cover opacity-0 transition-opacity duration-700"></video>
        {/* الـ scrim المرجعي مرفوع (--hero-scrim-strength 0.52): يعوّض دفء
            «الساعة الذهبية» ويُبقي العنوان ≥ AA. */}
        <div class="hero-scrim hero-scrim-v3 absolute inset-0"></div>
        {/* W373 — طبقة العمق: حجاب ضوء نحاسي خفيف جداً، زخرفي بحت (لا صورة،
            تدرّجات CSS فقط)، يتوازى بشكل أبطأ من الملصق خلفه (عامل JS
            منفصل، انظر V2Enhance). لا يمسّ LCP أبداً: موضوع بعد <img
            fetchpriority="high"> في الـ DOM، بلا أي وزن شبكي،
            transform/opacity فقط عند التمرير. */}
        <div class="hero-depth-layer absolute inset-0" aria-hidden="true"></div>
      </div>

      {/* W161 — دعوة إلى التمرير: شيفرون متحرّك، ساكن تحت prefers-reduced-motion */}
      <div class="absolute bottom-6 left-1/2 -translate-x-1/2 scroll-chevron" aria-hidden="true">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="6 9 12 15 18 9" />
        </svg>
      </div>

      {/* المحتوى مرسى أسفلًا — eyebrow مُرتجَع إلى لون اللون (انضباط النحاس).
          W205 — الرقم البطل مع count-up (العرض محجوز، صفر CLS).
          data-hero-tally: خطّاف JS أدناه، متمايز عن data-tally. */}
      <div class="mx-auto w-full max-w-6xl px-4 pb-24 pt-32 sm:pb-32">
        <p class="tech-label v2-kicker rule-brass cine-in text-lune">الدراسة أولًا، ثم الورش</p>
        <h1 id="hero-title" class="display v2-hero-title hero-title-sweep cine-in cine-in-1 mt-6 max-w-[15ch]">
          <span data-hero-tally class="font-variant-numeric tabular-nums" dir="ltr">{heroFigure}</span>{heroTitleSuffix}
        </h1>
        {/* W267 — المال في الصدارة، والـ kWh يبقى الإثبات خلفه. مجال صادق (لا
            رقم واحد أبداً) مُشتقّ من التعريفة الحدّية الحقيقية لـ RÉGIE — انظر
            تعليق الحساب أعلاه. */}
        <p class="cine-in cine-in-2 mt-4 max-w-xl text-lg font-bold text-brass-300 sm:text-xl">{heroMoneyLine}</p>
        <p class="v2-lead cine-in cine-in-2 mt-4 max-w-xl text-white/85">{heroSub}</p>
        <div class="cine-in cine-in-3 mt-10 flex flex-wrap items-center gap-3">
          {/* CTA نحاسي وحيد (انضباط النحاس) — الذهب مأذون هنا */}
          <a id="hero-cta-magnetic" href={L('/devis/mon-toit')} class="glow-hero magnetic-cta bg-brass-400 px-8 py-4 text-lg font-bold text-azur-950 transition-all hover:bg-brass-300">
            احصل على دراستي المجانية <span class="inline-block rtl:-scale-x-100">→</span>
          </a>
          {/* WhatsApp شبحي — حدّ أبيض، بلا أي نحاس */}
          <a href={waDirect} rel="noopener" class="inline-flex items-center gap-2 border border-white/40 px-6 py-3.5 text-base font-semibold text-white backdrop-blur-sm transition-colors hover:border-white hover:bg-white/10">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 0 0-8.6 15.1L2 22l5-1.3A10 10 0 1 0 12 2Zm5.4 14.1c-.2.6-1.3 1.2-1.8 1.2-.5.1-1 .2-3.3-.7-2.8-1.1-4.6-4-4.7-4.2-.1-.2-1.1-1.5-1.1-2.9s.7-2 1-2.3c.2-.3.5-.3.7-.3h.5c.2 0 .4 0 .6.4l.9 2.1c.1.2.1.4 0 .6l-.4.6-.5.5c-.2.2-.3.4-.1.7.2.3.9 1.4 1.9 2.3 1.3 1.1 2.3 1.5 2.6 1.6.3.1.5.1.7-.1l1-1.2c.2-.3.4-.2.7-.1l2 1c.3.1.5.2.6.4 0 .1 0 .7-.3 1.4Z"/></svg>
            WhatsApp مباشر
          </a>
        </div>
      </div>
    </section>

    {/* ── كيف يجري الأمر — شريط من 4 مراحل تحت البطل (W252). يُجيب فوراً عن
        «ماذا يحدث بعد الاستمارة؟»: نفس المراحل الأربع لشريط المسار المفصّل
        أسفله، مُكثَّفة. ── */}
    <div class="seam-soft" aria-hidden="true"></div>
    <section class="px-4 py-14 sm:py-18">
      <div class="mx-auto max-w-6xl">
        <h2 class="tech-label v2-kicker rule-brass text-lune text-center sm:text-start">كيف يجري الأمر</h2>
        <ol class="mt-8 grid gap-x-6 gap-y-10 sm:grid-cols-2 lg:grid-cols-4" data-stagger>
          {howItWorks.map((s, i) => (
            <li class="v2-rise relative border-t-2 border-white/10 pt-5" style={`--v2-i:${i}`}>
              <span class="absolute -top-px start-0 h-0.5 w-10 bg-brass-400" aria-hidden="true"></span>
              <span class="fig lum text-2xl">{s.n}</span>
              <h3 class="display mt-2 text-lg text-white">{s.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-lune-soft">{s.body}</p>
            </li>
          ))}
        </ol>
      </div>
    </section>

    {/* W250 — أداة التقدير الفوري، أعلى الصفحة: «أداة التقدير هي القمع نفسه».
        تعيد استخدام estimateFromBill (lib/billEstimate.ts) — لا منطق مكرّر.
        وُضعت مباشرة بعد «كيف يجري الأمر» ليتمكّن الزائر من تقدير فاتورته قبل
        الوصول حتى إلى التشخيص من 3 خطوات أسفله. ── */}
    <div class="seam-soft" aria-hidden="true"></div>
    <InstantEstimator variant="hero" />

    {/* وعد الضمان في الصدارة — التزام حقيقي وقوي، مأخوذ من /garanties (25 سنة
        أداء) ومن مراقبة Deye Cloud المقاسة. */}
    <div class="seam-soft" aria-hidden="true"></div>
    <section class="bg-brass-400/5 px-4 py-6">
      <p class="mx-auto flex max-w-6xl flex-wrap items-center justify-center gap-x-3 gap-y-1 text-center text-sm font-semibold text-lune sm:text-base">
        <span class="text-brass-300">25 سنة من الأداء المضمون</span>
        <span class="text-lune-faint" aria-hidden="true">·</span>
        <span>إنتاج مُقاس لا موعود — مراقبة Deye Cloud على كل تركيب</span>
      </p>
    </section>

    {/* ── 2 · معرض-إثبات — الضوء يأتي من الصور. شبكة متساوية الارتفاع (بطاقات 4/3
        موحّدة)؛ تحمل كل بطاقة المدينة · kWc · الإنتاج المقاس (حيث نُشر) · العتاد.
        grade «الساعة الذهبية» (.v3-grade) على صورة المحتوى. eyebrow مُرتجَع إلى
        لون اللون. ── */}
    <div class="seam-soft" aria-hidden="true"></div>
    <section class="section px-4">
      <div class="mx-auto max-w-6xl">
        <div class="flex flex-wrap items-end justify-between gap-4">
          <div class="v2-rise">
            <p class="tech-label text-lune">إنجازات حديثة</p>
            <h2 class="display v2-section-title mt-5 text-white">آخر إنجازاتنا</h2>
          </div>
          <p class="v2-rise max-w-sm text-sm leading-relaxed text-lune-soft">
            معطيات من الملفات التقنية. الوضوح والتأطير مُعدَّلان —
            لا إضافة ولا حذف.
          </p>
        </div>
        {/* W271 — شقائق فلترة المدينة، بجافاسكريبت خفيف من جانب العميل فوق
            المعطيات التي تحملها البطاقات أصلاً (بلا أي معطى جديد). «الكل»
            نشِطة افتراضياً؛ aria-pressed يعكس الحالة لقارئات الشاشة. تعمل بلا
            جافاسكريبت: بدون النص البرمجي، تبقى كل البطاقات ظاهرة (تحسين
            تدريجي). */}
        <div class="v2-rise mt-8 flex flex-wrap gap-2" role="group" aria-label="فلترة حسب المدينة" data-gallery-filter>
          {galleryCities.map((c, i) => (
            <button
              type="button"
              class={`gallery-filter-chip border px-4 py-2 text-xs font-bold uppercase tracking-wide transition-colors hover:border-white/50 hover:text-white ${i === 0 ? 'gallery-filter-chip-active border-brass-400 bg-brass-400/10 text-brass-300' : 'border-white/25 text-lune-soft'}`}
              data-city={c}
              aria-pressed={i === 0 ? 'true' : 'false'}
            >
              {c}
            </button>
          ))}
        </div>
        <div class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-3" data-stagger data-gallery-grid>
          {gallery.map((g, i) => (
            <div class="v2-rise cine-card cine-card-link group relative overflow-hidden" style={`--v2-i:${i % 3}`} data-gallery-card data-city={g.ville}>
              <a href={L(`/realisations/${g.slug}`)} class="absolute inset-0 z-0" aria-label={`شاهدوا الإنجاز: ${g.ville}, ${g.kwc}`}></a>
              {/* grade «الساعة الذهبية» موحّد — .v3-grade على صورة المحتوى */}
              <Picture name={g.name} alt={g.alt} widths={g.widths} ratio={4 / 3} sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
                class="v3-grade aspect-[4/3] w-full object-cover transition-transform duration-700 group-hover:scale-[1.04]" />
              {/* زرّ التكبير (lightbox) — عنصر مستقلّ عن رابط البطاقة (لا زرّ
                  داخل <a>، HTML غير صالح)؛ z-index أعلى من الرابط الممتدّ. */}
              <button
                type="button"
                class="gallery-zoom-btn absolute end-3 top-3 z-10 flex h-9 w-9 items-center justify-center rounded-full bg-nuit/70 text-white backdrop-blur-sm transition-colors hover:bg-nuit/90"
                aria-label={`تكبير الصورة: ${g.ville}, ${g.kwc}${g.prod ? `, ${g.prod}` : ''}`}
                data-lightbox-open
                data-name={g.name}
                data-alt={g.alt}
                data-widths={g.widths.join(',')}
                data-caption={`${g.ville} · ${g.kwc}${g.prod ? ` · ${g.prod}` : ''}`}
                data-type={g.type}
              >
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M8 3H5a2 2 0 0 0-2 2v3" /><path d="M21 8V5a2 2 0 0 0-2-2h-3" /><path d="M3 16v3a2 2 0 0 0 2 2h3" /><path d="M16 21h3a2 2 0 0 0 2-2v-3" />
                </svg>
              </button>
              <div class="pointer-events-none absolute inset-x-0 bottom-0 bg-gradient-to-t from-nuit/95 to-transparent px-4 pb-3 pt-12">
                <span class="tech-label block text-lune">{g.ville} · {g.kwc}{g.prod ? ` · ${g.prod}` : ''}</span>
                <span class="mt-0.5 block text-xs text-lune-soft">{g.type}</span>
              </div>
            </div>
          ))}
        </div>
        {/* رابط هادئ نحو كل الإنجازات — لا زرّ ممتلئ */}
        <a href={L('/realisations')} class="v2-rise group mt-10 inline-flex items-center gap-1 border-b-2 border-white/30 pb-0.5 text-sm font-bold text-white transition-colors hover:border-white">
          شاهدوا كل إنجازاتنا <span class="inline-block rtl:-scale-x-100 motion-safe:transition-transform motion-safe:duration-200 motion-safe:group-hover:-translate-x-1" aria-hidden="true">→</span>
        </a>
      </div>
    </section>

    {/* ── إمضاء الزليج — مرّة واحدة فقط، بين الإثبات والحلول ── */}
    <ZelligeSignature
      line="كل رقم في هذا الموقع مقيس، لا موعود."
      sub="الدراسة أولًا. ثم الورش."
    />

    {/* ── حلولنا (6) — كل العرض، أبعد من القطاعين ── */}
    <div class="seam-soft" aria-hidden="true"></div>
    <section class="section px-4">
      <div class="mx-auto max-w-6xl">
        {/* eyebrow مُرتجَع إلى لون اللون + رقم azur (انضباط النحاس) */}
        <p class="tech-label v2-kicker rule-brass text-lune"><span class="ms-2 font-display text-xs text-azur-200/80" aria-hidden="true">01</span>حلولنا</p>
        <h2 class="display v2-section-title mt-5 max-w-xl text-white">كل ما نركّبه</h2>
        <p class="v2-body mt-5 max-w-2xl">
          أبعد من السكني والمهني: الضخّ الفلاحي، والتخزين، وتتبّع الإنتاج، وتسوية
          الوضعية. ينطلق كل حلّ من وضعيتكم الحقيقية — والدراسة هي التي تقرّر.
        </p>
        <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3" data-stagger>
          {solutions.map((s, i) => (
            <a href={L(s.href)} class="v2-rise cine-card group flex flex-col p-7" style={`--v2-i:${i}`}>
              {/* أيقونة بالخطّ، currentColor (نحاسي)، بلا أي تبعية/صورة */}
              <svg class="h-9 w-9 text-brass-400 transition-colors group-hover:text-brass-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={solutionIcons[s.href] ?? ''} />
              <p class="tech-label mt-5 text-lune">{s.tag}</p>
              <h3 class="display mt-2 text-xl text-white">{s.title}</h3>
              <p class="mt-3 flex-1 text-sm leading-relaxed text-lune-soft">{s.body}</p>
              <span class="mt-5 inline-flex items-center gap-1 border-b-2 border-white/30 pb-0.5 text-sm font-bold text-white">اكتشفوا <span class="inline-block rtl:-scale-x-100 motion-safe:transition-transform motion-safe:duration-200 motion-safe:group-hover:-translate-x-1" aria-hidden="true">→</span></span>
            </a>
          ))}
        </div>
        <a href={L('/nos-solutions')} class="v2-rise group mt-10 inline-flex items-center gap-1 border border-white/40 px-6 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">شاهدوا كل حلولنا <span class="inline-block rtl:-scale-x-100 motion-safe:transition-transform motion-safe:duration-200 motion-safe:group-hover:-translate-x-1" aria-hidden="true">→</span></a>
      </div>
    </section>

    {/* ── رقعة لونية فاتحة واضحة (W265) — «استثمار يُسدَّد ثم يدفع لكم»، الرقعة
        الوحيدة بخلفية blanc-azur في الصفحة، لإراحة dark→light→dark. أرقام
        مطابقة لصفحة /financement (بلا أي رقم جديد). ── */}
    <div class="v2-seam" aria-hidden="true"></div>
    <section class="bg-blanc-azur px-4 py-20 text-encre sm:py-28">
      <div class="mx-auto max-w-6xl">
        <div class="v2-rise max-w-2xl">
          <p class="tech-label v2-kicker rule-brass text-azur-600">الاستثمار</p>
          <h2 class="display v2-section-title mt-5 text-encre">استثمار يُسدَّد نفسه، ثم يدفع لكم</h2>
          <p class="v2-body mt-5 text-encre-soft">
            التركيب يُسدَّد بفضل الكهرباء التي تتوقّفون عن شرائها من الشبكة — ويبقى بعد ذلك سنوات
            عديدة من أصل 25 سنة من ضمان الأداء، يستمر خلالها التركيب في الإنتاج لكم، بـ 0 درهم.
          </p>
        </div>
        <dl class="mt-12 grid grid-cols-2 gap-x-8 gap-y-10 sm:grid-cols-4" data-stagger>
          {investment.map((it, i) => (
            <div class="v2-rise min-w-0" style={`--v2-i:${i}`}>
              <dd class="fig fig-md whitespace-nowrap text-azur-600" data-tally dir="ltr">{it.v}</dd>
              <dt class="tech-label mt-2 text-encre-soft">{it.label}</dt>
            </div>
          ))}
        </dl>
        <a href={L('/financement')} class="v2-rise group mt-10 inline-flex items-center gap-1 border-b-2 border-azur-600 pb-0.5 text-sm font-bold text-azur-700 transition-colors hover:text-azur-600">
          اطّلعوا على تفاصيل التمويل <span class="inline-block rtl:-scale-x-100 motion-safe:transition-transform motion-safe:duration-200 motion-safe:group-hover:-translate-x-1" aria-hidden="true">→</span>
        </a>
      </div>
    </section>

    {/* ── لماذا تاكينور / الثقة — أربعة أرقام ضخمة (الذهب يعيش على أرقام .lum،
        انضباط النحاس) — وقائع منشورة سلفًا ── */}
