  /* ── W373 — طبقة عمق البطل ──────────────────────────────────────────
     حجاب ضوء ساكن عند الراحة (تدرّجات إشعاعية فقط، بلا صورة)؛ السكربت
     (V2Enhance) يحرّك فقط `transform` عند التمرير، بعامل أبطأ من سُرعة
     تكبير الملصق (الطبقة «الأعمق» تتحرك أقل — وهم عمق كلاسيكي). عتامة
     أساسية منخفضة جداً لتبقى «همساً»، أبداً حجاباً يُضعف وضوح العنوان. */
  .hero-depth-layer {
    background:
      radial-gradient(38% 32% at 82% 22%, rgb(232 181 74 / 0.16), transparent 70%),
      radial-gradient(30% 26% at 14% 78%, rgb(232 181 74 / 0.08), transparent 72%);
    opacity: 0.9;
    pointer-events: none;
  }
  @media (prefers-reduced-motion: no-preference) {
    @media (min-width: 1024px) {
      .hero-depth-layer {
        will-change: transform;
      }
    }
  }

  /* W368 — CTA مغناطيسي: السكربت يضبط فقط transform: translate(x, y)
     (بحد أقصى ±8px) عند pointermove؛ هذا يضيف فقط عودة ناعمة إلى الأصل عند
     مغادرة المؤشر (pointerleave يزيل النمط المضمّن، وهذا الانتقال يحرّك
     العودة). transform فقط: لا reflow ولا CLS أبداً. مُقيَّد بـ
     (pointer:fine) + reduced-motion داخل السكربت. */
  @media (prefers-reduced-motion: no-preference) and (pointer: fine) {
    .magnetic-cta {
      transition: transform var(--dur-hover) var(--ease-cine), background-color var(--dur-hover) ease;
      will-change: transform;
    }
  }

  /* ── W271 — lightbox المعرض ──────────────────────────────────────────── */
  .gallery-lightbox {
    max-width: min(92vw, 1100px);
    max-height: 90vh;
    border: none;
    background: var(--color-nuit);
    padding: 0;
    color: white;
  }
