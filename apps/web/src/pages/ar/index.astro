const featuredVilleAr = CITY_AR[featured.ville] ?? featured.ville;

// W205 — The protagonist figure of the headline is separated for the count-up.
// Its width is reserved (tabular-nums + JS-locked min-width) → zero CLS.
const heroFigure = (featured.productionNum ?? 0).toLocaleString('fr-FR');
const heroTitleSuffix = ` kWh في السنة، منتَجة على سطح في ${featuredVilleAr}.`;
const heroSub =
  `تركيب رقم ${featured.ref} — ${featured.kwc}، مُحجَّم ومُركَّب ومُقاس من طرف Taqinor. تركيبكم يبدأ بتشخيص في 60 ثانية.`;

// W267 — السطر المالي تحت البطل. بلا أي رقم مخترَع: الاستهلاك الحقيقي لأسرة
// المرجع 468 غير منشور في أي مكان بالموقع، لذا لا يمكن استدعاء
// `annualSavingsMad(production, consumption)` بدون اختراع هذا المتغيّر الثاني.
// الاشتقاق الوحيد الصادق من المعطى المنشور الوحيد (21 406 kWh مُنتَجة) هو
// تثمين هذا الإنتاج بالتعريفة الحدّية الحقيقية لبارِم RÉGIE
// (REGIE_TARIFF.selective، الشطرتان الأعلى — منسجم مع «أكبر تركيبة سكنية لنا
// في 2026»، أي أسرة في أعلى الفئات بلا أي التباس): وهذا بالضبط نفس مجال
// «≈ 1,38–1,60 MAD/kWh» المنشور والموثَّق سلفاً في billRange.ts /
// recharge-voiture-electrique-solaire.astro. مجال (لا رقم واحد أبداً): لأن
// الاستهلاك الذاتي الحقيقي للأسرة غير معروف، فرقم واحد سيخترع دقّة لا نملكها.
const heroProductionKwh = featured.productionNum ?? 0;
const heroTariffLowRate = REGIE_MARGINAL_RATE_SECOND; // 1,3817 MAD/kWh
const heroTariffHighRate = REGIE_MARGINAL_RATE_HIGH; // 1,5958 MAD/kWh
const heroMoneyLow = Math.round((heroProductionKwh * heroTariffLowRate) / 100) * 100;
const heroMoneyHigh = Math.round((heroProductionKwh * heroTariffHighRate) / 100) * 100;
const heroMoneyLine = `≈ ${heroMoneyLow.toLocaleString('fr-FR')} إلى ${heroMoneyHigh.toLocaleString('fr-FR')} MAD تُمحى من الفاتورة كل سنة`;

// PLACEHOLDER(MERYEM): FAQ مؤقتة.
const faq = [
  { q: 'كم يكلّف تركيب نظام شمسي سكني؟', a: 'يتوقف ذلك على استهلاككم وسطحكم. فيلا بفاتورة 1 500 MAD في الشهر تُجهَّز عادةً بـ 4 إلى 6 kWc. يمنحكم التشخيص أسفله مجالًا فوريًا؛ ويُحدَّد العرض الدقيق بعد زيارة تقنية.' },
  { q: 'ماذا يقول القانون 82-21 بالنسبة للأفراد؟', a: 'في الجهد المنخفض، تخضع التركيبات التي تقل عن 11 kW لنظام التصريح: إجراء قبلي وليس ترخيصًا. تتولى Taqinor إعداد التصريح وإيداعه نيابةً عنكم.' },
  { q: 'تركيبي القائم غير مُصرَّح به. ماذا أفعل؟', a: 'تفتح المادة 33 من القانون 82-21 نافذة لتسوية وضعية التركيبات القائمة. النافذة مفتوحة: أودِعوا الآن. راجعوا صفحة التسوية للاطّلاع على المسطرة في 5 مراحل.' },
  { q: 'كم تدوم الألواح؟', a: 'تُضمَن الألواح في الأداء على مدى 25 سنة (عمومًا ≥ 84,8 % من القدرة الأولية عند 25 سنة). أما العاكسات (onduleurs) فتُستبدَل عادةً مرة واحدة طوال عمر التركيب.' },
  { q: 'هل تلزم البطاريات؟', a: 'ليس بالضرورة. إذا كان استهلاككم نهاريًا في الغالب، فإن الاستهلاك الذاتي المباشر هو أفضل استثمار. تُبرَّر البطاريات للاستهلاك الليلي أو لاستمرارية الخدمة — نحسب ذلك في الدراسة.' },
];

// W284 — kwc/prod لم تعد منسوخة يدويًا: مُشتقّة من REALISATIONS عبر `slug`
// (مصدر الحقيقة الوحيد) لتجنّب أي انحراف صامت. `ville` تبقى بالعربية للعرض
