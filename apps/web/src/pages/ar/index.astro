      object-position: center 20%;
    }
  }

  /* scrim البطل مرفوع: يعوّض دفء grade «الساعة الذهبية» ويضمن تباين AA للعنوان
     الأبيض فوق الصورة. */
  .hero-scrim-v3 {
    --hero-scrim-strength: 0.52;
