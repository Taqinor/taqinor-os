const locale = getLocaleFromPath(Astro.url.pathname);
const L = (href: string) => localizeNavHref(href, locale);

const waDirect = whatsappLink(WHATSAPP_LEADS, 'مرحبًا، أرغب في دراسة لتركيب نظام للطاقة الشمسية.');

// W284 — أرقام دقيقة، لا تُقرَّب أبدًا: مُشتقّة من REALISATIONS (مصدر الحقيقة
// الوحيد، apps/web/src/lib/realisations.ts) بدل نسخها يدويًا، لذا لا يمكن أن
// تصبح خاطئة بصمت. الأرقام اللاتينية تبقى كما في FR (toLocaleString('fr-FR')).
const totalKwc = REALISATIONS.reduce((sum, r) => sum + r.kwcNum, 0);
const totalKwcLabel = totalKwc.toLocaleString('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' kWc';
