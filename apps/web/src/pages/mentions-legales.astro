---
import Layout from '../layouts/Layout.astro';
import { NAP } from '../lib/nap';

// Informations légales — dossier entreprise 2026. Pas d'adresse postale
// publiée (décision propriétaire : mode zone de service uniquement).
const rows = [
  { label: 'Raison sociale', value: 'TAQINOR Solutions SARLAU' },
  { label: 'Forme juridique', value: 'Société à responsabilité limitée à associé unique' },
  { label: 'Registre de commerce', value: 'RC 691213 — Tribunal de Commerce de Casablanca' },
  { label: 'ICE', value: '003799642000067' },
  { label: 'Capital social', value: '100 000,00 MAD' },
  { label: 'Gérant', value: 'M. Reda Kasri' },
  { label: 'Contact', value: `${NAP.email} · +212 6 61 85 04 10` },
  { label: 'Hébergement', value: 'Cloudflare, Inc. — réseau mondial (cloudflare.com)' },
];
---

<Layout
  title="Mentions légales | Taqinor"
  description="Informations légales de TAQINOR Solutions SARLAU — RC 691213 Casablanca, ICE 003799642000067."
  ogSlug="accueil"
>
  <section class="bg-azur-900 px-4 py-14 text-white">
    <div class="mx-auto max-w-3xl">
      <p class="tech-label rule-brass text-brass-300">Informations légales</p>
      <h1 class="display mt-4 text-4xl">Mentions légales</h1>
    </div>
  </section>

  <section class="mx-auto max-w-3xl px-4 py-16">
    <div class="border-t-2 border-azur-900 bg-blanc">
      {rows.map((r) => (
        <div class="grid gap-1 border-b border-azur-900/15 px-5 py-4 sm:grid-cols-[14rem_1fr] sm:gap-4">
          <span class="tech-label text-encre-faint">{r.label}</span>
          <span class="text-sm font-semibold">{r.value}</span>
        </div>
      ))}
    </div>
    <p class="mt-6 text-sm leading-relaxed text-encre-soft">
      Taqinor intervient en mode zone de service (interventions sur site uniquement,
      pas d'accueil du public) : Casablanca, Rabat, Marrakech, Tanger, Agadir —
      déplacements dans tout le Maroc.
    </p>
    <p class="mt-3 text-sm leading-relaxed text-encre-soft">
      Pour toute question relative aux données personnelles, consultez la
      <a href="/politique-de-confidentialite" class="font-semibold underline decoration-azur-600 decoration-2 underline-offset-4">politique de confidentialité</a>.
    </p>
  </section>
</Layout>
