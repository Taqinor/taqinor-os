---
/**
 * Maintenance & monitoring (W25) — la promesse d'après-pose. Reprend
 * EXACTEMENT les engagements déjà publiés sur /garanties (monitoring Deye
 * Cloud, SAV proactif, dossier technique) et les faits monitoring de
 * /équipement (réf. MON). AUCUN délai de réponse (SLA), aucune politique de
 * sous-performance, aucun « sous 24h/48h » inventé : rien de tout cela n'est
 * publié. Aucune fausse capture du tableau de bord Deye Cloud n'est annoncée :
 * on renvoie vers les réalisations réelles plutôt que vers un visuel manquant.
 *
 * ÉLÉVATION (2026-06-22) — « bleu Majorelle élevé + âme marocaine, avec
 * discipline ». On ÉLÈVE le système v2 « Cinéma du chantier » sans rien
 * remplacer : nuit profonde (#070b1d) + laiton, aucun noir. Tout le CONTENU et
 * les chiffres restent VERBATIM. Mouvements : un seul langage (.cine-in /
 * .v2-rise), tous gated prefers-reduced-motion, zéro CLS. Discipline laiton :
 * l'or ne vit plus que sur le chiffre clé (.lum) et le CTA principal — les
 * eyebrows brass sont rétrogradés en lune/azur. Rythme via les tokens .section
 * / .section-tight. Pas de photo de contenu ici → pas de .v3-grade ; pas de
 * signature zellige (page texte, aucun beat brand-soul qui la justifie). Le
 * formulaire de lead n'existe pas sur cette page : aucun flux de données touché.
 */
import Layout from '../layouts/Layout.astro';
import V2Enhance from '../components/V2Enhance.astro';
import Article33Ribbon from '../components/Article33Ribbon.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import CtaBand from '../components/CtaBand.astro';
import StickyCta from '../components/StickyCta.astro';

// Repris à l'identique des engagements de /garanties (source de vérité publiée).
const suivi = [
  {
    title: 'Monitoring Deye Cloud inclus',
    body: 'Chaque installation remonte sur Deye Cloud : production en temps réel, historiques par jour et par mois, alertes automatiques sur défaut. Vous recevez votre accès personnel sur l’application mobile, et vous voyez exactement ce que voit l’installateur.',
  },
  {
    title: 'SAV proactif',
    body: 'Nous gardons un œil sur l’ensemble du parc installé. Quand Deye Cloud lève une alerte, elle n’est pas qu’un voyant rouge : elle nomme l’onduleur concerné, le code de défaut remonté et l’heure à laquelle la production a décroché. Souvent, on a déjà identifié la cause quand le client, lui, n’a encore rien vu passer.',
  },
  {
    title: 'Dossier technique complet',
    body: 'L’installation repart avec son dossier : schémas unifilaires, calcul de section des câbles, liste des protections, procédure de mise en service et accès au monitoring Deye Cloud. De quoi permettre à un autre électricien de reprendre la main si besoin.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Maintenance & monitoring',
  serviceType: 'Maintenance et supervision d’installations solaires',
  provider: { '@type': 'Organization', name: 'Taqinor', url: 'https://taqinor.ma' },
  areaServed: { '@type': 'Country', name: 'Maroc' },
  description:
    'Supervision Deye Cloud incluse sur chaque installation solaire au Maroc : production en temps réel, alertes automatiques et SAV proactif, avec accès client via l’application mobile et dossier technique complet livré.',
};
---

<Layout
  title="Maintenance & monitoring solaire : supervision Deye Cloud incluse | Taqinor"
  description="Chaque installation Taqinor remonte sur Deye Cloud — production en temps réel, historiques, alertes automatiques — avec accès client sur l’application mobile. Une alerte nous prévient avant vous : SAV proactif, et dossier technique complet livré avec le chantier."
  ogSlug="equipement"
>
  <div class="v2">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <V2Enhance />
    <Article33Ribbon />

    <Breadcrumb items={[{ label: 'Accueil', href: '/' }, { label: 'Maintenance & monitoring' }]} />

    {/* ── HÉROS SOMBRE — eyebrow rétrogradé en lune (discipline laiton) ── */}
    <section class="px-4 pb-12 pt-16 text-white sm:pt-20">
      <div class="mx-auto max-w-3xl">
        <p class="tech-label v2-kicker rule-brass cine-in text-lune">Après la pose</p>
        <h1 class="display v2-page-title cine-in cine-in-1 mt-5">Maintenance &amp; monitoring</h1>
        <p class="v2-lead cine-in cine-in-2 mt-6 max-w-xl text-white/85">
          Le jour où l’installation est mise en service, elle commence à parler. Sur Deye Cloud,
          chaque toit Taqinor remonte sa production en continu — la vôtre lisible sur votre
          téléphone, la nôtre surveillée sur tout le parc. Une anomalie déclenche une alerte ; nous
          partons de là, avant la réclamation.
        </p>
      </div>
    </section>

    {/* ── CE QUE COMPREND LE SUIVI — rythme .section, eyebrow en lune ── */}
    <div class="seam-soft" aria-hidden="true"></div>
    <section class="section px-4">
      <div class="mx-auto max-w-6xl">
        <p class="tech-label v2-kicker rule-brass text-lune">Inclus à chaque installation</p>
        <h2 class="display v2-section-title mt-5 text-white">Ce que comprend le suivi</h2>
        <div class="mt-12 grid gap-6 md:grid-cols-3" data-stagger>
          {suivi.map((s, i) => (
            <div class="v2-rise cine-card p-7" style={`--v2-i:${i}`}>
              <h3 class="display text-xl text-white">{s.title}</h3>
              <p class="mt-3 text-sm leading-relaxed text-lune-soft">{s.body}</p>
            </div>
          ))}
        </div>
        {/* Filet azur (laiton rétrogradé) ; lien vers la fiche équipement en lune */}
        <p class="v2-rise mt-12 max-w-xl border-l-2 border-azur-200/40 pl-4 text-sm leading-relaxed text-lune-soft">
          Côté matériel, la remontée passe par un dongle WiFi ou Ethernet branché sur l’onduleur ;
          c’est lui qui envoie chaque mesure vers Deye Cloud. Le détail figure sur la fiche
          équipement.
          <a href="/équipement" class="border-b border-lune/40 pb-0.5 font-semibold text-lune transition-colors hover:border-lune hover:text-white">Voir le monitoring Deye Cloud →</a>
        </p>
      </div>
    </section>

    {/* ── PRODUCTION MESURÉE (acte clair, « salle blanche ») ── */}
    <div class="v2-seam" aria-hidden="true"></div>
    <section class="bg-blanc-azur px-4 pb-20 pt-12 text-encre sm:pb-24">
      <div class="mx-auto max-w-3xl">
        <div class="v2-rise">
          {/* Eyebrow canonique fond clair — accent azur unique (discipline) */}
          <p class="tech-label v2-kicker rule-brass eyebrow-light">Des chiffres relevés</p>
          <h2 class="display v2-section-title mt-5">Ce que dit le compteur, pas la plaquette</h2>
          <p class="v2-lead mt-5 text-encre-soft">
            Les kWh qu’une installation Taqinor affiche, Deye Cloud les enregistre jour après jour ;
            c’est ce relevé-là qui fait foi. Nos garanties écrites s’appuient sur cette même donnée :
            ce que la production a réellement donné, pas le chiffre flatteur d’une brochure.
          </p>
          <p class="mt-5 text-sm leading-relaxed text-encre-soft">
            Et le tableau de bord est aussi le vôtre : votre accès personnel sur l’application
            mobile vous montre, en temps réel, ce que votre toit produit — sans intermédiaire.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            {/* CTA principal : le seul laiton de cette section claire (discipline) */}
            <a href="/garanties" class="glow inline-block bg-brass-400 px-7 py-3.5 text-base font-bold text-azur-950 transition-colors hover:bg-brass-300">Voir nos garanties écrites</a>
            <a href="/realisations" class="inline-block border-b-2 border-azur-600 pb-0.5 text-base font-bold text-azur-600 transition-colors hover:text-azur-700">Voir nos réalisations →</a>
          </div>
        </div>
      </div>
    </section>

    {/* ── BLOC DE LIENS DE CLÔTURE — eyebrow en lune, liens ghost blancs ── */}
    <section class="section px-4">
      <div class="mx-auto max-w-6xl">
        <p class="tech-label v2-kicker rule-brass text-lune">Pour aller plus loin</p>
        <h2 class="display v2-section-title mt-5 text-white">Le suivi, dans le détail</h2>
        <p class="v2-rise mt-5 max-w-xl text-sm leading-relaxed text-lune-soft">
          Monitoring et SAV proactif ne tiennent que parce qu’ils s’appuient sur du matériel
          nommé et des garanties écrites noir sur blanc. Les voici en détail.
        </p>
        <div class="v2-rise mt-10 flex flex-wrap gap-3">
          <a href="/garanties" class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">Nos garanties →</a>
          <a href="/équipement" class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">L’équipement posé →</a>
          <a href="/contact#simulateur" class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">Mon diagnostic gratuit →</a>
        </div>
      </div>
    </section>

    <CtaBand title="Un toit qui se surveille tout seul, ça se prépare dès l’étude." href="/contact#simulateur" />

    <StickyCta />
  </div>
</Layout>
