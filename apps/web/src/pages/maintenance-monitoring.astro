---
/**
 * Maintenance & monitoring (W25) — la promesse d'après-pose. Reprend
 * EXACTEMENT les engagements déjà publiés sur /garanties (monitoring Deye
 * Cloud, SAV proactif, dossier technique) et les faits monitoring de
 * /équipement (réf. MON). AUCUN délai de réponse (SLA), aucune politique de
 * sous-performance, aucun « sous 24h/48h » inventé : rien de tout cela n'est
 * publié. Aucune fausse capture du tableau de bord Deye Cloud n'est annoncée :
 * on renvoie vers les réalisations réelles plutôt que vers un visuel manquant.
 *
 * ÉLÉVATION (2026-06-22) — « bleu Majorelle élevé + âme marocaine, avec
 * discipline ». On ÉLÈVE le système v2 « Cinéma du chantier » sans rien
 * remplacer : nuit profonde (#070b1d) + laiton, aucun noir. Tout le CONTENU et
 * les chiffres restent VERBATIM. Mouvements : un seul langage (.cine-in /
 * .v2-rise), tous gated prefers-reduced-motion, zéro CLS. Discipline laiton :
 * l'or ne vit plus que sur le chiffre clé (.lum) et le CTA principal — les
 * eyebrows brass sont rétrogradés en lune/azur. Rythme via les tokens .section
 * / .section-tight. Pas de photo de contenu ici → pas de .v3-grade ; pas de
 * signature zellige (page texte, aucun beat brand-soul qui la justifie). Le
 * formulaire de lead n'existe pas sur cette page : aucun flux de données touché.
 *
 * W255 — Le SAV proactif devient un titre à part entière (co-tête de page
 * avec le monitoring), et 3 tiers d'entretien NOMMÉS (Essentiel/Confort/
 * Premium) sont scaffoldés : inclusions du site (aucun chiffre inventé).
 * WN4 (2026-07-05) — délai de réponse (SLA) et tarif ne sont pas encore
 * validés par le fondateur (WG10) : plutôt qu'un placeholder « en attente de
 * validation » client-facing, ces deux champs sont OMIS et chaque tier
 * renvoie vers un devis personnalisé via un CTA WhatsApp pré-rempli.
 *
 * W257 — Monitoring présenté par résultats (3 mockups téléphone honnêtes —
 * aucun faux tableau de bord Deye Cloud, juste les 3 promesses déjà publiées
 * ci-dessus mises en scène) + rappel de l'alerte WhatsApp en cas d'anomalie.
 *
 * W340 — « Après votre installation » + porte Espace client. Section
 * narrative en 4 temps (mise en service → suivi de production → ouvrir un
 * ticket SAV → garanties), ancrée sur les capacités RÉELLES déjà publiées
 * ci-dessous (rien de nouveau n'est inventé ici, seule la mise en récit
 * change) : DEYE_CLOUD_URL pointe vers le vrai portail public Deye Cloud
 * (www.deyecloud.com/login — l'accès personnel mentionné plus haut), le
 * ticket SAV pointe vers la vraie porte W339 (/contact#deja-client), les
 * garanties vers /garanties. Contenu uniquement : aucun portail client
 * maison n'existe ni n'est prévu ici — ce serait du backend, hors périmètre.
 */
import Layout from '../layouts/Layout.astro';
import V2Enhance from '../components/V2Enhance.astro';
import Article33Ribbon from '../components/Article33Ribbon.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import CtaBand from '../components/CtaBand.astro';
import StickyCta from '../components/StickyCta.astro';
import { DEYE_CLOUD_URL, WHATSAPP_LEADS } from '../lib/nap';
import { whatsappLink } from '../lib/whatsapp';

// W340 — les 4 temps de l'après-installation, dans l'ordre réel du parcours.
// Chaque étape s'appuie sur une capacité déjà publiée sur cette page (suivi)
// ou ailleurs sur le site (garanties, SAV W339) — aucune promesse nouvelle.
const apresInstallation = [
  {
    k: '01',
    title: 'Mise en service',
    body: 'L’installation est raccordée, testée et le dongle de monitoring déclaré pour le suivi de production en temps réel. Le dossier technique complet (schémas, protections, procédure) est remis ce jour-là.',
  },
  {
    k: '02',
    title: 'Suivi de production',
    body: 'Dès le lendemain, votre accès personnel affiche la production réelle, jour après jour. C’est la même donnée qui alimente nos garanties écrites — rien de plus, rien de moins.',
  },
  {
    k: '03',
    title: 'Ouvrir un ticket SAV',
    body: 'Une alerte de votre côté ou de notre supervision en temps réel ? Un signalement WhatsApp ouvre un ticket dans notre module SAV, suivi jusqu’à sa clôture — la même porte que « Déjà client ? » sur la page contact.',
  },
  {
    k: '04',
    title: 'Garanties',
    body: 'Les garanties écrites (matériel, main-d’œuvre) courent en parallèle, avec la production mesurée comme référence commune en cas de litige.',
  },
];


// W255/WN4 (2026-07-05) — 3 tiers d'entretien NOMMÉS : inclusions tirées du
// positionnement déjà publié (monitoring/SAV/dossier technique). Le délai de
// réponse (SLA) et le tarif de chaque formule ne sont pas encore validés par
// le fondateur (WG10) : plutôt qu'afficher un placeholder « en attente de
// validation », ces deux champs sont OMIS (règle « faits vérifiés
// uniquement ») et chaque tier renvoie vers un devis personnalisé par
// WhatsApp — le prix reste réel, discuté au cas par cas, jamais un chiffre
// public non tenable.
const entretienTiers = [
  {
    name: 'Essentiel',
    body: 'Suivi de production en temps réel inclus et surveillance du parc : c’est le socle déjà livré avec chaque installation.',
    inclusions: ['Accès personnel au suivi de production', 'Alerte automatique sur défaut', 'Dossier technique complet'],
  },
  {
    name: 'Confort',
    body: 'Le socle Essentiel, plus un passage d’entretien programmé pour garder l’installation à son meilleur rendement.',
    inclusions: ['Tout Essentiel', 'Visite d’entretien programmée', 'Nettoyage des panneaux'],
  },
  {
    name: 'Premium',
    body: 'Le niveau le plus complet : entretien renforcé et intervention prioritaire sur alerte.',
    inclusions: ['Tout Confort', 'Visites d’entretien renforcées', 'Intervention prioritaire sur alerte'],
  },
];

const waTier = (tierName: string) =>
  whatsappLink(WHATSAPP_LEADS, `Bonjour, je souhaite en savoir plus sur le contrat d’entretien ${tierName}.`);

// W257 — 3 mockups téléphone illustratifs (aucune capture Deye Cloud réelle,
// aucun chiffre inventé) : la production en direct, l'alerte, le suivi des
// économies à date. Libellés génériques, jamais un chiffre qu'on ne tiendrait
// pas.
const phoneVues = [
  {
    appLabel: 'Suivi de production',
    headline: '3,2 kW',
    accent: 'text-brass-300',
    sub: 'Production en direct',
    caption: 'Votre production, lisible en temps réel — la même donnée que celle qui alimente nos garanties écrites.',
  },
  {
    appLabel: 'Suivi de production',
    headline: 'Alerte',
    accent: 'text-white',
    sub: 'Onduleur · code défaut',
    caption: 'Une anomalie déclenche une alerte WhatsApp chez nous avant même que vous l’ayez remarquée.',
  },
  {
    appLabel: 'Suivi de production',
    headline: 'Historique',
    accent: 'text-brass-300',
    sub: 'Économies à date',
    caption: 'Le cumul de production par jour et par mois, pour suivre ce que l’installation a réellement donné.',
  },
];

// Repris à l'identique des engagements de /garanties (source de vérité publiée).
const suivi = [
  {
    title: 'Suivi de production en temps réel inclus',
    body: 'Chaque installation fait l’objet d’un suivi de production en temps réel : historiques par jour et par mois, alertes automatiques sur défaut. Vous recevez votre accès personnel sur l’application mobile, et vous voyez exactement ce que voit l’installateur.',
  },
  {
    title: 'SAV proactif',
    body: 'Nous gardons un œil sur l’ensemble du parc installé. Quand notre supervision en temps réel lève une alerte, elle n’est pas qu’un voyant rouge : elle nomme l’onduleur concerné, le code de défaut remonté et l’heure à laquelle la production a décroché. Souvent, on a déjà identifié la cause quand le client, lui, n’a encore rien vu passer.',
  },
  {
    title: 'Dossier technique complet',
    body: 'L’installation repart avec son dossier : schémas unifilaires, calcul de section des câbles, liste des protections, procédure de mise en service et accès au suivi de production en temps réel. De quoi permettre à un autre électricien de reprendre la main si besoin.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Maintenance & monitoring',
  serviceType: 'Maintenance et supervision d’installations solaires',
  provider: { '@type': 'Organization', name: 'Taqinor', url: 'https://taqinor.ma' },
  areaServed: { '@type': 'Country', name: 'Maroc' },
  description:
    'Supervision en temps réel incluse sur chaque installation solaire au Maroc : production en temps réel, alertes automatiques et SAV proactif, avec accès client via l’application mobile et dossier technique complet livré.',
};
---

<Layout
  title="Maintenance, SAV & monitoring solaire : supervision en temps réel incluse | Taqinor"
  description="Chaque installation Taqinor fait l’objet d’un suivi de production en temps réel — historiques, alertes automatiques — avec accès client sur l’application mobile. Le SAV proactif agit sur alerte, avant la réclamation, et se prolonge en contrats d’entretien nommés. Dossier technique complet livré avec le chantier."
  ogSlug="maintenance-monitoring"
>
  <div class="v2">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <V2Enhance />
    <Article33Ribbon />

    <Breadcrumb items={[{ label: 'Accueil', href: '/' }, { label: 'Maintenance & monitoring' }]} />

    {/* ── HÉROS SOMBRE — W255 : SAV co-titre avec le monitoring (discipline laiton) ── */}
    <section class="px-4 pb-12 pt-16 text-white sm:pt-20">
      <div class="mx-auto max-w-3xl">
        <p class="tech-label v2-kicker rule-brass cine-in text-lune">Après la pose</p>
        <h1 class="display v2-page-title cine-in cine-in-1 mt-5">Monitoring &amp; SAV proactif</h1>
        <p class="v2-lead cine-in cine-in-2 mt-6 max-w-xl text-white/85">
          Le jour où l’installation est mise en service, elle commence à parler. Grâce au
          suivi de production en temps réel, chaque toit Taqinor remonte sa production en continu — la vôtre lisible sur votre
          téléphone, la nôtre surveillée sur tout le parc. Une anomalie déclenche une alerte ;
          notre SAV part de là, avant la réclamation — un module dédié de notre ERP suit chaque
          intervention jusqu’à sa clôture.
        </p>
      </div>
    </section>

    {/* ── W340 — APRÈS VOTRE INSTALLATION + ESPACE CLIENT ──
        Récit en 4 temps du parcours réel (mise en service → suivi de
        production → ouvrir un ticket SAV → garanties), puis la porte Espace
        client : le vrai portail Deye Cloud (accès personnel déjà remis à
        chaque client) + le vrai chemin de ticket SAV (/contact#deja-client,
        W339) + les garanties écrites. Contenu uniquement, aucun portail
        maison inventé. */}
    <div class="seam-soft" aria-hidden="true"></div>
    <section class="section px-4">
      <div class="mx-auto max-w-6xl">
        <p class="tech-label v2-kicker rule-brass text-lune">Ce qui se passe ensuite</p>
        <h2 class="display v2-section-title mt-5 text-white">Après votre installation</h2>
        <p class="v2-lead mt-5 max-w-2xl text-lune-soft">
          La pose n’est pas la fin de la relation, c’est son début. Voici, dans l’ordre, ce qui vous
          attend une fois le chantier terminé.
        </p>
        <ol class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4" data-stagger>
          {apresInstallation.map((s, i) => (
            <li class="v2-rise cine-card flex flex-col p-6" style={`--v2-i:${i}`}>
              <span class="fig lum text-2xl" aria-hidden="true">{s.k}</span>
              <h3 class="display mt-3 text-lg text-white">{s.title}</h3>
              <p class="mt-3 flex-1 text-sm leading-relaxed text-lune-soft">{s.body}</p>
            </li>
          ))}
        </ol>

        {/* Porte Espace client — un seul CTA laiton (le vrai portail de suivi),
            deux liens secondaires (ticket SAV réel, garanties). */}
        <div class="v2-rise mt-12 border-t-2 border-white/15 bg-white/[0.03] p-7 sm:p-9" style="--v2-i:4">
          <p class="tech-label text-lune">Espace client</p>
          <h3 class="display mt-2 text-xl text-white">Votre accès personnel au suivi de production</h3>
          <p class="mt-3 max-w-xl text-sm leading-relaxed text-lune-soft">
            Chaque client reçoit, à la mise en service, son propre accès au suivi de production en
            temps réel, via une application dédiée — pas un portail Taqinor séparé. C’est là que
            vous suivez votre production, jour après jour.
          </p>
          <div class="mt-6 flex flex-wrap gap-3">
            <a
              href={DEYE_CLOUD_URL}
              rel="noopener noreferrer"
              target="_blank"
              class="glow inline-flex items-center gap-2 bg-brass-400 px-6 py-3 text-sm font-bold text-azur-950 transition-colors hover:bg-brass-300"
            >
              Ouvrir mon Espace client →
            </a>
            <a href="/contact#deja-client" class="inline-flex items-center gap-2 border border-white/40 px-6 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">
              Ouvrir un ticket SAV
            </a>
            <a href="/garanties" class="inline-flex items-center gap-2 border border-white/40 px-6 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">
              Voir mes garanties
            </a>
          </div>
        </div>
      </div>
    </section>

    {/* ── CE QUE COMPREND LE SUIVI — rythme .section, eyebrow en lune ── */}
    <div class="seam-soft" aria-hidden="true"></div>
    <section class="section px-4">
      <div class="mx-auto max-w-6xl">
        <p class="tech-label v2-kicker rule-brass text-lune">Inclus à chaque installation</p>
        <h2 class="display v2-section-title mt-5 text-white">Ce que comprend le suivi</h2>
        <div class="mt-12 grid gap-6 md:grid-cols-3" data-stagger>
          {suivi.map((s, i) => (
            <div class="v2-rise cine-card p-7" style={`--v2-i:${i}`}>
              <h3 class="display text-xl text-white">{s.title}</h3>
              <p class="mt-3 text-sm leading-relaxed text-lune-soft">{s.body}</p>
            </div>
          ))}
        </div>
        {/* Filet azur (laiton rétrogradé) ; lien vers la fiche équipement en lune */}
        <p class="v2-rise mt-12 max-w-xl border-l-2 border-azur-200/40 pl-4 text-sm leading-relaxed text-lune-soft">
          Côté matériel, la remontée passe par un dongle WiFi ou Ethernet branché sur l’onduleur ;
          c’est lui qui envoie chaque mesure vers le suivi de production en temps réel. Le détail figure sur la fiche
          équipement.
          <a href="/équipement" class="border-b border-lune/40 pb-0.5 font-semibold text-lune transition-colors hover:border-lune hover:text-white">Voir le suivi de production →</a>
        </p>
      </div>
    </section>

    {/* ── W257 — CE QUE VOUS VOYEZ SUR VOTRE TÉLÉPHONE (résultats, pas specs) ──
        3 mockups téléphone CSS honnêtes : aucune capture Deye Cloud fabriquée,
        juste les 3 promesses déjà publiées ci-dessus (production, alerte,
        économies) mises en scène sur un cadre de téléphone. */}
    <div class="seam-soft" aria-hidden="true"></div>
    <section class="section px-4">
      <div class="mx-auto max-w-6xl">
        <p class="tech-label v2-kicker rule-brass text-lune">Sur votre téléphone</p>
        <h2 class="display v2-section-title mt-5 text-white">Ce que vous voyez, pas ce qu’on vous promet</h2>
        <p class="v2-lead mt-5 max-w-2xl text-lune-soft">
          Trois questions reviennent avant même de parler protocole ou fréquence de mesure : est-ce
          que je vois ma production sur mon téléphone, est-ce que je suis prévenu s’il y a un
          problème, et où en sont mes économies. Voici les trois réponses.
        </p>
        <div class="mt-12 grid gap-6 md:grid-cols-3" data-stagger>
          {phoneVues.map((v, i) => (
            <div class="v2-rise flex flex-col items-center p-4" style={`--v2-i:${i}`}>
              <div class="phone-frame">
                <div class="phone-notch" aria-hidden="true"></div>
                <div class="phone-screen">
                  <p class="phone-app-label">{v.appLabel}</p>
                  <p class={`phone-headline ${v.accent}`}>{v.headline}</p>
                  <p class="phone-sub">{v.sub}</p>
                </div>
              </div>
              <p class="mt-5 text-center text-sm leading-relaxed text-lune-soft">{v.caption}</p>
            </div>
          ))}
        </div>
        <p class="v2-rise mx-auto mt-10 max-w-xl text-center text-sm leading-relaxed text-lune-faint">
          Ces vues illustrent le principe de l’application de suivi de production — pas une capture d’écran
          officielle. Ce que la vôtre affichera dépend de votre installation réelle.
        </p>
      </div>
    </section>

    {/* ── W255/WN4 — SAV : CONTRATS D'ENTRETIEN NOMMÉS (prix sur devis) ── */}
    <div class="v2-seam" aria-hidden="true"></div>
    <section class="bg-blanc-azur px-4 py-16 text-encre sm:py-20">
      <div class="mx-auto max-w-6xl">
        <p class="tech-label v2-kicker rule-brass eyebrow-light">SAV proactif, en formule</p>
        <h2 class="display v2-section-title mt-5">Nos contrats d’entretien</h2>
        <p class="v2-lead mt-5 max-w-2xl text-encre-soft">
          Le socle Essentiel est déjà inclus avec chaque installation ; Confort et Premium
          ajoutent l’entretien programmé et une intervention prioritaire. Le tarif de chaque
          formule dépend de votre installation — écrivez-nous sur WhatsApp pour un devis
          personnalisé.
        </p>
        <div class="mt-12 grid gap-6 md:grid-cols-3" data-stagger>
          {entretienTiers.map((t, i) => (
            <div class="v2-rise flex flex-col border-t-2 border-azur-900 bg-blanc p-7" style={`--v2-i:${i}`}>
              <h3 class="display text-xl text-azur-700">{t.name}</h3>
              <p class="mt-3 flex-1 text-sm leading-relaxed text-encre-soft">{t.body}</p>
              <ul class="mt-4 space-y-2 text-sm text-encre-soft">
                {t.inclusions.map((inc) => (
                  <li class="flex items-start gap-2">
                    <span class="mt-1 text-azur-600" aria-hidden="true">✓</span>
                    <span>{inc}</span>
                  </li>
                ))}
              </ul>
              <a href={waTier(t.name)} rel="noopener" class="mt-6 inline-block border-2 border-azur-600 px-5 py-2.5 text-center text-sm font-bold text-azur-600 transition-colors hover:bg-azur-600 hover:text-white">
                Demander un devis — {t.name}
              </a>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* ── PRODUCTION MESURÉE (acte clair, « salle blanche ») ── */}
    <div class="v2-seam" aria-hidden="true"></div>
    <section class="bg-blanc-azur px-4 pb-20 pt-12 text-encre sm:pb-24">
      <div class="mx-auto max-w-3xl">
        <div class="v2-rise">
          {/* Eyebrow canonique fond clair — accent azur unique (discipline) */}
          <p class="tech-label v2-kicker rule-brass eyebrow-light">Des chiffres relevés</p>
          <h2 class="display v2-section-title mt-5">Ce que dit le compteur, pas la plaquette</h2>
          <p class="v2-lead mt-5 text-encre-soft">
            Les kWh qu’une installation Taqinor affiche, le suivi de production en temps réel les enregistre jour après jour ;
            c’est ce relevé-là qui fait foi. Nos garanties écrites s’appuient sur cette même donnée :
            ce que la production a réellement donné, pas le chiffre flatteur d’une brochure.
          </p>
          <p class="mt-5 text-sm leading-relaxed text-encre-soft">
            Et le tableau de bord est aussi le vôtre : votre accès personnel sur l’application
            mobile vous montre, en temps réel, ce que votre toit produit — sans intermédiaire.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            {/* CTA principal : le seul laiton de cette section claire (discipline) */}
            <a href="/garanties" class="glow inline-block bg-brass-400 px-7 py-3.5 text-base font-bold text-azur-950 transition-colors hover:bg-brass-300">Voir nos garanties écrites</a>
            <a href="/realisations" class="inline-block border-b-2 border-azur-600 pb-0.5 text-base font-bold text-azur-600 transition-colors hover:text-azur-700">Voir nos réalisations →</a>
          </div>
        </div>
      </div>
    </section>

    {/* ── BLOC DE LIENS DE CLÔTURE — eyebrow en lune, liens ghost blancs ── */}
    <section class="section px-4">
      <div class="mx-auto max-w-6xl">
        <p class="tech-label v2-kicker rule-brass text-lune">Pour aller plus loin</p>
        <h2 class="display v2-section-title mt-5 text-white">Le suivi, dans le détail</h2>
        <p class="v2-rise mt-5 max-w-xl text-sm leading-relaxed text-lune-soft">
          Monitoring et SAV proactif ne tiennent que parce qu’ils s’appuient sur du matériel
          nommé et des garanties écrites noir sur blanc. Les voici en détail.
        </p>
        <div class="v2-rise mt-10 flex flex-wrap gap-3">
          <a href="/garanties" class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">Nos garanties →</a>
          <a href="/équipement" class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">L’équipement posé →</a>
          {/* WB17 (2026-07-04) — le monitoring est exactement ce que ces deux
              pages de preuve chiffrée continue publient ; lien contextuel
              naturel depuis cette page (faiblement découvrable ailleurs). */}
          <a href="/production-mesuree" class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">Notre production suivie →</a>
          <a href="/impact-taqinor" class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">Impact Taqinor →</a>
          <a href="/devis/mon-toit" class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">Mon diagnostic gratuit →</a>
        </div>
      </div>
    </section>

    <CtaBand title="Un toit qui se surveille tout seul, ça se prépare dès l’étude." href="/devis/mon-toit" />

    <StickyCta />
  </div>
</Layout>

<style>
  /* W257 — cadre téléphone CSS pur, aucune image : anti-CLS garanti,
     dimensions fixes, zéro dépendance réseau. Discipline laiton : le seul
     accent doré vit sur le chiffre .text-brass-300, jamais sur le cadre. */
  .phone-frame {
    width: 160px;
    height: 320px;
    border-radius: 28px;
    border: 3px solid rgba(255, 255, 255, 0.25);
    background: #0c1330;
    padding: 10px;
    position: relative;
    box-shadow: 0 20px 45px -20px rgb(6 10 30 / 0.6);
  }
  .phone-notch {
    position: absolute;
