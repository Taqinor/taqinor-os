---
/**
 * Maintenance & monitoring (W25) — la promesse d'après-pose. Reprend
 * EXACTEMENT les engagements déjà publiés sur /garanties (monitoring Deye
 * Cloud, SAV proactif, dossier technique) et les faits monitoring de
 * /équipement (réf. MON). AUCUN délai de réponse (SLA), aucune politique de
 * sous-performance, aucun « sous 24h/48h » inventé : rien de tout cela n'est
 * publié. Emplacement réservé (carte vide stylée) pour de futures captures
 * anonymisées du tableau de bord Deye Cloud — aucune fausse capture.
 */
import Layout from '../layouts/Layout.astro';
import V2Enhance from '../components/V2Enhance.astro';
import Article33Ribbon from '../components/Article33Ribbon.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import CtaBand from '../components/CtaBand.astro';
import StickyCta from '../components/StickyCta.astro';

// Repris à l'identique des engagements de /garanties (source de vérité publiée).
const suivi = [
  {
    title: 'Monitoring Deye Cloud inclus',
    body: 'Chaque installation est supervisée sur Deye Cloud : production en temps réel, alertes automatiques, historiques. Le client reçoit son accès personnel via l’application mobile.',
  },
  {
    title: 'SAV proactif',
    body: 'Taqinor surveille l’ensemble du parc installé : les alertes automatiques permettent d’intervenir sans attendre que le client constate un problème.',
  },
  {
    title: 'Dossier technique complet',
    body: 'Chaque installation est livrée avec son dossier : schémas unifilaires, calcul de câbles, liste des protections, procédure de mise en service et accès monitoring Deye Cloud.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Maintenance & monitoring',
  serviceType: 'Maintenance et supervision d’installations solaires',
  provider: { '@type': 'Organization', name: 'Taqinor', url: 'https://taqinor.ma' },
  areaServed: { '@type': 'Country', name: 'Maroc' },
  description:
    'Supervision Deye Cloud incluse sur chaque installation solaire au Maroc : production en temps réel, alertes automatiques et SAV proactif, avec accès client via l’application mobile et dossier technique complet livré.',
};
---

<Layout
  title="Maintenance & monitoring — supervision Deye Cloud incluse | Taqinor"
  description="Après la pose, le suivi : monitoring Deye Cloud inclus sur chaque installation (production temps réel, alertes automatiques, accès client mobile), SAV proactif et dossier technique complet livré. Une production mesurée, pas promise."
  ogSlug="equipement"
>
  <div class="v2">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <V2Enhance />
    <Article33Ribbon />

    <Breadcrumb items={[{ label: 'Accueil', href: '/' }, { label: 'Maintenance & monitoring' }]} />

    <!-- Héros sombre -->
    <section class="px-4 pb-10 pt-16 text-white sm:pt-20">
      <div class="mx-auto max-w-3xl">
        <p class="tech-label v2-kicker rule-brass cine-in text-brass-300">Après la pose</p>
        <h1 class="display v2-page-title cine-in mt-5 [animation-delay:120ms]">Maintenance &amp; monitoring</h1>
        <p class="v2-lead cine-in mt-6 max-w-xl text-white/85 [animation-delay:240ms]">
          La pose n’est pas la fin du travail, c’est le début du suivi. Chaque installation Taqinor
          est supervisée sur Deye Cloud, avec accès client inclus : votre production se mesure en
          continu, et nous intervenons sur alerte plutôt que sur réclamation.
        </p>
      </div>
    </section>

    <!-- Ce que comprend le suivi -->
    <section class="px-4 pb-20 sm:pb-24">
      <div class="mx-auto max-w-6xl">
        <p class="tech-label v2-kicker rule-brass text-brass-300">Inclus à chaque installation</p>
        <h2 class="display v2-section-title mt-5 text-white">Ce que comprend le suivi</h2>
        <div class="mt-10 grid gap-6 md:grid-cols-3" data-stagger>
          {suivi.map((s, i) => (
            <div class="v2-rise cine-card p-7" style={`--v2-i:${i}`}>
              <h3 class="display text-xl text-white">{s.title}</h3>
              <p class="mt-3 text-sm leading-relaxed text-lune-soft">{s.body}</p>
            </div>
          ))}
        </div>
        <p class="mt-10 max-w-xl border-l-4 border-brass-400/60 pl-4 text-sm leading-relaxed text-lune-soft">
          Le détail du matériel de supervision — dongle WiFi/Ethernet, production mesurée en continu,
          alertes automatiques — figure sur la fiche équipement.
          <a href="/équipement" class="border-b border-brass-400 pb-0.5 font-semibold text-brass-300 transition-colors hover:text-brass-200">Voir le monitoring Deye Cloud →</a>
        </p>
      </div>
    </section>

    <!-- Production mesurée, pas promise (fond clair) -->
    <div class="v2-seam" aria-hidden="true"></div>
    <section class="bg-blanc-azur px-4 pb-20 pt-10 text-encre sm:pb-24">
      <div class="mx-auto max-w-6xl">
        <div class="grid gap-10 lg:grid-cols-[1.1fr_1fr] lg:items-start">
          <div class="v2-rise">
            <p class="tech-label v2-kicker rule-brass text-azur-600">Mesurée, pas promise</p>
            <h2 class="display v2-section-title mt-5">Une production que l’on mesure</h2>
            <p class="v2-lead mt-5 text-encre-soft">
              Une installation Taqinor n’est pas une promesse sur plaquette : sa production est suivie
              jour après jour sur Deye Cloud, et nos chiffres sont des chiffres mesurés. C’est la même
              logique que nos garanties écrites — la performance se constate, elle ne se raconte pas.
            </p>
            <p class="mt-5 text-sm leading-relaxed text-encre-soft">
              Vous gardez la main : votre accès personnel à l’application mobile vous montre, en temps
              réel, ce que votre toit produit.
            </p>
            <a href="/garanties" class="mt-8 inline-block bg-brass-400 px-7 py-3.5 text-base font-bold text-azur-950 transition-colors hover:bg-brass-300">Voir nos garanties écrites</a>
          </div>

          <!-- Emplacement réservé : futures captures anonymisées du tableau de bord -->
          <div class="v2-rise flex min-h-[18rem] flex-col items-center justify-center border-2 border-dashed border-azur-600/40 bg-blanc px-6 py-12 text-center">
            <p class="tech-label text-azur-600">Tableau de bord Deye Cloud</p>
            <p class="display mt-4 text-2xl text-encre">Captures du tableau de bord Deye Cloud — à venir</p>
            <p class="mt-3 max-w-sm text-sm leading-relaxed text-encre-soft">
              Nous ajouterons ici des vues anonymisées de production réelle issues du monitoring de
              nos installations. En attendant, demandez à voir un chantier en service.
            </p>
            <a href="/realisations" class="mt-6 inline-block border-b-2 border-azur-600 pb-0.5 text-sm font-bold text-azur-600 transition-colors hover:text-azur-700">Voir nos réalisations →</a>
          </div>
        </div>
      </div>
    </section>

    <!-- Bloc de liens de clôture -->
    <section class="px-4 py-20 sm:py-28">
      <div class="mx-auto max-w-6xl">
        <p class="tech-label v2-kicker rule-brass text-brass-300">Pour aller plus loin</p>
        <h2 class="display v2-section-title mt-5 text-white">Le suivi, dans le détail</h2>
        <p class="mt-5 max-w-xl text-sm leading-relaxed text-lune-soft">
          Le monitoring et le SAV proactif s’appuient sur le matériel posé et les garanties écrites.
          Tout commence par une étude sérieuse.
        </p>
        <div class="mt-10 flex flex-wrap gap-3">
          <a href="/garanties" class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">Nos garanties →</a>
          <a href="/équipement" class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">L’équipement posé →</a>
          <a href="/contact#simulateur" class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">Mon diagnostic gratuit →</a>
        </div>
      </div>
    </section>

    <CtaBand title="Un suivi sérieux commence par une étude sérieuse." href="/contact#simulateur" />

    <StickyCta />
  </div>
</Layout>
