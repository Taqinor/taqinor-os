---
/**
 * Pourquoi Taqinor (W4) — consolide les différenciateurs DÉJÀ exprimés sur le
 * site. Aucun chiffre ni claim nouveau : uniquement restructuration de
 * l'existant (accueil, équipement, loi-82-21, réalisations).
 */
import Layout from '../layouts/Layout.astro';
import V2Enhance from '../components/V2Enhance.astro';
import Article33Ribbon from '../components/Article33Ribbon.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import CtaBand from '../components/CtaBand.astro';
import StickyCta from '../components/StickyCta.astro';

const piliers = [
  {
    k: '01',
    title: 'L’étude d’abord, le chantier ensuite',
    body: 'Le dimensionnement part de votre consommation réelle et de votre toiture — c’est l’étude qui décide du matériel, jamais l’inverse. Chaque étude est validée par le fondateur, docteur-ingénieur avec plus de 10 ans d’expertise R&D. L’étude et le diagnostic sont à 0 MAD.',
    href: '/résidentiel',
    link: 'Voir le résidentiel',
  },
  {
    k: '02',
    title: 'Une production qui se mesure, pas une promesse',
    body: 'Chaque installation est supervisée sur Deye Cloud : production en temps réel, alertes automatiques, accès client inclus. Nos chiffres de production sont mesurés, pas estimés sur plaquette.',
    href: '/realisations',
    link: 'Voir nos réalisations',
  },
  {
    k: '03',
    title: 'Conforme loi 82-21, de bout en bout',
    body: 'Déclaration (moins de 11 kW en basse tension), accord de raccordement ou autorisation : nous identifions le régime, préparons et déposons le dossier — y compris la régularisation des installations existantes via l’Article 33. Le régime est en vigueur depuis le 9 juin 2026.',
    href: '/loi-82-21',
    link: 'Identifier mon régime',
  },
  {
    k: '04',
    title: 'Matériel tier-1 uniquement',
    body: 'Canadian Solar, JA Solar, Deye, Huawei, Dyness — sourcés via des distributeurs officiels au Maroc, garanties locales activables. Pas de catalogue infini, aucun matériel no-name. Garanties de 10 à 25 ans selon les composants.',
    href: '/équipement',
    link: 'Voir l’équipement',
  },
];
---

<Layout
  title="Pourquoi Taqinor — l’ingénierie d’abord, la preuve ensuite | Taqinor"
  description="Dimensionnement par l'ingénierie, production mesurée sur Deye Cloud, conformité loi 82-21 de bout en bout, matériel tier-1 et chantiers réels visitables : ce qui distingue Taqinor pour votre installation solaire au Maroc."
  ogSlug="accueil"
>
  <div class="v2">
    <V2Enhance />
    <Article33Ribbon />

    <Breadcrumb items={[{ label: 'Accueil', href: '/' }, { label: 'Pourquoi Taqinor' }]} />

    <section class="px-4 pb-10 pt-16 text-white sm:pt-20">
      <div class="mx-auto max-w-3xl">
        <p class="tech-label v2-kicker rule-brass cine-in text-brass-300">Pourquoi nous</p>
        <h1 class="display v2-page-title cine-in mt-5 [animation-delay:120ms]">L’ingénierie d’abord, la preuve ensuite</h1>
        <p class="v2-lead cine-in mt-6 max-w-xl text-white/85 [animation-delay:240ms]">
          Une installation solaire est un placement sur 25 ans. Il mérite une étude sérieuse, du
          matériel sérieux et des chiffres qu’on peut mesurer — pas des promesses. Voici ce qui
          fait notre différence.
        </p>
      </div>
    </section>

    <!-- Les piliers -->
    <section class="px-4 pb-20 sm:pb-24">
      <div class="mx-auto grid max-w-6xl gap-6 md:grid-cols-2" data-stagger>
        {piliers.map((p, i) => (
          <div class="v2-rise cine-card flex flex-col p-7" style={`--v2-i:${i}`}>
            <p class="fig lum text-3xl">{p.k}</p>
            <h2 class="display mt-2 text-2xl text-white">{p.title}</h2>
            <p class="mt-3 flex-1 text-sm leading-relaxed text-lune-soft">{p.body}</p>
            <a href={p.href} class="mt-5 inline-block border-b-2 border-brass-400 pb-0.5 text-sm font-bold text-brass-300 transition-colors hover:text-brass-200">{p.link} →</a>
          </div>
        ))}
      </div>
    </section>

    <!-- La preuve plutôt que les promesses -->
    <section class="border-y border-white/10 px-4 py-16 sm:py-20">
      <div class="mx-auto grid max-w-6xl gap-10 lg:grid-cols-[1.1fr_1fr] lg:items-center">
        <div class="v2-rise">
          <p class="tech-label v2-kicker rule-brass text-brass-300">La preuve, pas les promesses</p>
          <h2 class="display v2-section-title mt-5 text-white">Des chantiers réels, à voir sur demande</h2>
          <p class="v2-lead mt-5 text-lune-soft">
            Casablanca, El Jadida, Nouaceur : nos installations existent et produisent déjà. Leur
            production est suivie sur Deye Cloud. C’est la meilleure réponse à « est-ce que ça
            marche vraiment ? » — on vous montre, on ne vous raconte pas.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href="/realisations" class="inline-block bg-brass-400 px-7 py-3.5 text-base font-bold text-azur-950 transition-colors hover:bg-brass-300">Voir nos réalisations</a>
            <a href="/à-propos" class="inline-block border border-white/40 px-7 py-3.5 text-base font-bold text-white transition-colors hover:border-white hover:bg-white/10">Le fondateur &amp; la méthode →</a>
          </div>
        </div>
        <dl class="grid grid-cols-2 gap-x-6 gap-y-10 border-l-2 border-brass-400/60 pl-6 sm:pl-10" data-stagger>
          <div class="v2-rise" style="--v2-i:0">
            <dd class="fig lum whitespace-nowrap text-3xl sm:text-5xl" data-tally>43,48 kWc</dd>
            <dt class="tech-label mt-2 text-lune-faint">Installés — Casablanca, El Jadida, Nouaceur</dt>
          </div>
          <div class="v2-rise" style="--v2-i:1">
            <dd class="fig lum whitespace-nowrap text-3xl sm:text-5xl" data-tally>25 ans</dd>
            <dt class="tech-label mt-2 text-lune-faint">Garantie de performance</dt>
          </div>
          <div class="v2-rise" style="--v2-i:2">
            <dd class="fig lum whitespace-nowrap text-3xl sm:text-5xl" data-tally>0 MAD</dd>
            <dt class="tech-label mt-2 text-lune-faint">L’étude et le diagnostic</dt>
          </div>
          <div class="v2-rise" style="--v2-i:3">
            <dd class="font-display text-xl font-bold text-white">Deye Cloud</dd>
            <dt class="tech-label mt-2 text-lune-faint">Production mesurée, accès client inclus</dt>
          </div>
        </dl>
      </div>
    </section>

    <CtaBand title="L’ingénierie d’abord : commencez par l’étude gratuite." href="/contact#simulateur" />

    <StickyCta />
  </div>
</Layout>
