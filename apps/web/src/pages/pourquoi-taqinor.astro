---
/**
 * Pourquoi Taqinor (W4) — consolide les différenciateurs DÉJÀ exprimés sur le
 * site. Aucun chiffre ni claim nouveau : uniquement restructuration de
 * l'existant (accueil, équipement, loi-82-21, réalisations).
 */
import Layout from '../layouts/Layout.astro';
import V2Enhance from '../components/V2Enhance.astro';
import Article33Ribbon from '../components/Article33Ribbon.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import CtaBand from '../components/CtaBand.astro';
import StickyCta from '../components/StickyCta.astro';

const piliers = [
  {
    k: '01',
    title: 'On part de votre facture, pas d’un catalogue',
    body: 'La puissance se déduit de votre consommation réelle et de votre toiture — surface utile, orientation, ombrage. Tant que ce calcul n’a pas justifié une référence, on ne la pose pas. Le diagnostic et l’étude sont à 0 MAD ; c’est le fondateur qui les signe (voir À propos).',
    href: '/à-propos',
    link: 'Le fondateur & la méthode',
  },
  {
    k: '02',
    title: 'Nos chiffres de production sortent du compteur',
    body: 'Chaque installation est reliée à Deye Cloud : production en temps réel, alertes automatiques, accès client inclus. Quand nous citons une production, c’est un relevé, pas une projection de brochure.',
    href: '/realisations',
    link: 'Voir nos réalisations',
  },
  {
    k: '03',
    title: 'Le dossier loi 82-21, monté et déposé',
    body: 'Déclaration (moins de 11 kW en basse tension), accord de raccordement ou autorisation : nous lisons votre cas, identifions le régime et déposons le dossier — régularisation des installations existantes par l’Article 33 comprise. La loi s’applique depuis le 9 juin 2026.',
    href: '/loi-82-21',
    link: 'Identifier mon régime',
  },
  {
    k: '04',
    title: 'Cinq marques tier-1, et rien d’anonyme sur le toit',
    body: 'Canadian Solar, JA Solar, Deye, Huawei, Dyness : sourcés chez des distributeurs officiels au Maroc, garanties activables sur place. Selon le composant, cette garantie court de 10 à 25 ans.',
    href: '/équipement',
    link: 'Voir l’équipement',
  },
];
---

<Layout
  title="Pourquoi Taqinor — ce qui nous distingue, point par point | Taqinor"
  description="Quatre différences concrètes : un dimensionnement déduit de votre facture, une production relevée sur Deye Cloud, le dossier loi 82-21 monté et déposé, et une liste courte de marques tier-1 garanties de 10 à 25 ans. Chantiers réels visitables sur demande."
  ogSlug="accueil"
>
  <div class="v2">
    <V2Enhance />
    <Article33Ribbon />

    <Breadcrumb items={[{ label: 'Accueil', href: '/' }, { label: 'Pourquoi Taqinor' }]} />

    <section class="px-4 pb-10 pt-16 text-white sm:pt-20">
      <div class="mx-auto max-w-3xl">
        <p class="tech-label v2-kicker rule-brass cine-in text-lune">Pourquoi nous</p>
        <h1 class="display v2-page-title cine-in mt-5 [animation-delay:120ms]">Quatre différences que vous pouvez vérifier</h1>
        <p class="v2-lead cine-in mt-6 max-w-xl text-white/85 [animation-delay:240ms]">
          Beaucoup d’installateurs promettent la même chose. Nous préférons les quatre points que vous
          pouvez contrôler vous-même : d’où sort la puissance proposée, d’où sortent nos chiffres de
          production, qui s’occupe de votre dossier réglementaire, et ce qu’il y a vraiment sur le
          toit. La personne derrière la méthode, elle, est sur la page <a href="/à-propos" class="border-b border-white/40 pb-0.5 font-semibold text-white transition-colors hover:border-white">À propos</a>.
        </p>
      </div>
    </section>

    <!-- Les piliers -->
    <section class="px-4 pb-20 sm:pb-24">
      <div class="mx-auto grid max-w-6xl gap-6 md:grid-cols-2" data-stagger>
        {piliers.map((p, i) => (
          <div class="v2-rise cine-card flex flex-col p-7" style={`--v2-i:${i}`}>
            <p class="fig lum text-3xl">{p.k}</p>
            <h2 class="display mt-2 text-2xl text-white">{p.title}</h2>
            <p class="mt-3 flex-1 text-sm leading-relaxed text-lune-soft">{p.body}</p>
            <a href={p.href} class="mt-5 inline-block border-b-2 border-white/30 pb-0.5 text-sm font-bold text-white transition-colors hover:border-white">{p.link} →</a>
          </div>
        ))}
      </div>
    </section>

    <!-- La preuve plutôt que les promesses -->
    <section class="border-y border-white/10 px-4 py-16 sm:py-20">
      <div class="mx-auto grid max-w-6xl gap-10 lg:grid-cols-[1.1fr_1fr] lg:items-center">
        <div class="v2-rise">
          <p class="tech-label v2-kicker rule-brass text-lune">Allez les voir</p>
          <h2 class="display v2-section-title mt-5 text-white">Des chantiers réels, à voir sur demande</h2>
          <p class="v2-lead mt-5 text-lune-soft">
            Casablanca, El Jadida, Nouaceur : ces installations tournent déjà, et leur production
            défile sur Deye Cloud. À la question « est-ce que ça marche vraiment ? », nous
            répondons par une adresse, pas par un argumentaire. Demandez à visiter.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href="/realisations" class="inline-block bg-brass-400 px-7 py-3.5 text-base font-bold text-azur-950 transition-colors hover:bg-brass-300">Voir nos réalisations</a>
            <a href="/à-propos" class="inline-block border border-white/40 px-7 py-3.5 text-base font-bold text-white transition-colors hover:border-white hover:bg-white/10">Le fondateur &amp; la méthode →</a>
          </div>
        </div>
        <dl class="grid grid-cols-2 gap-x-6 gap-y-10 border-l-2 border-brass-400/60 pl-6 sm:pl-10" data-stagger>
          <div class="v2-rise" style="--v2-i:0">
            <dd class="fig lum whitespace-nowrap text-3xl sm:text-5xl" data-tally>43,48 kWc</dd>
            <dt class="tech-label mt-2 text-lune-faint">Installés — Casablanca, El Jadida, Nouaceur</dt>
          </div>
          <div class="v2-rise" style="--v2-i:1">
            <dd class="fig lum whitespace-nowrap text-3xl sm:text-5xl" data-tally>25 ans</dd>
            <dt class="tech-label mt-2 text-lune-faint">Garantie de performance</dt>
          </div>
          <div class="v2-rise" style="--v2-i:2">
            <dd class="fig lum whitespace-nowrap text-3xl sm:text-5xl" data-tally>0 MAD</dd>
            <dt class="tech-label mt-2 text-lune-faint">L’étude et le diagnostic</dt>
          </div>
          <div class="v2-rise" style="--v2-i:3">
            <dd class="font-display text-xl font-bold text-white">Deye Cloud</dd>
            <dt class="tech-label mt-2 text-lune-faint">Production mesurée, accès client inclus</dt>
          </div>
        </dl>
      </div>
    </section>

    <CtaBand title="Jugez-nous sur le calcul : l’étude est gratuite." href="/devis/mon-toit" />

    <StickyCta />
  </div>
</Layout>
