---
/**
 * Guide (W6) — Loi 82-21 expliquée simplement. Reprend en langage clair le
 * contenu de regime.ts et de la page loi-82-21. Seuils alignés 1:1 sur
 * regime.ts / loi-82-21.astro / la FAQ : < 11 kW BT (déclaration), jusqu'à
 * 5 MW (accord de raccordement), >= 5 MW (autorisation) ; décret 2-25-100 en
 * vigueur le 9 juin 2026 ; Article 33 = fenêtre de 18 mois. Autorités citées
 * (gestionnaire de réseau / ONEE / régies / ANRE) déjà établies ailleurs sur
 * le site (regime.ts, estimatorBrain, blog). Pas de tarif/coût.
 */
import Layout from '../../layouts/Layout.astro';
import V2Enhance from '../../components/V2Enhance.astro';
import Article33Ribbon from '../../components/Article33Ribbon.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CtaBand from '../../components/CtaBand.astro';
import StickyCta from '../../components/StickyCta.astro';
import Faq from '../../components/Faq.astro';
import { NAP } from '../../lib/nap';
import RelatedLinks from '../../components/RelatedLinks.astro';
import { estimateReadingTime } from '../../lib/readingTime';

// W303 — date de vérification + auteur + temps de lecture.
const verifiedDate = new Date('2026-07-03');
const dateFmt = new Intl.DateTimeFormat('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });
const guideBodyText = `
  Depuis le 9 juin 2026, la loi 82-21 sur l'autoproduction d'énergie électrique et son décret 2-25-100
  s'appliquent. La règle est plus simple qu'elle n'en a l'air : deux nombres — votre puissance et votre
  niveau de raccordement — suffisent à vous ranger dans l'un des trois régimes. En dessous de 11 kW en
  basse tension, une déclaration préalable suffit. Au-dessus du seuil de déclaration et jusqu'à 5 MW,
  il faut décrocher un accord de raccordement auprès du gestionnaire de réseau. À partir de 5 MW, une
  autorisation en bonne et due forme doit être obtenue avant le premier coup de pioche. La loi n'oublie
  pas les installations posées avant elle. Son Article 33 ouvre, depuis le 9 juin 2026, une fenêtre de
  18 mois pour les mettre en règle. Régularisée dans ce délai, une installation existante rejoint le
  cadre légal comme une neuve. Passé la fenêtre, elle reste en situation irrégulière au regard de la
  loi 82-21, avec les sanctions que cela suppose.
`;
const readingMinutes = estimateReadingTime(guideBodyText);

const url = new URL(Astro.url.pathname, Astro.site).href;
// W291 — image OG (même URL que celle passée à ogSlug plus bas), pour l'éligibilité Article rich results.
const schemaImageUrl = new URL('/og/loi-82-21.png', Astro.site).href;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'Loi 82-21 expliquée simplement',
  description: 'Les trois régimes de l’autoproduction d’électricité au Maroc (déclaration, accord de raccordement, autorisation) expliqués en langage clair.',
  image: schemaImageUrl,
  about: { '@type': 'Thing', name: 'Loi 82-21 — autoproduction d’énergie électrique' },
  author: { '@type': 'Organization', name: NAP.name, url: NAP.url },
  publisher: { '@type': 'Organization', name: NAP.name, url: NAP.url },
  mainEntityOfPage: url,
};

// W297 — AEO/GEO : Q&A autonome reprenant les faits déjà énoncés ci-dessus, pour
// que les assistants IA (Google AI Overviews / ChatGPT) puissent citer directement
// une réponse complète. schema={false} : /faq garde le seul FAQPage du site.
const faq = [
  {
    q: 'Quel régime de la loi 82-21 pour une villa au Maroc ?',
    a: 'Sous 11 kW en basse tension, une simple déclaration préalable suffit — c’est le cas de la quasi-totalité des villas. Au-dessus de ce seuil et jusqu’à 5 MW, il faut un accord de raccordement ; à partir de 5 MW, une autorisation.',
  },
  {
    q: 'Depuis quand la loi 82-21 est-elle en vigueur ?',
    a: 'Le décret d’application 2-25-100 s’applique depuis le 9 juin 2026.',
  },
  {
    q: 'Que faire si mon installation solaire existante n’est pas déclarée ?',
    a: 'L’Article 33 ouvre, depuis le 9 juin 2026, une fenêtre de 18 mois pour la régulariser. Passé ce délai, elle reste en situation irrégulière au regard de la loi, avec les sanctions que cela suppose.',
  },
];
const regimes = [
  {
    n: '01',
    title: 'Déclaration',
    body: 'En dessous de 11 kW en basse tension — ou hors réseau, sur un site isolé — vous n’avez rien à faire valider : une déclaration préalable, déposée avant la mise en service, suffit. C’est une formalité, pas une demande d’autorisation, et c’est le cas de la grande majorité des villas.',
  },
  {
    n: '02',
    title: 'Accord de raccordement',
    body: 'Au-dessus du seuil de déclaration et jusqu’à 5 MW, dès que l’on injecte sur le réseau en basse ou moyenne tension, il faut décrocher un accord de raccordement auprès du gestionnaire de réseau avant de démarrer — l’ONEE dans la plupart des régions, ou la régie locale là où il y en a une (Lydec à Casablanca, Redal à Rabat, Amendis à Tanger). C’est le terrain habituel des sites professionnels.',
  },
  {
    n: '03',
    title: 'Autorisation',
    body: 'À partir de 5 MW, en moyenne, haute ou très haute tension, on change d’échelle : une autorisation en bonne et due forme doit être obtenue avant le premier coup de pioche. Peu de toitures privées sont concernées.',
  },
];
---

<Layout
  title="Loi 82-21 expliquée simplement — les 3 régimes | Taqinor"
  description="Le seuil de 11 kW décide presque tout : en dessous, en basse tension, une simple déclaration suffit, et c’est le cas de la plupart des villas. Au-dessus, accord de raccordement, puis autorisation à partir de 5 MW. Les trois régimes en clair, et comment vous situer."
  ogSlug="loi-82-21"
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <div class="v2">
    <V2Enhance />
    <Article33Ribbon />

    <Breadcrumb items={[{ label: 'Accueil', href: '/' }, { label: 'Guides', href: '/guides' }, { label: 'Loi 82-21 expliquée simplement' }]} />

    <article class="mx-auto max-w-[68ch] px-4 pb-24 pt-12 sm:pb-28">
      <p class="tech-label v2-kicker rule-brass text-lune">Guide · Loi 82-21</p>
      <h1 class="display v2-page-title mt-5 text-white">Loi 82-21 expliquée simplement</h1>

      <!-- W303 — date de vérification + auteur + temps de lecture -->
      <p class="guide-byline mt-3 flex flex-wrap items-center gap-x-2 gap-y-1 text-xs text-lune-faint">
        <span>Vérifié le {dateFmt.format(verifiedDate)} · par Reda Kasri</span>
        <span aria-hidden="true">·</span>
        <span>{readingMinutes} min de lecture</span>
      </p>

      <p class="v2-lead mt-6 text-lune-soft">
        Depuis le 9 juin 2026, la loi 82-21 sur l’autoproduction d’énergie électrique et son décret
        2-25-100 s’appliquent. La règle est plus simple qu’elle n’en a l’air : deux nombres — votre
        puissance et votre niveau de raccordement — suffisent à vous ranger dans l’un des trois
        régimes ci-dessous, que votre installation soit neuve ou déjà en place. Voici comment vous
        situer, sans jargon.
      </p>

      <!-- W259 — « Où en est la loi ? » : distingue LIVE (MT/HT) de PENDING (BT résidentiel). -->
      <div class="v2-rise mt-10 border-2 border-brass-400/50 bg-nuit-800/60 p-6 sm:p-8">
        <p class="tech-label v2-kicker text-brass-300">Où en est la loi ? · vérifié le 3 juillet 2026</p>
        <div class="mt-4 grid gap-5 sm:grid-cols-2">
          <div>
            <p class="tech-label text-lune">En vigueur</p>
            <p class="mt-2 text-sm leading-relaxed text-lune-soft">
              Décret <strong class="text-white">2-25-100</strong> (BO du 9 mars 2026, en vigueur depuis
              le 9 juin 2026) et décision ANRE <strong class="text-white">04/26</strong> :
              <strong class="text-white">0,18–0,21 DH/kWh</strong> de rachat du surplus, mais seulement
              pour les régimes accord de raccordement et autorisation, en
              <strong class="text-white"> moyenne et haute tension (MT/HT)</strong>.
            </p>
          </div>
          <div>
            <p class="tech-label text-lune">Pas encore publié</p>
            <p class="mt-2 text-sm leading-relaxed text-lune-soft">
              Le tarif de rachat du régime <strong class="text-white">déclaration en basse tension
              (BT)</strong> — celui de la quasi-totalité des villas — n'est pas encore publié, avec une
              échéance évoquée autour de <strong class="text-white">2027</strong>, non confirmée à ce
              jour.
            </p>
          </div>
        </div>
        <p class="mt-5 text-xs leading-relaxed text-lune-faint">
          Une installation déjà posée ? La fenêtre de régularisation de l'Article 33 est ouverte dès
          aujourd'hui, indépendamment de ce tarif —
          <a href="/regularization-article-33" class="border-b border-brass-300/60 pb-0.5 font-semibold text-brass-300 transition-colors hover:text-brass-200">faites régulariser votre installation existante →</a>.
        </p>
      </div>

      <div class="mt-12 grid gap-6" data-stagger>
        {regimes.map((r, i) => (
          <div class="v2-rise cine-card grid gap-4 p-6 sm:grid-cols-[auto_1fr] sm:p-7" style={`--v2-i:${i}`}>
            <span class="fig lum text-4xl" aria-hidden="true">{r.n}</span>
            <div>
              <h2 class="display text-xl text-white">{r.title}</h2>
              <p class="mt-2 text-sm leading-relaxed text-lune-soft">{r.body}</p>
            </div>
          </div>
        ))}
      </div>

      <h2 class="display v2-section-title mt-14 text-white">Et si mon installation existe déjà ?</h2>
      <p class="v2-lead mt-5 text-lune-soft">
        La loi n’oublie pas les installations posées avant elle. Son Article 33 ouvre, depuis le
        9 juin 2026, une fenêtre de 18 mois pour les mettre en règle : c’est le délai dont vous
        disposez pour déposer le dossier qui manque — déclaration, accord de raccordement ou
        autorisation, selon le régime qui vous concerne ci-dessus. Régularisée dans ce délai, une
        installation existante rejoint le cadre légal comme une neuve. Passé la fenêtre, elle reste
        en situation irrégulière au regard de la loi 82-21, avec les sanctions que cela suppose. Il
        n’y a donc rien à gagner à attendre, et la démarche se lance dès aujourd’hui.
      </p>
      <RelatedLinks mt="mt-8" links={[
        { href: '/loi-82-21', label: 'Identifier mon régime en 3 questions' },
        { href: '/regularization-article-33', label: 'Régulariser mon installation' },
        { href: '/guides', label: 'Tous les guides' },
      ]} />
    </article>

    <!-- W297 — FAQ visuelle : schema={false}, /faq garde le seul FAQPage du site -->
    <Faq items={faq} heading="Loi 82-21 — questions fréquentes" schema={false} />

    <CtaBand title="Un doute sur votre régime ? Nous vérifions gratuitement." buttonLabel="Faire vérifier mon dossier" href="/devis/mon-toit" />

    <StickyCta />
  </div>
</Layout>
