---
/**
 * Hub Guides & ressources (W6). Explique des sujets DÉJÀ documentés sur le
 * site, en langage clair. AUCUN chiffre nouveau, AUCUN claim tarif/coût (la
 * base tarifaire du site est alignée séparément). Calendrier éditorial et
 * articles tarif/coût en attente (copie Meryem + alignement tarifaire).
 */
import Layout from '../../layouts/Layout.astro';
import V2Enhance from '../../components/V2Enhance.astro';
import Article33Ribbon from '../../components/Article33Ribbon.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CtaBand from '../../components/CtaBand.astro';
import StickyCta from '../../components/StickyCta.astro';

const guides = [
  {
    href: '/guides/loi-82-21-expliquee',
    title: 'Loi 82-21 expliquée simplement',
    summary: 'Les trois régimes de l’autoproduction — déclaration, accord de raccordement, autorisation — en clair, et à quel cas vous appartenez.',
  },
  {
    href: '/guides/faut-il-des-batteries',
    title: 'Faut-il des batteries ?',
    summary: 'Autoconsommation diurne ou stockage : comment se décide la présence de batteries dans une installation, et pourquoi c’est l’étude qui tranche.',
  },
  {
    href: '/guides/onduleur-hybride-ou-reseau',
    title: 'Onduleur hybride ou onduleur réseau ?',
    summary: 'Deye hybride ou Huawei réseau : la différence tient à une question simple — stockez-vous l’énergie, oui ou non ?',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Guides & ressources solaires — Taqinor',
  hasPart: guides.map((g) => ({ '@type': 'Article', headline: g.title, url: new URL(g.href, Astro.site).href })),
};
---

<Layout
  title="Guides & ressources solaires au Maroc | Taqinor"
  description="Des explications claires et sans jargon sur le solaire au Maroc : loi 82-21 et ses régimes, batteries ou non, onduleur hybride ou réseau. Construites à partir de ce que le site documente déjà."
  ogSlug="accueil"
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <div class="v2">
    <V2Enhance />
    <Article33Ribbon />

    <Breadcrumb items={[{ label: 'Accueil', href: '/' }, { label: 'Guides' }]} />

    <section class="px-4 pb-10 pt-16 text-white sm:pt-20">
      <div class="mx-auto max-w-3xl">
        <p class="tech-label v2-kicker rule-brass cine-in text-brass-300">Guides & ressources</p>
        <h1 class="display v2-page-title cine-in mt-5 [animation-delay:120ms]">Comprendre avant de se lancer</h1>
        <p class="v2-lead cine-in mt-6 max-w-xl text-white/85 [animation-delay:240ms]">
          Des explications claires, sans jargon, construites à partir de ce que nous documentons
          déjà sur le site. Pas de promesses chiffrées : seulement de quoi décider en connaissance
          de cause.
        </p>
      </div>
    </section>

    <section class="px-4 pb-24 sm:pb-32">
      <div class="mx-auto grid max-w-6xl gap-6 md:grid-cols-3" data-stagger>
        {guides.map((g, i) => (
          <a href={g.href} class="v2-rise cine-card flex flex-col p-7" style={`--v2-i:${i}`}>
            <p class="tech-label text-brass-300">Guide</p>
            <h2 class="display mt-2 text-xl text-white">{g.title}</h2>
            <p class="mt-3 flex-1 text-sm leading-relaxed text-lune-soft">{g.summary}</p>
            <span class="mt-5 inline-block border-b-2 border-brass-400 pb-0.5 text-sm font-bold text-white">Lire le guide →</span>
          </a>
        ))}
      </div>
    </section>

    <CtaBand title="Une question que les guides ne couvrent pas ? L’étude est gratuite." href="/contact#simulateur" />

    <StickyCta />
  </div>
</Layout>
