---
/**
 * Article de blog (W132) — route dynamique sur les articles PUBLIÉS.
 *
 * W195 — prose partagée (src/styles/prose.css) appliquée via classe .prose.
 * W196 — mesure de lecture 68ch (max-w-[68ch] sur .prose-body).
 * W197 — temps de lecture estimé + table des matières automatique (h2/h3).
 * W198 — champ cover optionnel (content.config.ts) ; fallback si absent.
 * W200 — RelatedLinks component pour les liens internes en pied d'article.
 *
 * Le rendu Markdown passe par l'API `render()` des content collections ; les
 * JSON-LD BlogPosting + BreadcrumbList sont construits ICI à partir du
 * frontmatter, pour que les fichiers .md ne portent que frontmatter + corps.
 * Canonique auto-référencé : émis par le Layout via l'URL de la page. L'image
 * OG vient de `ogSlug` (repli 'accueil'). Liens précédent/suivant + articles
 * liés (par tag partagé) en pied d'article.
 */
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import V2Enhance from '../../components/V2Enhance.astro';
import Article33Ribbon from '../../components/Article33Ribbon.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CtaBand from '../../components/CtaBand.astro';
import StickyCta from '../../components/StickyCta.astro';
import RelatedLinks from '../../components/RelatedLinks.astro';
import { NAP } from '../../lib/nap';
import { estimateReadingTime, extractTocFromMarkdown } from '../../lib/readingTime';
import '../../styles/prose.css';

export async function getStaticPaths() {
  const posts = (
    await getCollection('blog', ({ data }) => (import.meta.env.PROD ? !data.draft && data.pubDate.getTime() <= Date.now() : true))
  ).sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

  return posts.map((post, i) => ({
    params: { slug: post.id },
    props: {
      post,
      prev: posts[i - 1] ?? null,
      next: posts[i + 1] ?? null,
      // Articles liés : autres publiés partageant au moins un tag (max 3).
      related: posts
        .filter((p) => p.id !== post.id && p.data.tags.some((t) => post.data.tags.includes(t)))
        .slice(0, 3),
    },
  }));
}

const { post, prev, next, related } = Astro.props;
const { data, body } = post;
const { Content } = await render(post);

const dateFmt = new Intl.DateTimeFormat('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });
const url = new URL(`/blog/${post.id}`, Astro.site).href;

// W197 — temps de lecture + TOC
const readingMinutes = estimateReadingTime(body ?? '');
const toc = extractTocFromMarkdown(body ?? '');
const showToc = toc.length >= 3;

// W291 — image OG déjà calculée par le Layout (ogSlug ?? 'accueil' → /og/<slug>.png) ;
// on reproduit ici la même URL pour l'exposer au BlogPosting, Google recommandant
// explicitement `image` pour l'éligibilité aux rich results Article.
const schemaImageUrl = new URL(`/og/${data.ogSlug ?? 'accueil'}.png`, Astro.site).href;

const blogPosting = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: data.title,
  description: data.description,
  image: schemaImageUrl,
  datePublished: data.pubDate.toISOString(),
  ...(data.updatedDate ? { dateModified: data.updatedDate.toISOString() } : {}),
  ...(data.tags.length ? { keywords: data.tags.join(', ') } : {}),
  author: { '@type': 'Person', name: data.author || NAP.name },
  publisher: { '@type': 'Organization', name: NAP.name, url: NAP.url },
  mainEntityOfPage: { '@type': 'WebPage', '@id': url },
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: new URL('/', Astro.site).href },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: new URL('/blog', Astro.site).href },
    { '@type': 'ListItem', position: 3, name: data.title },
  ],
};
---

<Layout
  title={`${data.title} | Blog Taqinor`}
  description={data.description}
  ogSlug={data.ogSlug ?? 'accueil'}
>
  <script type="application/ld+json" set:html={JSON.stringify(blogPosting)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
  {/* W376 — reading progress bar (see global.css .reading-bar) */}
  <div class="reading-bar" aria-hidden="true"></div>
  <div class="v2">
    <V2Enhance />
    <Article33Ribbon />

    <Breadcrumb items={[{ label: 'Accueil', href: '/' }, { label: 'Blog', href: '/blog' }, { label: data.title }]} />

    <article class="mx-auto max-w-[68ch] px-4 pb-24 pt-12 sm:pb-28">

      {/* W198 — couverture optionnelle */}
      {data.cover && (
        <figure class="article-cover mb-8 -mx-4 sm:mx-0 sm:rounded overflow-hidden">
          <img
            src={data.cover}
            alt={data.title}
            class="w-full h-48 sm:h-64 object-cover"
            loading="eager"
            decoding="async"
          />
        </figure>
      )}

      <p class="tech-label v2-kicker rule-brass text-brass-300">
        Blog · {dateFmt.format(data.pubDate)}
        {data.author && <> · par {data.author}</>}
        {data.updatedDate && <> · mis à jour le {dateFmt.format(data.updatedDate)}</>}
      </p>
      <h1 class="display v2-page-title mt-5 text-white">{data.title}</h1>

      {/* W197 — temps de lecture */}
      <p class="article-meta mt-3 flex items-center gap-2 text-xs text-lune-faint" aria-label={`Temps de lecture estimé : ${readingMinutes} minute${readingMinutes > 1 ? 's' : ''}`}>
        <svg aria-hidden="true" focusable="false" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
        </svg>
        {readingMinutes} min de lecture
      </p>

      <p class="prose-lead mt-5">{data.description}</p>

      {data.tags.length > 0 && (
        <ul class="mt-4 flex flex-wrap gap-2" aria-label="Étiquettes">
          {data.tags.map((tag) => (
            <li class="border border-white/20 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-lune-soft">{tag}</li>
          ))}
        </ul>
      )}

      {/* W197 — table des matières auto (affiché seulement si ≥ 3 titres h2/h3) */}
      {showToc && (
        <nav class="toc mt-8 border border-white/10 p-4" aria-label="Sommaire de l'article">
          <p class="tech-label mb-3 text-brass-300">Sommaire</p>
          <ol class="toc__list">
            {toc.map((entry) => (
              <li class:list={['toc__item', entry.level === 3 && 'toc__item--sub']}>
                <a href={`#${entry.id}`} class="toc__link">{entry.text}</a>
              </li>
            ))}
          </ol>
        </nav>
      )}

      <div class="prose mt-10">
        <Content />
      </div>

      {(prev || next) && (
        <nav class="mt-14 grid gap-3 border-t border-white/10 pt-8 sm:grid-cols-2" aria-label="Navigation entre articles">
          {prev ? (
            <a href={`/blog/${prev.id}`} class="border border-white/20 p-4 transition-colors hover:border-white hover:bg-white/5">
              <span class="tech-label text-brass-300">← Plus récent</span>
              <span class="mt-1 block font-semibold text-white">{prev.data.title}</span>
            </a>
          ) : <span></span>}
          {next ? (
            <a href={`/blog/${next.id}`} class="border border-white/20 p-4 text-right transition-colors hover:border-white hover:bg-white/5 sm:text-right">
              <span class="tech-label text-brass-300">Plus ancien →</span>
              <span class="mt-1 block font-semibold text-white">{next.data.title}</span>
            </a>
          ) : <span></span>}
        </nav>
      )}

      {related.length > 0 && (
        <section class="mt-12" aria-label="Articles liés">
          <p class="tech-label text-brass-300">À lire aussi</p>
          <ul class="mt-3 flex flex-col gap-2">
            {related.map((r) => (
              <li>
                <a href={`/blog/${r.id}`} class="border-b border-white/20 pb-0.5 text-sm font-bold text-white transition-colors hover:border-brass-400">{r.data.title} →</a>
              </li>
            ))}
          </ul>
        </section>
      )}

      <RelatedLinks
        links={[
          { href: '/blog', label: 'Tous les articles' },
          { href: '/guides', label: 'Les guides pérennes' },
        ]}
      />
    </article>

    <CtaBand title="Un projet en tête ? Lancez l'étude gratuite." href="/devis/mon-toit" />

    <StickyCta />
  </div>
</Layout>

<style>
  /* W197 — table des matières */
  .toc__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .toc__item {
    margin: 0;
  }

  .toc__item--sub {
    padding-left: 1rem;
  }

  .toc__link {
    font-size: 0.875rem;
    color: var(--color-lune-soft, #adb5cd);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .toc__link:hover,
  .toc__link:focus-visible {
    color: var(--color-brass-300, #f3cc66);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .toc__link:focus-visible {
    outline: 2px solid var(--color-brass-300, #f3cc66);
    outline-offset: 2px;
  }

  /* W198 — couverture */
  .article-cover {
    border: 1px solid rgb(255 255 255 / 0.08);
  }

  /* article-meta */
  .article-meta {
    font-family: var(--font-sans, inherit);
  }
</style>
