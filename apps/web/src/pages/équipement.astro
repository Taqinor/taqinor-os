---
import Layout from '../layouts/Layout.astro';
import Article33Ribbon from '../components/Article33Ribbon.astro';
import CtaBand from '../components/CtaBand.astro';
import Picture from '../components/Picture.astro';

// Honnêteté de marque : uniquement ce qui est réellement stocké et posé.
// PLACEHOLDER(REDA): marques et gammes de panneaux à confirmer par l'équipe —
// la section panneaux reste volontairement générique d'ici là.
const categories = [
  {
    ref: 'OND-H',
    title: 'Onduleurs hybrides — Deye',
    body: 'Onduleurs hybrides monophasés et triphasés Deye, du résidentiel (3 à 12 kW) au petit tertiaire. Gestion batterie intégrée, suivi de production en ligne.',
    points: ['Monophasé et triphasé', 'Compatibles batteries basse et haute tension', 'Monitoring inclus'],
  },
  {
    ref: 'OND-R',
    title: 'Onduleurs réseau — Solis',
    body: 'Onduleurs string Solis pour l’autoconsommation sans stockage, du résidentiel aux toitures industrielles.',
    points: ['Gammes résidentielles et commerciales', 'Rendement européen élevé', 'Suivi de production en ligne'],
  },
  {
    ref: 'BAT',
    title: 'Batteries — Dyness',
    body: 'Batteries lithium fer phosphate (LFP) Dyness, montées en armoire ou en rack. Dimensionnées pour la consommation nocturne ou la continuité de service.',
    points: ['Chimie LFP éprouvée', 'Extensibles par modules', 'Garantie constructeur longue durée'],
  },
  {
    ref: 'PV',
    title: 'Panneaux photovoltaïques',
    body: 'Modules monocristallins de fabricants Tier 1, 550 à 620 Wc, garantis en performance sur 25 ans. Les marques en stock varient selon les arrivages — demandez la fiche technique du moment.',
    points: ['Garantie de performance 25 ans', 'Modules 550 – 620 Wc', 'Fiches techniques fournies avec chaque devis'],
  },
];
---

<Layout
  title="Équipement solaire en stock : Deye, Solis, Dyness | Taqinor"
  description="Le matériel que Taqinor stocke et installe réellement : onduleurs hybrides Deye, onduleurs réseau Solis, batteries LFP Dyness, panneaux Tier 1 garantis 25 ans."
  ogSlug="equipement"
>
  <Article33Ribbon />

  <section class="grid-paper-dark bg-night px-4 py-16 text-paper sm:py-20">
    <div class="mx-auto max-w-6xl">
      <p class="tech-label rule-amber text-amber-400">Stock réel · références courtes</p>
      <h1 class="display mt-4 max-w-2xl text-4xl sm:text-5xl">Ce que nous stockons, ce que nous posons</h1>
      <p class="mt-5 max-w-xl leading-relaxed text-paper/85">
        Pas de catalogue infini : une sélection courte de matériel que nous connaissons,
        stockons et garantissons. Chaque référence est choisie pour sa fiabilité mesurée et la
        disponibilité de ses pièces au Maroc.
      </p>
    </div>
  </section>

  <!-- Photos matériel -->
  <section class="mx-auto max-w-6xl px-4 pt-12">
    <div class="grid gap-4 sm:grid-cols-[1.4fr_1fr]">
      <figure class="reveal overflow-hidden border border-ink/15">
        <Picture
          name="mur-technique-dyness"
          alt="Mur technique d'une installation Taqinor : onduleur hybride, deux batteries Dyness et borne de recharge"
          widths={[1600, 1024, 640]}
          ratio={4 / 3}
          sizes="(min-width: 640px) 58vw, 100vw"
          loading="eager"
          class="w-full object-cover"
        />
        <figcaption class="tech-label bg-paper px-3 py-2.5 text-ink-faint">Onduleur hybride · 2 batteries Dyness · borne de recharge</figcaption>
      </figure>
      <figure class="reveal overflow-hidden border border-ink/15">
        <Picture
          name="silhouette-acrotere"
          alt="Panneau photovoltaïque et chauffe-eau solaire sur acrotère blanc contre un ciel bleu profond"
          widths={[1600, 1024, 640]}
          ratio={4 / 3}
          sizes="(min-width: 640px) 40vw, 100vw"
          loading="eager"
          class="h-full w-full object-cover"
        />
        <figcaption class="tech-label bg-paper px-3 py-2.5 text-ink-faint">Modules + chauffe-eau · installation réelle</figcaption>
      </figure>
    </div>
  </section>

  <!-- Fiches matériel -->
  <section class="mx-auto max-w-6xl px-4 py-12">
    <div class="grid gap-6 md:grid-cols-2">
      {categories.map((c) => (
        <div class="reveal border border-ink/15 bg-paper">
          <div class="flex items-center justify-between border-b border-ink/15 px-6 py-3">
            <span class="tech-label text-ink-faint">Réf. {c.ref}</span>
            <span class="h-1.5 w-1.5 rounded-full bg-amber-400" aria-hidden="true"></span>
          </div>
          <div class="p-6">
            <h2 class="display text-xl">{c.title}</h2>
            <p class="mt-3 text-sm leading-relaxed text-ink-soft">{c.body}</p>
            <ul class="mt-4 space-y-2 text-sm">
              {c.points.map((p) => (
                <li class="flex gap-2.5"><span class="font-mono font-medium text-amber-500" aria-hidden="true">+</span><span>{p}</span></li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>
    <p class="mx-auto mt-8 max-w-xl border-l-2 border-amber-400 pl-4 text-sm leading-relaxed text-ink-soft">
      Le choix final du matériel dépend du dimensionnement : c'est l'étude qui détermine
      l'équipement, jamais l'inverse.
    </p>
  </section>

  <CtaBand title="Le bon matériel, c'est celui que l'étude justifie." />
</Layout>
