---
/**
 * Page publique — élévation « élégance retenue » : typographie éditoriale,
 * révélations au défilement, chiffres count-up, parallaxe d'en-tête (desktop)
 * + mouvement photo (Ken Burns d'en-tête, montée d'échelle au défilement).
 * Tout le mouvement est désactivé sous prefers-reduced-motion. Le diagnostic
 * et son flux de données restent inchangés (composant partagé DiagnosticForm).
 * Voir apps/web/DESIGN_RATIONALE.md.
 */
import Layout from '../layouts/Layout.astro';
import V2Enhance from '../components/V2Enhance.astro';
import Article33Ribbon from '../components/Article33Ribbon.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import CtaBand from '../components/CtaBand.astro';
import Picture from '../components/Picture.astro';
import StickyCta from '../components/StickyCta.astro';

const categories = [
  { ref: 'PV-1', title: 'Panneaux — Canadian Solar TOPBiHiKu', body: "Le bifacial capte aussi la lumière réfléchie par le toit : sur une terrasse claire, c'est du rendement gagné sans surface en plus. Ces modules 705 à 720 Wc sortent d'un constructeur qui a livré plus de 100 GW dans le monde, tenus aux normes IEC 61215 et IEC 61730. Ce sont eux qui équipent Casablanca et El Jadida.", points: ['Bifacial 705 – 720 Wc', 'Garantie produit 12 ans', 'Garantie performance 25 ans (≥ 84,8 %)'] },
  { ref: 'PV-2', title: 'Panneaux — JA Solar DeepBlue', body: "La cellule monocristalline DeepBlue va chercher le rendement plutôt que la surface — utile quand la toiture est comptée. Même rang de fabricant, même exigence de certification. Posés à Nouaceur.", points: ['Monocristallin haut rendement', 'Garantie produit 12 ans', 'Garantie performance 25 ans'] },
  { ref: 'OND-1', title: 'Onduleurs hybrides — Deye', body: "L'onduleur hybride est le chef d'orchestre : il arbitre en temps réel entre panneaux, batterie et réseau. Les gammes Deye SUN-SG04LP1, SG04LP3 et SG01HP3 couvrent 5 à 30 kW, en mono comme en triphasé, et dialoguent directement avec le BMS de la batterie via CAN. Conformes CEI 61727 et VDE-AR-N-4105.", points: ['Monophasé et triphasé, 5 – 30 kW', 'Gestion batterie CAN BMS intégrée', 'Garantie 10 ans'] },
  { ref: 'OND-2', title: 'Onduleurs réseau — Huawei SUN2000', body: "Quand l'étude ne retient pas de batterie, on passe sur du string pur. Le Huawei SUN2000 optimise chaîne par chaîne : un panneau à l'ombre ne tire plus toute la rangée vers le bas. Du résidentiel à la toiture tertiaire.", points: ['Rendement européen élevé', 'Optimisation par chaîne', 'Garantie 10 ans'] },
  { ref: 'BAT', title: 'Batteries — Dyness DL5.0C', body: "Le lithium-fer-phosphate ne s'emballe pas thermiquement comme d'autres chimies lithium : c'est le choix de la sûreté pour du stockage chez soi. Les modules DL5.0C / DL5.0C PRO s'empilent par tranches de 5 kWh et parlent nativement le CAN BMS des Deye. Certifiés CE, IEC 62619, UN38.3.", points: ['Chimie LFP — 6 000+ cycles à 90 % DoD', 'Modulaire : 5 à 15 kWh et plus', 'Garantie 10 ans'] },
  { ref: 'MON', title: 'Monitoring — Deye Cloud', body: "Une installation qu'on ne mesure pas est une installation qu'on croit sur parole. Chaque toiture porte un dongle WiFi/Ethernet relié à Deye Cloud : production à la minute, historiques, alertes. Vous gardez votre accès personnel ; de notre côté, nous voyons tout le parc et intervenons avant que vous n'ayez constaté la panne.", points: ['Production mesurée en continu', 'Alertes automatiques — SAV proactif', 'Accès client via application mobile'] },
];

const warranties = [
  { item: 'Panneaux photovoltaïques (produit)', years: '12 ans' },
  { item: 'Panneaux photovoltaïques (performance)', years: '25 ans', note: '≥ 84,8 % de la puissance initiale' },
  { item: 'Onduleurs (Deye, Huawei)', years: '10 ans' },
  { item: 'Batteries Dyness LFP', years: '10 ans' },
  { item: 'Structure acier galvanisé', years: '20 ans' },
  { item: 'Installation et main-d’œuvre Taqinor', years: '2 ans' },
];
---

<Layout
  title="Le matériel posé : Canadian Solar, Deye, Huawei, Dyness — et pourquoi | Taqinor"
  description="Panneaux bifaciaux Canadian Solar (25 ans de performance), onduleurs hybrides Deye, batteries Dyness LFP 6 000 cycles, supervision Deye Cloud : le matériel réellement posé chez nous, et la raison technique de chaque choix."
  ogSlug="equipement"
>
  <div class="v2">
    <V2Enhance />
    <Article33Ribbon />

    <Breadcrumb items={[{ label: 'Accueil', href: '/' }, { label: 'Équipement' }]} />

    <section class="px-4 py-20 text-white sm:py-28">
      <div class="mx-auto max-w-6xl">
        <p class="tech-label v2-kicker rule-brass cine-in text-brass-300">Marques tier-1 · distributeurs officiels au Maroc</p>
        <h1 class="display v2-page-title cine-in mt-5 max-w-3xl [animation-delay:120ms]">Nos marques tier-1, et la raison technique de chacune</h1>
        <p class="v2-lead cine-in mt-6 max-w-xl text-white/85 [animation-delay:240ms]">
          Canadian Solar, JA Solar et Jinko côté panneaux ; Deye et Huawei côté onduleurs ;
          Dyness pour le stockage ; Nexans pour le câblage : voilà ce qui est vissé sur nos
          toitures de 2026, rien d'autre. Aucune référence sans nom, aucun catalogue à rallonge.
          Tout passe par des distributeurs officiels installés au Maroc — la pièce est en stock
          ici, et la garantie se fait jouer ici, pas à l'autre bout d'un mail.
        </p>
      </div>
    </section>

    <!-- Photos matériel — le geste autant que le matériel -->
    <section class="mx-auto max-w-6xl px-4 pt-8">
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-[1.3fr_1fr_1fr]" data-stagger>
        <figure class="v2-rise cine-card group relative overflow-hidden" style="--v2-i:0">
          <Picture name="mur-technique-dyness" alt="Mur technique d'une installation Taqinor à Casablanca : onduleur hybride Deye, deux batteries Dyness et borne de recharge"
            widths={[1600, 1024, 640]} ratio={4 / 3} sizes="(min-width: 1024px) 40vw, (min-width: 640px) 50vw, 100vw" loading="eager"
            class="w-full object-cover transition-transform duration-700 group-hover:scale-[1.04]" />
          <figcaption class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-nuit/95 to-transparent px-4 pb-3 pt-12">
            <span class="tech-label block text-brass-300">Casablanca · 11,36 kWc</span>
            <span class="mt-0.5 block text-xs text-lune">Onduleur hybride Deye 10 kW · 2 × Dyness DL5.0C · borne de recharge</span>
          </figcaption>
        </figure>
        <figure class="v2-rise cine-card group relative overflow-hidden" style="--v2-i:1">
          <Picture name="detail-cablage" alt="Gros plan sur les bornes des batteries Dyness et le coffret de protections, câblage soigné, El Jadida"
            widths={[1600, 1024, 640]} ratio={4 / 3} sizes="(min-width: 1024px) 30vw, (min-width: 640px) 50vw, 100vw" loading="eager"
            class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-[1.04]" />
          <figcaption class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-nuit/95 to-transparent px-4 pb-3 pt-12">
            <span class="tech-label block text-brass-300">El Jadida · 17,04 kWc</span>
            <span class="mt-0.5 block text-xs text-lune">Bornes batteries + coffret de protections · le soin du détail</span>
          </figcaption>
        </figure>
        <figure class="v2-rise cine-card group relative overflow-hidden" style="--v2-i:2">
          <Picture name="silhouette-acrotere" alt="Panneau photovoltaïque et chauffe-eau solaire sur acrotère blanc contre un ciel bleu profond"
            widths={[1600, 1024, 640]} ratio={4 / 3} sizes="(min-width: 1024px) 30vw, (min-width: 640px) 50vw, 100vw" loading="eager"
            class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-[1.04]" />
          <figcaption class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-nuit/95 to-transparent px-4 pb-3 pt-12">
            <span class="tech-label block text-brass-300">Détail de toiture</span>
            <span class="mt-0.5 block text-xs text-lune">Modules PV + chauffe-eau solaire</span>
          </figcaption>
        </figure>
      </div>
    </section>

    <!-- Fiches matériel -->
    <section class="mx-auto max-w-6xl px-4 py-16">
      <div class="grid gap-6 md:grid-cols-2" data-stagger>
        {categories.map((c, i) => (
          <div class="v2-rise cine-card" style={`--v2-i:${i}`}>
            <div class="flex items-center justify-between border-b-2 border-brass-400/70 px-6 py-3">
              <span class="tech-label text-brass-300">Réf. {c.ref}</span>
              <span class="h-1.5 w-1.5 rotate-45 border border-brass-400" aria-hidden="true"></span>
            </div>
            <div class="p-6">
              <h2 class="display text-xl text-white">{c.title}</h2>
              <p class="mt-3 text-sm leading-relaxed text-lune-soft">{c.body}</p>
              <ul class="mt-4 space-y-2 text-sm text-lune">
                {c.points.map((p) => (
                  <li class="flex gap-2.5"><span class="mt-1.5 inline-block h-1.5 w-1.5 flex-none rotate-45 border border-brass-400" aria-hidden="true"></span><span>{p}</span></li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- ACTE FINAL — les garanties, littéralement noir sur blanc -->
    <div class="v2-seam" aria-hidden="true"></div>
    <section class="bg-blanc-azur px-4 pb-20 pt-10 text-encre sm:pb-28">
      <div class="mx-auto max-w-3xl">
        <p class="tech-label v2-kicker rule-brass text-azur-600">Engagements contractuels</p>
        <h2 class="display v2-section-title mt-5">Les garanties, noir sur blanc</h2>
        <p class="v2-lead mt-4 text-encre-soft">
          Une garantie ne vaut que par le dossier qui la documente. Chaque installation repart
          avec le sien, complet : schémas unifilaires, calcul de section des câbles, liste des
          protections, procédure de mise en service et l'accès Deye Cloud pour vérifier la
          production vous-même.
        </p>
        <div class="mt-10 border-t-2 border-azur-900 bg-blanc" data-stagger>
          {warranties.map((w, i) => (
            <div class="v2-rise flex items-baseline justify-between gap-4 border-b border-azur-900/15 px-5 py-4" style={`--v2-i:${i}`}>
              <span class="text-sm font-semibold">{w.item}{w.note && <span class="block text-xs font-normal text-encre-faint">{w.note}</span>}</span>
              <span class="fig whitespace-nowrap text-2xl text-azur-600" data-tally>{w.years}</span>
            </div>
          ))}
        </div>
        <p class="mx-auto mt-6 max-w-xl border-l-4 border-azur-600 pl-4 text-sm leading-relaxed text-encre-soft">
          Aucune de ces références n'est choisie d'avance. La puissance retenue, la présence ou
          non d'une batterie, le mono ou le triphasé : tout sort des chiffres de votre toiture.
          Le matériel suit le calcul — il ne le précède pas.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/garanties" class="border border-azur-900/25 px-5 py-3 text-sm font-bold text-encre transition-colors hover:border-azur-600 hover:text-azur-600">Nos garanties →</a>
          <a href="/résidentiel" class="border border-azur-900/25 px-5 py-3 text-sm font-bold text-encre transition-colors hover:border-azur-600 hover:text-azur-600">Solaire résidentiel →</a>
          <a href="/professionnel" class="border border-azur-900/25 px-5 py-3 text-sm font-bold text-encre transition-colors hover:border-azur-600 hover:text-azur-600">Solaire professionnel →</a>
        </div>
      </div>
    </section>

    <CtaBand title="Le bon matériel, c'est celui que l'étude justifie." seam={false} />

    <StickyCta />
  </div>
</Layout>
