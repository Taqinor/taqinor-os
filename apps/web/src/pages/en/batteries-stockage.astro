---
/**
 * EN — Batteries & storage (W67). Faithful translation of /batteries-stockage ;
 * EVERY spec/figure (6 000 cycles, 90 % DoD, 5 kWh modules, 5–15 kWh, CE/IEC
 * 62619/UN38.3, 10 years, 15/10/5 kWh installs, refs 468/400/236) kept EXACT.
 * No invented capacity/price/spec. Internal links via localizeNavHref. FR
 * untouched.
 */
import Layout from '../../layouts/Layout.astro';
import V2Enhance from '../../components/V2Enhance.astro';
import Article33Ribbon from '../../components/Article33Ribbon.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CtaBand from '../../components/CtaBand.astro';
import StickyCta from '../../components/StickyCta.astro';
import { getLocaleFromPath } from '../../i18n/utils';
import { localizeNavHref } from '../../i18n/pages';

const locale = getLocaleFromPath(Astro.url.pathname);
const L = (href: string) => localizeNavHref(href, locale);
const contactSim = L('/contact') + '#simulateur';

const specs = [
  { item: 'Lithium-iron-phosphate (LFP) chemistry', detail: 'Dyness DL5.0C / DL5.0C PRO' },
  { item: 'Lifespan', detail: '6 000+ cycles at 90 % depth of discharge (DoD)' },
  { item: 'Modular capacity', detail: 'Expandable 5 kWh modules: 5 to 15 kWh and more' },
  { item: 'Communication', detail: 'Native CAN BMS with Deye hybrid inverters' },
  { item: 'Certifications', detail: 'CE · IEC 62619 · UN38.3' },
  { item: 'Warranty', detail: '10 ans' },
];

const cas = [
  {
    k: 'Without storage',
    title: 'Mostly daytime consumption',
    body: 'When most of your consumption falls during the day, the best kWh is the one your panels feed at that very moment — without a detour through a battery, without charge or discharge losses. That is the case for households active by day and sites whose activity follows the sun: pump, refrigeration, machines, air conditioning.',
  },
  {
    k: 'With storage',
    title: 'Night-time consumption or service continuity',
    body: 'The battery becomes useful when your consumption peak comes once the sun has set, or when an outage must stop nothing. The surplus produced at midday is set aside and returned in the evening, at the hour when the grid bills at the high rate.',
  },
];

const installs = [
  { kwh: '15 kWh', where: 'El Jadida', ref: '468' },
  { kwh: '10 kWh', where: 'Casablanca', ref: '400' },
  { kwh: '5 kWh', where: 'El Jadida', ref: '236' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Batteries & storage',
  serviceType: 'Solar energy storage',
  description: 'Solar storage in Morocco: Dyness lithium-iron-phosphate (LFP) batteries, sized by the study according to the consumption profile — daytime self-consumption or service continuity.',
  provider: { '@type': 'Organization', name: 'Taqinor', url: 'https://taqinor.ma' },
  areaServed: { '@type': 'Country', name: 'Maroc' },
};
---

<Layout
  title="Dyness LFP solar batteries in Morocco: 6 000 cycles, 90 % DoD | Taqinor"
  description="Solar storage in Morocco: Dyness lithium-iron-phosphate batteries, more than 6 000 cycles at 90 % depth of discharge, expandable 5 kWh modules, native CAN BMS dialogue with Deye hybrid inverters, 10-year warranty. The question is whether your consumption profile justifies a battery — often, by day, it doesn't."
  ogSlug="equipement"
>
  <div class="v2">
    <V2Enhance />
    <Article33Ribbon />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <Breadcrumb items={[{ label: 'Home', href: L('/') }, { label: 'Batteries & storage' }]} />

    <section class="px-4 pb-10 pt-16 text-white sm:pt-20">
      <div class="mx-auto max-w-3xl">
        <p class="tech-label v2-kicker rule-brass cine-in text-brass-300">Energy storage</p>
        <h1 class="display v2-page-title cine-in mt-5 [animation-delay:120ms]">Batteries &amp; storage</h1>
        <p class="v2-lead cine-in mt-6 max-w-xl text-white/85 [animation-delay:240ms]">
          A Dyness LFP battery takes more than 6 000 cycles at 90 % depth of discharge — enough to
          last for years. But it still has to be useful. The real question is not which battery, but
          <em>when</em> you consume: by day, the extra cost of a storage bank is rarely the best
          investment.
        </p>
      </div>
    </section>

    <!-- When storage is justified / when not -->
    <section class="px-4 pb-20 sm:pb-24">
      <div class="mx-auto max-w-6xl">
        <p class="tech-label v2-kicker rule-brass text-brass-300">The right trade-off</p>
        <h2 class="display v2-section-title mt-5 text-white">When a battery is justified — and when not</h2>
        <div class="mt-10 grid gap-6 md:grid-cols-2" data-stagger>
          {cas.map((c, i) => (
            <div class="v2-rise cine-card flex flex-col p-7" style={`--v2-i:${i}`}>
              <p class="tech-label text-brass-300">{c.k}</p>
              <h3 class="display mt-2 text-2xl text-white">{c.title}</h3>
              <p class="mt-3 flex-1 text-sm leading-relaxed text-lune-soft">{c.body}</p>
            </div>
          ))}
        </div>
        <p class="mt-8 max-w-2xl border-s-4 border-brass-400 ps-4 text-sm leading-relaxed text-lune-soft">
          Selling a battery is easy; saying it is useless less so. We first read your consumption
          curve, hour by hour: it is what says whether storage pays, and how many kWh are enough.
          Adding hardware is never the goal.
          <a href={L('/guides/faut-il-des-batteries')} class="border-b-2 border-brass-400 pb-0.5 font-bold text-brass-300 transition-colors hover:text-brass-200">Read the full guide →</a>
        </p>
      </div>
    </section>

    <!-- The storage hardware installed — Dyness LFP -->
    <div class="v2-seam" aria-hidden="true"></div>
    <section class="bg-blanc-azur px-4 pb-20 pt-10 text-encre sm:pb-28">
      <div class="mx-auto max-w-3xl">
        <p class="tech-label v2-kicker rule-brass text-azur-600">The hardware installed</p>
        <h2 class="display v2-section-title mt-5">Dyness lithium-iron-phosphate batteries</h2>
        <p class="v2-lead mt-4 text-encre-soft">
          When storage is justified, we install Dyness LFP batteries. Lithium-iron-phosphate
          chemistry does not run away thermally like some other lithiums and accepts being drained to
          90 % every cycle without ruining itself. The BMS talks over CAN with the Deye hybrid
          inverter, which manages charge and discharge precisely. Hardware sourced via official
          distributors in Morocco, warranty enforceable locally.
        </p>
        <div class="mt-10 border-t-2 border-azur-900 bg-blanc" data-stagger>
          {specs.map((s, i) => (
            <div class="v2-rise flex items-baseline justify-between gap-4 border-b border-azur-900/15 px-5 py-4" style={`--v2-i:${i}`}>
              <span class="text-sm font-semibold">{s.item}</span>
              <span class="whitespace-normal text-end text-sm text-azur-600">{s.detail}</span>
            </div>
          ))}
        </div>
        <p class="mx-auto mt-6 max-w-xl border-s-4 border-azur-600 ps-4 text-sm leading-relaxed text-encre-soft">
          The modules stack in 5 kWh increments: we set the capacity to the evening dip to cover, no
          more, no less. The size follows the figured need, not a commercial tier.
          <a href={L('/équipement')} class="border-b border-azur-600 pb-0.5 font-semibold text-azur-600 transition-colors hover:text-azur-700">See all the hardware installed →</a>
        </p>

        <!-- Real installations with storage -->
        <h3 class="display mt-14 text-xl">Storage already on our roofs</h3>
        <p class="mt-3 text-sm leading-relaxed text-encre-soft">
          From 5 kWh to 15 kWh: several households already run with Dyness batteries, each capacity
          set to the profile of the home that received it.
        </p>
        <div class="mt-6 grid gap-4 sm:grid-cols-3" data-stagger>
          {installs.map((inst, i) => (
            <div class="v2-rise border-s-2 border-azur-600 bg-blanc px-4 py-4" style={`--v2-i:${i}`}>
              <p class="fig whitespace-nowrap text-2xl text-azur-600" dir="ltr" data-tally>{inst.kwh}</p>
              <p class="tech-label mt-2 text-encre-faint">Dyness · {inst.where} · réf. {inst.ref}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Closing links -->
    <section class="px-4 py-20 sm:py-24">
      <div class="mx-auto max-w-6xl">
        <p class="tech-label v2-kicker rule-brass text-brass-300">To go further</p>
        <h2 class="display v2-section-title mt-5 text-white">Storage in your project</h2>
        <div class="mt-10 flex flex-wrap gap-3">
          <a href={L('/équipement')} class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">All the equipment →</a>
          <a href={L('/résidentiel')} class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">Residential solar →</a>
          <a href={L('/guides/faut-il-des-batteries')} class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">Guide: do you need batteries? →</a>
          <a href={L('/realisations')} class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">Our projects →</a>
        </div>
      </div>
    </section>

    <CtaBand title="Storage or not? Your consumption curve will say — free assessment." href={contactSim} />

    <StickyCta />
  </div>
</Layout>
