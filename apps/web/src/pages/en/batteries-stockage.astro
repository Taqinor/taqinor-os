---
/**
 * EN — Batteries & storage (W67). Faithful translation of /batteries-stockage ;
 * EVERY spec/figure (6,000 cycles at 90% DoD, 10-year warranty with ≥70%
 * capacity retained, 5 kWh modules, 5–15 kWh, CE/IEC 62619/UN38.3, 15/10/5 kWh
 * installs, refs 468/400/236) kept EXACT. DoD and end-of-life capacity are
 * distinct axes — never conflated. Visual FAQ (schema={false} so /faq stays the
 * only FAQPage) and the battery-guide cards mirror the FR. No invented
 * capacity/price/spec. Internal links via localizeNavHref. FR untouched.
 *
 * ELEVATION (W237) — mirrors /batteries-stockage.astro elevation treatment:
 *  - Eyebrows demoted from text-brass-300 to text-lune (brass discipline);
 *  - Card sub-labels demoted from text-brass-300 to text-lune;
 *  - Blockquote border: border-azur-200/50 (not brass); guide link text-azur-200;
 *  - Guide card hover: hover:border-azur-200/40 (not brass);
 *  - .section rhythm + .seam-soft seams; guide-links text-azur-200.
 */
import Layout from '../../layouts/Layout.astro';
import V2Enhance from '../../components/V2Enhance.astro';
import Article33Ribbon from '../../components/Article33Ribbon.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CtaBand from '../../components/CtaBand.astro';
import StickyCta from '../../components/StickyCta.astro';
import Faq from '../../components/Faq.astro';
import { getLocaleFromPath } from '../../i18n/utils';
import { localizeNavHref } from '../../i18n/pages';

const locale = getLocaleFromPath(Astro.url.pathname);
const L = (href: string) => localizeNavHref(href, locale);
const devisHref = L('/devis/mon-toit');

const specs = [
  { item: 'Lithium-iron-phosphate (LFP) chemistry', detail: 'Dyness DL5.0C / DL5.0C PRO' },
  { item: 'Lifespan', detail: '6,000 cycles at 90% depth of discharge' },
  { item: 'Modular capacity', detail: 'Expandable 5 kWh modules: 5 to 15 kWh and more' },
  { item: 'Communication', detail: 'Native CAN BMS with Deye hybrid inverters' },
  { item: 'Certifications', detail: 'CE · IEC 62619 · UN38.3' },
  { item: 'Warranty', detail: '10-year warranty with ≥ 70% capacity retained' },
];

const cas = [
  {
    k: 'Without storage',
    title: 'Mostly daytime consumption',
    body: "When most of your use falls during the day, the best kWh is the one your panels feed you on the spot — no detour through a battery, no charging and discharging losses. That fits households that are busy by day and sites whose activity follows the sun: a pump, refrigeration, machines, air conditioning.",
  },
  {
    k: 'With storage',
    title: 'Evening consumption or uninterrupted supply',
    body: "A battery earns its keep when your peak arrives after sunset, or when an outage must bring nothing to a halt. The surplus made at midday is set aside and given back in the evening — exactly the hour the grid charges its highest rate.",
  },
];

const installs = [
  { kwh: '15 kWh', where: 'El Jadida', ref: '468' },
  { kwh: '10 kWh', where: 'Casablanca', ref: '400' },
  { kwh: '5 kWh', where: 'El Jadida', ref: '236' },
];

// FAQ — schema={false} so /faq stays the only page carrying the FAQPage JSON-LD.
const faqItems = [
  {
    q: 'Do I really need a battery with my solar panels?',
    a: "Not necessarily. If you use most of your electricity during the day — refrigeration, a pump, air conditioning, machines — your panels feed your loads directly, and a battery would only add cost and conversion losses. It earns its place when your consumption peak falls in the evening, or when you need power to stay on through outages. We read your consumption curve hour by hour before recommending anything.",
  },
  {
    q: 'How long does an LFP battery last?',
    a: "On paper, a Dyness LFP battery takes 6,000 cycles at 90% depth of discharge, with a 10-year warranty and at least 70% of its capacity retained. Count one cycle a day and those 6,000 cycles alone span more than sixteen years. But a battery also ages while it sits — roughly 1 to 2% of capacity lost per year, even unused. It is this calendar ageing that usually decides matters in the end, bringing the real working life down to 12–15 years in the Moroccan climate. The way to claw back some of those years: keep the battery in the shade, ventilated, between 15 and 35 °C.",
  },
  {
    q: 'What battery size should I choose? (5–10 kWh, 10–20 kWh or 20 kWh+)',
    a: "The tiers map to distinct needs. 5 to 10 kWh: basic night-time backup, or keeping a few essentials running through an outage. 10 to 20 kWh: full evening self-consumption for an average household — the day's solar surplus covers most of the night-time load. 20 kWh and up: near-autonomy, remote sites, or 2 to 3 days of cover with no sun. Our Dyness modules stack in 5 kWh steps, so we set the capacity to the evening dip you need to cover, not to a marketing tier. A dedicated guide walks through the calculation.",
  },
  {
    q: 'Does a battery protect me from power cuts?',
    a: "Yes, if the hybrid inverter is set to EPS (Emergency Power Supply) mode. Deye SG-series inverters switch over almost instantly (about 4 ms) with no extra box — comparable to a UPS. How much power you have during an outage depends on the installed capacity and on the loads wired to the backup circuit. Don't confuse this with a plain on-grid inverter, which also shuts down during an outage, for safety.",
  },
  {
    q: 'Is it better to store the surplus or sell it to the grid in Morocco?',
    a: "In Morocco, law 82-21 (in force since June 2026) caps grid injection at 20% of annual output, and the ANRE buy-back rate runs from 0.18 to 0.21 DH/kWh depending on the hour. Yet a kWh bought from the grid costs you between 0.90 DH (first tier) and 1.66 DH (heavy use). In other words, a kWh stored and self-consumed in the evening is worth 4 to 9 times more than one sold to the grid. So the order of priority is: (1) consume directly by day, (2) store for the evening, (3) export the balance, capped at 20%. Don't oversize your batteries to export more — it doesn't pay.",
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Batteries & storage',
  serviceType: 'Solar energy storage',
  description: 'Solar storage in Morocco: Dyness lithium-iron-phosphate (LFP) batteries, sized by the study according to the consumption profile — daytime self-consumption or service continuity.',
  provider: { '@type': 'Organization', name: 'Taqinor', url: 'https://taqinor.ma' },
  areaServed: { '@type': 'Country', name: 'Maroc' },
};
---

<Layout
  title="Dyness LFP solar batteries in Morocco: 6,000 cycles, 90% DoD | Taqinor"
  description="Solar storage in Morocco: Dyness lithium-iron-phosphate batteries, 6,000 cycles at 90% depth of discharge, expandable 5 kWh modules, native CAN BMS dialogue with Deye hybrid inverters, 10-year warranty with ≥70% capacity retained. The real question is your consumption profile: if you use most of your power by day, the battery often has to wait its turn."
  ogSlug="equipement"
>
  <div class="v2">
    <V2Enhance />
    <Article33Ribbon />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <Breadcrumb items={[{ label: 'Home', href: L('/') }, { label: 'Batteries & storage' }]} />

    {/* ── EDITORIAL HERO — brass discipline #2: eyebrow demoted to lune,
        gold stays for .lum figures and the CTA. Rhythm via .section-lg. ── */}
    <section class="section-lg px-4 pb-10 text-white">
      <div class="mx-auto max-w-3xl">
        <p class="tech-label v2-kicker rule-brass cine-in text-lune">Energy storage</p>
        <h1 class="display v2-page-title cine-in cine-in-1 mt-6">Batteries &amp; storage</h1>
        <p class="v2-lead cine-in cine-in-2 mt-6 max-w-xl text-white/85">
          A Dyness LFP battery takes 6,000 cycles at 90% depth of discharge; it will last. The
          question that actually decides things, though, isn't <em>which</em> battery but <em>when</em>
          you consume. If most of your power goes out the door during the day, what you pay to store
          it is mostly money paid for nothing.
        </p>
      </div>
    </section>

    <!-- When storage is justified / when not -->
    <section class="section px-4">
      <div class="mx-auto max-w-6xl">
        {/* Eyebrow demoted to lune (brass discipline #2) */}
        <p class="tech-label v2-kicker rule-brass text-lune">The right trade-off</p>
        <h2 class="display v2-section-title mt-5 text-white">When a battery is justified — and when not</h2>
        <div class="mt-12 grid gap-6 md:grid-cols-2" data-stagger>
          {cas.map((c, i) => (
            <div class="v2-rise cine-card flex flex-col p-7" style={`--v2-i:${i}`}>
              {/* Card sub-label demoted to lune (gold stays on figures/CTA) */}
              <p class="tech-label text-lune">{c.k}</p>
              <h3 class="display mt-2 text-2xl text-white">{c.title}</h3>
              <p class="mt-3 flex-1 text-sm leading-relaxed text-lune-soft">{c.body}</p>
            </div>
          ))}
        </div>
        {/* Border demoted to azur + secondary link in lune/azur (discipline #2) */}
        <p class="mt-8 max-w-2xl border-l-4 border-azur-200/50 pl-4 text-sm leading-relaxed text-lune-soft">
          Our commercial interest would be to sell you one. We'd rather start by reading your
          consumption curve hour by hour: that is what settles whether storage pays its way and, if
          it does, how many kWh are genuinely enough. Often the honest answer is two words — not yet.
          <a href={L('/guides/faut-il-des-batteries')} class="border-b-2 border-azur-200/60 pb-0.5 font-bold text-azur-200 transition-colors hover:text-white">Read the full guide →</a>
        </p>
      </div>
    </section>

    <!-- The storage hardware installed — Dyness LFP -->
    <div class="v2-seam" aria-hidden="true"></div>
    <section class="section bg-blanc-azur px-4 text-encre">
      <div class="mx-auto max-w-3xl">
        <p class="tech-label v2-kicker rule-brass text-azur-600">The hardware installed</p>
        <h2 class="display v2-section-title mt-5">Dyness lithium-iron-phosphate batteries</h2>
        <p class="v2-lead mt-4 text-encre-soft">
          When storage is justified, we fit Dyness LFP batteries. Lithium-iron-phosphate chemistry
          doesn't run away thermally the way some other lithiums can, and it takes being drawn down to
          90% every cycle without wearing out. The BMS talks to the Deye hybrid inverter over CAN, and
          the inverter manages charge and discharge to the watt. Hardware sourced through the official
          distributors in Morocco, with the warranty honoured on the ground here.
        </p>
        <div class="mt-10 border-t-2 border-azur-900 bg-blanc" data-stagger>
          {specs.map((s, i) => (
            <div class="v2-rise flex items-baseline justify-between gap-4 border-b border-azur-900/15 px-5 py-4" style={`--v2-i:${i}`}>
              <span class="text-sm font-semibold">{s.item}</span>
              <span class="whitespace-normal text-right text-sm text-azur-600">{s.detail}</span>
            </div>
          ))}
        </div>
        <p class="mx-auto mt-6 max-w-xl border-l-4 border-azur-600 pl-4 text-sm leading-relaxed text-encre-soft">
          The modules stack in 5 kWh steps. In practice, we measure the dip your consumption leaves
          after sunset and stack just enough modules to fill it: that figure sets the capacity, never
          a catalogue tier.
          <a href={L('/équipement')} class="border-b border-azur-600 pb-0.5 font-semibold text-azur-600 transition-colors hover:text-azur-700">See all the hardware installed →</a>
        </p>

        <!-- Real installations with storage -->
        <h3 class="display mt-14 text-xl">Storage already on our roofs</h3>
        <p class="mt-3 text-sm leading-relaxed text-encre-soft">
          From 5 kWh to 15 kWh: several households already run with Dyness batteries, each capacity
          set to the profile of the home that received it.
        </p>
        <div class="mt-6 grid gap-4 sm:grid-cols-3" data-stagger>
          {installs.map((inst, i) => (
            <div class="v2-rise border-l-2 border-azur-600 bg-blanc px-4 py-4" style={`--v2-i:${i}`}>
              <p class="fig whitespace-nowrap text-2xl text-azur-600" data-tally>{inst.kwh}</p>
              <p class="tech-label mt-2 text-encre-faint">Dyness · {inst.where} · ref. {inst.ref}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Visual FAQ — schema={false}: /faq stays the only FAQPage -->
    <Faq
      schema={false}
      heading="Frequently asked questions about solar storage"
      items={faqItems}
    />

    <!-- Internal guides & resources — battery links -->
    <section class="section px-4">
      <div class="mx-auto max-w-6xl">
        {/* Eyebrow + sub-labels + links demoted to lune/azur (discipline #2) */}
        <p class="tech-label v2-kicker rule-brass text-lune">To go further</p>
        <h2 class="display v2-section-title mt-5 text-white">Battery &amp; storage guides</h2>
        <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3" data-stagger>
          <a href={L('/guides/batterie-lithium-ou-gel')} class="v2-rise cine-card flex flex-col p-6 transition-colors hover:border-azur-200/40" style="--v2-i:0">
            <p class="tech-label text-lune">Chemistry</p>
            <h3 class="display mt-2 text-lg text-white">Lithium or gel: which chemistry?</h3>
            <p class="mt-3 flex-1 text-sm leading-relaxed text-lune-soft">LFP, AGM/GEL, NMC — lifespan, depth of discharge, thermal safety: the comparison for Morocco.</p>
            <span class="mt-4 text-sm font-bold text-azur-200">Read the guide →</span>
          </a>
          <a href={L('/guides/quelle-taille-de-batterie')} class="v2-rise cine-card flex flex-col p-6 transition-colors hover:border-azur-200/40" style="--v2-i:1">
            <p class="tech-label text-lune">Sizing</p>
            <h3 class="display mt-2 text-lg text-white">What battery size for my home?</h3>
            <p class="mt-3 flex-1 text-sm leading-relaxed text-lune-soft">A step-by-step method: measure your evening dip, then choose between the 5–10 / 10–20 / 20+ kWh tiers.</p>
            <span class="mt-4 text-sm font-bold text-azur-200">Read the guide →</span>
          </a>
          <a href={L('/guides/electricite-pendant-les-coupures')} class="v2-rise cine-card flex flex-col p-6 transition-colors hover:border-azur-200/40" style="--v2-i:2">
            <p class="tech-label text-lune">Uninterrupted supply</p>
            <h3 class="display mt-2 text-lg text-white">Keeping the power on through outages</h3>
            <p class="mt-3 flex-1 text-sm leading-relaxed text-lune-soft">EPS mode, ≈ 4 ms switchover, backup circuits: how a hybrid system carries you through a grid cut.</p>
            <span class="mt-4 text-sm font-bold text-azur-200">Read the guide →</span>
          </a>
        </div>
      </div>
    </section>

    <!-- Closing links -->
    <section class="section-tight px-4 pb-20 sm:pb-24">
      <div class="mx-auto max-w-6xl">
        {/* Eyebrow demoted to lune (brass discipline #2) */}
        <p class="tech-label v2-kicker rule-brass text-lune">Storage in your project</p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a href={L('/équipement')} class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">All the equipment →</a>
          <a href={L('/résidentiel')} class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">Residential solar →</a>
          <a href={L('/guides/faut-il-des-batteries')} class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">Guide: do you need batteries? →</a>
          <a href={L('/garanties')} class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">Warranties →</a>
          <a href={L('/realisations')} class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">Our projects →</a>
        </div>
      </div>
    </section>

    <CtaBand title="Storage or not? Your consumption curve will say — free assessment." href={devisHref} />

    <StickyCta />
  </div>
</Layout>
