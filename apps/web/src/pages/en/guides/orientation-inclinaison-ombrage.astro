const L = (href: string) => localizeNavHref(href, locale);

const url = new URL(Astro.url.pathname, Astro.site).href;
const schemaImageUrl = new URL('/og/accueil.png', Astro.site).href;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'Orientation, tilt and shading: maximising production on a Moroccan roof',
  description: 'Due south, tilt optimum around 30°, and zero shade: the three rules that really make the difference on a Moroccan roof, explained with no jargon.',
  image: schemaImageUrl,
  about: { '@type': 'Thing', name: 'Photovoltaic solar installation' },
  author: { '@type': 'Organization', name: NAP.name, url: NAP.url },
