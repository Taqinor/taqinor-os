 * 80–85 % vs 92–98 % round-trip, NMC 92–96 %/80–90 % DoD/150–210 °C
 * decomposition). Internal links use localizeNavHref (EN/AR if available,
 * else the existing FR page — never a dead link). FR untouched.
 */
import Layout from '../../../layouts/Layout.astro';
import V2Enhance from '../../../components/V2Enhance.astro';
import Article33Ribbon from '../../../components/Article33Ribbon.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
