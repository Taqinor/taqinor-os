const L = (href: string) => localizeNavHref(href, locale);

const url = new URL(Astro.url.pathname, Astro.site).href;
const schemaImageUrl = new URL('/og/equipement.png', Astro.site).href;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'Solar battery: lithium LiFePO4 (LFP) vs GEL/lead-acid (and NMC)',
  description: 'LFP or GEL? Cycle life, depth of discharge, efficiency, heat tolerance in Morocco, and safety versus NMC: everything you need to know before choosing a solar battery.',
  image: schemaImageUrl,
  about: { '@type': 'Thing', name: 'LFP solar storage battery' },
