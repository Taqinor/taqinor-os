---
/**
 * EN — Guides & resources hub (W67). Faithful translation of /guides ; no new
 * figure or price claim. Card links use localizeNavHref (EN/AR if available,
 * else the existing FR page — never a dead link). FR untouched.
 */
import Layout from '../../../layouts/Layout.astro';
import V2Enhance from '../../../components/V2Enhance.astro';
import Article33Ribbon from '../../../components/Article33Ribbon.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import CtaBand from '../../../components/CtaBand.astro';
import StickyCta from '../../../components/StickyCta.astro';
import { getLocaleFromPath } from '../../../i18n/utils';
import { localizeNavHref } from '../../../i18n/pages';

const locale = getLocaleFromPath(Astro.url.pathname);
const L = (href: string) => localizeNavHref(href, locale);

const guides = [
  {
    href: '/guides/combien-de-panneaux-pour-ma-maison',
    title: 'How many panels and what power (kWc)?',
    summary: 'The method to go from your bill to the number of panels: annual kWh, kWc, roof surface. Enough to understand sizing before the study.',
  },
  {
    href: '/guides/on-grid-off-grid-ou-hybride',
    title: 'On-grid, off-grid or hybrid?',
    summary: 'Which system type for which need — and why a grid-connected system cuts out during an outage (anti-islanding), unless you go hybrid with a battery.',
  },
  {
    href: '/guides/orientation-inclinaison-ombrage',
    title: 'Orientation, tilt and shading',
    summary: 'Due south, east-west, tilt angle, and the disproportionate impact of shade on a Moroccan roof: how to get the most out of production.',
  },
  {
    href: '/guides/entretien-et-duree-de-vie-des-panneaux',
    title: 'Maintenance and lifespan of panels',
    summary: 'Dust and sand in Morocco, cleaning, heat, degradation: how long panels really last and how to preserve their production.',
  },
  {
    href: '/guides/monocristallin-ou-polycristallin',
    title: 'Monocrystalline or polycrystalline? String or micro-inverters?',
    summary: 'Choosing your equipment with no jargon: panel type and inverter type, and what each one changes in practice on a roof.',
  },
  {
    href: '/guides/loi-82-21-expliquee',
    title: 'Law 82-21 explained simply',
    summary: 'Declaration, connection agreement or authorisation: the three self-production regimes untangled, with the 11 kW threshold that puts almost every villa on the right side.',
  },
  {
    href: '/guides/onduleur-hybride-ou-reseau',
    title: 'Hybrid inverter or grid-tied inverter?',
    summary: 'Deye hybrid or Huawei SUN2000 grid-tied: the whole choice comes down to one question — do you store the energy, yes or no?',
  },
  {
    href: '/guides/mon-toit-peut-il-supporter-des-panneaux',
    title: 'Can my roof support panels?',
    summary: 'The real weight of a solar panel per m², roof by roof (concrete slab, tile, corrugated sheet, flat roof), and when a structural check is needed.',
  },
  {
    href: '/guides/faut-il-des-batteries',
    title: 'Do you need batteries?',
    summary: 'Often no. It all depends on when you consume: we show you when storage pays, and when it only weighs the bill down.',
  },
  {
    href: '/guides/batterie-lithium-ou-gel',
    title: 'Lithium LiFePO4 (LFP) vs GEL/lead-acid (and NMC)',
    summary: 'Why LFP wins out in Morocco: lifespan, depth of discharge, efficiency, heat tolerance and safety versus NMC.',
  },
  {
    href: '/guides/quelle-taille-de-batterie',
    title: 'What battery size (kWh)? Store or sell back?',
    summary: 'Sizing tiers, usable vs. nominal kWh, and why storing for the evening pays off far more than exporting your surplus in Morocco.',
  },
  {
    href: '/guides/electricite-pendant-les-coupures',
    title: 'Keeping the power on during outages',
    summary: 'Backup ≠ off-grid: EPS outputs, hybrid inverter and battery, and why a standard grid system shuts off during an outage.',
  },
  {
    // W293 — evergreen pricing pillar, distinct from the sizing-method guide above.
    href: '/prix-panneaux-solaires-maroc',
    title: 'Solar panel prices in Morocco',
    summary: 'Indicative brackets by power (kWc), roof and battery surcharges, VAT — reviewed every year, never a firm price promised.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Solar guides & resources — Taqinor',
  hasPart: guides.map((g) => ({ '@type': 'Article', headline: g.title, url: new URL(g.href, Astro.site).href })),
};
---

<Layout
  title="Solar guides in Morocco — Law 82-21, batteries, inverters | Taqinor"
  description="Three questions that keep coming up before signing, handled without jargon: which Law 82-21 regime concerns you, whether your profile justifies batteries, and what sets a hybrid inverter apart from a grid-tied one. Enough to decide with your eyes open."
  ogSlug="guides"
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <div class="v2">
    <V2Enhance />
    <Article33Ribbon />

    <Breadcrumb items={[{ label: 'Home', href: L('/') }, { label: 'Guides' }]} />

    <section class="px-4 pb-10 pt-16 text-white sm:pt-20">
      <div class="mx-auto max-w-3xl">
        <p class="tech-label v2-kicker rule-brass cine-in text-lune">Guides & resources</p>
        <h1 class="display v2-page-title cine-in mt-5 [animation-delay:120ms]">Understand before you sign</h1>
        <p class="v2-lead cine-in mt-6 max-w-xl text-white/85 [animation-delay:240ms]">
          Three questions come up in almost all our conversations. Rather than answer them on the
          phone, we've written them down here, without jargon and without a price figure thrown
          out at random. Enough to come to the study with the right questions already in mind.
        </p>
      </div>
    </section>

    <section class="px-4 pb-24 sm:pb-32">
      <div class="mx-auto grid max-w-6xl gap-6 md:grid-cols-3" data-stagger>
        {guides.map((g, i) => (
          <a href={L(g.href)} class="v2-rise cine-card flex flex-col p-7" style={`--v2-i:${i}`}>
            <p class="tech-label text-lune">Guide</p>
            <h2 class="display mt-2 text-xl text-white">{g.title}</h2>
            <p class="mt-3 flex-1 text-sm leading-relaxed text-lune-soft">{g.summary}</p>
            <span class="mt-5 inline-block border-b-2 border-azur-200/60 pb-0.5 text-sm font-bold text-white">Read the guide →</span>
          </a>
        ))}
      </div>
    </section>

    <CtaBand title="Your case isn't in the guides? Put it to the study — it's free." href={L('/devis/mon-toit')} />

    <StickyCta />
  </div>
</Layout>
