---
/**
 * EN — Guide (W67): Hybrid inverter or grid-tied inverter? Faithful translation
 * of /guides/onduleur-hybride-ou-reseau ; no figure beyond the already
 * published ranges (5–30 kW), no price/cost claim. Internal links use
 * localizeNavHref (EN/AR if available, else the existing FR page — never a dead
 * link). FR untouched.
 */
import Layout from '../../../layouts/Layout.astro';
import V2Enhance from '../../../components/V2Enhance.astro';
import Article33Ribbon from '../../../components/Article33Ribbon.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import CtaBand from '../../../components/CtaBand.astro';
import StickyCta from '../../../components/StickyCta.astro';
import { NAP } from '../../../lib/nap';
import { getLocaleFromPath } from '../../../i18n/utils';
import { localizeNavHref } from '../../../i18n/pages';

const locale = getLocaleFromPath(Astro.url.pathname);
const L = (href: string) => localizeNavHref(href, locale);

const url = new URL(Astro.url.pathname, Astro.site).href;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'Hybrid inverter or grid-tied inverter?',
  description: 'Deye hybrid inverter or Huawei grid-tied inverter: the difference comes down to one simple question — do you store the energy, yes or no?',
  about: { '@type': 'Thing', name: 'Solar inverters' },
  author: { '@type': 'Organization', name: NAP.name, url: NAP.url },
  publisher: { '@type': 'Organization', name: NAP.name, url: NAP.url },
  mainEntityOfPage: url,
};
---

<Layout
  title="Hybrid inverter or grid-tied inverter? | Taqinor"
  description="Deye hybrid inverter (with storage, service continuity) or Huawei SUN2000 grid-tied inverter (self-consumption without a battery): how the choice is made, explained simply."
  ogSlug="equipement"
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <div class="v2">
    <V2Enhance />
    <Article33Ribbon />

    <Breadcrumb items={[{ label: 'Home', href: L('/') }, { label: 'Guides', href: L('/guides') }, { label: 'Hybrid or grid-tied inverter?' }]} />

    <article class="mx-auto max-w-3xl px-4 pb-24 pt-12 sm:pb-28">
      <p class="tech-label v2-kicker rule-brass text-brass-300">Guide · Equipment</p>
      <h1 class="display v2-page-title mt-5 text-white">Hybrid inverter or grid-tied inverter?</h1>
      <p class="v2-lead mt-6 text-lune-soft">
        The inverter is the part that converts the direct current from the panels into current you
        can use at home: without it, nothing works. The debate between
        <strong class="text-lune">hybrid</strong> and <strong class="text-lune">grid-tied</strong>
        may seem technical, but it comes down to a single question: do you store the energy, yes or
        no?
      </p>

      <h2 class="display v2-section-title mt-12 text-white">The hybrid inverter (Deye)</h2>
      <p class="v2-lead mt-5 text-lune-soft">
        Answer "yes" to storage, and you're on a hybrid. The Deye units (single-phase and
        three-phase, from 5 to 30 kW) drive the panels and a battery at the same time, with
        built-in CAN BMS management. They make sense when you want to set aside the day's energy to
        consume it in the evening, or keep the power on during an outage.
      </p>

      <h2 class="display v2-section-title mt-12 text-white">The grid-tied inverter (Huawei SUN2000)</h2>
      <p class="v2-lead mt-5 text-lune-soft">
        Answer "no", and the grid-tied inverter is enough. The Huawei SUN2000 units (string type)
        are cut out for self-consumption without a battery, from residential to commercial
        rooftops. It's the option when your consumption is mostly during the day: no storage to pay
        for energy you already use as the sun goes.
      </p>

      <h2 class="display v2-section-title mt-12 text-white">How we choose</h2>
      <p class="v2-lead mt-5 text-lune-soft">
        The choice of inverter is therefore not the first, it's the last: it follows from the
        decision on storage, which itself follows from your consumption profile. We work back up the
        chain in the right order — your bill first, the hardware after — instead of starting from a
        model decided in advance.
      </p>
      <div class="mt-10 flex flex-wrap gap-3">
        <a href={L('/guides/faut-il-des-batteries')} class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">Do you need batteries? →</a>
        <a href={L('/équipement')} class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">See the equipment →</a>
        <a href={L('/guides')} class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">All the guides →</a>
      </div>
    </article>

    <CtaBand title="We settle hybrid or grid-tied in the study — and it's free." href={L('/contact') + '#simulateur'} />

    <StickyCta />
  </div>
</Layout>
