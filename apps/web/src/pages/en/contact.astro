---
/**
 * EN — Contact (W67). Faithful English translation of /contact ; FR untouched.
 * The lead form (DiagnosticForm) keeps an IDENTICAL data flow in every locale:
 * same payload, same /api/simulate endpoint, same 1 000 MAD threshold, same
 * WhatsApp deeplink — only the VISIBLE labels are localised (here via the
 * form's auto-derived locale from the /en/ URL).
 */
import Layout from '../../layouts/Layout.astro';
import V2Enhance from '../../components/V2Enhance.astro';
import Article33Ribbon from '../../components/Article33Ribbon.astro';
import DiagnosticForm from '../../components/DiagnosticForm.astro';
import { NAP, WHATSAPP_LEADS } from '../../lib/nap';
import { whatsappLink, regularizationWhatsappText } from '../../lib/whatsapp';

// Deeplinks are built server-side with the SAME WhatsApp leads number; the
// pre-filled text stays French (it reaches the French-speaking sales team).
const waGeneral = whatsappLink(WHATSAPP_LEADS, 'Bonjour, je souhaite une étude pour une installation solaire.');
const waRegul = whatsappLink(WHATSAPP_LEADS, regularizationWhatsappText());

// W339 — "Already a customer?" SAV/urgent door, SEPARATE from the commercial
// lead webhook (DiagnosticForm above, unchanged). Pre-filled text stays
// French (same sales/SAV team) but explicitly flags an existing-installation
// fault report so it's routed differently from a quote request.
const waSav = whatsappLink(
  WHATSAPP_LEADS,
  'Bonjour, je suis déjà client Taqinor et je signale un problème sur mon installation existante (SAV). Merci de me recontacter.',
);
---

<Layout
  title="Contact — free solar study | Taqinor"
  description="Request your free solar study: instant estimate form, direct WhatsApp, service across Morocco. Reply within 48 business hours."
  ogSlug="contact"
>
  <div class="v2">
    <V2Enhance />
    <Article33Ribbon />

    <section class="px-4 py-20 text-white">
      <div class="mx-auto max-w-6xl">
        <p class="tech-label v2-kicker rule-brass cine-in text-brass-300">Reply within 48 business hours</p>
        <h1 class="display v2-page-title cine-in mt-5 max-w-2xl [animation-delay:120ms]">Let's talk about your installation</h1>
        <p class="v2-lead cine-in mt-5 max-w-xl text-white/85 [animation-delay:240ms]">
          The form gives you an instant range. To move faster, write to us directly
          on WhatsApp.
        </p>
      </div>
    </section>

    <DiagnosticForm heading="Solar assessment — instant estimate" />

    <!-- Still in the lit act: the WhatsApp shortcuts and the NAP card -->
    <section class="bg-blanc-azur px-4 pb-16 text-encre">
      <div class="mx-auto max-w-2xl">
        <div class="grid gap-4 sm:grid-cols-2" data-stagger>
          <a href={waGeneral} rel="noopener"
            class="v2-rise group border border-azur-900/15 bg-blanc p-6 text-center transition-all hover:-translate-y-0.5 hover:border-azur-600 hover:shadow-[0_14px_40px_-16px_rgb(15_28_84/0.4)]" style="--v2-i:0">
            <p class="tech-label text-azur-600">New project</p>
            <p class="mt-2 font-display font-bold">WhatsApp — new installation</p>
            <p class="mt-1 text-sm text-encre-soft">Study and quote for a new project</p>
          </a>
          <a href={waRegul} rel="noopener"
            class="v2-rise group border border-azur-900/15 bg-blanc p-6 text-center transition-all hover:-translate-y-0.5 hover:border-azur-600 hover:shadow-[0_14px_40px_-16px_rgb(15_28_84/0.4)]" style="--v2-i:1">
            <p class="tech-label text-azur-600">Article 33</p>
            <p class="mt-2 font-display font-bold">WhatsApp — regularization</p>
            <p class="mt-1 text-sm text-encre-soft">Existing installation to bring into compliance</p>
          </a>
        </div>

        <div class="v2-rise mt-8 border border-azur-900/15 bg-blanc-azur p-7 text-center text-sm">
          <p class="font-display text-lg font-bold">{NAP.name}</p>
          <p class="mt-2">
            <a href={`tel:${NAP.phone}`} dir="ltr" class="font-semibold underline decoration-azur-600 decoration-2 underline-offset-4">{NAP.phoneDisplayIntl}</a>
            &nbsp;·&nbsp;
            <a href={`mailto:${NAP.email}`} dir="ltr" class="underline decoration-azur-600 decoration-2 underline-offset-4">{NAP.email}</a>
          </p>
          <p class="mt-3 text-encre-soft">
            Service area: Casablanca–Rabat axis, and {NAP.serviceArea.slice(2, -1).join(', ')} on request.
          </p>
          <p class="mt-1 text-xs text-encre-faint">On-site visits only — no public reception at an office.</p>
        </div>
      </div>
    </section>

    <!-- W339 — "Already a customer?" SAV/urgent door, visually and
         functionally separate from the quote block above. Pre-filled
         WhatsApp flags a fault report, routed to the SAV team — never the
         commercial lead webhook. -->
    <section id="deja-client" class="border-t border-azur-900/10 bg-blanc px-4 py-16 text-encre">
      <div class="mx-auto max-w-2xl">
        <div class="v2-rise border-2 border-azur-600/40 bg-blanc-azur p-7 text-center sm:p-9">
          <p class="tech-label text-azur-600">Already a customer?</p>
          <h2 class="display mt-2 text-2xl font-bold sm:text-3xl">A problem with your installation?</h2>
          <p class="mt-3 text-sm leading-relaxed text-encre-soft">
            What should you do if your inverter shows an error? Photograph the screen and message
            us on WhatsApp — the fastest way to reach the SAV (after-sales) team, who handle your
            report separately from a new quote request.
          </p>
          <div class="mt-6 flex flex-wrap items-center justify-center gap-3">
            <a
              href={waSav}
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 bg-brass-400 px-6 py-3 text-sm font-bold text-azur-950 transition-colors hover:bg-brass-300"
            >
              WhatsApp — report a fault (SAV)
            </a>
            <a
              href={`tel:${NAP.phone}`}
              dir="ltr"
              class="inline-flex items-center gap-2 border border-azur-900/25 px-6 py-3 text-sm font-semibold text-encre transition-colors hover:border-azur-600"
            >
              {NAP.phoneDisplayIntl}
            </a>
          </div>
        </div>
      </div>
    </section>
  </div>
</Layout>
