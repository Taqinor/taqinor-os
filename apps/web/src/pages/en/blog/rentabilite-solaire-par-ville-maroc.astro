const locale = getLocaleFromPath(Astro.url.pathname);
const L = (href: string) => localizeNavHref(href, locale);

const pubDate = new Date('2026-06-21');
const dateFmt = new Intl.DateTimeFormat('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });

const bodyText = `
PVOUT by city ranges 1500 to 1950 kWh per kWc per year, Marrakech confirmed at 1779. ONEE tariffs
range 0.90 to 1.66 DH per kWh, selective billing above 150 kWh a month bills the whole month at the
marginal bracket. Payback 5 to 7 years residential, consensus among installers. What influences
payback: your current tariff bracket, installation cost 10000 to 14000 DH per kWc, self-consumption
rate, and battery adding 1 to 3 years to payback.
`;
const readingMinutes = estimateReadingTime(bodyText);

const url = new URL(Astro.url.pathname, Astro.site).href;
const schemaImageUrl = new URL('/og/residentiel.png', Astro.site).href;
const blogPosting = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: 'Solar profitability and return on investment by Moroccan city',
  description: '5–7 year payback, production by city and ONEE tariffs: everything you need to know about solar profitability in Morocco.',
  image: schemaImageUrl,
  datePublished: pubDate.toISOString(),
  keywords: 'profitability, ROI, production, cities',
  author: { '@type': 'Person', name: 'Reda Kasri' },
  publisher: { '@type': 'Organization', name: NAP.name, url: NAP.url },
  mainEntityOfPage: { '@type': 'WebPage', '@id': url },
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: new URL(L('/'), Astro.site).href },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: new URL(L('/blog'), Astro.site).href },
    { '@type': 'ListItem', position: 3, name: 'Solar profitability and ROI by Moroccan city' },
  ],
};

const pvout = [
  { city: 'Tangier', value: '~1,550 – 1,650', tilt: '31°' },
  { city: 'Casablanca', value: '~1,620 – 1,700', tilt: '29°' },
  { city: 'Rabat-Salé', value: '~1,620 – 1,700', tilt: '29°' },
  { city: 'Fez', value: '~1,650 – 1,750', tilt: '~32°' },
  { city: 'Marrakech', value: '1,779', tilt: '28°' },
  { city: 'Agadir', value: '~1,750 – 1,820', tilt: '27°' },
  { city: 'Ouarzazate', value: '~1,850 – 1,950', tilt: '~28–30°' },
];

const tariffs = [
  { range: '0 – 100 kWh', tariff: '0.9010', mode: 'progressive' },
  { range: '101 – 150 kWh', tariff: '1.0732', mode: 'progressive' },
  { range: '151 – 210 kWh', tariff: '1.0732', mode: 'selective' },
  { range: '211 – 310 kWh', tariff: '1.1676', mode: 'selective' },
  { range: '311 – 510 kWh', tariff: '1.3817', mode: 'selective' },
