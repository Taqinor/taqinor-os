const locale = getLocaleFromPath(Astro.url.pathname);
const L = (href: string) => localizeNavHref(href, locale);

const pubDate = new Date('2026-06-21');
const dateFmt = new Intl.DateTimeFormat('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });

const bodyText = `
How much does it really cost? Turnkey brackets by power: 3 kWc 28,000-42,000 DH, 5 kWc
45,000-65,000 DH, 10 kWc 85,000-120,000 DH. Average turnkey cost about 10,000-14,000 DH per kWc.
Beware of 4,700 DH/kWc prices — that's equipment-kit-only, not turnkey. Roof surcharges: tile or
corrugated sheet +6,000-12,000 DH, steep slope over 30 degrees +4,000-8,000 DH. Battery: LFP
5-15 kWh adds 22,000-60,000 MAD and stretches payback by 1 to 3 years. VAT at 20% on turnkey
installs, panels alone exempt without input deduction. Payback 5 to 7 years residential.
`;
const readingMinutes = estimateReadingTime(bodyText);

const url = new URL(Astro.url.pathname, Astro.site).href;
const schemaImageUrl = new URL('/og/accueil.png', Astro.site).href;
const blogPosting = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: 'How much does a solar installation cost in Morocco in 2026?',
  description: "Indicative 2026 brackets by power, roof, battery and VAT surcharges — to know what to expect before your quote.",
  image: schemaImageUrl,
  datePublished: pubDate.toISOString(),
  keywords: 'cost, price, installation, 2026',
  author: { '@type': 'Person', name: 'Reda Kasri' },
  publisher: { '@type': 'Organization', name: NAP.name, url: NAP.url },
  mainEntityOfPage: { '@type': 'WebPage', '@id': url },
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: new URL(L('/'), Astro.site).href },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: new URL(L('/blog'), Astro.site).href },
    { '@type': 'ListItem', position: 3, name: 'How much does a solar installation cost in Morocco in 2026?' },
  ],
};

const fourchettes = [
  { kwc: '3 kWc', prix: '28,000 – 42,000 DH' },
  { kwc: '5 kWc', prix: '45,000 – 65,000 DH' },
  { kwc: '10 kWc', prix: '85,000 – 120,000 DH' },
