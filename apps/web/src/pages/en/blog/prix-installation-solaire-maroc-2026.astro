 * EXACT (28,000–42,000 / 45,000–65,000 / 85,000–120,000 DH brackets,
 * 10,000–14,000 DH/kWc, roof/battery surcharges, VAT, 5–7 year payback).
 * Static page (not a content-collection entry) mirroring the guides pattern,
 * since the blog collection has no locale field (out of this lane's scope —
 * see content.config.ts). Internal links use localizeNavHref (EN/AR if
 * available, else the existing FR page — never a dead link). FR untouched.
 */
import Layout from '../../../layouts/Layout.astro';
import V2Enhance from '../../../components/V2Enhance.astro';
import Article33Ribbon from '../../../components/Article33Ribbon.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import CtaBand from '../../../components/CtaBand.astro';
import StickyCta from '../../../components/StickyCta.astro';
import RelatedLinks from '../../../components/RelatedLinks.astro';
