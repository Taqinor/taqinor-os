---
/**
 * EN — Solar pumping (W67). Faithful translation of /pompage-solaire ; a
 * CAPABILITY page (no invented project/photo/production figure). The only
 * verified tax point is preserved EXACTLY: VAT exemption for AGRICULTURAL
 * pumping only — never residential rooftop PV. Internal links via
 * localizeNavHref. FR untouched.
 *
 * ELEVATION (W237) — mirrors /pompage-solaire.astro elevation treatment:
 *  - Eyebrows demoted from text-brass-300 to text-lune (brass discipline);
 *  - Equipment link: border-azur-200/60 text-azur-200 (not brass);
 *  - .section-lg hero rhythm + .section / .seam-soft spacing tokens;
 *  - No photo hero → no cinematic hero, no .v3-grade, no ZelligeSignature.
 *
 * W261 — Sibling parity, without crossing the "zero invented proof" line
 * above: mirrors the FR additions (capability stats band, 4-variable sizing
 * SVG diagram, diesel/butane-vs-solar narrative framing with NO invented
 * MAD/litre figure, and a WG11-gated financing/subsidy card labeled
 * "to verify with your DPA" — never a confirmed number or partnership claim).
 */
import Layout from '../../layouts/Layout.astro';
import V2Enhance from '../../components/V2Enhance.astro';
import Article33Ribbon from '../../components/Article33Ribbon.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CtaBand from '../../components/CtaBand.astro';
import StickyCta from '../../components/StickyCta.astro';
import Faq from '../../components/Faq.astro';
import ServiceWarrantyTable from '../../components/ServiceWarrantyTable.astro';
import { getLocaleFromPath } from '../../i18n/utils';
import { localizeNavHref } from '../../i18n/pages';
import { serviceFaqItems } from '../../lib/serviceFaq';

const locale = getLocaleFromPath(Astro.url.pathname);
const L = (href: string) => localizeNavHref(href, locale);
const devisHref = L('/devis/mon-toit');

// W263 — shared FAQ + per-component warranty, EN. Solar pumping fits neither
// an inverter nor a battery (repo fact) — includeOnduleur/includeBatterie false.
const faqItems = serviceFaqItems('pompage-solaire', 'en');

const etapes = [
  {
    k: '01',
    title: 'Solar capture',
    body: 'From sunrise to sunset, the panels turn sunlight into electricity. To know how many you need, we start from the volume of water to deliver and work back to the array: the irrigation need sets the power, and the array is sized to match.',
  },
  {
    k: '02',
    title: 'Pumping with the sun',
    body: 'Direct drive, usually without batteries: the pump runs through the daylight hours and pushes more water the stronger the sunlight. No battery bank to buy, cool or replace every eight years.',
  },
  {
    k: '03',
    title: 'Storing water, not energy',
    body: 'The reserve is the tank, not the battery. We pump at midday, when the array is at full power, and irrigate when the crop needs it. The water waits in the tank; it does not discharge and it does not age.',
  },
  {
    k: '04',
    title: 'Variable-speed drive control',
    body: 'The drive matches the pump speed to the energy available, ramps the motor up gently and shuts it down on a fault — dry running, undervoltage, overload. This is the electronics that rides out passing clouds and the changing seasons.',
  },
];

const variables = [
  {
    title: 'Flow rate',
    body: 'The volume of water to deliver, in m³/h or m³/day. It comes from the crop and the area to irrigate; it is the figure that drives every other.',
  },
  {
    title: 'Total head (HMT)',
    body: 'The total head: everything the pump has to overcome, added up — the depth of the water level in the borehole, the rise up to the tank, and friction losses in the pipes. Underestimate the head and you underflow all summer.',
  },
  {
    title: 'Borehole depth',
    body: 'The well depth, and above all the dynamic level — what the water drops to with the pump running — decide between a submersible and a surface pump, and set the array power.',
  },
  {
    title: "Crop water needs",
    body: 'The crop, the irrigated area and the season set the target volume. It opens the calculation: once fixed, it dictates the pump, the drive and the size of the array.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Solar pumping',
  serviceType: 'Photovoltaic solar pumping',
  provider: { '@type': 'Organization', name: 'Taqinor', url: 'https://taqinor.ma' },
  areaServed: { '@type': 'Country', name: 'Maroc' },
  description:
    'Study and sizing of solar pumping systems for agriculture and irrigation in Morocco: pump and photovoltaic array calculated on the real flow rate, head and water needs.',
};
---

<Layout
  title="Agricultural solar pumping in Morocco: flow rate, head, borehole | Taqinor"
  description="Solar pumping for irrigation: the pump runs with the sun, the water waits in the basin rather than in batteries, and the array is calculated on the flow rate, the head and the borehole level. Agricultural solar pumping is VAT-exempt in Morocco — an advantage specific to agriculture, not to residential PV."
  ogSlug="accueil"
>
  <div class="v2">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <V2Enhance />
    <Article33Ribbon />

    <Breadcrumb items={[{ label: 'Home', href: L('/') }, { label: 'Solar pumping' }]} />

    {/* ── EDITORIAL HERO — no photo (zero pumping site installed: no invented image).
        Brass discipline #2: eyebrow demoted to lune, gold stays for .lum figures
        and the CTA. Rhythm via .section-lg + space. ── */}
    <section class="section-lg px-4 pb-10 text-white">
      <div class="mx-auto max-w-3xl">
        <p class="tech-label v2-kicker rule-brass cine-in text-lune">New service</p>
        <h1 class="display v2-page-title cine-in cine-in-1 mt-6 max-w-[18ch]">Pump water with the sun, not with diesel</h1>
        <p class="v2-lead cine-in cine-in-2 mt-6 max-w-xl text-white/85">
          For irrigation, solar pumping replaces the tank of diesel: while the sun is up, the panels
          drive the pump. How many panels, though, depends entirely on your plot — the flow rate you
          are after, the head the pump must overcome, the depth of the borehole and the water the
          crop needs. We take those four measurements before we propose anything at all.
        </p>
      </div>
    </section>

    {/* W261 — Honest capability stats band: only facts already verified
        elsewhere on this page — no invented production or project figure. */}
    <section class="px-4 pb-4">
      <div class="mx-auto max-w-6xl">
        <dl class="cine-in grid max-w-3xl grid-cols-3 gap-3 border-t border-white/20 pt-6 sm:gap-6">
          <div>
            <dd class="fig lum text-base sm:text-3xl">4</dd>
            <dt class="tech-label mt-2 text-lune">Measurements taken on site</dt>
          </div>
          <div>
            <dd class="fig lum text-base sm:text-3xl">0%</dd>
            <dt class="tech-label mt-2 text-lune">VAT on agricultural pumping</dt>
          </div>
          <div>
            <dd class="fig lum text-base sm:text-3xl">Tier-1</dd>
            <dt class="tech-label mt-2 text-lune">Array and drive, same as our roofs</dt>
          </div>
        </dl>
      </div>
    </section>

    <!-- How it works -->
    <section class="section px-4">
      <div class="mx-auto max-w-6xl">
        {/* Eyebrow demoted to lune (brass discipline #2) — W274: chapter-
            numbering system (01/02…), same device as index.astro, extended
            here for site-wide consistency. Light-background eyebrows
            (text-azur-600, e.g. "Four measurements") stay unnumbered — same
            exclusion as the homepage's tonal-break section. */}
        <p class="tech-label v2-kicker rule-brass text-lune"><span class="mr-2 font-display text-xs text-azur-200/80" aria-hidden="true">01</span>How it works</p>
        <h2 class="display v2-section-title mt-5 text-white">From sun to field, in four stages</h2>
        <div class="mt-12 grid gap-6 md:grid-cols-2" data-stagger>
          {etapes.map((e, i) => (
            <div class="v2-rise cine-card flex flex-col p-7" style={`--v2-i:${i}`}>
              <p class="fig lum text-3xl">{e.k}</p>
              <h3 class="display mt-2 text-2xl text-white">{e.title}</h3>
              <p class="mt-3 flex-1 text-sm leading-relaxed text-lune-soft">{e.body}</p>
            </div>
          ))}
        </div>
        <p class="mx-auto mt-8 max-w-2xl text-sm leading-relaxed text-lune-faint">
          Every order of magnitude depends on your site: before the borehole survey we can walk you
          through the method, but not quote a figure we'd stand behind. The array and the drive, for
          their part, rely on the same tier-1 brands as our rooftops — <a href={L('/équipement')} class="border-b border-azur-200/60 pb-0.5 font-semibold text-azur-200 transition-colors hover:text-white">see the equipment →</a>
        </p>
      </div>
    </section>

    <!-- The sizing variables (light background) -->
    <div class="v2-seam" aria-hidden="true"></div>
    <section class="section bg-blanc-azur px-4 text-encre">
      <div class="mx-auto max-w-6xl">
        <p class="tech-label v2-kicker rule-brass text-azur-600">Four measurements</p>
        <h2 class="display v2-section-title mt-5">What decides the sizing</h2>
        <p class="v2-lead mt-5 max-w-2xl text-encre-soft">
          An oversized pump wastes panels; a pump cut too fine runs dry in the heat of July. The
          right answer sits at the intersection of four concrete variables, all measured on site
          before we open a single catalogue.
        </p>
        <div class="mt-12 grid gap-6 md:grid-cols-2" data-stagger>
          {variables.map((v, i) => (
            <div class="v2-rise border-t-2 border-azur-900 bg-blanc p-6" style={`--v2-i:${i}`}>
              <h3 class="display text-xl text-azur-700">{v.title}</h3>
              <p class="mt-3 text-sm leading-relaxed text-encre-soft">{v.body}</p>
            </div>
          ))}
        </div>
        <p class="mx-auto mt-8 max-w-2xl border-l-4 border-azur-600 pl-4 text-sm leading-relaxed text-encre-soft">
          With these four figures in hand, the system almost designs itself. Without them — when the
          flow rate or the head is missing — we'd be left guessing, and we don't size a pump on
          guesswork. <a href={devisHref} class="border-b border-azur-600 pb-0.5 font-semibold text-azur-600 transition-colors hover:text-azur-700">Request an assessment →</a>
        </p>

        {/* W261 — Diagram of the 4 sizing variables converging on the system:
            same content as the four cards above, staged visually. */}
        <div class="mx-auto mt-14 max-w-3xl">
          <svg viewBox="0 0 600 260" role="img" aria-label="Flow rate, total head, borehole depth and crop water needs converge on the pump, drive and photovoltaic array sizing" class="w-full">
            <g font-size="11" class="fill-azur-700">
              <g transform="translate(70,40)">
                <circle r="26" fill="none" stroke="#0f1c54" stroke-width="2.5" />
                <text text-anchor="middle" dy="4" font-weight="700">Flow</text>
              </g>
              <g transform="translate(70,110)">
                <circle r="26" fill="none" stroke="#0f1c54" stroke-width="2.5" />
                <text text-anchor="middle" dy="4" font-weight="700">Head</text>
              </g>
              <g transform="translate(70,180)">
                <circle r="26" fill="none" stroke="#0f1c54" stroke-width="2.5" />
                <text text-anchor="middle" dy="-2" font-weight="700">Borehole</text>
              </g>
              <g transform="translate(70,240)">
                <circle r="26" fill="none" stroke="#0f1c54" stroke-width="2.5" />
                <text text-anchor="middle" dy="-2" font-weight="700">Needs</text>
              </g>
            </g>
            <g stroke="#0f1c54" stroke-width="2" fill="none" opacity="0.6" aria-hidden="true">
              <path d="M96 40 L300 130" marker-end="url(#arrowP)" />
              <path d="M96 110 L300 130" marker-end="url(#arrowP)" />
              <path d="M96 180 L300 130" marker-end="url(#arrowP)" />
              <path d="M96 240 L300 130" marker-end="url(#arrowP)" />
            </g>
            <defs>
              <marker id="arrowP" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
                <path d="M0 0 L6 3 L0 6 Z" fill="#0f1c54" />
              </marker>
            </defs>
            <g transform="translate(300,130)">
              <rect x="-70" y="-40" width="140" height="80" rx="4" fill="#0f1c54" />
              <text text-anchor="middle" dy="-8" font-size="11" fill="white" font-weight="700">Pump +</text>
              <text text-anchor="middle" dy="8" font-size="11" fill="white" font-weight="700">drive</text>
              <text text-anchor="middle" dy="24" font-size="11" fill="white" font-weight="700">+ PV array</text>
            </g>
            <path d="M370 130 L520 130" stroke="#0f1c54" stroke-width="2" opacity="0.6" marker-end="url(#arrowP)" />
            <g transform="translate(560,130)" class="fill-azur-700">
              <circle r="26" fill="none" stroke="#e8b54a" stroke-width="2.5" />
              <text text-anchor="middle" dy="4" font-size="18">💧</text>
            </g>
          </svg>
          <p class="mx-auto mt-4 max-w-xl text-center text-xs leading-relaxed text-encre-faint">
            The four measurements taken on site together determine one coherent system — not four
            separate calculations.
          </p>
        </div>
      </div>
    </section>

    <!-- Tax advantage: VAT exemption (agricultural pumping only) -->
    <section class="section px-4">
      <div class="mx-auto max-w-6xl">
        <div class="grid gap-10 lg:grid-cols-[1.1fr_1fr] lg:items-center">
          <div class="v2-rise">
            {/* Eyebrow demoted to lune (brass discipline #2) — W274 chapter 02 */}
            <p class="tech-label v2-kicker rule-brass text-lune"><span class="mr-2 font-display text-xs text-azur-200/80" aria-hidden="true">02</span>Verified tax advantage</p>
            <h2 class="display v2-section-title mt-5 text-white">Agricultural pumping, VAT-exempt</h2>
            <p class="v2-lead mt-5 text-lune-soft">
              In Morocco, solar water-pumping systems are exempt from VAT — and the exemption covers
              the lot: the pump as much as the panels that power it. For a farm, that is money that
              never lands on the equipment bill, and it brings forward the day the system has paid for
              itself in diesel never burned.
            </p>
          </div>
          <div class="v2-rise cine-card p-7" style="--v2-i:1">
            <h3 class="display text-xl text-white">Not to be confused</h3>
            <p class="mt-3 text-sm leading-relaxed text-lune-soft">
              The exemption is for <strong class="text-white">agricultural pumping</strong> — the pump
              and its array — and <strong class="text-white">it does not extend to residential rooftop
              photovoltaics</strong>. Solar on a house roof still carries VAT: two separate regimes,
              and we will never promise to carry one across to the other.
            </p>
          </div>
        </div>
      </div>
    </section>

    {/* W261 — Diesel/butane vs solar framing: the SAME story as the agricole
        quote engine (decompensated butane costs more than the sticker price
        suggests, diesel is volatile, solar fixes the cost), with NO invented
        MAD/litre figure — those values are volatile and "to confirm" on the
        ERP engine side, never published as a fixed fact on the marketing
        site. The real calculation happens at the study, with the day's price
        and the pump's measured consumption. */}
    <div class="v2-seam" aria-hidden="true"></div>
    <section class="section bg-blanc-azur px-4 text-encre">
      <div class="mx-auto max-w-6xl">
        <p class="tech-label v2-kicker rule-brass text-azur-600">The calculation that matters to you</p>
        <h2 class="display v2-section-title mt-5">Against diesel, against butane</h2>
        <p class="v2-lead mt-5 max-w-2xl text-encre-soft">
          A farmer doesn't compare kWc, they compare tanks. Every hour of diesel or butane pumping
          has a cost that moves with the day's price — and decompensated butane costs, in reality,
          considerably more than the subsidized cylinder's sticker price suggests. Solar fixes that
          cost at zero once the system is paid off: the sun doesn't send an invoice.
        </p>
        <div class="mt-10 grid gap-6 md:grid-cols-2">
          <div class="v2-rise border-t-2 border-azur-900 bg-blanc p-6">
            <h3 class="display text-lg text-azur-700">Diesel & butane</h3>
            <p class="mt-3 text-sm leading-relaxed text-encre-soft">
              A recurring cost, indexed to a price that moves, tank after tank, season after season.
              Decompensated butane weighs even heavier on the real bill than the subsidized
              cylinder's sticker price suggests.
            </p>
          </div>
          <div class="v2-rise border-t-2 border-brass-400 bg-blanc p-6">
            <h3 class="display text-lg text-azur-700">Solar pumping</h3>
            <p class="mt-3 text-sm leading-relaxed text-encre-soft">
              A one-time investment, VAT-exempt, then a running cost close to zero: the crossover
              point with diesel or butane depends on your actual consumption — which is exactly
              what the study calculates, figure by figure, for your plot.
            </p>
          </div>
        </div>
        <p class="mx-auto mt-8 max-w-2xl border-l-4 border-azur-600 pl-4 text-sm leading-relaxed text-encre-soft">
          The day's fuel price and your pump's actual running hours change the calculation from one
          farm to the next: that's why the exact figure — and the number of years to payback —
          comes out of the study, never a national average. <a href={devisHref} class="border-b border-azur-600 pb-0.5 font-semibold text-azur-600 transition-colors hover:text-azur-700">Request my study →</a>
        </p>
      </div>
    </section>

    {/* W261 — Financing/subsidy card, gated WG11: FDA 30% + Saquii are NOT
        republished as a confirmed fact until the terms have been verified
        with the primary sources (DPA/ORMVA/CAM) — see docs/WEB_PLAN.md WG11.
        Shown here as a lead to verify, never as a Taqinor offer or
        partnership. */}
    <section class="section px-4">
      <div class="mx-auto max-w-6xl">
        <div class="v2-rise cine-card border-2 border-dashed border-white/25 p-7">
          {/* W274 chapter 03 */}
          <p class="tech-label v2-kicker rule-brass text-lune"><span class="mr-2 font-display text-xs text-azur-200/80" aria-hidden="true">03</span>Financing lead — to verify</p>
          <h2 class="display mt-3 text-xl text-white">Agricultural subsidy (FDA) and financing (Saquii)</h2>
          <p class="mt-4 max-w-2xl text-sm leading-relaxed text-lune-soft">
            The Moroccan state has historically offered an Agricultural Development Fund subsidy for
            solar pumping, and Crédit Agricole du Maroc offers financing mechanisms dedicated to
            agricultural solar. Current rates, caps and conditions change and depend on your DPA/
            ORMVA — we publish no percentage or amount until it has been verified with the relevant
            body.
          </p>
          <p class="mt-4 text-sm font-semibold text-lune-faint">
            To verify with your DPA before any commitment — Taqinor is neither a lender nor a
            subsidizing body and guarantees no eligibility.
          </p>
        </div>
      </div>
    </section>

    <!-- Links block / business segment -->
    <section class="section border-t border-white/10 px-4">
      <div class="mx-auto max-w-6xl">
        {/* Eyebrow demoted to lune (brass discipline #2) — W274 chapter 04 */}
        <p class="tech-label v2-kicker rule-brass text-lune"><span class="mr-2 font-display text-xs text-azur-200/80" aria-hidden="true">04</span>To go further</p>
        <h2 class="display v2-section-title mt-5 text-white">Agriculture, a business segment</h2>
        <p class="v2-lead mt-5 max-w-2xl text-lune-soft">
          Solar pumping belongs to the working farm, not to the plug-in kit you wire up yourself.
          After the borehole survey and the sizing calculation, we install tier-1 hardware and the
          system is handed over with its full technical file.
        </p>
        <div class="mt-10 flex flex-wrap gap-3">
          <a href={devisHref} class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">Request an assessment →</a>
          <a href={L('/professionnel')} class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">Business solar →</a>
          <a href={L('/équipement')} class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">See the equipment →</a>
        </div>
      </div>
    </section>

    <!-- W263 — shared FAQ (maintenance/price/included-excluded/timelines/
         warranties) + per-component warranty, BEFORE the final CTA.
         schema={false}: /faq stays the only FAQPage JSON-LD (W19).
         Solar pumping fits neither an inverter nor a battery (repo fact). -->
    <Faq schema={false} heading="Frequently asked questions — solar pumping" items={faqItems} />
    <section class="section-tight bg-blanc-azur px-4 text-encre">
      <ServiceWarrantyTable includeOnduleur={false} includeBatterie={false} />
    </section>

    <CtaBand title="A solar pumping project? Start with the free study." href={devisHref} />

    <StickyCta />
  </div>
</Layout>
