---
/**
 * EN — FAQ (W67). Faithful translation of /faq ; EVERY figure (MAD, kWc, kW,
 * MW, %, years, 18 months, 9 June 2026, fines, 87.4 %) is kept EXACT. The Faq
 * component emits one FAQPage for this locale. FR untouched.
 */
import Layout from '../../layouts/Layout.astro';
import V2Enhance from '../../components/V2Enhance.astro';
import Article33Ribbon from '../../components/Article33Ribbon.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import Faq from '../../components/Faq.astro';
import CtaBand from '../../components/CtaBand.astro';
import StickyCta from '../../components/StickyCta.astro';
import { getLocaleFromPath } from '../../i18n/utils';
import { localizeNavHref } from '../../i18n/pages';

const locale = getLocaleFromPath(Astro.url.pathname);
const L = (href: string) => localizeNavHref(href, locale);
const devisHref = L('/devis/mon-toit');

const faq = [
  // — Price & orders of magnitude —
  {
    cluster: 'Price & orders of magnitude',
    q: 'How much does a residential solar installation cost?',
    a: "There's no price per square metre: it all starts from your bill and your roof. To set ideas, a villa paying around 1 500 MAD a month is most often equipped with 4 to 6 kWc. The online assessment returns a range in a few seconds; the real figure comes after the technical visit.",
  },
  {
    q: "How is an installation's price calculated?",
    a: 'The price follows the power, and the power follows your consumption. Take an order of magnitude, not a quote: a villa with about 2 000 MAD of monthly bill generally aims for 6 kWc, an investment of the order of 60 000 to 75 000 MAD (indicative range, 2026). Where your figure lands within that range depends on the roof and the equipment chosen, which the technical visit settles.',
  },
  {
    q: 'From what bill is solar worthwhile?',
    a: 'Below about 1 000 MAD a month, the return on investment generally goes past the 7-year mark, and we will tell you frankly rather than equipping you for nothing. Above 10 000 MAD a month, you are no longer in the residential bracket: your case deserves a dedicated study (see the Business page).',
  },
  // — Financing (W297: AEO/GEO — self-contained Q&A block) —
  {
    cluster: 'Financing',
    q: 'How can I finance a solar installation in Morocco?',
    a: "Three concrete ways, no detours. Most of our clients pay in cash, and the installation then pays for itself through the electricity they stop buying from the grid. Others go through a standard consumer credit taken out directly with their bank — Taqinor is not involved and takes no commission. For businesses, green financing lines exist for renewable-energy projects, but the arrangement is between you and your bank. The detail is on the Financing & Returns page.",
  },
  {
    q: 'Does Taqinor offer a loan or a subsidy?',
    a: "No, and it's better to know that before signing anything. Taqinor is not a lending institution: we install and warranty solar equipment, we don't sell any financial product and grant no loans. No special residential subsidy exists either for a private solar installation in Morocco, nor a residential VAT exemption — VAT applies normally to a turnkey installation. Be wary of any claim to the contrary.",
  },
  // — How panels work —
  {
    cluster: 'How panels work',
    q: 'Do panels work at night or in cloudy weather?',
    a: "At night, no: no light, no current. Overcast weather is another story — the panels still produce, simply less, because the photovoltaic cell also responds to diffuse light, not just direct sun. In Morocco, with more than 300 days of sun a year and some of the best irradiation in the world, the days that are truly “lost” can be counted on one hand. That is what makes self-consumption so worthwhile here.",
  },
  {
    q: 'Does shade reduce production a lot?',
    a: 'More than you might think. In a conventional series-string installation, shade falling on a single panel holds back the whole row, a bit like bulbs wired in series. A badly placed chimney is enough to cut 20 to 30 % of the output. Power optimisers or micro-inverters (one per panel) ease the effect, at an added cost. This is precisely one of the first things we note on the technical visit.',
  },
  {
    q: 'Do the panels need cleaning, and how often?',
    a: "In Morocco, yes: dust, Saharan sand and bird droppings eat into the output. Winter rains do part of the job, but a flat or low-tilt mount fouls faster than a roof at 30°. In practice, a rinse with clean water (no abrasive detergent) two to three times a year is enough in most regions; in very dusty areas or by the sea, expect more like a monthly pass. The monitoring warns you as soon as an abnormal drop sets in.",
  },
  {
    q: 'What happens if the grid goes down?',
    a: 'It all depends on the inverter. A conventional grid-tied inverter cuts out automatically, by anti-islanding — a legal safety requirement that protects grid technicians — so you stay without power even in full sun. A hybrid inverter paired with a battery, by contrast, switches to standalone mode within milliseconds and keeps your essentials running: lighting, fridge, internet box. That is one of the main reasons to add a battery where the grid is unstable.',
  },
  // — Law 82-21 —
  {
    cluster: 'Law 82-21',
    q: 'What does Law 82-21 say for individuals?',
    a: 'For the vast majority of villas, it is good news: in low voltage and under 11 kW, you fall under the lightest regime, the declaration. A formality to file before commissioning, not an authorization to obtain. And we are the ones who prepare and file it for you.',
  },
  {
    q: 'What are the three regimes of Law 82-21?',
    a: 'It all hinges on your power. Declaration: under 11 kW in low voltage, or an isolated off-grid site. Connection agreement: from the declaration threshold up to 5 MW, in low or medium voltage. Authorization: from 5 MW, in medium, high or very high voltage. The implementing decree 2-25-100 applies since 9 June 2026.',
  },
  // — Article 33 —
  {
    cluster: 'Article 33 (regularization)',
    q: 'My existing installation is not declared. What should I do?',
    a: "Don't wait. Article 33 gives you an 18-month window, opened on 9 June 2026, to regularize an installation already in place — after that deadline it closes. The wisest move is to start the process now; the Regularization page details the 5-step procedure.",
  },
  {
    q: 'What does a non-regularized installation risk?',
    a: 'As long as it is not regularized, an existing installation remains, in the eyes of Law 82-21, in an irregular situation. The possible consequences range from a fine — 2 000 to 5 000 MAD for operating without the required declaration, and 100 000 to 1 000 000 MAD without a connection agreement or authorization — to formal notice, shutdown of the installation, or even its disconnection from the grid. So many good reasons to take advantage of the Article 33 window.',
  },
  // — Batteries / self-consumption —
  {
    cluster: 'Batteries & self-consumption',
    q: 'Do I need batteries?',
    a: "Often no, and that is rarely the expected answer. When you consume mostly during the day, the energy flows straight to your appliances, and that direct self-consumption pays more than any storage. A battery comes into its own for night-time use or to ride out an outage; your consumption curve is what decides, and we look at it closely in the study.",
  },
  {
    q: 'How long does an LFP battery last?',
    a: 'The lithium iron phosphate (LFP) batteries we fit — such as the Dyness — last far longer than the old lead-acid batteries. The Dyness is rated for 6,000 cycles at 90 % depth of discharge, with a 10-year warranty at 70 % or more of capacity retained. In ordinary residential use (around one cycle a day), it often passes 12 to 15 years before dropping below that threshold. LFP chemistry is also the safest at home: unlike NMC chemistries, it does not release oxygen if it overheats.',
  },
  // — Warranties —
  {
    cluster: 'Warranties',
    q: 'What are the warranties?',
    a: 'Component by component. Panels: 12 years on the product and 30 years on linear performance (at least 87.4 % of the initial power after 30 years). Deye and Huawei inverters and Dyness LFP batteries: 10 years. Galvanised steel structure: 20 years. Taqinor installation and workmanship: 2 years. The detail, with what each warranty covers, is on the Our Warranties page.',
  },
  {
    q: 'How long do panels last?',
    a: "A panel doesn't 'die' on a fixed date: it slowly loses efficiency, and the warranty frames this decline. Ours are guaranteed to deliver at least 87.4 % of their initial power after 30 years (a linear warranty). The inverter, being an electronic part, will generally need one replacement over the installation's lifetime.",
  },
  // — Electric vehicle —
  {
    cluster: 'Electric vehicle',
    q: 'Can I charge my electric car with my solar panels?',
    a: "Yes, and it's one of the most cost-effective combinations. A compact car uses about 15 kWh/100 km (a Dacia Spring runs around 14 kWh, a BYD Dolphin 14.5 kWh). For a daily trip of 30 to 40 km, you need to cover about 5 kWh a day — what 2 to 3 panels of 550 W produce on average in Morocco. If you come home in the evening, a 'solar-aware' charger (such as the myenergi Zappi or the Wallbox in solar mode) automatically redirects the day's surplus to the car while you're away. The marginal cost per kilometre then falls close to zero, where petrol works out at about 93 MAD/100 km.",
  },
  {
    q: 'Do I need a battery to charge the car at night?',
    a: "It's an option, not an obligation. If you plug the car in when you get home in the evening, the sun already down, two routes are open to you. The first is to schedule charging during the grid's off-peak hours, cheaper than peak. The second rests on a home battery that stores the day's solar surplus and gives it back to the car come evening. The battery becomes worthwhile when you drive a lot and want to break free of the grid; otherwise, off-peak grid charging stays economical. We work out the figures together in the study.",
  },
  // — Timeline & process —
  {
    cluster: 'Timeline & process',
    q: 'How does an installation work, step by step?',
    a: 'Three stages, no detours. First a 60-second assessment that returns a first range. Then a direct WhatsApp exchange with a technician, with roof photos. Finally the technical visit, the complete free study, and the quote. You talk to the person who sizes the system, not a switchboard that will call back.',
  },
  // — Monitoring / after-sales —
  {
    cluster: 'Monitoring & after-sales',
    q: 'How do you track production after installation?',
    a: 'A small WiFi/Ethernet dongle links your installation to Deye Cloud: real-time production, automatic alerts, history. You receive your personal access on the mobile app, and on our side we monitor the whole fleet — the idea being to spot a deviation before you have to notice it at home.',
  },
];
---

<Layout
  title="FAQ on solar, batteries and EV charging in Morocco | Taqinor"
  description="Questions about solar energy in Morocco: prices, profitability, Law 82-21, shade, LFP batteries, electric-car charging and warranties — with figured, honest answers."
  ogSlug="accueil"
>
  <div class="v2">
    <V2Enhance />
    <Article33Ribbon />

    <Breadcrumb items={[{ label: 'Home', href: L('/') }, { label: 'Frequently asked questions' }]} />

    <section class="px-4 pb-10 pt-16 text-white sm:pt-20">
      <div class="mx-auto max-w-3xl">
        <p class="tech-label v2-kicker rule-brass cine-in text-lune">FAQ</p>
        <h1 class="display v2-page-title cine-in mt-5 [animation-delay:120ms]">Your questions, our answers</h1>
        <p class="v2-lead cine-in mt-6 max-w-xl text-white/85 [animation-delay:240ms]">
          Here, without spin, is what buyers ask us before signing: what it costs, from when it pays
          off, what Law 82-21 says, what the warranties cover and how we track production. Is your
          question missing?
          <a href={L('/contact')} class="border-b border-azur-200/60 pb-0.5 font-semibold text-azur-200 transition-colors hover:text-white">Write to us.</a>
        </p>
      </div>
    </section>

    <Faq items={faq} heading="Frequently asked questions" />

    <CtaBand title="One last question? A free study answers it." href={devisHref} seam={false} />

    <StickyCta />
  </div>
</Layout>
