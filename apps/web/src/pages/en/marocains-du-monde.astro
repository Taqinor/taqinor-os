---
/**
 * EN — Moroccans abroad / MRE (W67). Faithful translation of /marocains-du-monde ;
 * uses ONLY the positioning already on the site (WhatsApp-first, remote
 * assessment, Deye Cloud monitoring with client access, law 82-21 compliance,
 * service area = all of Morocco). No new factual claim, no invented SLA. The
 * lead WhatsApp text is translated but the leads number (WHATSAPP_LEADS) and the
 * whatsappLink helper are reused UNCHANGED. Internal links via localizeNavHref.
 * Shared component (WhatsAppMock) auto-detects locale. FR untouched.
 */
import Layout from '../../layouts/Layout.astro';
import V2Enhance from '../../components/V2Enhance.astro';
import Article33Ribbon from '../../components/Article33Ribbon.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import Picture from '../../components/Picture.astro';
import WhatsAppMock from '../../components/WhatsAppMock.astro';
import CtaBand from '../../components/CtaBand.astro';
import StickyCta from '../../components/StickyCta.astro';
import { WHATSAPP_LEADS } from '../../lib/nap';
import { whatsappLink } from '../../lib/whatsapp';
import { getLocaleFromPath } from '../../i18n/utils';
import { localizeNavHref } from '../../i18n/pages';

const locale = getLocaleFromPath(Astro.url.pathname);
const L = (href: string) => localizeNavHref(href, locale);
const devisHref = L('/devis/mon-toit');

const wa = whatsappLink(WHATSAPP_LEADS, 'Hello, I am a Moroccan living abroad and I would like to study a solar installation for my villa in Morocco.');

const etapes = [
  { n: '1', body: 'A 60-second assessment gives you a first range, wherever you live and whatever the time difference.' },
  { n: '2', body: 'You talk live on WhatsApp with the technical team. The roof photos are yours to send — or a relative back home sends them; we handle the rest remotely.' },
  { n: '3', body: 'We come on site for the technical visit and the full study, free of charge, then hand you the quote. At no point is your presence in Morocco required to get started.' },
];
---

<Layout
  title="Moroccans abroad: an installation managed from Morocco, tracked from abroad | Taqinor"
  description="You live abroad, your roof is in Morocco. Assessment and coordination over WhatsApp, technical visit on site, then your villa's production visible on Deye Cloud wherever you are. Law 82-21 compliance handled for you, with no trip required."
  ogSlug="accueil"
>
  <div class="v2">
    <V2Enhance />
    <Article33Ribbon />

    <Breadcrumb items={[{ label: 'Home', href: L('/') }, { label: 'Moroccans abroad' }]} />

    {/* ── CINEMATIC HERO (~90svh) — photo is the protagonist. Hero photo stays
        the LCP element: NEVER .v3-grade here (LCP protection), only the canonical
        scrim carries AA contrast for the headline. Eyebrow demoted to lune (brass
        discipline); one brass CTA + one ghost WhatsApp. ── */}
    <section class="relative isolate mt-4 flex min-h-[90svh] flex-col justify-end overflow-hidden text-white">
      <div class="v2-hero-media absolute inset-0 -z-10">
        <Picture name="crepuscule-penthouse" alt="" widths={[1600, 1024, 640]} ratio={4 / 3} sizes="100vw"
          loading="eager" fetchpriority="high" class="h-full w-full object-cover object-[65%_40%]" />
        <div class="hero-scrim absolute inset-0"></div>
      </div>

      {/* Scroll invitation — static under prefers-reduced-motion */}
      <div class="absolute bottom-6 left-1/2 -translate-x-1/2 scroll-chevron" aria-hidden="true">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="6 9 12 15 18 9" />
        </svg>
      </div>

      <div class="mx-auto w-full max-w-6xl px-4 pb-24 pt-32 sm:pb-32">
        <p class="tech-label v2-kicker rule-brass cine-in text-lune">Moroccans abroad · MRE</p>
        <h1 class="display v2-page-title cine-in cine-in-1 mt-6 max-w-[22ch]">
          Are you a Moroccan living abroad?
        </h1>
        <p class="v2-lead cine-in cine-in-2 mt-6 max-w-2xl text-white/85">
          Your roof is in Morocco, you are elsewhere. We take charge of your villa's installation
          from study to production monitoring, and it all runs through a WhatsApp thread
          with a technician — a human who answers, never a switchboard or a queue.
        </p>
        <div class="cine-in cine-in-3 mt-10 flex flex-wrap items-center gap-3">
          {/* ONE brass CTA (brass discipline) — gold is authorised here */}
          <a href={devisHref} class="glow bg-brass-400 px-8 py-4 text-lg font-bold text-azur-950 transition-colors hover:bg-brass-300">
            Start my remote study →
          </a>
          {/* Ghost WhatsApp — white outline, no brass */}
          <a href={wa} rel="noopener" class="inline-flex items-center gap-2 border border-white/40 px-6 py-3.5 text-base font-semibold text-white backdrop-blur-sm transition-colors hover:border-white hover:bg-white/10">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 0 0-8.6 15.1L2 22l5-1.3A10 10 0 1 0 12 2Zm5.4 14.1c-.2.6-1.3 1.2-1.8 1.2-.5.1-1 .2-3.3-.7-2.8-1.1-4.6-4-4.7-4.2-.1-.2-1.1-1.5-1.1-2.9s.7-2 1-2.3c.2-.3.5-.3.7-.3h.5c.2 0 .4 0 .6.4l.9 2.1c.1.2.1.4 0 .6l-.4.6-.5.5c-.2.2-.3.4-.1.7.2.3.9 1.4 1.9 2.3 1.3 1.1 2.3 1.5 2.6 1.6.3.1.5.1.7-.1l1-1.2c.2-.3.4-.2.7-.1l2 1c.3.1.5.2.6.4 0 .1 0 .7-.3 1.4Z"/></svg>
            WhatsApp direct
          </a>
        </div>
      </div>
    </section>

    <!-- Remote, but on the ground -->
    <section class="border-y border-white/10 px-4 py-20 sm:py-24">
      <div class="mx-auto grid max-w-6xl items-center gap-12 lg:grid-cols-[1.1fr_1fr]">
        <div class="v2-rise">
          <p class="tech-label v2-kicker rule-brass text-lune">How it works</p>
          <h2 class="display v2-section-title mt-5 max-w-md text-white">The time zone doesn't stop us</h2>
          <p class="v2-lead mt-5 max-w-md text-lune-soft">
            The assessment reaches you on WhatsApp, you talk with the technician whenever it suits
            you, roof photos in hand, right up to the on-site visit. The only moment someone is
            needed in Morocco is to open the gate — and that someone isn't
            necessarily you.
          </p>
          <p class="mt-4 inline-flex items-center gap-2 text-sm font-semibold text-white">
            <span class="fig lum">⏱</span> WhatsApp reply within 1 h, 7 days a week — Morocco time, whatever your own time difference.
          </p>
          <ol class="mt-8 space-y-3 text-sm text-lune">
            {etapes.map((e) => (
              <li class="flex gap-3"><span class="fig lum text-lg">{e.n}.</span>{e.body}</li>
            ))}
          </ol>
          <a href={wa} rel="noopener" class="mt-8 inline-flex items-center gap-2 bg-ok-600 px-6 py-3.5 text-base font-bold text-white transition-opacity hover:opacity-90">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 0 0-8.6 15.1L2 22l5-1.3A10 10 0 1 0 12 2Zm5.4 14.1c-.2.6-1.3 1.2-1.8 1.2-.5.1-1 .2-3.3-.7-2.8-1.1-4.6-4-4.7-4.2-.1-.2-1.1-1.5-1.1-2.9s.7-2 1-2.3c.2-.3.5-.3.7-.3h.5c.2 0 .4 0 .6.4l.9 2.1c.1.2.1.4 0 .6l-.4.6-.5.5c-.2.2-.3.4-.1.7.2.3.9 1.4 1.9 2.3 1.3 1.1 2.3 1.5 2.6 1.6.3.1.5.1.7-.1l1-1.2c.2-.3.4-.2.7-.1l2 1c.3.1.5.2.6.4 0 .1 0 .7-.3 1.4Z"/></svg>
            Start on WhatsApp
          </a>
        </div>
        <div class="v2-rise">
          <WhatsAppMock />
        </div>
      </div>
    </section>

    <!-- The real worries when you order from far away -->
    <section class="border-b border-white/10 px-4 py-20 sm:py-24">
      <div class="mx-auto max-w-6xl">
        <p class="tech-label v2-kicker rule-brass text-lune">What holds you back, unspoken</p>
        <h2 class="display v2-section-title mt-5 max-w-2xl text-white">Three fears nobody says out loud</h2>
        <p class="v2-lead mt-5 max-w-2xl text-lune-soft">
          Entrusting a project you can't watch over yourself, paying a large sum from another
          country, touching the house that carries a family story: these hesitations are
          legitimate. Here is how we take them seriously, without empty promises.
        </p>
        <div class="mt-10 grid gap-6 md:grid-cols-3" data-stagger>
          <div class="v2-rise cine-card flex flex-col p-7" style="--v2-i:0">
            <p class="tech-label text-lune">Trust</p>
            <h3 class="display mt-2 text-xl text-white">&ldquo;I won't be there to check&rdquo;</h3>
            <p class="mt-3 flex-1 text-sm leading-relaxed text-lune-soft">
              It's the most common worry, and the most justified. Our answer isn't a speech, it's
              safeguards: a written, itemised quote before a single dirham changes hands, payment
              staged against the progress of the work rather than all up front, and the freedom for
              you to appoint someone close — a brother, a cousin, a trusted neighbour — to come and
              witness the install in your place. You only settle the balance once production is read
              off Deye Cloud.
            </p>
            <p class="mt-3 text-sm leading-relaxed text-lune-soft">
              And if no one can come in person? A <strong class="text-white">power of attorney</strong>
              — a simple signed letter naming you, or someone close to you, to approve the quote and
              take delivery of the work on your behalf — is enough to move the file forward without
              your physical presence. We give you the exact wording to send once the study is ready.
            </p>
          </div>
          <div class="v2-rise cine-card flex flex-col p-7" style="--v2-i:1">
            <p class="tech-label text-lune">Payment</p>
            <h3 class="display mt-2 text-xl text-white">&ldquo;How do I pay from abroad?&rdquo;</h3>
            <p class="mt-3 flex-1 text-sm leading-relaxed text-lune-soft">
              The quote is drawn up in dirhams, the real cost of the work in Morocco — you know
              exactly what you're committing to, with no hidden conversion. The path most of our
              clients abroad follow: a bank transfer to the company's account, in Morocco, in
              dirhams — staged against the progress of the work rather than all up front. Many then
              think in euros or Canadian dollars depending on the exchange rate of the moment, and
              rely on a dirham account opened here or on the person who represents them back home.
              The exact bank fees and payment schedule are confirmed with your advisor at quote
              stage — we don't play the role of a bank and never touch your currency exchange.
            </p>
          </div>
          <div class="v2-rise cine-card flex flex-col p-7" style="--v2-i:2">
            <p class="tech-label text-lune">The house</p>
            <h3 class="display mt-2 text-xl text-white">&ldquo;It's my parents' house&rdquo;</h3>
            <p class="mt-3 flex-1 text-sm leading-relaxed text-lune-soft">
              A villa back home isn't just a roof: it's often the one where the family gathers in
              summer, the one that took years to build, sometimes the one of a parent who is no longer
              there. We work on it with that respect. Careful fixings, clean cabling, nothing that
              spoils the façade — and the assurance that when you come back from holiday you find an
              improved home, not a job to redo.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Remote monitoring + compliance -->
    <section class="px-4 py-20 sm:py-24">
      <div class="mx-auto grid max-w-6xl gap-8 md:grid-cols-3" data-stagger>
        <div class="v2-rise" style="--v2-i:0">
          <h3 class="display text-xl text-white">Your villa, on your screen</h3>
          <p class="mt-3 text-sm leading-relaxed text-lune-soft">Every installation reports to Deye Cloud, client access included. From the mobile app, you watch what your roof in Morocco produces in real time — useful to check, remotely, that everything is running while the villa stands empty.</p>
        </div>
        <div class="v2-rise" style="--v2-i:1">
          <h3 class="display text-xl text-white">The paperwork, without you</h3>
          <p class="mt-3 text-sm leading-relaxed text-lune-soft">Declaration or law 82-21 regularization: we read your case, identify the regime and assemble the file — no back-and-forth to the country to plan for you. <a href={L('/loi-82-21')} class="border-b border-white/40 pb-0.5 font-semibold text-white transition-colors hover:border-white">See the regimes →</a></p>
        </div>
        <div class="v2-rise" style="--v2-i:2">
          <h3 class="display text-xl text-white">From one city to another</h3>
          <p class="mt-3 text-sm leading-relaxed text-lune-soft">Casablanca, Rabat, Marrakech, Tangier, Agadir — and the rest of the country. Wherever the family home is, we go there. <a href={L('/realisations')} class="border-b border-white/40 pb-0.5 font-semibold text-white transition-colors hover:border-white">See our projects →</a></p>
        </div>
      </div>
      <div class="mx-auto mt-10 flex max-w-6xl flex-wrap gap-3">
        <a href={L('/résidentiel')} class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">Residential solar →</a>
        <a href={L('/pourquoi-taqinor')} class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">Why Taqinor →</a>
      </div>
    </section>

    <CtaBand title="Launch the study from abroad — it costs you nothing." href={devisHref} />

    <StickyCta />
  </div>
</Layout>
