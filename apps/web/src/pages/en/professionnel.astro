---
/**
 * EN — Business & industrial solar (W67). Faithful translation of /professionnel ;
 * EVERY figure kept EXACT in Latin digits (3–5 years, +20 years, 5 MW, 17,04 kWc,
 * 21 406 kWh/an, 3,72 kWc, ref. 468, Canadian Solar 710 Wc, Deye 15 kW, law
 * 82-21) — UK spelling (authorisation). Price-bracket data + solar math (localEstimateBand / formatMAD) reused
 * UNCHANGED — only visible labels translated. Internal links via localizeNavHref.
 * Shared components (GarantiesTeaser, Testimonials) auto-detect locale. FR untouched.
 *
 * W249 — Single funnel: the closing act is no longer DiagnosticForm but the
 * instant-estimate widget shared with the homepage (InstantEstimator, W250).
 * DiagnosticForm stays intact in the codebase as the documented fallback.
 *
 * ELEVATION (W237) — mirrors /professionnel.astro elevation treatment:
 *  1. Cinematic hero (~92svh) full-frame photo, eyebrow text-lune, ONE brass CTA
 *     + ghost WhatsApp, scroll chevron, hero-scrim-v3, hero key figures .lum,
 *     content anchored low;
 *  2. Brass discipline: gold only on .lum figures and the one primary CTA;
 *     eyebrows demoted to text-lune;
 *  3. Warm grade (.v3-grade) on content photos only (never the hero/LCP image);
 *  4. .section / .section-tight rhythm + .seam-soft seams;
 *  5. Single motion language .cine-in / .v2-rise.
 */
import Layout from '../../layouts/Layout.astro';
import V2Enhance from '../../components/V2Enhance.astro';
import Article33Ribbon from '../../components/Article33Ribbon.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import InstantEstimator from '../../components/InstantEstimator.astro';
import CtaBand from '../../components/CtaBand.astro';
import Picture from '../../components/Picture.astro';
import StickyCta from '../../components/StickyCta.astro';
import ZelligeDivider from '../../components/ZelligeDivider.astro';
import GarantiesTeaser from '../../components/GarantiesTeaser.astro';
import Testimonials from '../../components/Testimonials.astro';
import CertLogoRow from '../../components/CertLogoRow.astro';
import Faq from '../../components/Faq.astro';
import ServiceWarrantyTable from '../../components/ServiceWarrantyTable.astro';
import RelatedLinks from '../../components/RelatedLinks.astro';
import { localEstimateBand } from '../../lib/billRange';
import { formatMAD } from '../../lib/format';
import { getLocaleFromPath } from '../../i18n/utils';
import { localizeNavHref } from '../../i18n/pages';
import { WHATSAPP_LEADS } from '../../lib/nap';
import { whatsappLink } from '../../lib/whatsapp';
import { serviceFaqItems } from '../../lib/serviceFaq';

const locale = getLocaleFromPath(Astro.url.pathname);
const L = (href: string) => localizeNavHref(href, locale);

const waDirect = whatsappLink(WHATSAPP_LEADS, 'Hello, I would like a study for a solar installation.');

// W263 — shared FAQ + per-component warranty, EN.
const faqItems = serviceFaqItems('professionnel', 'en');
// W337 — "visit a real site" invitation, same mechanic as pourquoi-taqinor.astro
const waVisite = whatsappLink(WHATSAPP_LEADS, 'Hello, I would like to visit a real business installation.');

// W337 — RC Pro / liability insurance: no-op-safe scaffold (WG8). No real data
// exists yet from the founder → stays `null` and the section renders NOTHING
// until the value is supplied. Never invent a policy number.
const RC_PRO_ASSURANCE: string | null = null;

// W260 — self-identification sub-cards by building type (instead of one
// generic block): a C&I buyer recognises their site type before thinking in
// kWc. One concrete proof point per card.
// W335 — each segment card now carries TWO lines: a financial line (the CFO
// argument) and a technical/operational line (the on-site argument) — no new
// figure, just the same already-published proof split into two reading angles.
const segments = [
  {
    n: '01', title: 'Warehouse / plant',
    body: "Every kWh enters the cost price of a manufactured part. A wide, flat roof pays for itself in 3 to 5 years and produces exactly when the machines are running — production lands when demand is there.",
    proof: 'Proof: El Jadida, 17,04 kWc, 21 406 kWh/year',
    financial: 'An operating cost that becomes an asset paid off in 3 to 5 years',
    technical: 'Wide, flat roof · install with no production stoppage',
  },
  {
    n: '02', title: 'Agro-industrial shed',
    body: "Drying, cold storage, processing: an agricultural shed consumes in broad daylight, exactly when the sun gives. The roof, already there, costs nothing extra to use — it carries the panels without eating a square metre of ground.",
    proof: 'Proof: galvanised steel structure, 20-year warranty, mounted on the existing roof',
    financial: 'Zero extra land tied up — the existing roof funds the structure',
    technical: 'Galvanised steel structure, 20-year warranty · no ground surface lost',
  },
  {
    n: '03', title: 'Retail / hospitality',
    body: "Air conditioning in the afternoon, laundry in the morning, pool pumps running non-stop: a shop or hotel's curve hugs the sun's, hour for hour. Solar comes to cap a cost item that climbs every season.",
    proof: 'Proof: 3-to-5-year payback, the same load logic as industry',
    financial: 'Caps a cost line that climbs every tourist season',
    technical: 'Consumption curve tracks sunshine, hour for hour',
  },
  {
    n: '04', title: 'Public sites',
    body: "A public building or clinic tolerates no outage. Hybrid inverters plus batteries hold the critical equipment through grid dips, and by day the bill drops on the rest of the building.",
    proof: 'Proof: Deye/Huawei hybrid inverters, 10-year warranty',
    financial: 'Lowers the building bill while securing continuity of service',
    technical: 'Hybrid inverters + batteries · continuity on critical equipment',
  },
];

const PRIX_PAR_KWC = { bas: 8500, haut: 11000 };
const arrondi10k = (v: number) => Math.round(v / 10000) * 10000;
// W335 — "cumulative saving over 20 years": derived from already-published
// CONSTANTS (investment per kWc + payback range), no new figure. Logic:
// once payback is reached, the installation keeps producing up to the
// 30-year performance guarantee; we project over a 20-year horizon (the same
// horizon as the structure and the accounting depreciation cited below) the
// multiple investment × (20 years / payback duration) — an order of
// magnitude, never a study figure.
const HORIZON_YEARS = 20;
const cumulativeSaving = (investMin: number, investMax: number, paybackMinYrs: number, paybackMaxYrs: number) => {
  const low = arrondi10k((investMin * HORIZON_YEARS) / paybackMaxYrs);
  const high = arrondi10k((investMax * HORIZON_YEARS) / paybackMinYrs);
  return `${formatMAD(low)} – ${formatMAD(high)}`;
};

const proBrackets = (['5000-10000', 'gt10000'] as const).map((id) => {
  const band = localEstimateBand(id);
  const investMin = arrondi10k(band.kwcMin * PRIX_PAR_KWC.bas);
  const investMax = arrondi10k(band.kwcMax * PRIX_PAR_KWC.haut);
  return {
    bill: id === '5000-10000' ? '5 000 – 10 000 MAD / month' : 'Over 10 000 MAD / month',
    kwc: band.kwcLabel,
    investMin,
    invest:
      id === 'gt10000'
        ? `from ${formatMAD(investMin)} — dedicated study`
        : `${formatMAD(investMin)} – ${formatMAD(investMax)}`,
    payback: band.paybackLabel,
    // "3 to 5 years" / "3 to 7 years" → numeric bounds for the 20-year projection.
    saving20yrs: cumulativeSaving(investMin, investMax, 3, 5),
    exemple: id === '5000-10000' ? 'Real example: ref. 468 — 17,04 kWc, El Jadida, April 2026' : null,
  };
});

// WB14 (2026-07-04) — extractable AEO answer derived from the first business
// bracket above; no new figure.
const proInvestFromLabel = formatMAD(proBrackets[0]?.investMin ?? 0);
const proPaybackLabel = proBrackets[0]?.payback ?? '3–5 years';

// W335 — structural Purchase (CAPEX) / Leasing (OPEX) comparator: who owns,
// who books depreciation, day-one cash impact. NO named rate or bank — the
// named boxes (CAM, Maghrebail…) live on /financement (W258/WG11).
const capexOpex = [
  {
    criterion: 'Who owns the installation',
    purchase: 'Your company, from commissioning',
    leasing: 'The lessor for the contract term; end-of-contract buyout option depending on the structure',
  },
  {
    criterion: 'Who books the depreciation',
    purchase: 'Your company, as a fixed asset on its balance sheet (see the tax section below)',
    leasing: 'The lessor; you book the rent as an operating expense',
  },
  {
    criterion: 'Day-one cash impact',
    purchase: 'Immediate cash outflow (or on loan drawdown if financed)',
    leasing: 'No upfront cash outflow — a periodic rent replaces the avoided bill',
  },
];
---

<Layout
  title="Industrial, hotel and clinic solar in Morocco — paid off in 3 to 5 years | Taqinor"
  description="17,04 kWc in El Jadida, 21 406 kWh a year: medium-voltage solar installations sized on your load curves, surplus valued under law 82-21, from grid connection (≤ 5 MW) to authorisation."
  ogSlug="professionnel"
>
  <div class="v2">
    <V2Enhance />
    <Article33Ribbon />

    <Breadcrumb items={[{ label: 'Home', href: L('/') }, { label: 'Business' }]} />

    {/* ── 1 · CINEMATIC HERO (~92svh) — the industrial sunset as protagonist ── */}
    <section class="relative isolate flex min-h-[92svh] flex-col justify-end overflow-hidden text-white">
      <div class="v2-hero-media absolute inset-0 -z-10">
        {/* Full-frame hero image (LCP element) — NEVER .v3-grade here
            (LCP protection): only the raised scrim carries the warmth. */}
        <Picture name="industriel-couchant" alt="" widths={[2000, 1280, 768, 480]} ratio={16 / 9} sizes="100vw"
          loading="eager" fetchpriority="high" class="h-full w-full object-cover object-[70%_30%]" />
        {/* Raised canonical scrim (.hero-scrim-v3 → --hero-scrim-strength 0.52):
            compensates the warmth of the sunset and keeps the headline ≥ AA. */}
        <div class="hero-scrim hero-scrim-v3 absolute inset-0"></div>
      </div>

      {/* Scroll-invitation chevron — static under reduced-motion */}
      <div class="absolute bottom-6 left-1/2 -translate-x-1/2 scroll-chevron" aria-hidden="true">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="6 9 12 15 18 9" />
        </svg>
      </div>

      {/* Content anchored LOW — eyebrow demoted to lune (brass discipline) */}
      <div class="mx-auto w-full max-w-6xl px-4 pb-24 pt-32 sm:pb-32">
        <p class="tech-label v2-kicker rule-brass cine-in text-lune">Warehouse · agro-industrial · retail · public sites</p>
        <h1 class="display v2-page-title cine-in cine-in-1 mt-5 max-w-[20ch]">Your electricity cost line — you can steer it instead of enduring it</h1>
        <p class="v2-lead cine-in cine-in-2 mt-6 max-w-xl text-white/85">
          On a business site, solar isn't a showpiece: it's a production asset, paid back in 3 to
          5 years, that then delivers for more than twenty years. In El Jadida,
          17,04 kWc supply 21 406 kWh a year. The sizing, though, starts from your load
          curves — not from a template.
        </p>
        <div class="cine-in cine-in-3 mt-10 flex flex-wrap items-center gap-3">
          {/* ONE brass CTA (brass discipline) — gold is authorised here.
              W337 — reframed as an audit offer: same journey, same
              DiagnosticForm webhook, only the label changes. */}
          <a href={L('/devis/mon-toit')} class="glow-hero bg-brass-400 px-8 py-4 text-lg font-bold text-azur-950 transition-all hover:bg-brass-300">
            Free energy audit of my site →
          </a>
          {/* Ghost WhatsApp — white border, no brass */}
          <a href={waDirect} rel="noopener" class="inline-flex items-center gap-2 border border-white/40 px-6 py-3.5 text-base font-semibold text-white backdrop-blur-sm transition-colors hover:border-white hover:bg-white/10">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 0 0-8.6 15.1L2 22l5-1.3A10 10 0 1 0 12 2Zm5.4 14.1c-.2.6-1.3 1.2-1.8 1.2-.5.1-1 .2-3.3-.7-2.8-1.1-4.6-4-4.7-4.2-.1-.2-1.1-1.5-1.1-2.9s.7-2 1-2.3c.2-.3.5-.3.7-.3h.5c.2 0 .4 0 .6.4l.9 2.1c.1.2.1.4 0 .6l-.4.6-.5.5c-.2.2-.3.4-.1.7.2.3.9 1.4 1.9 2.3 1.3 1.1 2.3 1.5 2.6 1.6.3.1.5.1.7-.1l1-1.2c.2-.3.4-.2.7-.1l2 1c.3.1.5.2.6.4 0 .1 0 .7-.3 1.4Z"/></svg>
            WhatsApp direct
          </a>
        </div>
        {/* Hero key figures — gold lives on the .lum (brass discipline) */}
        <dl class="cine-in cine-in-4 mt-10 grid max-w-2xl grid-cols-3 gap-3 border-t border-white/20 pt-6 sm:gap-6">
          <div>
            <dd class="fig lum text-base sm:text-4xl" data-tally>3–5 years</dd>
            <dt class="tech-label mt-2 text-lune">Payback</dt>
          </div>
          <div>
            <dd class="fig lum text-base sm:text-4xl" data-tally>+20 years</dd>
            <dt class="tech-label mt-2 text-lune">Of production</dt>
          </div>
          <div>
            <dd class="fig lum text-base sm:text-4xl" data-tally>5 MW</dd>
            <dt class="tech-label mt-2 text-lune">Authorisation threshold</dt>
          </div>
        </dl>
      </div>
    </section>

    {/* W260 — Four self-identification cards by site type */}
    <div class="seam-soft" aria-hidden="true"></div>
    <section class="section mx-auto max-w-6xl px-4">
      {/* W274 — chapter-numbering system (01/02…), same device as index.astro,
          extended here so the editorial device is consistent site-wide. Only
          eyebrows opening a MAJOR section get a number (sub-headings inside
          the same section, like "Two possible structures" below, do not). */}
      <p class="tech-label v2-kicker rule-brass text-lune"><span class="mr-2 font-display text-xs text-azur-200/80" aria-hidden="true">01</span>Where do you see yourself?</p>
      <h2 class="display v2-section-title mt-5 text-white">Four site types, one load logic</h2>
      <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-4" data-stagger>
        {segments.map((s, i) => (
          <div class="v2-rise border-l-2 border-brass-400/60 pl-6" style={`--v2-i:${i}`}>
            <p class="fig lum text-2xl">{s.n}</p>
            <h2 class="display mt-2 text-xl text-white">{s.title}</h2>
            <p class="mt-3 text-sm leading-relaxed text-lune-soft">{s.body}</p>
            {/* W335 — two reading lines: financial (CFO) then technical/operational */}
            <dl class="mt-4 space-y-2 border-t border-white/10 pt-3">
              <div>
                <dt class="tech-label text-brass-300">Financial line</dt>
                <dd class="mt-0.5 text-xs leading-relaxed text-lune-soft">{s.financial}</dd>
              </div>
              <div>
                <dt class="tech-label text-lune">Technical line</dt>
                <dd class="mt-0.5 text-xs leading-relaxed text-lune-soft">{s.technical}</dd>
              </div>
            </dl>
            <p class="tech-label mt-3 text-lune-faint">{s.proof}</p>
          </div>
        ))}
      </div>
    </section>

    {/* Business orders of magnitude — the ledger, figures that tally up.
        Eyebrow demoted to lune (brass discipline). */}
    <div class="seam-soft" aria-hidden="true"></div>
    <section class="section px-4">
      <div class="mx-auto max-w-4xl">
        {/* W274 — chapter 02. "Two possible structures" and "What your
            procurement team checks" below stay unnumbered: sub-headings
            inside this same section, not new major sections. */}
        <p class="tech-label v2-kicker rule-brass text-lune"><span class="mr-2 font-display text-xs text-azur-200/80" aria-hidden="true">02</span>Price transparency</p>
        <h2 class="display v2-section-title mt-5 text-white">What budget to expect for a business site</h2>
        <p class="v2-lead mt-4 max-w-2xl font-semibold text-white">
          For a business site, the investment starts around {proInvestFromLabel} and pays back in
          {proPaybackLabel}, for the self-consumed share — the kWc installed there typically comes
          out cheaper than residential thanks to the continuous roof surface.
        </p>
        <p class="v2-lead mt-4 max-w-2xl text-lune-soft">
          Indicative ranges for a business roof — <strong class="text-lune">never a quote</strong>.
          The real costing locks onto your load curves and the conditions of your
          connection. On a large warehouse roof, each kWc installed comes out cheaper than in
          residential: the more continuous the surface, the lower the unit cost, so the range
          below sits beneath the one on the Residential page.
        </p>
        <div class="mt-10 border-t-2 border-brass-400/60" data-stagger>
          {proBrackets.map((b, i) => (
            <div class="v2-rise border-b border-white/10 py-5" style={`--v2-i:${i}`}>
              <div class="grid gap-1.5 sm:grid-cols-[1fr_0.7fr_1.3fr_0.7fr] sm:items-baseline sm:gap-4">
                <span class="font-display text-base font-bold text-white">{b.bill}</span>
                <span class="fig lum text-xl sm:text-2xl" data-tally>{b.kwc}</span>
                <span class="fig text-lg text-lune sm:text-xl">{b.invest}</span>
                <span class="fig text-xl text-brass-300 sm:text-2xl" data-tally>{b.payback}</span>
              </div>
              {/* W335 — cumulative saving over 20 years, derived from the columns above (no new figure) */}
              <p class="tech-label mt-2.5 text-lune-faint">
                Cumulative saving over 20 years (estimated): <span class="text-brass-300">{b.saving20yrs}</span>
              </p>
              {b.exemple && <p class="tech-label mt-1 text-lune-faint">{b.exemple}</p>}
            </div>
          ))}
        </div>

        {/* W335 — structural Purchase (CAPEX) / Leasing (OPEX) comparator — no named rate or bank here */}
        <div class="mt-14">
          <p class="tech-label v2-kicker rule-brass text-lune">Two possible structures</p>
          <h3 class="display mt-3 text-xl text-white">Purchase (CAPEX) or leasing (OPEX): what changes structurally</h3>
          <p class="v2-lead mt-3 max-w-2xl text-sm text-lune-soft">
            The named boxes (banks, rates, contracts) live on the <a href={L('/financement')} class="border-b border-white/40 pb-0.5 font-semibold text-white transition-colors hover:border-white">Financing &amp; returns</a> page
            once verified. Here, just the mechanics — who owns, who books depreciation, what it does to your day-one cash.
          </p>
          <div class="mt-6 overflow-x-auto">
            <table class="w-full min-w-[560px] border-collapse text-sm">
              <thead>
                <tr class="border-b-2 border-brass-400/60 text-left">
                  <th class="py-3 pr-4 font-display font-bold text-white">Criterion</th>
                  <th class="py-3 pr-4 font-display font-bold text-white">Purchase (CAPEX)</th>
                  <th class="py-3 font-display font-bold text-white">Leasing (OPEX)</th>
                </tr>
              </thead>
              <tbody data-stagger>
                {capexOpex.map((c, i) => (
                  <tr class="v2-rise border-b border-white/10" style={`--v2-i:${i}`}>
                    <td class="py-3 pr-4 font-semibold text-lune">{c.criterion}</td>
                    <td class="py-3 pr-4 text-lune-soft">{c.purchase}</td>
                    <td class="py-3 text-lune-soft">{c.leasing}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>

        {/* W337 — procurement trust, near the pricing table. CertLogoRow is
            already no-op-safe (WJ35): it only shows already-published
            technical facts. The RC Pro / insurance line stays a WG8 scaffold
            — it renders NOTHING until the founder supplies the real policy
            number. */}
        <div class="mt-14 border-t border-white/10 pt-10">
          <p class="tech-label v2-kicker rule-brass text-lune">What your procurement team checks</p>
          <CertLogoRow />
          {RC_PRO_ASSURANCE && (
            <p class="tech-label mt-4 text-lune-faint">Professional liability insurance: {RC_PRO_ASSURANCE}</p>
          )}
        </div>
      </div>
    </section>

    {/* Precision of the work — captioned site photos */}
    <div class="seam-soft" aria-hidden="true"></div>
    <section class="section mx-auto max-w-6xl px-4">
      <div class="grid gap-4 sm:grid-cols-2" data-stagger>
        <figure class="v2-rise cine-card group relative overflow-hidden" style="--v2-i:0">
          <Picture name="mesure-rails" alt="Marking out and measuring the mounting rails on a business roof"
            widths={[1600, 1024, 640]} ratio={4 / 3} sizes="(min-width: 640px) 50vw, 100vw"
            class="v3-grade w-full object-cover transition-transform duration-700 group-hover:scale-[1.04]" />
          <figcaption class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-nuit/95 to-transparent px-4 pb-3 pt-12">
            <span class="tech-label block text-brass-300">Nouaceur · 3,72 kWc · layout</span>
            <span class="mt-0.5 block text-xs text-lune">Every rail is marked out and measured before fixing</span>
          </figcaption>
        </figure>
        <figure class="v2-rise cine-card group relative overflow-hidden" style="--v2-i:1">
          <Picture name="equipe-trois" alt="Taqinor team in front of a long row of panels at the end of the install"
            widths={[1600, 1024, 640]} ratio={3 / 2} sizes="(min-width: 640px) 50vw, 100vw"
            class="v3-grade w-full object-cover transition-transform duration-700 group-hover:scale-[1.04]" />
          <figcaption class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-nuit/95 to-transparent px-4 pb-3 pt-12">
            <span class="tech-label block text-brass-300">El Jadida · 17,04 kWc · 21 406 kWh/an</span>
            <span class="mt-0.5 block text-xs text-lune">End of install · 24 × Canadian Solar 710 Wc · Deye 15 kW three-phase</span>
          </figcaption>
        </figure>
      </div>
    </section>

    <ZelligeDivider tone="white" />

    {/* Surplus + MV regimes — eyebrow demoted to lune (brass discipline) */}
    <section class="section px-4">
      <div class="mx-auto max-w-3xl">
        <div class="v2-rise">
          {/* W274 — chapter 03. "The two tax levers nobody cites" below stays
              unnumbered: sub-heading inside this same section. */}
          <p class="tech-label v2-kicker rule-brass text-lune"><span class="mr-2 font-display text-xs text-azur-200/80" aria-hidden="true">03</span>Law 82-21 · medium voltage</p>
          <h2 class="display v2-section-title mt-5 text-white">Make every exported kilowatt-hour pay</h2>
          <p class="v2-lead mt-5 text-lune-soft">
            Law 82-21 sets the framework for self-generation and for the surplus sent back to the
            grid. In medium voltage, the study separates from the outset what you consume on site
            from what you inject, on the terms of your connection agreement. The idea fits in one
            line: that a kilowatt-hour produced on your site never leaves without something in return.
          </p>
        </div>
        <div class="v2-rise">
          <h2 class="display v2-section-title mt-12 text-white">Which law 82-21 regime your site falls under</h2>
          <p class="v2-lead mt-5 text-lune-soft">
            Power decides. Up to 5 MW in low or medium voltage, a simple
            <strong class="text-lune">connection agreement</strong> with the grid operator is enough. Cross
            the 5 MW threshold — medium, high or very high voltage — and you move into the
            <strong class="text-lune">authorisation</strong> regime. In both cases, we assemble the technical
            file and carry it through to commissioning.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href={L('/loi-82-21')} class="inline-block border border-white/40 px-6 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">
              Identify my regime in 3 questions
            </a>
            <a href={L('/équipement')} class="inline-block border border-white/40 px-6 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">
              See the equipment we install
            </a>
          </div>
        </div>

        {/* W336 — the two CFO tax levers: CGI art. 123-22° VAT + depreciation.
            Cited law articles, never a partnership claim. WG16 (legal skim)
            still in progress: "subject to verification" note visible. */}
