---
/**
 * EN — Business & industrial solar (W67). Faithful translation of /professionnel ;
 * EVERY figure kept EXACT in Latin digits (3–5 years, +20 years, 5 MW, 17,04 kWc,
 * 21 406 kWh/an, 3,72 kWc, ref. 468, Canadian Solar 710 Wc, Deye 15 kW, law
 * 82-21) — UK spelling (authorisation). Price-bracket data + solar math (localEstimateBand / formatMAD) reused
 * UNCHANGED — only visible labels translated. Internal links via localizeNavHref.
 * Shared components (GarantiesTeaser, Testimonials, DiagnosticForm) auto-detect
 * locale. FR untouched.
 *
 * ELEVATION (W237) — mirrors /professionnel.astro elevation treatment:
 *  1. Cinematic hero (~92svh) full-frame photo, eyebrow text-lune, ONE brass CTA
 *     + ghost WhatsApp, scroll chevron, hero-scrim-v3, hero key figures .lum,
 *     content anchored low;
 *  2. Brass discipline: gold only on .lum figures and the one primary CTA;
 *     eyebrows demoted to text-lune;
 *  3. Warm grade (.v3-grade) on content photos only (never the hero/LCP image);
 *  4. .section / .section-tight rhythm + .seam-soft seams;
 *  5. Single motion language .cine-in / .v2-rise.
 */
import Layout from '../../layouts/Layout.astro';
import V2Enhance from '../../components/V2Enhance.astro';
import Article33Ribbon from '../../components/Article33Ribbon.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import DiagnosticForm from '../../components/DiagnosticForm.astro';
import CtaBand from '../../components/CtaBand.astro';
import Picture from '../../components/Picture.astro';
import StickyCta from '../../components/StickyCta.astro';
import ZelligeDivider from '../../components/ZelligeDivider.astro';
import GarantiesTeaser from '../../components/GarantiesTeaser.astro';
import Testimonials from '../../components/Testimonials.astro';
import { localEstimateBand } from '../../lib/billRange';
import { formatMAD } from '../../lib/format';
import { getLocaleFromPath } from '../../i18n/utils';
import { localizeNavHref } from '../../i18n/pages';
import { WHATSAPP_LEADS } from '../../lib/nap';
import { whatsappLink } from '../../lib/whatsapp';

const locale = getLocaleFromPath(Astro.url.pathname);
const L = (href: string) => localizeNavHref(href, locale);

const waDirect = whatsappLink(WHATSAPP_LEADS, 'Hello, I would like a study for a solar installation.');

const segments = [
  { n: '01', title: 'Industry', body: "Every kWh enters the cost price of a manufactured part. A warehouse roof, wide and flat, pays for itself in 3 to 5 years and produces exactly when the machines are running — production lands when demand is there." },
  { n: '02', title: 'Hotels', body: "Air conditioning in the afternoon, laundry in the morning, pool pumps running non-stop: a hotel's curve hugs the sun's, hour for hour. Solar comes to cap a cost item that climbs every season." },
  { n: '03', title: 'Clinics', body: "An operating theatre tolerates no outage. Hybrid inverters plus batteries hold the critical equipment through grid dips, and by day the bill drops on the rest of the building." },
];

const PRIX_PAR_KWC = { bas: 8500, haut: 11000 };
const arrondi10k = (v: number) => Math.round(v / 10000) * 10000;
const proBrackets = (['5000-10000', 'gt10000'] as const).map((id) => {
  const band = localEstimateBand(id);
  return {
    bill: id === '5000-10000' ? '5 000 – 10 000 MAD / month' : 'Over 10 000 MAD / month',
    kwc: band.kwcLabel,
    invest:
      id === 'gt10000'
        ? `from ${formatMAD(arrondi10k(band.kwcMin * PRIX_PAR_KWC.bas))} — dedicated study`
        : `${formatMAD(arrondi10k(band.kwcMin * PRIX_PAR_KWC.bas))} – ${formatMAD(arrondi10k(band.kwcMax * PRIX_PAR_KWC.haut))}`,
    payback: band.paybackLabel,
    exemple: id === '5000-10000' ? 'Real example: ref. 468 — 17,04 kWc, El Jadida, April 2026' : null,
  };
});
---

<Layout
  title="Industrial, hotel and clinic solar in Morocco — paid off in 3 to 5 years | Taqinor"
  description="17,04 kWc in El Jadida, 21 406 kWh a year: medium-voltage solar installations sized on your load curves, surplus valued under law 82-21, from grid connection (≤ 5 MW) to authorisation."
  ogSlug="professionnel"
>
  <div class="v2">
    <V2Enhance />
    <Article33Ribbon />

    <Breadcrumb items={[{ label: 'Home', href: L('/') }, { label: 'Business' }]} />

    {/* ── 1 · CINEMATIC HERO (~92svh) — the industrial sunset as protagonist ── */}
    <section class="relative isolate flex min-h-[92svh] flex-col justify-end overflow-hidden text-white">
      <div class="v2-hero-media absolute inset-0 -z-10">
        {/* Full-frame hero image (LCP element) — NEVER .v3-grade here
            (LCP protection): only the raised scrim carries the warmth. */}
        <Picture name="industriel-couchant" alt="" widths={[2000, 1280, 768, 480]} ratio={16 / 9} sizes="100vw"
          loading="eager" fetchpriority="high" class="h-full w-full object-cover object-[70%_30%]" />
        {/* Raised canonical scrim (.hero-scrim-v3 → --hero-scrim-strength 0.52):
            compensates the warmth of the sunset and keeps the headline ≥ AA. */}
        <div class="hero-scrim hero-scrim-v3 absolute inset-0"></div>
      </div>

      {/* Scroll-invitation chevron — static under reduced-motion */}
      <div class="absolute bottom-6 left-1/2 -translate-x-1/2 scroll-chevron" aria-hidden="true">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="6 9 12 15 18 9" />
        </svg>
      </div>

      {/* Content anchored LOW — eyebrow demoted to lune (brass discipline) */}
      <div class="mx-auto w-full max-w-6xl px-4 pb-24 pt-32 sm:pb-32">
        <p class="tech-label v2-kicker rule-brass cine-in text-lune">Industry · hotels · clinics</p>
        <h1 class="display v2-page-title cine-in cine-in-1 mt-5 max-w-[20ch]">Your electricity cost line — you can steer it instead of enduring it</h1>
        <p class="v2-lead cine-in cine-in-2 mt-6 max-w-xl text-white/85">
          On a business site, solar isn't a showpiece: it's a production asset, paid back in 3 to
          5 years, that then delivers for more than twenty years. In El Jadida,
          17,04 kWc supply 21 406 kWh a year. The sizing, though, starts from your load
          curves — not from a template.
        </p>
        <div class="cine-in cine-in-3 mt-10 flex flex-wrap items-center gap-3">
          {/* ONE brass CTA (brass discipline) — gold is authorised here */}
          <a href={L('/devis/mon-toit')} class="glow-hero bg-brass-400 px-8 py-4 text-lg font-bold text-azur-950 transition-all hover:bg-brass-300">
            Get my free study →
          </a>
          {/* Ghost WhatsApp — white border, no brass */}
          <a href={waDirect} rel="noopener" class="inline-flex items-center gap-2 border border-white/40 px-6 py-3.5 text-base font-semibold text-white backdrop-blur-sm transition-colors hover:border-white hover:bg-white/10">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 0 0-8.6 15.1L2 22l5-1.3A10 10 0 1 0 12 2Zm5.4 14.1c-.2.6-1.3 1.2-1.8 1.2-.5.1-1 .2-3.3-.7-2.8-1.1-4.6-4-4.7-4.2-.1-.2-1.1-1.5-1.1-2.9s.7-2 1-2.3c.2-.3.5-.3.7-.3h.5c.2 0 .4 0 .6.4l.9 2.1c.1.2.1.4 0 .6l-.4.6-.5.5c-.2.2-.3.4-.1.7.2.3.9 1.4 1.9 2.3 1.3 1.1 2.3 1.5 2.6 1.6.3.1.5.1.7-.1l1-1.2c.2-.3.4-.2.7-.1l2 1c.3.1.5.2.6.4 0 .1 0 .7-.3 1.4Z"/></svg>
            WhatsApp direct
          </a>
        </div>
        {/* Hero key figures — gold lives on the .lum (brass discipline) */}
        <dl class="cine-in cine-in-4 mt-10 grid max-w-2xl grid-cols-3 gap-3 border-t border-white/20 pt-6 sm:gap-6">
          <div>
            <dd class="fig lum text-base sm:text-4xl" data-tally>3–5 years</dd>
            <dt class="tech-label mt-2 text-lune">Payback</dt>
          </div>
          <div>
            <dd class="fig lum text-base sm:text-4xl" data-tally>+20 years</dd>
            <dt class="tech-label mt-2 text-lune">Of production</dt>
          </div>
          <div>
            <dd class="fig lum text-base sm:text-4xl" data-tally>5 MW</dd>
            <dt class="tech-label mt-2 text-lune">Authorisation threshold</dt>
          </div>
        </dl>
      </div>
    </section>

    {/* Three segments */}
    <div class="seam-soft" aria-hidden="true"></div>
    <section class="section mx-auto max-w-6xl px-4">
      <div class="grid gap-6 md:grid-cols-3" data-stagger>
        {segments.map((s, i) => (
          <div class="v2-rise border-l-2 border-brass-400/60 pl-6" style={`--v2-i:${i}`}>
            <p class="fig lum text-2xl">{s.n}</p>
            <h2 class="display mt-2 text-2xl text-white">{s.title}</h2>
            <p class="mt-3 text-sm leading-relaxed text-lune-soft">{s.body}</p>
          </div>
        ))}
      </div>
    </section>

    {/* Business orders of magnitude — the ledger, figures that tally up.
        Eyebrow demoted to lune (brass discipline). */}
    <div class="seam-soft" aria-hidden="true"></div>
    <section class="section px-4">
      <div class="mx-auto max-w-4xl">
        <p class="tech-label v2-kicker rule-brass text-lune">Price transparency</p>
        <h2 class="display v2-section-title mt-5 text-white">What budget to expect for a business site</h2>
        <p class="v2-lead mt-4 max-w-2xl text-lune-soft">
          Indicative ranges for a business roof — <strong class="text-lune">never a quote</strong>.
          The real costing locks onto your load curves and the conditions of your
          connection. On a large warehouse roof, each kWc installed comes out cheaper than in
          residential: the more continuous the surface, the lower the unit cost, so the range
          below sits beneath the one on the Residential page.
        </p>
        <div class="mt-10 border-t-2 border-brass-400/60" data-stagger>
          {proBrackets.map((b, i) => (
            <div class="v2-rise border-b border-white/10 py-5" style={`--v2-i:${i}`}>
              <div class="grid gap-1.5 sm:grid-cols-[1fr_0.7fr_1.3fr_0.7fr] sm:items-baseline sm:gap-4">
                <span class="font-display text-base font-bold text-white">{b.bill}</span>
                <span class="fig lum text-xl sm:text-2xl" data-tally>{b.kwc}</span>
                <span class="fig text-lg text-lune sm:text-xl">{b.invest}</span>
                <span class="fig text-xl text-brass-300 sm:text-2xl" data-tally>{b.payback}</span>
              </div>
              {b.exemple && <p class="tech-label mt-2.5 text-lune-faint">{b.exemple}</p>}
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* Precision of the work — captioned site photos */}
    <div class="seam-soft" aria-hidden="true"></div>
    <section class="section mx-auto max-w-6xl px-4">
      <div class="grid gap-4 sm:grid-cols-2" data-stagger>
        <figure class="v2-rise cine-card group relative overflow-hidden" style="--v2-i:0">
          <Picture name="mesure-rails" alt="Marking out and measuring the mounting rails on a business roof"
            widths={[1600, 1024, 640]} ratio={4 / 3} sizes="(min-width: 640px) 50vw, 100vw"
            class="v3-grade w-full object-cover transition-transform duration-700 group-hover:scale-[1.04]" />
          <figcaption class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-nuit/95 to-transparent px-4 pb-3 pt-12">
            <span class="tech-label block text-brass-300">Nouaceur · 3,72 kWc · layout</span>
            <span class="mt-0.5 block text-xs text-lune">Every rail is marked out and measured before fixing</span>
          </figcaption>
        </figure>
        <figure class="v2-rise cine-card group relative overflow-hidden" style="--v2-i:1">
          <Picture name="equipe-trois" alt="Taqinor team in front of a long row of panels at the end of the install"
            widths={[1600, 1024, 640]} ratio={3 / 2} sizes="(min-width: 640px) 50vw, 100vw"
            class="v3-grade w-full object-cover transition-transform duration-700 group-hover:scale-[1.04]" />
          <figcaption class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-nuit/95 to-transparent px-4 pb-3 pt-12">
            <span class="tech-label block text-brass-300">El Jadida · 17,04 kWc · 21 406 kWh/an</span>
            <span class="mt-0.5 block text-xs text-lune">End of install · 24 × Canadian Solar 710 Wc · Deye 15 kW three-phase</span>
          </figcaption>
        </figure>
      </div>
    </section>

    <ZelligeDivider tone="white" />

    {/* Surplus + MV regimes — eyebrow demoted to lune (brass discipline) */}
    <section class="section px-4">
      <div class="mx-auto max-w-3xl">
        <div class="v2-rise">
          <p class="tech-label v2-kicker rule-brass text-lune">Law 82-21 · medium voltage</p>
          <h2 class="display v2-section-title mt-5 text-white">Make every exported kilowatt-hour pay</h2>
          <p class="v2-lead mt-5 text-lune-soft">
            Law 82-21 sets the framework for self-generation and for the surplus sent back to the
            grid. In medium voltage, the study separates from the outset what you consume on site
            from what you inject, on the terms of your connection agreement. The idea fits in one
            line: that a kilowatt-hour produced on your site never leaves without something in return.
          </p>
        </div>
        <div class="v2-rise">
          <h2 class="display v2-section-title mt-12 text-white">Which law 82-21 regime your site falls under</h2>
          <p class="v2-lead mt-5 text-lune-soft">
            Power decides. Up to 5 MW in low or medium voltage, a simple
            <strong class="text-lune">connection agreement</strong> with the grid operator is enough. Cross
            the 5 MW threshold — medium, high or very high voltage — and you move into the
            <strong class="text-lune">authorisation</strong> regime. In both cases, we assemble the technical
            file and carry it through to commissioning.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href={L('/loi-82-21')} class="inline-block border border-white/40 px-6 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">
              Identify my regime in 3 questions
            </a>
            <a href={L('/équipement')} class="inline-block border border-white/40 px-6 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">
              See the equipment we install
            </a>
          </div>
        </div>
      </div>
    </section>

    {/* Contextual links */}
    <div class="seam-soft" aria-hidden="true"></div>
    <section class="section-tight px-4">
      <div class="mx-auto flex max-w-6xl flex-wrap gap-3">
        <a href={L('/realisations')} class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">Our projects →</a>
        <a href={L('/équipement')} class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">The equipment we install →</a>
        <a href={L('/pompage-solaire')} class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">Solar pumping →</a>
        <a href={L('/financement')} class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">Financing &amp; returns →</a>
        <a href={L('/pourquoi-taqinor')} class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">Why Taqinor →</a>
      </div>
    </section>

    <!-- W62 — Client reviews (empty → renders nothing until a real review exists) -->
    <Testimonials />

    <!-- Reassurance: the written warranties, in brief (links to /garanties) -->
    <GarantiesTeaser />

    <!-- FINAL ACT — the clean room -->
    <DiagnosticForm heading="Assessment for your business site" />

    <CtaBand
      title="A question about your site before you commit? Talk to a human."
      buttonLabel="WhatsApp direct with an advisor"
      href={waDirect}
      seam={false}
    />

    <StickyCta />
  </div>
</Layout>

<style>
  /* Raised hero scrim for the elevation: compensates the warmth of the
     full-frame sunset and guarantees AA contrast for the white headline (ref. v3). */
  .hero-scrim-v3 {
    --hero-scrim-strength: 0.52;
  }
</style>
