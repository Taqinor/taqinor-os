---
/**
 * EN — Production mesurée / "Measured production" (W354). Faithful translation
 * of /production-mesuree ; every figure is DERIVED live from realisations.ts
 * (read-only), exactly like the FR page — no number is hand-typed. Internal
 * links use localizeNavHref (EN if it exists, else the FR page — never a dead
 * link). FR untouched.
 *
 * NOTE: this EN route is NOT yet registered in src/i18n/pages.ts
 * (STATIC_TRANSLATED) — that file is out of scope for this task, so the
 * language switcher / hreflang do not surface this page yet. The route itself
 * renders correctly and is a real, indexable page.
 */
import Layout from '../../layouts/Layout.astro';
import V2Enhance from '../../components/V2Enhance.astro';
import Article33Ribbon from '../../components/Article33Ribbon.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import KeyFigure from '../../components/KeyFigure.astro';
import Callout from '../../components/Callout.astro';
import RelatedLinks from '../../components/RelatedLinks.astro';
import CtaBand from '../../components/CtaBand.astro';
import StickyCta from '../../components/StickyCta.astro';
import { getLocaleFromPath } from '../../i18n/utils';
import { localizeNavHref } from '../../i18n/pages';
import { REALISATIONS, MEASURED_FLEET, MEASURED_FLEET_LIFETIME_MWH } from '../../lib/realisations';
import { FACTS_GENERATED_AT } from '../../lib/facts';

const locale = getLocaleFromPath(Astro.url.pathname);
const L = (href: string) => localizeNavHref(href, locale);
const devisHref = L('/devis/mon-toit');

// ── Derived figures — nothing hand-typed ─────────────────────────────────────
// RULE B (2026-07-04): the raw install count is no longer featured in user
// copy (h2, denominators) — the page leads with measured kWh instead
// (partially supersedes W354).
// (2026-07-05, founder): cumulative installed kWc is dropped (no longer shown
// anywhere on the site) — the page now leads with MEASURED production.

// WB1 (2026-07-04): the fabricated per-installation ANNUAL production was
// removed (identical yield factor across several sites — impossible). The
// only real production figure is the CUMULATIVE tally of the fleet monitored
// in real time (MEASURED_FLEET, realisations.ts) — cumulative "since
// commissioning", NEVER annualized.
const productionTotal = Math.round(MEASURED_FLEET_LIFETIME_MWH * 1000);
const productionTotalLabel = productionTotal.toLocaleString('en-US');

const dateFmt = new Intl.DateTimeFormat('en-US', { day: 'numeric', month: 'long', year: 'numeric' });
const generatedDateLabel = dateFmt.format(new Date(FACTS_GENERATED_AT));

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Dataset',
  name: 'Tracked solar production — Taqinor fleet',
  description: `Cumulative production measured across the fleet monitored in real time (${MEASURED_FLEET.length} plants), as of ${generatedDateLabel}: ${productionTotalLabel} kWh cumulative.`,
  temporalCoverage: FACTS_GENERATED_AT,
  creator: { '@type': 'Organization', name: 'Taqinor', url: 'https://taqinor.ma' },
};
---

<Layout
  title="Tracked solar production — our fleet's real cumulative tally | Taqinor"
  description={`${productionTotalLabel} kWh tallied cumulatively across the fleet monitored in real time, as of ${generatedDateLabel} — nothing rounded up, nothing padded.`}
  ogSlug="equipement"
>
  <div class="v2">
    <V2Enhance />
    <Article33Ribbon />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <Breadcrumb items={[{ label: 'Home', href: L('/') }, { label: 'Tracked production' }]} />

    <section class="section-lg px-4 pb-10 text-white">
      <div class="mx-auto max-w-3xl">
        <p class="tech-label v2-kicker rule-brass cine-in text-lune">Ongoing transparency</p>
        <h1 class="display v2-page-title cine-in cine-in-1 mt-6">Tracked production</h1>
        <p class="v2-lead cine-in cine-in-2 mt-6 max-w-xl text-white/85">
          Not a brochure: a counter that keeps rolling. What the fleet monitored in real time
          has actually produced since commissioning, cumulatively — as of{' '}
          <strong class="text-white">{generatedDateLabel}</strong>.
        </p>
      </div>
    </section>

    <!-- Key figures — derived live from realisations.ts -->
    <section class="section px-4">
      <div class="mx-auto max-w-6xl">
        <p class="tech-label v2-kicker rule-brass text-lune">Tracked tally as of {generatedDateLabel}</p>
        <h2 class="display v2-section-title mt-5 text-white">{productionTotalLabel} kWh, one counter</h2>
        <div class="mt-10 grid gap-6 sm:grid-cols-2" data-stagger>
          <KeyFigure value={productionTotalLabel} unit="kWh cumulative" label="Tracked production">
            Cumulative tally from the fleet monitored in real time since commissioning — never
            annualized.
          </KeyFigure>
          <KeyFigure value={String(MEASURED_FLEET.length)} unit="monitored plants" label="Published monitoring">
            Fleet tracked live, client access.
          </KeyFigure>
        </div>
        <Callout type="info" title="How this figure gets refreshed">
          <p>
            This tally is recalculated each time a monitoring export is republished (roughly:
            with every newly monitored site added to the fleet). The date above is the latest
            snapshot — never a rolling average, never a projection. The measured cumulative is
            tracked continuously by our real-time production monitoring, recalculated with every
            newly documented project.
          </p>
        </Callout>
      </div>
    </section>

    <!-- The detail, project by project -->
    <div class="v2-seam" aria-hidden="true"></div>
    <section class="section bg-blanc-azur px-4 text-encre">
      <div class="mx-auto max-w-3xl">
        <p class="tech-label v2-kicker rule-brass text-azur-600">The detail</p>
        <h2 class="display v2-section-title mt-5">Project by project</h2>
        <p class="v2-lead mt-4 text-encre-soft">
          Every line corresponds to a real installation, documented on our projects page.
        </p>
        <div class="mt-10 border-t-2 border-azur-900 bg-blanc" data-stagger>
          {REALISATIONS.map((r, i) => (
            <div class="v2-rise flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1 border-b border-azur-900/15 px-5 py-4" style={`--v2-i:${i}`}>
              <span class="text-sm font-semibold">{r.ville} · {r.kwc} · ref. {r.ref} · {r.date}</span>
              <span class="whitespace-normal text-right text-sm text-azur-600">
                {[r.onduleur, r.batterie].filter(Boolean).join(' · ') || r.panneaux}
              </span>
            </div>
          ))}
        </div>
        <p class="mx-auto mt-6 max-w-xl border-l-4 border-azur-600 pl-4 text-sm leading-relaxed text-encre-soft">
          <a href={L('/realisations')} class="border-b border-azur-600 pb-0.5 font-semibold text-azur-600 transition-colors hover:text-azur-700">See all our projects in detail →</a>
        </p>
      </div>
    </section>

    <section class="section-tight px-4 pb-20 sm:pb-24">
      <div class="mx-auto max-w-6xl">
        <p class="tech-label v2-kicker rule-brass text-lune">To go further</p>
        <RelatedLinks links={[
          { href: L('/realisations'), label: 'Our projects' },
          { href: L('/impact-taqinor'), label: 'Taqinor Impact (CO2 avoided)' },
          { href: L('/ensoleillement-maroc'), label: 'Solar yield by city' },
          { href: L('/maintenance-monitoring'), label: 'Maintenance & monitoring' },
        ]} />
      </div>
    </section>

    <CtaBand title="A project that could add to this counter? Start the free assessment." href={devisHref} />

    <StickyCta />
  </div>
</Layout>
