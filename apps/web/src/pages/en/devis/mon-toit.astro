  /* ===== QX — PRINT: only the document exists on paper. Navy/gold bands
     print (print-color-adjust), sections stay whole (break-inside), the
     rest of the page (header, wizard, forms, sticky CTA, footer) vanishes. ===== */
  @media print {
    @page {
      size: A4;
      margin: 10mm;
    }
    body {
      background: #ffffff !important;
    }
    body * {
      visibility: hidden !important;
    }
    #mt-doc,
    #mt-doc * {
      visibility: visible !important;
    }
    #mt-doc,
    #mt-doc * {
      -webkit-print-color-adjust: exact !important;
      print-color-adjust: exact !important;
    }
    #mt-doc {
      position: absolute;
      inset: 0 auto auto 0;
      width: 100%;
      max-width: none;
      margin: 0;
      border-radius: 0;
      box-shadow: none;
    }
    .mt-doc-header,
    .mt-doc-footer,
    .mt-doc-kpi,
    .mt-doc-hypo,
    .mt-doc-step,
    .mt-doc-flowgrid,
    .mt-doc-callback,
    #mt-doc-chart-wrap {
      break-inside: avoid;
      page-break-inside: avoid;
    }
    /* The KPI grid stays a grid when printed (never flex). */
    .mt-doc-kpis {
      display: grid !important;
      grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
    }
    .mt-doc-steps {
      grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
    }
  }
</style>

<script>
  import { estimateFromBill, formatMad, formatMadRange } from '../../../lib/billEstimate';
  // QX — the two new per-profile engines (Lane A contract): PRO (C&I
  // self-consumption) and AGRICULTURAL (pumping). Residential stays on
  // estimateFromBill, unchanged.
  import { estimatePro } from '../../../lib/estimatorPro';
  // WJ122 — commercial per-category questions + key→webhook mapping (QX51).
  import { COMMERCIAL_CATEGORY_QUESTIONS, COMMERCIAL_QUESTION_WEBHOOK_KEY } from '../../../lib/commercialCategories';
  // WJ124 — agronomy water engine (crop → m³/day need) — QX48 mirror.
  import { monthlyWaterDemand } from '../../../lib/agronomy';
