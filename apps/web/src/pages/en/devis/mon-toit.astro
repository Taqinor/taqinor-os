                <li class="mt-doc-step">
                  <span class="mt-doc-step-num" aria-hidden="true">2</span>
                  <p class="mt-doc-step-name">Technical visit</p>
                  <p class="mt-doc-step-sub">On-site validation, no obligation</p>
                </li>
                <li class="mt-doc-step">
                  <span class="mt-doc-step-num" aria-hidden="true">3</span>
                  <p class="mt-doc-step-name">Installation, 2–5 days</p>
