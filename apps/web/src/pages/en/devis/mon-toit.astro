      </div>

      <!-- ============ WJ8/WJ35 — TRUST AT THE POINT OF CAPTURE ============ -->
      <aside class="mt-8 border-t border-white/10 pt-6">
        <!-- pending real content from Reda: real installation photos.
             We do NOT FABRICATE any figure or review: we show verifiable facts (law
             82-21, standard manufacturer warranties, real service area) + a scaffolded
             slot for the photos. The installation counter (4th tile) is now REAL —
             derived from src/lib/realisations.ts (WJ35, InstallCounter). -->
        <div class="grid grid-cols-2 gap-3 sm:grid-cols-4">
          <div class="cine-card p-3 text-center">
            <p class="text-sm font-bold text-white">Law 82-21 compliant</p>
            <p class="text-xs text-lune-faint">Declared self-production</p>
          </div>
          <div class="cine-card p-3 text-center">
            <p class="text-sm font-bold text-white">25-year warranty</p>
            <p class="text-xs text-lune-faint">Panels (manufacturer)</p>
          </div>
          <div class="cine-card p-3 text-center">
            <p class="text-sm font-bold text-white">Certified equipment</p>
            <p class="text-xs text-lune-faint">IEC 61215 / 61730</p>
          </div>
          <div class="cine-card p-3 text-center">
            <p class="text-sm font-bold text-white">All across Morocco</p>
            <p class="text-xs text-lune-faint">Local site study</p>
          </div>
        </div>

        <!-- WJ8 — real service towns -->
        <p class="mt-4 text-center text-xs text-lune-faint">
          <span>Installations and studies in</span>
          {' '}{TOWNS.join(' · ')}
        </p>

        <!-- WJ8 — slot for REAL installation photos (scaffold, not fabricated) -->
        <!-- pending real content from Reda: replace with 3 real installation photos
             (path /images/installs/*.webp) + city caption. Until then, we show no
             fabricated visual — this block stays hidden. -->
        <div id="mt-install-photos" hidden class="mt-4 grid grid-cols-3 gap-2" aria-label="Completed installations"></div>

        <!-- WJ35 — premium social proof: real counter + Google rating (scaffold until
             available) + certifications. Discreet v3 grade (section-tight rhythm). -->
        <div class="mt-6 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
          <InstallCounter />
          <StarRating compact />
        </div>
        <div class="mt-5">
          <CertLogoRow />
        </div>
      </aside>

      <!-- WJ35 — closing zellige signature (v3 imprint, consistent with the elevated homepage) -->
      <ZelligeSignature
        line="Every figure on this page is measured, not promised."
        sub="Your estimate first. The study next."
      />
    </div>
  </section>

  <!-- ============ WJ7 — ABANDONMENT RECOVERY (exit-intent / mobile leave) ============
       WJ34 — safe-area-inset-bottom: anchored to the bottom on mobile (items-end), the
       modal must never sit under the gesture bar / notch. ==== -->
  <div id="mt-exit" hidden class="fixed inset-0 z-50 flex items-end justify-center bg-black/60 p-4 sm:items-center"
    style="padding-bottom: max(1rem, env(safe-area-inset-bottom));"
    role="dialog" aria-modal="true" aria-labelledby="mt-exit-title">
    <div class="cine-card w-full max-w-md border border-brass-400/40 p-5">
      <div class="flex items-start justify-between gap-3">
        <p id="mt-exit-title" class="display text-lg text-white">Receive your estimate on WhatsApp</p>
        <!-- WJ88 — minimum ≥24×24 px touch target (WCAG 2.5.8). -->
        <button type="button" id="mt-exit-close" aria-label="Close"
          class="flex-none min-h-6 min-w-6 inline-flex items-center justify-center text-lune-faint hover:text-white">✕</button>
      </div>
      <p class="mt-2 text-sm text-lune-soft">
        Just leave your number — we'll send you your estimate and answer your questions.
        Free, no obligation.
      </p>
      <div class="mt-4 flex flex-col gap-2 sm:flex-row">
        <input id="mt-exit-phone" type="tel" inputmode="tel" autocomplete="tel"
          placeholder="06 XX XX XX XX" class={inputClass} />
        <a id="mt-exit-wa" href="#" target="_blank" rel="noopener"
          class="inline-flex flex-none items-center justify-center gap-2 bg-ok-600 px-5 py-3 text-base font-bold text-white transition-opacity hover:opacity-90">
          <span>Send</span>
        </a>
      </div>
      <p id="mt-exit-err" hidden class="mt-2 text-xs text-alert-300" aria-live="polite"></p>
    </div>
  </div>
</Layout>

<style>
  /* WJ2 — boîte à hauteur RÉSERVÉE (zéro CLS) : le bouton « voir les panneaux »
     et le canvas 3D qui le remplace ensuite occupent EXACTEMENT la même zone. */
  .mt-panels3d-stage {
    height: 320px;
    background: linear-gradient(160deg, rgb(20 38 63 / 0.9), rgb(7 11 29 / 0.95));
  }
  @media (min-width: 640px) {
    .mt-panels3d-stage {
      height: 380px;
    }
  }

  /* ===== WJ34 — squelettes de performance perçue (zéro CLS : la zone occupe
     déjà sa hauteur finale — bg-nuit-700/min-h existants — on n'ajoute qu'un
     effet de « chargement » par-dessus, retiré au premier rendu réel). ===== */
  .mt-skeleton-shimmer {
    background-image: linear-gradient(
      100deg,
      transparent 30%,
      rgb(255 255 255 / 0.06) 50%,
      transparent 70%
    );
    background-size: 200% 100%;
  }
  @media (prefers-reduced-motion: no-preference) {
    .mt-skeleton-shimmer {
      animation: mt-shimmer 1.6s ease-in-out infinite;
    }
  }
  @keyframes mt-shimmer {
    from { background-position: 200% 0; }
    to { background-position: -200% 0; }
  }

  /* Squelettes des 3 chiffres d'estimation — mêmes proportions que le texte
     final (text-3xl), donc AUCUN CLS quand les vrais chiffres les remplacent. */
  .mt-est-skeleton {
    display: inline-block;
    height: 2.25rem;
    width: 4.5rem;
    border-radius: 0.25rem;
    background: rgb(255 255 255 / 0.08);
    vertical-align: middle;
  }

  /* WJ48 — branded "thinking" dot: a discreet pulse, never a generic
     spinner. Gated reduced-motion (static otherwise), same discipline as
     .mt-skeleton-shimmer. */
  @media (prefers-reduced-motion: no-preference) {
    .mt-thinking-dot {
      animation: mt-thinking-pulse 1s ease-in-out infinite;
    }
  }
  @keyframes mt-thinking-pulse {
    0%, 100% { opacity: 0.35; transform: scale(0.85); }
    50% { opacity: 1; transform: scale(1); }
  }
</style>

<script>
  import { estimateFromBill, formatMad, formatMadRange } from '../../../lib/billEstimate';
  import { captureWhatsappText, whatsappLink } from '../../../lib/whatsapp';
  import { WHATSAPP_LEADS } from '../../../lib/nap';
  import { buildClientRef, validateLead } from '../../../lib/lead';
  // WJ72 — single kWc number style, shared with the proposal (src/lib/proposition.ts):
  // comma decimal, trailing zeros stripped — never the raw dot from `String(est.kwc)`.
  import { formatKwc } from '../../../lib/proposition';
  // W342 — "closest installation": client-side haversine over the dropped GPS
  // pin (no network call).
  import { nearestRealisation } from '../../../lib/realisations';
  import { type CaptureStrings } from '../../../scripts/roofPro11/mapDraw';

  // WJ60/WJ63 fix — moved here from the frontmatter: a plain <script> tag in an
  // .astro file compiles to a SEPARATE client module with NO access to
  // frontmatter bindings (only `define:vars` bridges that gap, and it would force
  // this script to become `is:inline` — breaking the `import`s above). The
  // frontmatter copy was a silent dead reference (ReferenceError at runtime on
  // every field-validation failure) since WJ39 first introduced it — verified via
  // `astro build`, the compiled client chunk never defined this identifier.
  //
  // WJ39 — known client-side validateLead()/normalizeMoroccanPhone() error
  // strings (src/lib/lead.ts, src/lib/phone.ts — shared FR source, out of this
  // page's file scope) translated to English so inline field errors never show
  // French on this route. Falls back to the raw (French) message only if the
  // shared validator ever returns something outside this known set.
  const VALIDATION_ERROR_EN: Record<string, string> = {
    'Nom complet requis': 'Full name required',
    'Numéro invalide': 'Invalid number',
    'Numéro invalide — format attendu : 06 XX XX XX XX ou +212 6 XX XX XX XX':
      'Invalid number — expected format: 06 XX XX XX XX or +212 6 XX XX XX XX',
    'Ville / commune requise': 'City / town required',
    'Type de toiture requis': 'Roof type required',
    'Tranche de facture requise': 'Bill range required',
    'Le consentement est requis pour être recontacté': 'Consent is required so we can contact you back',
  };

  // WJ41 — map/geocoder system messages (roofPro11/mapDraw.ts + captureBoot.ts
  // default to French); this page passes English strings so the single most
  // interactive moment of the funnel never speaks French to EN visitors.
  const ROOF_TOOL_STRINGS_EN: CaptureStrings = {
    searchAddressThenPin: 'Search for your address, then drop a pin on your roof.',
    pinPlaced: 'Pin placed. You can adjust it, or trace the outline (optional), then fill in your details.',
    outlineTraced: 'Outline traced. Fill in your details below, then submit.',
    traceOutline: 'Trace the outline of your roof. Double-click to close it (optional).',
    outlineCrosses: 'Your trace crosses itself — fix it ("Clear") before closing.',
    pointWouldCross: 'This point would cross your trace — place it elsewhere to keep a simple outline.',
    doubleClickToClose: 'Double-click (or "Finish") to close the roof and start the calculation.',
    cornerPlaced: (n) => `Corner ${n} placed — keep tracing the outline.`,
    lastPointUndone: (n) => `Last point undone — ${n} corner(s) remaining. Keep tracing.`,
    clickCornersToClose: 'Click the corners of your roof. Double-click to close it and start the calculation.',
    searchingAddress: 'Searching for the address…',
    addressNotFound: 'Address not found. Specify the city or move the map by hand.',
    chooseFromList: 'Choose your address from the list, then click the corners of your roof.',
    searchUnavailable: 'Search unavailable. Move the map by hand to find your roof.',
  };

  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const $ = (id: string) => document.getElementById(id);
  const fallback = $('mt-fallback');
  const cityEl = $('mt-city') as HTMLInputElement | null;
  const addressEl = $('rp9-address') as HTMLInputElement | null;
  const fallbackAddrEl = $('mt-fallback-address') as HTMLInputElement | null;

  // ——— WJ45: offline banner (navigator.onLine + online/offline) ———
  // A mobile network drop must never look like a silent failure: the banner
  // appears/disappears live, independently of any submission attempt.
  const offlineBanner = $('mt-offline-banner');
  function syncOfflineBanner() {
    if (offlineBanner) offlineBanner.hidden = navigator.onLine;
  }
  syncOfflineBanner();
  window.addEventListener('online', syncOfflineBanner);
  window.addEventListener('offline', syncOfflineBanner);

  // ——— WJ59 : step-level funnel beacon (privacy-light, no PII) ———
  // Anonymous PER-TAB token (sessionStorage, never a device/user id): only
  // used to dedupe/correlate "reached"/"abandoned" events within ONE visit,
  // never to identify a visitor. See src/lib/funnelBeacon.ts for the full
  // contract (strict 4-field allowlist, never name/phone/email/address/GPS/outline).
  const FUNNEL_TOKEN_KEY = 'mt-funnel-token-v1';
  function getFunnelToken(): string {
    try {
      let t = sessionStorage.getItem(FUNNEL_TOKEN_KEY);
      if (!t) {
        t = Math.random().toString(36).slice(2) + Date.now().toString(36);
        sessionStorage.setItem(FUNNEL_TOKEN_KEY, t);
      }
      return t;
    } catch {
      return Math.random().toString(36).slice(2);
    }
  }
  const funnelToken = getFunnelToken();
  const funnelStepReached = new Set<string>();
  function sendFunnelBeacon(step: 'toit' | 'facture' | 'estimation' | 'contact', action: 'reached' | 'abandoned') {
    if (action === 'reached') {
      const key = `${step}:${action}`;
      if (funnelStepReached.has(key)) return;
      funnelStepReached.add(key);
    }
    try {
      const payload = JSON.stringify({ step, action, sessionToken: funnelToken, path: location.pathname });
      if (navigator.sendBeacon) {
        const blob = new Blob([payload], { type: 'application/json' });
        navigator.sendBeacon('/api/funnel-beacon', blob);
      } else {
        void fetch('/api/funnel-beacon', { method: 'POST', headers: { 'content-type': 'application/json' }, body: payload, keepalive: true }).catch(() => {});
      }
    } catch {
      // Best-effort measurement only — must never disrupt the flow.
    }
  }

  // ——— état capture (repère / contour) tenu par onCaptureChange ———
  let capturePin: { lat: number; lng: number } | null = null;
  let captureOutline: Array<[number, number]> = [];
  let cityTouched = false;
  cityEl?.addEventListener('input', () => { cityTouched = true; });

  // WJ39 — no in-page language toggle on this route: the /en/ URL already
  // declares the locale (Layout.astro sets <html lang="en" dir="ltr">), so the
  // FR/AR dual-node data-i18n toggle used by the FR/AR variants doesn't apply
  // here. `langue_preferee` (fr/ar only, src/lib/lead.ts LEAD_LANGS) is simply
  // omitted from the submitted body below — the webhook contract stays
  // unchanged (the field is optional).

  // ——— WJ61 : the wizard's state survives a refresh/back navigation ———
  // A phone call or an accidental back-swipe used to silently destroy
  // everything typed — the costliest UX failure in the funnel. We persist a
  // minimal snapshot (step/mode/bill/pin-outline/optional answers) to
  // sessionStorage (per tab, never shared between visitors): rehydrated on
  // load, cleared on success. Never blocks submission if sessionStorage is
  // unavailable (strict private browsing…).
  const WIZARD_STORAGE_KEY = 'mt-wizard-v1';
  interface WizardSnapshot {
    step?: number;
    mode?: string;
    ombrage?: string;
    visitWindowPart?: string;
    visitWindowWeek?: string;
    futureLoads?: string[];
    capturePin?: { lat: number; lng: number } | null;
    captureOutline?: Array<[number, number]>;
    fields?: Record<string, string>;
    checks?: Record<string, boolean>;
  }
  const PERSISTED_TEXT_FIELDS = [
    'mt-name', 'mt-phone', 'mt-city', 'mt-email', 'mt-facture-hiver', 'mt-facture-ete',
    'mt-bill', 'mt-roof', 'mt-raccordement', 'mt-distributeur', 'mt-bill-kwh', 'mt-roof-age',
    'mt-occupant-type', 'mt-project-timing', 'mt-financing-intent', 'mt-fallback-address',
    'rp9-address',
    // WJ68 — professionnel mode (optional, additive).
    'mt-raison-sociale', 'mt-facility-type', 'mt-site-count',
  ];
  const PERSISTED_CHECK_FIELDS = ['mt-ete-differente', 'mt-contact-whatsapp', 'mt-contact-phone', 'mt-consent', 'mt-battery-interest'];
  let restoring = false; // WJ61 — avoids re-saving WHILE rehydrating.
  function saveWizardState() {
    if (restoring) return;
    try {
      const fields: Record<string, string> = {};
      for (const id of PERSISTED_TEXT_FIELDS) {
        const v = val(id);
        if (v) fields[id] = v;
      }
      const checks: Record<string, boolean> = {};
      for (const id of PERSISTED_CHECK_FIELDS) {
        const el = $(id) as HTMLInputElement | null;
        if (el) checks[id] = el.checked;
      }
      const snapshot: WizardSnapshot = {
        step, mode, ombrage,
        visitWindowPart, visitWindowWeek,
        futureLoads: Array.from(futureLoads),
        capturePin, captureOutline,
        fields, checks,
      };
      sessionStorage.setItem(WIZARD_STORAGE_KEY, JSON.stringify(snapshot));
    } catch {
      // sessionStorage unavailable (strict private browsing, quota…): the
      // persistence is a CONVENIENCE, never a blocker for typing/submitting.
    }
  }
  function loadWizardState(): WizardSnapshot | null {
    try {
      const raw = sessionStorage.getItem(WIZARD_STORAGE_KEY);
      return raw ? (JSON.parse(raw) as WizardSnapshot) : null;
    } catch {
      return null;
    }
  }
  function clearWizardState() {
    try { sessionStorage.removeItem(WIZARD_STORAGE_KEY); } catch { /* convenience only */ }
  }
  // WJ61 — exit guard: once the visitor has started entering something, an
  // ACCIDENTAL refresh/close shows the browser's native confirmation prompt
  // (text not customisable by spec).
  let hasEnteredData = false;
  function markDataEntered() { hasEnteredData = true; }
  window.addEventListener('beforeunload', (e) => {
    if (!hasEnteredData || submitted) return;
    e.preventDefault();
    e.returnValue = '';
  });

  const savedWizard = loadWizardState();

  // ——— WJ6 : sélecteur de mode ———
  let mode = savedWizard?.mode || 'residentiel';
  // WJ68 — professionnel-only optional fields, hidden otherwise.
  function syncProFieldsVisibility() {
    const proFields = $('mt-pro-fields');
    if (proFields) proFields.hidden = mode !== 'professionnel';
  }
  document.querySelectorAll<HTMLButtonElement>('.mt-mode').forEach((btn) => {
    btn.addEventListener('click', () => {
      mode = btn.dataset.mode || 'residentiel';
      document.querySelectorAll<HTMLButtonElement>('.mt-mode').forEach((b) => {
        const on = b === btn;
        b.setAttribute('aria-pressed', String(on));
        b.classList.toggle('border-brass-400', on);
        b.classList.toggle('border-white/15', !on);
      });
      syncProFieldsVisibility();
      markDataEntered();
      saveWizardState();
      // WJ111 — if the estimate (step 3) was already computed, switching to/from
      // agricultural must update the card IMMEDIATELY (numeric <-> qualitative
      // card) without waiting for a fresh click on "See my estimate".
      if (!$('mt-estimate-body')?.hidden || !$('mt-estimate-agricole')?.hidden) computeEstimate();
    });
  });
  // état initial : marquer le mode sélectionné (réhydraté ou résidentiel par défaut).
  document.querySelectorAll<HTMLButtonElement>('.mt-mode').forEach((b) => {
    const on = (b.dataset.mode || 'residentiel') === mode;
    b.setAttribute('aria-pressed', String(on));
    b.classList.toggle('border-brass-400', on);
    b.classList.toggle('border-white/15', !on);
  });
  syncProFieldsVisibility();

  // ——— WJ48 : image cards "roof type" — sync the sr-only <select> (mt-roof)
  // which stays the source of truth for val('mt-roof'), validation
  // (setFieldError) and WJ61 persistence (already wired on 'mt-roof' via
  // PERSISTED_TEXT_FIELDS). Single active choice at a time. ———
  const roofSelect = $('mt-roof') as HTMLSelectElement | null;
  function syncRoofCards() {
    const current = roofSelect?.value || '';
    document.querySelectorAll<HTMLButtonElement>('.mt-roof-card').forEach((b) => {
      const on = b.dataset.roof === current;
      b.setAttribute('aria-pressed', String(on));
      b.classList.toggle('border-brass-400', on);
      b.classList.toggle('border-white/15', !on);
    });
  }
  document.querySelectorAll<HTMLButtonElement>('.mt-roof-card').forEach((btn) => {
    btn.addEventListener('click', () => {
      if (roofSelect) {
        roofSelect.value = btn.dataset.roof || '';
        setFieldError('mt-roof', 'mt-roof-err', null);
      }
      syncRoofCards();
      markDataEntered();
      saveWizardState();
    });
  });
  syncRoofCards(); // initial state (rehydrated or empty).

  // ——— WJ31 : puce à bascule unique (ombrage) — un seul choix actif à la fois ———
  // WJ112 — shading is no longer decorative: it now REALLY derates production/
  // kWc (billEstimate.ts OMBRAGE_DERATE), so recompute live on click, exactly
  // like mode or the bill.
  let ombrage = savedWizard?.ombrage || '';
  document.querySelectorAll<HTMLButtonElement>('.mt-ombrage').forEach((btn) => {
    btn.addEventListener('click', () => {
      const same = ombrage === btn.dataset.value;
      ombrage = same ? '' : (btn.dataset.value || '');
      document.querySelectorAll<HTMLButtonElement>('.mt-ombrage').forEach((b) => {
        const on = !same && b === btn;
        b.setAttribute('aria-pressed', String(on));
        b.classList.toggle('border-brass-400', on);
        b.classList.toggle('border-white/15', !on);
      });
      markDataEntered();
      saveWizardState();
      computeEstimate();
    });
  });
  if (ombrage) {
    document.querySelectorAll<HTMLButtonElement>('.mt-ombrage').forEach((b) => {
      const on = b.dataset.value === ombrage;
      b.setAttribute('aria-pressed', String(on));
      b.classList.toggle('border-brass-400', on);
      b.classList.toggle('border-white/15', !on);
    });
  }

  // ——— W353 : technical visit slot — two INDEPENDENT single-select toggles
  // (time of day + week), same pattern as .mt-ombrage above. STATIC and
  // OPTIONAL preference: no calendar, no confirmed booking — a human
  // validates the real slot after contact. ———
  let visitWindowPart = savedWizard?.visitWindowPart || '';
  let visitWindowWeek = savedWizard?.visitWindowWeek || '';
  function wireVisitToggle(selector: string, getCurrent: () => string, setCurrent: (v: string) => void) {
    document.querySelectorAll<HTMLButtonElement>(selector).forEach((btn) => {
      btn.addEventListener('click', () => {
        const same = getCurrent() === btn.dataset.value;
        setCurrent(same ? '' : (btn.dataset.value || ''));
        document.querySelectorAll<HTMLButtonElement>(selector).forEach((b) => {
          const on = !same && b === btn;
          b.setAttribute('aria-pressed', String(on));
          b.classList.toggle('border-brass-400', on);
          b.classList.toggle('border-white/15', !on);
        });
        markDataEntered();
        saveWizardState();
      });
    });
    const current = getCurrent();
    if (current) {
      document.querySelectorAll<HTMLButtonElement>(selector).forEach((b) => {
        const on = b.dataset.value === current;
        b.setAttribute('aria-pressed', String(on));
        b.classList.toggle('border-brass-400', on);
        b.classList.toggle('border-white/15', !on);
      });
    }
  }
  wireVisitToggle('.mt-visit-part', () => visitWindowPart, (v) => { visitWindowPart = v; });
  wireVisitToggle('.mt-visit-week', () => visitWindowWeek, (v) => { visitWindowWeek = v; });

  // ——— WJ31 : puces multi-sélection (charges futures) ———
  const futureLoads = new Set<string>(savedWizard?.futureLoads ?? []);
  document.querySelectorAll<HTMLButtonElement>('.mt-future-load').forEach((btn) => {
    const preOn = futureLoads.has(btn.dataset.value || '');
    if (preOn) {
      btn.setAttribute('aria-pressed', 'true');
      btn.classList.add('border-brass-400');
      btn.classList.remove('border-white/15');
    }
    btn.addEventListener('click', () => {
      const v = btn.dataset.value || '';
      const on = !futureLoads.has(v);
      if (on) futureLoads.add(v); else futureLoads.delete(v);
      btn.setAttribute('aria-pressed', String(on));
      btn.classList.toggle('border-brass-400', on);
      btn.classList.toggle('border-white/15', !on);
      markDataEntered();
      saveWizardState();
    });
  });

  // ——— WJ31 : photo compteur/facture — capturée EN LOCAL, JAMAIS uploadée ———
  // Pas d'endpoint d'upload aujourd'hui (cf. PLAN2 QK6 OCR) : on garde un simple
  // signal booléen (hasMeterPhoto) et on encourage l'envoi direct sur WhatsApp.
  // WJ61 — not persisted: a local file does not survive sessionStorage (nor
  // should it — no binary data is serialised here).
  let hasMeterPhoto = false;
  const meterPhotoInput = $('mt-meter-photo') as HTMLInputElement | null;
  meterPhotoInput?.addEventListener('change', () => {
    hasMeterPhoto = !!(meterPhotoInput.files && meterPhotoInput.files.length > 0);
  });

  // ——— boot carte (captureOnly). Repli sans clé carte AUTORISE la suite (WJ4) ———
  let started = false;
  const mapEl = $('rp9-map');
  // WJ34 — retire le squelette de chargement dès que la carte annonce son
  // premier rendu (onReady) ou dès qu'on bascule sur le repli sans carte.
  function clearMapSkeleton() { mapEl?.classList.remove('mt-skeleton-shimmer'); }
  async function boot(key: string, mapboxToken: string) {
    if (started) return;
    started = true;
    try {
      // WJ47 — imports roofPro11/captureBoot DIRECTLY (not all of
      // roof-tool-pro11.ts): the full boot drags in scene3d/optimizer/matrix
      // (Three.js + the packing engine), internal tool code this public
      // capture page never runs. This lazy chunk now only loads MapLibre +
      // the geocoder + the pin/outline.
      const { bootCaptureOnly } = await import('../../../scripts/roofPro11/captureBoot');
      bootCaptureOnly({
        maptilerKey: key,
        mapboxToken: mapboxToken || undefined,
        reducedMotion,
        // WJ41 — English map/geocoder system messages (default is French).
        strings: ROOF_TOOL_STRINGS_EN,
        // WJ62 — geolocation refused/unavailable is now announced, not a
        // silent failure.
        geolocateErrorMsg: 'Location denied — search for your address or drop the pin by hand.',
        onReady: clearMapSkeleton,
        // WJ61 — a pin/outline restored from sessionStorage (refresh or
        // browser back mid-journey) is seeded straight into the map at boot,
        // via the same mechanism as hydrating from an existing lead (W113):
        // the visitor doesn't have to re-drop their pin.
        hydrate: capturePin
          ? { lead: { roof_point: capturePin, roof_outline: captureOutline.length >= 3 ? captureOutline : null } }
          : undefined,
        onCaptureChange: (s) => {
          capturePin = s.pin;
          captureOutline = s.outline;
          if (cityEl && !cityTouched) {
            const fromMap = (s.address && s.address.trim()) || addressEl?.value.trim() || '';
            if (fromMap) cityEl.value = fromMap;
          }
          // WJ2 — le contour peut arriver/changer APRÈS le calcul d'estimation :
          // on ré-évalue l'éligibilité du bouton « voir les panneaux » à chaque
          // changement de tracé (fonction déclarée plus bas, hissée par `function`).
          updatePanels3dVisibility();
        },
      });
    } catch {
      started = false;
      showFallback();
    }
  }
  // WJ4 — repli carte : on montre le champ d'adresse en clair ET on garde la suite ouverte.
  function showFallback() { if (fallback) fallback.hidden = false; clearMapSkeleton(); }

  // WJ60 — on slow 3G, a fetch with no timeout could hang indefinitely (the UI
  // stayed stuck on the map's loading skeleton). 10 s gives a slow connection
  // ample time to respond while still bounding the wait; the failure (timeout
  // included) falls into the existing address fallback (WJ4), never a block.
  const FETCH_TIMEOUT_MS = 10_000;
  // W324 — only fire the /api/roof-config fetch (→ lazy maplibre-gl import,
  // ~200 KB+) once the map step (step 0) is actually the ACTIVE step — never
  // on plain page load. A visitor resuming mid-journey at step 1/2 (WJ61:
  // restored sessionStorage snapshot, or browser back) never pays for a map
  // they won't see. `mapFetchDone` keeps the call idempotent (one fetch per
  // visit, even across repeated step-0 visits via Back/Continue).
  let mapFetchDone = false;
  function ensureMapBooted() {
    if (mapFetchDone) return;
    mapFetchDone = true;
    (async () => {
      try {
        const res = await fetch('/api/roof-config', { signal: AbortSignal.timeout(FETCH_TIMEOUT_MS) });
        const cfg = (await res.json()) as { available?: boolean; maptilerKey?: string; mapboxToken?: string };
        if (!cfg.available || !cfg.maptilerKey) { showFallback(); return; }
        void boot(cfg.maptilerKey, cfg.mapboxToken || '');
      } catch {
        showFallback();
      }
    })();
  }

  // ——— WJ6 : assistant multi-étapes + barre de progression ———
  // WJ61 — the initial step reprises the sessionStorage snapshot if present
  // (refresh/back mid-journey), otherwise 0 as before.
  let step = savedWizard?.step != null ? Math.max(0, Math.min(2, savedWizard.step)) : 0;
  const panels = [0, 1, 2].map((i) => $(`mt-panel-${i}`));
  let firstRender = true;
  function renderStep() {
    panels.forEach((p, i) => { if (p) p.hidden = i !== step; });
    document.querySelectorAll<HTMLElement>('.mt-step').forEach((li, i) => {
      const bar = li.querySelector<HTMLElement>('.mt-step-bar');
      const label = li.querySelector<HTMLElement>('.mt-step-label');
      const active = i <= step;
      if (bar) bar.className = `h-1.5 w-full rounded-full mt-step-bar transition-colors ${active ? 'bg-brass-400' : 'bg-white/10'}`;
      if (label) label.classList.toggle('text-white', i === step);
    });
    // W324 — the map step is now ACTIVE: this is where (never on plain page
    // load) we fire the config fetch + the lazy maplibre-gl import.
    if (step === 0) ensureMapBooted();
    // WJ59 — "step reached", deduped by sendFunnelBeacon (once per step per visit).
    sendFunnelBeacon(step === 0 ? 'toit' : step === 1 ? 'facture' : 'estimation', 'reached');
    // WJ61 — on the very first render (load/rehydration), don't force a
    // scroll: the visitor just arrived/came back, the page hasn't moved under
    // them yet. Scrolling stays for every SUBSEQUENT step.
    if (firstRender) { firstRender = false; return; }
    const root = document.querySelector('section');
    root?.scrollIntoView({ behavior: reducedMotion ? 'auto' : 'smooth', block: 'start' });
  }
  // WJ61 — pushState PER STEP: the browser's back button steps back one
  // wizard step instead of leaving the page outright (the most frequent
  // failure of an accidental "back"). `fromPopstate` avoids re-pushing a
  // state while already reacting to a `popstate`.
  function goStep(n: number, fromPopstate = false) {
    step = Math.max(0, Math.min(2, n));
    renderStep();
    saveWizardState();
    if (!fromPopstate) {
      history.pushState({ mtStep: step }, '', location.href);
    }
  }
  window.addEventListener('popstate', (e) => {
    const st = (e.state as { mtStep?: number } | null)?.mtStep;
    goStep(st != null ? st : Math.max(0, step - 1), true);
  });
  $('mt-next-0')?.addEventListener('click', () => goStep(1));
  $('mt-back-1')?.addEventListener('click', () => goStep(0));
  $('mt-back-2')?.addEventListener('click', () => goStep(1));
  // WJ61 — push a first history entry on load so the very first "back" has an
  // `mtStep` state to consult.
  history.replaceState({ mtStep: step }, '', location.href);
  renderStep();

  // ——— helpers de saisie ———
  const val = (id: string) => (($(id) as HTMLInputElement | HTMLSelectElement | null)?.value ?? '');
  const num = (id: string): number | null => {
    const raw = val(id).trim();
    if (raw === '') return null;
    const n = Number(raw);
    return Number.isFinite(n) ? n : null;
  };

  // toggle été ≠ hiver
  const eteToggle = $('mt-ete-differente') as HTMLInputElement | null;
  const eteWrap = $('mt-facture-ete-wrap') as HTMLElement | null;
  const eteInput = $('mt-facture-ete') as HTMLInputElement | null;
  eteToggle?.addEventListener('change', () => {
    const on = eteToggle.checked === true;
    if (eteWrap) eteWrap.hidden = !on;
    if (!on && eteInput) eteInput.value = '';
  });

  // WJ105 — concrete callback SLA: visible ONLY when "An advisor may call me"
  // is the active preference. `sync` is re-called after rehydration (WJ61,
  // below): setting `.checked` via script never fires the native `change` event.
  const contactPhoneRadio = $('mt-contact-phone') as HTMLInputElement | null;
  const contactWhatsappRadio = $('mt-contact-whatsapp') as HTMLInputElement | null;
  const callbackSla = $('mt-callback-sla') as HTMLElement | null;
  function syncCallbackSla(): void {
    if (callbackSla) callbackSla.hidden = contactPhoneRadio?.checked !== true;
  }
  contactPhoneRadio?.addEventListener('change', syncCallbackSla);
  contactWhatsappRadio?.addEventListener('change', syncCallbackSla);
  syncCallbackSla();

  // WJ61 — rehydrate input fields + map pin/outline from the snapshot (BEFORE
  // the map boot: `hydrate` below seeds the pin/outline directly into
  // captureBoot, without waiting for a first click). `restoring` prevents
  // saveWizardState() from firing WHILE we populate fields (native
  // `input`/`change` events don't fire on a scripted `.value`/`.checked`
  // assignment, but we still guard for clarity/consistency with saveWizardState()).
  if (savedWizard) {
    restoring = true;
    for (const [id, v] of Object.entries(savedWizard.fields ?? {})) {
      const el = $(id) as HTMLInputElement | HTMLSelectElement | null;
      if (el) el.value = v;
    }
    for (const [id, v] of Object.entries(savedWizard.checks ?? {})) {
      const el = $(id) as HTMLInputElement | null;
      if (el) el.checked = v;
    }
    // WJ61 — a restored city counts as "already touched": assigning `.value`
    // via script doesn't fire the native `input` event that normally sets
    // `cityTouched`, and without this guard the next pin dropped on the map
    // would silently overwrite the city we just restored.
    if (savedWizard.fields?.['mt-city']) cityTouched = true;
    if (eteToggle?.checked && eteWrap) eteWrap.hidden = false;
    // WJ105 — a restored contact preference must re-sync the callback SLA
    // visibility (assigning `.checked` via script never fires `change`).
    syncCallbackSla();
    if (savedWizard.capturePin) capturePin = savedWizard.capturePin;
    if (savedWizard.captureOutline?.length) captureOutline = savedWizard.captureOutline;
    if (Object.keys(savedWizard.fields ?? {}).length > 0 || savedWizard.capturePin) markDataEntered();
    restoring = false;
  }
  // WJ61 — persist on any typing/change of the remaining text/select/checkbox
  // fields (beyond the chip groups already wired above).
  const PERSIST_ON_INPUT_IDS = [...PERSISTED_TEXT_FIELDS, ...PERSISTED_CHECK_FIELDS];
  for (const id of PERSIST_ON_INPUT_IDS) {
    const el = $(id);
    el?.addEventListener('input', () => { markDataEntered(); saveWizardState(); });
    el?.addEventListener('change', () => { markDataEntered(); saveWizardState(); });
  }

  // ——— WJ1 : résoudre la facture mensuelle (montant exact prioritaire, sinon tranche) ———
  /** Milieu indicatif d'une tranche (MAD) — uniquement pour ESTIMER quand le montant
   *  exact est absent ; ne sert jamais au seuil (le seuil reste sur billRange/qualifies). */
  const RANGE_MIDPOINT: Record<string, number> = {
    'lt800': 600, '800-1000': 900, '1000-1500': 1250, '1500-3000': 2250,
    '3000-5000': 4000, '5000-10000': 7500, 'gt10000': 12000,
  };
  // WJ65 — sanity cap on the EXACT bill entered: beyond it, a typo (e.g. an
  // extra zero) would produce an estimated figure with the same confidence as
  // a genuinely large commercial account — better to ask the visitor to check.
  // 200,000 MAD/month is already well beyond Taqinor's largest real
  // industrial clients; applies only to the EXACT amount, never to ranges.
  const MAX_BILL = 200_000;
  function resolveMonthlyBill(): number | null {
    const exact = num('mt-facture-hiver');
    if (exact != null && exact > 0) return exact;
    const range = val('mt-bill');
    if (range && RANGE_MIDPOINT[range] != null) return RANGE_MIDPOINT[range];
    return null;
  }

  // ——— WJ1 : calculer + afficher l'estimation instantanée ———
  let lastKwcLabel = '';
  let lastSavingsLabel = '';
  let lastKwc: number | null = null;
  // W356/W360 — full snapshot of the last REAL estimate shown (never
  // fabricated: identical to the numbers already on screen) — powers the
  // takeaway one-pager (W356) and the "cost of waiting" line (W360).
  let lastEstFull: { kwc: number; monthlyLabel: string; paybackLabel: string; savingsMonthlyLow: number } | null = null;
  // WJ88 — single, clean announcement of the result (never during the
  // skeleton phase): replaces the old aria-live set on the whole
  // #mt-estimate-card, which caused a screen-reader double-fire (skeleton
  // THEN result).
  function announceEstimate(message: string) {
    const el = $('mt-estimate-announce');
    if (el) el.textContent = message;
  }
  function computeEstimate() {
    const exact = num('mt-facture-hiver');
    const bill = resolveMonthlyBill();
    const card = $('mt-estimate-body');
    const note = $('mt-estimate-note');
    const unavail = $('mt-estimate-unavailable');
    const toolarge = $('mt-estimate-toolarge');
    const cowEl = $('mt-cost-of-waiting');
    const climateBandEl = $('mt-climate-band');
    const saveBtn = $('mt-save-estimate');
    const agricoleEl = $('mt-estimate-agricole');
    // WJ111 — AGRICULTURAL mode: `estimateFromBill` is mode-blind (bill only),
    // so showing its residential kWc/savings here would be a FALSE number for
    // a pumping project (the real driver is HMT + flow rate, not a bill). Show
    // the dedicated qualitative card instead and stop -- capture (lead + pump
    // fields) keeps working normally through the form, untouched here.
    if (mode === 'agricole') {
      if (card) card.hidden = true;
      if (note) note.hidden = true;
      if (unavail) unavail.hidden = true;
      if (toolarge) toolarge.hidden = true;
      if (agricoleEl) agricoleEl.hidden = false;
      setFieldError('mt-facture-hiver', 'mt-facture-hiver-err', null);
      lastKwcLabel = '';
      lastSavingsLabel = '';
      lastKwc = null;
      lastEstFull = null;
      if (cowEl) cowEl.hidden = true;
      if (climateBandEl) climateBandEl.hidden = true;
      { const nearestElAg = $('mt-nearest-install'); if (nearestElAg) nearestElAg.hidden = true; }
      if (saveBtn) saveBtn.hidden = true;
      updatePanels3dVisibility();
      announceEstimate('Pumping is sized on your head (HMT) and flow rate — an advisor will call you back with an adapted calculation.');
      return;
    }
    if (agricoleEl) agricoleEl.hidden = true;
    // WJ65 — exact amount beyond the cap: dedicated honest message (never a
    // confidently computed figure on a likely-mistaken entry) + inline error
    // on the field itself, without ever BLOCKING the step (the visitor can
    // correct it or fall back to a range).
    if (exact != null && exact > MAX_BILL) {
      if (card) card.hidden = true;
      if (note) note.hidden = true;
      if (unavail) unavail.hidden = true;
      if (toolarge) toolarge.hidden = false;
      setFieldError('mt-facture-hiver', 'mt-facture-hiver-err', 'Please check the amount entered.');
      lastKwcLabel = '';
      lastSavingsLabel = '';
      lastKwc = null;
      lastEstFull = null;
      if (cowEl) cowEl.hidden = true;
      if (climateBandEl) climateBandEl.hidden = true;
      { const nearestElTL = $('mt-nearest-install'); if (nearestElTL) nearestElTL.hidden = true; }
      if (saveBtn) saveBtn.hidden = true;
      updatePanels3dVisibility();
      announceEstimate('Estimate unavailable — please check the amount entered.');
      return;
    }
    setFieldError('mt-facture-hiver', 'mt-facture-hiver-err', null);
    if (toolarge) toolarge.hidden = true;
    const lat = capturePin?.lat;
    const city = (val('mt-city') || addressEl?.value || '').trim() || undefined;
    // WJ112 — the "refine my sizing" accordion now actually feeds the
    // calculation: declared exact kWh overrides the MAD bill when present, and
    // the chosen shading honestly derates production (see billEstimate.ts
    // OMBRAGE_DERATE — documented, never a fabricated number).
    const exactKwhMonthly = num('mt-bill-kwh') ?? undefined;
    const est = bill != null ? estimateFromBill(bill, { lat, city, exactKwhMonthly, ombrage: ombrage || undefined }) : null;
    if (!est) {
      if (card) card.hidden = true;
      if (note) note.hidden = true;
      if (unavail) unavail.hidden = false;
      lastKwcLabel = '';
      lastSavingsLabel = '';
      lastKwc = null;
      lastEstFull = null;
      if (cowEl) cowEl.hidden = true;
      if (climateBandEl) climateBandEl.hidden = true;
      { const nearestElNa = $('mt-nearest-install'); if (nearestElNa) nearestElNa.hidden = true; }
      if (saveBtn) saveBtn.hidden = true;
      updatePanels3dVisibility();
      announceEstimate('Estimate unavailable: enter your monthly bill to calculate it.');
      return;
    }
    if (card) card.hidden = false;
    if (note) note.hidden = false;
    if (unavail) unavail.hidden = true;
    const kwcEl = $('mt-est-kwc');
    const savEl = $('mt-est-savings');
    const payEl = $('mt-est-payback');
    if (kwcEl) kwcEl.textContent = formatKwc(est.kwc);
    const monthly = formatMadRange(est.savingsMonthlyLow, est.savingsMonthlyHigh);
    if (savEl) savEl.textContent = monthly;
    if (payEl) payEl.textContent = est.paybackLabel;
    lastKwcLabel = `${formatKwc(est.kwc)} kWc`;
    lastSavingsLabel = `${monthly}/mois`;
    lastKwc = est.kwc;
    // WJ71 — climate confidence band, shown only when it says something real
    // (a hot coastal summer lowers the low bound below the already-shown high).
    if (climateBandEl) {
      const climateBandValueEl = $('mt-climate-band-value');
      const showBand = est.savingsLowBand < est.savingsHigh;
      climateBandEl.hidden = !showBand;
      if (showBand && climateBandValueEl) {
        climateBandValueEl.textContent = formatMadRange(est.savingsLowBand, est.savingsLowBand);
      }
    }
    lastEstFull = {
      kwc: est.kwc,
      monthlyLabel: monthly,
      paybackLabel: est.paybackLabel,
      savingsMonthlyLow: est.savingsMonthlyLow,
    };
    // W342 — "installation closest to you": ONLY when a GPS pin was dropped
    // (capturePin) and a real Taqinor job site is within an honest radius
    // (<= 80 km, see nearestRealisation). Without a pin, the card stays
    // hidden -- never a guessed city from free text.
    const nearestEl = $('mt-nearest-install');
    if (nearestEl && capturePin) {
      const near = nearestRealisation(capturePin.lat, capturePin.lng);
      if (near) {
        const { realisation: r, distanceKm } = near;
        const textEl = $('mt-nearest-install-text');
        const linkEl = $('mt-nearest-install-link') as HTMLAnchorElement | null;
        const km = Math.round(distanceKm);
        if (textEl) textEl.textContent = `${r.ville} — ${r.kwc} — about ${km} km from you`;
        if (linkEl) linkEl.href = `/en/realisations/${r.slug}`;
        nearestEl.hidden = false;
      } else {
        nearestEl.hidden = true;
      }
    } else if (nearestEl) {
      nearestEl.hidden = true;
    }
    // W360 — cost of waiting DERIVED from the same low bound already shown
    // (never a separate/invented figure, never a countdown).
    if (cowEl) {
      const costEl = $('mt-cost-of-waiting-value');
      if (costEl) costEl.textContent = `${formatMad(est.savingsMonthlyLow)} MAD`;
      cowEl.hidden = est.savingsMonthlyLow <= 0;
    }
    if (saveBtn) saveBtn.hidden = false;
    updatePanels3dVisibility();
    // WJ59 — the real estimate is when the contact form becomes the relevant action.
    sendFunnelBeacon('contact', 'reached');
    // WJ88 — single, clean final announcement (never during the skeleton phase).
    announceEstimate(`Your estimate: ${formatKwc(est.kwc)} kWc, estimated savings ${monthly}/month, payback ${est.paybackLabel}.`);
  }
  // WJ34 — squelette bref pendant le calcul (performance perçue) : les 3
  // chiffres passent en squelette shimmer AVANT le calcul, puis
  // requestAnimationFrame laisse peindre ce squelette une fois avant de
  // révéler les vrais chiffres — sensation de « calcul », zéro CLS (mêmes
  // dimensions text-3xl), et prêt à absorber un futur calcul plus lourd
  // (PVGIS réseau) sans changement d'UX.
  function showEstimateSkeleton() {
    const card = $('mt-estimate-body');
    const unavail = $('mt-estimate-unavailable');
    const toolarge = $('mt-estimate-toolarge');
    if (unavail) unavail.hidden = true;
    if (toolarge) toolarge.hidden = true;
    if (card) card.hidden = false;
    for (const id of ['mt-est-kwc', 'mt-est-savings']) {
      const el = $(id);
      if (el) el.innerHTML = '<span class="mt-est-skeleton mt-skeleton-shimmer"></span>';
    }
    const payEl = $('mt-est-payback');
    if (payEl) payEl.innerHTML = '<span class="mt-est-skeleton mt-skeleton-shimmer"></span>';
  }
  // WJ48/WJ112 — branded anticipation, CUT to <=500 ms (250-450 ms, randomised):
  // the real calculation (billEstimate) is synchronous and instant -- a very
  // short perceived delay still lets the visitor "see" a calculation happen
  // (Enpal/EnergySage's pattern) without breaking WJ112's <=0.5 s first-number
  // promise, including live recalcs (shading/exact kWh/mode).
  // reduced-motion -> INSTANT (no artificial delay, no spinner to watch) -- unchanged.
  const THINKING_MIN_MS = 250;
  const THINKING_MAX_MS = 450;
  function thinkingDelayMs(): number {
    if (reducedMotion) return 0;
    return THINKING_MIN_MS + Math.random() * (THINKING_MAX_MS - THINKING_MIN_MS);
  }
  $('mt-estimate')?.addEventListener('click', () => {
    showEstimateSkeleton();
    const thinkingEl = $('mt-estimate-thinking');
    if (thinkingEl) thinkingEl.hidden = false;
    goStep(2);
    requestAnimationFrame(() => {
      setTimeout(() => {
        if (thinkingEl) thinkingEl.hidden = true;
        computeEstimate();
      }, thinkingDelayMs());
    });
  });
  // recalcule à la volée si l'utilisateur revient corriger sa facture
  $('mt-facture-hiver')?.addEventListener('input', computeEstimate);
  $('mt-bill')?.addEventListener('change', computeEstimate);
  // WJ112 — exact kWh now feeds the calculation, so it must recompute live too.
  $('mt-bill-kwh')?.addEventListener('input', computeEstimate);

  // ——— WJ2 : « voir les panneaux sur votre toit » — facultatif, lazy, dégrade
  // proprement (pas de WebGL / pas de contour tracé → le bloc reste masqué). ———
  const panels3dBlock = $('mt-panels3d') as HTMLElement | null;
  const panels3dStage = $('mt-panels3d-stage') as HTMLElement | null;
  const panels3dOverlay = $('mt-panels3d-overlay') as HTMLElement | null;
  const panels3dStart = $('mt-panels3d-start') as HTMLButtonElement | null;
  const panels3dHint = $('mt-panels3d-hint') as HTMLElement | null;
  let panels3dStarted = false;

  /** Le bouton n'apparaît QUE si un contour (≥3 sommets) a été tracé ET qu'un
   *  kWc est disponible — sinon rien de significatif à montrer (pas de faux
   *  aperçu sur un simple repère). */
  function updatePanels3dVisibility() {
    if (!panels3dBlock) return;
    const eligible = captureOutline.length >= 3 && lastKwc != null;
    panels3dBlock.hidden = !eligible;
  }

  async function startPanels3d() {
    if (panels3dStarted || !panels3dStage || lastKwc == null) return;
    panels3dStarted = true;
    try {
      const [{ capturePreviewLayout, buildViewerModel }, { createRoofViewer }] = await Promise.all([
        import('../../../lib/proposition'),
        import('../../../scripts/roofPro11/viewerOnly'),
      ]);
      const layout = capturePreviewLayout(captureOutline, lastKwc);
      const model = layout ? buildViewerModel(layout) : null;
      if (!model) throw new Error('modèle indisponible');
      const nav = navigator as Navigator & { deviceMemory?: number; connection?: { saveData?: boolean } };
      const lowEnd = (nav.deviceMemory != null && nav.deviceMemory <= 4) || (navigator.hardwareConcurrency || 8) <= 4;
      const handle = createRoofViewer(panels3dStage, model, {
        reducedMotion,
        lowEnd,
        onReady: () => {
          if (panels3dOverlay) panels3dOverlay.hidden = true;
          if (panels3dHint) panels3dHint.hidden = false;
        },
        onFail: () => { panels3dStarted = false; },
      });
      if (!handle) throw new Error('WebGL indisponible');
    } catch {
      // Repli gracieux : le bouton reste, avec un message sobre — jamais de blocage.
      panels3dStarted = false;
      if (panels3dOverlay) {
        const btn = panels3dStart;
        if (btn) {
          btn.disabled = true;
          btn.textContent = '3D preview unavailable on this device';
        }
      }
    }
  }
  panels3dStart?.addEventListener('click', () => { void startPanels3d(); });

  // ——— W356 : takeaway "Save my estimate" — a LIGHTWEIGHT one-pager generated
  // 100% client-side (canvas → PNG), NO server call, NO new dependency.
  // Content strictly identical to what's already on screen: kWc, savings
  // range, caveat, wa.me link — nothing invented here. ———
  function drawWrappedText(ctx: CanvasRenderingContext2D, text: string, x: number, y: number, maxWidth: number, lineHeight: number): number {
    const words = text.split(' ');
    let line = '';
    let cy = y;
    for (const word of words) {
      const test = line ? `${line} ${word}` : word;
      if (ctx.measureText(test).width > maxWidth && line) {
        ctx.fillText(line, x, cy);
        line = word;
        cy += lineHeight;
      } else {
        line = test;
      }
    }
    if (line) { ctx.fillText(line, x, cy); cy += lineHeight; }
    return cy;
  }
  function buildEstimatePng(): string | null {
    if (!lastEstFull) return null;
    const W = 640;
    const H = 380;
    const canvas = document.createElement('canvas');
    canvas.width = W;
    canvas.height = H;
    const ctx = canvas.getContext('2d');
    if (!ctx) return null;
    ctx.fillStyle = '#0a0e1f';
    ctx.fillRect(0, 0, W, H);
    ctx.fillStyle = '#caa15a';
    ctx.font = '600 14px system-ui, sans-serif';
    ctx.fillText('Taqinor — solar estimate', 32, 44);
    ctx.fillStyle = '#ffffff';
    ctx.font = '700 40px system-ui, sans-serif';
    ctx.fillText(`${formatKwc(lastEstFull.kwc)} kWc`, 32, 104);
    ctx.font = '600 22px system-ui, sans-serif';
    ctx.fillStyle = '#4ade80';
    ctx.fillText(`Estimated savings: ${lastEstFull.monthlyLabel}/month`, 32, 144);
    ctx.fillStyle = '#e5e7eb';
    ctx.font = '500 18px system-ui, sans-serif';
    ctx.fillText(`Payback: ${lastEstFull.paybackLabel}`, 32, 178);
    ctx.fillStyle = '#9ca3af';
    ctx.font = 'italic 400 14px system-ui, sans-serif';
    let cy = drawWrappedText(
      ctx,
      'Preliminary estimate, refined after a technical site visit. Not contractual.',
      32, 216, W - 64, 20,
    );
    cy += 12;
    ctx.strokeStyle = 'rgba(255,255,255,0.15)';
    ctx.beginPath();
    ctx.moveTo(32, cy);
    ctx.lineTo(W - 32, cy);
    ctx.stroke();
    ctx.fillStyle = '#ffffff';
    ctx.font = '600 15px system-ui, sans-serif';
    ctx.fillText('WhatsApp: wa.me/212661850410', 32, cy + 34);
    ctx.fillStyle = '#6b7280';
    ctx.font = '400 12px system-ui, sans-serif';
    ctx.fillText('taqinor.ma', 32, H - 20);
    return canvas.toDataURL('image/png');
  }
  $('mt-save-estimate')?.addEventListener('click', () => {
    const dataUrl = buildEstimatePng();
    const note = $('mt-save-estimate-note');
    if (!dataUrl) return;
    try {
      const a = document.createElement('a');
      a.href = dataUrl;
      a.download = 'taqinor-solar-estimate.png';
      document.body.appendChild(a);
      a.click();
      a.remove();
      if (note) note.hidden = false;
    } catch {
      // Honest fallback: the image stays visible on screen even if the
      // download fails (e.g. a browser blocking data: URLs) — never a
      // silent block of the action.
      if (note) note.hidden = true;
    }
  });

  // ——— WJ4 : validation INLINE alignée sur validateLead (avant le round-trip) ———
  function setFieldError(inputId: string, errId: string, message: string | null) {
    const input = $(inputId) as HTMLInputElement | null;
    const err = $(errId);
    if (input) input.setAttribute('aria-invalid', message ? 'true' : 'false');
    if (err) {
      err.textContent = message || '';
      err.hidden = !message;
    }
  }
  // ——— WJ52 : short client reference, generated ONCE in the browser ———
  // Stable across repeated submissions (e.g. a network failure then a retry):
  // generated on the first attempt, reused as-is afterwards — never silently
  // regenerated, never a server uniqueness key (see lib/lead.ts).
  let clientRef = '';
  function getOrCreateClientRef(): string {
    if (!clientRef) clientRef = buildClientRef();
    return clientRef;
  }

  // WJ116 — reprise fbclid + UTM depuis sessionStorage (capture first-touch du
  // Layout, apps/web/src/layouts/Layout.astro ~l.206) : sans ceci, AUCUNE
  // attribution UTM (parrainage compris — /parrainage) ne partait jamais sur ce
  // funnel PRINCIPAL alors que le webhook / validateLead les acceptent déjà.
  // Miroir exact de DiagnosticForm.astro ~l.279. Seules les clés PRÉSENTES sont
  // jointes (convention WJ30/WJ31 « absent plutôt que vide ») : un visiteur sans
  // paramètre de tracking envoie un corps byte-identique à avant.
  const TRACK_KEYS = ['fbclid', 'utm_source', 'utm_medium', 'utm_campaign', 'utm_content', 'utm_term'] as const;
  function readTrackingParams(): Record<string, string> {
    const out: Record<string, string> = {};
    for (const k of TRACK_KEYS) {
      try {
        const v = sessionStorage.getItem('tq_' + k);
        if (v) out[k] = v;
      } catch {}
    }
    return out;
  }

  /** Construit le corps de lead + renvoie les erreurs client (miroir validateLead). */
  function buildBody(): { body: Record<string, unknown>; errors: Record<string, string> } {
    const eteDifferente = eteToggle?.checked === true;
    const consent = ($('mt-consent') as HTMLInputElement | null)?.checked === true;
    // WJ51 — explicit contact preference ("WhatsApp only" vs "An advisor may
    // call me"): `whatsappOptIn` stays derived so nothing breaks CRM/webhook
    // side, `contactPreference` is forwarded in addition (maps to `canal`).
    const contactPreference = (($('mt-contact-phone') as HTMLInputElement | null)?.checked === true)
      ? 'phone_ok'
      : 'whatsapp_only';
    const whatsappOptIn = contactPreference === 'whatsapp_only';
    const adresse = (val('mt-city') || addressEl?.value.trim() || fallbackAddrEl?.value.trim() || '').trim();
    const body: Record<string, unknown> = {
      fullName: val('mt-name'),
      phone: val('mt-phone'),
      city: adresse,
      billRange: val('mt-bill'),
      roofType: val('mt-roof'),
      consent,
      whatsappOptIn,
      contactPreference,
      email: val('mt-email') || undefined,
      factureHiver: num('mt-facture-hiver'),
      factureEte: eteDifferente ? num('mt-facture-ete') : null,
      eteDifferente,
      raccordement: val('mt-raccordement'),
      adresse,
      // WJ30 — le type de projet part au webhook. WJ39 — cette page n'a pas de
      // bascule FR/AR (l'URL /en/ déclare déjà la locale) et `langue_preferee`
      // n'accepte que fr/ar (src/lib/lead.ts LEAD_LANGS) : on l'omet.
      mode,
      // WJ31 — questions de capture élargies, TOUTES facultatives (déjà validées
      // une à une côté serveur : un champ vide/malformé est simplement écarté).
      distributeur: val('mt-distributeur') || undefined,
      billKwh: num('mt-bill-kwh'),
      ombrage: ombrage || undefined,
      roofAgeYears: num('mt-roof-age'),
      futureLoads: futureLoads.size > 0 ? Array.from(futureLoads) : undefined,
      batteryInterest: ($('mt-battery-interest') as HTMLInputElement | null)?.checked === true,
      occupantType: val('mt-occupant-type') || undefined,
      projectTiming: val('mt-project-timing') || undefined,
      financingIntent: val('mt-financing-intent') || undefined,
      hasMeterPhoto,
      // WJ52 — short reference for the post-submission artefact (echoed as-is,
      // never a server uniqueness key — see lib/lead.ts).
      clientRef: getOrCreateClientRef(),
      // W353 — technical visit slot preference (optional, STATIC).
      visitWindowPart: visitWindowPart || undefined,
      visitWindowWeek: visitWindowWeek || undefined,
      // WJ68 — professionnel mode: optional, additive, never blocking.
      raisonSociale: val('mt-raison-sociale') || undefined,
      facilityType: val('mt-facility-type') || undefined,
      siteCount: val('mt-site-count') || undefined,
      // W317 — honeypot: empty for any human visitor (hidden off-screen
      // field, never knowingly filled); rejected server-side if not empty.
      website_url: val('mt-hp'),
    };
    // WJ116 — fbclid/UTM (parrainage inclus) : joints seulement s'ils existent.
    Object.assign(body, readTrackingParams());
    // WJ4 — repère FACULTATIF : on le joint s'il existe, on ne BLOQUE jamais sans lui.
    if (capturePin) {
      body.roofPoint = capturePin;
      body.gpsLat = capturePin.lat;
      body.gpsLng = capturePin.lng;
    }
    if (captureOutline.length >= 3) body.roofOutline = captureOutline;
    const v = validateLead(body);
    const errors: Record<string, string> = v.ok ? {} : { ...v.errors };
    // WJ65 — validateLead (lib/lead.ts, out of this page's file scope) only
    // requires a length ≥ 2: a name made only of emoji/symbols (e.g. "😀😀")
    // used to pass silently. We require at least ONE letter (any alphabet —
    // \p{L} covers Latin) before submitting.
    if (!errors.fullName && !/\p{L}/u.test(val('mt-name'))) {
      errors.fullName = 'Nom complet requis'; // enMsg() below translates this known key.
    }
    return { body, errors };
  }

  // WJ39 — the shared validateLead() (src/lib/lead.ts, out of this page's file
  // scope) returns French messages; translate the known set to English so
  // inline errors never show French on this route (see VALIDATION_ERROR_EN above).
  const enMsg = (msg: string | null | undefined): string | null =>
    msg == null ? null : (VALIDATION_ERROR_EN[msg] ?? msg);
  function showInlineErrors(errors: Record<string, string>) {
    setFieldError('mt-name', 'mt-name-err', enMsg(errors.fullName));
    setFieldError('mt-phone', 'mt-phone-err', enMsg(errors.phone));
    setFieldError('mt-city', 'mt-city-err', enMsg(errors.city));
    setFieldError('mt-roof', 'mt-roof-err', enMsg(errors.roofType));
    setFieldError('mt-bill', 'mt-bill-err', enMsg(errors.billRange));
    const cErr = $('mt-consent-err');
    const consentMsg = enMsg(errors.consent);
    if (cErr) { cErr.textContent = consentMsg ?? ''; cErr.hidden = !consentMsg; }
  }

  // ——— WJ3 : deeplink WhatsApp prérempli avec l'estimation ———
  function buildWaUrl(): string {
    const text = captureWhatsappText({
      fullName: val('mt-name'),
      city: (val('mt-city') || addressEl?.value || '').trim(),
      kwcLabel: lastKwcLabel || undefined,
      savingsLabel: lastSavingsLabel || undefined,
    });
    return whatsappLink(WHATSAPP_LEADS, text);
  }

  // ——— soumission → /api/capture-lead (contrat INCHANGÉ) ———
  const form = $('mt-form') as HTMLFormElement | null;
  const errEl = $('mt-error');
  const okEl = $('mt-success');
  const belowEl = $('mt-belowthreshold');
  const submitBtn = $('mt-submit') as HTMLButtonElement | null;
  const submitLabelEl = $('mt-submit-label');
  const submitPendingEl = $('mt-submit-pending');
  let submitted = false;

  // WJ60 — toggle the CTA to "Sending…" while the network request is pending
  // (never a mute button on slow 3G); restored at the end regardless of
  // outcome (except success, where the whole form disables right after).
  function setSubmitPending(pending: boolean) {
    if (submitBtn) submitBtn.disabled = pending;
    if (submitLabelEl) submitLabelEl.hidden = pending;
    if (submitPendingEl) submitPendingEl.hidden = !pending;
  }

  // WJ60 — HONEST message for a SERVER-SIDE failure (≥500, malformed JSON,
  // timeout, network cut): never blames the visitor's fields for a failure
  // that isn't theirs. WJ63 — the client ALWAYS prefers its own localised copy
  // over server-sent text (e.g. the rate-limit's 429 message, in French on
  // the API side): `data.errors` is only shown as-is for REAL field errors
  // (4xx validation), never for a generic server failure.
  const SERVER_ERROR_MSG = 'A technical problem on our side — please try again.';
  // WJ45 — DISTINCT message when the cut comes from the visitor's own network
  // (not our side): reassures that nothing is lost instead of the generic
  // "problem on our side" line.
  const OFFLINE_MSG = "No connection — your answers are kept, we'll retry as soon as the network is back.";
  // WJ60 — 15 s gives a slow connection time to respond, without leaving the
  // "Sending…" CTA hanging indefinitely (the failure, timeout included, falls
  // into the honest message above — never a silent block).
  const SUBMIT_TIMEOUT_MS = 15_000;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (errEl) errEl.hidden = true;
    const { body, errors } = buildBody();
    if (Object.keys(errors).length > 0) {
      showInlineErrors(errors);
      if (errEl) {
        errEl.textContent = 'Please check the highlighted fields above.';
        errEl.hidden = false;
      }
      // amène l'utilisateur au premier champ en erreur.
      // WJ48 — mt-roof est désormais sr-only (le choix visuel se fait via les
      // cartes .mt-roof-card) : focaliser le <select> caché déplacerait le
      // focus clavier sur un élément invisible pour un utilisateur voyant. On
      // focalise plutôt la première carte visible dans ce cas.
      const firstId = ['mt-name', 'mt-phone', 'mt-city', 'mt-roof', 'mt-bill']
        .find((id) => $(id)?.getAttribute('aria-invalid') === 'true');
      if (firstId === 'mt-roof') {
        document.querySelector<HTMLButtonElement>('.mt-roof-card')?.focus();
      } else if (firstId) {
        ($(firstId) as HTMLElement | null)?.focus();
      }
      return;
    }
    showInlineErrors({});

    setSubmitPending(true);
    try {
      const res = await fetch('/api/capture-lead', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify(body),
        signal: AbortSignal.timeout(SUBMIT_TIMEOUT_MS),
      });
      // WJ60/WJ63 — a malformed JSON response (empty/unreadable body) is
      // treated as a server failure, never silently as "no error".
      let malformed = false;
      const data = (await res.json().catch(() => {
        malformed = true;
        return {};
      })) as { ok?: boolean; qualified?: boolean; errors?: Record<string, string> };
      if (res.ok && !malformed && data.ok) {
        submitted = true;
        hasEnteredData = false; // WJ61 — success: no longer need the beforeunload guard.
        clearWizardState(); // WJ61 — the request went through: the snapshot no longer applies.
        const waUrl = buildWaUrl();
        // WJ5 — réponse HONNÊTE selon le seuil 1 000 MAD (qualified renvoyé par le serveur).
        if (data.qualified) {
          if (okEl) okEl.hidden = false;
          // WJ52 — display the reference generated in buildBody() (already
          // included in the sent body — re-read here via getOrCreateClientRef()
          // to stay the SAME value, never regenerated).
          const refEl = $('mt-client-ref');
          if (refEl) refEl.textContent = getOrCreateClientRef();
          const waLink = $('mt-success-wa') as HTMLAnchorElement | null;
          if (waLink) waLink.href = waUrl;
          // WJ3/WJ51 — on mobile, offer WhatsApp right away when the contact
          // preference is "WhatsApp only" (the option checked by default).
          const wantsWa = ($('mt-contact-phone') as HTMLInputElement | null)?.checked !== true;
          if (wantsWa && /Mobi|Android|iPhone/i.test(navigator.userAgent) && !reducedMotion) {
            setTimeout(() => { window.location.href = waUrl; }, 900);
          }
        } else {
          // sous le seuil : PAS de faux « enregistré » — message adapté + WhatsApp.
          if (belowEl) belowEl.hidden = false;
          const belowWa = $('mt-belowthreshold-wa') as HTMLAnchorElement | null;
          if (belowWa) belowWa.href = waUrl;
        }
        // désactive les champs après envoi (sauf les liens WhatsApp).
        Array.from(form.elements).forEach((el) => ((el as HTMLInputElement).disabled = true));
        return;
      }
      // WJ60/WJ63 — ≥500 or malformed JSON: SERVER-SIDE failure, never a
      // message that blames the fields. Below 500 with usable field errors
      // (4xx validation, e.g. `errors.fullName`), we still show them inline
      // as before — but a server text that is NOT a known field error (e.g.
      // `errors.rate`, the rate-limit's 429, in French on the API side) never
      // overwrites our honest copy: only the `errors.rate` field falls back
      // to the same generic server message.
      const isServerError = malformed || res.status >= 500 || (!!data.errors && 'rate' in data.errors);
      if (!isServerError && data.errors) showInlineErrors(data.errors);
      const firstFieldErr = !isServerError && data.errors ? Object.values(data.errors)[0] : null;
      if (errEl) {
        errEl.textContent = isServerError
          ? SERVER_ERROR_MSG
          : ((firstFieldErr && (VALIDATION_ERROR_EN[firstFieldErr] ?? firstFieldErr)) || 'A field is missing or invalid. Please check your information.');
        errEl.hidden = false;
      }
      setSubmitPending(false);
    } catch {
      // WJ60 — covers the timeout (AbortSignal.timeout) and any network
      // outage. WJ45 — if the browser knows it's offline, say so explicitly
      // (banner + dedicated message) rather than the generic "problem on our
      // side" — which would wrongly blame our infrastructure. The form stays
      // filled and the WJ61 sessionStorage snapshot persists: nothing is
      // lost, just resend once the network is back.
      syncOfflineBanner();
      if (errEl) {
        errEl.textContent = navigator.onLine ? SERVER_ERROR_MSG : OFFLINE_MSG;
        errEl.hidden = false;
      }
      setSubmitPending(false);
    }
  });

  // ——— WJ7/WJ33 : récupération d'abandon (exit-intent desktop + retour/onglet caché mobile) ———
  const exitModal = $('mt-exit') as HTMLElement | null;
  const exitPhoneInput = $('mt-exit-phone') as HTMLInputElement | null;
  const exitWaLink = $('mt-exit-wa') as HTMLAnchorElement | null;
  let exitShown = false;
  let exitTriggerEl: HTMLElement | null = null; // WJ33 — pour restaurer le focus à la fermeture

  /** WJ33 — construit (ou reconstruit) le lien WhatsApp d'abandon depuis l'état actuel. */
  function buildExitWaHref(): string {
    const phone = exitPhoneInput?.value.trim() || '';
    const text = captureWhatsappText({
      fullName: '',
      city: (val('mt-city') || addressEl?.value || '').trim(),
      kwcLabel: lastKwcLabel || undefined,
      savingsLabel: lastSavingsLabel || undefined,
    }) + (phone.length >= 6 ? ` Mon numéro : ${phone}.` : '');
    return whatsappLink(WHATSAPP_LEADS, text);
  }

  // WJ59 — "step abandoned": tracked separately from the WhatsApp offer
  // (which only shows once per visit via `exitShown`), since the measurement
  // signal stays useful even if the offer already showed once.
  let funnelAbandonSent = false;
  function maybeShowExit(triggerEl: HTMLElement | null = null) {
    if (exitShown || submitted) return;
    // ne déranger que si l'utilisateur a au moins commencé (mode/facture ou step > 0)
    const started2 = step > 0 || resolveMonthlyBill() != null || (capturePin != null);
    if (!started2) return;
    if (!funnelAbandonSent) {
      funnelAbandonSent = true;
      const currentStep = step === 0 ? 'toit' : step === 1 ? 'facture' : (lastKwc != null ? 'contact' : 'estimation');
      sendFunnelBeacon(currentStep, 'abandoned');
    }
    exitShown = true;
    exitTriggerEl = triggerEl ?? (document.activeElement as HTMLElement | null);
    if (exitWaLink) exitWaLink.href = buildExitWaHref();
    if (exitModal) {
      exitModal.hidden = false;
      // WJ33 — focus initial DANS la modale (premier champ interactif).
      exitPhoneInput?.focus();
    }
  }
  function closeExit() {
    if (!exitModal || exitModal.hidden) return;
    exitModal.hidden = true;
    // WJ33 — restauration du focus vers l'élément qui a déclenché l'ouverture
    // (ou, à défaut, un point d'ancrage stable de la page — pas de bascule de
    // langue sur cette route EN, cf. WJ39).
    (exitTriggerEl && document.contains(exitTriggerEl) ? exitTriggerEl : $('mt-next-0'))?.focus();
    exitTriggerEl = null;
  }
  // desktop : la souris quitte par le haut
  document.addEventListener('mouseout', (e) => {
    if (!e.relatedTarget && (e as MouseEvent).clientY <= 0) maybeShowExit();
  });
  // mobile : l'onglet passe en arrière-plan
  document.addEventListener('visibilitychange', () => {
    if (document.visibilityState === 'hidden') maybeShowExit();
  });
  $('mt-exit-close')?.addEventListener('click', () => closeExit());
  exitModal?.addEventListener('click', (e) => { if (e.target === exitModal) closeExit(); });

  // WJ33 — clavier : Esc ferme + focus trap (Tab/Shift+Tab restent DANS la modale).
  exitModal?.addEventListener('keydown', (e) => {
    const ke = e as KeyboardEvent;
    if (ke.key === 'Escape') { closeExit(); return; }
    if (ke.key !== 'Tab' || !exitModal) return;
    const focusable = Array.from(
      exitModal.querySelectorAll<HTMLElement>('a[href], button:not([disabled]), input:not([disabled]), [tabindex]:not([tabindex="-1"])'),
    ).filter((el) => el.offsetParent !== null || el === document.activeElement);
    if (focusable.length === 0) return;
    const first = focusable[0];
    const last = focusable[focusable.length - 1];
    const active = document.activeElement as HTMLElement | null;
    if (ke.shiftKey && active === first) {
      ke.preventDefault();
      last.focus();
    } else if (!ke.shiftKey && active === last) {
      ke.preventDefault();
      first.focus();
    }
  });

  // WJ33 — le CTA WhatsApp d'abandon : le lien `href` est reconstruit à CHAQUE
  // saisie (pas seulement au clic), pour rester correct si l'utilisateur
  // ouvre WhatsApp via un clic droit / « copier le lien » avant de finir de taper.
  exitPhoneInput?.addEventListener('input', () => {
    const err = $('mt-exit-err');
    if (err) err.hidden = true;
    if (exitWaLink) exitWaLink.href = buildExitWaHref();
  });
  exitWaLink?.addEventListener('click', (e) => {
    const phone = exitPhoneInput?.value.trim() || '';
    const err = $('mt-exit-err');
    if (phone.length < 6) {
      e.preventDefault();
      if (err) { err.textContent = 'Please enter a number so we can reply to you.'; err.hidden = false; }
      return;
    }
    if (err) err.hidden = true;
  });
</script>
