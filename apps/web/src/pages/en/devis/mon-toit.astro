  // page uses its own BILL_RANGE_LABEL_EN map for the detected-range line.
  import { billRangeFromExact, type BillRangeId } from '../../../lib/billRange';
  import { captureWhatsappText, whatsappLink } from '../../../lib/whatsapp';
  import { WHATSAPP_LEADS } from '../../../lib/nap';
  import { buildClientRef, validateLead, MAX_BILL_BY_MODE } from '../../../lib/lead';
  // QX/Lane C — TYPE only (erased at build: Three.js/viewerOnly NEVER joins
  // the initial bundle — WJ18; the real module stays a lazy import()).
  import type { RoofImageSpec } from '../../../scripts/roofPro11/viewerOnly';
  // WJ72 — single kWc number style, shared with the proposal (src/lib/proposition.ts):
  // comma decimal, trailing zeros stripped — never the raw dot from `String(est.kwc)`.
  import { formatKwc } from '../../../lib/proposition';
  // W342 — "closest installation": client-side haversine over the dropped GPS
  // pin (no network call).
  import { nearestRealisation } from '../../../lib/realisations';
  import { type CaptureStrings } from '../../../scripts/roofPro11/mapDraw';

  // WJ39 — the shared client libs (lib/lead.ts, lib/billRange.ts,
  // scripts/roofPro11/mapDraw.ts) return/default to French text; this page
  // supplies its own English copy so this route never speaks French where a
  // visitor can see it. Only the WhatsApp deep-link text stays French by
  // design (frontmatter note above) — it reaches the French-speaking sales team.

  // Detected-range label (QX bill auto-detect) — own English map, the
  // frontmatter's BILL_RANGE_LABEL_EN is NOT reachable here (a plain
  // <script> tag compiles to a separate client module with no access to
  // frontmatter bindings).
  const BILL_RANGE_LABEL_EN: Record<string, string> = {
    lt800: 'Under 800 MAD',
    '800-1000': '800 – 1,000 MAD',
    '1000-1500': '1,000 – 1,500 MAD',
    '1500-3000': '1,500 – 3,000 MAD',
    '3000-5000': '3,000 – 5,000 MAD',
    '5000-10000': '5,000 – 10,000 MAD',
    gt10000: 'Over 10,000 MAD',
  };

  // WJ39 — known client-side validateLead() error strings (src/lib/lead.ts,
  // out of this page's file scope) translated to English so inline field
  // errors never show French on this route. Falls back to the raw (French)
  // message only if the shared validator ever returns something outside
  // this known set.
  const VALIDATION_ERROR_EN: Record<string, string> = {
    'Nom complet requis': 'Full name required',
    'Numéro invalide': 'Invalid number',
    'Numéro invalide — format attendu : 06 XX XX XX XX ou +212 6 XX XX XX XX':
      'Invalid number — expected format: 06 XX XX XX XX or +212 6 XX XX XX XX',
    'Ville / commune requise': 'City / town required',
    'Type de toiture requis': 'Roof type required',
    'Tranche de facture requise': 'Bill range required',
    'Le consentement est requis pour être recontacté': 'Consent is required so we can contact you back',
  };

  // WJ41 — map/geocoder system messages (roofPro11/mapDraw.ts + captureBoot.ts
  // default to French); this page passes English strings so the single most
  // interactive moment of the funnel never speaks French to EN visitors.
  const ROOF_TOOL_STRINGS_EN: CaptureStrings = {
    searchAddressThenPin: 'Search for your address, then drop a pin on your roof.',
    pinPlaced: 'Pin placed. You can adjust it, or trace the outline (optional), then fill in your details.',
    outlineTraced: 'Outline traced. Fill in your details below, then submit.',
    traceOutline: 'Trace the outline of your roof. Double-click to close it (optional).',
    outlineCrosses: 'Your trace crosses itself — fix it ("Clear") before closing.',
    pointWouldCross: 'This point would cross your trace — place it elsewhere to keep a simple outline.',
    doubleClickToClose: 'Double-click (or "Finish") to close the roof and start the calculation.',
    cornerPlaced: (n) => `Corner ${n} placed — keep tracing the outline.`,
    lastPointUndone: (n) => `Last point undone — ${n} corner(s) remaining. Keep tracing.`,
    clickCornersToClose: 'Click the corners of your roof. Double-click to close it and start the calculation.',
    searchingAddress: 'Searching for the address…',
    addressNotFound: 'Address not found. Specify the city or move the map by hand.',
    chooseFromList: 'Choose your address from the list, then click the corners of your roof.',
    searchUnavailable: 'Search unavailable. Move the map by hand to find your roof.',
  };

  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const $ = (id: string) => document.getElementById(id);
  const fallback = $('mt-fallback');
  const cityEl = $('mt-city') as HTMLInputElement | null;
  const addressEl = $('rp9-address') as HTMLInputElement | null;
  const fallbackAddrEl = $('mt-fallback-address') as HTMLInputElement | null;

  // ——— WJ59 : per-step funnel beacon (privacy-light, no PII) ———
  // Anonymous PER-TAB token (sessionStorage, never a device/user id): only
  // used to dedupe/correlate "reached"/"abandoned" events within ONE visit,
  // never to identify a visitor. See src/lib/funnelBeacon.ts for the full
  // contract (strict 4-field allowlist, never name/phone/email/address/GPS/outline).
  const FUNNEL_TOKEN_KEY = 'mt-funnel-token-v1';
  function getFunnelToken(): string {
    try {
      let t = sessionStorage.getItem(FUNNEL_TOKEN_KEY);
      if (!t) {
        t = Math.random().toString(36).slice(2) + Date.now().toString(36);
        sessionStorage.setItem(FUNNEL_TOKEN_KEY, t);
      }
      return t;
    } catch {
      // sessionStorage unavailable: an ephemeral token (single request, no
      // correlation possible) — never a block on measurement or UX.
      return Math.random().toString(36).slice(2);
    }
  }
  const funnelToken = getFunnelToken();
  const funnelStepReached = new Set<string>(); // avoids duplicate "reached" events on re-render.
  // WB30 — consent (the checkbox) only exists in panel 2 (contact): until the
  // visitor has reached that panel, no behavioural signal should leave, even
  // anonymous/best-effort. `hasReachedConsentStep` reads the `step` variable
  // (the wizard step number, declared below) — checked at CALL time, never
  // inside `sendFunnelBeacon` (whose `step` parameter deliberately shadows it).
  function hasReachedConsentStep(): boolean {
    return step >= 2;
  }
  /** Best-effort, NEVER blocking: sendBeacon survives tab close, with a
   *  fetch(keepalive) fallback if sendBeacon is unavailable. No PII possible
   *  in this body (4 fields only — see lib/funnelBeacon.ts). WB30 — emits
   *  nothing before the consent step (panel 2) is reached — see
   *  hasReachedConsentStep, checked by every caller.
   *  WJ104 — `action` widened to `viewed`/`callback_requested`; `reached`/
   *  `abandoned` stay unchanged for every existing caller. */
  function sendFunnelBeacon(
    step: 'toit' | 'facture' | 'estimation' | 'contact',
    action: 'reached' | 'abandoned' | 'viewed' | 'callback_requested',
  ) {
    // WJ104 — same dedupe discipline as "reached": an event that is only
    // meaningful once must never fire in a loop (e.g. the estimate
    // recomputing several times while the visitor adjusts their bill).
    if (action === 'reached' || action === 'viewed' || action === 'callback_requested') {
      const key = `${step}:${action}`;
      if (funnelStepReached.has(key)) return;
      funnelStepReached.add(key);
    }
    try {
      const payload = JSON.stringify({ step, action, sessionToken: funnelToken, path: location.pathname });
      if (navigator.sendBeacon) {
        const blob = new Blob([payload], { type: 'application/json' });
        navigator.sendBeacon('/api/funnel-beacon', blob);
      } else {
        void fetch('/api/funnel-beacon', { method: 'POST', headers: { 'content-type': 'application/json' }, body: payload, keepalive: true }).catch(() => {});
      }
    } catch {
      // Best-effort measurement only — must never disrupt the flow.
    }
  }

  // ——— capture state (pin / outline) held by onCaptureChange ———
  let capturePin: { lat: number; lng: number } | null = null;
  let captureOutline: Array<[number, number]> = [];
  let cityTouched = false;
  cityEl?.addEventListener('input', () => { cityTouched = true; });

  // WJ39 — no in-page language toggle on this route: the /en/ URL already
  // declares the locale (Layout.astro sets <html lang="en" dir="ltr">), so
  // the FR/AR dual-node data-i18n toggle used by the FR/AR variants doesn't
  // apply here. `langue_preferee` (fr/ar only, src/lib/lead.ts LEAD_LANGS)
  // is simply omitted from the submitted body below — the webhook contract
  // stays unchanged (the field is optional).

  // ——— WJ61 : the wizard's state survives a refresh/back navigation ———
  // A phone call or an accidental back-swipe used to silently destroy
  // everything typed — the costliest UX failure in the funnel. We persist a
  // minimal snapshot (step/mode/bill/pin-outline/optional answers) to
  // sessionStorage (per tab, never shared between visitors): rehydrated on
  // load, cleared on success. Never blocks submission if sessionStorage is
  // unavailable (strict private browsing…).
  const WIZARD_STORAGE_KEY = 'mt-wizard-v1';
  interface WizardSnapshot {
    step?: number;
    mode?: string;
    ombrage?: string;
    visitWindowPart?: string;
    visitWindowWeek?: string;
    futureLoads?: string[];
    // QX — states of the PRO + AGRICULTURAL card/segment groups (tension,
    // activity, surface, generator, water source, irrigation, units).
    sel?: Record<string, string>;
    capturePin?: { lat: number; lng: number } | null;
    captureOutline?: Array<[number, number]>;
    fields?: Record<string, string>;
    checks?: Record<string, boolean>;
  }
  const PERSISTED_TEXT_FIELDS = [
    'mt-name', 'mt-phone', 'mt-city', 'mt-email', 'mt-facture-hiver', 'mt-facture-ete',
    'mt-bill', 'mt-roof', 'mt-raccordement', 'mt-distributeur', 'mt-bill-kwh', 'mt-roof-age',
    'mt-occupant-type', 'mt-project-timing', 'mt-financing-intent', 'mt-fallback-address',
    'rp9-address',
    // WJ68 — professional mode (optional, additive).
    'mt-raison-sociale', 'mt-facility-type', 'mt-site-count',
    // QX — PROFESSIONAL sub-panel (step 2).
    'mt-pro-bill', 'mt-puissance-kva', 'mt-surface-m2',
    // WJ123 — INDUSTRIAL v2 sub-panel (cos φ, generator).
    'mt-cos-phi', 'mt-groupe-kva', 'mt-diesel-dh',
    // WJ122 — COMMERCIAL sub-panel (bill).
    'mt-cc-bill',
    // QX — AGRICULTURAL sub-panel (step 2).
    'mt-profondeur', 'mt-hmt', 'mt-water-need', 'mt-heures-pompage',
    'mt-culture', 'mt-surface-ha', 'mt-pompe-actuelle', 'mt-pompe-cv', 'mt-fuel-spend',
  ];
  const PERSISTED_CHECK_FIELDS = ['mt-ete-differente', 'mt-contact-whatsapp', 'mt-contact-phone', 'mt-consent', 'mt-battery-interest', 'mt-weekend'];
  let restoring = false; // WJ61 — avoids re-saving WHILE rehydrating.
  function saveWizardState() {
    if (restoring) return;
    try {
      const fields: Record<string, string> = {};
      for (const id of PERSISTED_TEXT_FIELDS) {
        const v = val(id);
        if (v) fields[id] = v;
      }
      const checks: Record<string, boolean> = {};
      for (const id of PERSISTED_CHECK_FIELDS) {
        const el = $(id) as HTMLInputElement | null;
        if (el) checks[id] = el.checked;
      }
      const snapshot: WizardSnapshot = {
        step, mode, ombrage,
        visitWindowPart, visitWindowWeek,
        futureLoads: Array.from(futureLoads),
        sel: { proUnit, tension, activity, surfaceType, generator, waterSource, irrigation, waterUnit, commercialCategory, ccUnit, equipes, regionAgricole },
        capturePin, captureOutline,
        fields, checks,
      };
      sessionStorage.setItem(WIZARD_STORAGE_KEY, JSON.stringify(snapshot));
    } catch {
      // sessionStorage unavailable (strict private browsing, quota…): the
      // persistence is a CONVENIENCE, never a blocker for typing/submitting.
    }
  }
  function loadWizardState(): WizardSnapshot | null {
    try {
      const raw = sessionStorage.getItem(WIZARD_STORAGE_KEY);
      return raw ? (JSON.parse(raw) as WizardSnapshot) : null;
    } catch {
      return null;
    }
  }
  function clearWizardState() {
    try { sessionStorage.removeItem(WIZARD_STORAGE_KEY); } catch { /* convenience only */ }
  }
  // WJ61 — exit guard: once the visitor has started entering something, an
  // ACCIDENTAL refresh/close shows the browser's native confirmation prompt
  // (text not customisable by spec).
  let hasEnteredData = false;
  function markDataEntered() { hasEnteredData = true; }
  window.addEventListener('beforeunload', (e) => {
    if (!hasEnteredData || submitted) return;
    e.preventDefault();
    e.returnValue = '';
  });

  const savedWizard = loadWizardState();

  // ——— WJ6/QX : mode selector — no default at all (the profile drives an
  // entirely different step-2 questionnaire); "Continue" requires an
  // explicit choice (validateStep0, inline nudge on the cards). ———
  let mode = savedWizard?.mode || '';
  // WJ121 — in-flight session migration: the old single 'professionnel'
  // profile rehydrates as 'industriel' (the backend already maps
  // professionnel→industriel) — the site never EMITS 'professionnel' anymore.
  if (mode === 'professionnel') mode = 'industriel';
  /** WJ121 — both C&I modes share the existing pro sub-panel/engine (dedicated
   *  panels = WJ122/WJ123); 'professionnel' kept as defence in depth (the
   *  migration above already eliminates it). */
  function isProMode(m: string): boolean {
    return m === 'industriel' || m === 'commercial' || m === 'professionnel';
  }
  // QX — stepper labels + document dressing per profile.
  const STEP_LABELS_BY_MODE: Record<string, [string, string, string]> = {
    residentiel: ['Your roof', 'Your bill', 'Your estimate'],
    industriel: ['Your site', 'Your energy', 'Your estimate'],
    commercial: ['Your premises', 'Your energy', 'Your estimate'],
    agricole: ['Your land', 'Your pumping', 'Your estimate'],
  };
  const MODE_LABEL: Record<string, string> = {
    residentiel: 'Residential', industriel: 'Industrial', commercial: 'Commercial', agricole: 'Agricultural',
  };
  const MODE_DOC_SUBTITLE: Record<string, string> = {
    residentiel: 'Residential', industriel: 'Industrial Self-Consumption',
    commercial: 'Commercial Self-Consumption', agricole: 'Agricultural Pumping',
  };
  /** QX — the stepper follows the profile. */
  function syncStepLabels() {
    const labels = STEP_LABELS_BY_MODE[mode] || STEP_LABELS_BY_MODE.residentiel;
    document.querySelectorAll<HTMLElement>('.mt-step-label').forEach((el, i) => {
      if (labels[i]) el.textContent = labels[i];
    });
    [0, 1, 2].forEach((i) => {
      const h = $(`mt-h2-${i}`);
      if (h && labels[i]) h.textContent = labels[i];
    });
  }
  /** QX — only one question sub-panel is visible at step 2, per profile. */
  function syncStep2Panels() {
    const m = mode || 'residentiel';
    const res = $('mt-sub-residentiel');
    const pro = $('mt-sub-professionnel');
    const commercial = $('mt-sub-commercial');
    const agri = $('mt-sub-agricole');
    if (res) res.hidden = m !== 'residentiel';
    // WJ122 — 'commercial' now has its OWN panel (category cards); 'industrial'
    // (and the legacy 'professionnel' alias) keep the pro panel.
    if (pro) pro.hidden = !(m === 'industriel' || m === 'professionnel');
    if (commercial) commercial.hidden = m !== 'commercial';
    if (agri) agri.hidden = m !== 'agricole';
  }
  function syncModeCards() {
    document.querySelectorAll<HTMLButtonElement>('.mt-mode').forEach((b) => {
      const on = mode !== '' && b.dataset.mode === mode;
      b.setAttribute('aria-pressed', String(on));
      b.classList.toggle('border-brass-400', on);
      b.classList.toggle('border-white/15', !on);
    });
  }
  document.querySelectorAll<HTMLButtonElement>('.mt-mode').forEach((btn) => {
    btn.addEventListener('click', () => {
      mode = btn.dataset.mode || '';
      syncModeCards();
      const modeErr = $('mt-mode-err');
      if (modeErr) { modeErr.textContent = ''; modeErr.hidden = true; }
      syncStepLabels();
      syncStep2Panels();
      markDataEntered();
      saveWizardState();
      // WJ111 — if the estimate (step 3) was already computed, switching
      // to/from agricultural must update the document IMMEDIATELY (numeric
      // <-> qualitative card) without waiting for a fresh click on "See my estimate".
      if (!$('mt-estimate-body')?.hidden || !$('mt-estimate-agricole')?.hidden) computeEstimate();
      else if (docRendered) computeEstimate();
    });
  });
  // initial state: rehydrated from the snapshot, otherwise NO mode marked.
  syncModeCards();
  syncStepLabels();
  syncStep2Panels();

  // ——— WJ48 : "roof type" image cards — sync the sr-only <select> (mt-roof)
  // which stays the source of truth for val('mt-roof'), validation
  // (setFieldError) and WJ61 persistence (already wired on 'mt-roof' via
  // PERSISTED_TEXT_FIELDS). Single active choice at a time. ———
  const roofSelect = $('mt-roof') as HTMLSelectElement | null;
  function syncRoofCards() {
    const current = roofSelect?.value || '';
    document.querySelectorAll<HTMLButtonElement>('.mt-roof-card').forEach((b) => {
      const on = b.dataset.roof === current;
      b.setAttribute('aria-pressed', String(on));
      b.classList.toggle('border-brass-400', on);
      b.classList.toggle('border-white/15', !on);
    });
  }
  document.querySelectorAll<HTMLButtonElement>('.mt-roof-card').forEach((btn) => {
    btn.addEventListener('click', () => {
      if (roofSelect) {
        roofSelect.value = btn.dataset.roof || '';
        // WJ4 — mirrors the existing inline validation (setFieldError already
        // wired on mt-roof-err): a visual choice clears the displayed error.
        setFieldError('mt-roof', 'mt-roof-err', null);
      }
      syncRoofCards();
      markDataEntered();
      saveWizardState();
    });
  });
  syncRoofCards(); // initial state (rehydrated or empty).

  // ——— WJ31 : single-toggle chip (shading) — one active choice at a time ———
  // WJ112 — shading is no longer decorative: it now REALLY derates
  // production/kWc (billEstimate.ts OMBRAGE_DERATE); recompute live on click,
  // exactly like mode or the bill.
  let ombrage = savedWizard?.ombrage || '';
  document.querySelectorAll<HTMLButtonElement>('.mt-ombrage').forEach((btn) => {
    btn.addEventListener('click', () => {
      const same = ombrage === btn.dataset.value;
      ombrage = same ? '' : (btn.dataset.value || '');
      document.querySelectorAll<HTMLButtonElement>('.mt-ombrage').forEach((b) => {
        const on = !same && b === btn;
        b.setAttribute('aria-pressed', String(on));
        b.classList.toggle('border-brass-400', on);
        b.classList.toggle('border-white/15', !on);
      });
      markDataEntered();
      saveWizardState();
      computeEstimate();
    });
  });
  if (ombrage) {
    document.querySelectorAll<HTMLButtonElement>('.mt-ombrage').forEach((b) => {
      const on = b.dataset.value === ombrage;
      b.setAttribute('aria-pressed', String(on));
      b.classList.toggle('border-brass-400', on);
      b.classList.toggle('border-white/15', !on);
    });
  }

  // ——— W353 : technical visit slot — two INDEPENDENT single-select toggles
  // (time of day + week), same pattern as .mt-ombrage above. STATIC and
  // OPTIONAL preference: no calendar, no confirmed booking — a human
  // validates the real slot after contact. ———
  let visitWindowPart = savedWizard?.visitWindowPart || '';
  let visitWindowWeek = savedWizard?.visitWindowWeek || '';
  function wireVisitToggle(selector: string, getCurrent: () => string, setCurrent: (v: string) => void) {
    document.querySelectorAll<HTMLButtonElement>(selector).forEach((btn) => {
      btn.addEventListener('click', () => {
        const same = getCurrent() === btn.dataset.value;
        setCurrent(same ? '' : (btn.dataset.value || ''));
        document.querySelectorAll<HTMLButtonElement>(selector).forEach((b) => {
          const on = !same && b === btn;
          b.setAttribute('aria-pressed', String(on));
          b.classList.toggle('border-brass-400', on);
          b.classList.toggle('border-white/15', !on);
        });
        markDataEntered();
        saveWizardState();
      });
    });
    const current = getCurrent();
    if (current) {
      document.querySelectorAll<HTMLButtonElement>(selector).forEach((b) => {
        const on = b.dataset.value === current;
        b.setAttribute('aria-pressed', String(on));
        b.classList.toggle('border-brass-400', on);
        b.classList.toggle('border-white/15', !on);
      });
    }
  }
  wireVisitToggle('.mt-visit-part', () => visitWindowPart, (v) => { visitWindowPart = v; });
  wireVisitToggle('.mt-visit-week', () => visitWindowWeek, (v) => { visitWindowWeek = v; });

  // ——— WJ31 : multi-select chips (future loads) ———
  const futureLoads = new Set<string>(savedWizard?.futureLoads ?? []);
  document.querySelectorAll<HTMLButtonElement>('.mt-future-load').forEach((btn) => {
    const preOn = futureLoads.has(btn.dataset.value || '');
    if (preOn) {
      btn.setAttribute('aria-pressed', 'true');
      btn.classList.add('border-brass-400');
      btn.classList.remove('border-white/15');
    }
    btn.addEventListener('click', () => {
      const v = btn.dataset.value || '';
      const on = !futureLoads.has(v);
      if (on) futureLoads.add(v); else futureLoads.delete(v);
      btn.setAttribute('aria-pressed', String(on));
      btn.classList.toggle('border-brass-400', on);
      btn.classList.toggle('border-white/15', !on);
      markDataEntered();
      saveWizardState();
    });
  });

  // ——— WJ31 : meter/bill photo — captured LOCALLY, NEVER uploaded ———
  // No upload endpoint today (see PLAN2 QK6 OCR): we keep a simple boolean
  // signal (hasMeterPhoto) and encourage sending it directly on WhatsApp.
  // WJ61 — not persisted: a local file does not survive sessionStorage (nor
  // should it — no binary data is serialised here).
  let hasMeterPhoto = false;
  const meterPhotoInput = $('mt-meter-photo') as HTMLInputElement | null;
  meterPhotoInput?.addEventListener('change', () => {
    hasMeterPhoto = !!(meterPhotoInput.files && meterPhotoInput.files.length > 0);
  });

  // ——— WJ46 : anti-false-trigger grace window for the exit-intent ———
  // Opening the file picker (meter/bill photo, capture="environment") flips
  // the tab to the background while the camera/gallery shows: a bare
  // `visibilitychange->hidden` used to fire the exit-intent at the EXACT
  // moment the form invites the user to take a photo. We suspend the
  // exit-intent while the picker is open: set on click/focus of the file
  // field, cleared on window focus return (the picker closed) — with a
  // safety-net timeout in case the return-focus event never fires (browser fallback).
  let filePickerOpen = false;
  let filePickerGraceTimer: ReturnType<typeof setTimeout> | null = null;
  function openFilePickerGrace() {
    filePickerOpen = true;
    if (filePickerGraceTimer != null) clearTimeout(filePickerGraceTimer);
    // safety net: 60 s comfortably covers taking a photo, without blocking
    // the exit-intent indefinitely if the browser never fires a return
    // `focus`/`visibilitychange->visible` (rare case).
    filePickerGraceTimer = setTimeout(() => { filePickerOpen = false; }, 60_000);
  }
  function closeFilePickerGrace() {
    filePickerOpen = false;
    if (filePickerGraceTimer != null) { clearTimeout(filePickerGraceTimer); filePickerGraceTimer = null; }
  }
  meterPhotoInput?.addEventListener('click', openFilePickerGrace);
  meterPhotoInput?.addEventListener('focus', openFilePickerGrace);
  meterPhotoInput?.addEventListener('change', closeFilePickerGrace);
  meterPhotoInput?.addEventListener('cancel', closeFilePickerGrace);
  // Window focus return is the most reliable signal that the picker
  // (camera/gallery) closed, whether a file was chosen or not.
  window.addEventListener('focus', closeFilePickerGrace);

  // ——— map boot (captureOnly). No-map-key fallback ALLOWS the journey to continue (WJ4) ———
  let started = false;
  const mapEl = $('rp9-map');
  // WJ34 — removes the loading skeleton as soon as the map announces its
  // first render (onReady) or as soon as we fall back to the no-map path.
  function clearMapSkeleton() { mapEl?.classList.remove('mt-skeleton-shimmer'); }
  async function boot(key: string, mapboxToken: string) {
    if (started) return;
    started = true;
    try {
      // WJ47 — imports roofPro11/captureBoot DIRECTLY (not all of
      // roof-tool-pro11.ts): the full boot drags in scene3d/optimizer/matrix
      // (Three.js + the packing engine), internal tool code this public
      // capture page never runs. This lazy chunk now only loads MapLibre +
      // the geocoder + the pin/outline.
      const { bootCaptureOnly } = await import('../../../scripts/roofPro11/captureBoot');
      bootCaptureOnly({
        maptilerKey: key,
        mapboxToken: mapboxToken || undefined,
        reducedMotion,
        // WJ41 — English map/geocoder system messages (default is French).
        strings: ROOF_TOOL_STRINGS_EN,
        // WJ62 — geolocation refused/unavailable is now announced, not a
        // silent failure.
        geolocateErrorMsg: 'Location denied — search for your address or drop the pin by hand.',
        onReady: clearMapSkeleton,
        // WJ61 — a pin/outline restored from sessionStorage (refresh or
        // browser back mid-journey) is seeded straight into the map at boot,
        // via the same mechanism as hydrating from an existing lead (W113):
        // the visitor doesn't have to re-drop their pin.
        hydrate: capturePin
          ? { lead: { roof_point: capturePin, roof_outline: captureOutline.length >= 3 ? captureOutline : null } }
          : undefined,
        onCaptureChange: (s) => {
          capturePin = s.pin;
          captureOutline = s.outline;
          // QX/Lane C — the outline changed: the cached satellite snapshot no
          // longer matches, let it rebuild.
          roofImageSpecPromise = null;
          if (cityEl && !cityTouched) {
            const fromMap = (s.address && s.address.trim()) || addressEl?.value.trim() || '';
            if (fromMap) cityEl.value = fromMap;
          }
          // WJ2 — the outline can arrive/change AFTER the estimate is
          // computed: re-evaluate the "see the panels" button's eligibility
          // on every trace change (function declared below, hoisted by `function`).
          updatePanels3dVisibility();
        },
      });
    } catch {
      started = false;
      showFallback();
    }
  }
  // WJ4 — map fallback: show the plain-text address field AND keep the journey open.
  // QX — also HIDE the whole map block (#mt-stage: geocoder, canvas, trace
  // buttons): without an imagery key those controls are dead UI next to the
  // honest address-only fallback (mirrors the FR fix).
  function showFallback() {
    clearMapSkeleton();
    if (fallback) fallback.hidden = false;
    const stage = $('mt-stage');
    if (stage) stage.hidden = true;
  }

  // WJ60 — on slow 3G, a fetch with no timeout could hang indefinitely (the UI
  // stayed stuck on the map's loading skeleton). 10 s gives a slow connection
  // ample time to respond while still bounding the wait; the failure (timeout
  // included) falls into the existing address fallback (WJ4), never a block.
  const FETCH_TIMEOUT_MS = 10_000;
  // W324 — only fire the /api/roof-config fetch (→ lazy maplibre-gl import,
  // ~200 KB+) once the map step (step 0) is actually the ACTIVE step — never
  // on plain page load. A visitor resuming mid-journey at step 1/2 (WJ61:
  // restored sessionStorage snapshot, or browser back) never pays for a map
  // they won't see. `mapFetchDone` keeps the call idempotent (one fetch per
  // visit, even across repeated step-0 visits via Back/Continue).
  let mapFetchDone = false;
  function ensureMapBooted() {
    if (mapFetchDone) return;
    mapFetchDone = true;
    (async () => {
      try {
        const res = await fetch('/api/roof-config', { signal: AbortSignal.timeout(FETCH_TIMEOUT_MS) });
        const cfg = (await res.json()) as { available?: boolean; maptilerKey?: string; mapboxToken?: string };
        if (!cfg.available || !cfg.maptilerKey) { showFallback(); return; }
        void boot(cfg.maptilerKey, cfg.mapboxToken || '');
      } catch {
        showFallback();
      }
    })();
  }

  // ——— WJ6 : multi-step wizard + progress bar ———
  // WJ61 — the initial step reprises the sessionStorage snapshot if present
  // (refresh/back mid-journey), otherwise 0 as before.
  let step = savedWizard?.step != null ? Math.max(0, Math.min(2, savedWizard.step)) : 0;
  const panels = [0, 1, 2].map((i) => $(`mt-panel-${i}`));
  let firstRender = true;
  function renderStep() {
    panels.forEach((p, i) => { if (p) p.hidden = i !== step; });
    document.querySelectorAll<HTMLElement>('.mt-step').forEach((li, i) => {
      const bar = li.querySelector<HTMLElement>('.mt-step-bar');
      const label = li.querySelector<HTMLElement>('.mt-step-label');
      const active = i <= step;
      if (bar) bar.className = `h-1.5 w-full rounded-full mt-step-bar transition-colors ${active ? 'bg-brass-400' : 'bg-white/10'}`;
      if (label) label.classList.toggle('text-white', i === step);
    });
    // W324 — the map step is now ACTIVE: this is where (never on plain page
    // load) we fire the config fetch + the lazy maplibre-gl import.
    if (step === 0) ensureMapBooted();
    // WJ59 — "step reached", deduped by sendFunnelBeacon (once per step per
    // visit, even after a Back/Continue round trip).
    // WB30 — no beacon before the consent step (panel 2) is reached.
    if (hasReachedConsentStep()) sendFunnelBeacon(step === 0 ? 'toit' : step === 1 ? 'facture' : 'estimation', 'reached');
    // WJ61 — on the very first render (load/rehydration), don't force a
    // scroll: the visitor just arrived/came back, the page hasn't moved under
    // them yet. Scrolling stays for every SUBSEQUENT step.
    if (firstRender) { firstRender = false; return; }
    const root = document.querySelector('section');
    root?.scrollIntoView({ behavior: reducedMotion ? 'auto' : 'smooth', block: 'start' });
  }
  // WJ61 — pushState PER STEP: the browser's back button steps back one
  // wizard step instead of leaving the page outright (the most frequent
  // failure of an accidental "back"). `fromPopstate` avoids re-pushing a
  // state while already reacting to a `popstate`.
  function goStep(n: number, fromPopstate = false) {
    step = Math.max(0, Math.min(2, n));
    renderStep();
    saveWizardState();
    if (!fromPopstate) {
      history.pushState({ mtStep: step }, '', location.href);
    }
  }
  window.addEventListener('popstate', (e) => {
    const st = (e.state as { mtStep?: number } | null)?.mtStep;
    goStep(st != null ? st : Math.max(0, step - 1), true);
  });
  // QX — the map step now requires a chosen PROFILE (inline nudge on the
  // cards, never an alert): the profile drives the whole step-2 questionnaire.
  $('mt-next-0')?.addEventListener('click', () => {
    if (validateStep0()) goStep(1);
  });
  $('mt-back-1')?.addEventListener('click', () => goStep(0));
  $('mt-back-2')?.addEventListener('click', () => goStep(1));
  // WJ61 — push a first history entry on load so the very first "back" has an
  // `mtStep` state to consult.
  history.replaceState({ mtStep: step }, '', location.href);
  renderStep();
  // WJ96(c) — a visitor who RESUMES their journey (WJ61 sessionStorage
  // snapshot) directly at step 1/2 never triggers `ensureMapBooted()` via
  // `renderStep()` (which only boots at `step === 0`): clicking "Back" to the
  // map step used to show the loading skeleton every time, instead of an
  // already-ready map. We prewarm the config/map in the background as soon
  // as we know this visitor already has a restored step > 0 — never
  // blocking the render of the current step (best-effort, idempotent via
  // `mapFetchDone`).
  if (savedWizard?.step != null && savedWizard.step > 0) ensureMapBooted();

  // ——— input helpers ———
  const val = (id: string) => (($(id) as HTMLInputElement | HTMLSelectElement | null)?.value ?? '');
  const num = (id: string): number | null => {
    const raw = val(id).trim();
    if (raw === '') return null;
    const n = Number(raw);
    return Number.isFinite(n) ? n : null;
  };

  // summer ≠ winter toggle
  const eteToggle = $('mt-ete-differente') as HTMLInputElement | null;
  const eteWrap = $('mt-facture-ete-wrap') as HTMLElement | null;
  const eteInput = $('mt-facture-ete') as HTMLInputElement | null;
  eteToggle?.addEventListener('change', () => {
    const on = eteToggle.checked === true;
    if (eteWrap) eteWrap.hidden = !on;
    if (!on && eteInput) eteInput.value = '';
  });

  // WJ105 — concrete callback SLA: visible ONLY when "An advisor may call
  // me" is the active preference. `sync` is re-called after rehydration
  // (WJ61, below): setting `.checked` via script never fires the native
  // `change` event.
  const contactPhoneRadio = $('mt-contact-phone') as HTMLInputElement | null;
  const contactWhatsappRadio = $('mt-contact-whatsapp') as HTMLInputElement | null;
  const callbackSla = $('mt-callback-sla') as HTMLElement | null;
  function syncCallbackSla(): void {
    if (callbackSla) callbackSla.hidden = contactPhoneRadio?.checked !== true;
  }
  contactPhoneRadio?.addEventListener('change', syncCallbackSla);
  contactWhatsappRadio?.addEventListener('change', syncCallbackSla);
  syncCallbackSla();

  // WJ61 — rehydrate input fields + map pin/outline from the snapshot
  // (BEFORE the map boot: `hydrate` below seeds the pin/outline directly
  // into captureBoot, without waiting for a first click). `restoring`
  // prevents saveWizardState() from firing WHILE we populate fields (native
  // `input`/`change` events don't fire on a scripted `.value`/`.checked` assignment).
  if (savedWizard) {
    restoring = true;
    for (const [id, v] of Object.entries(savedWizard.fields ?? {})) {
      const el = $(id) as HTMLInputElement | HTMLSelectElement | null;
      if (el) el.value = v;
    }
    for (const [id, v] of Object.entries(savedWizard.checks ?? {})) {
      const el = $(id) as HTMLInputElement | null;
      if (el) el.checked = v;
    }
    // WJ61 — a restored city counts as "already touched": assigning `.value`
    // via script doesn't fire the native `input` event that normally sets
    // `cityTouched`, and without this guard the next pin dropped on the map
    // would silently overwrite the city we just restored.
    if (savedWizard.fields?.['mt-city']) cityTouched = true;
    if (eteToggle?.checked && eteWrap) eteWrap.hidden = false;
    // WJ105 — a restored contact preference must re-sync the callback SLA
    // visibility (assigning `.checked` via script never fires `change`).
    syncCallbackSla();
    if (savedWizard.capturePin) capturePin = savedWizard.capturePin;
    if (savedWizard.captureOutline?.length) captureOutline = savedWizard.captureOutline;
    if (Object.keys(savedWizard.fields ?? {}).length > 0 || savedWizard.capturePin) markDataEntered();
    restoring = false;
  }
  // WJ61 — persist on any typing/change of the remaining text/select/checkbox
  // fields (beyond the chip groups already wired above).
  const PERSIST_ON_INPUT_IDS = [...PERSISTED_TEXT_FIELDS, ...PERSISTED_CHECK_FIELDS];
  for (const id of PERSIST_ON_INPUT_IDS) {
    const el = $(id);
    el?.addEventListener('input', () => { markDataEntered(); saveWizardState(); });
    el?.addEventListener('change', () => { markDataEntered(); saveWizardState(); });
  }

  // ——— QX : single-select card/chip groups of the PRO and AGRICULTURAL
  // sub-panels (same visual/ARIA pattern as .mt-ombrage). `recompute`
  // re-runs the estimate live when the choice drives a shown figure. LV +
  // "Daytime" come preselected: VISIBLE defaults on screen (never a hidden
  // assumption), one tap to change. ———
  const savedSel = savedWizard?.sel ?? {};
  let proUnit = savedSel.proUnit || 'mad';
  let tension = savedSel.tension || 'bt';
  let activity = savedSel.activity || 'day';
  let surfaceType = savedSel.surfaceType || '';
  let generator = savedSel.generator || '';
  let waterSource = savedSel.waterSource || '';
  let irrigation = savedSel.irrigation || '';
  let waterUnit = savedSel.waterUnit || 'm3h';
  // WJ122 — COMMERCIAL mode: active category + bill unit (MAD/kWh).
  let commercialCategory = savedSel.commercialCategory || '';
  let ccUnit = savedSel.ccUnit || 'mad';
  // WJ123 — INDUSTRIAL mode: shift pattern (self-consumption ceiling).
  let equipes = savedSel.equipes || '';
  // WJ124 — AGRICULTURAL mode: agronomy region (drives the FAO-56 water engine).
  let regionAgricole = savedSel.regionAgricole || '';
  function wireCardGroup(
    selector: string,
    getCurrent: () => string,
    setCurrent: (v: string) => void,
    opts: { allowUnset?: boolean; recompute?: boolean; onChange?: () => void } = {},
  ) {
    const paint = () => {
      const current = getCurrent();
      document.querySelectorAll<HTMLButtonElement>(selector).forEach((b) => {
        const on = current !== '' && b.dataset.value === current;
        b.setAttribute('aria-pressed', String(on));
        b.classList.toggle('border-brass-400', on);
        b.classList.toggle('border-white/15', !on);
      });
    };
    document.querySelectorAll<HTMLButtonElement>(selector).forEach((btn) => {
      btn.addEventListener('click', () => {
        const same = getCurrent() === btn.dataset.value;
        setCurrent(same && opts.allowUnset ? '' : (btn.dataset.value || ''));
        paint();
        opts.onChange?.();
        markDataEntered();
        saveWizardState();
        if (opts.recompute) computeEstimate();
      });
    });
    paint();
  }
  // PRO — the kVA field only appears at medium voltage.
  function syncKvaVisibility() {
    const wrap = $('mt-puissance-kva-wrap');
    if (wrap) wrap.hidden = tension !== 'mt';
  }
  wireCardGroup('.mt-pro-unit', () => proUnit, (v) => { proUnit = v || 'mad'; }, { recompute: true });
  wireCardGroup('.mt-tension', () => tension, (v) => { tension = v || 'bt'; }, { recompute: true, onChange: syncKvaVisibility });
  wireCardGroup('.mt-activity', () => activity, (v) => { activity = v || 'day'; }, { recompute: true });
  wireCardGroup('.mt-surface-type', () => surfaceType, (v) => { surfaceType = v; }, { allowUnset: true, recompute: true });
  wireCardGroup('.mt-generator', () => generator, (v) => { generator = v; }, { allowUnset: true });
  syncKvaVisibility();
  // WJ122 — COMMERCIAL: category cards (reveal the matching question grid) + bill
  // unit toggle. Picking a category recomputes the estimate (archetype day-share
  // → hotel ≠ office at equal bill).
  function syncCommercialQuestions() {
    document.querySelectorAll<HTMLElement>('.mt-commercial-questions').forEach((el) => { el.hidden = true; });
    if (commercialCategory) {
      const g = $(`mt-cc-questions-${commercialCategory}`);
      if (g) g.hidden = false;
    }
  }
  wireCardGroup('.mt-commercial-cat', () => commercialCategory, (v) => { commercialCategory = v; }, { allowUnset: true, recompute: true, onChange: syncCommercialQuestions });
  wireCardGroup('.mt-cc-unit', () => ccUnit, (v) => { ccUnit = v || 'mad'; }, { recompute: true });
  syncCommercialQuestions();
  // WJ123 — INDUSTRIAL: shift pattern (the self-consumption ceiling recomputes).
  wireCardGroup('.mt-equipes', () => equipes, (v) => { equipes = v; }, { allowUnset: true, recompute: true });
  // WJ124 — AGRICULTURAL: region (cards) drives the water engine; crop (cards)
  // syncs the sr-only mt-culture <select> (the payload source of truth).
  wireCardGroup('.mt-region-card', () => regionAgricole, (v) => { regionAgricole = v; }, { allowUnset: true, recompute: true });
  const cultureSelect = $('mt-culture') as HTMLSelectElement | null;
  function syncCultureCards() {
    const current = cultureSelect?.value || '';
    document.querySelectorAll<HTMLButtonElement>('.mt-culture-card').forEach((b) => {
      const on = current !== '' && b.dataset.value === current;
      b.setAttribute('aria-pressed', String(on));
      b.classList.toggle('border-brass-400', on);
      b.classList.toggle('border-white/15', !on);
    });
  }
  document.querySelectorAll<HTMLButtonElement>('.mt-culture-card').forEach((btn) => {
    btn.addEventListener('click', () => {
      if (cultureSelect) cultureSelect.value = cultureSelect.value === btn.dataset.value ? '' : (btn.dataset.value || '');
      syncCultureCards();
      markDataEntered();
      saveWizardState();
      computeEstimate();
    });
  });
  syncCultureCards();
  // AGRICULTURAL — the water source drives the pump type (submersible/surface).
  wireCardGroup('.mt-water-source', () => waterSource, (v) => { waterSource = v; }, { allowUnset: true, recompute: true });
  wireCardGroup('.mt-irrigation', () => irrigation, (v) => { irrigation = v; }, { allowUnset: true });
  wireCardGroup('.mt-water-unit', () => waterUnit, (v) => { waterUnit = v || 'm3h'; }, { recompute: true });
  // "Pumping hours / day" slider — live displayed value.
  const heuresInput = $('mt-heures-pompage') as HTMLInputElement | null;
  function syncHeuresLabel() {
    const out = $('mt-heures-pompage-value');
    if (out && heuresInput) out.textContent = `${heuresInput.value} h`;
  }
  heuresInput?.addEventListener('input', () => {
    syncHeuresLabel();
    computeEstimate();
  });
  syncHeuresLabel();
  // Live recompute on every numeric field that drives a shown figure (same
  // pattern as mt-facture-hiver / mt-bill-kwh on the residential side).
  for (const id of ['mt-pro-bill', 'mt-cc-bill', 'mt-puissance-kva', 'mt-surface-m2', 'mt-profondeur', 'mt-hmt', 'mt-water-need', 'mt-fuel-spend', 'mt-cos-phi', 'mt-groupe-kva', 'mt-diesel-dh']) {
    $(id)?.addEventListener('input', computeEstimate);
  }

  // ——— WJ1 : resolve the monthly bill (exact amount first, else range) ———
  /** Indicative midpoint of a range (MAD) — ONLY used to ESTIMATE when the
   *  exact amount is absent; never used for the threshold (that stays on billRange/qualifies). */
  const RANGE_MIDPOINT: Record<string, number> = {
    'lt800': 600, '800-1000': 900, '1000-1500': 1250, '1500-3000': 2250,
    '3000-5000': 4000, '5000-10000': 7500, 'gt10000': 12000,
  };
  // WJ65/QX — sanity cap PER PROFILE (MAX_BILL_BY_MODE, lib/lead.ts): beyond
  // it, a typo would produce a confidently stated figure — we ask to double
  // check (residential) or route to a dedicated study (pro). Only applies to
  // the EXACT amount entered, never to ranges.
  function maxBillFor(m: string): number {
    return MAX_BILL_BY_MODE[m as keyof typeof MAX_BILL_BY_MODE] ?? 200_000;
  }
  function resolveMonthlyBill(): number | null {
    const exact = num('mt-facture-hiver');
    if (exact != null && exact > 0) return exact;
    const range = val('mt-bill');
    if (range && RANGE_MIDPOINT[range] != null) return RANGE_MIDPOINT[range];
    return null;
  }

  // ——— QX : fix "redundant range" (residential) — a VALID exact amount
  // derives the range automatically (billRangeFromExact), hides the <select>
  // and shows a discreet confirmation line. The payload billRange (read off
  // the <select>) stays ALWAYS consistent with what drove the estimate
  // shown. Empty/invalid exact field -> the <select> reappears, as before. ———
  function syncBillRangeFromExact() {
    const wrap = $('mt-bill-wrap');
    const detected = $('mt-bill-detected');
    const detectedValue = $('mt-bill-detected-value');
    const billSelect = $('mt-bill') as HTMLSelectElement | null;
    const exact = num('mt-facture-hiver');
    if (exact != null && exact > 0 && exact <= maxBillFor('residentiel')) {
      const rid = billRangeFromExact(exact);
      if (rid && billSelect) {
        billSelect.value = rid;
        if (detectedValue) detectedValue.textContent = BILL_RANGE_LABEL_EN[rid as BillRangeId] ?? '';
        if (wrap) wrap.hidden = true;
        if (detected) detected.hidden = false;
        setFieldError('mt-bill', 'mt-bill-err', null);
        return;
      }
    }
    if (wrap) wrap.hidden = false;
    if (detected) detected.hidden = true;
  }

  // ——— WJ1/QX : compute + display the estimate in THE DOCUMENT ———
  let lastKwcLabel = '';
  let lastSavingsLabel = '';
  let lastKwc: number | null = null;
  // QX — has the document already been rendered at least once (fallback included)?
  let docRendered = false;
  // QX — estimateShown: EXACTLY the computed figures, attached to the lead (the
  // CRM advisor sees everything). WJ125 — they are NO LONGER rendered on screen.
  let estimateShown: Record<string, number | string> | null = null;
  // ——— WJ125 — FOUNDER anti-competitor RULE: in the public journey, the
  // figured estimate document (#mt-doc), the "nearest installation" (kWc + km)
  // and the "cost of waiting" (MAD) NO LONGER render. The calculation keeps
  // running silently (estimateShown + labels still reach the CRM and the
  // WhatsApp deeplink) but NO precise figure is written into the public DOM: a
  // locked teaser card (blurred preview WITHOUT a single figure) leads to the
  // form. The full document + "Print" live ONLY on /proposition/<token> (sent
  // by the sales rep). ———
  const PUBLIC_ESTIMATE_GATED: boolean = true;
  const GATED_ANNOUNCE = 'Your estimate is ready. Enter your details to receive your complete, personalised study.';
  /** WJ125 — switches the public journey to gated mode: hides the figured
   *  document AND the out-of-#mt-doc zones that would leak figures (nearest
   *  installation, cost of waiting, Print button), then reveals the locked
   *  teaser card (figure-free hook adapted to pumping vs roof). The CALCULATION
   *  is unchanged — only the public RENDER changes. */
  function showEstimateTeaser(m: string) {
    docRendered = true;
    const doc = $('mt-doc');
    if (doc) doc.hidden = true;
    const printBtn = $('mt-print-estimate');
    if (printBtn) printBtn.hidden = true;
    const nearestEl = $('mt-nearest-install');
    if (nearestEl) nearestEl.hidden = true;
    const cowEl = $('mt-cost-of-waiting');
    if (cowEl) cowEl.hidden = true;
    const teaser = $('mt-teaser');
    if (teaser) teaser.hidden = false;
    const isAgri = m === 'agricole';
    const roofHook = $('mt-teaser-hook-roof');
    if (roofHook) roofHook.hidden = isAgri;
    const pumpHook = $('mt-teaser-hook-pump');
    if (pumpHook) pumpHook.hidden = !isAgri;
  }
  // QX — MAD/kWh tariff of the last PRO estimate shown (engine assumptions):
  // used to derive a consistent billRange when consumption is in kWh.
  let lastProTarifMadKwh: number | null = null;
  // WJ88 — SINGLE announcement of the result (never during the skeleton
  // phase): replaces the old aria-live set on the whole card, which caused a
  // screen-reader double-fire (skeleton THEN result).
  function announceEstimate(message: string) {
    const el = $('mt-estimate-announce');
    if (el) el.textContent = message;
  }
  // ——— QX : small document formatters (en-GB, deterministic) ———
  const fmtNum = (n: number): string => (Math.round(n * 10) / 10).toLocaleString('en-GB');
  const fmtYears = (n: number): string => (Math.round(n * 10) / 10).toLocaleString('en-GB');
  /** Robust percentage: accepts 0–1 (ratio) as well as 0–100 (already a %). */
  const pct = (v: number): number => (v <= 1 ? Math.round(v * 100) : Math.round(v));
  function setText(id: string, text: string) {
    const el = $(id);
    if (el) el.textContent = text;
  }
  /** Honest KPI card: an unknown value -> the card DISAPPEARS (never a dash). */
  function setCard(cardId: string, valueId: string, text: string | null) {
    const cardEl = $(cardId);
    if (cardEl) cardEl.hidden = text == null;
    if (text != null) setText(valueId, text);
  }
  // ——— QX : 12-month chart (pure SVG, gold/navy — no lib). INDICATIVE
  // monthly breakdown of solar irradiation in Morocco (PVGIS-type profile for
  // Casablanca, normalised to 1.00): used ONLY to spread an already-computed
  // ANNUAL production over 12 months — never to invent a new figure. ———
  const MONTH_LETTERS = ['J', 'F', 'M', 'A', 'M', 'J', 'J', 'A', 'S', 'O', 'N', 'D'];
  const GHI_MONTHLY_SHARE = [0.057, 0.062, 0.084, 0.094, 0.105, 0.108, 0.113, 0.105, 0.089, 0.075, 0.057, 0.051];
  function renderMonthlyChart(annualKwh: number) {
    const wrap = $('mt-doc-chart-wrap');
    const host = $('mt-doc-chart');
    if (!wrap || !host) return;
    if (!Number.isFinite(annualKwh) || annualKwh <= 0) {
      wrap.hidden = true;
      return;
    }
    const values = GHI_MONTHLY_SHARE.map((s) => annualKwh * s);
    const maxV = Math.max(...values);
    const W = 560;
    const H = 168;
    const pad = 8;
    const baseY = 140;
    const slot = (W - pad * 2) / 12;
    const barW = Math.min(30, slot - 8);
    let bars = '';
    values.forEach((v, i) => {
      const h = maxV > 0 ? Math.max(3, (v / maxV) * 108) : 3;
      const x = pad + slot * i + (slot - barW) / 2;
      const cx = pad + slot * i + slot / 2;
      bars += `<rect x="${x.toFixed(1)}" y="${(baseY - h).toFixed(1)}" width="${barW.toFixed(1)}" height="${h.toFixed(1)}" rx="3" fill="#F5A623"/>`;
      bars += `<text x="${cx.toFixed(1)}" y="${baseY + 17}" text-anchor="middle" font-size="11" fill="#6b7280" font-family="DM Sans, system-ui, sans-serif">${MONTH_LETTERS[i]}</text>`;
    });
    const avg = Math.round(annualKwh / 12);
    host.innerHTML =
      `<svg viewBox="0 0 ${W} ${H}" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid meet">` +
      `<line x1="${pad}" y1="${baseY}" x2="${W - pad}" y2="${baseY}" stroke="#E5E7EB" stroke-width="1"/>` +
      bars +
      `<text x="${W - pad}" y="14" text-anchor="end" font-size="11" fill="#1A2B4A" font-family="DM Sans, system-ui, sans-serif">≈ ${formatMad(avg)} kWh/month on average</text>` +
      '</svg>';
    wrap.hidden = false;
  }
  // ——— QX : shared document dressing (date, per-profile subtitle, city,
  // client/site line — only KNOWN facts, never a dash). ———
  function fillDocChrome() {
    docRendered = true;
    const dateEl = $('mt-doc-date');
    if (dateEl) dateEl.textContent = new Date().toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
    const m = mode || 'residentiel';
    const subEl = $('mt-doc-subtitle');
    if (subEl) subEl.textContent = MODE_DOC_SUBTITLE[m] || MODE_DOC_SUBTITLE.residentiel;
    const city = (val('mt-city') || addressEl?.value || fallbackAddrEl?.value || '').trim();
    const citySpan = $('mt-doc-city');
    const cityLine = $('mt-doc-city-line');
    if (citySpan) citySpan.textContent = city;
    if (cityLine) cityLine.hidden = !city;
    const metaEl = $('mt-doc-meta');
    if (metaEl) {
      const parts: string[] = [];
      if (city) parts.push(city);
      parts.push(`${MODE_LABEL[m] || 'Residential'} project`);
      if (capturePin) parts.push('roof located on the satellite map');
      metaEl.textContent = parts.join(' · ');
      metaEl.hidden = false;
    }
    void tryRoofSnapshot();
  }
  // ——— QX/Lane C : roof satellite snapshot — wired to the REAL Lane C
  // helper `buildPublicRoofImageSpec(outline)` (roofPro11/viewerOnly), via a
  // dynamic import + typeof guard (defensive: any failure/absence -> null,
  // the document stays complete without an image). The spec is cached and
  // SHARED with the 3D preview (one fetch), invalidated when the outline changes. ———
  let roofImageSpecPromise: Promise<RoofImageSpec | null> | null = null;
  function fetchRoofImageSpec(): Promise<RoofImageSpec | null> {
    if (!roofImageSpecPromise) {
      roofImageSpecPromise = (async () => {
        if (captureOutline.length < 3) return null;
        const mod = await import('../../../scripts/roofPro11/viewerOnly');
        if (typeof mod.buildPublicRoofImageSpec !== 'function') return null;
        const spec = await mod.buildPublicRoofImageSpec({ outline: captureOutline });
        return spec && spec.image ? spec : null;
      })().catch(() => null);
    }
    return roofImageSpecPromise;
  }
  /** "Your roof" in the document: a small satellite photo + provider
   *  attribution (required), ONLY when an outline with ≥3 vertices exists. */
  async function tryRoofSnapshot() {
    const fig = $('mt-doc-roof');
    const img = $('mt-doc-roof-img') as HTMLImageElement | null;
    if (!fig || !img) return;
    if (captureOutline.length < 3) {
      fig.hidden = true;
      return;
    }
    const spec = await fetchRoofImageSpec();
    if (!spec) return;
    img.src = spec.image.src;
    const attr = $('mt-doc-roof-attr');
    if (attr) attr.textContent = spec.attribution || '';
    fig.hidden = false;
  }
  /** QX — resets the document's cross-cutting zones; each branch
   *  (residential/pro/agricultural) then only re-shows its own. */
  function resetDocZones() {
    for (const id of [
      'mt-estimate-toolarge-pro', 'mt-estimate-pro-missing', 'mt-doc-kpis-pro',
      'mt-doc-kpis-agri', 'mt-pro-capped', 'mt-doc-chart-wrap', 'mt-doc-flow',
      'mt-doc-hypo-wrap', 'mt-nearest-install', 'mt-cost-of-waiting', 'mt-climate-band',
    ]) {
      const el = $(id);
      if (el) el.hidden = true;
    }
  }
  // ——— QX : PRO engine (Lane A contract, estimatorPro) ———
  interface ProEstimateOk {
    ok: true;
    kwc: number;
    nbPanneaux: number;
    prodAnnuelleKwh: number;
    consoAnnuelleKwh: number;
    tauxAutoconso: number;
    tauxCouverture: number;
    ecoAnnuelleMadLow: number;
    ecoAnnuelleMadHigh: number;
    paybackYearsLow: number;
    paybackYearsHigh: number;
    surfaceCapped: boolean;
    hypotheses: { tarifMadKwh: number; dayShare: number; prixKwcLow: number; prixKwcHigh: number };
  }
  // WJ122 — the C&I bill comes from the ACTIVE panel: 'commercial' has its own
  // field (mt-cc-bill / ccUnit), 'industrial' keeps mt-pro-bill / proUnit.
  const proBillId = () => (mode === 'commercial' ? 'mt-cc-bill' : 'mt-pro-bill');
  const proBillErrId = () => (mode === 'commercial' ? 'mt-cc-bill-err' : 'mt-pro-bill-err');
  const proBillUnit = () => (mode === 'commercial' ? ccUnit : proUnit);
  function computeProEstimate(): boolean {
    const unavail = $('mt-estimate-unavailable');
    const toolarge = $('mt-estimate-toolarge');
    const toolargePro = $('mt-estimate-toolarge-pro');
    const proMissing = $('mt-estimate-pro-missing');
    const printBtn = $('mt-print-estimate');
    if (unavail) unavail.hidden = true;
    if (toolarge) toolarge.hidden = true;
    const clearShown = () => {
      lastKwcLabel = '';
      lastSavingsLabel = '';
      lastKwc = null;
      estimateShown = null;
      if (printBtn) printBtn.hidden = true;
    };
    const proBill = num(proBillId());
    if (proBill == null || proBill <= 0) {
      if (proMissing) proMissing.hidden = false;
      clearShown();
      fillDocChrome();
      updatePanels3dVisibility();
      announceEstimate('Estimate unavailable: enter your monthly consumption (MAD or kWh).');
      return false;
    }
    // WJ121 — cap of the active C&I mode (industrial and commercial share 1M MAD).
    if (proBillUnit() === 'mad' && proBill > maxBillFor(mode)) {
      if (toolargePro) toolargePro.hidden = false;
      clearShown();
      fillDocChrome();
      updatePanels3dVisibility();
      announceEstimate('At this scale, your site needs a dedicated study — an engineer will contact you.');
      return true;
    }
    setFieldError(proBillId(), proBillErrId(), null);
    const raw = estimatePro({
      monthlyKwh: proBillUnit() === 'kwh' ? proBill : undefined,
      monthlyMad: proBillUnit() === 'mad' ? proBill : undefined,
      raccordement: tension === 'mt' ? 'mt' : 'bt',
      activityProfile: activity === 'day_evening' || activity === 'continuous' ? activity : 'day',
      surfaceType: surfaceType ? (surfaceType as 'bac_acier' | 'terrasse' | 'ombriere' | 'terrain') : undefined,
      surfaceM2: num('mt-surface-m2') ?? undefined,
      // WJ122 — the commercial category (archetype day-share) overrides the
      // activity profile: hotel 55% ≠ office 80% at equal bill.
      categorieCommerciale: mode === 'commercial' && commercialCategory ? commercialCategory : undefined,
      // WJ123 — the industrial shift pattern imposes its honest ceiling: a 3x8
      // no longer shows an office's self-consumption.
      equipes: (mode === 'industriel' || mode === 'professionnel') && equipes ? equipes : undefined,
    }) as unknown as ProEstimateOk | { ok: false; reason: 'missing_conso' | 'too_large' | 'invalid' };
    if (!raw.ok) {
      if (raw.reason === 'too_large') {
        if (toolargePro) toolargePro.hidden = false;
        clearShown();
        fillDocChrome();
        updatePanels3dVisibility();
        announceEstimate('At this scale, your site needs a dedicated study — an engineer will contact you.');
        return true;
      }
      if (proMissing) proMissing.hidden = false;
      clearShown();
      fillDocChrome();
      updatePanels3dVisibility();
      announceEstimate('Estimate unavailable: please check the consumption entered.');
      return false;
    }
    const est = raw;
    lastProTarifMadKwh = est.hypotheses && est.hypotheses.tarifMadKwh > 0 ? est.hypotheses.tarifMadKwh : null;
    if (hasReachedConsentStep()) sendFunnelBeacon('estimation', 'viewed');
    // WJ125 — lead payload (exact figures) + labels built BEFORE any render;
    // in the gated public journey we stop here WITHOUT writing a single figure.
    {
      const s: Record<string, number | string> = {};
      const kOk = Number.isFinite(est.kwc) && est.kwc > 0;
      if (kOk) s.kwc = est.kwc;
      if (Number.isFinite(est.prodAnnuelleKwh) && est.prodAnnuelleKwh > 0) s.prodKwh = Math.round(est.prodAnnuelleKwh);
      if (Number.isFinite(est.tauxAutoconso) && est.tauxAutoconso > 0) s.tauxAutoconso = pct(est.tauxAutoconso);
      if (Number.isFinite(est.tauxCouverture) && est.tauxCouverture > 0) s.tauxCouverture = pct(est.tauxCouverture);
      const eOk = est.ecoAnnuelleMadLow > 0 && est.ecoAnnuelleMadHigh > 0;
      if (eOk) { s.ecoMadYearLow = est.ecoAnnuelleMadLow; s.ecoMadYearHigh = est.ecoAnnuelleMadHigh; }
      const rOk = est.paybackYearsLow > 0 && est.paybackYearsHigh > 0;
      const rLabel = rOk
        ? (est.paybackYearsLow === est.paybackYearsHigh
          ? `${fmtYears(est.paybackYearsLow)} yrs`
          : `${fmtYears(est.paybackYearsLow)} – ${fmtYears(est.paybackYearsHigh)} yrs`)
        : null;
      if (rLabel) s.paybackLabel = rLabel;
      estimateShown = s;
      lastKwc = kOk ? est.kwc : null;
      lastKwcLabel = kOk ? `${formatKwc(est.kwc)} kWc` : '';
      const eLabel = eOk ? formatMadRange(est.ecoAnnuelleMadLow, est.ecoAnnuelleMadHigh) : null;
      lastSavingsLabel = eLabel ? `${eLabel}/yr` : '';
    }
    if (PUBLIC_ESTIMATE_GATED) {
      updatePanels3dVisibility();
      if (hasReachedConsentStep()) sendFunnelBeacon('contact', 'reached');
      announceEstimate(GATED_ANNOUNCE);
      return true;
    }
    const kpis = $('mt-doc-kpis-pro');
    if (kpis) kpis.hidden = false;
    const shown: Record<string, number | string> = {};
    const kwcOk = Number.isFinite(est.kwc) && est.kwc > 0;
    setCard('mt-pro-kwc-card', 'mt-pro-kwc', kwcOk ? formatKwc(est.kwc) : null);
    if (kwcOk) shown.kwc = est.kwc;
    const prodOk = Number.isFinite(est.prodAnnuelleKwh) && est.prodAnnuelleKwh > 0;
    setCard('mt-pro-prod-card', 'mt-pro-prod', prodOk ? formatMad(Math.round(est.prodAnnuelleKwh)) : null);
    if (prodOk) shown.prodKwh = Math.round(est.prodAnnuelleKwh);
    const autocOk = Number.isFinite(est.tauxAutoconso) && est.tauxAutoconso > 0;
    setCard('mt-pro-autoconso-card', 'mt-pro-autoconso', autocOk ? String(pct(est.tauxAutoconso)) : null);
    if (autocOk) shown.tauxAutoconso = pct(est.tauxAutoconso);
    const couvOk = Number.isFinite(est.tauxCouverture) && est.tauxCouverture > 0;
    setCard('mt-pro-couverture-card', 'mt-pro-couverture', couvOk ? String(pct(est.tauxCouverture)) : null);
    if (couvOk) shown.tauxCouverture = pct(est.tauxCouverture);
    const ecoOk = est.ecoAnnuelleMadLow > 0 && est.ecoAnnuelleMadHigh > 0;
    const ecoLabel = ecoOk ? formatMadRange(est.ecoAnnuelleMadLow, est.ecoAnnuelleMadHigh) : null;
    setCard('mt-pro-eco-card', 'mt-pro-eco', ecoLabel);
    if (ecoOk) {
      shown.ecoMadYearLow = est.ecoAnnuelleMadLow;
      shown.ecoMadYearHigh = est.ecoAnnuelleMadHigh;
    }
    const retourOk = est.paybackYearsLow > 0 && est.paybackYearsHigh > 0;
    const retourLabel = retourOk
      ? (est.paybackYearsLow === est.paybackYearsHigh
        ? `${fmtYears(est.paybackYearsLow)} years`
        : `${fmtYears(est.paybackYearsLow)} – ${fmtYears(est.paybackYearsHigh)} years`)
      : null;
    setCard('mt-pro-retour-card', 'mt-pro-retour', retourLabel);
    if (retourLabel) shown.paybackLabel = retourLabel;
    const capped = $('mt-pro-capped');
    if (capped) capped.hidden = est.surfaceCapped !== true;
    if (prodOk) renderMonthlyChart(est.prodAnnuelleKwh);
    // Honest assumptions — only what the engine provides (never an absolute
    // system price: a MAD/kWc range only).
    const hypEl = $('mt-doc-hypotheses');
    const hypWrap = $('mt-doc-hypo-wrap');
    const noteEl = $('mt-estimate-note');
    const h = est.hypotheses;
    const hypParts: string[] = [];
    if (h && h.tarifMadKwh > 0) hypParts.push(`tariff used ${h.tarifMadKwh.toLocaleString('en-GB')} MAD/kWh`);
    if (h && h.dayShare > 0) hypParts.push(`estimated daytime share ${pct(h.dayShare)}%`);
    if (h && h.prixKwcLow > 0 && h.prixKwcHigh > 0) hypParts.push(`investment ${formatMad(h.prixKwcLow)} – ${formatMad(h.prixKwcHigh)} MAD/kWc (market range)`);
    if (hypEl) {
      hypEl.textContent = hypParts.length > 0 ? `Assumptions: ${hypParts.join(' · ')} — self-consumption under law 82-21, no resale.` : '';
      hypEl.hidden = hypParts.length === 0;
    }
    if (noteEl) noteEl.hidden = true;
    if (hypWrap) hypWrap.hidden = false;
    estimateShown = shown;
    lastKwc = kwcOk ? est.kwc : null;
    lastKwcLabel = kwcOk ? `${formatKwc(est.kwc)} kWc` : '';
    lastSavingsLabel = ecoLabel ? `${ecoLabel}/year` : '';
    if (printBtn) printBtn.hidden = false;
    fillDocChrome();
    updatePanels3dVisibility();
    if (hasReachedConsentStep()) sendFunnelBeacon('contact', 'reached');
    announceEstimate(`Your estimate: ${lastKwcLabel || 'calculated'}${ecoLabel ? `, estimated savings ${ecoLabel}/year` : ''}.`);
    return true;
  }
