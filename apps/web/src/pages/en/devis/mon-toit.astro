              <svg aria-hidden="true" width="10" height="10" viewBox="0 0 10 10" fill="none">
                <polyline points="7,1 3,5 7,9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              <span>Back</span>
            </button>
          </div>

          <!-- WJ5 — qualified success (≥ threshold: the request reaches the CRM) -->
          <div id="mt-success" hidden class="border border-ok-600/40 bg-ok-600/10 p-4 text-sm text-white">
            <p class="font-semibold">Thank you! Your request has been recorded.</p>
            <p class="mt-1 text-lune-soft">Our team is preparing your study and will contact you back very soon — often on WhatsApp.</p>
            <!-- WJ52 — short reference: fills the post-submission void (24–48 h
                 wait) with a concrete artefact to mention on WhatsApp. -->
            <p class="mt-2 text-lune-soft">
              <span>Your reference:</span>
              {' '}<strong id="mt-client-ref" class="font-mono text-white" dir="ltr">—</strong>
              <br />
              <span class="text-xs">Mention this code on WhatsApp to find your file faster.</span>
            </p>
            <a id="mt-success-wa" href="#" target="_blank" rel="noopener"
              class="mt-3 inline-flex items-center gap-2 bg-ok-600 px-4 py-2.5 text-sm font-bold text-white transition-opacity hover:opacity-90">
              <span>Open WhatsApp now</span>
            </a>
          </div>

          <!-- WJ5 — HONEST path below the qualifying threshold (never a fake "recorded") -->
          <div id="mt-belowthreshold" hidden class="border border-brass-400/40 bg-brass-400/10 p-4 text-sm text-white">
            <p class="font-semibold">Solar isn't profitable yet at your scale.</p>
            <p class="mt-1 text-lune-soft">
              Below ~1,000 MAD/month, the investment takes too long to pay back for us to
              honestly recommend it. Let's stay in touch: as soon as your bill increases, or
              for free energy-efficiency advice, write to us on WhatsApp.
            </p>
            <a id="mt-belowthreshold-wa" href="#" target="_blank" rel="noopener"
              class="mt-3 inline-flex items-center gap-2 bg-ok-600 px-4 py-2.5 text-sm font-bold text-white transition-opacity hover:opacity-90">
              <span>Chat on WhatsApp</span>
            </a>
          </div>
        </form>
      </div>

      <!-- ============ WJ8/WJ35 — TRUST AT THE POINT OF CAPTURE ============ -->
      <aside class="mt-8 border-t border-white/10 pt-6">
        <!-- pending real content from Reda: real installation photos.
             We do NOT FABRICATE any figure or review: we show verifiable facts (law
             82-21, standard manufacturer warranties, real service area) + a scaffolded
             slot for the photos. The installation counter (4th tile) is now REAL —
             derived from src/lib/realisations.ts (WJ35, InstallCounter). -->
        <div class="grid grid-cols-2 gap-3 sm:grid-cols-4">
          <div class="cine-card p-3 text-center">
            <p class="text-sm font-bold text-white">Law 82-21 compliant</p>
            <p class="text-xs text-lune-faint">Declared self-production</p>
          </div>
          <div class="cine-card p-3 text-center">
            <p class="text-sm font-bold text-white">25-year warranty</p>
            <p class="text-xs text-lune-faint">Panels (manufacturer)</p>
          </div>
          <div class="cine-card p-3 text-center">
            <p class="text-sm font-bold text-white">Certified equipment</p>
            <p class="text-xs text-lune-faint">IEC 61215 / 61730</p>
          </div>
          <div class="cine-card p-3 text-center">
            <p class="text-sm font-bold text-white">All across Morocco</p>
            <p class="text-xs text-lune-faint">Local site study</p>
          </div>
        </div>

        <!-- WJ8 — real service towns -->
        <p class="mt-4 text-center text-xs text-lune-faint">
          <span>Installations and studies in</span>
          {' '}{TOWNS.join(' · ')}
        </p>

        <!-- QX — the old #mt-install-photos scaffold (always hidden, never
             populated) is retired: real photos from Reda will go through a
             dedicated component, not a dead div. -->

        <!-- WJ35 — premium social proof: real counter + Google rating (scaffold until
             available) + certifications. Discreet v3 grade (section-tight rhythm). -->
        <div class="mt-6 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
          <InstallCounter />
          <StarRating compact />
        </div>
        <div class="mt-5">
          <CertLogoRow />
        </div>
      </aside>

      <!-- WJ35 — closing zellige signature (v3 imprint, consistent with the elevated homepage) -->
      <ZelligeSignature
        line="Every figure on this page is measured, not promised."
        sub="Your estimate first. The study next."
      />
    </div>
  </section>

  <!-- ============ WJ7 — ABANDONMENT RECOVERY (exit-intent / mobile leave) ============
       WJ34 — safe-area-inset-bottom: anchored to the bottom on mobile (items-end), the
       modal must never sit under the gesture bar / notch. ==== -->
  <div id="mt-exit" hidden class="fixed inset-0 z-50 flex items-end justify-center bg-black/60 p-4 sm:items-center"
    style="padding-bottom: max(1rem, env(safe-area-inset-bottom));"
    role="dialog" aria-modal="true" aria-labelledby="mt-exit-title">
    <div class="cine-card w-full max-w-md border border-brass-400/40 p-5">
      <div class="flex items-start justify-between gap-3">
        <p id="mt-exit-title" class="display text-lg text-white">Receive your estimate on WhatsApp</p>
        <!-- WJ88 — target ≥24×24 px (WCAG 2.5.8). WA29 — bumped to ~44px
             (iOS comfort) for a modal a visitor on their way out must be able
             to close quickly. -->
        <button type="button" id="mt-exit-close" aria-label="Close"
          class="flex-none min-h-11 min-w-11 inline-flex items-center justify-center text-lune-faint hover:text-white">✕</button>
      </div>
      <p class="mt-2 text-sm text-lune-soft">
        Just leave your number — we'll send you your estimate and answer your questions.
        Free, no obligation.
      </p>
      <div class="mt-4 flex flex-col gap-2 sm:flex-row">
        <input id="mt-exit-phone" type="tel" inputmode="tel" autocomplete="tel"
          placeholder="06 XX XX XX XX" class={inputClass} />
        <a id="mt-exit-wa" href="#" target="_blank" rel="noopener"
          class="inline-flex flex-none items-center justify-center gap-2 bg-ok-600 px-5 py-3 text-base font-bold text-white transition-opacity hover:opacity-90">
          <span>Send</span>
        </a>
      </div>
      <p id="mt-exit-err" hidden class="mt-2 text-xs text-alert-300" aria-live="polite"></p>
    </div>
  </div>
</Layout>

<style>
  /* WJ2 — RESERVED-height box (zero CLS): the "see the panels" button and the
     3D canvas that replaces it occupy EXACTLY the same area.
     QX — "daylight sky" background (light blue → warm horizon gradient)
     instead of the navy void: the panels no longer float in the dark,
     consistent with the paper aesthetic of the estimate document just above. */
  .mt-panels3d-stage {
    height: 320px;
    background: linear-gradient(180deg, #b9d7ee 0%, #dcebf7 55%, #f2ecdf 100%);
  }
  @media (min-width: 640px) {
    .mt-panels3d-stage {
      height: 380px;
    }
  }

  /* ===== WJ34 — perceived-performance skeletons (zero CLS: the area already
     occupies its final height — existing bg-nuit-700/min-h — we only add a
     "loading" effect on top, removed at first real render). ===== */
  .mt-skeleton-shimmer {
    background-image: linear-gradient(
      100deg,
      transparent 30%,
      rgb(255 255 255 / 0.06) 50%,
      transparent 70%
    );
    background-size: 200% 100%;
  }
  @media (prefers-reduced-motion: no-preference) {
    .mt-skeleton-shimmer {
      animation: mt-shimmer 1.6s ease-in-out infinite;
    }
  }
  @keyframes mt-shimmer {
    from { background-position: 200% 0; }
    to { background-position: -200% 0; }
  }

  /* Skeletons for the 3 estimate numbers — same proportions as the final text
     (text-3xl), so NO CLS when the real numbers replace them. */
  .mt-est-skeleton {
    display: inline-block;
    height: 2.25rem;
    width: 4.5rem;
    border-radius: 0.25rem;
    background: rgb(255 255 255 / 0.08);
    vertical-align: middle;
  }

  /* WJ48 — branded "thinking" dot: a discreet pulse, never a generic
     spinner. Gated reduced-motion (static otherwise), same discipline as
     .mt-skeleton-shimmer. */
  @media (prefers-reduced-motion: no-preference) {
    .mt-thinking-dot {
      animation: mt-thinking-pulse 1s ease-in-out infinite;
    }
  }
  @keyframes mt-thinking-pulse {
    0%, 100% { opacity: 0.35; transform: scale(0.85); }
    50% { opacity: 1; transform: scale(1); }
  }

  /* ===== WJ125 — locked teaser card. The blur is only a dressing: the bars/
     chart below hold NO figure (the real value masking is done in JS — the
     figured zones are never populated in the public journey). ===== */
  .mt-teaser-preview {
    filter: blur(7px);
    opacity: 0.4;
    pointer-events: none;
    user-select: none;
  }
  .mt-teaser-kpis {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem;
  }
  .mt-teaser-bar {
    display: block;
    height: 2.5rem;
    border-radius: 0.375rem;
    background: rgb(255 255 255 / 0.12);
  }
  .mt-teaser-chart {
    margin-top: 0.75rem;
    height: 4.5rem;
    border-radius: 0.375rem;
    background: repeating-linear-gradient(
      90deg,
      rgb(255 255 255 / 0.12) 0 14px,
      transparent 14px 26px
    );
  }
  .mt-teaser-lock {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    padding: 1rem;
    text-align: center;
    background: rgb(10 15 26 / 0.55);
  }
  .mt-teaser-lock-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 9999px;
    border: 1px solid var(--color-brass-400, #f5a623);
    color: var(--color-brass-300, #f7c66a);
  }
  .mt-teaser-hook {
    font-size: 0.95rem;
    font-weight: 600;
    color: #ffffff;
    max-width: 30ch;
  }
  .mt-teaser-headline {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-brass-300, #f7c66a);
  }
  .mt-teaser-sub {
    font-size: 0.8rem;
    color: var(--color-lune-soft, #c7cdd6);
    max-width: 34ch;
  }
</style>

<!-- ===== QX — THE ESTIMATE DOCUMENT: GLOBAL styles (is:global) because (1)
     the monthly SVG chart is injected by JS (scoped Astro styles don't match
     JS-injected nodes) and (2) the @media print rules must hide the
     Layout's header/footer, out of reach of a scoped style. Tokens = the
     REAL theme of the premium engine (quote_engine residential/theme.py):
     navy #1A2B4A, gold #F5A623, green #16A34A, ink #1f2937, greys
     #6b7280/#9BA3AE, rules #E5E7EB/#EFF1F4, wash #F7F9FC. Fonts: DM Serif
     Display (headings, numbers) + DM Sans (body) — the SAME woff2 as the PDF. ===== -->
<style is:global>
  @font-face {
    font-family: 'DM Serif Display';
    src: url('/fonts/dm-serif-display-400.woff2') format('woff2');
