      });
      if (!handle) throw new Error('WebGL unavailable');
    } catch {
      // Graceful fallback: the button stays, with a sober message — never a block.
      panels3dStarted = false;
      if (panels3dOverlay) {
        const btn = panels3dStart;
        if (btn) {
          btn.disabled = true;
          btn.textContent = '3D preview unavailable on this device';
        }
      }
    }
  }
  panels3dStart?.addEventListener('click', () => { void startPanels3d(); });

  // ——— QX : "Print / Save as PDF" — the estimate document prints as-is
  // (@media print: only #mt-doc stays visible, navy/gold bands preserved via
  // print-color-adjust). Replaces the old PNG one-pager, W356: same
  // honesty, a much better artefact — a real A4 document. ———
  $('mt-print-estimate')?.addEventListener('click', () => {
    window.print();
  });

  // ——— WJ4 : INLINE validation aligned with validateLead (before the round-trip) ———
  function setFieldError(inputId: string, errId: string, message: string | null) {
    const input = $(inputId) as HTMLInputElement | null;
    const err = $(errId);
    if (input) input.setAttribute('aria-invalid', message ? 'true' : 'false');
    if (err) {
      err.textContent = message || '';
      err.hidden = !message;
    }
  }

  // ——— QX : LIVE VALIDATION — every field validates on blur, every
  // "Continue" validates ITS step (inline errors + focus + smooth scroll to
  // the first invalid field). Typed values are NEVER auto-corrected/rejected
  // (repo rule: no snapping). ———
  function scrollToInvalid(el: HTMLElement | null) {
    if (!el) return;
    el.scrollIntoView({ behavior: reducedMotion ? 'auto' : 'smooth', block: 'center' });
    if (typeof el.focus === 'function') el.focus({ preventScroll: true });
  }
  /** OPTIONAL numeric field: empty = OK; non-numeric or negative = error. */
  function checkOptionalNumber(id: string, label: string): boolean {
    const raw = val(id).trim();
    if (raw === '') {
      setFieldError(id, `${id}-err`, null);
      return true;
    }
    const n = num(id);
    if (n == null || n < 0) {
      setFieldError(id, `${id}-err`, `${label}: numbers only.`);
      return false;
    }
    setFieldError(id, `${id}-err`, null);
    return true;
  }
  const OPTIONAL_NUMBER_FIELDS: Array<[string, string]> = [
    ['mt-puissance-kva', 'Contracted power'],
    ['mt-surface-m2', 'Surface'],
    ['mt-profondeur', 'Depth'],
    ['mt-hmt', 'TDH'],
    ['mt-water-need', 'Water need'],
    ['mt-surface-ha', 'Surface'],
    ['mt-pompe-cv', 'Power (HP)'],
    ['mt-fuel-spend', 'Fuel spend'],
  ];
  for (const [id, label] of OPTIONAL_NUMBER_FIELDS) {
    $(id)?.addEventListener('blur', () => {
      checkOptionalNumber(id, label);
    });
  }
  /** Exact residential bill on blur: format + sanity cap. */
  function checkFactureHiver(): boolean {
    const raw = val('mt-facture-hiver').trim();
    if (raw === '') {
      setFieldError('mt-facture-hiver', 'mt-facture-hiver-err', null);
      return true;
    }
    const n = num('mt-facture-hiver');
    if (n == null || n <= 0) {
      setFieldError('mt-facture-hiver', 'mt-facture-hiver-err', 'Invalid amount — numbers only.');
      return false;
    }
    if (n > maxBillFor('residentiel')) {
      setFieldError('mt-facture-hiver', 'mt-facture-hiver-err', 'Please check the amount entered.');
      return true; // the document shows the honest "please check" path — never a block
    }
    setFieldError('mt-facture-hiver', 'mt-facture-hiver-err', null);
    return true;
  }
  $('mt-facture-hiver')?.addEventListener('blur', () => {
    checkFactureHiver();
  });
  $('mt-pro-bill')?.addEventListener('blur', () => {
    const raw = val('mt-pro-bill').trim();
    if (raw === '') {
      setFieldError('mt-pro-bill', 'mt-pro-bill-err', null);
      return;
    }
    const n = num('mt-pro-bill');
    setFieldError('mt-pro-bill', 'mt-pro-bill-err', n == null || n <= 0 ? 'Invalid amount — numbers only.' : null);
  });
  // WJ122 — same light blur validation for the COMMERCIAL bill.
  $('mt-cc-bill')?.addEventListener('blur', () => {
    const raw = val('mt-cc-bill').trim();
    if (raw === '') {
      setFieldError('mt-cc-bill', 'mt-cc-bill-err', null);
      return;
    }
    const n = num('mt-cc-bill');
    setFieldError('mt-cc-bill', 'mt-cc-bill-err', n == null || n <= 0 ? 'Invalid amount — numbers only.' : null);
  });
  // Contact: every field validates as soon as it loses focus (a light
  // mirror of validateLead — the final submission stays validated by the
  // full validateLead).
  $('mt-name')?.addEventListener('blur', () => {
    const v = val('mt-name').trim();
    setFieldError('mt-name', 'mt-name-err', v !== '' && (v.length < 2 || !/\p{L}/u.test(v)) ? 'Full name required' : null);
  });
  $('mt-phone')?.addEventListener('blur', () => {
    const digits = val('mt-phone').replace(/\D/g, '');
    setFieldError('mt-phone', 'mt-phone-err', val('mt-phone').trim() !== '' && digits.length < 9 ? 'Invalid phone number' : null);
  });
  $('mt-city')?.addEventListener('blur', () => {
    const v = val('mt-city').trim();
    setFieldError('mt-city', 'mt-city-err', v !== '' && v.length < 2 ? 'Address / city required' : null);
  });
  /** Map step: a profile must be chosen (inline nudge on the cards). */
  function validateStep0(): boolean {
    if (mode) return true;
    const err = $('mt-mode-err');
    if (err) {
      err.textContent = 'Choose your project type to continue.';
      err.hidden = false;
    }
    scrollToInvalid(document.querySelector<HTMLButtonElement>('.mt-mode'));
    return false;
  }
  /** Questions step: validation PER PROFILE before the calculation. */
  function validateStep1(): boolean {
    if (isProMode(mode)) {
      if (!checkOptionalNumber('mt-puissance-kva', 'Contracted power')) {
        scrollToInvalid($('mt-puissance-kva'));
        return false;
      }
      const raw = val(proBillId()).trim();
      const n = num(proBillId());
      if (raw === '' || n == null || n <= 0) {
        setFieldError(proBillId(), proBillErrId(), 'Enter your monthly consumption (MAD or kWh) to calculate your estimate.');
        scrollToInvalid($(proBillId()));
        return false;
      }
      setFieldError(proBillId(), proBillErrId(), null);
      return true;
    }
    if (mode === 'agricole') {
      // Nothing is REQUIRED (missing hydraulics = the honest "an engineer
      // will call you back" path) — but a number entered must be a number.
      for (const [id, label] of OPTIONAL_NUMBER_FIELDS) {
        if (!['mt-profondeur', 'mt-hmt', 'mt-water-need', 'mt-pompe-cv', 'mt-fuel-spend'].includes(id)) continue;
        if (!checkOptionalNumber(id, label)) {
          scrollToInvalid($(id));
          return false;
        }
      }
      return true;
    }
    // Residential: a bill is required (exact amount OR range) + a roof type
    // (validateLead requires it anyway at submission — better to say so HERE, not at the end).
    const rawF = val('mt-facture-hiver').trim();
    const exact = num('mt-facture-hiver');
    if (rawF !== '' && (exact == null || exact <= 0)) {
      setFieldError('mt-facture-hiver', 'mt-facture-hiver-err', 'Invalid amount — numbers only.');
      scrollToInvalid($('mt-facture-hiver'));
      return false;
    }
    if ((exact == null || exact <= 0) && !val('mt-bill')) {
      setFieldError('mt-facture-hiver', 'mt-facture-hiver-err', 'Enter your bill: exact amount or a range.');
      setFieldError('mt-bill', 'mt-bill-err', "Choose a range if you don't know the exact amount.");
      scrollToInvalid($('mt-facture-hiver'));
      return false;
    }
    setFieldError('mt-bill', 'mt-bill-err', null);
    if (!val('mt-roof')) {
      setFieldError('mt-roof', 'mt-roof-err', 'Choose your roof type.');
      scrollToInvalid(document.querySelector<HTMLButtonElement>('.mt-roof-card'));
      return false;
    }
    return true;
  }

  // ——— QX : PROFESSIONAL billRange derived from the entered consumption —
  // always consistent with what drove the estimate shown. In kWh, the
  // implicit MAD = kWh × the engine's assumed tariff (the same figure as the
  // document); "gt10000" stays factually true for any large account. ———
  function resolveProBillRange(): string {
    const v = num(proBillId());
    if (v == null || v <= 0) return '';
    let mad: number | null = null;
    if (proBillUnit() === 'mad') mad = v;
    else if (lastProTarifMadKwh != null && lastProTarifMadKwh > 0) mad = v * lastProTarifMadKwh;
    if (mad == null || !(mad > 0)) return '';
    const rid = billRangeFromExact(mad);
    if (rid) return rid;
    return mad > 10_000 ? 'gt10000' : '';
  }
  // ——— QX : per-profile roofType — validateLead (lib/lead.ts) requires it
  // for any mon-toit submission, but the "roof type" cards only live in the
  // RESIDENTIAL sub-panel. For pro/agricultural we DERIVE the value from the
  // real answers given (never an invented roof choice): metal roof ->
  // hangar/shed, flat roof (terrace) -> flat roof, everything else -> 'other'
  // (the honest bucket — the CRM gets surfaceType/waterSource, the precise
  // fields, anyway). ———
  function resolveRoofType(): string {
    if (isProMode(mode)) {
      if (surfaceType === 'bac_acier') return 'hangar';
      if (surfaceType === 'terrasse') return 'toit_plat';
      return 'autre';
    }
    if (mode === 'agricole') return 'autre';
    return val('mt-roof');
  }
  // ——— WJ52 : short client reference, generated ONCE in the browser ———
  // Stable across repeated submissions (e.g. a network failure then a retry):
  // generated on the first attempt, reused as-is afterwards — never silently
  // regenerated, never a server uniqueness key (see lib/lead.ts).
  let clientRef = '';
  function getOrCreateClientRef(): string {
    if (!clientRef) clientRef = buildClientRef();
    return clientRef;
  }

  // WJ116 — resumes fbclid + UTM from sessionStorage (first-touch capture in
  // the Layout, apps/web/src/layouts/Layout.astro ~l.206): without this, NO
  // UTM attribution (referrals included — /parrainage) ever left this MAIN
  // funnel even though the webhook / validateLead already accept them.
  // Exact mirror of DiagnosticForm.astro ~l.279. Only PRESENT keys are
  // joined (WJ30/WJ31 convention "absent rather than empty"): a visitor with
  // no tracking parameter sends a byte-identical body to before.
  const TRACK_KEYS = ['fbclid', 'utm_source', 'utm_medium', 'utm_campaign', 'utm_content', 'utm_term'] as const;
  function readTrackingParams(): Record<string, string> {
    const out: Record<string, string> = {};
    for (const k of TRACK_KEYS) {
      try {
        const v = sessionStorage.getItem('tq_' + k);
        if (v) out[k] = v;
      } catch {}
    }
    return out;
  }

  // WJ122 — active commercial category answers, mapped snake_case → the webhook
  // whitelist camelCase (QX51). Only questions with a webhook key are sent
  // (hammam surface_m2 ⇒ never sent); a boolean is joined only when checked, a
  // number/select only when filled.
  function readCommercialAnswers(): Record<string, unknown> {
    const out: Record<string, unknown> = {};
    if (mode !== 'commercial' || !commercialCategory) return out;
    const qs = COMMERCIAL_CATEGORY_QUESTIONS[commercialCategory] || [];
    for (const q of qs) {
      const webhookKey = COMMERCIAL_QUESTION_WEBHOOK_KEY[q.key];
      if (!webhookKey) continue;
      const domId = `mt-cc-${commercialCategory}-${q.key}`;
      const el = $(domId) as HTMLInputElement | HTMLSelectElement | null;
      if (!el) continue;
      if (q.type === 'bool') {
        if ((el as HTMLInputElement).checked === true) out[webhookKey] = true;
      } else if (q.type === 'number') {
        const n = num(domId);
        if (n != null) out[webhookKey] = n;
      } else {
        const v = el.value;
        if (v) out[webhookKey] = v;
      }
    }
    return out;
  }
  /** Builds the lead body + returns client-side errors (mirrors validateLead). */
  function buildBody(): { body: Record<string, unknown>; errors: Record<string, string> } {
    const eteDifferente = eteToggle?.checked === true;
    const consent = ($('mt-consent') as HTMLInputElement | null)?.checked === true;
    // WJ51 — EXPLICIT contact preference (radio "WhatsApp only" vs "An
    // advisor may call me"): `whatsappOptIn` stays derived so nothing breaks
    // CRM/webhook side, `contactPreference` is forwarded in addition (maps to `canal`).
    const contactPreference = (($('mt-contact-phone') as HTMLInputElement | null)?.checked === true)
      ? 'phone_ok'
      : 'whatsapp_only';
    const whatsappOptIn = contactPreference === 'whatsapp_only';
    const adresse = (val('mt-city') || addressEl?.value.trim() || fallbackAddrEl?.value.trim() || '').trim();
    const body: Record<string, unknown> = {
      fullName: val('mt-name'),
      phone: val('mt-phone'),
      city: adresse,
      // QX — billRange ALWAYS consistent with what drove the estimate shown:
      // residential = the <select> (auto-derived from the exact amount,
      // syncBillRangeFromExact); C&I (industrial/commercial) = derived from the entered
      // consumption; agricultural = no longer required (lib/lead.ts, mode 'agricole').
      billRange: isProMode(mode) ? resolveProBillRange() : mode === 'agricole' ? '' : val('mt-bill'),
      // QX — derived from the real answers for pro/agricultural (roof cards
      // = residential sub-panel only); see resolveRoofType.
      roofType: resolveRoofType(),
      consent,
      whatsappOptIn,
      contactPreference,
      email: val('mt-email') || undefined,
      factureHiver: num('mt-facture-hiver'),
      factureEte: eteDifferente ? num('mt-facture-ete') : null,
      eteDifferente,
      raccordement: val('mt-raccordement'),
      adresse,
      // WJ30 — the project type is forwarded to the webhook. WJ39 — this
      // page has no FR/AR toggle (the /en/ URL already declares the locale)
      // and `langue_preferee` only accepts fr/ar (src/lib/lead.ts LEAD_LANGS): omitted.
      mode,
      // WJ31 — widened optional capture questions (already validated one by
      // one server-side: an empty/malformed field is simply discarded).
      distributeur: val('mt-distributeur') || undefined,
      billKwh: num('mt-bill-kwh'),
      ombrage: ombrage || undefined,
      roofAgeYears: num('mt-roof-age'),
      futureLoads: futureLoads.size > 0 ? Array.from(futureLoads) : undefined,
      batteryInterest: ($('mt-battery-interest') as HTMLInputElement | null)?.checked === true,
      occupantType: val('mt-occupant-type') || undefined,
      projectTiming: val('mt-project-timing') || undefined,
      financingIntent: val('mt-financing-intent') || undefined,
      hasMeterPhoto,
      // WJ52 — short reference for the post-submission artefact (echoed as-is,
      // never a server uniqueness key — see lib/lead.ts).
      clientRef: getOrCreateClientRef(),
      // W353 — technical visit slot preference (optional, STATIC).
      visitWindowPart: visitWindowPart || undefined,
      visitWindowWeek: visitWindowWeek || undefined,
      // WJ68 — professional mode: optional, additive, never blocking. Fields
      // are still sent even if the mode changed since (validateLead accepts
      // them independently of the mode — a visitor toggling
      // residential->professional->residential loses nothing typed).
      raisonSociale: val('mt-raison-sociale') || undefined,
      facilityType: val('mt-facility-type') || undefined,
      siteCount: val('mt-site-count') || undefined,
      // QX — PROFESSIONAL sub-panel. `tensionRaccordement` (bt/mt) is
      // deliberately DISTINCT from the residential `raccordement` select
      // (single/three-phase) — never both meanings in one field. Fields with
      // a VISIBLE default (tension/activity) are only sent when a C&I
      // (industrial/commercial) profile is active — never fabricated data for another profile.
      tensionRaccordement: isProMode(mode) ? tension : undefined,
      puissanceKva: num('mt-puissance-kva') ?? undefined,
      activityProfile: isProMode(mode) ? activity : undefined,
      surfaceType: surfaceType || undefined,
      surfaceM2: num('mt-surface-m2') ?? undefined,
      hasGenerator: generator ? generator === 'oui' : undefined,
      // WJ122 — C&I consumption comes from the active panel (commercial: mt-cc-bill).
      proMonthlyKwh: proBillUnit() === 'kwh' ? (num(proBillId()) ?? undefined) : undefined,
      proMonthlyMad: proBillUnit() === 'mad' ? (num(proBillId()) ?? undefined) : undefined,
      // WJ122 — COMMERCIAL mode: category + category-specific answers (webhook
      // whitelist QX51; hotel ≠ office at equal bill via the archetype day-share).
      categorieCommerciale: mode === 'commercial' ? (commercialCategory || undefined) : undefined,
      ...readCommercialAnswers(),
      // WJ123 — INDUSTRIAL v2: shifts + weekend + context (webhook whitelist QX51).
      // `weekend` is a SEPARATE boolean, never a 5th shift value.
      equipes: (mode === 'industriel' || mode === 'professionnel') ? (equipes || undefined) : undefined,
      weekend: (mode === 'industriel' || mode === 'professionnel') && (($('mt-weekend') as HTMLInputElement | null)?.checked === true) ? true : undefined,
      cosPhiConnu: (mode === 'industriel' || mode === 'professionnel') ? (num('mt-cos-phi') ?? undefined) : undefined,
      groupeKva: (mode === 'industriel' || mode === 'professionnel') ? (num('mt-groupe-kva') ?? undefined) : undefined,
      dieselDhMois: (mode === 'industriel' || mode === 'professionnel') ? (num('mt-diesel-dh') ?? undefined) : undefined,
      // surface_toiture_m2 = roof surface in the strict sense (the backend
      // distinguishes ground: webhooks.py:303-304) — only send it for a real roof;
      // ombrière/terrain are described by their booleans, never a fake roof.
      surfaceToitureM2: (mode === 'industriel' || mode === 'professionnel') && (surfaceType === 'bac_acier' || surfaceType === 'terrasse') ? (num('mt-surface-m2') ?? undefined) : undefined,
      ombriere: (mode === 'industriel' || mode === 'professionnel') && surfaceType === 'ombriere' ? true : undefined,
      terrain: (mode === 'industriel' || mode === 'professionnel') && surfaceType === 'terrain' ? true : undefined,
      // QX — AGRICULTURAL sub-panel (pumping).
      waterSource: waterSource || undefined,
      profondeurM: num('mt-profondeur') ?? undefined,
      hmtM: num('mt-hmt') ?? undefined,
      debitM3h: waterUnit === 'm3h' ? (num('mt-water-need') ?? undefined) : undefined,
      besoinM3j: waterUnit === 'm3j' ? (num('mt-water-need') ?? undefined) : undefined,
      heuresPompage: mode === 'agricole' ? (num('mt-heures-pompage') ?? undefined) : undefined,
      irrigation: irrigation || undefined,
      culture: val('mt-culture') || undefined,
      // WJ124 — agronomy region (drives the FAO-56 water engine on the proposal).
      regionAgricole: regionAgricole || undefined,
      surfaceHa: num('mt-surface-ha') ?? undefined,
      pompeActuelle: val('mt-pompe-actuelle') || undefined,
      pompeCvActuelle: num('mt-pompe-cv') ?? undefined,
      fuelSpendMad: num('mt-fuel-spend') ?? undefined,
      // QX — EXACTLY the figures shown in the estimate document (the CRM
      // advisor sees what the client saw — never more).
      estimateShown: estimateShown ?? undefined,
      // W317 — honeypot: empty for any human visitor (hidden off-screen
      // field, never knowingly filled); rejected server-side if not empty.
      website_url: val('mt-hp'),
    };
    // WJ116 — fbclid/UTM (referrals included): joined only if present.
    Object.assign(body, readTrackingParams());
    // WJ4 — OPTIONAL pin: joined if it exists, never BLOCKS without it.
    if (capturePin) {
      body.roofPoint = capturePin;
      body.gpsLat = capturePin.lat;
      body.gpsLng = capturePin.lng;
    }
    if (captureOutline.length >= 3) body.roofOutline = captureOutline;
    const v = validateLead(body);
    const errors: Record<string, string> = v.ok ? {} : { ...v.errors };
    // WJ65 — validateLead (lib/lead.ts, out of this page's file scope) only
    // requires a length >= 2: a name made only of emoji/symbols (e.g.
    // "😀😀") used to pass silently. We require at least ONE letter (any
    // alphabet — \p{L} covers Latin and Arabic) before submitting.
    if (!errors.fullName && !/\p{L}/u.test(val('mt-name'))) {
      errors.fullName = 'Full name required';
    }
    return { body, errors };
  }

  // WJ39 — the shared validateLead() (src/lib/lead.ts, out of this page's
  // file scope) returns French messages; translate the known set to English
  // so inline errors never show French on this route (see VALIDATION_ERROR_EN above).
  const enMsg = (msg: string | null | undefined): string | null =>
    msg == null ? null : (VALIDATION_ERROR_EN[msg] ?? msg);
  function showInlineErrors(errors: Record<string, string>) {
    setFieldError('mt-name', 'mt-name-err', enMsg(errors.fullName));
    setFieldError('mt-phone', 'mt-phone-err', enMsg(errors.phone));
    setFieldError('mt-city', 'mt-city-err', enMsg(errors.city));
    setFieldError('mt-roof', 'mt-roof-err', enMsg(errors.roofType));
    setFieldError('mt-bill', 'mt-bill-err', enMsg(errors.billRange));
    const cErr = $('mt-consent-err');
    const consentMsg = enMsg(errors.consent);
    if (cErr) { cErr.textContent = consentMsg ?? ''; cErr.hidden = !consentMsg; }
  }

  // ——— WJ3 : WhatsApp deeplink prefilled with the estimate ———
  function buildWaUrl(): string {
    const text = captureWhatsappText({
      fullName: val('mt-name'),
      city: (val('mt-city') || addressEl?.value || '').trim(),
      kwcLabel: lastKwcLabel || undefined,
      savingsLabel: lastSavingsLabel || undefined,
    });
    return whatsappLink(WHATSAPP_LEADS, text);
  }

  // ——— submission -> /api/capture-lead (contract UNCHANGED) ———
  const form = $('mt-form') as HTMLFormElement | null;
  const errEl = $('mt-error');
  const okEl = $('mt-success');
  const belowEl = $('mt-belowthreshold');
  const submitBtn = $('mt-submit') as HTMLButtonElement | null;
  const submitLabelEl = $('mt-submit-label');
  const submitPendingEl = $('mt-submit-pending');
  let submitted = false;

  // WJ60 — toggle the CTA to "Sending…" while the network request is pending
  // (never a mute button on slow 3G); restored at the end regardless of
  // outcome (except success, where the whole form disables right after).
  function setSubmitPending(pending: boolean) {
    if (submitBtn) submitBtn.disabled = pending;
    if (submitLabelEl) submitLabelEl.hidden = pending;
    if (submitPendingEl) submitPendingEl.hidden = !pending;
  }

  // WJ60 — HONEST message for a SERVER-SIDE failure (>=500, malformed JSON,
  // timeout, network cut): never blames the visitor's fields for a failure
  // that isn't theirs. WJ63 — the client ALWAYS prefers its own localised
  // copy over server-sent text (e.g. the rate-limit's 429 message, in
  // French on the API side): `data.errors` is only shown as-is for REAL
  // field errors (4xx validation), never for a generic server failure.
  const SERVER_ERROR_MSG = 'A technical problem on our side — please try again.';
  // WJ45 — DISTINCT message when the cut comes from the visitor's own
  // network (not our side): reassures that nothing is lost instead of the
  // generic "problem on our side" line.
  const OFFLINE_MSG = "No connection — your answers are kept, we'll retry as soon as the network is back.";
  // WJ60 — 15 s gives a slow connection time to respond, without leaving the
  // "Sending…" CTA hanging indefinitely (the failure, timeout included, falls
  // into the honest message above — never a silent block).
  const SUBMIT_TIMEOUT_MS = 15_000;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (errEl) errEl.hidden = true;
    const { body, errors } = buildBody();
    if (Object.keys(errors).length > 0) {
      showInlineErrors(errors);
      if (errEl) {
        errEl.textContent = 'Please check the highlighted fields above.';
        errEl.hidden = false;
      }
      // brings the user to the first field in error.
      // WJ48 — mt-roof is now sr-only (the visual choice is made via the
      // .mt-roof-card cards): focusing the hidden <select> would move
      // keyboard focus to an element invisible to a sighted user. We focus
      // the first visible card instead in that case.
      const firstId = ['mt-name', 'mt-phone', 'mt-city', 'mt-roof', 'mt-bill']
        .find((id) => $(id)?.getAttribute('aria-invalid') === 'true');
      if (firstId === 'mt-roof') {
        document.querySelector<HTMLButtonElement>('.mt-roof-card')?.focus();
      } else if (firstId) {
        ($(firstId) as HTMLElement | null)?.focus();
      }
      return;
    }
    showInlineErrors({});

    setSubmitPending(true);
    try {
      const res = await fetch('/api/capture-lead', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify(body),
        signal: AbortSignal.timeout(SUBMIT_TIMEOUT_MS),
      });
      // WJ60/WJ63 — a malformed JSON response (empty/unreadable body) is
      // treated as a server failure, never silently as "no error".
      let malformed = false;
      const data = (await res.json().catch(() => {
        malformed = true;
        return {};
      })) as { ok?: boolean; qualified?: boolean; errors?: Record<string, string> };
      if (res.ok && !malformed && data.ok) {
        submitted = true;
        hasEnteredData = false; // WJ61 — success: no longer need the beforeunload guard.
        clearWizardState(); // WJ61 — the request went through: the snapshot no longer applies.
        // WJ104 — "callback requested": a signal DISTINCT from a WhatsApp
        // opt-in, emitted ONLY when the chosen contact preference is "call
        // me" (mt-contact-phone), never for the default WhatsApp fallback.
        // Deduped like the other beacons on this page.
        if (($('mt-contact-phone') as HTMLInputElement | null)?.checked === true) {
          sendFunnelBeacon('contact', 'callback_requested');
        }
        const waUrl = buildWaUrl();
        // WJ5 — HONEST response per the qualifying threshold (`qualified` returned by the server).
        if (data.qualified) {
          if (okEl) okEl.hidden = false;
          // WJ52 — display the reference generated in buildBody() (already
          // included in the sent body — re-read here via getOrCreateClientRef()
          // to stay the SAME value, never regenerated).
          const refEl = $('mt-client-ref');
          if (refEl) refEl.textContent = getOrCreateClientRef();
          const waLink = $('mt-success-wa') as HTMLAnchorElement | null;
          if (waLink) waLink.href = waUrl;
          // WJ3/WJ51 — on mobile, offer WhatsApp right away when the contact
          // preference is "WhatsApp only" (the option checked by default).
          const wantsWa = ($('mt-contact-phone') as HTMLInputElement | null)?.checked !== true;
          if (wantsWa && /Mobi|Android|iPhone/i.test(navigator.userAgent) && !reducedMotion) {
            setTimeout(() => { window.location.href = waUrl; }, 900);
          }
        } else {
          // below the threshold: NO fake "recorded" — an adapted message + WhatsApp.
          if (belowEl) belowEl.hidden = false;
          const belowWa = $('mt-belowthreshold-wa') as HTMLAnchorElement | null;
          if (belowWa) belowWa.href = waUrl;
        }
        // disable the fields after submission (except the WhatsApp links).
        Array.from(form.elements).forEach((el) => ((el as HTMLInputElement).disabled = true));
        return;
      }
      // WJ60/WJ63 — >=500 or malformed JSON: SERVER-SIDE failure, never a
      // message that blames the fields. Below 500 with usable field errors
      // (4xx validation, e.g. `errors.fullName`), we still show them inline
      // as before — but a server text that is NOT a known field error (e.g.
      // `errors.rate`, the rate-limit's 429, in French on the API side)
      // never overwrites our honest copy: only the `errors.rate` field falls
      // back to the same generic server message.
      const isServerError = malformed || res.status >= 500 || (!!data.errors && 'rate' in data.errors);
      if (!isServerError && data.errors) showInlineErrors(data.errors);
      const firstFieldErr = !isServerError && data.errors ? Object.values(data.errors)[0] : null;
      if (errEl) {
        errEl.textContent = isServerError
          ? SERVER_ERROR_MSG
          : ((firstFieldErr && (VALIDATION_ERROR_EN[firstFieldErr] ?? firstFieldErr)) || 'A field is missing or invalid. Please check your information.');
        errEl.hidden = false;
      }
      setSubmitPending(false);
    } catch {
      // WJ60 — covers the timeout (AbortSignal.timeout) and any network
      // outage. WJ45 — if the browser knows it's offline, say so explicitly
      // (banner + dedicated message) rather than the generic "problem on our
      // side" — which would wrongly blame our infrastructure. The form stays
      // filled and the WJ61 sessionStorage snapshot persists: nothing is
      // lost, just resend once the network is back.
      syncOfflineBanner();
      if (errEl) {
        errEl.textContent = navigator.onLine ? SERVER_ERROR_MSG : OFFLINE_MSG;
        errEl.hidden = false;
      }
      setSubmitPending(false);
    }
  });

  // ——— WJ7/WJ33/WJ46 : WhatsApp offer — exit-intent (desktop + hidden
  // mobile tab) AND peak interest (instant estimate shown). Same modal, same
  // `exitShown` guard (only shows ONCE, whatever the trigger): exit-intent
  // stays a SAFETY NET for whoever didn't see the offer at peak interest
  // (e.g. closes the tab before step 3), never a duplicate. ———
  const exitModal = $('mt-exit') as HTMLElement | null;
  const exitPhoneInput = $('mt-exit-phone') as HTMLInputElement | null;
  const exitWaLink = $('mt-exit-wa') as HTMLAnchorElement | null;
  let exitShown = false;
  let exitTriggerEl: HTMLElement | null = null; // WJ33 — to restore focus on close

  /** WJ33 — builds (or rebuilds) the abandonment WhatsApp link from the current state. */
  function buildExitWaHref(): string {
    const phone = exitPhoneInput?.value.trim() || '';
    // WJ39 — the phone-number sentence stays French by design (frontmatter
    // note): the WhatsApp deep-link text reaches the French-speaking sales team.
    const text = captureWhatsappText({
      fullName: '',
      city: (val('mt-city') || addressEl?.value || '').trim(),
      kwcLabel: lastKwcLabel || undefined,
      savingsLabel: lastSavingsLabel || undefined,
    }) + (phone.length >= 6 ? ` Mon numéro : ${phone}.` : '');
    return whatsappLink(WHATSAPP_LEADS, text);
  }

  // WJ102 — while the abandonment modal is open, the REST of the document
  // (header, footer, the wizard itself behind the overlay) must become truly
  // unreachable — not just visually hidden. Otherwise a keyboard/screen-
  // reader user could Tab-cycle to header/footer links BEHIND the
  // semi-transparent overlay, since the focus trap (Tab/Shift+Tab below)
  // only covers the LAST Tab before looping — not links reachable by a
  // direct click/VoiceOver rotor. Same idiom as Header.astro (mobile menu):
  // `inert` set on every DIRECT child of <body> that does NOT contain the
  // modal itself.
  const inertedSiblings: HTMLElement[] = [];
  function setBackgroundInert(on: boolean): void {
    if (on) {
      inertedSiblings.length = 0;
      for (const child of Array.from(document.body.children)) {
        if (!(child instanceof HTMLElement)) continue;
        if (child.contains(exitModal)) continue; // never make the modal itself inert
        if (child.hasAttribute('inert')) continue; // already inert for another reason: leave it alone on close
        child.setAttribute('inert', '');
        inertedSiblings.push(child);
      }
    } else {
      for (const el of inertedSiblings) el.removeAttribute('inert');
      inertedSiblings.length = 0;
    }
  }

  /** WJ46 — shows the WhatsApp offer (exit-intent OR peak interest). Only
   *  shows once per visit (`exitShown`), never after submission. */
  function showWhatsappOffer(triggerEl: HTMLElement | null = null) {
    if (exitShown || submitted) return;
    exitShown = true;
    exitTriggerEl = triggerEl ?? (document.activeElement as HTMLElement | null);
    if (exitWaLink) exitWaLink.href = buildExitWaHref();
    if (exitModal) {
      exitModal.hidden = false;
      // WJ102 — the rest of the document becomes inert while the modal is open.
      setBackgroundInert(true);
      // WJ33 — initial focus INSIDE the modal (first interactive field).
      exitPhoneInput?.focus();
    }
  }
  // WJ59 — "step abandoned": deduped separately from the WhatsApp offer
  // (which only shows once per visit via `exitShown`), since the
  // measurement signal stays useful even if the offer already showed once.
  let funnelAbandonSent = false;
  function maybeShowExit(triggerEl: HTMLElement | null = null) {
    // WJ46 — grace window: do NOT interpret the tab going to the background
    // while the meter/bill photo picker is open as an abandonment (the
    // camera/gallery hides the tab for the length of the shot — the exact
    // gesture the form invites).
    if (filePickerOpen) return;
    // only interrupt if the visitor has at least started (mode/bill or step > 0)
    const started2 = step > 0 || resolveMonthlyBill() != null || (capturePin != null);
    if (!started2) return;
    // WB30 — no "abandoned" beacon before the consent step (panel 2).
    if (!submitted && !funnelAbandonSent && hasReachedConsentStep()) {
      funnelAbandonSent = true;
      const currentStep = step === 0 ? 'toit' : step === 1 ? 'facture' : (lastKwc != null ? 'contact' : 'estimation');
      sendFunnelBeacon(currentStep, 'abandoned');
    }
    showWhatsappOffer(triggerEl);
  }
  function closeExit() {
    if (!exitModal || exitModal.hidden) return;
    exitModal.hidden = true;
    // WJ102 — restores the rest of the document's accessibility BEFORE
    // returning focus (otherwise the focus target below could still be inert).
    setBackgroundInert(false);
    // WJ33 — restores focus to the element that triggered the opening (or,
    // failing that, a stable anchor point — no language toggle on this EN
    // route, see WJ39).
    (exitTriggerEl && document.contains(exitTriggerEl) ? exitTriggerEl : $('mt-next-0'))?.focus();
    exitTriggerEl = null;
  }
  // desktop: the mouse leaves from the top
  document.addEventListener('mouseout', (e) => {
    if (!e.relatedTarget && (e as MouseEvent).clientY <= 0) maybeShowExit();
  });
  // mobile: the tab goes to the background
  document.addEventListener('visibilitychange', () => {
    if (document.visibilityState === 'hidden') maybeShowExit();
  });
  $('mt-exit-close')?.addEventListener('click', () => closeExit());
  exitModal?.addEventListener('click', (e) => { if (e.target === exitModal) closeExit(); });

  // WJ33 — keyboard: Esc closes + focus trap (Tab/Shift+Tab stay INSIDE the modal).
  exitModal?.addEventListener('keydown', (e) => {
    const ke = e as KeyboardEvent;
    if (ke.key === 'Escape') { closeExit(); return; }
    if (ke.key !== 'Tab' || !exitModal) return;
    const focusable = Array.from(
      exitModal.querySelectorAll<HTMLElement>('a[href], button:not([disabled]), input:not([disabled]), [tabindex]:not([tabindex="-1"])'),
    ).filter((el) => el.offsetParent !== null || el === document.activeElement);
    if (focusable.length === 0) return;
    const first = focusable[0];
    const last = focusable[focusable.length - 1];
    const active = document.activeElement as HTMLElement | null;
    if (ke.shiftKey && active === first) {
      ke.preventDefault();
      last.focus();
    } else if (!ke.shiftKey && active === last) {
      ke.preventDefault();
      first.focus();
    }
  });

  // WJ33 — the abandonment WhatsApp CTA: the `href` is rebuilt on EVERY
  // keystroke (not just on click), to stay correct if the user opens
  // WhatsApp via a right-click / "copy link" before finishing typing.
  exitPhoneInput?.addEventListener('input', () => {
    const err = $('mt-exit-err');
    if (err) err.hidden = true;
    if (exitWaLink) exitWaLink.href = buildExitWaHref();
  });
  exitWaLink?.addEventListener('click', (e) => {
    const phone = exitPhoneInput?.value.trim() || '';
    const err = $('mt-exit-err');
    if (phone.length < 6) {
      e.preventDefault();
      if (err) { err.textContent = 'Please enter a number so we can reply to you.'; err.hidden = false; }
      return;
    }
    if (err) err.hidden = true;
  });

  // ——— QX : initial state after full rehydration (everything defined here) ———
  // Range derived from a restored exact amount (fix "redundant range").
  syncBillRangeFromExact();
  // Journey restored directly at the estimate step (WJ61): recompute the
  // document immediately — otherwise dashes until the first interaction.
  if (step === 2) computeEstimate();

</script>
