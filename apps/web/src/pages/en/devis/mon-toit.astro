              placeholder="you@example.com" class={`${inputClass} mt-1`} />
          </label>

          <!-- WJ51 — explicit contact preference (replaces the single "I prefer
               WhatsApp" checkbox): a named choice, never a box checked by default
               without the visitor seeing it. Forwarded as `contactPreference`
               (optional) + derives `whatsappOptIn` to keep the webhook contract
               unchanged. -->
          <fieldset class="mt-1">
            <legend class="text-sm text-lune-soft">How would you prefer we contact you back?</legend>
            <div class="mt-2 grid grid-cols-1 gap-2 sm:grid-cols-2">
              <label class="mt-contact-pref cine-card flex cursor-pointer items-center gap-2 border border-white/15 p-3 text-sm text-white transition-colors has-[:checked]:border-ok-600">
                <input id="mt-contact-whatsapp" name="contactPreference" type="radio" value="whatsapp_only" checked
                  class="h-4 w-4 flex-none accent-ok-600" />
                <span>WhatsApp only</span>
              </label>
              <label class="mt-contact-pref cine-card flex cursor-pointer items-center gap-2 border border-white/15 p-3 text-sm text-white transition-colors has-[:checked]:border-brass-400">
                <input id="mt-contact-phone" name="contactPreference" type="radio" value="phone_ok"
                  class="h-4 w-4 flex-none accent-brass-400" />
                <span>An advisor may call me</span>
              </label>
            </div>
            <!-- WJ105 — concrete callback SLA, shown ONLY when "An advisor may
                 call me" is selected. The preferred callback window reuses the
                 W353 slot control below — never a second, duplicate picker. -->
            <p id="mt-callback-sla" hidden class="mt-2 flex items-center gap-1.5 text-xs text-brass-300">
              An advisor calls you back within ~1 business hour. Pick a preferred window below too.
            </p>
          </fieldset>

          <!-- W353/WJ105 — "Book a technical visit slot" v1: a STATIC, OPTIONAL
