            <p id="mt-panels3d-hint" hidden class="mt-2 text-xs text-lune-faint">
              Drag to rotate · pinch or scroll to zoom.
            </p>
          </div>

        <!-- Contact form (the gate comes AFTER the estimate). -->
        <form id="mt-form" novalidate class="cine-card mt-5 space-y-4 p-5 sm:p-6">
          <!-- W317 — honeypot anti-bot: hidden off-screen (never
               display:none — more robust against bots that skip invisible
               fields), tabindex -1 + autocomplete off so it never interferes
               with a real keyboard user. Rejected server-side (lib/lead.ts
               isHoneypotTripped) — the webhook contract is unchanged, this
               field is never forwarded to the CRM. -->
          <div aria-hidden="true" style="position:absolute; width:1px; height:1px; overflow:hidden; clip-path:inset(50%); white-space:nowrap;">
            <label>Do not fill<input id="mt-hp" name="website_url" type="text" tabindex="-1" autocomplete="off" /></label>
          </div>

          <p class="tech-label rule-brass text-brass-300">To receive your study</p>

          <div class="grid gap-4 sm:grid-cols-2">
            <label class="block text-sm text-lune-soft">
              <span>Full name</span>
              <input id="mt-name" name="fullName" type="text" autocomplete="name" required aria-required="true"
                aria-describedby="mt-name-err" class={`${inputClass} mt-1`} />
              <span id="mt-name-err" hidden role="alert" class="mt-1 block text-xs text-alert-300"></span>
            </label>
            <label class="block text-sm text-lune-soft">
              <span>Phone / WhatsApp</span>
              <input id="mt-phone" name="phone" type="tel" inputmode="tel" autocomplete="tel" required aria-required="true"
                aria-describedby="mt-phone-err" placeholder="06 XX XX XX XX" class={`${inputClass} mt-1`} />
              <span id="mt-phone-err" hidden role="alert" class="mt-1 block text-xs text-alert-300"></span>
            </label>
          </div>

          <label class="block text-sm text-lune-soft">
            <span>Address / city</span>
            <input id="mt-city" name="city" type="text" autocomplete="address-level2" required aria-required="true"
              aria-describedby="mt-city-err" placeholder="Read from the map — editable if needed" class={`${inputClass} mt-1`} />
            <span id="mt-city-err" hidden role="alert" class="mt-1 block text-xs text-alert-300"></span>
          </label>

          <!-- WJ3 — e-mail (optional) + WhatsApp opt-in -->
          <label class="block text-sm text-lune-soft">
            <span>E-mail (optional)</span>
