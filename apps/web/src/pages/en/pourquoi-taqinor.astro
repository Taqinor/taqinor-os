---
/**
 * EN — Why Taqinor (W67). Faithful translation of /pourquoi-taqinor ; no new
 * figure or claim (43.48 kWc, 25 years, 0 MAD, 11 kW, 5 MW, 10–25 years,
 * 9 June 2026 kept exact). Internal links via localizeNavHref. FR untouched.
 */
import Layout from '../../layouts/Layout.astro';
import V2Enhance from '../../components/V2Enhance.astro';
import Article33Ribbon from '../../components/Article33Ribbon.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CtaBand from '../../components/CtaBand.astro';
import StickyCta from '../../components/StickyCta.astro';
import { getLocaleFromPath } from '../../i18n/utils';
import { localizeNavHref } from '../../i18n/pages';

const locale = getLocaleFromPath(Astro.url.pathname);
const L = (href: string) => localizeNavHref(href, locale);
const contactSim = L('/contact') + '#simulateur';

const piliers = [
  {
    k: '01',
    title: 'We start from your bill, not a catalogue',
    body: 'The power is deduced from your real consumption and your roof — usable area, orientation, shading. Until that calculation has justified a product, we don\'t install it. The assessment and the study are 0 MAD; the founder signs them off (see About).',
    href: '/à-propos',
    link: 'The founder & the method',
  },
  {
    k: '02',
    title: 'Our production figures come straight from the meter',
    body: 'Every installation is connected to Deye Cloud: real-time production, automatic alerts, client access included. When we quote a production figure, it is a reading — not a brochure projection.',
    href: '/realisations',
    link: 'See our projects',
  },
  {
    k: '03',
    title: 'The Law 82-21 file, prepared and filed',
    body: 'Declaration (under 11 kW in low voltage), connection agreement or authorisation: we read your case, identify the regime and file the dossier — regularisation of existing installations via Article 33 included. The law has applied since 9 June 2026.',
    href: '/loi-82-21',
    link: 'Identify my regime',
  },
  {
    k: '04',
    title: 'A short list of tier-1 brands',
    body: 'Canadian Solar, JA Solar, Deye, Huawei, Dyness — sourced from official distributors in Morocco, warranties enforceable locally. Five names, no anonymous hardware: the warranty covers from 10 to 25 years depending on the component.',
    href: '/équipement',
    link: 'See the equipment',
  },
];
---

<Layout
  title="Why Taqinor — what sets us apart, point by point | Taqinor"
  description="Four concrete differences: sizing deduced from your bill, production read on Deye Cloud, the Law 82-21 file prepared and filed, and a short list of tier-1 brands warranted from 10 to 25 years. Real installations, visitable on request."
  ogSlug="accueil"
>
  <div class="v2">
    <V2Enhance />
    <Article33Ribbon />

    <Breadcrumb items={[{ label: 'Home', href: L('/') }, { label: 'Why Taqinor' }]} />

    <section class="px-4 pb-10 pt-16 text-white sm:pt-20">
      <div class="mx-auto max-w-3xl">
        <p class="tech-label v2-kicker rule-brass cine-in text-lune">Why us</p>
        <h1 class="display v2-page-title cine-in mt-5 [animation-delay:120ms]">What sets us apart, point by point</h1>
        <p class="v2-lead cine-in mt-6 max-w-xl text-white/85 [animation-delay:240ms]">
          Many installers say the same thing. Here are four differences you can verify yourself: where
          the proposed power comes from, where our production figures come from, who handles your
          regulatory file, and what is really on the roof. The person behind the method is on the
          <a href={L('/à-propos')} class="border-b border-white/40 pb-0.5 font-semibold text-white transition-colors hover:border-white">About</a> page.
        </p>
      </div>
    </section>

    <!-- The pillars -->
    <section class="px-4 pb-20 sm:pb-24">
      <div class="mx-auto grid max-w-6xl gap-6 md:grid-cols-2" data-stagger>
        {piliers.map((p, i) => (
          <div class="v2-rise cine-card flex flex-col p-7" style={`--v2-i:${i}`}>
            <p class="fig lum text-3xl">{p.k}</p>
            <h2 class="display mt-2 text-2xl text-white">{p.title}</h2>
            <p class="mt-3 flex-1 text-sm leading-relaxed text-lune-soft">{p.body}</p>
            <a href={L(p.href)} class="mt-5 inline-block border-b-2 border-white/30 pb-0.5 text-sm font-bold text-white transition-colors hover:border-white">{p.link} →</a>
          </div>
        ))}
      </div>
    </section>

    <!-- Proof rather than promises -->
    <section class="border-y border-white/10 px-4 py-16 sm:py-20">
      <div class="mx-auto grid max-w-6xl gap-10 lg:grid-cols-[1.1fr_1fr] lg:items-center">
        <div class="v2-rise">
          <p class="tech-label v2-kicker rule-brass text-lune">Go and see them</p>
          <h2 class="display v2-section-title mt-5 text-white">Real installations, visitable on request</h2>
          <p class="v2-lead mt-5 text-lune-soft">
            Casablanca, El Jadida, Nouaceur: these installations are already running, and their
            production scrolls by on Deye Cloud. To the question "does it really work?", we answer
            with an address, not a sales pitch. Ask to visit.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href={L('/realisations')} class="inline-block bg-brass-400 px-7 py-3.5 text-base font-bold text-azur-950 transition-colors hover:bg-brass-300">See our projects</a>
            <a href={L('/à-propos')} class="inline-block border border-white/40 px-7 py-3.5 text-base font-bold text-white transition-colors hover:border-white hover:bg-white/10">The founder &amp; the method →</a>
          </div>
        </div>
        <dl class="grid grid-cols-2 gap-x-6 gap-y-10 border-s-2 border-brass-400/60 ps-6 sm:ps-10" data-stagger>
          <div class="v2-rise" style="--v2-i:0">
            <dd class="fig lum whitespace-nowrap text-3xl sm:text-5xl" dir="ltr" data-tally>43,48 kWc</dd>
            <dt class="tech-label mt-2 text-lune-faint">Installed — Casablanca, El Jadida, Nouaceur</dt>
          </div>
          <div class="v2-rise" style="--v2-i:1">
            <dd class="fig lum whitespace-nowrap text-3xl sm:text-5xl" dir="ltr" data-tally>25 yrs</dd>
            <dt class="tech-label mt-2 text-lune-faint">Performance warranty</dt>
          </div>
          <div class="v2-rise" style="--v2-i:2">
            <dd class="fig lum whitespace-nowrap text-3xl sm:text-5xl" dir="ltr" data-tally>0 MAD</dd>
            <dt class="tech-label mt-2 text-lune-faint">The study and the assessment</dt>
          </div>
          <div class="v2-rise" style="--v2-i:3">
            <dd class="font-display text-xl font-bold text-white">Deye Cloud</dd>
            <dt class="tech-label mt-2 text-lune-faint">Measured production, client access included</dt>
          </div>
        </dl>
      </div>
    </section>

    <CtaBand title="Judge us on the calculation: the study is free." href={contactSim} />

    <StickyCta />
  </div>
</Layout>
