---
/**
 * EN — Why Taqinor (W67). Faithful translation of /pourquoi-taqinor ; no new
 * figure or claim (43.48 kWc, 30 years, 0 MAD, 11 kW, 5 MW, 10–30 years,
 * 9 June 2026 kept exact). Internal links via localizeNavHref. FR untouched.
 */
import Layout from '../../layouts/Layout.astro';
import V2Enhance from '../../components/V2Enhance.astro';
import Article33Ribbon from '../../components/Article33Ribbon.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CtaBand from '../../components/CtaBand.astro';
import StickyCta from '../../components/StickyCta.astro';
import RelatedLinks from '../../components/RelatedLinks.astro';
import { getLocaleFromPath } from '../../i18n/utils';
import { localizeNavHref } from '../../i18n/pages';
import { PANEL_PERFORMANCE_WARRANTY_YEARS } from '../../lib/warranty';

const locale = getLocaleFromPath(Astro.url.pathname);
const L = (href: string) => localizeNavHref(href, locale);
const devisHref = L('/devis/mon-toit');

// WB4 (2026-07-04) — derived instead of a hand-typed literal, mirroring FR.
// The aggregate installed-kWc total (sum across projects) is no longer shown
// here (RULE B) — per-project specs stay on /realisations.
const panelWarrantyLabel = `${PANEL_PERFORMANCE_WARRANTY_YEARS} years`;

const piliers = [
  {
    k: '01',
    title: 'We start from your bill, not a catalogue',
    body: 'The power is deduced from your real consumption and your roof — usable area, orientation, shading. Until that calculation has justified a product, we don\'t install it. The assessment and the study are 0 MAD; the founder signs them off (see About).',
    contrast: 'Most solar quotes in Morocco start from a standard kit (3, 5 or 6 kWc) before ever seeing your bill — ours starts from your bill.',
    href: '/à-propos',
    link: 'The founder & the method',
  },
  {
    k: '02',
    title: 'Our production figures come straight from the meter',
    body: 'Every installation has real-time production monitoring: automatic alerts, client access included — a figure tracked on our projects, never a brochure projection.',
    contrast: 'Many installers quote the promised savings from a theoretical simulation that is never checked against a real meter — ours is, continuously.',
    href: '/realisations',
    link: 'See our projects',
  },
  {
    k: '03',
    title: 'The Law 82-21 file, prepared and filed',
    body: 'Declaration (under 11 kW in low voltage), connection agreement or authorisation: we read your case, identify the regime and file the dossier — regularisation of existing installations via Article 33 included. The law has applied since 9 June 2026.',
    contrast: 'The regulatory file is often left to the client once the install is finished — ours is filed before the job is considered done.',
    href: '/loi-82-21',
    link: 'Identify my regime',
  },
  {
    k: '04',
    title: 'A short list of tier-1 brands',
    body: 'Canadian Solar, JA Solar, Deye, Huawei, Dyness — sourced from official distributors in Morocco, warranties enforceable locally. Five names, no anonymous hardware: the warranty covers from 10 to 30 years depending on the component.',
    contrast: 'A panel imported with no manufacturer datasheet or official distributor can\'t prove its warranty the day it needs to apply — ours can, brand by brand.',
    href: '/équipement',
    link: 'See the equipment',
  },
];
---

<Layout
  title="Why Taqinor — what sets us apart, point by point | Taqinor"
  description="Four concrete differences: sizing deduced from your bill, real-time production monitoring, the Law 82-21 file prepared and filed, and a short list of tier-1 brands warranted from 10 to 30 years. Real installations, visitable on request."
  ogSlug="accueil"
>
  <div class="v2">
    <V2Enhance />
    <Article33Ribbon />

    <Breadcrumb items={[{ label: 'Home', href: L('/') }, { label: 'Why Taqinor' }]} />

    <section class="px-4 pb-10 pt-16 text-white sm:pt-20">
      <div class="mx-auto max-w-3xl">
        <p class="tech-label v2-kicker rule-brass cine-in text-lune">Why us</p>
        <h1 class="display v2-page-title cine-in mt-5 [animation-delay:120ms]">What sets us apart, point by point</h1>
        <p class="v2-lead cine-in mt-6 max-w-xl text-white/85 [animation-delay:240ms]">
          Many installers say the same thing. Here are four differences you can verify yourself: where
          the proposed power comes from, where our production figures come from, who handles your
          regulatory file, and what is really on the roof. The person behind the method is on the
          <a href={L('/à-propos')} class="border-b border-white/40 pb-0.5 font-semibold text-white transition-colors hover:border-white">About</a> page.
        </p>
      </div>
    </section>

    <!-- The pillars -->
    <section class="px-4 pb-20 sm:pb-24">
      <div class="mx-auto grid max-w-6xl gap-6 md:grid-cols-2" data-stagger>
        {piliers.map((p, i) => (
          <div class="v2-rise cine-card flex flex-col p-7" style={`--v2-i:${i}`}>
            <p class="fig lum text-3xl">{p.k}</p>
            <h2 class="display mt-2 text-2xl text-white">{p.title}</h2>
            <p class="mt-3 flex-1 text-sm leading-relaxed text-lune-soft">{p.body}</p>
            <p class="mt-3 border-l-2 border-brass-400/50 pl-3 text-sm leading-relaxed text-lune-faint">{p.contrast}</p>
            <a href={L(p.href)} class="mt-5 inline-block border-b-2 border-white/30 pb-0.5 text-sm font-bold text-white transition-colors hover:border-white">{p.link} →</a>
          </div>
        ))}
      </div>
    </section>

    <!-- W277 — Why traceability matters -->
    <section class="px-4 pb-20 sm:pb-24">
      <div class="mx-auto max-w-3xl">
        <p class="tech-label v2-kicker rule-brass text-brass-300">Why traceability matters</p>
        <h2 class="display v2-section-title mt-5 text-white">The fear isn't irrational — the answer is verifiable</h2>
        <p class="v2-lead mt-5 text-lune-soft">
          In 2025, the Moroccan press reported on a case where batches of imported solar panels
          turned out to underperform: real-world output noticeably below what the technical
          datasheets claimed, on volumes destined for public tenders. We are not citing this case
          against any particular installer — none is named in it — but because it asks exactly the
          right question before you sign: where does this panel come from, and who can prove it?
        </p>
        <p class="mt-4 max-w-2xl text-sm leading-relaxed text-lune-soft">
          Our answer fits on one page: five named tier-1 brands, each with its
          <a href={L('/équipement')} class="text-brass-300 underline underline-offset-2 hover:text-white">official manufacturer datasheet</a>,
          its contractual warranty and — once installed — verifiable production in real time.
        </p>
      </div>
    </section>

    <!-- Proof rather than promises -->
    <section class="border-y border-white/10 px-4 py-16 sm:py-20">
      <div class="mx-auto grid max-w-6xl gap-10 lg:grid-cols-[1.1fr_1fr] lg:items-center">
        <div class="v2-rise">
          <p class="tech-label v2-kicker rule-brass text-lune">Go and see them</p>
          <h2 class="display v2-section-title mt-5 text-white">Real installations, visitable on request</h2>
          <p class="v2-lead mt-5 text-lune-soft">
            Casablanca, El Jadida, Nouaceur: these installations are already running, and their
            production is tracked in real time. To the question "does it really work?", we answer
            with an address, not a sales pitch. Ask to visit.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href={L('/realisations')} class="inline-block bg-brass-400 px-7 py-3.5 text-base font-bold text-azur-950 transition-colors hover:bg-brass-300">See our projects</a>
            <a href={L('/à-propos')} class="inline-block border border-white/40 px-7 py-3.5 text-base font-bold text-white transition-colors hover:border-white hover:bg-white/10">The founder &amp; the method →</a>
          </div>
        </div>
        <dl class="grid grid-cols-2 gap-x-6 gap-y-10 border-s-2 border-brass-400/60 ps-6 sm:ps-10" data-stagger>
          <div class="v2-rise" style="--v2-i:0">
            <dd class="font-display text-xl font-bold text-white">Casablanca, El Jadida, Nouaceur</dd>
            <dt class="tech-label mt-2 text-lune-faint">Real projects, visitable on request</dt>
          </div>
          <div class="v2-rise" style="--v2-i:1">
            <dd class="fig lum whitespace-nowrap text-3xl sm:text-5xl" dir="ltr" data-tally>{panelWarrantyLabel}</dd>
            <dt class="tech-label mt-2 text-lune-faint">Performance warranty</dt>
          </div>
          <div class="v2-rise" style="--v2-i:2">
            <dd class="fig lum whitespace-nowrap text-3xl sm:text-5xl" dir="ltr" data-tally>0 MAD</dd>
            <dt class="tech-label mt-2 text-lune-faint">The study and the assessment</dt>
          </div>
          <div class="v2-rise" style="--v2-i:3">
            <dd class="font-display text-xl font-bold text-white">Real-time monitoring</dd>
            <dt class="tech-label mt-2 text-lune-faint">Tracked production, client access included</dt>
          </div>
        </dl>
      </div>
    </section>

    {/* WB17 (2026-07-04) — contextual links into the two ongoing measured-proof
        pages, weakly discoverable (absent from header/footer). */}
    <section class="section-tight px-4 text-white">
      <div class="mx-auto max-w-6xl">
        <p class="tech-label v2-kicker rule-brass text-lune">To verify these figures</p>
        <RelatedLinks links={[
          { href: L('/production-mesuree'), label: 'Our tracked production, ongoing' },
          { href: L('/impact-taqinor'), label: 'Taqinor Impact (kWc, kWh, CO2 avoided)' },
        ]} />
      </div>
    </section>

    <CtaBand title="Judge us on the calculation: the study is free." href={devisHref} />

    <StickyCta />
  </div>
</Layout>
