---
/**
 * EN — Privacy policy (W67). Faithful translation of
 * /politique-de-confidentialite ; the data-flow facts (what the form collects,
 * fbclid/UTM, law 09-08) are unchanged. FR untouched.
 *
 * W318 — the real field set collected by the journey (/devis/mon-toit
 * assessment + proposal e-signature) is wider than the 5 fields this page
 * used to describe: the map (GPS pin + optional roof outline), the full
 * address, email, the full energy profile (summer/winter bills, kWh,
 * bracket), financing intent, and — at proposal e-signature — the drawn
 * signature image. Plus a new GDPR section for EU-resident clients (the MRE
 * segment). Every line below matches a field the code actually sends
 * (src/pages/devis/mon-toit.astro, src/pages/proposition/[token].astro).
 */
import Layout from '../../layouts/Layout.astro';
import { NAP } from '../../lib/nap';
import { getLocaleFromPath } from '../../i18n/utils';
import { localizeNavHref } from '../../i18n/pages';

const legalHref = localizeNavHref('/mentions-legales', getLocaleFromPath(Astro.url.pathname));

const sections = [
  {
    t: 'What we collect',
    p: 'When you complete the solar assessment (/devis/mon-toit), we collect: your full name, your phone number, your email (optional), your city or town and your full address, the GPS pin you place on your roof and, if you draw it, your roof outline (both optional — you can continue with the address alone), your roof type, your energy profile (bill bracket, summer/winter bill amounts where given, consumption in kWh), and — if you indicate it — your intended financing method (cash, credit, other). You also choose whether you prefer to be contacted by WhatsApp. If your assessment leads to a proposal you sign online, the image of your hand-drawn signature (drawn on screen) as well as the date and time of signature are also recorded with your consent.',
  },
  {
    t: 'Why we collect it',
    p: 'To prepare your preliminary solar study and send it to you, then to get back to you — by WhatsApp and email — only if you ticked the consent box. The GPS pin and roof outline are used only for sizing (orientation, usable area, shading). Your intended financing method is used to tailor our advice, never shared with a third party without your consent. No other use.',
  },
  {
    t: 'Advertising measurement (fbclid and UTM)',
    p: 'If you reach the site from an ad, the link may contain technical parameters (fbclid, utm_source, utm_medium, utm_campaign, utm_content, utm_term). We keep them with your request to measure how effective our campaigns are — to know which ad led to which request. They contain neither your name nor your number and serve only this measurement.',
  },
  {
    t: 'Journey-usage measurement (steps reached/abandoned)',
    p: 'While you go through the solar assessment, an anonymous technical signal tells us which step of the form you reached and, if applicable, at which step you left without finishing. This signal contains no name, phone number, email, or any data that identifies you — it is used only to measure and improve the usability of the journey (knowing where visitors drop off so we can simplify those steps).',
  },
  {
    t: 'Who has access, where it goes',
    p: 'Your data is accessible to the Taqinor team only. It is never sold, rented or transferred to third parties. The site is hosted on Cloudflare infrastructure.',
  },
  {
    t: 'Retention period',
    p: 'We keep your request for the time of its commercial processing, then for as long as a customer relationship exists. You can request its deletion at any time (see below).',
  },
  {
    t: 'Your rights',
    p: `In accordance with Law 09-08 on the protection of individuals with regard to the processing of personal data, you have a right of access, rectification and deletion of your data. To exercise it, write to ${NAP.email} — we reply within reasonable timeframes.`,
  },
  {
    t: 'Consent',
    p: 'The assessment checkbox constitutes your explicit consent to be contacted again. Its date and time are recorded with your request. Withdrawing your consent is as simple as granting it: a single message is enough.',
  },
  {
    t: 'CNDP declaration',
    p: 'This personal-data processing is the subject of a CNDP declaration in progress with the Commission Nationale de contrôle de la protection des Données à caractère Personnel (Morocco’s data-protection authority). The declaration number will be added here once issued.',
  },
];

// W318 — GDPR addendum for EU-resident clients (including our MRE segment —
// Moroccans living abroad, some of whom reside in the EU/EEA). Sits alongside
// the law 09-08 section above, not instead of it.
const gdprSection = {
  t: 'EU residents (GDPR)',
  p: `If you reside in the European Union or the European Economic Area — including our MRE clients (Moroccans living abroad) — the General Data Protection Regulation (GDPR) applies in addition to Moroccan Law 09-08 above. Legal basis: your explicit consent (checkbox ticked at assessment or at signature) and, once a contract is under way, performance of that contract. You have the same rights as a Morocco-resident client — access, rectification, deletion — plus the right to restrict processing and the right to lodge a complaint with the supervisory authority of your country of residence. To exercise any of these rights, write to ${NAP.email} stating your request; we reply within a reasonable timeframe and in any case within one month.`,
};
---

<Layout
  title="Privacy policy | Taqinor"
  description="What the Taqinor solar assessment collects, why, who accesses it, and your rights (Law 09-08) — in plain language."
  ogSlug="accueil"
>
  <section class="px-4 py-14 text-white">
    <div class="mx-auto max-w-3xl">
      <p class="tech-label rule-brass cine-in text-brass-300">Law 09-08 · plain language</p>
      <h1 class="display cine-in mt-4 text-4xl [animation-delay:120ms]">Privacy policy</h1>
      <p class="cine-in mt-4 max-w-xl leading-relaxed text-white/85 [animation-delay:240ms]">
        What we collect, why, and what you can demand — no jargon.
      </p>
    </div>
  </section>

  <!-- The document, in full light -->
  <div class="seam-lumiere" aria-hidden="true"></div>
  <section class="bg-blanc-azur px-4 pb-16 pt-6 text-encre"
    ><div class="mx-auto max-w-3xl">
    {sections.map((s, i) => (
      <div class="border-b border-azur-900/15 py-7 first:pt-0">
        <h2 class="display flex items-baseline gap-4 text-xl">
          <span class="fig text-lg text-azur-600">{String(i + 1).padStart(2, '0')}</span>
          {s.t}
        </h2>
        <p class="mt-3 ps-10 text-sm leading-relaxed text-encre-soft">{s.p}</p>
      </div>
    ))}
    <!-- W318 — GDPR addendum (MRE / EU-resident segment) -->
    <div class="border-b border-azur-900/15 py-7">
      <h2 class="display flex items-baseline gap-4 text-xl">
        <span class="fig text-lg text-azur-600">{String(sections.length + 1).padStart(2, '0')}</span>
        {gdprSection.t}
      </h2>
      <p class="mt-3 ps-10 text-sm leading-relaxed text-encre-soft">{gdprSection.p}</p>
    </div>
    <p class="mt-7 text-xs text-encre-faint">
      Last updated: July 2026 — TAQINOR Solutions SARLAU, RC 691213 (Casablanca).
      See also the <a href={legalHref} class="underline decoration-azur-600 underline-offset-2">legal notice</a>.
    </p>
    </div>
  </section>
</Layout>
