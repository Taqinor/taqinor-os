---
/**
 * EN — Privacy policy (W67). Faithful translation of
 * /politique-de-confidentialite ; the data-flow facts (what the form collects,
 * fbclid/UTM, law 09-08) are unchanged. FR untouched.
 */
import Layout from '../../layouts/Layout.astro';
import { NAP } from '../../lib/nap';
import { getLocaleFromPath } from '../../i18n/utils';
import { localizeNavHref } from '../../i18n/pages';

const legalHref = localizeNavHref('/mentions-legales', getLocaleFromPath(Astro.url.pathname));

const sections = [
  {
    t: 'What we collect',
    p: 'When you complete the solar assessment, we collect: your full name, your phone number, your city or town, your roof type and your electricity bill bracket. You also choose whether you prefer to be contacted by WhatsApp.',
  },
  {
    t: 'Why we collect it',
    p: 'To prepare your preliminary solar study and send it to you, then to get back to you — by WhatsApp and email — only if you ticked the consent box. No other use.',
  },
  {
    t: 'Advertising measurement (fbclid and UTM)',
    p: 'If you reach the site from an ad, the link may contain technical parameters (fbclid, utm_source, utm_medium, utm_campaign, utm_content, utm_term). We keep them with your request to measure how effective our campaigns are — to know which ad led to which request. They contain neither your name nor your number and serve only this measurement.',
  },
  {
    t: 'Who has access, where it goes',
    p: 'Your data is accessible to the Taqinor team only. It is never sold, rented or transferred to third parties. The site is hosted on Cloudflare infrastructure.',
  },
  {
    t: 'Retention period',
    p: 'We keep your request for the time of its commercial processing, then for as long as a customer relationship exists. You can request its deletion at any time (see below).',
  },
  {
    t: 'Your rights',
    p: `In accordance with Law 09-08 on the protection of individuals with regard to the processing of personal data, you have a right of access, rectification and deletion of your data. To exercise it, write to ${NAP.email} — we reply within reasonable timeframes.`,
  },
  {
    t: 'Consent',
    p: 'The assessment checkbox constitutes your explicit consent to be contacted again. Its date and time are recorded with your request. Withdrawing your consent is as simple as granting it: a single message is enough.',
  },
];
---

<Layout
  title="Privacy policy | Taqinor"
  description="What the Taqinor solar assessment collects, why, who accesses it, and your rights (Law 09-08) — in plain language."
  ogSlug="accueil"
>
  <section class="px-4 py-14 text-white">
    <div class="mx-auto max-w-3xl">
      <p class="tech-label rule-brass cine-in text-brass-300">Law 09-08 · plain language</p>
      <h1 class="display cine-in mt-4 text-4xl [animation-delay:120ms]">Privacy policy</h1>
      <p class="cine-in mt-4 max-w-xl leading-relaxed text-white/85 [animation-delay:240ms]">
        What we collect, why, and what you can demand — no jargon.
      </p>
    </div>
  </section>

  <!-- The document, in full light -->
  <div class="seam-lumiere" aria-hidden="true"></div>
  <section class="bg-blanc-azur px-4 pb-16 pt-6 text-encre"
    ><div class="mx-auto max-w-3xl">
    {sections.map((s, i) => (
      <div class="border-b border-azur-900/15 py-7 first:pt-0">
        <h2 class="display flex items-baseline gap-4 text-xl">
          <span class="fig text-lg text-azur-600">{String(i + 1).padStart(2, '0')}</span>
          {s.t}
        </h2>
        <p class="mt-3 ps-10 text-sm leading-relaxed text-encre-soft">{s.p}</p>
      </div>
    ))}
    <p class="mt-7 text-xs text-encre-faint">
      Last updated: June 2026 — TAQINOR Solutions SARLAU, RC 691213 (Casablanca).
      See also the <a href={legalHref} class="underline decoration-azur-600 underline-offset-2">legal notice</a>.
    </p>
    </div>
  </section>
</Layout>
