---
/**
 * EN — Financing & returns (W67). Faithful translation of /financement ; EVERY
 * figure (≈80 000 MAD, 3–7 yrs, 25 yrs, 60–90 %, 0 MAD, 4–6 yrs, 3–5 yrs,
 * 1 000 MAD, 84.8 %, ONEE) kept EXACT, and the hard honesty constraints
 * preserved: Taqinor is NOT a lender, no residential subsidy, no residential VAT
 * exemption, no bank/partner/rate named. Internal links via localizeNavHref.
 * FR untouched.
 */
import Layout from '../../layouts/Layout.astro';
import V2Enhance from '../../components/V2Enhance.astro';
import Article33Ribbon from '../../components/Article33Ribbon.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CtaBand from '../../components/CtaBand.astro';
import StickyCta from '../../components/StickyCta.astro';
import { getLocaleFromPath } from '../../i18n/utils';
import { localizeNavHref } from '../../i18n/pages';

const locale = getLocaleFromPath(Astro.url.pathname);
const L = (href: string) => localizeNavHref(href, locale);
const contactSim = L('/contact') + '#simulateur';

const chiffres = [
  { v: '3–7 ans', label: 'Typical return on investment' },
  { v: '25 ans', label: 'Panel performance warranty' },
  { v: '60–90 %', label: 'Of the bill covered' },
  { v: '0 MAD', label: 'The study and the assessment' },
];

const moyens = [
  {
    k: '01',
    title: 'Cash',
    body: 'Most of our clients pay for the installation in one go. From commissioning, it pays for itself: every kWh produced is a kWh you no longer buy from the grid, valued at the ONEE utility tariff.',
  },
  {
    k: '02',
    title: 'Classic bank consumer loan',
    body: 'Others go through a classic consumer loan, taken out directly with their bank. The arrangement is between you and your institution — we don\'t intervene and take no commission on it.',
  },
  {
    k: '03',
    title: 'Green financing (businesses)',
    body: 'For businesses, green financing lines for renewable energy exist in Morocco. The agreement and the terms are up to your bank and your file; we sell no loan or banking product, and guarantee none.',
  },
];
---

<Layout
  title="Solar returns & financing in Morocco: 3–7 year ROI | Taqinor"
  description="What a solar installation really earns in Morocco: roughly paid off in 3 to 7 years through the electricity you stop buying (ONEE utility tariff), then 25 years of guaranteed performance and 60 to 90 % of the bill covered. How to finance it plainly — Taqinor installs and warrants, but is not a lender."
  ogSlug="accueil"
>
  <div class="v2">
    <V2Enhance />
    <Article33Ribbon />

    <Breadcrumb items={[{ label: 'Home', href: L('/') }, { label: 'Financing & returns' }]} />

    <!-- ACT I — dark hero: the investment that pays itself back -->
    <section class="px-4 pb-10 pt-16 text-white sm:pt-20">
      <div class="mx-auto max-w-3xl">
        <p class="tech-label v2-kicker rule-brass cine-in text-lune">Returns</p>
        <h1 class="display v2-page-title cine-in mt-5 [animation-delay:120ms]">The investment that pays itself back, then pays for you</h1>
        <p class="v2-lead cine-in mt-6 max-w-xl text-white/85 [animation-delay:240ms]">
          An installation is on the order of 80 000 MAD for a villa — a real investment, not a gadget.
          Well sized, it <strong class="text-white">pays itself back in roughly 3 to 7 years</strong>
          thanks to the electricity you stop buying from the grid, valued at the ONEE utility tariff.
          Beyond that point, a good fifteen years remain of the 25 guaranteed where your power is
          <strong class="text-white">nearly free</strong>.
        </p>
      </div>
    </section>

    <!-- The investment in figures -->
    <section class="px-4 pb-20 sm:pb-24">
      <div class="mx-auto max-w-6xl">
        <p class="tech-label v2-kicker rule-brass text-lune">The investment in figures</p>
        <h2 class="display v2-section-title mt-5 text-white">Orders of magnitude — never a quote</h2>
        <p class="v2-lead mt-4 max-w-2xl text-lune-soft">
          The ranges below are the same as on our Residential and Business pages — none is inflated
          for this page. The exact figure of <em>your</em> return is computed on your real bill; and if
          solar is not the right investment for your profile, we will tell you plainly.
        </p>
        <dl class="mt-10 grid grid-cols-2 gap-x-6 gap-y-10 border-s-2 border-brass-400/60 ps-6 sm:grid-cols-4 sm:ps-10" data-stagger>
          {chiffres.map((c, i) => (
            <div class="v2-rise" style={`--v2-i:${i}`}>
              <dd class="fig lum whitespace-nowrap text-3xl sm:text-4xl" dir="ltr" data-tally>{c.v}</dd>
              <dt class="tech-label mt-2 text-lune-faint">{c.label}</dt>
            </div>
          ))}
        </dl>
        <p class="mt-8 max-w-2xl text-sm leading-relaxed text-lune-soft">
          The heavier the bill, the faster the return. For a typical villa, count on the order of
          <a href={L('/résidentiel')} class="border-b border-white/40 pb-0.5 font-semibold text-white transition-colors hover:border-white">4 to 6 years in residential</a>;
          on a warehouse, the scale effect tightens the return to
          <a href={L('/professionnel')} class="border-b border-white/40 pb-0.5 font-semibold text-white transition-colors hover:border-white">3 to 5 years for a business site</a>.
          Below 1 000 MAD of monthly bill, however, the return most often goes beyond 7 years — and we
          will tell you frankly rather than sell you the useless.
        </p>
      </div>
    </section>

    <!-- How to finance — clear section, total honesty -->
    <div class="v2-seam" aria-hidden="true"></div>
    <section class="bg-blanc-azur px-4 pb-20 pt-10 text-encre sm:pb-24">
      <div class="mx-auto max-w-6xl">
        <p class="tech-label v2-kicker rule-brass text-azur-600">No detours</p>
        <h2 class="display v2-section-title mt-5">How to finance — in full transparency</h2>
        <p class="v2-lead mt-4 max-w-2xl text-encre-soft">
          Let's be clear from the start: we install and warrant solar, we sell no financial product.
          Here, without dressing up, are the three ways our clients actually pay for their
          installation.
        </p>
        <div class="mt-10 grid gap-6 md:grid-cols-3" data-stagger>
          {moyens.map((m, i) => (
            <div class="v2-rise flex flex-col border-t-2 border-azur-900 bg-blanc p-7" style={`--v2-i:${i}`}>
              <p class="fig text-3xl text-azur-600" dir="ltr">{m.k}</p>
              <h3 class="display mt-2 text-xl">{m.title}</h3>
              <p class="mt-3 flex-1 text-sm leading-relaxed text-encre-soft">{m.body}</p>
            </div>
          ))}
        </div>

        <!-- The honest clarifications -->
        <div class="mt-10 max-w-3xl border-s-4 border-azur-600 bg-blanc px-5 py-5 text-sm leading-relaxed text-encre-soft">
          <p class="tech-label text-azur-600">What you should know, in black and white</p>
          <ul class="mt-4 space-y-2.5">
            <li><strong class="text-encre">Taqinor is not a credit body</strong> or a lender: we grant no financing and take no banking commission.</li>
            <li><strong class="text-encre">No special residential subsidy</strong> exists for a private solar installation in Morocco — beware of any such promise.</li>
            <li><strong class="text-encre">No residential VAT exemption</strong>: VAT applies to a complete turnkey installation. We won't promise you otherwise.</li>
            <li>For businesses, <strong class="text-encre">green financing lines</strong> for renewable energy projects exist in Morocco, but it is your bank that decides — we name no institution and guarantee no terms.</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- The study computes YOUR return -->
    <section class="px-4 py-20 sm:py-28">
      <div class="mx-auto grid max-w-6xl gap-10 lg:grid-cols-[1.1fr_1fr] lg:items-center">
        <div class="v2-rise">
          <p class="tech-label v2-kicker rule-brass text-lune">Your return, not an average</p>
          <h2 class="display v2-section-title mt-5 text-white">The study computes the return on your bill</h2>
          <p class="v2-lead mt-5 text-lune-soft">
            Everything above stays an order of magnitude. Your figure — what you save each month, the
            year the installation paid itself back — comes from three data points that belong only to
            you: your bill, your consumption profile, your roof. We run them through the calculation,
            and the result is yours, not a brochure average.
          </p>
          <a href={contactSim} class="mt-8 inline-block bg-brass-400 px-7 py-3.5 text-base font-bold text-azur-950 transition-colors hover:bg-brass-300">Compute my return — study at 0 MAD</a>
        </div>
        <dl class="grid grid-cols-2 gap-x-6 gap-y-10 border-s-2 border-brass-400/60 ps-6 sm:ps-10" data-stagger>
          <div class="v2-rise" style="--v2-i:0">
            <dd class="fig lum whitespace-nowrap text-3xl sm:text-5xl" dir="ltr" data-tally>0 MAD</dd>
            <dt class="tech-label mt-2 text-lune-faint">The study and the assessment</dt>
          </div>
          <div class="v2-rise" style="--v2-i:1">
            <dd class="fig lum whitespace-nowrap text-3xl sm:text-5xl" dir="ltr" data-tally>25 ans</dd>
            <dt class="tech-label mt-2 text-lune-faint">Guaranteed performance (≥ 84.8 %)</dt>
          </div>
          <div class="v2-rise" style="--v2-i:2">
            <dd class="fig lum whitespace-nowrap text-3xl sm:text-5xl" dir="ltr" data-tally>3–7 ans</dd>
            <dt class="tech-label mt-2 text-lune-faint">Typical return on investment</dt>
          </div>
          <div class="v2-rise" style="--v2-i:3">
            <dd class="font-display text-xl font-bold text-white">ONEE tariff</dd>
            <dt class="tech-label mt-2 text-lune-faint">Basis for the avoided-electricity calculation</dt>
          </div>
        </dl>
      </div>
    </section>

    <!-- Contextual links -->
    <section class="border-t border-white/10 px-4 py-16">
      <div class="mx-auto flex max-w-6xl flex-wrap gap-3">
        <a href={L('/résidentiel')} class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">Residential returns →</a>
        <a href={L('/professionnel')} class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">Business returns →</a>
        <a href={L('/garanties')} class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">Our warranties (25 years) →</a>
        <a href={contactSim} class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">Start my assessment →</a>
      </div>
    </section>

    <CtaBand title="How much does your roof earn you? The free assessment figures it out." href={contactSim} />

    <StickyCta />
  </div>
</Layout>
