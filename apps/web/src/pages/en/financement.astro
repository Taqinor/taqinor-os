---
/**
 * EN — Financing & returns (W67). Faithful translation of /financement ; EVERY
 * figure (≈80 000 MAD, 3–7 yrs, 30 yrs, 60–90 %, 0 MAD, 4–6 yrs, 3–5 yrs,
 * 1 000 MAD, 87.4 %, ONEE) kept EXACT, and the hard honesty constraints
 * preserved: Taqinor is NOT a lender, no residential subsidy, no residential VAT
 * exemption, no bank/partner/rate named. Internal links via localizeNavHref.
 * FR untouched.
 *
 * W258 — Named, verified Moroccan mechanisms by segment (WG11): each program
 * cited below was confirmed via a primary source at build time. What could
 * not be verified — a residential green loan packaged by a named bank — is
 * explicitly absent: no bank is named for residential, per the "zero
 * invented partnership" rule.
 */
import Layout from '../../layouts/Layout.astro';
import V2Enhance from '../../components/V2Enhance.astro';
import Article33Ribbon from '../../components/Article33Ribbon.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CtaBand from '../../components/CtaBand.astro';
import StickyCta from '../../components/StickyCta.astro';
import RelatedLinks from '../../components/RelatedLinks.astro';
import { getLocaleFromPath } from '../../i18n/utils';
import { localizeNavHref } from '../../i18n/pages';

const locale = getLocaleFromPath(Astro.url.pathname);
const L = (href: string) => localizeNavHref(href, locale);
const devisHref = L('/devis/mon-toit');

const chiffres = [
  { v: '3–7 years', label: 'Typical return on investment' },
  { v: '30 years', label: 'Panel performance warranty' },
  { v: '50–100 %', label: 'Of the bill covered — depending on batteries and day/night usage' },
  { v: '0 MAD', label: 'The study and the assessment' },
];

const moyens = [
  {
    k: '01',
    title: 'Cash',
    body: 'Most of our clients pay for the installation in one go. From commissioning, it pays for itself: every kWh produced is a kWh you no longer buy from the grid, valued at the ONEE utility tariff.',
  },
  {
    k: '02',
    title: 'Classic bank consumer loan',
    body: 'Others go through a classic consumer loan, taken out directly with their bank. The arrangement is between you and your institution — we don\'t intervene and take no commission on it.',
  },
  {
    k: '03',
    title: 'Green financing (businesses)',
    body: 'For businesses, green financing lines for renewable energy exist in Morocco. The agreement and the terms are up to your bank and your file; we sell no loan or banking product, and guarantee none.',
  },
];

// W258 — named, verified mechanisms by segment. Each entry cites its source;
// nothing is published without one. Residential deliberately stays WITHOUT a
// named bank (not verifiable at build time).
const mecanismes = [
  {
    segment: 'Agriculture',
    items: [
      {
        nom: 'CAM "Saquii Solaire"',
        body: 'A named offer from Crédit Agricole du Maroc dedicated to financing agricultural solar pumping. The exact rate and terms depend on your file — ask directly at your CAM branch.',
        source: 'creditagricole.ma',
      },
      {
        nom: 'FDA — solar pumping subsidy ≈ 30 %',
        body: 'The Agricultural Development Fund subsidises roughly 30 % of the acquisition and installation cost of an agricultural solar pumping kit (panels, pump unit, structure, accessories), paid after invoicing — filed at your regional DPA or ORMVA. Cumulative with the existing drip-irrigation subsidy.',
        source: 'FDA guide (agrimaroc.ma / casainvest.ma)',
      },
    ],
  },
  {
    segment: 'Businesses',
    items: [
      {
        nom: 'Import VAT exemption — CGI art. 123-22°',
        body: 'Investment goods recorded as a fixed asset, imported by a VAT-registered company within 36 months of starting activity, are exempt — subject to the guarantees required by the tax authorities. Full detail below.',
        source: 'Code Général des Impôts, art. 123-22°',
      },
      {
        nom: 'Leasing — Maghrebail "Energy Lease"',
        body: 'A named leasing product explicitly covering photovoltaic installations, with a built-in investment subsidy for renewable-energy projects. Terms and caps are set by Maghrebail — we guarantee no banking terms.',
        source: 'maghrebail.ma',
      },
    ],
  },
  {
    segment: 'Residential',
    items: [
      {
        nom: 'Green bank loans',
        body: 'Some Moroccan banks offer, case by case, so-called "green" credit lines that can cover a residential solar project. We have not been able to verify, as of today, that any named institution packages a dedicated residential-solar offer — so we name no bank here: ask your own bank directly.',
        source: 'not verified — no bank named until confirmed',
      },
    ],
  },
];
---

<Layout
  title="Solar returns & financing in Morocco: 3–7 year ROI | Taqinor"
  description="What a solar installation really earns in Morocco: roughly paid off in 3 to 7 years through the electricity you stop buying (ONEE utility tariff), then 30 years of guaranteed performance and 60 to 90 % of the bill covered. How to finance it plainly — Taqinor installs and warrants, but is not a lender."
  ogSlug="financement"
>
  <div class="v2">
    <V2Enhance />
    <Article33Ribbon />

    <Breadcrumb items={[{ label: 'Home', href: L('/') }, { label: 'Financing & returns' }]} />

    <!-- ACT I — dark hero: the investment that pays itself back -->
    <section class="px-4 pb-10 pt-16 text-white sm:pt-20">
      <div class="mx-auto max-w-3xl">
        <p class="tech-label v2-kicker rule-brass cine-in text-lune">Returns</p>
        <h1 class="display v2-page-title cine-in mt-5 [animation-delay:120ms]">The investment that pays itself back, then pays for you</h1>
        <p class="v2-lead cine-in mt-6 max-w-xl text-white/85 [animation-delay:240ms]">
          An installation is on the order of 80 000 MAD for a villa — a real investment, not a gadget.
          Well sized, it <strong class="text-white">pays itself back in roughly 3 to 7 years</strong>
          thanks to the electricity you stop buying from the grid, valued at the ONEE utility tariff.
          Beyond that point, over twenty years remain of the 30 guaranteed where your power is
          <strong class="text-white">nearly free</strong>.
        </p>
      </div>
    </section>

    <!-- The investment in figures -->
    <section class="px-4 pb-20 sm:pb-24">
      <div class="mx-auto max-w-6xl">
        <p class="tech-label v2-kicker rule-brass text-lune">The investment in figures</p>
        <h2 class="display v2-section-title mt-5 text-white">Orders of magnitude — never a quote</h2>
        <p class="v2-lead mt-4 max-w-2xl text-lune-soft">
          The ranges below are the same as on our Residential and Business pages — none is inflated
          for this page. The exact figure of <em>your</em> return is computed on your real bill; and if
          solar is not the right investment for your profile, we will tell you plainly.
        </p>
        <dl class="mt-10 grid grid-cols-2 gap-x-6 gap-y-10 border-s-2 border-brass-400/60 ps-6 sm:grid-cols-4 sm:ps-10" data-stagger>
          {chiffres.map((c, i) => (
            <div class="v2-rise" style={`--v2-i:${i}`}>
              <dd class="fig lum whitespace-nowrap text-3xl sm:text-4xl" dir="ltr" data-tally>{c.v}</dd>
              <dt class="tech-label mt-2 text-lune-faint">{c.label}</dt>
            </div>
          ))}
        </dl>
        <p class="mt-8 max-w-2xl text-sm leading-relaxed text-lune-soft">
          The heavier the bill, the faster the return. For a typical villa, count on the order of
          <a href={L('/résidentiel')} class="border-b border-white/40 pb-0.5 font-semibold text-white transition-colors hover:border-white">4 to 6 years in residential</a>;
          on a warehouse, the scale effect tightens the return to
          <a href={L('/professionnel')} class="border-b border-white/40 pb-0.5 font-semibold text-white transition-colors hover:border-white">3 to 5 years for a business site</a>.
          Below 1 000 MAD of monthly bill, however, the return most often goes beyond 7 years — and we
          will tell you frankly rather than sell you the useless.
        </p>
      </div>
    </section>

    <!-- W331 — Fully worked numeric walkthrough (bill → kWc → investment →
         saving → payback), reused VERBATIM from the example already published
         on /résidentiel (villa at 2 000 MAD/month): no new figure, just the
         same calculation made visible step by step. -->
    <div class="v2-seam" aria-hidden="true"></div>
    <section class="px-4 pb-20 sm:pb-24">
      <div class="mx-auto max-w-4xl">
        <p class="tech-label v2-kicker rule-brass text-lune">One calculation, start to finish</p>
        <h2 class="display v2-section-title mt-5 text-white">A 2 000 MAD villa bill, walked through step by step</h2>
        <p class="v2-lead mt-4 max-w-2xl text-lune-soft">
          The same example as on our Residential page — not one figure more, just each step of the
          calculation made visible.
        </p>
        <ol class="mt-10 border-t-2 border-brass-400/60" data-stagger>
          <li class="v2-rise flex items-baseline justify-between gap-4 border-b border-white/10 py-5" style="--v2-i:0">
            <span class="text-sm text-lune-soft"><span class="tech-label text-brass-300">1 · Bill</span><br />Your monthly ONEE utility reading</span>
            <span class="fig lum text-xl sm:text-2xl" data-tally>2 000 MAD</span>
          </li>
          <li class="v2-rise flex items-baseline justify-between gap-4 border-b border-white/10 py-5" style="--v2-i:1">
            <span class="text-sm text-lune-soft"><span class="tech-label text-brass-300">2 · Power</span><br />The size that bill calls for</span>
            <span class="fig lum text-xl sm:text-2xl" data-tally>6 kWc</span>
          </li>
          <li class="v2-rise flex items-baseline justify-between gap-4 border-b border-white/10 py-5" style="--v2-i:2">
            <span class="text-sm text-lune-soft"><span class="tech-label text-brass-300">3 · Investment</span><br />Order of magnitude, never a quote</span>
            <span class="fig lum text-xl sm:text-2xl">60 000 – 75 000 MAD</span>
          </li>
          <li class="v2-rise flex items-baseline justify-between gap-4 border-b border-white/10 py-5" style="--v2-i:3">
            <span class="text-sm text-lune-soft"><span class="tech-label text-brass-300">4 · Saving</span><br />Erased every year at the ONEE utility tariff</span>
            <span class="fig lum text-xl sm:text-2xl">12 000 – 16 000 MAD/year</span>
          </li>
          <li class="v2-rise flex items-baseline justify-between gap-4 py-5" style="--v2-i:4">
            <span class="text-sm text-lune-soft"><span class="tech-label text-brass-300">5 · Payback</span><br />Then 19 to 21 years of near-free power</span>
            <span class="fig text-xl text-brass-300 sm:text-2xl" data-tally>4 to 6 years</span>
          </li>
        </ol>
        <p class="mt-6 max-w-2xl text-xs leading-relaxed text-lune-soft">
          Yours will start from your own bill, not this one — <a href={devisHref} class="border-b border-white/40 pb-0.5 font-semibold text-white transition-colors hover:border-white">start your free assessment</a>.
        </p>
      </div>
    </section>

    <!-- How to finance — clear section, total honesty -->
    <div class="v2-seam" aria-hidden="true"></div>
    <section class="bg-blanc-azur px-4 pb-20 pt-10 text-encre sm:pb-24">
      <div class="mx-auto max-w-6xl">
        <p class="tech-label v2-kicker rule-brass text-azur-600">No detours</p>
        <h2 class="display v2-section-title mt-5">How to finance — in full transparency</h2>
        <p class="v2-lead mt-4 max-w-2xl text-encre-soft">
          Let's be clear from the start: we install and warrant solar, we sell no financial product.
          Here, without dressing up, are the three ways our clients actually pay for their
          installation.
        </p>
        <div class="mt-10 grid gap-6 md:grid-cols-3" data-stagger>
          {moyens.map((m, i) => (
            <div class="v2-rise flex flex-col border-t-2 border-azur-900 bg-blanc p-7" style={`--v2-i:${i}`}>
              <p class="fig text-3xl text-azur-600" dir="ltr">{m.k}</p>
              <h3 class="display mt-2 text-xl">{m.title}</h3>
              <p class="mt-3 flex-1 text-sm leading-relaxed text-encre-soft">{m.body}</p>
            </div>
          ))}
        </div>

        <!-- The honest clarifications -->
        <div class="mt-10 max-w-3xl border-s-4 border-azur-600 bg-blanc px-5 py-5 text-sm leading-relaxed text-encre-soft">
          <p class="tech-label text-azur-600">What you should know, in black and white</p>
          <ul class="mt-4 space-y-2.5">
            <li><strong class="text-encre">Taqinor is not a credit body</strong> or a lender: we grant no financing and take no banking commission.</li>
            <li><strong class="text-encre">No special residential subsidy</strong> exists for a private solar installation in Morocco — beware of any such promise.</li>
            <li><strong class="text-encre">No residential VAT exemption</strong>: VAT applies to a complete turnkey installation. We won't promise you otherwise.</li>
            <li>For businesses, <strong class="text-encre">green financing lines</strong> for renewable energy projects exist in Morocco, but it is your bank that decides — we name no institution and guarantee no terms.</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- W258 — Named, verified mechanisms by segment (WG11) -->
    <div class="v2-seam" aria-hidden="true"></div>
    <section class="px-4 py-20 sm:py-24">
      <div class="mx-auto max-w-6xl">
        <p class="tech-label v2-kicker rule-brass text-lune">What really exists, named</p>
        <h2 class="display v2-section-title mt-5 text-white">Verified Moroccan mechanisms, by profile</h2>
        <p class="v2-lead mt-4 max-w-2xl text-lune-soft">
          Every name cited below was verified against a primary source at the time this page was
          published — never a partnership we don't actually have. What we couldn't verify does not
          appear here.
        </p>
        <div class="mt-10 grid gap-8 md:grid-cols-3" data-stagger>
          {mecanismes.map((seg, i) => (
            <div class="v2-rise border-t-2 border-brass-400/60 pt-5" style={`--v2-i:${i}`}>
              <h3 class="display text-xl text-white">{seg.segment}</h3>
              <div class="mt-4 space-y-5">
                {seg.items.map((it) => (
                  <div>
                    <p class="font-display text-base font-bold text-white">{it.nom}</p>
                    <p class="mt-1.5 text-sm leading-relaxed text-lune-soft">{it.body}</p>
                    <p class="tech-label mt-1.5 text-lune-faint">Source: {it.source}</p>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- W336 — The two CFO tax levers: CGI art. 123-22° VAT + depreciation.
         WG16 (legal skim) still in progress: "subject to verification" note
         visible. For businesses (residential stays with no VAT exemption —
         clarification already published above). -->
    <div class="v2-seam" aria-hidden="true"></div>
    <section class="bg-blanc-azur px-4 pb-20 pt-16 text-encre sm:pb-24">
      <div class="mx-auto max-w-4xl">
        <p class="tech-label v2-kicker rule-brass text-azur-600">For businesses · the two levers nobody cites</p>
        <h2 class="display v2-section-title mt-5">Import VAT and depreciation: what the CGI says</h2>
        <p class="v2-lead mt-4 max-w-2xl text-encre-soft">
          Two real, checkable law articles work in favour of a business solar installation recorded
          as a fixed asset on your company's books — these are not terms Taqinor negotiated, but open
          provisions of the Code Général des Impôts.
        </p>
        <div class="mt-8 grid gap-6 sm:grid-cols-2">
          <div class="border-t-2 border-azur-900 bg-blanc p-6">
            <p class="fig text-lg text-azur-600">CGI · art. 123-22°</p>
            <h3 class="display mt-2 text-lg">Import VAT exemption</h3>
            <p class="mt-3 text-sm leading-relaxed text-encre-soft">
              An investment good recorded as a fixed asset, imported by a VAT-registered company
              within 36 months of starting its activity, is exempt from VAT — subject to constituting
              the guarantees required by the tax authorities.
            </p>
          </div>
          <div class="border-t-2 border-azur-900 bg-blanc p-6">
            <p class="fig text-lg text-azur-600">Depreciation</p>
            <h3 class="display mt-2 text-lg">20 years, straight-line, 5 % a year</h3>
            <p class="mt-3 text-sm leading-relaxed text-encre-soft">
              A solar installation is depreciated for accounting purposes like a standard production
              asset: straight-line over 20 years, i.e. 5 % of its value deducted from taxable income
              each year.
            </p>
          </div>
        </div>
        <p class="mx-auto mt-8 max-w-2xl border-s-4 border-azur-600 ps-4 text-sm leading-relaxed text-encre-soft">
          <strong class="text-encre">Subject to verification (legal skim in progress):</strong> the most
          recent finance law extends, for certain companies bound by a state convention, the import
          VAT exemption window beyond the standard 36 months — a point that does not apply the same
          way to every company. Confirm your exact situation with your accountant before any decision.
        </p>
      </div>
    </section>

    <!-- The study computes YOUR return -->
    <section class="px-4 py-20 sm:py-28">
      <div class="mx-auto grid max-w-6xl gap-10 lg:grid-cols-[1.1fr_1fr] lg:items-center">
        <div class="v2-rise">
          <p class="tech-label v2-kicker rule-brass text-lune">Your return, not an average</p>
          <h2 class="display v2-section-title mt-5 text-white">The study computes the return on your bill</h2>
          <p class="v2-lead mt-5 text-lune-soft">
            Everything above stays an order of magnitude. Your figure — what you save each month, the
            year the installation paid itself back — comes from three data points that belong only to
            you: your bill, your consumption profile, your roof. We run them through the calculation,
            and the result is yours, not a brochure average.
          </p>
          <a href={devisHref} class="mt-8 inline-block bg-brass-400 px-7 py-3.5 text-base font-bold text-azur-950 transition-colors hover:bg-brass-300">Compute my return — study at 0 MAD</a>
        </div>
        <dl class="grid grid-cols-2 gap-x-6 gap-y-10 border-s-2 border-brass-400/60 ps-6 sm:ps-10" data-stagger>
          <div class="v2-rise" style="--v2-i:0">
            <dd class="fig lum whitespace-nowrap text-3xl sm:text-5xl" dir="ltr" data-tally>0 MAD</dd>
            <dt class="tech-label mt-2 text-lune-faint">The study and the assessment</dt>
          </div>
          <div class="v2-rise" style="--v2-i:1">
            <dd class="fig lum whitespace-nowrap text-3xl sm:text-5xl" dir="ltr" data-tally>30 years</dd>
            <dt class="tech-label mt-2 text-lune-faint">Guaranteed performance (≥ 87.4 %)</dt>
          </div>
          <div class="v2-rise" style="--v2-i:2">
            <dd class="fig lum whitespace-nowrap text-3xl sm:text-5xl" dir="ltr" data-tally>3–7 years</dd>
            <dt class="tech-label mt-2 text-lune-faint">Typical return on investment</dt>
          </div>
          <div class="v2-rise" style="--v2-i:3">
            <dd class="font-display text-xl font-bold text-white">ONEE tariff</dd>
            <dt class="tech-label mt-2 text-lune-faint">Basis for the avoided-electricity calculation</dt>
          </div>
        </dl>
      </div>
    </section>

    {/* Contextual links — price/residential + pumping cluster (W299) */}
    <section class="border-t border-white/10 px-4 py-16">
      <div class="mx-auto max-w-6xl">
        <RelatedLinks mt="mt-0" links={[
          { href: L('/résidentiel'), label: 'Residential returns' },
          { href: L('/professionnel'), label: 'Business returns' },
          { href: L('/pompage-solaire'), label: 'Agricultural solar pumping' },
          { href: L('/prix-panneaux-solaires-maroc'), label: 'Solar panel prices in Morocco' },
          { href: L('/garanties'), label: 'Our warranties (30 years)' },
          { href: devisHref, label: 'Start my assessment' },
        ]} />
      </div>
    </section>

    <CtaBand title="How much does your roof earn you? The free assessment figures it out." href={devisHref} />

    <StickyCta />
  </div>
</Layout>
