---
/**
 * EN — Maintenance & monitoring (W67). Faithful translation of
 * /maintenance-monitoring ; no invented SLA or "within 24h/48h" claim (none is
 * published). Internal links via localizeNavHref. FR untouched.
 *
 * ELEVATION (W237) — mirrors /maintenance-monitoring.astro elevation treatment:
 *  - Eyebrows demoted from text-brass-300 to text-lune (brass discipline);
 *  - "Inclus à chaque installation" eyebrow: text-lune;
 *  - Equipment link: border-lune/40 text-lune (not brass);
 *  - .section-lg hero + .section / .seam-soft spacing tokens;
 *  - .v2-rise wrapper on closing block; "To go further" eyebrow: text-lune;
 *  - No photo content → no .v3-grade, no ZelligeSignature.
 *
 * W255 — Proactive after-sales becomes a headline in its own right (co-lead
 * with monitoring), and 3 NAMED entretien tiers (Essentiel/Confort/Premium)
 * are scaffolded: inclusions from the site (no invented figure), response
 * SLA + prices marked "pending founder validation" (WG10 — not yet supplied).
 * Each tier has a prefilled WhatsApp CTA.
 *
 * W257 — Monitoring presented by outcomes (3 honest phone mockups — no fake
 * Deye Cloud dashboard, just the 3 promises already published above staged
 * visually) + the WhatsApp-alert-on-anomaly reminder.
 *
 * W340 — "After your installation" + client-area door. A 4-step narrative
 * section (commissioning → production tracking → open an after-sales
 * ticket → warranties), anchored on the REAL capabilities already published
 * below (nothing new invented here, only the storytelling changes):
 * DEYE_CLOUD_URL points to the real public Deye Cloud portal
 * (www.deyecloud.com/login — the personal access mentioned above), the
 * after-sales ticket points to the real W339 door (/contact#deja-client),
 * warranties to /garanties. Content-only: no custom client portal exists or
 * is planned here — that would be backend work, out of scope.
 */
import Layout from '../../layouts/Layout.astro';
import V2Enhance from '../../components/V2Enhance.astro';
import Article33Ribbon from '../../components/Article33Ribbon.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CtaBand from '../../components/CtaBand.astro';
import StickyCta from '../../components/StickyCta.astro';
import { getLocaleFromPath } from '../../i18n/utils';
import { localizeNavHref } from '../../i18n/pages';
import { DEYE_CLOUD_URL, WHATSAPP_LEADS } from '../../lib/nap';
import { whatsappLink } from '../../lib/whatsapp';

const locale = getLocaleFromPath(Astro.url.pathname);
const L = (href: string) => localizeNavHref(href, locale);
const devisHref = L('/devis/mon-toit');

// W340 — the 4 after-installation steps, in the journey's real order. Each
// step rests on a capability already published on this page (tracking) or
// elsewhere on the site (warranties, W339 after-sales) — no new promise.
const apresInstallation = [
  {
    k: '01',
    title: 'Commissioning',
    body: 'The installation is connected, tested, and the monitoring dongle registered on Deye Cloud. The complete technical file (diagrams, protections, procedure) is handed over that same day.',
  },
  {
    k: '02',
    title: 'Production tracking',
    body: 'From the next day on, your personal Deye Cloud access shows real production, day after day. It is the same data that feeds our written warranties — nothing more, nothing less.',
  },
  {
    k: '03',
    title: 'Open an after-sales ticket',
    body: 'An alert on your side or from Deye Cloud? A WhatsApp report opens a ticket in our after-sales module, tracked through to its close — the same door as "Already a customer?" on the contact page.',
  },
  {
    k: '04',
    title: 'Warranties',
    body: 'Written warranties (hardware, workmanship) run in parallel, with measured production as the shared reference should any dispute arise.',
  },
];

// W255 — 3 NAMED entretien tiers, no-op-safe scaffold: inclusions drawn from
// what's already published (monitoring/after-sales/technical file); response
// SLA and prices stay explicit placeholders until Reda validates the real
// commitments (WG10, gate open).
const entretienTiers = [
  {
    name: 'Essentiel',
    body: 'Deye Cloud monitoring included and fleet-wide supervision: this is the base already delivered with every installation.',
    inclusions: ['Personal Deye Cloud access', 'Automatic fault alert', 'Complete technical file'],
    sla: 'pending founder validation',
    prix: 'pending founder validation',
  },
  {
    name: 'Confort',
    body: 'The Essentiel base, plus a scheduled maintenance visit to keep the installation at its best output.',
    inclusions: ['Everything in Essentiel', 'Scheduled maintenance visit', 'Panel cleaning'],
    sla: 'pending founder validation',
    prix: 'pending founder validation',
  },
  {
    name: 'Premium',
    body: 'The most complete level: reinforced maintenance and priority intervention on alert.',
    inclusions: ['Everything in Confort', 'Reinforced maintenance visits', 'Priority intervention on alert'],
    sla: 'pending founder validation',
    prix: 'pending founder validation',
  },
];

const waTier = (tierName: string) =>
  whatsappLink(WHATSAPP_LEADS, `Bonjour, je souhaite en savoir plus sur le contrat d’entretien ${tierName}.`);

// W257 — 3 illustrative phone mockups (no real Deye Cloud screenshot, no
// invented figure): live production, the alert, savings-to-date tracking.
// Generic labels only, never a figure we wouldn't stand behind.
const phoneVues = [
  {
    appLabel: 'Deye Cloud',
    headline: '3.2 kW',
    accent: 'text-brass-300',
    sub: 'Live production',
    caption: 'Your production, readable in real time — the same data that backs our written warranties.',
  },
  {
    appLabel: 'Deye Cloud',
    headline: 'Alert',
    accent: 'text-white',
    sub: 'Inverter · fault code',
    caption: 'An anomaly triggers a WhatsApp alert on our side before you have even noticed it.',
  },
  {
    appLabel: 'Deye Cloud',
    headline: 'History',
    accent: 'text-brass-300',
    sub: 'Savings to date',
    caption: 'The daily and monthly production total, to track what the installation has actually delivered.',
  },
];

const suivi = [
  {
    title: 'Deye Cloud monitoring included',
    body: 'Every installation reports to Deye Cloud: real-time production, daily and monthly history, automatic alerts on faults. You receive your personal access on the mobile app, and you see exactly what the installer sees.',
  },
  {
    title: 'Proactive after-sales',
    body: 'We keep an eye on the whole installed fleet. When Deye Cloud raises an alert, it is more than a red light: it names the inverter concerned, the fault code reported and the time production dropped off. Often we have already pinned down the cause before the client has seen anything at all.',
  },
  {
    title: 'Complete technical file',
    body: 'The installation leaves with its file: single-line diagrams, cable sizing, the list of protections, the commissioning procedure and access to Deye Cloud monitoring. Enough for another electrician to take over if needed.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Maintenance & monitoring',
  serviceType: 'Maintenance and supervision of solar installations',
  provider: { '@type': 'Organization', name: 'Taqinor', url: 'https://taqinor.ma' },
  areaServed: { '@type': 'Country', name: 'Maroc' },
  description:
    'Deye Cloud supervision included on every solar installation in Morocco: real-time production, automatic alerts and proactive after-sales, with client access via the mobile app and a complete technical file delivered.',
};
---

<Layout
  title="Solar maintenance, after-sales & monitoring: Deye Cloud supervision included | Taqinor"
  description="Every Taqinor installation reports to Deye Cloud — real-time production, history, automatic alerts — with client access on the mobile app. Proactive after-sales acts on alert, before the complaint, and extends into named maintenance contracts. Complete technical file delivered with the project."
  ogSlug="equipement"
>
  <div class="v2">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <V2Enhance />
    <Article33Ribbon />

    <Breadcrumb items={[{ label: 'Home', href: L('/') }, { label: 'Maintenance & monitoring' }]} />

    {/* ── DARK HERO — W255: after-sales co-leads with monitoring (brass discipline) ── */}
    <section class="px-4 pb-12 pt-16 text-white sm:pt-20">
      <div class="mx-auto max-w-3xl">
        <p class="tech-label v2-kicker rule-brass cine-in text-lune">After the install</p>
        <h1 class="display v2-page-title cine-in cine-in-1 mt-5">Monitoring &amp; proactive after-sales</h1>
        <p class="v2-lead cine-in cine-in-2 mt-6 max-w-xl text-white/85">
          The day the installation is commissioned, it starts to talk. On Deye Cloud, every Taqinor
          roof reports its production continuously — yours readable on your phone, ours monitored
          across the whole fleet. An anomaly triggers an alert; our after-sales team starts from
          there, before the complaint — a dedicated module in our ERP tracks every intervention
          through to its close.
        </p>
      </div>
    </section>

    {/* ── W340 — AFTER YOUR INSTALLATION + CLIENT AREA ──
        4-step narrative of the real journey (commissioning → production
        tracking → open an after-sales ticket → warranties), then the client
        area door: the real Deye Cloud portal (personal access already
        handed to every client) + the real after-sales ticket path
        (/contact#deja-client, W339) + written warranties. Content-only, no
        invented custom portal. */}
    <div class="seam-soft" aria-hidden="true"></div>
    <section class="section px-4">
      <div class="mx-auto max-w-6xl">
        <p class="tech-label v2-kicker rule-brass text-lune">What happens next</p>
        <h2 class="display v2-section-title mt-5 text-white">After your installation</h2>
        <p class="v2-lead mt-5 max-w-2xl text-lune-soft">
          Installation isn't the end of the relationship, it's the start. Here is, in order, what
          awaits you once the site is finished.
        </p>
        <ol class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4" data-stagger>
          {apresInstallation.map((s, i) => (
            <li class="v2-rise cine-card flex flex-col p-6" style={`--v2-i:${i}`}>
              <span class="fig lum text-2xl" aria-hidden="true">{s.k}</span>
              <h3 class="display mt-3 text-lg text-white">{s.title}</h3>
              <p class="mt-3 flex-1 text-sm leading-relaxed text-lune-soft">{s.body}</p>
            </li>
          ))}
        </ol>

        {/* Client-area door — one brass CTA (the real Deye Cloud portal), two
            secondary links (real after-sales ticket, warranties). */}
        <div class="v2-rise mt-12 border-t-2 border-white/15 bg-white/[0.03] p-7 sm:p-9" style="--v2-i:4">
          <p class="tech-label text-lune">Client area</p>
          <h3 class="display mt-2 text-xl text-white">Your personal Deye Cloud access</h3>
          <p class="mt-3 max-w-xl text-sm leading-relaxed text-lune-soft">
            Every client receives, at commissioning, their own Deye Cloud access — the same
            platform described above, not a separate Taqinor portal. That's where you track your
            production, day after day.
          </p>
          <div class="mt-6 flex flex-wrap gap-3">
            <a
              href={DEYE_CLOUD_URL}
              rel="noopener noreferrer"
              target="_blank"
              class="glow inline-flex items-center gap-2 bg-brass-400 px-6 py-3 text-sm font-bold text-azur-950 transition-colors hover:bg-brass-300"
            >
              Open my client area (Deye Cloud) →
            </a>
            <a href={`${L('/contact')}#deja-client`} class="inline-flex items-center gap-2 border border-white/40 px-6 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">
              Open an after-sales ticket
            </a>
            <a href={L('/garanties')} class="inline-flex items-center gap-2 border border-white/40 px-6 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">
              See my warranties
            </a>
          </div>
        </div>
      </div>
    </section>

    {/* ── WHAT THE MONITORING INCLUDES — .section rhythm, eyebrow lune ── */}
    <div class="seam-soft" aria-hidden="true"></div>
    <section class="section px-4">
      <div class="mx-auto max-w-6xl">
        <p class="tech-label v2-kicker rule-brass text-lune">Included with every installation</p>
        <h2 class="display v2-section-title mt-5 text-white">What the monitoring includes</h2>
        <div class="mt-12 grid gap-6 md:grid-cols-3" data-stagger>
          {suivi.map((s, i) => (
            <div class="v2-rise cine-card p-7" style={`--v2-i:${i}`}>
              <h3 class="display text-xl text-white">{s.title}</h3>
              <p class="mt-3 text-sm leading-relaxed text-lune-soft">{s.body}</p>
            </div>
          ))}
        </div>
        {/* Filet azur (brass demoted); equipment link in lune (discipline) */}
        <p class="v2-rise mt-12 max-w-xl border-l-2 border-azur-200/40 pl-4 text-sm leading-relaxed text-lune-soft">
          On the hardware side, the data goes through a WiFi or Ethernet dongle plugged into the
          inverter; it is what sends every measurement to Deye Cloud. The detail is on the equipment
          sheet.
          <a href={L('/équipement')} class="border-b border-lune/40 pb-0.5 font-semibold text-lune transition-colors hover:border-lune hover:text-white">See the Deye Cloud monitoring →</a>
        </p>
      </div>
    </section>

    {/* ── W257 — WHAT YOU SEE ON YOUR PHONE (outcomes, not specs) ──
        3 honest CSS phone mockups: no fabricated Deye Cloud screenshot, just
        the 3 promises already published above staged on a phone frame. */}
    <div class="seam-soft" aria-hidden="true"></div>
    <section class="section px-4">
      <div class="mx-auto max-w-6xl">
        <p class="tech-label v2-kicker rule-brass text-lune">On your phone</p>
        <h2 class="display v2-section-title mt-5 text-white">What you see, not what we promise</h2>
        <p class="v2-lead mt-5 max-w-2xl text-lune-soft">
          Three questions come up before anyone asks about protocol or measurement frequency: can I
          see my production on my phone, will I be warned if something goes wrong, and where do my
          savings stand. Here are the three answers.
        </p>
        <div class="mt-12 grid gap-6 md:grid-cols-3" data-stagger>
          {phoneVues.map((v, i) => (
            <div class="v2-rise flex flex-col items-center p-4" style={`--v2-i:${i}`}>
              <div class="phone-frame">
                <div class="phone-notch" aria-hidden="true"></div>
                <div class="phone-screen">
                  <p class="phone-app-label">{v.appLabel}</p>
                  <p class={`phone-headline ${v.accent}`}>{v.headline}</p>
                  <p class="phone-sub">{v.sub}</p>
                </div>
              </div>
              <p class="mt-5 text-center text-sm leading-relaxed text-lune-soft">{v.caption}</p>
            </div>
          ))}
        </div>
        <p class="v2-rise mx-auto mt-10 max-w-xl text-center text-sm leading-relaxed text-lune-faint">
          These views illustrate how the Deye Cloud app works — not an official screenshot. What
          yours shows depends on your actual installation.
        </p>
      </div>
    </section>

    {/* ── W255 — AFTER-SALES: NAMED MAINTENANCE CONTRACTS (scaffold, SLA/price gated WG10) ── */}
    <div class="v2-seam" aria-hidden="true"></div>
    <section class="bg-blanc-azur px-4 py-16 text-encre sm:py-20">
      <div class="mx-auto max-w-6xl">
        <p class="tech-label v2-kicker rule-brass eyebrow-light">Proactive after-sales, in tiers</p>
        <h2 class="display v2-section-title mt-5">Our maintenance contracts</h2>
        <p class="v2-lead mt-5 max-w-2xl text-encre-soft">
          The Essentiel base is already included with every installation; Confort and Premium add
          scheduled maintenance and priority intervention. The committed response times and the
          price of each tier are pending founder validation — nothing is published until it is a
          real, keepable commitment.
        </p>
        <div class="mt-12 grid gap-6 md:grid-cols-3" data-stagger>
          {entretienTiers.map((t, i) => (
            <div class="v2-rise flex flex-col border-t-2 border-azur-900 bg-blanc p-7" style={`--v2-i:${i}`}>
              <h3 class="display text-xl text-azur-700">{t.name}</h3>
              <p class="mt-3 flex-1 text-sm leading-relaxed text-encre-soft">{t.body}</p>
              <ul class="mt-4 space-y-2 text-sm text-encre-soft">
                {t.inclusions.map((inc) => (
                  <li class="flex items-start gap-2">
                    <span class="mt-1 text-azur-600" aria-hidden="true">✓</span>
                    <span>{inc}</span>
                  </li>
                ))}
              </ul>
              <dl class="mt-5 space-y-1 border-t border-azur-900/10 pt-4 text-xs">
                <div class="flex justify-between gap-2">
                  <dt class="text-encre-faint">Response time</dt>
                  <dd class="text-right italic text-encre-faint">{t.sla}</dd>
                </div>
                <div class="flex justify-between gap-2">
                  <dt class="text-encre-faint">Price</dt>
                  <dd class="text-right italic text-encre-faint">{t.prix}</dd>
                </div>
              </dl>
              <a href={waTier(t.name)} rel="noopener" class="mt-6 inline-block border-2 border-azur-600 px-5 py-2.5 text-center text-sm font-bold text-azur-600 transition-colors hover:bg-azur-600 hover:text-white">
                Learn more — {t.name}
              </a>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* ── MEASURED PRODUCTION (clear act, "clean room") ── */}
    <div class="v2-seam" aria-hidden="true"></div>
    <section class="bg-blanc-azur px-4 pb-20 pt-12 text-encre sm:pb-24">
      <div class="mx-auto max-w-3xl">
        <div class="v2-rise">
          {/* Canonical light-background eyebrow — azur accent (discipline) */}
          <p class="tech-label v2-kicker rule-brass eyebrow-light">Figures, read off</p>
          <h2 class="display v2-section-title mt-5">What the meter says, not the brochure</h2>
          <p class="v2-lead mt-5 text-encre-soft">
            The kWh a Taqinor installation shows don't come from a leaflet: Deye Cloud reads them day
            after day, and that reading is what counts. Our written warranties rest on the same data —
            the one the meter records, not the one we'd like to announce.
          </p>
          <p class="mt-5 text-sm leading-relaxed text-encre-soft">
            And the dashboard is yours too: your personal access on the mobile app shows you, in real
            time, what your roof produces — with no intermediary.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            {/* Primary CTA: the only brass in this light section (discipline) */}
            <a href={L('/garanties')} class="glow inline-block bg-brass-400 px-7 py-3.5 text-base font-bold text-azur-950 transition-colors hover:bg-brass-300">See our written warranties</a>
            <a href={L('/realisations')} class="inline-block border-b-2 border-azur-600 pb-0.5 text-base font-bold text-azur-600 transition-colors hover:text-azur-700">See our projects →</a>
          </div>
        </div>
      </div>
    </section>

    {/* ── CLOSING LINKS BLOCK — eyebrow lune, ghost white links ── */}
    <section class="section px-4">
      <div class="mx-auto max-w-6xl">
        <p class="tech-label v2-kicker rule-brass text-lune">To go further</p>
        <h2 class="display v2-section-title mt-5 text-white">The monitoring, in detail</h2>
        <p class="v2-rise mt-5 max-w-xl text-sm leading-relaxed text-lune-soft">
          Monitoring and proactive after-sales only hold because they rest on named hardware and
          warranties written in black and white. Here they are in detail.
        </p>
        <div class="v2-rise mt-10 flex flex-wrap gap-3">
          <a href={L('/garanties')} class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">Our warranties →</a>
          <a href={L('/équipement')} class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">The equipment installed →</a>
          <a href={devisHref} class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">My free assessment →</a>
        </div>
      </div>
    </section>

    <CtaBand title="A roof that watches itself is prepared from the study onward." href={devisHref} />

    <StickyCta />
  </div>
</Layout>

<style>
  /* W257 — pure CSS phone frame, no image: guaranteed anti-CLS, fixed
     dimensions, zero network dependency. Brass discipline: the only gold
     accent lives on .text-brass-300, never on the frame. */
  .phone-frame {
    width: 160px;
    height: 320px;
    border-radius: 28px;
    border: 3px solid rgba(255, 255, 255, 0.25);
    background: #0c1330;
    padding: 10px;
    position: relative;
    box-shadow: 0 20px 45px -20px rgb(6 10 30 / 0.6);
  }
  .phone-notch {
    position: absolute;
    top: 10px;
    left: 50%;
    transform: translateX(-50%);
    width: 48px;
    height: 6px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.2);
  }
  .phone-screen {
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    padding-top: 1rem;
    text-align: center;
  }
  .phone-app-label {
    font-size: 0.6rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.45);
  }
  .phone-headline {
    font-family: var(--font-display, inherit);
    font-weight: 700;
    font-size: 1.5rem;
    line-height: 1.1;
  }
  .phone-sub {
    font-size: 0.7rem;
    color: rgba(255, 255, 255, 0.6);
  }
</style>
