---
/**
 * EN — Homepage (W67 + W236). Faithful translation of the FR homepage (/) into
 * natural English, on the FR "elevation" composition (2026-06-22): full-frame
 * cinematic hero (~100svh) with hero count-up, proof carried by the gallery,
 * single zellige signature, the complete section set sequenced and aired
 * (.section / .v2-body / .fig tokens), brass discipline (gold lives on .lum/.fig
 * key figures and the single primary CTA; eyebrows demoted to lune), "golden
 * hour" grade (.v3-grade) on content photography — NEVER the hero (LCP). No
 * figure, %, year, kWc/kWh, MAD amount, brand name, law number (82-21) or legal
 * line is invented, dropped or altered — Western/Latin digits stay exactly as FR.
 * Every internal link goes through localizeNavHref so it lands on the EN page
 * when one exists, else falls back to the existing FR page (never a dead link).
 * The FR homepage is untouched. The DiagnosticForm and its lead data flow are
 * locale-agnostic (the shared component reads the locale from the URL) — mounted
 * exactly as on the FR home.
 */
import Layout from '../../layouts/Layout.astro';
import V2Enhance from '../../components/V2Enhance.astro';
import Article33Ribbon from '../../components/Article33Ribbon.astro';
import DiagnosticForm from '../../components/DiagnosticForm.astro';
import Faq from '../../components/Faq.astro';
import Picture from '../../components/Picture.astro';
import VideoChantier from '../../components/VideoChantier.astro';
import StickyCta from '../../components/StickyCta.astro';
import WhatsAppMock from '../../components/WhatsAppMock.astro';
import GarantiesTeaser from '../../components/GarantiesTeaser.astro';
import Testimonials from '../../components/Testimonials.astro';
import BrandStrip from '../../components/BrandStrip.astro';
import ZelligeSignature from '../../components/ZelligeSignature.astro';
import FounderPortrait from '../../components/FounderPortrait.astro';
import { WHATSAPP_LEADS } from '../../lib/nap';
import { whatsappLink } from '../../lib/whatsapp';
import { getLocaleFromPath } from '../../i18n/utils';
import { localizeNavHref } from '../../i18n/pages';
import { REGIE_MARGINAL_RATE_SECOND, REGIE_MARGINAL_RATE_HIGH } from '../../lib/regieTariff';

const locale = getLocaleFromPath(Astro.url.pathname);
const L = (href: string) => localizeNavHref(href, locale);

const waDirect = whatsappLink(WHATSAPP_LEADS, 'Hello, I would like a study for a solar installation.');

// W205 — The protagonist figure of the headline is separated for the count-up.
// Its width is reserved (tabular-nums + JS-locked min-width) → zero CLS.
const heroFigure = '21 406';
const heroTitleSuffix = ' kWh a year, produced on a rooftop in El Jadida.';
const heroSub =
  'Installation ref. 468 — 17,04 kWc, sized, installed and measured by Taqinor. Yours starts with a 60-second diagnostic.';

// W267 — Hero money sub-line. NO invented figure: the real consumption of
// the ref. 468 household is not published anywhere on the site, so we
// cannot call `annualSavingsMad(production, consumption)` without inventing
// that second variable. The only honest derivation from the SOLE published
// data point (21 406 kWh produced) is to value that production at the real
// MARGINAL rate of the REGIE tariff grid (REGIE_TARIFF.selective, the two
// top tranches — consistent with "our largest residential of 2026", i.e. a
// household unambiguously in the top bracket): this is exactly the same
// "≈ 1.38–1.60 MAD/kWh" range already published and documented in
// billRange.ts / recharge-voiture-electrique-solaire.astro. A range (never a
// single figure): the household's real self-consumption isn't known, so a
// single point value would invent a precision we don't have.
const heroProductionKwh = 21406;
const heroTariffLowRate = REGIE_MARGINAL_RATE_SECOND; // 1.3817 MAD/kWh
const heroTariffHighRate = REGIE_MARGINAL_RATE_HIGH; // 1.5958 MAD/kWh
const heroMoneyLow = Math.round((heroProductionKwh * heroTariffLowRate) / 100) * 100;
const heroMoneyHigh = Math.round((heroProductionKwh * heroTariffHighRate) / 100) * 100;
const heroMoneyLine = `≈ ${heroMoneyLow.toLocaleString('en-US')} to ${heroMoneyHigh.toLocaleString('en-US')} MAD wiped off the bill every year`;

// PLACEHOLDER(MERYEM): provisional FAQ.
const faq = [
  { q: 'How much does a residential solar installation cost?', a: 'It depends on your consumption and your roof. A villa with a bill of 1 500 MAD per month typically gets a 4 to 6 kWc system. The diagnostic below gives you an immediate range; the precise quote is set after a technical visit.' },
  { q: 'What does Law 82-21 say for households?', a: 'At low voltage, an installation under 11 kW falls under the declaration regime: a prior formality, not an authorisation. Taqinor prepares and files the declaration for you.' },
  { q: 'My existing installation is not declared. What should I do?', a: 'Article 33 of Law 82-21 opens a regularisation window for existing installations. The window is open: file now. See the Regularisation page for the 5-step procedure.' },
  { q: 'How long do the panels last?', a: 'Panels carry a 25-year performance warranty (generally ≥ 84,8 % of the initial output at 25 years). Inverters are typically replaced once over the lifetime of the installation.' },
  { q: 'Do I need batteries?', a: 'Not necessarily. If your consumption is mostly during the day, direct self-consumption is the best investment. Batteries are justified for night-time consumption or service continuity — we calculate it in the study.' },
];

const gallery = [
  { name: 'reflet-468', alt: 'The sun reflects off the row of panels during the install, El Jadida', widths: [1600, 1024, 640], ratio: 3 / 2, ville: 'El Jadida', kwc: '17,04 kWc', prod: '21 406 kWh/yr', type: '24 × Canadian Solar 710 Wc · Deye 15 kW', slug: 'el-jadida-17-kwc' },
  { name: 'equipe-trois', alt: 'Taqinor team in front of the long row of panels at the end of the job, El Jadida', widths: [1600, 1024, 640], ratio: 3 / 2, ville: 'El Jadida', kwc: '17,04 kWc', prod: null, type: 'Job complete · Taqinor team', slug: 'el-jadida-17-kwc' },
  { name: 'hero-skyline', alt: 'Row of solar panels in front of the Casablanca skyline and a minaret, golden light', widths: [2000, 1280, 768, 480], ratio: 16 / 9, ville: 'Casablanca', kwc: '11,36 kWc', prod: '14 271 kWh/yr', type: '16 × Canadian Solar 710 Wc · Deye 10 kW', slug: 'casablanca-11-kwc' },
  { name: 'portrait-400', alt: 'The engineer in front of the panel array, Casablanca skyline', widths: [1600, 1024, 640], ratio: 4 / 3, ville: 'Casablanca', kwc: '11,36 kWc', prod: null, type: 'Measured production — Deye Cloud', slug: 'casablanca-11-kwc' },
  { name: 'champ-villa', alt: 'Array of eight panels on a flat villa roof, El Jadida', widths: [1600, 1024, 640], ratio: 3 / 2, ville: 'El Jadida', kwc: '5,68 kWc', prod: '7 135 kWh/yr', type: '8 × Canadian Solar 710 Wc · Deye 5 kW', slug: 'el-jadida-6-kwc' },
  { name: 'pose-134', alt: 'The team tilts a panel during the install, Casablanca', widths: [1600, 1024, 640], ratio: 4 / 3, ville: 'Casablanca', kwc: '5,68 kWc', prod: '7 135 kWh/yr', type: 'Install in progress · 8 × Canadian Solar 710 Wc', slug: 'casablanca-6-kwc' },
  { name: 'equipe-gilet-taqinor', alt: 'Installer in a Taqinor vest fitting the rails of a structure, Nouaceur', widths: [1600, 1024, 640], ratio: 1, ville: 'Nouaceur', kwc: '3,72 kWc', prod: null, type: 'Fitting the rails · 6 × JA Solar', slug: 'nouaceur-4-kwc' },
  { name: 'entretien-jet', alt: 'Jet-wash cleaning of the panel array, Nouaceur', widths: [1600, 1024, 640], ratio: 1, ville: 'Nouaceur', kwc: '3,72 kWc', prod: null, type: 'Array maintenance · 6 × JA Solar', slug: 'nouaceur-4-kwc' },
];

// W271 — City filter chips: "All" + the cities actually present in `gallery`
// above (no invented city; order follows each city's first appearance in the
// array — El Jadida, Casablanca, Nouaceur).
const galleryCities = ['All', ...Array.from(new Set(gallery.map((g) => g.ville)))];

// Our solutions — every offering visible from the homepage, not only in the
// menu. Descriptions from the already-published positioning, no new claim or
// figure. Text cards (no image) → zero CLS.
const solutions = [
  { href: '/résidentiel', tag: 'Villas & apartments', title: 'Residential solar', body: 'Sized to your real bill, Law 82-21 declaration included.' },
  { href: '/professionnel', tag: 'Industry · hotels · clinics', title: 'Business solar', body: 'Cutting your electricity costs, medium voltage, Law 82-21 compliance.' },
  { href: '/pompage-solaire', tag: 'Agriculture & irrigation', title: 'Solar pumping', body: 'Pumping with the sun, often without batteries, sized to the real need.' },
  { href: '/batteries-stockage', tag: 'Self-consumption', title: 'Batteries & storage', body: 'LFP storage for the evening or service continuity — when the study justifies it.' },
  { href: '/maintenance-monitoring', tag: 'After the install', title: 'Maintenance & monitoring', body: 'Deye Cloud supervision with client access, proactive after-sales, technical file.' },
  { href: '/regularization-article-33', tag: 'Bringing into compliance', title: 'Law 82-21 regularisation', body: 'Regularising existing installations via Article 33.' },
];

// The real journey, end to end. Facts already published on the site (60-second
// diagnostic, WhatsApp exchange, free visit & study, install, commissioning,
// Deye Cloud monitoring with client access). No invented delay/SLA.
const journey = [
  { n: '1', title: '60-second diagnostic', body: 'An immediate range from your bill, with no commitment.' },
  { n: '2', title: 'WhatsApp exchange', body: 'Straight to the technical team, roof photos in hand — no call centre.' },
  { n: '3', title: 'Technical visit & free study', body: 'On-site roof reading, complete study and a 0 MAD quote.' },
  { n: '4', title: 'Installation', body: 'Tier-1 equipment installed with its complete technical file.' },
  { n: '5', title: 'Commissioning', body: 'Connection, checks, and the Law 82-21 file carried through to the end.' },
  { n: '6', title: 'Deye Cloud monitoring', body: 'Production read continuously, client access included: you read your kWh at the source.' },
];

// W252 — "How it works": 4-step band under the hero, the near-universal
// 3-4-icon device used by every serious player in the sector. These are the
// SAME 4 stages as the fuller "The journey" timeline further down — just
// condensed to 4 (instead of 6) to answer, right under the hero, "what
// happens after the form?". No invented delay/SLA; the 4 stages are the ones
// actually delivered by the built journey (diagnostic → signed study → quote
// + e-signature → install & after-sales, see /devis/mon-toit).
const howItWorks = [
  { n: '1', title: 'Instant estimate', body: 'Your bill gives a kWc range in 60 seconds, with no commitment.' },
  { n: '2', title: 'Personalised, signed study', body: 'Technical visit, sizing on your actual roof, validated and signed before any quote.' },
  { n: '3', title: 'Quote + e-signature', body: 'The detailed quote is signed electronically, wherever you are.' },
  { n: '4', title: 'Installation & after-sales', body: 'Installed by our team, commissioned, then Deye Cloud monitoring and proactive after-sales.' },
];

// Sober iconography for the "Our solutions" cards: one SVG line per card,
// currentColor (brass tint), in the brand language. Keyed by href so it stays
// stable even if the card order changes.
const solutionIcons: Record<string, string> = {
  '/résidentiel': '<path d="M4 13 12 5l8 8" /><path d="M6 11v8h12v-8" /><path d="M10 19v-4h4v4" />',
  '/professionnel': '<path d="M4 21V8l7-3v4l7-3v15" /><path d="M4 21h16" /><path d="M8 12h0M8 16h0M14 12h0M14 16h0" />',
  '/pompage-solaire': '<path d="M12 3v6" /><path d="M5 21c1.6-2 3.2-2 4.8 0s3.2 2 4.8 0 3.2-2 4.4 0" /><path d="M8 9h8l-2 6H10z" />',
  '/batteries-stockage': '<path d="M5 8h14v11H5z" /><path d="M9 5h6v3H9z" /><path d="M12 11v5" /><path d="M9.5 13.5h5" />',
  '/maintenance-monitoring': '<path d="M4 18 9 12l3 3 4-6 4 5" /><path d="M4 21h16" /><circle cx="9" cy="12" r="0.6" /><circle cx="16" cy="9" r="0.6" />',
  '/regularization-article-33': '<path d="M7 4h7l4 4v12H7z" /><path d="M14 4v4h4" /><path d="M9.5 14l1.5 1.5 3-3.5" />',
};

// Why Taqinor / trust — four monumental figures, already-published facts. Founder
// decision 2026-06-22: the "doctor-engineer" slot is replaced by Law 82-21
// compliance — a concrete, non-personal trust signal (the founder credit lives on
// the team page). The three other values (3 visitable worksites, 43,48 kWc
// installed, Deye Cloud) are unchanged. Gold lives on the .lum figures (brass
// discipline). No invented claim.
const trust = [
  { fig: '3', tally: false, label: 'Worksites you can visit', body: 'Real installations to see on request — Casablanca, El Jadida, Nouaceur' },
  { fig: '43,48 kWc', tally: true, label: 'Installed', body: 'Casablanca, El Jadida, Nouaceur' },
  { fig: 'Law 82-21', tally: false, label: 'Compliance included', body: 'Declaration prepared and filed for you by Taqinor' },
  { fig: 'Deye Cloud', tally: false, label: 'Measured production', body: 'Monitoring on every installation, client access included' },
];

// W265 — The 25-year investment story: the page's ONE clear tonal break
// (blanc-azur background, encre text), placed at position 3-4 to let the
// dark→light→dark narrative breathe. Figures STRICTLY reused from
// /financement (already published) — no new number.
const investment = [
  { v: '3–7 years', label: 'Typical return on investment' },
  { v: '25 years', label: 'Panel performance warranty' },
  { v: '60–90 %', label: 'Of the bill covered' },
  { v: '0 MAD', label: 'The study and the assessment' },
];

// W276 — "Our engine, built in Morocco": the true in-house engineering
// story, told with the THREE tools actually built and already in production
// on the site (no third-party software, no invented claim):
//   1. The bill-driven estimator (src/lib/estimatorBrain.ts — home-grown
//      solar position, row spacing derived from a winter-solstice shading
//      rule, see ESTIMATOR_BRAIN_NOTES.md).
//   2. The 3D roof engine (/devis/mon-toit — real roof tracing, real
//      orientation/tilt, not a generic lookup table).
//   3. The premium quote engine (apps/ventes/quote_engine, e-signed PDF,
//      see CLAUDE.md rule #4) that renders the final quote.
// No fabricated number here: the link leads straight to the real journey
// (/devis/mon-toit) so the visitor can VERIFY it themselves in 60 seconds.
const engineeringPillars = [
  {
    title: 'The bill-driven estimator',
    body: 'Your electricity bill is enough: our engine computes the sun’s position and the row spacing between panels from a winter-solstice shading rule — not a generic imported lookup table.',
  },
  {
    title: 'The 3D roof engine',
    body: 'Trace your roof, orient it, and the sizing adapts to your home’s real geometry — the same technology you just tried in the diagnostic above.',
  },
  {
    title: 'The quote engine',
    body: 'The resulting quote is signed electronically, online — no manual re-entry between the study and the document you sign.',
  },
];
---

<Layout
  title="Taqinor — Solar installations in Morocco, Law 82-21 compliant"
  description="Design, installation and declaration of solar installations for villas, industry and hotels in Morocco. Free study, engineering-led sizing, Law 82-21 compliance."
  ogSlug="accueil"
  preloadHeroPoster
>
  <div class="v2">
    <V2Enhance />
    <Article33Ribbon />

    {/* ── 1 · CINEMATIC HERO (~100svh) — the photo is the protagonist ── */}
    <section class="relative isolate flex min-h-[100svh] flex-col justify-end overflow-hidden text-white">
      <div class="v2-hero-media absolute inset-0 -z-10">
        {/* Full-frame hero poster (LCP element) — Ken Burns inherited from the
            photo layer. NEVER .v3-grade here (LCP protection): only the scrim,
            raised on this page, carries the warmth without touching text contrast.
            W155 — Portrait-crop: in portrait orientation (phone held vertical),
            portrait sources are picked first; object-position recenters the panels. */}
        <picture>
          <source type="image/avif" media="(orientation: portrait)" sizes="100vw"
            srcset="/videos/hero-poster-540.avif 540w, /videos/hero-poster-720.avif 720w, /videos/hero-poster-1080.avif 1080w" />
          <source type="image/webp" media="(orientation: portrait)" sizes="100vw"
            srcset="/videos/hero-poster-540.webp 540w, /videos/hero-poster-720.webp 720w, /videos/hero-poster-1080.webp 1080w" />
          <source type="image/avif" sizes="100vw"
            srcset="/videos/hero-poster-540.avif 540w, /videos/hero-poster-720.avif 720w, /videos/hero-poster-1080.avif 1080w, /videos/hero-poster-1600.avif 1600w" />
          <source type="image/webp" sizes="100vw"
            srcset="/videos/hero-poster-540.webp 540w, /videos/hero-poster-720.webp 720w, /videos/hero-poster-1080.webp 1080w, /videos/hero-poster-1600.webp 1600w" />
          <img src="/videos/hero-poster-1600.webp" alt="" width="1600" height="900"
            loading="eager" decoding="async" fetchpriority="high"
            class="h-full w-full object-cover hero-portrait-img" />
        </picture>
        <video id="hero-video" muted loop playsinline preload="none" aria-hidden="true" tabindex="-1"
          class="absolute inset-0 h-full w-full object-cover opacity-0 transition-opacity duration-700"></video>
        {/* Canonical scrim RAISED (--hero-scrim-strength 0.52): compensates for
            the "golden hour" grade warmth and keeps the headline ≥ AA. */}
        <div class="hero-scrim hero-scrim-v3 absolute inset-0"></div>
      </div>

      {/* W161 — Scroll invitation: animated chevron, static under prefers-reduced-motion */}
      <div class="absolute bottom-6 left-1/2 -translate-x-1/2 scroll-chevron" aria-hidden="true">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="6 9 12 15 18 9" />
        </svg>
      </div>

      {/* Content anchored LOW — eyebrow demoted to lune (brass discipline).
          W205 — Protagonist figure with count-up (width reserved, zero CLS).
          data-hero-tally: JS hook below, distinct from data-tally. */}
      <div class="mx-auto w-full max-w-6xl px-4 pb-24 pt-32 sm:pb-32">
        <p class="tech-label v2-kicker rule-brass cine-in text-lune">The study first, the worksite second</p>
        <h1 class="display v2-hero-title cine-in cine-in-1 mt-6 max-w-[15ch]">
          <span data-hero-tally class="font-variant-numeric tabular-nums">{heroFigure}</span>{heroTitleSuffix}
        </h1>
        {/* W267 — money leads, kWh stays the credibility behind it. Honest
            range (never a point figure) derived from the real REGIE marginal
            tariff — see the calculation comment above. */}
        <p class="cine-in cine-in-2 mt-4 max-w-xl text-lg font-bold text-brass-300 sm:text-xl">{heroMoneyLine}</p>
        <p class="v2-lead cine-in cine-in-2 mt-4 max-w-xl text-white/85">{heroSub}</p>
        <div class="cine-in cine-in-3 mt-10 flex flex-wrap items-center gap-3">
          {/* The single brass CTA (brass discipline) — gold is allowed here */}
          <a href={L('/devis/mon-toit')} class="glow-hero bg-brass-400 px-8 py-4 text-lg font-bold text-azur-950 transition-all hover:bg-brass-300">
            Get my free study →
          </a>
          {/* Ghost WhatsApp — white outline, no brass */}
          <a href={waDirect} rel="noopener" class="inline-flex items-center gap-2 border border-white/40 px-6 py-3.5 text-base font-semibold text-white backdrop-blur-sm transition-colors hover:border-white hover:bg-white/10">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 0 0-8.6 15.1L2 22l5-1.3A10 10 0 1 0 12 2Zm5.4 14.1c-.2.6-1.3 1.2-1.8 1.2-.5.1-1 .2-3.3-.7-2.8-1.1-4.6-4-4.7-4.2-.1-.2-1.1-1.5-1.1-2.9s.7-2 1-2.3c.2-.3.5-.3.7-.3h.5c.2 0 .4 0 .6.4l.9 2.1c.1.2.1.4 0 .6l-.4.6-.5.5c-.2.2-.3.4-.1.7.2.3.9 1.4 1.9 2.3 1.3 1.1 2.3 1.5 2.6 1.6.3.1.5.1.7-.1l1-1.2c.2-.3.4-.2.7-.1l2 1c.3.1.5.2.6.4 0 .1 0 .7-.3 1.4Z"/></svg>
            WhatsApp direct
          </a>
        </div>
      </div>
    </section>

    {/* ── HOW IT WORKS — 4-step band under the hero (W252). Answers "what
        happens after the form?" right away: the same 4 stages as the fuller
        timeline further down, condensed. ── */}
    <div class="seam-soft" aria-hidden="true"></div>
    <section class="px-4 py-14 sm:py-18">
      <div class="mx-auto max-w-6xl">
        <h2 class="tech-label v2-kicker rule-brass text-lune text-center sm:text-left">How it works</h2>
        <ol class="mt-8 grid gap-x-6 gap-y-10 sm:grid-cols-2 lg:grid-cols-4" data-stagger>
          {howItWorks.map((s, i) => (
            <li class="v2-rise relative border-t-2 border-white/10 pt-5" style={`--v2-i:${i}`}>
              <span class="absolute -top-px left-0 h-0.5 w-10 bg-brass-400" aria-hidden="true"></span>
              <span class="fig lum text-2xl">{s.n}</span>
              <h3 class="display mt-2 text-lg text-white">{s.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-lune-soft">{s.body}</p>
            </li>
          ))}
        </ol>
      </div>
    </section>

    {/* Warranty promise up top — a true, strong commitment, taken from
        /garanties (25-year performance) and the measured Deye Cloud monitoring. */}
    <div class="seam-soft" aria-hidden="true"></div>
    <section class="bg-brass-400/5 px-4 py-6">
      <p class="mx-auto flex max-w-6xl flex-wrap items-center justify-center gap-x-3 gap-y-1 text-center text-sm font-semibold text-lune sm:text-base">
        <span class="text-brass-300">25-year performance warranty</span>
        <span class="text-lune-faint" aria-hidden="true">·</span>
        <span>production measured, not promised — Deye Cloud monitoring on every installation</span>
      </p>
    </section>

    {/* ── 2 · PROOF GALLERY — the light comes from the photos. Equal-height grid
        (uniform 4/3 cards); each card carries city · kWc · measured production
        (where published) · equipment. "Golden hour" grade (.v3-grade) on the
        content photos. Eyebrow demoted to lune. ── */}
    <div class="seam-soft" aria-hidden="true"></div>
    <section class="section px-4">
      <div class="mx-auto max-w-6xl">
        <div class="flex flex-wrap items-end justify-between gap-4">
          <div class="v2-rise">
            <p class="tech-label text-lune">Recent installations</p>
            <h2 class="display v2-section-title mt-5 text-white">Our latest installations</h2>
          </div>
          <p class="v2-rise max-w-sm text-sm leading-relaxed text-lune-soft">
            Data from the technical files. Clarity and framing adjusted —
            nothing added, nothing erased.
          </p>
        </div>
        {/* W271 — City filter chips, light client-side over the data the
            cards already carry (no new data). "All" active by default;
            aria-pressed reflects state for screen readers. Works without
            JS: without the script, every card stays visible (progressive
            enhancement). */}
        <div class="v2-rise mt-8 flex flex-wrap gap-2" role="group" aria-label="Filter by city" data-gallery-filter>
          {galleryCities.map((c, i) => (
            <button
              type="button"
              class={`gallery-filter-chip border px-4 py-2 text-xs font-bold uppercase tracking-wide transition-colors hover:border-white/50 hover:text-white ${i === 0 ? 'gallery-filter-chip-active border-brass-400 bg-brass-400/10 text-brass-300' : 'border-white/25 text-lune-soft'}`}
              data-city={c}
              aria-pressed={i === 0 ? 'true' : 'false'}
            >
              {c}
            </button>
          ))}
        </div>
        <div class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-3" data-stagger data-gallery-grid>
          {gallery.map((g, i) => (
            <div class="v2-rise cine-card cine-card-link group relative overflow-hidden" style={`--v2-i:${i % 3}`} data-gallery-card data-city={g.ville}>
              <a href={L(`/realisations/${g.slug}`)} class="absolute inset-0 z-0" aria-label={`View the installation: ${g.ville}, ${g.kwc}`}></a>
              {/* Uniform "golden hour" grade — .v3-grade on the content photo */}
