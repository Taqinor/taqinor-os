---
/**
 * EN — Homepage (W67). Faithful translation of the FR homepage (/) into natural
 * English. No figure, %, year, kWc/kWh, MAD amount, brand name, law number
 * (82-21) or legal line is invented, dropped or altered — Western/Latin digits
 * stay exactly as FR. Every internal link goes through localizeNavHref so it
 * lands on the EN page when one exists, else falls back to the existing FR page
 * (never a dead link). The FR homepage is untouched. The DiagnosticForm and its
 * lead data flow are locale-agnostic (the shared component reads the locale
 * from the URL) — mounted exactly as on the FR home.
 */
import Layout from '../../layouts/Layout.astro';
import V2Enhance from '../../components/V2Enhance.astro';
import Article33Ribbon from '../../components/Article33Ribbon.astro';
import DiagnosticForm from '../../components/DiagnosticForm.astro';
import Faq from '../../components/Faq.astro';
import Picture from '../../components/Picture.astro';
import VideoChantier from '../../components/VideoChantier.astro';
import StickyCta from '../../components/StickyCta.astro';
import WhatsAppMock from '../../components/WhatsAppMock.astro';
import GarantiesTeaser from '../../components/GarantiesTeaser.astro';
import Testimonials from '../../components/Testimonials.astro';
import FounderPortrait from '../../components/FounderPortrait.astro';
import BrandStrip from '../../components/BrandStrip.astro';
import { WHATSAPP_LEADS } from '../../lib/nap';
import { whatsappLink } from '../../lib/whatsapp';
import { getLocaleFromPath } from '../../i18n/utils';
import { localizeNavHref } from '../../i18n/pages';

const locale = getLocaleFromPath(Astro.url.pathname);
const L = (href: string) => localizeNavHref(href, locale);
const diagHref = '#simulateur';

const waDirect = whatsappLink(WHATSAPP_LEADS, 'Hello, I would like a study for a solar installation.');

const heroTitle = '21 406 kWh a year, produced on a rooftop in El Jadida.';
const heroSub =
  'Installation ref. 468 — 17,04 kWc, sized, installed and measured by Taqinor. Yours starts with a 60-second diagnostic.';

// PLACEHOLDER(MERYEM): provisional FAQ.
const faq = [
  { q: 'How much does a residential solar installation cost?', a: 'It depends on your consumption and your roof. A villa with a bill of 1 500 MAD per month typically gets a 4 to 6 kWc system. The diagnostic below gives you an immediate range; the precise quote is set after a technical visit.' },
  { q: 'What does Law 82-21 say for households?', a: 'At low voltage, an installation under 11 kW falls under the declaration regime: a prior formality, not an authorisation. Taqinor prepares and files the declaration for you.' },
  { q: 'My existing installation is not declared. What should I do?', a: 'Article 33 of Law 82-21 opens a regularisation window for existing installations. The window is open: file now. See the Regularisation page for the 5-step procedure.' },
  { q: 'How long do the panels last?', a: 'Panels carry a 25-year performance warranty (generally ≥ 84,8 % of the initial output at 25 years). Inverters are typically replaced once over the lifetime of the installation.' },
  { q: 'Do I need batteries?', a: 'Not necessarily. If your consumption is mostly during the day, direct self-consumption is the best investment. Batteries are justified for night-time consumption or service continuity — we calculate it in the study.' },
];

const gallery = [
  { name: 'reflet-468', alt: 'The sun reflects off the row of panels during the install, El Jadida', widths: [1600, 1024, 640], ratio: 3 / 2, ville: 'El Jadida', kwc: '17,04 kWc', prod: '21 406 kWh/yr', type: '24 × Canadian Solar 710 Wc · Deye 15 kW', slug: 'el-jadida-17-kwc' },
  { name: 'equipe-trois', alt: 'Taqinor team in front of the long row of panels at the end of the job, El Jadida', widths: [1600, 1024, 640], ratio: 3 / 2, ville: 'El Jadida', kwc: '17,04 kWc', prod: null, type: 'Job complete · Taqinor team', slug: 'el-jadida-17-kwc' },
  { name: 'hero-skyline', alt: 'Row of solar panels in front of the Casablanca skyline and a minaret, golden light', widths: [2000, 1280, 768, 480], ratio: 16 / 9, ville: 'Casablanca', kwc: '11,36 kWc', prod: '14 271 kWh/yr', type: '16 × Canadian Solar 710 Wc · Deye 10 kW', slug: 'casablanca-11-kwc' },
  { name: 'portrait-400', alt: 'The engineer in front of the panel array, Casablanca skyline', widths: [1600, 1024, 640], ratio: 4 / 3, ville: 'Casablanca', kwc: '11,36 kWc', prod: null, type: 'Measured production — Deye Cloud', slug: 'casablanca-11-kwc' },
  { name: 'champ-villa', alt: 'Array of eight panels on a flat villa roof, El Jadida', widths: [1600, 1024, 640], ratio: 3 / 2, ville: 'El Jadida', kwc: '5,68 kWc', prod: '7 135 kWh/yr', type: '8 × Canadian Solar 710 Wc · Deye 5 kW', slug: 'el-jadida-6-kwc' },
  { name: 'pose-134', alt: 'The team tilts a panel during the install, Casablanca', widths: [1600, 1024, 640], ratio: 4 / 3, ville: 'Casablanca', kwc: '5,68 kWc', prod: '7 135 kWh/yr', type: 'Install in progress · 8 × Canadian Solar 710 Wc', slug: 'casablanca-6-kwc' },
  { name: 'equipe-gilet-taqinor', alt: 'Installer in a Taqinor vest fitting the rails of a structure, Nouaceur', widths: [1600, 1024, 640], ratio: 1, ville: 'Nouaceur', kwc: '3,72 kWc', prod: null, type: 'Fitting the rails · 6 × JA Solar', slug: 'nouaceur-4-kwc' },
  { name: 'entretien-jet', alt: 'Jet-wash cleaning of the panel array, Nouaceur', widths: [1600, 1024, 640], ratio: 1, ville: 'Nouaceur', kwc: '3,72 kWc', prod: null, type: 'Array maintenance · 6 × JA Solar', slug: 'nouaceur-4-kwc' },
];

// Our solutions — every offering visible from the homepage, not only in the
// menu. Descriptions from the already-published positioning, no new claim or
// figure. Text cards (no image) → zero CLS.
const solutions = [
  { href: '/résidentiel', tag: 'Villas & apartments', title: 'Residential solar', body: 'Sized to your real bill, Law 82-21 declaration included.' },
  { href: '/professionnel', tag: 'Industry · hotels · clinics', title: 'Business solar', body: 'Cutting your electricity costs, medium voltage, Law 82-21 compliance.' },
  { href: '/pompage-solaire', tag: 'Agriculture & irrigation', title: 'Solar pumping', body: 'Pumping with the sun, often without batteries, sized to the real need.' },
  { href: '/batteries-stockage', tag: 'Self-consumption', title: 'Batteries & storage', body: 'LFP storage for the evening or service continuity — when the study justifies it.' },
  { href: '/maintenance-monitoring', tag: 'After the install', title: 'Maintenance & monitoring', body: 'Deye Cloud supervision with client access, proactive after-sales, technical file.' },
  { href: '/regularization-article-33', tag: 'Bringing into compliance', title: 'Law 82-21 regularisation', body: 'Regularising existing installations via Article 33.' },
];

// The real journey, end to end. Facts already published on the site (60-second
// diagnostic, WhatsApp exchange, free visit & study, install, commissioning,
// Deye Cloud monitoring with client access). No invented delay/SLA.
const journey = [
  { n: '1', title: '60-second diagnostic', body: 'An immediate range from your bill, with no commitment.' },
  { n: '2', title: 'WhatsApp exchange', body: 'Straight to the technical team, roof photos in hand — no call centre.' },
  { n: '3', title: 'Technical visit & free study', body: 'On-site roof reading, complete study and a 0 MAD quote.' },
  { n: '4', title: 'Installation', body: 'Tier-1 equipment installed with its complete technical file.' },
  { n: '5', title: 'Commissioning', body: 'Connection, checks, and the Law 82-21 file carried through to the end.' },
  { n: '6', title: 'Deye Cloud monitoring', body: 'Production read continuously, client access included: you read your kWh at the source.' },
];

// Sober iconography for the "Our solutions" cards: one SVG line per card,
// currentColor (brass tint), in the brand language. Keyed by href so it stays
// stable even if the card order changes.
const solutionIcons: Record<string, string> = {
  '/résidentiel': '<path d="M4 13 12 5l8 8" /><path d="M6 11v8h12v-8" /><path d="M10 19v-4h4v4" />',
  '/professionnel': '<path d="M4 21V8l7-3v4l7-3v15" /><path d="M4 21h16" /><path d="M8 12h0M8 16h0M14 12h0M14 16h0" />',
  '/pompage-solaire': '<path d="M12 3v6" /><path d="M5 21c1.6-2 3.2-2 4.8 0s3.2 2 4.8 0 3.2-2 4.4 0" /><path d="M8 9h8l-2 6H10z" />',
  '/batteries-stockage': '<path d="M5 8h14v11H5z" /><path d="M9 5h6v3H9z" /><path d="M12 11v5" /><path d="M9.5 13.5h5" />',
  '/maintenance-monitoring': '<path d="M4 18 9 12l3 3 4-6 4 5" /><path d="M4 21h16" /><circle cx="9" cy="12" r="0.6" /><circle cx="16" cy="9" r="0.6" />',
  '/regularization-article-33': '<path d="M7 4h7l4 4v12H7z" /><path d="M14 4v4h4" /><path d="M9.5 14l1.5 1.5 3-3.5" />',
};
---

<Layout
  title="Taqinor — Solar installations in Morocco, Law 82-21 compliant"
  description="Design, installation and declaration of solar installations for villas, industry and hotels in Morocco. Free study, engineering-led sizing, Law 82-21 compliance."
  ogSlug="accueil"
  preloadHeroPoster
>
  <div class="v2">
    <V2Enhance />
    <Article33Ribbon />

    <!-- ACT I — the dark room: the video IS the hero, light parallax -->
    <section class="relative isolate flex min-h-[92svh] flex-col justify-end overflow-hidden text-white">
      <div class="v2-hero-media absolute inset-0 -z-10">
        <picture>
          <source type="image/avif" sizes="100vw"
            srcset="/videos/hero-poster-540.avif 540w, /videos/hero-poster-720.avif 720w, /videos/hero-poster-1080.avif 1080w, /videos/hero-poster-1600.avif 1600w" />
          <source type="image/webp" sizes="100vw"
            srcset="/videos/hero-poster-540.webp 540w, /videos/hero-poster-720.webp 720w, /videos/hero-poster-1080.webp 1080w, /videos/hero-poster-1600.webp 1600w" />
          <img src="/videos/hero-poster-1600.webp" alt="" width="1600" height="900"
            loading="eager" decoding="async" fetchpriority="high"
            class="h-full w-full object-cover" />
        </picture>
        <video id="hero-video" muted loop playsinline preload="none" aria-hidden="true" tabindex="-1"
          class="absolute inset-0 h-full w-full object-cover opacity-0 transition-opacity duration-700"></video>
        <div class="absolute inset-0 bg-gradient-to-t from-nuit via-nuit/35 to-transparent"></div>
      </div>
      <div class="mx-auto w-full max-w-6xl px-4 pb-20 pt-32 sm:pb-28">
        <p class="tech-label v2-kicker rule-brass cine-in text-brass-300">The study first, the worksite second</p>
        <h1 class="display v2-hero-title cine-in mt-6 max-w-[15ch] [animation-delay:120ms]">{heroTitle}</h1>
        <p class="v2-lead cine-in mt-6 max-w-xl text-white/85 [animation-delay:240ms]">{heroSub}</p>
        <div class="cine-in mt-10 flex flex-wrap items-center gap-3 [animation-delay:360ms]">
          <a href={diagHref} class="glow bg-brass-400 px-7 py-3.5 text-base font-bold text-azur-950 transition-all hover:bg-brass-300">
            Get your study on WhatsApp
          </a>
          <a href={waDirect} rel="noopener" class="inline-flex items-center gap-2 border border-white/40 px-6 py-3.5 text-base font-semibold text-white backdrop-blur-sm transition-colors hover:border-white hover:bg-white/10">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 0 0-8.6 15.1L2 22l5-1.3A10 10 0 1 0 12 2Zm5.4 14.1c-.2.6-1.3 1.2-1.8 1.2-.5.1-1 .2-3.3-.7-2.8-1.1-4.6-4-4.7-4.2-.1-.2-1.1-1.5-1.1-2.9s.7-2 1-2.3c.2-.3.5-.3.7-.3h.5c.2 0 .4 0 .6.4l.9 2.1c.1.2.1.4 0 .6l-.4.6-.5.5c-.2.2-.3.4-.1.7.2.3.9 1.4 1.9 2.3 1.3 1.1 2.3 1.5 2.6 1.6.3.1.5.1.7-.1l1-1.2c.2-.3.4-.2.7-.1l2 1c.3.1.5.2.6.4 0 .1 0 .7-.3 1.4Z"/></svg>
            WhatsApp direct
          </a>
        </div>
      </div>
    </section>

    <!-- Warranty promise up top: a true, strong commitment, taken from
         /garanties (25-year performance) and the measured Deye Cloud monitoring. -->
    <section class="border-y border-white/10 bg-brass-400/5 px-4 py-6">
      <p class="mx-auto flex max-w-6xl flex-wrap items-center justify-center gap-x-3 gap-y-1 text-center text-sm font-semibold text-lune sm:text-base">
        <span class="text-brass-300">25-year performance warranty</span>
        <span class="text-lune-faint" aria-hidden="true">·</span>
        <span>production measured, not promised — Deye Cloud monitoring on every installation</span>
      </p>
    </section>

    <!-- Trust strip — four proofs, revealed in cascade -->
    <section class="border-y border-white/10 px-4 py-16 sm:py-20">
      <dl class="mx-auto grid max-w-6xl gap-x-6 gap-y-10 sm:grid-cols-2 lg:grid-cols-4" data-stagger>
        <div class="v2-rise" style="--v2-i:0">
          <dd class="font-display text-xl font-bold text-white">Worksites you can visit</dd>
          <dt class="mt-2 text-sm leading-snug text-lune-soft">Real installations to see on request — Casablanca, El Jadida, Nouaceur</dt>
        </div>
        <div class="v2-rise" style="--v2-i:1">
          <dd class="fig lum whitespace-nowrap text-4xl" data-tally>43,48 kWc</dd>
          <dt class="mt-2 text-sm leading-snug text-lune-soft">installed — Casablanca, El Jadida, Nouaceur</dt>
        </div>
        <div class="v2-rise" style="--v2-i:2">
          <dd class="font-display text-xl font-bold text-white">Doctor-engineer</dd>
          <dt class="mt-2 text-sm leading-snug text-lune-soft">10+ years of R&D expertise — every study validated by the founder</dt>
        </div>
        <div class="v2-rise" style="--v2-i:3">
          <dd class="font-display text-xl font-bold text-white">Measured production</dd>
          <dt class="mt-2 text-sm leading-snug text-lune-soft">Deye Cloud monitoring on every installation, client access included</dt>
        </div>
      </dl>
    </section>

    <!-- The argument in figures — numbers that count up -->
    <section class="mx-auto grid max-w-6xl gap-12 px-4 py-20 sm:py-28 lg:grid-cols-[1fr_1.1fr] lg:items-center">
      <div class="v2-rise">
        <p class="tech-label v2-kicker rule-brass text-brass-300">The argument, in figures</p>
        <h2 class="display v2-section-title mt-5 max-w-md text-white">The return, worked out before installation</h2>
        <p class="v2-lead mt-5 max-w-md text-lune-soft">
          A well-sized installation covers most of your bill for twenty-five years.
          The calculation starts from your real consumption, and it is the calculation
          that decides the equipment — never the other way around.
        </p>
      </div>
      <dl class="grid grid-cols-2 gap-x-6 gap-y-12 border-l-2 border-brass-400/60 pl-6 sm:pl-10" data-stagger>
        <div class="v2-rise" style="--v2-i:0">
          <dd class="fig lum whitespace-nowrap text-3xl sm:text-5xl xl:text-6xl" data-tally>60–90 %</dd>
          <dt class="tech-label mt-2 text-lune-faint">Of the bill covered</dt>
        </div>
        <div class="v2-rise" style="--v2-i:1">
          <dd class="fig lum whitespace-nowrap text-3xl sm:text-5xl xl:text-6xl" data-tally>3–7 yrs</dd>
          <dt class="tech-label mt-2 text-lune-faint">Return on investment</dt>
        </div>
        <div class="v2-rise" style="--v2-i:2">
          <dd class="fig lum whitespace-nowrap text-3xl sm:text-5xl xl:text-6xl" data-tally>25 yrs</dd>
          <dt class="tech-label mt-2 text-lune-faint">Performance warranty</dt>
        </div>
        <div class="v2-rise" style="--v2-i:3">
          <dd class="fig lum whitespace-nowrap text-3xl sm:text-5xl xl:text-6xl" data-tally>0 MAD</dd>
          <dt class="tech-label mt-2 text-lune-faint">The study and the diagnostic</dt>
        </div>
      </dl>
    </section>

    <!-- The founder: a strong trust signal, photo-ready component (identical
         text fallback until Reda Kasri's portrait is dropped in). No invented image. -->
    <FounderPortrait />

    <!-- ACT II — Two trades: the photos are the light -->
    <section class="px-4 py-20 sm:py-28">
      <div class="mx-auto max-w-6xl">
        <p class="tech-label v2-kicker rule-brass text-brass-300">Two trades</p>
        <h2 class="display v2-section-title mt-5 max-w-xl text-white">One engineering standard, from the house to the factory</h2>
        <div class="mt-12 grid gap-6 md:grid-cols-2" data-stagger>
          <a href={L('/résidentiel')} class="v2-rise group relative block overflow-hidden" style="--v2-i:0">
            <Picture name="crepuscule-penthouse" alt="Taqinor residential solar installation at dusk, white penthouse and solar water heater"
              widths={[1600, 1024, 640]} ratio={4 / 3} sizes="(min-width: 768px) 50vw, 100vw"
              class="aspect-[4/3] w-full object-cover transition-transform duration-700 group-hover:scale-[1.04]" />
            <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-nuit/95 to-transparent px-6 pb-5 pt-16 text-white">
              <p class="tech-label text-brass-300">Villas · apartments</p>
              <h3 class="display mt-1 text-2xl">Residential</h3>
              <span class="mt-2 inline-block border-b-2 border-brass-400 pb-0.5 text-sm font-bold">See residential →</span>
            </div>
          </a>
          <a href={L('/professionnel')} class="v2-rise group relative block overflow-hidden" style="--v2-i:1">
            <Picture name="industriel-couchant" alt="Taqinor industrial solar worksite at sunset, double row of panels"
              widths={[2000, 1280, 768, 480]} ratio={16 / 9} sizes="(min-width: 768px) 50vw, 100vw"
              class="aspect-[4/3] w-full object-cover transition-transform duration-700 group-hover:scale-[1.04]" />
            <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-nuit/95 to-transparent px-6 pb-5 pt-16 text-white">
              <p class="tech-label text-brass-300">Industry · hotels · clinics</p>
              <h3 class="display mt-1 text-2xl">Business</h3>
              <span class="mt-2 inline-block border-b-2 border-brass-400 pb-0.5 text-sm font-bold">See business →</span>
            </div>
          </a>
        </div>
      </div>
    </section>

    <!-- Our solutions — the whole offering, beyond the two segments -->
    <section class="border-t border-white/10 px-4 py-20 sm:py-28">
      <div class="mx-auto max-w-6xl">
        <p class="tech-label v2-kicker rule-brass text-brass-300">Our solutions</p>
        <h2 class="display v2-section-title mt-5 max-w-xl text-white">Everything we install</h2>
        <p class="v2-lead mt-5 max-w-2xl text-lune-soft">
          Beyond residential and business: agricultural pumping, storage, production
          monitoring and bringing into compliance. Every solution starts from your real
          situation — it is the study that decides.
        </p>
        <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3" data-stagger>
          {solutions.map((s, i) => (
            <a href={L(s.href)} class="v2-rise cine-card group flex flex-col p-7" style={`--v2-i:${i}`}>
              {/* line pictogram, currentColor (brass), no dependency/image */}
              <svg class="h-9 w-9 text-brass-400 transition-colors group-hover:text-brass-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={solutionIcons[s.href] ?? ''} />
              <p class="tech-label mt-5 text-brass-300">{s.tag}</p>
              <h3 class="display mt-2 text-xl text-white">{s.title}</h3>
              <p class="mt-3 flex-1 text-sm leading-relaxed text-lune-soft">{s.body}</p>
              <span class="mt-5 inline-block border-b-2 border-brass-400 pb-0.5 text-sm font-bold text-white">Discover →</span>
            </a>
          ))}
        </div>
        <a href={L('/nos-solutions')} class="v2-rise mt-10 inline-block border border-white/40 px-6 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">See all our solutions →</a>
      </div>
    </section>

    <!-- Tier-1 brand strip → BrandStrip component: official logos when a file
         exists (public/brands/), styled word-marks as fallback. -->
    <BrandStrip />

    <!-- Proof gallery: the light comes from the photos. Equal-height grid
         (uniform 4/3 cards); each card carries city · kWc · measured production
         (where published) · equipment. -->
    <section class="px-4 py-20 pb-28 sm:py-28 sm:pb-36">
      <div class="mx-auto max-w-6xl">
        <div class="flex flex-wrap items-end justify-between gap-4">
          <div class="v2-rise">
            <p class="tech-label v2-kicker rule-brass text-brass-300">Recent installations</p>
            <h2 class="display v2-section-title mt-5 text-white">Our latest installations</h2>
          </div>
          <p class="v2-rise max-w-sm text-sm leading-relaxed text-lune-soft">
            Data from the technical files. Clarity and framing adjusted —
            nothing added, nothing erased.
          </p>
        </div>
        <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-3" data-stagger>
          {gallery.map((g, i) => (
            <a href={L(`/realisations/${g.slug}`)} class="v2-rise cine-card group relative block overflow-hidden" style={`--v2-i:${i % 3}`}>
              <Picture name={g.name} alt={g.alt} widths={g.widths} ratio={4 / 3} sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
                class="aspect-[4/3] w-full object-cover transition-transform duration-700 group-hover:scale-[1.04]" />
              <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-nuit/95 to-transparent px-4 pb-3 pt-12">
                <span class="tech-label block text-brass-300">{g.ville} · {g.kwc}{g.prod ? ` · ${g.prod}` : ''}</span>
                <span class="mt-0.5 block text-xs text-lune">{g.type}</span>
              </div>
            </a>
          ))}
        </div>
        <a href={L('/realisations')} class="v2-rise mt-10 inline-block border border-white/40 px-6 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">See all our installations →</a>
      </div>
    </section>

    <!-- Client reviews: REAL social proof. Empty today (no invented review) →
         renders nothing until the founder adds real reviews. -->
    <Testimonials />

    <!-- How it works — the complete journey + the WhatsApp preview. The
         end-to-end timeline (diagnostic → monitoring) replaces the small 3-step
         list; the two no longer repeat. Facts already published on the site,
         no invented delay. -->
    <section class="border-t border-white/10 px-4 py-20 sm:py-28">
      <div class="mx-auto max-w-6xl">
        <div class="grid items-center gap-12 lg:grid-cols-[1.1fr_1fr]">
          <div class="v2-rise">
            <p class="tech-label v2-kicker rule-brass text-brass-300">How it works</p>
            <h2 class="display v2-section-title mt-5 max-w-md text-white">The rest happens on WhatsApp</h2>
            <p class="v2-lead mt-5 max-w-md text-lune-soft">
              No call centre, no chasing: your diagnostic arrives on WhatsApp,
              you talk directly with the technical team, roof photos in hand,
              right up to the on-site visit. Sample exchange opposite — anonymised.
            </p>
          </div>
          <div class="v2-rise">
            <WhatsAppMock />
          </div>
        </div>
        <!-- The real journey timeline — from diagnostic to monitoring -->
        <ol class="mt-14 grid gap-x-6 gap-y-8 sm:grid-cols-2 lg:grid-cols-3" data-stagger>
          {journey.map((s, i) => (
