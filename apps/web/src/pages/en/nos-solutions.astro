---
/**
 * EN — Solutions hub (W67). Faithful translation of /nos-solutions ; no new
 * figure or claim. Solution-card links use localizeNavHref so they point to the
 * EN page when it exists, else fall back to the existing FR page (never a dead
 * link). FR untouched.
 *
 * W256/W262 — mirrors the FR additions: a dedicated "Free study & assessment"
 * hub card + section, and an honest "Areas we serve" block.
 *
 * W253 — elevates this into a true services hub: EV-charging card added (the
 * page existed but was invisible here); a "how you finance your project"
 * strip (figures reused VERBATIM from /financement, no new amount); visible
 * cross-links to equipment + warranties ("what you receive"); icons + a
 * one-line "when to choose it" qualifier per card; "Six trades" copy + the
 * JSON-LD `hasPart` recalculated from the real count (`solutions.length`).
 */
import Layout from '../../layouts/Layout.astro';
import V2Enhance from '../../components/V2Enhance.astro';
import Article33Ribbon from '../../components/Article33Ribbon.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CtaBand from '../../components/CtaBand.astro';
import StickyCta from '../../components/StickyCta.astro';
import { getLocaleFromPath } from '../../i18n/utils';
import { localizeNavHref } from '../../i18n/pages';
import { NAP } from '../../lib/nap';

const locale = getLocaleFromPath(Astro.url.pathname);
const L = (href: string) => localizeNavHref(href, locale);
const devisHref = L('/devis/mon-toit');

// W262 — same NAP.serviceArea source of truth, minus the generic 'Maroc' tail.
const villesDesservies = NAP.serviceArea.slice(0, -1);

const solutions = [
  {
    href: '/devis/mon-toit',
    title: 'Free study & assessment',
    summary:
      'Free, no obligation: a 3D design of your roof included, sized to your real bill — the starting point for every solution.',
    qualifier: 'Choose this one first — it points to all the others.',
    highlight: true,
  },
  {
    // W348 — named "bill" entry into the same quote journey, pre-set to the
    // bill step via ?etape=facture (query appended after localizeNavHref so
    // the lookup itself always uses the clean root path).
    // TODO(follow-up, out of scope here): /devis/mon-toit does not yet read
    // ?etape=facture to jump straight to the bill panel (see
    // apps/web/src/pages/devis/mon-toit.astro — wizard `step` is only
    // restored from sessionStorage). The link lands on the roof step (0)
    // today, same as any other link into this journey; wiring the param is a
    // separate follow-up since that file is outside this task's scope.
    href: '/devis/mon-toit',
    query: '?etape=facture',
    title: 'Free bill analysis',
    summary:
      'Enter your ONEE bill amount: we pull your real consumption and an instant costed range from it, without going through the roof survey first.',
    qualifier: 'Choose this if you haven’t measured your roof yet, but have your bill handy.',
  },
  {
    href: '/résidentiel',
    title: 'Residential solar',
    summary:
      'Villa or apartment: we size to your bill, not to a kit, and the Law 82-21 declaration goes out with the project.',
    qualifier: 'For a home — the Law 82-21 declaration is included.',
  },
  {
    href: '/professionnel',
    title: 'Business & industrial solar',
    summary:
      'Warehouses, factories, hotels, clinics: we go after the electricity bill, medium voltage if needed, within the rules of Law 82-21.',
    qualifier: 'For a business site — up to medium voltage if needed.',
  },
  {
    href: '/pompage-solaire',
    title: 'Solar pumping',
    summary:
      'Irrigation with the sun, most often without batteries, set to flow rate and total head — and VAT-exempt for agriculture.',
    qualifier: 'For agricultural irrigation — sized to your real flow rate and head.',
  },
  {
    href: '/batteries-stockage',
    title: 'Batteries & storage',
    summary:
      'Dyness LFP batteries for the evening dip or service continuity, when your consumption curve justifies it.',
    qualifier: 'Add this if your usage is mostly at night, or an outage costs you dearly.',
  },
  {
    // W253 — page existed but had no inbound link from this hub.
    href: '/recharge-voiture-electrique-solaire',
    title: 'Solar EV charging',
    summary:
      'Charge your electric car with the energy your own roof produces, instead of paying full grid rate.',
    qualifier: 'For a household that drives (or is about to drive) electric.',
  },
  {
    href: '/maintenance-monitoring',
    title: 'Maintenance & monitoring',
    summary:
      'Deye Cloud supervision with client access, after-sales that acts on alerts and a complete technical file — life after install.',
    qualifier: 'Included after install — also worth it for an existing, unmonitored installation.',
  },
  {
    href: '/regularization-article-33',
    title: 'Law 82-21 regularisation',
    summary:
      'An existing installation brought back into line via Article 33.',
    qualifier: 'If your existing installation was never declared.',
  },
];

// W253 — same icon set as the FR page (index.astro `solutionIcons`), keyed by
// root href so query-string variants (e.g. ?etape=facture) still resolve.
const solutionIcons: Record<string, string> = {
  '/devis/mon-toit': '<path d="M4 13 12 5l8 8" /><path d="M6 11v8h12v-8" /><path d="M10 19v-4h4v4" /><path d="M9 9.5 12 8l3 1.5" />',
  '/résidentiel': '<path d="M4 13 12 5l8 8" /><path d="M6 11v8h12v-8" /><path d="M10 19v-4h4v4" />',
  '/professionnel': '<path d="M4 21V8l7-3v4l7-3v15" /><path d="M4 21h16" /><path d="M8 12h0M8 16h0M14 12h0M14 16h0" />',
  '/pompage-solaire': '<path d="M12 3v6" /><path d="M5 21c1.6-2 3.2-2 4.8 0s3.2 2 4.8 0 3.2-2 4.4 0" /><path d="M8 9h8l-2 6H10z" />',
  '/batteries-stockage': '<path d="M5 8h14v11H5z" /><path d="M9 5h6v3H9z" /><path d="M12 11v5" /><path d="M9.5 13.5h5" />',
  '/maintenance-monitoring': '<path d="M4 18 9 12l3 3 4-6 4 5" /><path d="M4 21h16" /><circle cx="9" cy="12" r="0.6" /><circle cx="16" cy="9" r="0.6" />',
  '/regularization-article-33': '<path d="M7 4h7l4 4v12H7z" /><path d="M14 4v4h4" /><path d="M9.5 14l1.5 1.5 3-3.5" />',
};
function iconFor(href: string): string {
  if (solutionIcons[href]) return solutionIcons[href];
  if (href === '/recharge-voiture-electrique-solaire') {
    return '<path d="M4 17V9a2 2 0 0 1 2-2h6l3 4h3a2 2 0 0 1 2 2v4" /><circle cx="7.5" cy="17.5" r="1.6" /><circle cx="16.5" cy="17.5" r="1.6" /><path d="M11 12v-5" /><path d="M9.5 7.5h3" />';
  }
  return '';
}

// W253 — the count is derived from `solutions.length` (single source of
// truth), never copied by hand, so prose and JSON-LD can never silently diverge.
const solutionsCount = solutions.length;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Our solar solutions — Taqinor',
  hasPart: solutions.map((s) => ({
    '@type': 'Service',
    name: s.title,
    url: new URL(s.href, Astro.site).href,
  })),
};
---

<Layout
  title="Our solar solutions in Morocco | Taqinor"
  description="The whole Taqinor offer at a glance: free study, residential solar, business & industrial, agricultural pumping, EV charging, LFP batteries & storage, Deye Cloud maintenance & monitoring, and Law 82-21 regularisation. One shared starting point for every solution — your real, measured situation."
  ogSlug="nos-solutions"
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <div class="v2">
    <V2Enhance />
    <Article33Ribbon />

    <Breadcrumb items={[{ label: 'Home', href: L('/') }, { label: 'Our solutions' }]} />

    <section class="px-4 pb-10 pt-16 text-white sm:pt-20">
      <div class="mx-auto max-w-3xl">
        <p class="tech-label v2-kicker rule-brass cine-in text-lune">Our solutions</p>
        <h1 class="display v2-page-title cine-in mt-5 [animation-delay:120ms]">A solar offer for every need</h1>
        {/* W253 — count derived from `solutions.length`, never hand-copied. */}
        <p class="v2-lead cine-in mt-6 max-w-xl text-white/85 [animation-delay:240ms]">
          A villa and a warehouse aren't sized the same way; agricultural pumping and the
          regularisation of an existing installation follow rules of their own again. {solutionsCount}
          distinct solutions, then — but all of them begin in the same place: your situation,
          measured, before a single piece of equipment is chosen. Here they are.
        </p>
      </div>
    </section>

    <section class="px-4 pb-24 sm:pb-32">
      <div class="mx-auto grid max-w-6xl gap-6 md:grid-cols-3" data-stagger>
        {solutions.map((s, i) => (
          <a href={`${L(s.href)}${s.query ?? ''}`} class={`v2-rise cine-card group flex flex-col p-7 ${s.highlight ? 'border-2 border-brass-400/70' : ''}`} style={`--v2-i:${i}`}>
            <svg class="h-9 w-9 text-brass-400 transition-colors group-hover:text-brass-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={iconFor(s.href)} />
            <p class="tech-label mt-5 text-lune">{s.highlight ? 'Free · no obligation' : 'Solution'}</p>
            <h2 class="display mt-2 text-xl text-white" set:html={s.title.replace('&', '&amp;')} />
            <p class="mt-3 flex-1 text-sm leading-relaxed text-lune-soft">{s.summary}</p>
            <p class="mt-4 border-t border-white/10 pt-3 text-xs text-brass-300/90">{s.qualifier}</p>
            <span class="mt-5 inline-flex items-center gap-1 border-b-2 border-white/30 pb-0.5 text-sm font-bold text-white">Discover <span class="motion-safe:transition-transform motion-safe:duration-200 motion-safe:group-hover:translate-x-1" aria-hidden="true">→</span></span>
          </a>
        ))}
      </div>
    </section>

    {/* W256 — the study sold as a full product, not a process step */}
    <section class="border-y border-white/10 px-4 py-16 sm:py-20">
      <div class="mx-auto max-w-3xl text-center">
        <p class="tech-label v2-kicker rule-brass text-lune">The starting point, on us</p>
        <h2 class="display v2-section-title mt-5 text-white">The study & assessment are free — and no obligation</h2>
        <p class="v2-lead mt-5 text-lune-soft">
          Before any equipment choice, we start from your real bill and your actual roof. The 3D
          design of your roof is included, and so is the instant costed range: nothing commits you to
          go further.
        </p>
        <div class="mx-auto mt-10 grid max-w-2xl gap-4 sm:grid-cols-3" data-stagger>
          <div class="v2-rise border-t-2 border-brass-400/60 pt-4" style="--v2-i:0">
            <p class="fig lum text-2xl">Free</p>
            <p class="mt-1 text-sm text-lune-soft">No fee, no surprise</p>
          </div>
          <div class="v2-rise border-t-2 border-brass-400/60 pt-4" style="--v2-i:1">
            <p class="fig lum text-2xl">No obligation</p>
            <p class="mt-1 text-sm text-lune-soft">You decide after, not before</p>
          </div>
          <div class="v2-rise border-t-2 border-brass-400/60 pt-4" style="--v2-i:2">
            <p class="fig lum text-2xl">3D design included</p>
            <p class="mt-1 text-sm text-lune-soft">Of your own roof, not a template</p>
          </div>
        </div>
        <a href={devisHref} class="mt-10 inline-block bg-brass-400 px-7 py-3.5 text-base font-bold text-azur-950 transition-colors hover:bg-brass-300">Start my free diagnostic</a>
        <p class="mt-6 text-sm text-lune-faint">
          Drive an electric car? See also how to
          <a href={L('/recharge-voiture-electrique-solaire')} class="text-white underline underline-offset-2 hover:text-lune">charge it on solar</a>,
          how much <a href={L('/prix-panneaux-solaires-maroc')} class="text-white underline underline-offset-2 hover:text-lune">solar panels cost in Morocco</a>,
          or browse all our <a href={L('/guides')} class="text-white underline underline-offset-2 hover:text-lune">guides</a> and our <a href={L('/blog')} class="text-white underline underline-offset-2 hover:text-lune">blog</a>.
        </p>
      </div>
    </section>

    {/* W253 — "How you finance your project": figures reused VERBATIM from
        /financement — no new amount here, just a reminder + a link to the
        full detail. */}
    <section class="section px-4">
      <div class="mx-auto max-w-4xl text-center">
        <p class="tech-label v2-kicker rule-brass text-lune">How you finance your project</p>
        <h2 class="display v2-section-title mt-5 text-white">Three ways to pay, none we impose</h2>
        <p class="v2-lead mt-5 text-lune-soft">
          Cash, a classic bank consumer loan, or green financing for businesses — the arrangement is
          between you and your bank; we take no commission on any of it.
        </p>
        <dl class="mx-auto mt-10 grid max-w-2xl grid-cols-2 gap-x-6 gap-y-8 sm:grid-cols-4" data-stagger>
          <div class="v2-rise min-w-0" style="--v2-i:0">
            <dd class="fig fig-md lum whitespace-nowrap">3–7 yrs</dd>
            <dt class="tech-label mt-2 text-lune-faint">Typical return on investment</dt>
          </div>
          <div class="v2-rise min-w-0" style="--v2-i:1">
            <dd class="fig fig-md lum whitespace-nowrap">25 yrs</dd>
            <dt class="tech-label mt-2 text-lune-faint">Panel performance warranty</dt>
          </div>
          <div class="v2-rise min-w-0" style="--v2-i:2">
            <dd class="fig fig-md lum whitespace-nowrap">60–90 %</dd>
            <dt class="tech-label mt-2 text-lune-faint">Of the bill covered</dt>
          </div>
          <div class="v2-rise min-w-0" style="--v2-i:3">
            <dd class="fig fig-md lum whitespace-nowrap">0 MAD</dd>
            <dt class="tech-label mt-2 text-lune-faint">The study and assessment</dt>
          </div>
        </dl>
        <a href={L('/financement')} class="v2-rise group mt-10 inline-flex items-center gap-1 border-b-2 border-white/30 pb-0.5 text-sm font-bold text-white transition-colors hover:border-white">
          See the full financing detail <span class="motion-safe:transition-transform motion-safe:duration-200 motion-safe:group-hover:translate-x-1" aria-hidden="true">→</span>
        </a>
      </div>
    </section>

    {/* W253 — "What you receive" cross-links: equipment + written warranties,
        missing from this hub until now despite answering "what do I actually get?". */}
    <div class="seam-soft" aria-hidden="true"></div>
    <section class="px-4 py-14 sm:py-16">
      <div class="mx-auto max-w-6xl">
        <p class="tech-label v2-kicker rule-brass text-lune">What you receive</p>
        <h2 class="display v2-section-title mt-5 max-w-xl text-white">The equipment installed and the written warranties</h2>
        <div class="mt-8 grid gap-6 sm:grid-cols-2" data-stagger>
          <a href={L('/équipement')} class="v2-rise cine-card group flex flex-col p-7" style="--v2-i:0">
            <p class="tech-label text-lune">Equipment</p>
            <h3 class="display mt-2 text-xl text-white">The equipment installed</h3>
            <p class="mt-3 flex-1 text-sm leading-relaxed text-lune-soft">
              Panels, inverters, batteries: the tier-1 brands actually installed on our projects, spec
              sheet by spec sheet.
            </p>
            <span class="mt-5 inline-flex items-center gap-1 border-b-2 border-white/30 pb-0.5 text-sm font-bold text-white">See the equipment <span class="motion-safe:transition-transform motion-safe:duration-200 motion-safe:group-hover:translate-x-1" aria-hidden="true">→</span></span>
          </a>
          <a href={L('/garanties')} class="v2-rise cine-card group flex flex-col p-7" style="--v2-i:1">
            <p class="tech-label text-lune">Warranties</p>
            <h3 class="display mt-2 text-xl text-white">Our written warranties</h3>
            <p class="mt-3 flex-1 text-sm leading-relaxed text-lune-soft">
              25 years of performance warranty on the panels, and the written detail of what's covered
              on the rest of the equipment and the install.
            </p>
            <span class="mt-5 inline-flex items-center gap-1 border-b-2 border-white/30 pb-0.5 text-sm font-bold text-white">See the warranties <span class="motion-safe:transition-transform motion-safe:duration-200 motion-safe:group-hover:translate-x-1" aria-hidden="true">→</span></span>
          </a>
        </div>
      </div>
    </section>

    {/* W262 — Areas we serve, honestly: Casablanca–Rabat axis (where our real
        projects are) + the other named cities, never an implicit "all of
        Morocco". */}
    <div class="v2-seam" aria-hidden="true"></div>
    <section class="bg-blanc-azur px-4 py-16 text-encre sm:py-20">
      <div class="mx-auto max-w-3xl text-center">
        <p class="tech-label v2-kicker rule-brass eyebrow-light">Areas we serve</p>
        <h2 class="display v2-section-title mt-5">A Casablanca–Rabat axis, and beyond on request</h2>
        <p class="v2-lead mt-5 text-encre-soft">
          Our projects are concentrated on the Casablanca–Rabat axis, where most of our completed
          installations are. We also work in {villesDesservies.slice(2).join(', ')} on request — no
          vague claim of nationwide coverage: every trip is confirmed case by case.
        </p>
        <div class="mx-auto mt-8 flex flex-wrap justify-center gap-2">
          {villesDesservies.map((ville) => (
            <span class="border border-azur-900/20 bg-blanc px-4 py-2 text-sm font-semibold text-azur-700">{ville}</span>
          ))}
        </div>
      </div>
    </section>

    <CtaBand title="It's the diagnostic that points to the right solution. And it's free." href={devisHref} />

    <StickyCta />
  </div>
</Layout>
