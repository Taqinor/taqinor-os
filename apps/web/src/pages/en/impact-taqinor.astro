---
/**
 * EN — Impact Taqinor (W279). Faithful translation of /impact-taqinor ; every
 * figure is DERIVED live from realisations.ts (read-only), exactly like the FR
 * page — no number is hand-typed or re-translated by hand. Internal links use
 * localizeNavHref (EN if it exists, else the FR page — never a dead link).
 * FR untouched.
 *
 * NOTE: this EN route is NOT yet registered in src/i18n/pages.ts
 * (STATIC_TRANSLATED) — that file is out of scope for this task, so the
 * language switcher / hreflang do not surface this page yet. The route itself
 * renders correctly and is a real, indexable page.
 */
import Layout from '../../layouts/Layout.astro';
import V2Enhance from '../../components/V2Enhance.astro';
import Article33Ribbon from '../../components/Article33Ribbon.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import KeyFigure from '../../components/KeyFigure.astro';
import Callout from '../../components/Callout.astro';
import RelatedLinks from '../../components/RelatedLinks.astro';
import CtaBand from '../../components/CtaBand.astro';
import StickyCta from '../../components/StickyCta.astro';
import { getLocaleFromPath } from '../../i18n/utils';
import { localizeNavHref } from '../../i18n/pages';
import { REALISATIONS } from '../../lib/realisations';
import { CO2_KG_PER_KWH, CO2_KG_PER_TREE_YEAR } from '../../lib/proposition';

const locale = getLocaleFromPath(Astro.url.pathname);
const L = (href: string) => localizeNavHref(href, locale);
const devisHref = L('/devis/mon-toit');

// ── Derived figures — nothing hand-typed ─────────────────────────────────────
const installCount = REALISATIONS.length;

const kwcTotal = REALISATIONS.reduce((sum, r) => sum + r.kwcNum, 0);
const kwcTotalLabel = kwcTotal.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });

const withMeasuredProduction = REALISATIONS.filter((r) => r.productionNum !== null);
const productionTotal = withMeasuredProduction.reduce((sum, r) => sum + (r.productionNum ?? 0), 0);
const productionTotalLabel = productionTotal.toLocaleString('en-US');

const co2KgTotal = productionTotal * CO2_KG_PER_KWH;
const co2TonnesTotal = Math.round((co2KgTotal / 1000) * 10) / 10;
const co2TonnesLabel = co2TonnesTotal.toLocaleString('en-US', { minimumFractionDigits: 1, maximumFractionDigits: 1 });

const treesEquivalent = Math.round(co2KgTotal / CO2_KG_PER_TREE_YEAR);
const treesLabel = treesEquivalent.toLocaleString('en-US');

const battersInstalls = REALISATIONS.filter((r) => r.batterie !== null);
const batteryKwhTotal = battersInstalls.reduce((sum, r) => {
  const m = /([\d.,]+)\s*kWh/.exec(r.batterie ?? '');
  return sum + (m ? parseFloat(m[1].replace(',', '.')) : 0);
}, 0);

const villesUniques = [...new Set(REALISATIONS.map((r) => r.ville))];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Taqinor Impact',
  description: `Taqinor's cumulative, measured, honest impact: ${kwcTotalLabel} kWc installed, ${productionTotalLabel} kWh/year of measured production, ${co2TonnesLabel} tonnes of CO2 avoided per year.`,
  isPartOf: { '@type': 'WebSite', name: 'Taqinor', url: 'https://taqinor.ma' },
};
---

<Layout
  title="Taqinor Impact: our real, cumulative, verifiable numbers | Taqinor"
  description={`${kwcTotalLabel} kWc installed, ${productionTotalLabel} kWh/year measured, ${co2TonnesLabel} t of CO2 avoided: the honest tally of our installations, derived from our published projects — nothing estimated, nothing rounded up.`}
  ogSlug="equipement"
>
  <div class="v2">
    <V2Enhance />
    <Article33Ribbon />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <Breadcrumb items={[{ label: 'Home', href: L('/') }, { label: 'Taqinor Impact' }]} />

    <section class="section-lg px-4 pb-10 text-white">
      <div class="mx-auto max-w-3xl">
        <p class="tech-label v2-kicker rule-brass cine-in text-lune">Accountability</p>
        <h1 class="display v2-page-title cine-in cine-in-1 mt-6">Taqinor Impact</h1>
        <p class="v2-lead cine-in cine-in-2 mt-6 max-w-xl text-white/85">
          Not a projection, not a target: what our {installCount} published installations actually
          produce, added up. This page grows project by project — today it is small, on purpose,
          because it only states what we can prove.
        </p>
      </div>
    </section>

    <!-- Key figures — derived live from realisations.ts -->
    <section class="section px-4">
      <div class="mx-auto max-w-6xl">
        <p class="tech-label v2-kicker rule-brass text-lune">The tally today</p>
        <h2 class="display v2-section-title mt-5 text-white">{installCount} installations, one tally</h2>
        <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4" data-stagger>
          <KeyFigure value={kwcTotalLabel} unit="kWc" label="Installed capacity">
            Cumulative total across {installCount} installations in {villesUniques.join(', ')}.
          </KeyFigure>
          <KeyFigure value={productionTotalLabel} unit="kWh/yr" label="Measured production">
            Across {withMeasuredProduction.length} monitored installations (Deye Cloud) — projects
            with no published production figure aren't counted.
          </KeyFigure>
          <KeyFigure value={co2TonnesLabel} unit="t CO2/yr" label="CO2 avoided">
            Calculated at {CO2_KG_PER_KWH} kg CO2/kWh, the Moroccan grid emission factor already
            used in our quoted studies.
          </KeyFigure>
          <KeyFigure value={String(batteryKwhTotal).replace('.', ',')} unit="kWh" label="Cumulative storage">
            Battery capacity installed across {battersInstalls.length} of the {installCount} projects.
          </KeyFigure>
        </div>
        <Callout type="info" title="How this figure is calculated">
          <p>
            CO2 avoided = annual measured production × {CO2_KG_PER_KWH} kg/kWh (the average emission
            factor of the Moroccan electricity grid, a heavily carbon-based mix — the same constant
            shown on every Taqinor quoted study). Tree equivalent: a mature tree absorbs roughly
            {' '}{CO2_KG_PER_TREE_YEAR} kg of CO2 a year, so this works out to roughly{' '}
            <strong>{treesLabel} trees</strong> planted every year. No figure here is rounded up,
            extrapolated, or estimated beyond the installations actually published.
          </p>
        </Callout>
      </div>
    </section>

    <!-- The detail, project by project -->
    <div class="v2-seam" aria-hidden="true"></div>
    <section class="section bg-blanc-azur px-4 text-encre">
      <div class="mx-auto max-w-3xl">
        <p class="tech-label v2-kicker rule-brass text-azur-600">The detail</p>
        <h2 class="display v2-section-title mt-5">Project by project</h2>
        <p class="v2-lead mt-4 text-encre-soft">
          Every line in the tally above corresponds to a real installation, documented on our
          projects page.
        </p>
        <div class="mt-10 border-t-2 border-azur-900 bg-blanc" data-stagger>
          {REALISATIONS.map((r, i) => (
            <div class="v2-rise flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1 border-b border-azur-900/15 px-5 py-4" style={`--v2-i:${i}`}>
              <span class="text-sm font-semibold">{r.ville} · {r.kwc} · ref. {r.ref}</span>
              <span class="whitespace-normal text-right text-sm text-azur-600">
                {r.production ? `${r.production} measured` : 'production not published'}
                {r.batterie ? ` · ${r.batterie}` : ''}
              </span>
            </div>
          ))}
        </div>
        <p class="mx-auto mt-6 max-w-xl border-l-4 border-azur-600 pl-4 text-sm leading-relaxed text-encre-soft">
          <a href={L('/realisations')} class="border-b border-azur-600 pb-0.5 font-semibold text-azur-600 transition-colors hover:text-azur-700">See all our projects in detail →</a>
        </p>
      </div>
    </section>

    <!-- Why this page stays small -->
    <section class="section px-4 text-white">
      <div class="mx-auto max-w-3xl">
        <p class="tech-label v2-kicker rule-brass text-lune">Why so little</p>
        <h2 class="display v2-section-title mt-5 text-white">Small for now, honest always</h2>
        <p class="v2-lead mt-5 text-lune-soft">
          We could pad this tally with theoretical estimates, catalogue yields, or five-year
          projections. We'd rather count only what's already installed, monitored, and published
          — which makes this figure smaller than it could look, but verifiable line by line on our
          projects page. Every newly documented project moves this total forward; that's the only
          way it will grow.
        </p>
      </div>
    </section>

    <section class="section-tight px-4 pb-20 sm:pb-24">
      <div class="mx-auto max-w-6xl">
        <p class="tech-label v2-kicker rule-brass text-lune">To go further</p>
        <RelatedLinks links={[
          { href: L('/realisations'), label: 'Our projects' },
          { href: L('/batteries-stockage'), label: 'Batteries & storage' },
          { href: L('/garanties'), label: 'Warranties' },
          { href: L('/à-propos'), label: 'About Taqinor' },
        ]} />
      </div>
    </section>

    <CtaBand title="A project that could add to this tally? Start the free assessment." href={devisHref} />

    <StickyCta />
  </div>
</Layout>
