---
import Layout from '../layouts/Layout.astro';
import Article33Ribbon from '../components/Article33Ribbon.astro';
import { NAP } from '../lib/nap';
import { whatsappLink, regularizationWhatsappText } from '../lib/whatsapp';

const wa = whatsappLink(NAP.whatsapp, regularizationWhatsappText());

const steps = [
  {
    title: 'Inventaire technique',
    body: 'Relevé de l’installation existante : puissance installée, mode de raccordement, niveau de tension, équipements de protection et de comptage.',
  },
  {
    title: 'Détermination du régime',
    body: 'Selon la puissance et le raccordement, l’installation relève de la déclaration, de l’accord de raccordement ou de l’autorisation (décret 2-25-100).',
  },
  {
    title: 'Constitution du dossier',
    body: 'Fiches techniques, schéma unifilaire, attestations de conformité et formulaires du régime applicable — préparés par nos soins.',
  },
  {
    title: 'Dépôt de la demande de régularisation',
    body: 'Dépôt auprès du gestionnaire de réseau ou de l’autorité compétente, dans le cadre de la fenêtre ouverte par l’Article 33.',
  },
  {
    title: 'Suivi jusqu’à la mise en conformité',
    body: 'Suivi de l’instruction, réponses aux compléments demandés, et le cas échéant mise à niveau technique de l’installation.',
  },
];

const sanctions = [
  {
    title: 'Situation irrégulière',
    body: 'Une installation existante non régularisée est en situation irrégulière au regard de la loi 82-21, désormais en vigueur.',
  },
  {
    title: 'Amendes — article 28',
    body: 'De 2 000 à 5 000 MAD pour exploitation sans la déclaration requise.',
  },
  {
    title: 'Amendes — article 29',
    body: 'De 100 000 à 1 000 000 MAD pour exploitation sans accord de raccordement ou sans autorisation.',
  },
  {
    title: 'Mise en demeure et arrêt — articles 25 et 27',
    body: 'Risque de mise en demeure puis d’arrêt ordonné de l’installation.',
  },
  {
    title: 'Déconnexion du réseau — article 32',
    body: 'Le gestionnaire de réseau peut déconnecter une installation non conforme.',
  },
];
---

<Layout
  title="Régularisation Article 33 — installations solaires existantes | Taqinor"
  description="La loi 82-21 est en vigueur depuis le 9 juin 2026. L'Article 33 ouvre une fenêtre de 18 mois pour régulariser les installations solaires existantes : procédure en 5 étapes, sanctions encourues, prise en charge complète du dossier."
  ogSlug="article-33"
>
  <Article33Ribbon />

  <section class="grid-paper-dark bg-night px-4 py-16 text-paper sm:py-20">
    <div class="mx-auto max-w-6xl">
      <p class="tech-label rule-amber text-amber-400">Loi 82-21 — Article 33</p>
      <h1 class="display mt-4 max-w-2xl text-4xl sm:text-5xl">Votre installation solaire existe déjà ? Régularisez-la maintenant.</h1>
      <p class="mt-5 max-w-xl leading-relaxed text-paper/85">
        Le décret 2-25-100 et la décision ANRE 04/26 sont entrés en vigueur le 9 juin 2026.
        Depuis cette date, le régime de la loi 82-21 s'applique à toutes les installations
        d'autoproduction — y compris celles posées avant la loi.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-3xl px-4 py-14">
    <p class="tech-label rule-amber text-ink-soft">Le texte</p>
    <h2 class="display mt-3 text-3xl">Ce que dit l'Article 33</h2>
    <p class="mt-4 leading-relaxed text-ink-soft">
      L'Article 33 de la loi 82-21 accorde aux exploitants d'installations existantes une
      fenêtre de <strong class="fig text-xl text-ink">18 mois</strong> pour déposer une demande de régularisation.
      Cette fenêtre est ouverte depuis le 9 juin 2026 : déposez maintenant. Une installation
      régularisée est sécurisée juridiquement ; une installation non régularisée est en
      situation irrégulière.
    </p>

    <h2 class="display mt-12 text-3xl">Qui est concerné ?</h2>
    <ul class="mt-4 space-y-2.5 text-sm leading-relaxed text-ink-soft">
      <li class="flex gap-2.5"><span class="font-mono font-medium text-amber-500" aria-hidden="true">+</span><span>Toute installation solaire d'autoproduction mise en service avant l'entrée en vigueur du régime — villa, hangar, hôtel, exploitation agricole.</span></li>
      <li class="flex gap-2.5"><span class="font-mono font-medium text-amber-500" aria-hidden="true">+</span><span>Raccordée au réseau ou en site isolé, quelle que soit la puissance.</span></li>
      <li class="flex gap-2.5"><span class="font-mono font-medium text-amber-500" aria-hidden="true">+</span><span>Sans déclaration, sans accord de raccordement ou sans autorisation au regard du régime applicable.</span></li>
    </ul>

    <h2 class="display mt-12 text-3xl">La régularisation en 5 étapes</h2>
    <ol class="mt-7 border-l-2 border-amber-400">
      {steps.map((s, i) => (
        <li class="reveal relative pb-8 pl-8 last:pb-0">
          <span class="fig absolute -left-5 flex h-10 w-10 items-center justify-center rounded-full bg-amber-400 text-lg text-ink">{i + 1}</span>
          <h3 class="display pt-1.5 text-lg">{s.title}</h3>
          <p class="mt-1.5 text-sm leading-relaxed text-ink-soft">{s.body}</p>
        </li>
      ))}
    </ol>

    <h2 class="display mt-12 text-3xl">Ce que vous risquez en ne faisant rien</h2>
    <p class="mt-2 text-sm text-ink-soft">Sanctions prévues par la loi 82-21 :</p>
    <div class="mt-5 grid gap-4 sm:grid-cols-2">
      {sanctions.map((s) => (
        <div class="reveal border border-alert-600/25 bg-alert-50 p-5">
          <h3 class="font-display text-sm font-bold text-alert-600">{s.title}</h3>
          <p class="mt-1.5 text-sm leading-relaxed text-ink-soft">{s.body}</p>
        </div>
      ))}
    </div>

    <div class="grid-paper-dark mt-12 bg-night p-8 text-center text-paper sm:p-10">
      <p class="tech-label text-amber-400">Prise en charge complète</p>
      <h2 class="display mt-2 text-2xl">Confiez-nous le dossier</h2>
      <p class="mx-auto mt-3 max-w-md text-sm leading-relaxed text-paper/80">
        Envoyez la puissance approximative et la ville de votre installation : nous identifions
        le régime applicable et constituons le dossier de régularisation.
      </p>
      <a
        href={wa}
        rel="noopener"
        class="mt-6 inline-block bg-amber-400 px-8 py-3.5 text-base font-bold text-ink transition-colors hover:bg-amber-300"
      >Démarrer sur WhatsApp</a>
    </div>
  </section>
</Layout>
