---
/**
 * Financement & rentabilité (W26) — page éditoriale « rentabilité d'abord,
 * honnêteté totale ». AUCUN chiffre nouveau : on réutilise uniquement les ordres
 * de grandeur déjà publiés (accueil, résidentiel, professionnel, garanties).
 * Contraintes dures : Taqinor n'est PAS prêteur, aucune subvention résidentielle,
 * pas d'exonération de TVA résidentielle, aucune banque/partenaire/taux nommé.
 * Page publique et indexée. Schéma limité au fil d'Ariane.
 *
 * W258 — Mécanismes marocains NOMMÉS et vérifiés, par segment (WG11) :
 * chaque programme cité ci-dessous a été confirmé via une source primaire
 * (site de l'organisme émetteur ou texte réglementaire) au moment du build.
 * Ce qui n'a pas pu être vérifié — un prêt vert résidentiel packagé par une
 * banque nommée — est explicitement absent : aucune banque n'est citée pour
 * le résidentiel, conformément à la règle « zéro partenariat inventé ».
 * Sources : creditagricole.ma (Saquii Solaire), agrimaroc.ma/casainvest.ma
 * (guide FDA 2024), maghrebail.ma (Energy Lease), fiscamaroc.com (art. 123-22°
 * CGI). Taux/montants non publiés par l'émetteur restent hors de cette page.
 */
import Layout from '../layouts/Layout.astro';
import V2Enhance from '../components/V2Enhance.astro';
import Article33Ribbon from '../components/Article33Ribbon.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import CtaBand from '../components/CtaBand.astro';
import StickyCta from '../components/StickyCta.astro';
import RelatedLinks from '../components/RelatedLinks.astro';

const chiffres = [
  { v: '3–7 ans', label: 'Retour sur investissement typique' },
  { v: '25 ans', label: 'Garantie de performance des panneaux' },
  { v: '60–90 %', label: 'De la facture couverte' },
  { v: '0 MAD', label: 'L’étude et le diagnostic' },
];

const moyens = [
  {
    k: '01',
    title: 'Au comptant',
    body: 'La plupart de nos clients règlent l’installation en une fois. À partir de la mise en service, elle se rembourse seule : chaque kWh produit est un kWh que vous n’achetez plus au réseau, valorisé au barème régie ONEE.',
  },
  {
    k: '02',
    title: 'Crédit à la consommation bancaire classique',
    body: 'D’autres passent par un crédit à la consommation classique, souscrit directement auprès de leur banque. Le montage se traite entre vous et votre établissement — nous n’y intervenons pas et n’y touchons aucune commission.',
  },
  {
    k: '03',
    title: 'Financement vert (entreprises)',
    body: 'Côté entreprises, des lignes de financement vert pour les énergies renouvelables existent au Maroc. L’accord et les conditions relèvent de votre banque et de votre dossier ; nous ne vendons ni crédit ni produit bancaire, et n’en garantissons aucun.',
  },
];

// W258 — mécanismes NOMMÉS et vérifiés par segment. Chaque entrée cite sa
// source ; rien n'est publié sans elle. Le résidentiel reste volontairement
// SANS banque nommée (non vérifiable au moment du build) — l'appellation
// générique déjà publiée plus bas (« prêts verts bancaires » sans nom) reste
// la seule affirmation de ce type sur la page.
const mecanismes = [
  {
    segment: 'Agricole',
    items: [
      {
        nom: 'CAM « Saquii Solaire »',
        body: 'Offre nommée du Crédit Agricole du Maroc dédiée au financement du pompage solaire agricole. Le taux et les conditions précises dépendent de votre dossier — à demander directement à votre agence CAM.',
        source: 'creditagricole.ma',
      },
      {
        nom: 'FDA — subvention pompage solaire ≈ 30 %',
        body: 'Le Fonds de Développement Agricole subventionne environ 30 % du coût d’acquisition et d’installation d’un kit de pompage solaire agricole (panneaux, groupe motopompe, structure, accessoires), versée après facture — dossier à déposer à la DPA ou à l’ORMVA de votre région. Cumulable avec la subvention goutte-à-goutte existante.',
        source: 'Guide FDA (agrimaroc.ma / casainvest.ma)',
      },
    ],
  },
  {
    segment: 'Entreprises',
    items: [
      {
        nom: 'Exonération de TVA à l’import — art. 123-22° du CGI',
        body: 'Les biens d’investissement inscrits à l’actif immobilisé, importés par une entreprise assujettie à la TVA dans les 36 mois suivant le début d’activité, en sont exonérés — sous réserve de la constitution des garanties exigées par l’administration fiscale. Détail complet plus bas.',
        source: 'Code Général des Impôts, art. 123-22°',
      },
      {
        nom: 'Leasing type Maghrebail « Energy Lease »',
        body: 'Produit de crédit-bail nommé, couvrant explicitement les installations photovoltaïques, avec subvention d’investissement intégrée pour les projets d’énergie renouvelable. Conditions et plafonds définis par Maghrebail — nous ne garantissons aucune condition bancaire.',
        source: 'maghrebail.ma',
      },
    ],
  },
  {
    segment: 'Résidentiel',
    items: [
      {
        nom: 'Prêts verts bancaires',
        body: 'Certaines banques marocaines proposent, au cas par cas, des lignes de crédit dites « vertes » pouvant couvrir un projet solaire résidentiel. Nous n’avons pas pu vérifier à ce jour qu’un établissement nommé package une offre dédiée au solaire résidentiel — nous ne citons donc aucune banque ici : renseignez-vous directement auprès de la vôtre.',
        source: 'non vérifié — aucune banque nommée tant que non confirmé',
      },
    ],
  },
];
---

<Layout
  title="Rentabilité & financement du solaire au Maroc : ROI 3–7 ans | Taqinor"
  description="Ce que rapporte vraiment une installation solaire au Maroc : remboursée en gros en 3 à 7 ans par l’électricité que vous cessez d’acheter (barème régie ONEE), puis 25 ans de performance garantie et 60 à 90 % de facture couverte. Comment la financer sans détour — Taqinor installe et garantit, mais n’est pas prêteur."
  ogSlug="financement"
>
  <div class="v2">
    <V2Enhance />
    <Article33Ribbon />

    <Breadcrumb items={[{ label: 'Accueil', href: '/' }, { label: 'Financement & rentabilité' }]} />

    <!-- ACTE I — hero sombre : l'investissement qui se rembourse -->
    <section class="px-4 pb-10 pt-16 text-white sm:pt-20">
      <div class="mx-auto max-w-3xl">
        <p class="tech-label v2-kicker rule-brass cine-in text-lune">Rentabilité</p>
        <h1 class="display v2-page-title cine-in mt-5 [animation-delay:120ms]">L’investissement qui se rembourse, puis paie pour vous</h1>
        <p class="v2-lead cine-in mt-6 max-w-xl text-white/85 [animation-delay:240ms]">
          Une installation, c’est de l’ordre de 80 000 MAD pour une villa — un vrai investissement,
          pas un gadget. Bien dimensionnée, elle <strong class="text-white">s’amortit en gros en
          3 à 7 ans</strong> grâce à l’électricité que vous cessez d’acheter au réseau, valorisée au
          barème régie ONEE. Passé ce point, il reste une bonne quinzaine d’années sur les 25 ans
          garantis où votre courant est <strong class="text-white">quasi gratuit</strong>.
        </p>
      </div>
    </section>

    <!-- L'investissement en chiffres — blocs fig lum, chiffres count-up -->
    <section class="px-4 pb-20 sm:pb-24">
      <div class="mx-auto max-w-6xl">
        <p class="tech-label v2-kicker rule-brass text-lune">L’investissement en chiffres</p>
        <h2 class="display v2-section-title mt-5 text-white">Des ordres de grandeur — jamais un devis</h2>
        <p class="v2-lead mt-4 max-w-2xl text-lune-soft">
          Les fourchettes ci-dessous reprennent celles de nos pages Résidentiel et Professionnel —
          aucune n’est gonflée pour cette page. Le chiffre exact de <em>votre</em> rentabilité, lui,
          se calcule sur votre facture réelle ; et si le solaire n’est pas le bon placement pour
          votre profil, nous vous le dirons sans détour.
        </p>
        <dl class="mt-10 grid grid-cols-2 gap-x-6 gap-y-10 border-l-2 border-brass-400/60 pl-6 sm:grid-cols-4 sm:pl-10" data-stagger>
          {chiffres.map((c, i) => (
            <div class="v2-rise" style={`--v2-i:${i}`}>
              <dd class="fig lum whitespace-nowrap text-3xl sm:text-4xl" data-tally>{c.v}</dd>
              <dt class="tech-label mt-2 text-lune-faint">{c.label}</dt>
            </div>
          ))}
        </dl>
        <p class="mt-8 max-w-2xl text-sm leading-relaxed text-lune-soft">
          Plus la facture est lourde, plus le retour est rapide. Pour une villa typique, comptez de
          l’ordre de
          <a href="/résidentiel" class="border-b border-white/40 pb-0.5 font-semibold text-white transition-colors hover:border-white">4 à 6 ans en résidentiel</a> ;
          sur un hangar, l’effet d’échelle resserre le retour à
          <a href="/professionnel" class="border-b border-white/40 pb-0.5 font-semibold text-white transition-colors hover:border-white">3 à 5 ans pour un site professionnel</a>.
          En dessous de 1 000 MAD de facture mensuelle, en revanche, le retour passe le plus souvent
          au-delà de 7 ans — et nous vous le dirons franchement plutôt que de vous vendre l’inutile.
        </p>
      </div>
    </section>

    <!-- W331 — Exemple chiffré entièrement déroulé (facture → kWc → investissement
         → économie → payback), repris VERBATIM de l'exemple déjà publié sur
         /résidentiel (villa à 2 000 MAD/mois) : aucun chiffre nouveau, juste le
         même calcul rendu visible étape par étape. -->
    <div class="v2-seam" aria-hidden="true"></div>
    <section class="px-4 pb-20 sm:pb-24">
      <div class="mx-auto max-w-4xl">
        <p class="tech-label v2-kicker rule-brass text-lune">Un calcul, du début à la fin</p>
        <h2 class="display v2-section-title mt-5 text-white">L’exemple d’une villa à 2 000 MAD de facture, déroulé étape par étape</h2>
        <p class="v2-lead mt-4 max-w-2xl text-lune-soft">
          Même exemple que sur notre page Résidentiel — pas un chiffre de plus, juste chaque étape du
          calcul rendue visible.
        </p>
        <ol class="mt-10 border-t-2 border-brass-400/60" data-stagger>
          <li class="v2-rise flex items-baseline justify-between gap-4 border-b border-white/10 py-5" style="--v2-i:0">
            <span class="text-sm text-lune-soft"><span class="tech-label text-brass-300">1 · Facture</span><br />Votre relevé ONEE mensuel</span>
            <span class="fig lum text-xl sm:text-2xl" data-tally>2 000 MAD</span>
          </li>
          <li class="v2-rise flex items-baseline justify-between gap-4 border-b border-white/10 py-5" style="--v2-i:1">
            <span class="text-sm text-lune-soft"><span class="tech-label text-brass-300">2 · Puissance</span><br />La taille que cette facture appelle</span>
            <span class="fig lum text-xl sm:text-2xl" data-tally>6 kWc</span>
          </li>
          <li class="v2-rise flex items-baseline justify-between gap-4 border-b border-white/10 py-5" style="--v2-i:2">
            <span class="text-sm text-lune-soft"><span class="tech-label text-brass-300">3 · Investissement</span><br />Ordre de grandeur, jamais un devis</span>
            <span class="fig lum text-xl sm:text-2xl">60 000 – 75 000 MAD</span>
          </li>
          <li class="v2-rise flex items-baseline justify-between gap-4 border-b border-white/10 py-5" style="--v2-i:3">
            <span class="text-sm text-lune-soft"><span class="tech-label text-brass-300">4 · Économie</span><br />Effacé chaque année au barème régie ONEE</span>
            <span class="fig lum text-xl sm:text-2xl">12 000 – 16 000 MAD/an</span>
          </li>
          <li class="v2-rise flex items-baseline justify-between gap-4 py-5" style="--v2-i:4">
            <span class="text-sm text-lune-soft"><span class="tech-label text-brass-300">5 · Retour</span><br />Puis 19 à 21 ans de courant quasi gratuit</span>
            <span class="fig text-xl text-brass-300 sm:text-2xl" data-tally>4 à 6 ans</span>
          </li>
        </ol>
        <p class="mt-6 max-w-2xl text-xs leading-relaxed text-lune-soft">
          Le vôtre partira de votre propre facture, pas de celle-ci — <a href="/devis/mon-toit" class="border-b border-white/40 pb-0.5 font-semibold text-white transition-colors hover:border-white">lancez votre diagnostic gratuit</a>.
        </p>
      </div>
    </section>

    <!-- Comment financer — section claire, honnêteté totale -->
    <div class="v2-seam" aria-hidden="true"></div>
    <section class="bg-blanc-azur px-4 pb-20 pt-10 text-encre sm:pb-24">
      <div class="mx-auto max-w-6xl">
        <p class="tech-label v2-kicker rule-brass text-azur-600">Sans détour</p>
        <h2 class="display v2-section-title mt-5">Comment financer — en toute transparence</h2>
        <p class="v2-lead mt-4 max-w-2xl text-encre-soft">
          Mettons une chose au clair d’emblée : nous posons et garantissons le solaire, nous ne
          vendons aucun produit financier. Voilà, sans habillage, les trois manières dont nos
          clients règlent réellement leur installation.
        </p>
        <div class="mt-10 grid gap-6 md:grid-cols-3" data-stagger>
          {moyens.map((m, i) => (
            <div class="v2-rise flex flex-col border-t-2 border-azur-900 bg-blanc p-7" style={`--v2-i:${i}`}>
              <p class="fig text-3xl text-azur-600">{m.k}</p>
              <h3 class="display mt-2 text-xl">{m.title}</h3>
              <p class="mt-3 flex-1 text-sm leading-relaxed text-encre-soft">{m.body}</p>
            </div>
          ))}
        </div>

        <!-- Les mises au point honnêtes -->
        <div class="mt-10 max-w-3xl border-l-4 border-azur-600 bg-blanc px-5 py-5 text-sm leading-relaxed text-encre-soft">
          <p class="tech-label text-azur-600">Ce qu’il faut savoir, noir sur blanc</p>
          <ul class="mt-4 space-y-2.5">
            <li><strong class="text-encre">Taqinor n’est pas un organisme de crédit</strong> ni un prêteur : nous n’accordons aucun financement et ne percevons aucune commission bancaire.</li>
            <li><strong class="text-encre">Aucune subvention résidentielle spéciale</strong> n’existe pour une installation solaire de particulier au Maroc — méfiez-vous de toute promesse de ce type.</li>
            <li><strong class="text-encre">Pas d’exonération de TVA résidentielle</strong> : la TVA s’applique à une installation clé en main complète. Nous ne vous promettrons pas le contraire.</li>
            <li>Pour les entreprises, des <strong class="text-encre">lignes de financement vert</strong> pour les projets d’énergies renouvelables existent au Maroc, mais c’est votre banque qui décide — nous ne nommons aucun établissement et ne garantissons aucune condition.</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- W258 — Mécanismes NOMMÉS et vérifiés, par segment (WG11) -->
    <div class="v2-seam" aria-hidden="true"></div>
    <section class="px-4 py-20 sm:py-24">
      <div class="mx-auto max-w-6xl">
        <p class="tech-label v2-kicker rule-brass text-lune">Ce qui existe vraiment, nommé</p>
        <h2 class="display v2-section-title mt-5 text-white">Les dispositifs marocains vérifiés, par profil</h2>
        <p class="v2-lead mt-4 max-w-2xl text-lune-soft">
          Chaque nom cité ci-dessous a été vérifié auprès d’une source primaire au moment de la
          publication de cette page — jamais un partenariat que nous n’aurions pas nous-mêmes. Ce que
          nous n’avons pas pu vérifier n’apparaît pas ici.
        </p>
        <div class="mt-10 grid gap-8 md:grid-cols-3" data-stagger>
          {mecanismes.map((seg, i) => (
            <div class="v2-rise border-t-2 border-brass-400/60 pt-5" style={`--v2-i:${i}`}>
              <h3 class="display text-xl text-white">{seg.segment}</h3>
              <div class="mt-4 space-y-5">
                {seg.items.map((it) => (
                  <div>
                    <p class="font-display text-base font-bold text-white">{it.nom}</p>
                    <p class="mt-1.5 text-sm leading-relaxed text-lune-soft">{it.body}</p>
                    <p class="tech-label mt-1.5 text-lune-faint">Source : {it.source}</p>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- W336 — Les deux leviers fiscaux CFO : art. 123-22° TVA + amortissement.
         WG16 (skim juridique) encore en cours : note « sous réserve de
         vérification » visible. Cité pour les entreprises (le résidentiel
         reste sans exonération TVA — mise au point déjà publiée ci-dessus). -->
    <div class="v2-seam" aria-hidden="true"></div>
    <section class="bg-blanc-azur px-4 pb-20 pt-16 text-encre sm:pb-24">
      <div class="mx-auto max-w-4xl">
        <p class="tech-label v2-kicker rule-brass text-azur-600">Pour les entreprises · les deux leviers que personne ne cite</p>
        <h2 class="display v2-section-title mt-5">TVA à l’import et amortissement : ce que dit le CGI</h2>
        <p class="v2-lead mt-4 max-w-2xl text-encre-soft">
          Deux articles de loi, réels et vérifiables, jouent en faveur d’une installation solaire
          professionnelle inscrite à l’actif de votre entreprise — ce ne sont pas des avantages
          négociés par Taqinor, mais des dispositions ouvertes du Code Général des Impôts.
        </p>
        <div class="mt-8 grid gap-6 sm:grid-cols-2">
          <div class="border-t-2 border-azur-900 bg-blanc p-6">
            <p class="fig text-lg text-azur-600">CGI · art. 123-22°</p>
            <h3 class="display mt-2 text-lg">Exonération de TVA à l’import</h3>
            <p class="mt-3 text-sm leading-relaxed text-encre-soft">
              Un bien d’investissement inscrit à l’actif immobilisé, importé par une entreprise
              assujettie à la TVA dans les 36 mois suivant le début de son activité, en est exonéré —
              sous réserve de constituer les garanties exigées par l’administration fiscale.
            </p>
          </div>
          <div class="border-t-2 border-azur-900 bg-blanc p-6">
            <p class="fig text-lg text-azur-600">Amortissement</p>
            <h3 class="display mt-2 text-lg">20 ans, linéaire, 5 % par an</h3>
            <p class="mt-3 text-sm leading-relaxed text-encre-soft">
              Une installation solaire s’amortit comptablement comme un équipement de production
              classique : linéairement sur 20 ans, soit 5 % de sa valeur chaque année déduits du
              résultat imposable.
            </p>
          </div>
        </div>
        <p class="mx-auto mt-8 max-w-2xl border-l-4 border-azur-600 pl-4 text-sm leading-relaxed text-encre-soft">
          <strong class="text-encre">Sous réserve de vérification (skim juridique en cours) :</strong> la
          loi de finances la plus récente prolonge, pour certaines entreprises liées par une
          convention avec l’État, la fenêtre d’exonération de TVA à l’import au-delà des 36 mois
          standards — un point qui ne s’applique pas à toutes les sociétés de la même façon. Confirmez
          votre situation exacte avec votre expert-comptable avant toute décision.
        </p>
      </div>
    </section>

    <!-- L'étude calcule VOTRE rentabilité -->
    <section class="px-4 py-20 sm:py-28">
      <div class="mx-auto grid max-w-6xl gap-10 lg:grid-cols-[1.1fr_1fr] lg:items-center">
        <div class="v2-rise">
          <p class="tech-label v2-kicker rule-brass text-lune">Votre rentabilité, pas une moyenne</p>
          <h2 class="display v2-section-title mt-5 text-white">L’étude calcule la rentabilité de votre facture</h2>
          <p class="v2-lead mt-5 text-lune-soft">
            Tout ce qui précède reste des ordres de grandeur. Votre chiffre — ce que vous économisez
            chaque mois, l’année où l’installation s’est remboursée — sort de trois données qui
            n’appartiennent qu’à vous : votre facture, votre profil de consommation, votre toiture.
            On les fait passer dans le calcul, et le résultat est le vôtre, pas une moyenne de
            plaquette.
          </p>
          <a href="/devis/mon-toit" class="mt-8 inline-block bg-brass-400 px-7 py-3.5 text-base font-bold text-azur-950 transition-colors hover:bg-brass-300">Calculer ma rentabilité — étude à 0 MAD</a>
        </div>
        <dl class="grid grid-cols-2 gap-x-6 gap-y-10 border-l-2 border-brass-400/60 pl-6 sm:pl-10" data-stagger>
          <div class="v2-rise" style="--v2-i:0">
            <dd class="fig lum whitespace-nowrap text-3xl sm:text-5xl" data-tally>0 MAD</dd>
            <dt class="tech-label mt-2 text-lune-faint">L’étude et le diagnostic</dt>
          </div>
          <div class="v2-rise" style="--v2-i:1">
            <dd class="fig lum whitespace-nowrap text-3xl sm:text-5xl" data-tally>25 ans</dd>
            <dt class="tech-label mt-2 text-lune-faint">Performance garantie (≥ 84,8 %)</dt>
          </div>
          <div class="v2-rise" style="--v2-i:2">
            <dd class="fig lum whitespace-nowrap text-3xl sm:text-5xl" data-tally>3–7 ans</dd>
            <dt class="tech-label mt-2 text-lune-faint">Retour sur investissement typique</dt>
          </div>
          <div class="v2-rise" style="--v2-i:3">
            <dd class="font-display text-xl font-bold text-white">Barème ONEE</dd>
            <dt class="tech-label mt-2 text-lune-faint">Base du calcul d’électricité évitée</dt>
          </div>
        </dl>
      </div>
    </section>

    {/* Liens contextuels — cluster prix/résidentiel + pompage (W299) */}
    <section class="border-t border-white/10 px-4 py-16">
      <div class="mx-auto max-w-6xl">
        <RelatedLinks mt="mt-0" links={[
          { href: '/résidentiel', label: 'Rentabilité résidentielle' },
          { href: '/professionnel', label: 'Rentabilité professionnelle' },
          { href: '/pompage-solaire', label: 'Pompage solaire agricole' },
          { href: '/prix-panneaux-solaires-maroc', label: 'Prix des panneaux solaires au Maroc' },
          { href: '/garanties', label: 'Nos garanties (25 ans)' },
          { href: '/devis/mon-toit', label: 'Lancer mon diagnostic' },
        ]} />
      </div>
    </section>

    <CtaBand title="Combien votre toit vous rapporte ? Le diagnostic gratuit le chiffre." href="/devis/mon-toit" />

    <StickyCta />
  </div>
</Layout>
