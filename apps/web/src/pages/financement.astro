---
/**
 * Financement & rentabilité (W26) — page éditoriale « rentabilité d'abord,
 * honnêteté totale ». AUCUN chiffre nouveau : on réutilise uniquement les ordres
 * de grandeur déjà publiés (accueil, résidentiel, professionnel, garanties).
 * Contraintes dures : Taqinor n'est PAS prêteur, aucune subvention résidentielle,
 * pas d'exonération de TVA résidentielle, aucune banque/partenaire/taux nommé.
 * Page publique et indexée. Schéma limité au fil d'Ariane.
 */
import Layout from '../layouts/Layout.astro';
import V2Enhance from '../components/V2Enhance.astro';
import Article33Ribbon from '../components/Article33Ribbon.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import CtaBand from '../components/CtaBand.astro';
import StickyCta from '../components/StickyCta.astro';

const chiffres = [
  { v: '3–7 ans', label: 'Retour sur investissement typique' },
  { v: '25 ans', label: 'Garantie de performance des panneaux' },
  { v: '60–90 %', label: 'De la facture couverte' },
  { v: '0 MAD', label: 'L’étude et le diagnostic' },
];

const moyens = [
  {
    k: '01',
    title: 'Au comptant',
    body: 'La plupart de nos clients règlent l’installation au comptant. L’investissement se rembourse ensuite tout seul par l’électricité que vous cessez d’acheter au réseau — au barème régie ONEE.',
  },
  {
    k: '02',
    title: 'Crédit à la consommation bancaire classique',
    body: 'Certains clients financent l’installation via un crédit à la consommation bancaire classique, souscrit directement auprès de leur banque. Taqinor n’intervient pas dans ce montage : nous ne sommes pas un organisme de crédit.',
  },
  {
    k: '03',
    title: 'Financement vert (entreprises)',
    body: 'Pour les projets professionnels, des lignes de financement vert dédiées aux énergies renouvelables existent au Maroc. C’est votre banque qui en décide, selon votre dossier — Taqinor ne vend ni crédit ni produit bancaire.',
  },
];
---

<Layout
  title="Financement & rentabilité du solaire au Maroc | Taqinor"
  description="Combien rapporte une installation solaire au Maroc : remboursée en gros en 3 à 7 ans par l'électricité évitée (barème régie ONEE), puis 25 ans de performance garantie. Comment la financer, en toute transparence — Taqinor n'est pas un organisme de crédit."
  ogSlug="accueil"
>
  <div class="v2">
    <V2Enhance />
    <Article33Ribbon />

    <Breadcrumb items={[{ label: 'Accueil', href: '/' }, { label: 'Financement & rentabilité' }]} />

    <!-- ACTE I — hero sombre : l'investissement qui se rembourse -->
    <section class="px-4 pb-10 pt-16 text-white sm:pt-20">
      <div class="mx-auto max-w-3xl">
        <p class="tech-label v2-kicker rule-brass cine-in text-brass-300">Rentabilité</p>
        <h1 class="display v2-page-title cine-in mt-5 [animation-delay:120ms]">L’investissement qui se rembourse, puis paie pour vous</h1>
        <p class="v2-lead cine-in mt-6 max-w-xl text-white/85 [animation-delay:240ms]">
          Une installation solaire est un investissement sérieux — de l’ordre de 80 000 MAD pour une
          villa. Bien dimensionnée, elle <strong class="text-white">se rembourse en gros en 3 à 7 ans</strong>
          par l’électricité que vous cessez d’acheter au réseau, au barème régie ONEE. Ensuite,
          pendant les années qui restent sur les 25 ans de performance garantie, votre électricité
          est <strong class="text-white">quasi gratuite</strong>.
        </p>
      </div>
    </section>

    <!-- L'investissement en chiffres — blocs fig lum, chiffres count-up -->
    <section class="px-4 pb-20 sm:pb-24">
      <div class="mx-auto max-w-6xl">
        <p class="tech-label v2-kicker rule-brass text-brass-300">L’investissement en chiffres</p>
        <h2 class="display v2-section-title mt-5 text-white">Des ordres de grandeur — jamais un devis</h2>
        <p class="v2-lead mt-4 max-w-2xl text-lune-soft">
          Les fourchettes ci-dessous sont celles déjà publiées sur nos pages Résidentiel et
          Professionnel. Le chiffre exact de <em>votre</em> rentabilité est calculé dans l’étude,
          à partir de votre facture réelle — nous vous dirons honnêtement si le solaire n’est pas
          le bon placement pour votre profil.
        </p>
        <dl class="mt-10 grid grid-cols-2 gap-x-6 gap-y-10 border-l-2 border-brass-400/60 pl-6 sm:grid-cols-4 sm:pl-10" data-stagger>
          {chiffres.map((c, i) => (
            <div class="v2-rise" style={`--v2-i:${i}`}>
              <dd class="fig lum whitespace-nowrap text-3xl sm:text-4xl" data-tally>{c.v}</dd>
              <dt class="tech-label mt-2 text-lune-faint">{c.label}</dt>
            </div>
          ))}
        </dl>
        <p class="mt-8 max-w-2xl text-sm leading-relaxed text-lune-soft">
          Le retour dépend de votre profil : pour une villa typique, il est de l’ordre de
          <a href="/résidentiel" class="border-b border-brass-400 pb-0.5 font-semibold text-brass-300 transition-colors hover:text-brass-200">4 à 6 ans en résidentiel</a>,
          et de l’ordre de
          <a href="/professionnel" class="border-b border-brass-400 pb-0.5 font-semibold text-brass-300 transition-colors hover:text-brass-200">3 à 5 ans pour un site professionnel</a>
          (effet d’échelle en toiture de hangar). En dessous de 1 000 MAD de facture par mois, le
          retour dépasse généralement 7 ans — nous vous le dirons franchement.
        </p>
      </div>
    </section>

    <!-- Comment financer — section claire, honnêteté totale -->
    <div class="v2-seam" aria-hidden="true"></div>
    <section class="bg-blanc-azur px-4 pb-20 pt-10 text-encre sm:pb-24">
      <div class="mx-auto max-w-6xl">
        <p class="tech-label v2-kicker rule-brass text-azur-600">Sans détour</p>
        <h2 class="display v2-section-title mt-5">Comment financer — en toute transparence</h2>
        <p class="v2-lead mt-4 max-w-2xl text-encre-soft">
          Soyons clairs sur ce que nous sommes et ne sommes pas. Taqinor installe et garantit le
          solaire ; nous ne vendons aucun produit financier. Voici les façons dont nos clients
          financent réellement leur installation.
        </p>
        <div class="mt-10 grid gap-6 md:grid-cols-3" data-stagger>
          {moyens.map((m, i) => (
            <div class="v2-rise flex flex-col border-t-2 border-azur-900 bg-blanc p-7" style={`--v2-i:${i}`}>
              <p class="fig text-3xl text-azur-600">{m.k}</p>
              <h3 class="display mt-2 text-xl">{m.title}</h3>
              <p class="mt-3 flex-1 text-sm leading-relaxed text-encre-soft">{m.body}</p>
            </div>
          ))}
        </div>

        <!-- Les mises au point honnêtes -->
        <div class="mt-10 max-w-3xl border-l-4 border-azur-600 bg-blanc px-5 py-5 text-sm leading-relaxed text-encre-soft">
          <p class="tech-label text-azur-600">Ce qu’il faut savoir, noir sur blanc</p>
          <ul class="mt-4 space-y-2.5">
            <li><strong class="text-encre">Taqinor n’est pas un organisme de crédit</strong> ni un prêteur : nous n’accordons aucun financement et ne percevons aucune commission bancaire.</li>
            <li><strong class="text-encre">Aucune subvention résidentielle spéciale</strong> n’existe pour une installation solaire de particulier au Maroc — méfiez-vous de toute promesse de ce type.</li>
            <li><strong class="text-encre">Pas d’exonération de TVA résidentielle</strong> : la TVA s’applique à une installation clé en main complète. Nous ne vous promettrons pas le contraire.</li>
            <li>Pour les entreprises, des <strong class="text-encre">lignes de financement vert</strong> pour les projets d’énergies renouvelables existent au Maroc, mais c’est votre banque qui décide — nous ne nommons aucun établissement et ne garantissons aucune condition.</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- L'étude calcule VOTRE rentabilité -->
    <section class="px-4 py-20 sm:py-28">
      <div class="mx-auto grid max-w-6xl gap-10 lg:grid-cols-[1.1fr_1fr] lg:items-center">
        <div class="v2-rise">
          <p class="tech-label v2-kicker rule-brass text-brass-300">Votre rentabilité, pas une moyenne</p>
          <h2 class="display v2-section-title mt-5 text-white">L’étude calcule la rentabilité de votre facture</h2>
          <p class="v2-lead mt-5 text-lune-soft">
            Les fourchettes de cette page sont des ordres de grandeur. Le vrai chiffre — combien
            vous économisez, en combien d’années l’installation est remboursée — est calculé dans
            l’étude, à partir de votre facture réelle, de votre profil de consommation et de votre
            toiture. C’est un calcul de rentabilité personnalisé, pas une promesse de plaquette.
          </p>
          <a href="/contact#simulateur" class="mt-8 inline-block bg-brass-400 px-7 py-3.5 text-base font-bold text-azur-950 transition-colors hover:bg-brass-300">Calculer ma rentabilité — étude à 0 MAD</a>
        </div>
        <dl class="grid grid-cols-2 gap-x-6 gap-y-10 border-l-2 border-brass-400/60 pl-6 sm:pl-10" data-stagger>
          <div class="v2-rise" style="--v2-i:0">
            <dd class="fig lum whitespace-nowrap text-3xl sm:text-5xl" data-tally>0 MAD</dd>
            <dt class="tech-label mt-2 text-lune-faint">L’étude et le diagnostic</dt>
          </div>
          <div class="v2-rise" style="--v2-i:1">
            <dd class="fig lum whitespace-nowrap text-3xl sm:text-5xl" data-tally>25 ans</dd>
            <dt class="tech-label mt-2 text-lune-faint">Performance garantie (≥ 84,8 %)</dt>
          </div>
          <div class="v2-rise" style="--v2-i:2">
            <dd class="fig lum whitespace-nowrap text-3xl sm:text-5xl" data-tally>3–7 ans</dd>
            <dt class="tech-label mt-2 text-lune-faint">Retour sur investissement typique</dt>
          </div>
          <div class="v2-rise" style="--v2-i:3">
            <dd class="font-display text-xl font-bold text-white">Barème ONEE</dd>
            <dt class="tech-label mt-2 text-lune-faint">Base du calcul d’électricité évitée</dt>
          </div>
        </dl>
      </div>
    </section>

    <!-- Liens contextuels -->
    <section class="border-t border-white/10 px-4 py-16">
      <div class="mx-auto flex max-w-6xl flex-wrap gap-3">
        <a href="/résidentiel" class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">Rentabilité résidentielle →</a>
        <a href="/professionnel" class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">Rentabilité professionnelle →</a>
        <a href="/garanties" class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">Nos garanties (25 ans) →</a>
        <a href="/contact#simulateur" class="border border-white/40 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-white hover:bg-white/10">Lancer mon diagnostic →</a>
      </div>
    </section>

    <CtaBand title="Votre rentabilité se calcule : commencez par l’étude gratuite." href="/contact#simulateur" />

    <StickyCta />
  </div>
</Layout>
