---
/**
 * PAGE PRIVÉE DE PRÉVISUALISATION — /preview/toiture-3d-pro (noindex, hors nav,
 * exclue du sitemap, non liée). VARIANTE 3D RÉALISTE, à comparer avec la 2D
 * (/preview/toiture) et la 3D « volumes » (/preview/toiture-3d). Le fondateur
 * garde celle qu'il préfère ; rien n'est promu en ligne.
 *
 * Même parcours (adresse → tracé satellite → MÊME estimation PVGIS → MÊME
 * diagnostic/lead pré-rempli). Différence : sur toit plat, les panneaux sont
 * rendus INCLINÉS sur CHÂSSIS TRIANGULAIRES LESTÉS, en RANGÉES espacées, avec
 * de vraies ombres douces — via Three.js (couche personnalisée MapLibre). Le
 * calepinage espacé pilote un nombre de panneaux PLUS JUSTE (et parfois un peu
 * plus bas) → kWc → production. Voir SOLAR_3D_RATIONALE.md.
 *
 * Three.js + la carte sont chargés PARESSEUSEMENT (import() dynamique de
 * src/scripts/roof-tool-pro.ts) : aucune autre page ne les télécharge. Sans clé
 * MapTiler, sans WebGL ou sans JS : repli gracieux (2D / diagnostic), jamais de
 * canvas figé ni de page cassée. Design de production (.v2 + V2Enhance).
 */
import Layout from '../../layouts/Layout.astro';
import V2Enhance from '../../components/V2Enhance.astro';
import DiagnosticFormEnriched from '../../components/DiagnosticFormEnriched.astro';

const inputClass =
  'w-full border border-white/15 bg-white/5 px-3 py-3 text-base text-white placeholder:text-lune-faint outline-none transition-colors focus:border-brass-400 focus:ring-2 focus:ring-brass-400/30';
---

<Layout
  title="Prévisualisation privée — estimateur de toiture 3D réaliste | Taqinor"
  description="Page de travail privée, non indexée."
  noindex={true}
>
  <div class="v2">
    <V2Enhance />

    <section class="border-b border-white/10 bg-nuit-800 px-4 py-14 sm:py-20">
      <div class="mx-auto max-w-6xl">
        <p class="tech-label rule-brass text-brass-300">Prévisualisation privée · 3D réaliste · non publiée</p>
        <h1 class="display v2-page-title mt-5 max-w-[22ch] text-white">
          Vos panneaux inclinés sur leurs supports, comme en vrai
        </h1>
        <p class="v2-lead mt-6 max-w-2xl text-lune-soft">
          Cherchez votre adresse, tracez le contour de votre toiture : l'outil relève votre bâtiment
          en 3D et y pose vos panneaux <strong class="text-white">inclinés sur châssis triangulaires
          lestés</strong>, en rangées espacées — comme une vraie installation sur toit plat. Vous
          faites pivoter et inclinez du doigt. Puissance, production et économies, comme les autres
          versions. Le site et le formulaire en production restent inchangés.
        </p>
        <p class="mt-4 text-sm text-lune-faint">
          Estimation indicative, jamais un devis. Comparez :
          <a href="/preview/toiture" class="text-brass-300 underline underline-offset-2 hover:text-brass-400">2D</a> ·
          <a href="/preview/toiture-3d" class="text-brass-300 underline underline-offset-2 hover:text-brass-400">3D volumes</a> ·
          <a href="#simulateur" class="text-brass-300 underline underline-offset-2 hover:text-brass-400">diagnostic classique</a>.
        </p>
      </div>
    </section>

    <section class="bg-nuit px-4 py-16 sm:py-20">
      <div class="mx-auto max-w-6xl">
        <ol class="mb-10 grid gap-4 sm:grid-cols-3">
          <li class="border-l-2 border-brass-400/60 pl-4 text-sm text-lune-soft">
            <span class="tech-label block text-brass-300">Étape 1</span>
            <strong class="mt-1 block text-white">Votre adresse</strong>
            La carte zoome sur votre maison en vue satellite.
          </li>
          <li class="border-l-2 border-brass-400/60 pl-4 text-sm text-lune-soft">
            <span class="tech-label block text-brass-300">Étape 2</span>
            <strong class="mt-1 block text-white">Tracez le toit</strong>
            Cliquez les coins ; double-cliquez (ou « Terminer ») pour passer en 3D.
          </li>
          <li class="border-l-2 border-brass-400/60 pl-4 text-sm text-lune-soft">
            <span class="tech-label block text-brass-300">Étape 3</span>
            <strong class="mt-1 block text-white">Faites pivoter</strong>
            Voyez les rangées inclinées sur leurs supports lestés, sous tous les angles.
          </li>
        </ol>

        <div id="rp-fallback" hidden class="cine-card mb-8 border-l-4 border-alert-300 p-6">
          <p class="font-semibold text-white">Vue 3D réaliste momentanément indisponible</p>
          <p class="mt-2 text-sm text-lune-soft">
            La 3D n'est pas accessible sur cet appareil (carte graphique, clé ou JavaScript).
            Essayez <a href="/preview/toiture" class="text-brass-300 underline underline-offset-2">la version 2D</a>
            ou <a href="/preview/toiture-3d" class="text-brass-300 underline underline-offset-2">la 3D volumes</a>,
            ou obtenez votre étude directement — <a href="#simulateur" class="text-brass-300 underline underline-offset-2">le diagnostic en 60 secondes</a>.
          </p>
        </div>

        <div id="rp-stage" class="grid gap-6 lg:grid-cols-[1.5fr_1fr] lg:items-start">
          <div class="cine-card overflow-hidden">
            <form id="rp-search" class="flex flex-col gap-3 border-b border-white/10 p-4 sm:flex-row">
              <label for="rp-address" class="sr-only">Votre adresse</label>
              <input id="rp-address" name="address" type="text" autocomplete="street-address"
                placeholder="Adresse, quartier ou ville (ex. Casablanca, Maârif)" class={inputClass} />
              <button type="submit"
                class="flex-none bg-brass-400 px-6 py-3 text-base font-bold text-azur-950 transition-colors hover:bg-brass-300">
                Localiser mon toit
              </button>
            </form>

            <div id="rp-map" class="rp-map" role="application" aria-label="Carte satellite 3D réaliste pour tracer votre toiture">
              <div id="rp-map-placeholder" class="rp-map-placeholder">
                <p class="text-sm text-lune-soft">
                  Saisissez votre adresse ci-dessus pour afficher la vue satellite, ou
                </p>
                <button type="button" id="rp-open"
                  class="mt-3 border border-white/30 px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-white/10">
                  ouvrir la carte sans adresse
                </button>
                <noscript>
                  <p class="mt-3 text-sm text-lune-faint">
                    Cet outil nécessite JavaScript. <a href="/preview/toiture" class="text-brass-300 underline">Version 2D</a> ·
                    <a href="#simulateur" class="text-brass-300 underline">diagnostic classique →</a>
                  </p>
                </noscript>
              </div>
            </div>

            <div class="flex flex-wrap items-center gap-3 border-t border-white/10 p-4">
              <button type="button" id="rp-finish" disabled
                class="border border-white/25 px-4 py-2.5 text-sm font-semibold text-white transition-colors hover:border-brass-400 hover:text-brass-300 disabled:cursor-not-allowed disabled:opacity-40">
                Terminer le tracé
              </button>
              <button type="button" id="rp-clear"
                class="border border-white/25 px-4 py-2.5 text-sm font-semibold text-lune-soft transition-colors hover:border-white/50 hover:text-white">
                Effacer
              </button>
              <div class="ml-auto flex items-center gap-2">
                <label for="rp-orient" class="text-sm text-lune-soft">Orientation</label>
                <select id="rp-orient" class="border border-white/15 bg-nuit-700 px-3 py-2 text-sm text-white outline-none focus:border-brass-400">
                  <option value="sud" selected>Sud</option>
                  <option value="sud-est">Sud-Est</option>
                  <option value="sud-ouest">Sud-Ouest</option>
                  <option value="est">Est</option>
                  <option value="ouest">Ouest</option>
                  <option value="nord">Nord</option>
                  <option value="inconnu">Je ne sais pas</option>
                </select>
              </div>
            </div>

            <div id="rp-build-controls" hidden class="flex flex-wrap items-center gap-x-6 gap-y-3 border-t border-white/10 bg-nuit-800 p-4">
              <div class="flex items-center gap-2">
                <label for="rp-floors" class="text-sm text-lune-soft">Étages</label>
                <select id="rp-floors" class="border border-white/15 bg-nuit-700 px-3 py-2 text-sm text-white outline-none focus:border-brass-400">
                  <option value="1">1</option>
                  <option value="2" selected>2</option>
                  <option value="3">3 et +</option>
                </select>
              </div>
              <label class="flex items-center gap-2 text-sm text-lune-soft">
                <input type="checkbox" id="rp-pitch" class="accent-brass-400" />
                Toit en pente (villa — pose affleurante)
              </label>
              <span class="ml-auto text-xs text-lune-faint">Glissez pour pivoter · molette/pincez pour zoomer</span>
            </div>

            <p id="rp-status" class="border-t border-white/10 px-4 py-3 text-sm text-lune-faint" aria-live="polite">
              Cherchez votre adresse pour commencer.
            </p>
          </div>

          <div id="rp-results" class="rp-results cine-card p-6">
            <p class="tech-label rule-brass text-brass-300">Votre potentiel solaire</p>
            <dl class="mt-6 grid grid-cols-2 gap-x-6 gap-y-7">
              <div>
                <dd id="rp-res-kwc" class="fig text-3xl text-brass-300 sm:text-4xl">—</dd>
                <dt class="tech-label mt-2 text-lune-faint">Puissance</dt>
              </div>
              <div>
                <dd id="rp-res-panels" class="fig text-3xl text-white sm:text-4xl">—</dd>
                <dt class="tech-label mt-2 text-lune-faint">Panneaux</dt>
              </div>
              <div>
                <dd id="rp-res-area" class="fig text-3xl text-white sm:text-4xl">—</dd>
                <dt class="tech-label mt-2 text-lune-faint">Surface tracée</dt>
              </div>
              <div>
                <dd id="rp-res-prod" class="fig text-2xl text-white sm:text-3xl">—</dd>
                <dt class="tech-label mt-2 text-lune-faint">Production estimée</dt>
              </div>
            </dl>
            <div class="mt-7 border-t border-white/10 pt-6">
              <dd id="rp-res-savings" class="fig text-2xl text-brass-300 sm:text-3xl">—</dd>
              <dt class="tech-label mt-2 text-lune-faint">Économies estimées</dt>
            </div>
            <p id="rp-res-note" class="mt-6 text-xs leading-relaxed text-lune-faint">
              Tracez votre toit pour découvrir votre potentiel solaire.
            </p>
            <p class="mt-3 text-xs leading-relaxed text-lune-faint/80">
              Montage réaliste (panneaux inclinés sur châssis lestés, rangées espacées) sur un volume
              de bâtiment approximatif — pas une copie exacte de la maison. Le nombre de panneaux peut
              être un peu plus bas que la version « à plat » : les vraies rangées ont besoin d'espace,
              c'est plus juste.
            </p>
            <button type="button" id="rp-cta" hidden
              class="mt-6 inline-flex w-full items-center justify-center gap-2 bg-ok-600 px-6 py-4 text-base font-bold text-white transition-opacity hover:opacity-90">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 0 0-8.6 15.1L2 22l5-1.3A10 10 0 1 0 12 2Zm5.4 14.1c-.2.6-1.3 1.2-1.8 1.2-.5.1-1 .2-3.3-.7-2.8-1.1-4.6-4-4.7-4.2-.1-.2-1.1-1.5-1.1-2.9s.7-2 1-2.3c.2-.3.5-.3.7-.3h.5c.2 0 .4 0 .6.4l.9 2.1c.1.2.1.4 0 .6l-.4.6-.5.5c-.2.2-.3.4-.1.7.2.3.9 1.4 1.9 2.3 1.3 1.1 2.3 1.5 2.6 1.6.3.1.5.1.7-.1l1-1.2c.2-.3.4-.2.7-.1l2 1c.3.1.5.2.6.4 0 .1 0 .7-.3 1.4Z"/></svg>
              Recevoir mon étude sur WhatsApp
            </button>
          </div>
        </div>
      </div>
    </section>

    <DiagnosticFormEnriched heading="Recevez votre étude détaillée" />
  </div>
</Layout>

<style>
  .rp-map {
    position: relative;
    width: 100%;
    height: 60vh;
    min-height: 360px;
    background: var(--color-nuit-700);
  }
  @media (min-width: 1024px) {
    .rp-map { height: 560px; }
  }
  .rp-map-placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
    text-align: center;
  }
  .rp-results { min-height: 360px; }
  .rp-results--ready { border-color: rgb(243 204 102 / 0.25); }
  .rp-map :global(.maplibregl-map) { position: absolute; inset: 0; }
</style>

<script>
  // Activation paresseuse : MapLibre + Three.js ne sont téléchargés qu'au premier
  // geste réel. La clé publique MapTiler est lue à l'exécution via /api/roof-config.
  const fallback = document.getElementById('rp-fallback');
  const stage = document.getElementById('rp-stage');
  const searchForm = document.getElementById('rp-search') as HTMLFormElement | null;
  const addressEl = document.getElementById('rp-address') as HTMLInputElement | null;
  const openBtn = document.getElementById('rp-open');
  const placeholder = document.getElementById('rp-map-placeholder');

  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  let started = false;
  let key = '';

  function showFallback() {
    if (fallback) fallback.hidden = false;
    if (stage) stage.hidden = true;
  }

  async function boot(initialQuery?: string) {
    if (started || !key) return;
    started = true;
    // Le repli ne s'affiche QUE si la carte n'a jamais pu être créée (module qui
    // échoue, WebGL absent, création MapLibre/Three impossible). Une fois la carte
    // créée (onReady), une erreur ultérieure ne la fait jamais disparaître.
    let mapCreated = false;
    try {
      const mod = await import('../../scripts/roof-tool-pro.ts');
      placeholder?.remove();
      mod.initRoofToolPro({
        maptilerKey: key,
        reducedMotion,
        initialQuery,
        onReady: () => {
          mapCreated = true;
        },
      });
    } catch {
      if (!mapCreated) {
        started = false;
        showFallback();
      }
    }
  }

  (async () => {
    try {
      const res = await fetch('/api/roof-config');
      const cfg = (await res.json()) as { available?: boolean; maptilerKey?: string };
      if (!cfg.available || !cfg.maptilerKey) {
        showFallback();
        return;
      }
      key = cfg.maptilerKey;
      searchForm?.addEventListener('submit', (e) => {
        e.preventDefault();
        boot(addressEl?.value.trim() || undefined);
      });
      openBtn?.addEventListener('click', () => boot());
    } catch {
      showFallback();
    }
  })();
</script>
