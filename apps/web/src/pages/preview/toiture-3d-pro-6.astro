  }
  .rp6-map {
    position: relative;
    width: 100%;
    height: 60vh;
    min-height: 360px;
    background: var(--color-nuit-700);
  }
  @media (min-width: 1024px) {
    .rp6-map { height: 560px; }
  }
  .rp6-map-placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
    text-align: center;
  }
  /* Largeur réservée : la recommandation ne provoque aucun saut de mise en page. */
  .rp6-results { min-height: 520px; }
  .rp6-results--ready { border-color: rgb(243 204 102 / 0.25); }
  .rp6-map :global(.maplibregl-map) { position: absolute; inset: 0; }

  .rp6-chip[aria-pressed='true'] {
    border-color: var(--color-brass-400, #e8b54a);
    color: var(--color-brass-300, #f3cc66);
    background: rgb(243 204 102 / 0.08);
  }
  #rp6-compare tr { border-bottom: 1px solid rgb(255 255 255 / 0.06); cursor: pointer; }
  #rp6-compare tr:hover { background: rgb(255 255 255 / 0.04); }
  #rp6-compare tr[data-active='true'] { background: rgb(243 204 102 / 0.10); }
  #rp6-compare td { padding: 0.75rem 1.25rem; }
  #rp6-compare td.num { text-align: right; font-variant-numeric: lining-nums tabular-nums; }

  .rp6-compass {
    position: absolute;
    top: 12px;
    left: 12px;
    z-index: 2;
    width: 52px;
    height: 52px;
    border-radius: 9999px;
    background: rgb(7 11 29 / 0.72);
    border: 1px solid rgb(214 219 233 / 0.25);
    backdrop-filter: blur(4px);
    pointer-events: none;
  }
  .rp6-compass-arrow {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-between;
    padding: 5px 0;
    font: 700 0.7rem/1 var(--font-sans, sans-serif);
    transition: transform 120ms linear;
  }
  .rp6-compass-n { color: var(--color-brass-300, #f3cc66); }
  .rp6-compass-s { color: var(--color-lune-soft, #adb5cd); }
  @media (prefers-reduced-motion: reduce) {
    .rp6-compass-arrow { transition: none; }
  }
</style>

<script>
  // Activation paresseuse : MapLibre + Three.js + le cerveau ne sont téléchargés
  // qu'au premier geste réel. La clé publique MapTiler est lue via /api/roof-config.
  const fallback = document.getElementById('rp6-fallback');
  const stage = document.getElementById('rp6-stage');
  const searchForm = document.getElementById('rp6-search') as HTMLFormElement | null;
  const addressEl = document.getElementById('rp6-address') as HTMLInputElement | null;
  const openBtn = document.getElementById('rp6-open');
  const placeholder = document.getElementById('rp6-map-placeholder');

  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  let started = false;
  let key = '';
  let mapboxToken = '';

  function showFallback() {
    if (fallback) fallback.hidden = false;
    if (stage) stage.hidden = true;
  }

  async function boot(initialQuery?: string) {
    if (started || !key) return;
    started = true;
    let mapCreated = false;
    try {
      const mod = await import('../../scripts/roof-tool-pro6.ts');
      placeholder?.remove();
      mod.initRoofToolPro6({
        maptilerKey: key,
        mapboxToken: mapboxToken || undefined,
        reducedMotion,
        initialQuery,
        onReady: () => {
          mapCreated = true;
        },
      });
    } catch {
      if (!mapCreated) {
        started = false;
        showFallback();
      }
    }
  }

  (async () => {
    try {
      const res = await fetch('/api/roof-config');
      const cfg = (await res.json()) as { available?: boolean; maptilerKey?: string; mapboxToken?: string };
      if (!cfg.available || !cfg.maptilerKey) {
        showFallback();
        return;
      }
      key = cfg.maptilerKey;
      // Token Mapbox facultatif : présent → imagerie satellite plus nette ;
      // absent → repli transparent sur le style hybride MapTiler.
      mapboxToken = cfg.mapboxToken || '';
      searchForm?.addEventListener('submit', (e) => {
        e.preventDefault();
        boot(addressEl?.value.trim() || undefined);
      });
      openBtn?.addEventListener('click', () => boot());
    } catch {
      showFallback();
    }
  })();
</script>
