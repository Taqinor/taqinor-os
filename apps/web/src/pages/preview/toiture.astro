---
/**
 * PAGE PRIVÉE DE PRÉVISUALISATION — /preview/toiture (noindex, hors nav,
 * exclue du sitemap, non liée). Réservée à la revue mobile du fondateur AVANT
 * toute promotion.
 *
 * « Dessinez votre toit » : le visiteur cherche son adresse, trace le contour
 * de sa toiture sur une carte satellite, voit un calepinage de panneaux à
 * l'échelle, une puissance (kWc), une production annuelle (PVGIS, côté serveur)
 * et une fourchette d'économies — puis bascule vers le MÊME diagnostic/lead que
 * la production (DiagnosticFormEnriched → /api/preview-lead), pré-rempli.
 *
 * La carte (MapLibre) est LOURDE : elle est chargée PARESSEUSEMENT
 * (import() dynamique de src/scripts/roof-tool.ts) — aucune autre page ne la
 * télécharge. Sans clé MapTiler ou sans JS : repli gracieux, jamais de carte
 * cassée. Construite sur le design de production (.v2 + V2Enhance).
 */
import Layout from '../../layouts/Layout.astro';
import V2Enhance from '../../components/V2Enhance.astro';
import DiagnosticFormEnriched from '../../components/DiagnosticFormEnriched.astro';

const inputClass =
  'w-full border border-white/15 bg-white/5 px-3 py-3 text-base text-white placeholder:text-lune-faint outline-none transition-colors focus:border-brass-400 focus:ring-2 focus:ring-brass-400/30';
---

<Layout
  title="Prévisualisation privée — estimateur de toiture | Taqinor"
  description="Page de travail privée, non indexée."
  noindex={true}
>
  <div class="v2">
    <V2Enhance />

    <!-- Bandeau de revue — rappelle que rien n'est en ligne -->
    <section class="border-b border-white/10 bg-nuit-800 px-4 py-14 sm:py-20">
      <div class="mx-auto max-w-6xl">
        <p class="tech-label rule-brass text-brass-300">Prévisualisation privée · non publiée</p>
        <h1 class="display v2-page-title mt-5 max-w-[18ch] text-white">
          Dessinez votre toit, voyez vos panneaux
        </h1>
        <p class="v2-lead mt-6 max-w-2xl text-lune-soft">
          Cherchez votre adresse, tracez le contour de votre toiture sur la vue satellite, et
          l'outil y dépose des panneaux à l'échelle réelle : puissance, production annuelle et
          économies estimées — en quelques secondes. Le site et le formulaire en production restent
          inchangés.
        </p>
        <p class="mt-4 text-sm text-lune-faint">
          Estimation indicative, jamais un devis. <a href="#simulateur" class="text-brass-300 underline underline-offset-2 hover:text-brass-400">Vous préférez le diagnostic classique ?</a>
        </p>
      </div>
    </section>

    <!-- L'OUTIL -->
    <section class="bg-nuit px-4 py-16 sm:py-20">
      <div class="mx-auto max-w-6xl">
        <!-- Mode d'emploi en 3 temps -->
        <ol class="mb-10 grid gap-4 sm:grid-cols-3">
          <li class="border-l-2 border-brass-400/60 pl-4 text-sm text-lune-soft">
            <span class="tech-label block text-brass-300">Étape 1</span>
            <strong class="mt-1 block text-white">Votre adresse</strong>
            La carte zoome sur votre maison en vue satellite.
          </li>
          <li class="border-l-2 border-brass-400/60 pl-4 text-sm text-lune-soft">
            <span class="tech-label block text-brass-300">Étape 2</span>
            <strong class="mt-1 block text-white">Tracez le toit</strong>
            Cliquez les coins ; double-cliquez (ou « Terminer ») pour fermer.
          </li>
          <li class="border-l-2 border-brass-400/60 pl-4 text-sm text-lune-soft">
            <span class="tech-label block text-brass-300">Étape 3</span>
            <strong class="mt-1 block text-white">Votre potentiel</strong>
            Puissance, production et économies — puis l'étude sur WhatsApp.
          </li>
        </ol>

        <!-- Repli gracieux : clé MapTiler absente, ou JavaScript indisponible -->
        <div id="rt-fallback" hidden class="cine-card mb-8 border-l-4 border-alert-300 p-6">
          <p class="font-semibold text-white">Outil momentanément indisponible</p>
          <p class="mt-2 text-sm text-lune-soft">
            La carte interactive n'est pas accessible pour l'instant. Vous pouvez quand même obtenir
            votre étude — <a href="#simulateur" class="text-brass-300 underline underline-offset-2">passez par le diagnostic en 60 secondes</a>, on regarde votre toit ensemble sur WhatsApp.
          </p>
        </div>

        <div id="rt-stage" class="grid gap-6 lg:grid-cols-[1.5fr_1fr] lg:items-start">
          <!-- Colonne carte -->
          <div class="cine-card overflow-hidden">
            <form id="rt-search" class="flex flex-col gap-3 border-b border-white/10 p-4 sm:flex-row">
              <label for="rt-address" class="sr-only">Votre adresse</label>
              <input id="rt-address" name="address" type="text" autocomplete="street-address"
                placeholder="Adresse, quartier ou ville (ex. Casablanca, Maârif)" class={inputClass} />
              <button type="submit"
                class="flex-none bg-brass-400 px-6 py-3 text-base font-bold text-azur-950 transition-colors hover:bg-brass-300">
                Localiser mon toit
              </button>
            </form>

            <!-- Conteneur carte — hauteur réservée (zéro saut de page) -->
            <div id="rt-map" class="rt-map" role="application" aria-label="Carte satellite pour tracer votre toiture">
              <div id="rt-map-placeholder" class="rt-map-placeholder">
                <p class="text-sm text-lune-soft">
                  Saisissez votre adresse ci-dessus pour afficher la vue satellite, ou
                </p>
                <button type="button" id="rt-open"
                  class="mt-3 border border-white/30 px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-white/10">
                  ouvrir la carte sans adresse
                </button>
                <noscript>
                  <p class="mt-3 text-sm text-lune-faint">
                    Cet outil nécessite JavaScript. <a href="#simulateur" class="text-brass-300 underline">Utilisez le diagnostic classique →</a>
                  </p>
                </noscript>
              </div>
            </div>

            <!-- Barre de contrôle du tracé -->
            <div class="flex flex-wrap items-center gap-3 border-t border-white/10 p-4">
              <button type="button" id="rt-finish" disabled
                class="border border-white/25 px-4 py-2.5 text-sm font-semibold text-white transition-colors hover:border-brass-400 hover:text-brass-300 disabled:cursor-not-allowed disabled:opacity-40">
                Terminer le tracé
              </button>
              <button type="button" id="rt-clear"
                class="border border-white/25 px-4 py-2.5 text-sm font-semibold text-lune-soft transition-colors hover:border-white/50 hover:text-white">
                Effacer
              </button>
              <div class="ml-auto flex items-center gap-2">
                <label for="rt-orient" class="text-sm text-lune-soft">Orientation</label>
                <select id="rt-orient" class="border border-white/15 bg-nuit-700 px-3 py-2 text-sm text-white outline-none focus:border-brass-400">
                  <option value="sud" selected>Sud</option>
                  <option value="sud-est">Sud-Est</option>
                  <option value="sud-ouest">Sud-Ouest</option>
                  <option value="est">Est</option>
                  <option value="ouest">Ouest</option>
                  <option value="nord">Nord</option>
                  <option value="inconnu">Je ne sais pas</option>
                </select>
              </div>
            </div>
            <p id="rt-status" class="border-t border-white/10 px-4 py-3 text-sm text-lune-faint" aria-live="polite">
              Cherchez votre adresse pour commencer.
            </p>
          </div>

          <!-- Colonne résultats — espace réservé (aucun CLS à l'apparition) -->
          <div id="rt-results" class="rt-results cine-card p-6">
            <p class="tech-label rule-brass text-brass-300">Votre potentiel solaire</p>
            <dl class="mt-6 grid grid-cols-2 gap-x-6 gap-y-7">
              <div>
                <dd id="rt-res-kwc" class="fig text-3xl text-brass-300 sm:text-4xl">—</dd>
                <dt class="tech-label mt-2 text-lune-faint">Puissance</dt>
              </div>
              <div>
                <dd id="rt-res-panels" class="fig text-3xl text-white sm:text-4xl">—</dd>
                <dt class="tech-label mt-2 text-lune-faint">Panneaux</dt>
              </div>
              <div>
                <dd id="rt-res-area" class="fig text-3xl text-white sm:text-4xl">—</dd>
                <dt class="tech-label mt-2 text-lune-faint">Surface tracée</dt>
              </div>
              <div>
                <dd id="rt-res-prod" class="fig text-2xl text-white sm:text-3xl">—</dd>
                <dt class="tech-label mt-2 text-lune-faint">Production estimée</dt>
              </div>
            </dl>
            <div class="mt-7 border-t border-white/10 pt-6">
              <dd id="rt-res-savings" class="fig text-2xl text-brass-300 sm:text-3xl">—</dd>
              <dt class="tech-label mt-2 text-lune-faint">Économies estimées</dt>
            </div>
            <p id="rt-res-note" class="mt-6 text-xs leading-relaxed text-lune-faint">
              Tracez votre toit pour découvrir votre potentiel solaire.
            </p>
            <button type="button" id="rt-cta" hidden
              class="mt-6 inline-flex w-full items-center justify-center gap-2 bg-ok-600 px-6 py-4 text-base font-bold text-white transition-opacity hover:opacity-90">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 0 0-8.6 15.1L2 22l5-1.3A10 10 0 1 0 12 2Zm5.4 14.1c-.2.6-1.3 1.2-1.8 1.2-.5.1-1 .2-3.3-.7-2.8-1.1-4.6-4-4.7-4.2-.1-.2-1.1-1.5-1.1-2.9s.7-2 1-2.3c.2-.3.5-.3.7-.3h.5c.2 0 .4 0 .6.4l.9 2.1c.1.2.1.4 0 .6l-.4.6-.5.5c-.2.2-.3.4-.1.7.2.3.9 1.4 1.9 2.3 1.3 1.1 2.3 1.5 2.6 1.6.3.1.5.1.7-.1l1-1.2c.2-.3.4-.2.7-.1l2 1c.3.1.5.2.6.4 0 .1 0 .7-.3 1.4Z"/></svg>
              Recevoir mon étude sur WhatsApp
            </button>
          </div>
        </div>
      </div>
    </section>

    <!-- Le MÊME diagnostic/lead que la production (pré-rempli par l'outil) -->
    <DiagnosticFormEnriched heading="Recevez votre étude détaillée" />
  </div>
</Layout>

<style>
  .rt-map {
    position: relative;
    width: 100%;
    height: 60vh;
    min-height: 360px;
    background: var(--color-nuit-700);
  }
  @media (min-width: 1024px) {
    .rt-map { height: 560px; }
  }
  .rt-map-placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
    text-align: center;
  }
  /* Réserve la hauteur du panneau de résultats → aucun saut de page (CLS=0). */
  .rt-results { min-height: 360px; }
  .rt-results--ready { border-color: rgb(243 204 102 / 0.25); }
  /* La carte MapLibre doit remplir son conteneur. */
  .rt-map :global(.maplibregl-map) { position: absolute; inset: 0; }
</style>

<script>
  // Activation paresseuse : MapLibre n'est téléchargé qu'au premier geste réel
  // (recherche d'adresse ou « ouvrir la carte »). La clé publique MapTiler est
  // lue à l'exécution via /api/roof-config — absente → repli gracieux.
  const fallback = document.getElementById('rt-fallback');
  const stage = document.getElementById('rt-stage');
  const searchForm = document.getElementById('rt-search') as HTMLFormElement | null;
  const addressEl = document.getElementById('rt-address') as HTMLInputElement | null;
  const openBtn = document.getElementById('rt-open');
  const placeholder = document.getElementById('rt-map-placeholder');

  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  let started = false;
  let key = '';

  function showFallback() {
    if (fallback) fallback.hidden = false;
    if (stage) stage.hidden = true;
  }

  async function boot(initialQuery?: string) {
    if (started || !key) return;
    started = true;
    placeholder?.remove();
    try {
      const mod = await import('../../scripts/roof-tool.ts');
      mod.initRoofTool({ maptilerKey: key, reducedMotion, initialQuery });
    } catch {
      started = false;
      showFallback();
    }
  }

  (async () => {
    try {
      const res = await fetch('/api/roof-config');
      const cfg = (await res.json()) as { available?: boolean; maptilerKey?: string };
      if (!cfg.available || !cfg.maptilerKey) {
        showFallback();
        return;
      }
      key = cfg.maptilerKey;
      searchForm?.addEventListener('submit', (e) => {
        e.preventDefault();
        boot(addressEl?.value.trim() || undefined);
      });
      openBtn?.addEventListener('click', () => boot());
    } catch {
      showFallback();
    }
  })();
</script>
