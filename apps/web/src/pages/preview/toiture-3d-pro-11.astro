  #rp9-compare td { padding: 0.75rem 1.25rem; }
  #rp9-compare td.num { text-align: right; font-variant-numeric: lining-nums tabular-nums; }
  /* FIX 2 (V6) — en-têtes de tri + filtre de la matrice. */
