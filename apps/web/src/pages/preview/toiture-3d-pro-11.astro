  .rp9-sort[data-active='true'] { color: var(--color-brass-300, #f3cc66); }
  .rp9-sort-arrow { font-variant-numeric: tabular-nums; }
  .rp9-filter { border-radius: 0; }

  /* Listes déroulantes (<select>) : sur fond sombre, le menu natif s'affichait en
     blanc sur blanc — illisible tant qu'une ligne n'était pas survolée. `color-scheme:
     dark` rend le menu natif sombre (Chrome/Firefox/Edge/Safari) ; les couleurs d'option
     explicites sont un repli pour les navigateurs qui ignorent color-scheme. */
  #rp9-matrix-filter,
