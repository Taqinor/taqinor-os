---
/**
 * PAGE PRIVÉE DE PRÉVISUALISATION — /preview/toiture-3d-pro-11 (noindex, hors nav,
 * exclue du sitemap, non liée). COPIE de pro-10 (laissée intacte comme baseline)
 * branchée sur les CERVEAUX V7 + V8 (W34 + W35) : OPTIMISEUR CONTRAINT VIVANT pour les
 * DEUX types de toit.
 *
 *  W35 — le toit EN PENTE reçoit le MÊME optimiseur vivant que le toit plat (W34), avec
 *  deux différences imposées par la pose affleurante : PAS d'axe inclinaison (l'inclinaison
 *  = la pente) et orientation FIXÉE « aligné toit » (azimut = la face). Axes LIBRES en
 *  pente : pose (portrait/paysage), marge de rive, panneaux nécessaires. Verrouiller un
 *  axe le TIENT et re-résout les autres ; chaque axe montre sa valeur « Recommandé » ;
 *  production PVGIS au (pente, face) réels, pose `mountingplace='building'`, repli table.
 *  La pose affleurante coplanaire et la 3D du toit en pente sont INCHANGÉES (modèle V6).
 *
 *  W34 — le toit PLAT garde son optimiseur vivant (estimatorBrainV7) : chaque option
 *  (orientation, inclinaison, pose, marge, panneaux) est un AXE qui se verrouille puis
 *  re-résout en direct au GPS exact ; la matrice complète (V6) reste affichée.
 *
 * pro-9 (cerveau V6) corrigeait DEUX choses de pro-8 :
 *
 *  FIX 1 — TOIT EN PENTE = VRAI PLAN INCLINÉ. pro-8 gardait le calepinage plat et se
 *    contentait d'incliner chaque panneau (tous à la même hauteur). Ici, en pente, la
 *    SURFACE de toit elle-même devient un plan incliné (photo détourée géo-alignée) et
 *    les panneaux sont posés AFFLEURANTS et COPLANAIRES dessus — AUCUN châssis
 *    triangulaire, aucun espacement inter-rangées. La pente est saisie (presets
 *    15/22/30/45°), la face confirmée à la boussole ; production PVGIS au (pente, face)
 *    réels, pose `mountingplace='building'`, repli table « estimé » si injoignable.
 *  FIX 2 — TOIT PLAT : l'optimiseur AFFICHE la MATRICE COMPLÈTE balayée (inclinaison
 *    0→35°, azimut sud ±45° + Est-Ouest, portrait/paysage), production PVGIS au GPS
 *    exact, dans un tableau TRIABLE/FILTRABLE — l'optimum réel épinglé, badgé
 *    « Recommandé ». Plus les ~6 configs nommées du V4.
 *
 *  - Le TYPE DE TOIT (plat vs pente/tuiles) est demandé EN PREMIER, avant de tracer.
 *
 * À comparer avec pro-8 (cerveau V5) et les previews existantes, laissées intactes.
 * Le site et le formulaire en production restent inchangés : cette page ne fait que
 * PRÉ-REMPLIR le diagnostic enrichi (jamais poster de lead).
 *
 * Three.js + MapLibre + le cerveau sont chargés PARESSEUSEMENT (import() dynamique
 * de src/scripts/roof-tool-pro11.ts) : aucune autre page ne les télécharge. Sans clé
 * MapTiler, sans WebGL ou sans JS : repli gracieux. Voir
 * apps/web/BRAIN_V6_NOTES.md, BRAIN_V5_NOTES.md et BRAIN_V4_NOTES.md.
 */
import Layout from '../../layouts/Layout.astro';
import V2Enhance from '../../components/V2Enhance.astro';
import DiagnosticFormEnriched from '../../components/DiagnosticFormEnriched.astro';

const inputClass =
  'w-full border border-white/15 bg-white/5 px-3 py-3 text-base text-white placeholder:text-lune-faint outline-none transition-colors focus:border-brass-400 focus:ring-2 focus:ring-brass-400/30';
const chipClass =
  'rp9-chip border border-white/20 px-3.5 py-2 text-sm font-semibold text-lune-soft transition-colors hover:border-brass-400 hover:text-brass-300';
---

<Layout
  title="Prévisualisation privée — estimateur solaire piloté par la facture | Taqinor"
  description="Page de travail privée, non indexée."
  noindex={true}
>
  <div class="v2">
    <V2Enhance />

    <section class="border-b border-white/10 bg-nuit-800 px-4 py-14 sm:py-20">
      <div class="mx-auto max-w-6xl">
        <p class="tech-label rule-brass text-brass-300">Prévisualisation privée · cerveau facture → calepinage · non publiée</p>
        <h1 class="display v2-page-title mt-5 max-w-[24ch] text-white">
          Votre facture décide de l'angle, des rangées et du nombre de panneaux
        </h1>
        <p class="v2-lead mt-6 max-w-2xl text-lune-soft">
          Cerveaux V7 + V8 — <strong class="text-white">optimiseur contraint vivant</strong> sur les
          DEUX types de toit. Chaque option est un <strong class="text-white">axe</strong> ; au départ
          tout est <strong class="text-white">AUTO</strong> (l'optimum global, chaque groupe badgé
          « Recommandé »), et dès que vous <strong class="text-white">verrouillez</strong> une option,
          tout le reste se <strong class="text-white">re-résout en direct</strong> pour maximiser la
          génération annuelle (PVGIS au GPS exact), les verrous
          <strong class="text-white">s'accumulent</strong>. Sur un toit <strong class="text-white">en
          pente / tuiles</strong>, la pose reste <strong class="text-white">affleurante coplanaire</strong>
          (inclinaison = la pente, azimut = la face, imposés) et les seuls axes libres sont la
          <strong class="text-white">pose, la marge et le nombre de panneaux</strong> ; production PVGIS
          au (pente, face) réels, pose « building ». « Réinitialiser » relâche tout. Le site et le
          formulaire en production restent inchangés.
        </p>
        <p class="mt-4 text-sm text-lune-faint">
          Estimation indicative, jamais un devis. Comparer les versions :
          <a href="/preview/toiture" class="text-brass-300 underline underline-offset-2 hover:text-brass-400">2D</a> ·
          <a href="/preview/toiture-3d" class="text-brass-300 underline underline-offset-2 hover:text-brass-400">3D volumes</a> ·
          <a href="/preview/toiture-3d-pro" class="text-brass-300 underline underline-offset-2 hover:text-brass-400">3D racks</a> ·
          <a href="/preview/toiture-3d-pro-2" class="text-brass-300 underline underline-offset-2 hover:text-brass-400">3D pro-2</a> ·
          <a href="/preview/toiture-3d-pro-3" class="text-brass-300 underline underline-offset-2 hover:text-brass-400">3D pro-3</a> ·
          <a href="/preview/toiture-3d-pro-4" class="text-brass-300 underline underline-offset-2 hover:text-brass-400">3D pro-4</a> ·
          <a href="/preview/toiture-3d-pro-5" class="text-brass-300 underline underline-offset-2 hover:text-brass-400">3D pro-5</a> ·
          <a href="/preview/toiture-3d-pro-6" class="text-brass-300 underline underline-offset-2 hover:text-brass-400">3D pro-6</a> ·
          <a href="/preview/toiture-3d-pro-7" class="text-brass-300 underline underline-offset-2 hover:text-brass-400">3D pro-7</a> ·
          <a href="/preview/toiture-3d-pro-8" class="text-brass-300 underline underline-offset-2 hover:text-brass-400">3D pro-8</a> ·
          <a href="/preview/toiture-3d-pro-9" class="text-brass-300 underline underline-offset-2 hover:text-brass-400">3D pro-9</a> ·
          <a href="/preview/toiture-3d-pro-10" class="text-brass-300 underline underline-offset-2 hover:text-brass-400">3D pro-10</a> ·
          <a href="#simulateur" class="text-brass-300 underline underline-offset-2 hover:text-brass-400">diagnostic</a>.
        </p>
      </div>
    </section>

    <section class="bg-nuit px-4 py-16 sm:py-20">
      <div class="mx-auto max-w-6xl">
        <!-- ÉTAPE FACTURE — d'abord, dans la voix du site -->
        <div class="cine-card mb-8 p-6">
          <p class="tech-label rule-brass text-brass-300">Étape 1 · votre facture</p>
          <label for="rp9-bill" class="mt-3 block max-w-xl text-lune-soft">
            Quelle est votre <strong class="text-white">facture d'électricité moyenne par mois</strong> ?
            On en déduit votre consommation annuelle pour dimensionner l'installation.
          </label>
          <div class="mt-3 flex flex-wrap items-center gap-3">
            <div class="relative">
              <input id="rp9-bill" name="bill" type="text" inputmode="decimal" step="any"
                placeholder="ex. 1 500" class={`${inputClass} max-w-[12rem] pr-12`} />
              <span class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 text-sm text-lune-faint">MAD</span>
            </div>
            <span class="text-xs text-lune-faint">≈ <span id="rp9-bill-kwh" class="fig">—</span> par an</span>
          </div>
        </div>

        <!-- ÉTAPE TYPE DE TOIT — choisie AVANT le tracé (V5). Les puces partagent
             l'attribut data-rooftype avec le panneau de config (toutes câblées). -->
        <div id="rp9-rooftype-first" class="cine-card mb-8 p-6">
          <p class="tech-label rule-brass text-brass-300">Étape 2 · type de toit</p>
          <p class="mt-3 max-w-xl text-lune-soft">
            Votre toit est-il <strong class="text-white">plat</strong> (terrasse, pose sur racks
            inclinés) ou <strong class="text-white">en pente / tuiles</strong> (pose affleurante) ?
            On le demande <strong class="text-white">d'abord</strong> : le calcul et la 3D en dépendent.
          </p>
          <div class="mt-4 flex flex-wrap items-center gap-2">
            <button type="button" data-rooftype="flat" class={chipClass} aria-pressed="true">Toit plat</button>
            <button type="button" data-rooftype="pitched" class={chipClass} aria-pressed="false">Toit en pente / tuiles</button>
          </div>
          <p class="mt-3 text-xs leading-relaxed text-lune-faint">
            Toit plat : l'optimiseur cherche la meilleure inclinaison/orientation (production PVGIS au
            GPS exact). Toit en pente : l'inclinaison et l'azimut sont imposés par le toit ; vous
            saisirez la pente (15/22/30/45°) et la face après le tracé.
          </p>
        </div>

        <ol class="mb-10 grid gap-4 sm:grid-cols-3">
          <li class="border-l-2 border-brass-400/60 pl-4 text-sm text-lune-soft">
            <span class="tech-label block text-brass-300">Étape 3</span>
            <strong class="mt-1 block text-white">Votre adresse</strong>
            La carte zoome sur votre maison en vue satellite.
          </li>
          <li class="border-l-2 border-brass-400/60 pl-4 text-sm text-lune-soft">
            <span class="tech-label block text-brass-300">Étape 4</span>
            <strong class="mt-1 block text-white">Tracez le toit</strong>
            Cliquez les coins ; double-cliquez (ou « Terminer ») pour lancer le calcul.
          </li>
          <li class="border-l-2 border-brass-400/60 pl-4 text-sm text-lune-soft">
            <span class="tech-label block text-brass-300">Étape 5</span>
            <strong class="mt-1 block text-white">Ajustez et choisissez</strong>
            Plat : Sud/Est-Ouest, l'angle, portrait/paysage. Pente : la pente et la face.
          </li>
        </ol>

        <div id="rp9-fallback" hidden class="cine-card mb-8 border-l-4 border-alert-300 p-6">
          <p class="font-semibold text-white">Vue 3D momentanément indisponible</p>
          <p class="mt-2 text-sm text-lune-soft">
            La 3D n'est pas accessible sur cet appareil (carte graphique, clé ou JavaScript).
            Essayez <a href="/preview/toiture" class="text-brass-300 underline underline-offset-2">la version 2D</a>
            ou obtenez votre étude directement — <a href="#simulateur" class="text-brass-300 underline underline-offset-2">le diagnostic en 60 secondes</a>.
          </p>
        </div>

        <div id="rp9-stage" class="grid gap-6 lg:grid-cols-[1.5fr_1fr] lg:items-start">
          <div class="cine-card overflow-hidden">
            <form id="rp9-search" class="flex flex-col gap-3 border-b border-white/10 p-4 sm:flex-row">
              <label for="rp9-address" class="sr-only">Votre adresse</label>
              <!-- W93 — autocomplétion d'adresse : combobox WAI-ARIA. La liste de
                   suggestions (jusqu'à 5) est positionnée sous le champ ; le survol
                   clavier (flèches) met à jour aria-activedescendant ; on ne vole
                   vers une adresse QUE sur sélection. -->
              <div class="relative flex-1">
                <input id="rp9-address" name="address" type="text" autocomplete="off"
                  role="combobox" aria-autocomplete="list" aria-expanded="false"
                  aria-controls="rp9-suggestions" aria-haspopup="listbox"
                  placeholder="Adresse, quartier ou ville (ex. Casablanca, Maârif)" class={inputClass} />
                <ul id="rp9-suggestions" role="listbox" aria-label="Suggestions d'adresses" hidden
                  class="absolute left-0 right-0 top-full z-20 mt-1 max-h-72 overflow-auto border border-white/15 bg-nuit-900 shadow-xl">
                </ul>
              </div>
              <button type="submit"
                class="flex-none bg-brass-400 px-6 py-3 text-base font-bold text-azur-950 transition-colors hover:bg-brass-300">
                Localiser mon toit
              </button>
            </form>

            <div id="rp9-map" class="rp9-map" role="application" aria-label="Carte satellite 3D pour tracer votre toiture">
              <div class="rp9-compass" aria-hidden="true">
                <div id="rp9-compass-arrow" class="rp9-compass-arrow">
                  <span class="rp9-compass-n">N</span>
                  <span class="rp9-compass-s">S</span>
                </div>
              </div>
              <div id="rp9-map-placeholder" class="rp9-map-placeholder">
                <p class="text-sm text-lune-soft">
                  Saisissez votre adresse ci-dessus pour afficher la vue satellite, ou
                </p>
                <button type="button" id="rp9-open"
                  class="mt-3 border border-white/30 px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-white/10">
                  ouvrir la carte sans adresse
                </button>
                <noscript>
                  <p class="mt-3 text-sm text-lune-faint">
                    Cet outil nécessite JavaScript. <a href="/preview/toiture" class="text-brass-300 underline">Version 2D</a> ·
                    <a href="#simulateur" class="text-brass-300 underline">diagnostic classique →</a>
                  </p>
                </noscript>
              </div>
            </div>

            <div class="flex flex-wrap items-center gap-3 border-t border-white/10 p-4">
              <button type="button" id="rp9-finish" disabled
                class="border border-white/25 px-4 py-2.5 text-sm font-semibold text-white transition-colors hover:border-brass-400 hover:text-brass-300 disabled:cursor-not-allowed disabled:opacity-40">
                Terminer le tracé
              </button>
              <!-- W92 — annule le dernier coin posé pendant le tracé (avant fermeture).
                   Masqué tant qu'aucun coin n'est posé / une fois le toit fermé. -->
              <button type="button" id="rp9-undo-point" hidden
                class="border border-white/25 px-4 py-2.5 text-sm font-semibold text-lune-soft transition-colors hover:border-brass-400 hover:text-brass-300">
                Annuler le dernier point
              </button>
              <button type="button" id="rp9-clear"
                class="border border-white/25 px-4 py-2.5 text-sm font-semibold text-lune-soft transition-colors hover:border-white/50 hover:text-white">
                Effacer
              </button>
              <!-- Plusieurs zones — fige la zone tracée et démarre un nouveau tracé.
                   Activé seulement quand la zone active est fermée (cf. script, null-gardé). -->
              <button type="button" id="rp9-add-area" disabled
                class="border border-brass-400 bg-brass-400/10 px-4 py-2.5 text-sm font-bold text-brass-300 transition-colors hover:bg-brass-400/20 disabled:cursor-not-allowed disabled:border-white/25 disabled:bg-transparent disabled:text-lune-faint disabled:opacity-50">
                + Ajouter une zone
              </button>
              <!-- Surface tracée — emplacement réservé (hauteur constante, zéro CLS) -->
              <p id="rp9-area" class="ml-auto min-w-0 text-sm text-lune-faint" aria-live="polite">
                <span>Surface du toit&nbsp;: </span><span id="rp9-area-value" class="fig text-white">—</span>
              </p>
            </div>

            <!-- Contrôles de configuration — la 3D + le cerveau recalculent à chaque clic -->
            <div id="rp9-config" hidden class="space-y-4 border-t border-white/10 bg-nuit-800 p-4">
              <!-- V3 — Type de toit : plat (modèle existant, défaut) ou en pente /
                   tuiles (pose affleurante, inclinaison + azimut imposés par le toit). -->
              <div class="flex flex-wrap items-center gap-2">
                <span class="tech-label mr-1 text-lune-faint">Type de toit</span>
                <button type="button" data-rooftype="flat" class={chipClass} aria-pressed="true">Toit plat</button>
                <button type="button" data-rooftype="pitched" class={chipClass} aria-pressed="false">Toit en pente / tuiles</button>
              </div>
              <!-- W34 — Réinitialiser : relâche TOUS les verrous → l'optimum global vivant.
                   (En toit plat, l'optimum est déjà calé en direct ; ce bouton remet tout en AUTO.) -->
              <div class="flex flex-wrap items-center gap-2">
                <button type="button" id="rp9-optimum"
                  class="border border-brass-400 bg-brass-400/10 px-4 py-2.5 text-sm font-bold text-brass-300 transition-colors hover:bg-brass-400/20">
                  ↺ Réinitialiser
                </button>
                <span id="rp9-optimum-note" class="min-w-0 flex-1 text-xs leading-relaxed text-lune-faint">
                  Tout est calé sur le meilleur compromis. Verrouillez une option et le reste se re-résout en direct ; les verrous s'accumulent. « Réinitialiser » relâche tout.
                </span>
              </div>

              <!-- W34/W35 — Contrôles de config. #rp9-flat-only (orientation / inclinaison /
                   azimut) est PROPRE au toit plat (masqué en pente). « Panneaux » (pose) et
                   « Marge de rive » sont COMMUNS : ce sont les axes LIBRES du toit en pente
                   (W35), donc visibles dans les deux modes. -->
              <div id="rp9-flat-controls" class="space-y-4">
                <!-- Toit PLAT uniquement (orientation / inclinaison / azimut) -->
                <div id="rp9-flat-only" class="space-y-4">
                  <div class="flex flex-wrap items-center gap-2">
                    <span class="tech-label mr-1 text-lune-faint">Orientation</span>
                    <button type="button" data-family="south" class={chipClass} aria-pressed="true">Plein sud<span class="rp9-reco-badge" hidden> ✓ Recommandé</span></button>
                    <button type="button" data-family="eastwest" class={chipClass} aria-pressed="false">Est-Ouest<span class="rp9-reco-badge" hidden> ✓ Recommandé</span></button>
                  </div>
                  <div class="flex flex-wrap items-center gap-2">
                    <span class="tech-label mr-1 text-lune-faint">Inclinaison</span>
                    <button type="button" data-tilt="reco" class={chipClass} aria-pressed="true">Recommandé<span class="rp9-reco-badge" hidden> ✓</span></button>
                    <button type="button" data-tilt="29" class={chipClass} aria-pressed="false">29°<span class="rp9-reco-badge" hidden> ✓ Recommandé</span></button>
                    <button type="button" data-tilt="15" class={chipClass} aria-pressed="false">15°<span class="rp9-reco-badge" hidden> ✓ Recommandé</span></button>
                    <button type="button" data-tilt="10" class={chipClass} aria-pressed="false">10°<span class="rp9-reco-badge" hidden> ✓ Recommandé</span></button>
                  </div>
                  <!-- V2 : curseur d'inclinaison fin (mobile-first). Le cerveau peut
                       recommander une inclinaison plus plate sur un toit limité ; ici on
                       explore librement de 5° à 35°. -->
                  <div class="flex items-center gap-3">
                    <label for="rp9-tilt-range" class="tech-label shrink-0 text-lune-faint">Inclinaison fine</label>
                    <input
                      id="rp9-tilt-range"
                      type="range"
                      min="5"
                      max="35"
                      step="1"
                      value="29"
                      class="rp9-range min-w-0 flex-1"
                      aria-label="Inclinaison des panneaux en degrés"
                    />
                    <span id="rp9-tilt-value" class="w-16 shrink-0 text-right text-sm font-semibold text-brass-300">29° · reco</span>
                  </div>
                  <!-- W1 — Azimut : caché sur un toit aligné (aucun choix réel) ; visible
                       sur un toit tourné, où aligner les rangées sur les arêtes loge
                       plus de panneaux. -->
                  <div id="rp9-azimuth-group" hidden class="flex flex-wrap items-center gap-2">
                    <span class="tech-label mr-1 text-lune-faint">Azimut</span>
                    <button type="button" data-azimuth="south" class={chipClass} aria-pressed="true">Plein sud<span class="rp9-reco-badge" hidden> ✓ Recommandé</span></button>
                    <button type="button" data-azimuth="aligned" class={chipClass} aria-pressed="false">Aligné toit<span class="rp9-reco-badge" hidden> ✓ Recommandé</span></button>
                  </div>
                </div><!-- /rp9-flat-only -->

                <!-- COMMUN (toit plat ET pente) — pose des panneaux : axe libre dans les deux modes -->
                <div class="flex flex-wrap items-center gap-2">
                  <span class="tech-label mr-1 text-lune-faint">Panneaux</span>
                  <button type="button" data-orient="auto" class={chipClass} aria-pressed="true">Auto</button>
                  <button type="button" data-orient="portrait" class={chipClass} aria-pressed="false">Portrait<span class="rp9-reco-badge" hidden> ✓ Recommandé</span></button>
                  <button type="button" data-orient="landscape" class={chipClass} aria-pressed="false">Paysage<span class="rp9-reco-badge" hidden> ✓ Recommandé</span></button>
                </div>
                <!-- COMMUN — marge de rive : garder (0,5 m) ou pleine rive (0 m). Axe libre dans les deux modes. -->
                <div class="flex flex-wrap items-center gap-2">
                  <span class="tech-label mr-1 text-lune-faint">Marge de rive</span>
                  <button type="button" data-margin="keep" class={chipClass} aria-pressed="true">Garder la marge<span class="rp9-reco-badge" hidden> ✓ Recommandé</span></button>
                  <button type="button" data-margin="remove" class={chipClass} aria-pressed="false">Pleine rive<span class="rp9-reco-badge" hidden> ✓ Recommandé</span></button>
                </div>
                <!-- W109 — COMMUN — débord panneaux autorisé : combien (m) un panneau peut
                     déborder de la rive, rails restant sur le toit (fréquent en pente). 0 par
                     défaut → calepinage inchangé. Change la CAPACITÉ géométrique seulement :
                     le nombre posé reste plafonné au besoin (facture). step="any" → jamais de snap. -->
                <div class="flex flex-wrap items-center gap-2">
                  <label for="rp9-overhang-input" class="tech-label mr-1 text-lune-faint">Débord panneaux autorisé (m)</label>
                  <input id="rp9-overhang-input" type="number" inputmode="decimal" step="any" min="0"
                    value="0" autocomplete="off"
                    class="fig h-9 w-20 border border-white/20 bg-nuit-900 px-2 text-center text-base text-white outline-none focus:border-brass-400" />
                  <span class="text-xs text-lune-faint">rails sur le toit · capacité seule, jamais au-delà du besoin</span>
                </div>
              </div><!-- /rp9-flat-controls -->

              <!-- Contrôles TOIT EN PENTE / TUILES (masqués en mode plat). La pente
                   et la face sont SAISIES (non mesurables sur l'imagerie marocaine) ;
                   elles IMPOSENT l'inclinaison et l'azimut de l'array (lecture seule). -->
              <div id="rp9-pitched-controls" hidden class="space-y-4">
                <!-- W47 — Orientation en pente : « Alignée toit » est PRÉSENTE, par DÉFAUT et
                     FORCÉE (lecture seule). Sur un toit en pente, chaque panneau est
                     coplanaire au pan (normale panneau = normale du pan) : inclinaison = pente,
                     azimut = face. Plein-sud tourné et tentes Est-Ouest sont PHYSIQUEMENT
                     impossibles pour une pose affleurante → non proposés (≠ toit plat). -->
                <div id="rp9-pitched-orientation" class="flex flex-wrap items-center gap-2">
                  <span class="tech-label mr-1 text-lune-faint">Orientation</span>
                  <button type="button" data-pitched-orient="aligned" class={chipClass}
                    aria-pressed="true" aria-disabled="true" disabled
                    title="Pose affleurante : les panneaux suivent le pan du toit (inclinaison = pente, azimut = face).">
                    Alignée toit
                  </button>
                  <span class="text-xs text-lune-faint">imposée · panneaux coplanaires au pan</span>
                </div>
                <div class="flex flex-wrap items-center gap-2">
                  <span class="tech-label mr-1 text-lune-faint">Pente du toit</span>
                  <button type="button" data-pitch="15" class={chipClass} aria-pressed="false">~15°</button>
                  <button type="button" data-pitch="22" class={chipClass} aria-pressed="true">~22°</button>
                  <button type="button" data-pitch="30" class={chipClass} aria-pressed="false">~30°</button>
                  <button type="button" data-pitch="45" class={chipClass} aria-pressed="false">~45°</button>
                </div>
                <div class="flex items-center gap-3">
                  <label for="rp9-pitch-range" class="tech-label shrink-0 text-lune-faint">Pente fine</label>
                  <input id="rp9-pitch-range" type="range" min="5" max="45" step="1" value="22"
                    class="rp9-range min-w-0 flex-1"
                    aria-label="Pente du toit en degrés" />
                  <span id="rp9-pitch-value" class="w-12 shrink-0 text-right text-sm font-semibold text-brass-300">22°</span>
                </div>
                <div class="flex flex-wrap items-center gap-2">
                  <span class="tech-label mr-1 text-lune-faint">Face du pan</span>
                  <button type="button" data-facing="180" class={chipClass} aria-pressed="true">Sud</button>
                  <button type="button" data-facing="135" class={chipClass} aria-pressed="false">Sud-Est</button>
                  <button type="button" data-facing="225" class={chipClass} aria-pressed="false">Sud-Ouest</button>
                  <button type="button" data-facing="90" class={chipClass} aria-pressed="false">Est</button>
                  <button type="button" data-facing="270" class={chipClass} aria-pressed="false">Ouest</button>
                </div>
                <!-- W106 — note : la face d'un pan adjacent à une autre zone est AUTO-orientée
                     vers la faîtière commune ; un clic « Face du pan » la corrige (par zone). -->
                <p id="rp9-facing-note" class="min-h-[1rem] text-xs leading-relaxed text-lune-faint" aria-live="polite"></p>
                <!-- Correction FINE du sens de la pente : les 5 boutons cardinaux ne
                     couvrent ni les directions intermédiaires ni le nord. Ce curseur
                     0–359° règle la VRAIE face descendante du pan, par zone, quand le
                     choix automatique (W106) est faux. Hauteur réservée (zéro CLS), saisie
                     libre (step="any") — aucun nombre tapé n'est rejeté. -->
                <div class="flex items-center gap-3">
                  <label for="rp9-facing-range" class="tech-label shrink-0 text-lune-faint">Sens de la pente — vers où le toit descend (corriger si besoin)</label>
                  <input id="rp9-facing-range" type="range" min="0" max="359" step="any" value="180"
                    class="rp9-range min-w-0 flex-1"
                    aria-label="Sens de la pente du toit en degrés (0 = nord, 90 = est, 180 = sud, 270 = ouest)" />
                  <span id="rp9-facing-value" class="min-h-[1.25rem] w-28 shrink-0 text-right text-sm font-semibold text-brass-300" aria-live="polite">Sud · 180°</span>
                </div>
                <p class="border border-white/10 bg-nuit-900/40 p-3 text-xs leading-relaxed text-lune-faint">
                  Pose affleurante (panneaux à plat sur les tuiles, sans rangées espacées).
                  <span class="text-lune-soft">Inclinaison = pente du toit · Azimut = face du pan</span>
                  — imposés par la toiture. <strong class="text-white">Vous pouvez corriger ici le
                  sens de la pente</strong> (vers où le toit descend) si le choix automatique est
                  faux : le curseur règle n'importe quelle direction (0–359°) et re-calcule la pose
                  en direct, par zone. La production vient de PVGIS à ces valeurs réelles. La pente
                  est saisie (non mesurable sur l'imagerie satellite marocaine).
                </p>
                <p id="rp9-pitched-note" class="min-h-[1.25rem] text-xs leading-relaxed text-lune-soft" aria-live="polite"></p>
              </div>

              <!-- W87 — Soleil réel : l'ombre portée de la scène 3D suit une VRAIE position
                   solaire (latitude du toit + heure + saison). Le défaut « midi solstice
                   d'hiver » est le PIRE cas d'ombrage : à cet angle, les rangées espacées par
                   la géométrie solaire se dégagent visiblement (la preuve de l'anti-ombrage).
                   Curseur d'heure solaire + bascule saison. Zéro CLS (hauteur réservée). -->
              <div id="rp9-sun-controls" class="space-y-3 border border-white/10 bg-nuit-900/40 p-3">
                <div class="flex items-center gap-3">
                  <label for="rp9-sun-hour" class="tech-label shrink-0 text-lune-faint">Heure du soleil</label>
                  <input id="rp9-sun-hour" type="range" min="6" max="18" step="1" value="12"
                    class="rp9-range min-w-0 flex-1"
                    aria-label="Heure solaire (6 h à 18 h, midi solaire = 12 h)" />
                  <span id="rp9-sun-hour-value" class="w-12 shrink-0 text-right text-sm font-semibold text-brass-300">12 h</span>
                </div>
                <div class="flex flex-wrap items-center gap-2">
                  <span class="tech-label mr-1 text-lune-faint">Saison</span>
                  <button type="button" data-sun-season="winter" class={chipClass} aria-pressed="true">Hiver (pire cas)</button>
                  <button type="button" data-sun-season="summer" class={chipClass} aria-pressed="false">Été</button>
                </div>
                <p class="text-xs leading-relaxed text-lune-faint">
                  L'ombre de la 3D suit le vrai soleil à la latitude du toit. Au
                  <strong class="text-lune-soft">midi du solstice d'hiver</strong> (pire cas),
                  les rangées se dégagent l'une l'autre — c'est la preuve de l'espacement
                  anti-ombrage.
                </p>
                <!-- WJ21 — carte d'accès solaire (heatmap d'irradiance) : teinte chaque
                     panneau par sa part réelle d'irradiation annuelle reçue (astronomie
                     pure, pondérée par l'irradiation du lieu). Bascule manuelle. -->
                <div class="flex flex-wrap items-center gap-2 border-t border-white/10 pt-3">
                  <span class="tech-label mr-1 text-lune-faint">Accès solaire</span>
                  <button type="button" id="rp9-heatmap-toggle" class={chipClass} aria-pressed="false">
                    Carte d'accès solaire
                  </button>
                </div>
                <p id="rp9-heatmap-note" class="min-h-[1.25rem] text-xs leading-relaxed text-lune-faint" aria-live="polite"></p>
              </div>

              <div class="flex flex-wrap items-center gap-2">
                <span class="tech-label mr-1 text-lune-faint">Obstacles</span>
                <button type="button" id="rp9-obstacle" class={chipClass}>Ajouter un obstacle (cheminée…)</button>
                <button type="button" id="rp9-obstacle-clear" class={chipClass}>Tout effacer</button>
              </div>
              <p class="text-xs leading-relaxed text-lune-faint">
                Marquez les obstacles (climatiseur, cheminée, lanterneau, citerne…) —
                on n'y posera pas de panneaux. Glissez sur le toit pour dessiner un
                rectangle ; touchez-le pour le redimensionner. Un dégagement de
                0,3 m est réservé tout autour.
              </p>

              <!-- Panneau d'édition d'un obstacle sélectionné (tactile) -->
              <div id="rp9-obs-edit" hidden class="border border-white/15 bg-nuit-900/40 p-4">
                <div class="flex items-center justify-between gap-3">
                  <span class="tech-label text-brass-300">Obstacle sélectionné</span>
                  <button type="button" id="rp9-obs-delete"
                    class="border border-alert-300/60 px-3 py-2 text-sm font-semibold text-alert-300 transition-colors hover:bg-alert-300/10">
                    × Supprimer
                  </button>
                </div>
                <div class="mt-3 grid grid-cols-2 gap-3">
                  <label class="block text-sm text-lune-soft">
                    Longueur (m)
                    <input id="rp9-obs-length" type="text" inputmode="decimal" step="any"
                      class={`${inputClass} mt-1`} />
                  </label>
                  <label class="block text-sm text-lune-soft">
                    Largeur (m)
                    <input id="rp9-obs-width" type="text" inputmode="decimal" step="any"
                      class={`${inputClass} mt-1`} />
                  </label>
                </div>
                <div class="mt-3 flex items-center gap-3">
                  <span class="tech-label text-lune-faint">Taille</span>
                  <button type="button" id="rp9-obs-minus" aria-label="Réduire l'obstacle"
                    class="h-11 w-11 border border-white/25 text-xl font-bold text-white transition-colors hover:border-brass-400 hover:text-brass-300">−</button>
                  <button type="button" id="rp9-obs-plus" aria-label="Agrandir l'obstacle"
                    class="h-11 w-11 border border-white/25 text-xl font-bold text-white transition-colors hover:border-brass-400 hover:text-brass-300">+</button>
                  <span id="rp9-obs-dims" class="fig text-sm text-lune-soft">—</span>
                </div>
              </div>
            </div>

            <!-- W69 — « PERSONNALISER LA DISPOSITION » : COLLÉE AU PLAN (juste sous la carte
                 3D), repliée par défaut et dépliable. Déplacer/ajouter/retirer des panneaux sur
                 la LATTICE valide (cellules déjà validées par l'optimiseur). Le PLAN TACTILE
                 (touche-panneau → touche-emplacement) est la méthode fiable ; le glissé sur la
                 3D reste un bonus. Masquée tant qu'aucun plan n'existe. -->
            <div id="rp9-layout-window" hidden class="border-t border-white/10 bg-nuit-800 p-4">
              <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-2">
                <p class="tech-label text-brass-300">Personnaliser la disposition</p>
                <button type="button" id="rp9-layout-toggle" aria-pressed="false"
                  class="border border-brass-400 bg-brass-400/10 px-4 py-2 text-sm font-bold text-brass-300 transition-colors hover:bg-brass-400/20">
                  Déplacer les panneaux
                </button>
              </div>
              <p class="mt-2 text-xs leading-relaxed text-lune-faint">
                Activez, puis dans le <strong class="text-lune-soft">plan tactile</strong> ci-dessous
                touchez un panneau (bleu) puis un emplacement libre (vert) pour l'y déplacer — ou
                utilisez <strong class="text-lune-soft">+ / −</strong>. Vous pouvez aussi glisser un
                panneau directement sur la 3D. Les panneaux se calent toujours sur des emplacements
                valides (jamais hors toit, hors retrait ou sur un obstacle) ; le nombre, la puissance,
                la production et les économies se recalculent.
              </p>

              <div id="rp9-layout-panel" hidden class="mt-5 space-y-5">
                <dl class="grid grid-cols-2 gap-x-6 gap-y-4 sm:grid-cols-4">
                  <div>
                    <dd id="rp9-layout-count" class="fig text-lg text-white sm:text-xl">—</dd>
                    <dt class="tech-label mt-0.5 text-lune-faint">Panneaux posés</dt>
                  </div>
                  <div>
                    <dd id="rp9-layout-kwc" class="fig text-lg text-white sm:text-xl">—</dd>
                    <dt class="tech-label mt-0.5 text-lune-faint">Puissance</dt>
                  </div>
                  <div>
                    <dd id="rp9-layout-free" class="fig text-lg text-white sm:text-xl">—</dd>
                    <dt class="tech-label mt-0.5 text-lune-faint">Emplacements libres</dt>
                  </div>
                  <div>
                    <dd id="rp9-layout-cover" class="fig text-lg text-brass-300 sm:text-xl">—</dd>
                    <dt class="tech-label mt-0.5 text-lune-faint">Couverture besoin</dt>
                  </div>
                </dl>

                <!-- Boutons +/− (touch + mouvement réduit, sans glissé fin) -->
                <div class="flex flex-wrap items-center gap-3">
                  <span class="tech-label text-lune-faint">Ajouter / retirer</span>
                  <button type="button" id="rp9-layout-minus" aria-label="Retirer un panneau"
                    class="h-11 w-11 border border-white/25 text-2xl font-bold text-white transition-colors hover:border-brass-400 hover:text-brass-300 disabled:cursor-not-allowed disabled:opacity-40">−</button>
                  <button type="button" id="rp9-layout-plus" aria-label="Ajouter un panneau"
                    class="h-11 w-11 border border-white/25 text-2xl font-bold text-white transition-colors hover:border-brass-400 hover:text-brass-300 disabled:cursor-not-allowed disabled:opacity-40">+</button>
                  <button type="button" id="rp9-layout-fill"
                    class="border border-brass-400 bg-brass-400/10 px-4 py-2.5 text-sm font-bold text-brass-300 transition-colors hover:bg-brass-400/20 disabled:cursor-not-allowed disabled:opacity-40">
                    ⤢ Remplir automatiquement
                  </button>
                  <button type="button" id="rp9-layout-reset"
                    class="ml-auto border border-brass-400 bg-brass-400/10 px-4 py-2.5 text-sm font-bold text-brass-300 transition-colors hover:bg-brass-400/20">
                    ↺ Réinitialiser la disposition optimale
                  </button>
                </div>

                <!-- Repli tactile : tap-sélection d'un panneau → tap-cible d'un emplacement vide.
                     Une mini-carte des cellules (occupées / libres) rend l'interaction code-vérifiable
                     et fonctionne sans glissé fin ni mouvement. -->
                <div>
                  <p class="tech-label text-lune-faint">Plan des emplacements (tactile) — touchez un panneau, puis un emplacement libre</p>
                  <div id="rp9-layout-grid" class="rp9-layout-grid mt-3" role="group" aria-label="Plan des emplacements de panneaux"></div>
                  <p id="rp9-layout-note" class="mt-2 min-h-[1.25rem] text-xs leading-relaxed text-lune-soft" aria-live="polite"></p>
                </div>
              </div>
            </div>

            <p id="rp9-status" class="border-t border-white/10 px-4 py-3 text-sm text-lune-faint" aria-live="polite">
              Indiquez votre facture, puis cherchez votre adresse pour commencer.
            </p>
          </div>

          <!-- RECOMMANDATION + COMPARATIF — largeurs réservées (zéro CLS) -->
          <div id="rp9-results" class="rp9-results cine-card p-6">
            <p class="tech-label rule-brass text-brass-300">Recommandation</p>
            <p id="rp9-reco-title" class="fig mt-4 text-2xl text-brass-300 sm:text-3xl">—</p>

            <!-- Plafond « panneaux nécessaires » — éditable, jamais dépassé quelle
                 que soit l'orientation. Emplacement réservé (la carte réserve déjà
                 520px) → aucun saut de mise en page. -->
            <div class="mt-5 border border-white/10 bg-nuit-800/60 p-4">
              <label for="rp9-need-input" class="tech-label text-lune-faint">Panneaux nécessaires</label>
              <div class="mt-2 flex items-center gap-3">
                <button type="button" id="rp9-need-minus" aria-label="Un panneau de moins"
                  class="h-11 w-11 flex-none border border-white/25 text-2xl font-bold text-white transition-colors hover:border-brass-400 hover:text-brass-300 disabled:cursor-not-allowed disabled:opacity-40">−</button>
                <input id="rp9-need-input" type="text" inputmode="numeric" autocomplete="off"
                  aria-label="Nombre de panneaux nécessaires" value="—" disabled
                  class="fig h-11 w-20 border border-white/20 bg-nuit-900 text-center text-2xl text-white outline-none focus:border-brass-400 disabled:opacity-50" />
                <button type="button" id="rp9-need-plus" aria-label="Un panneau de plus"
                  class="h-11 w-11 flex-none border border-white/25 text-2xl font-bold text-white transition-colors hover:border-brass-400 hover:text-brass-300 disabled:cursor-not-allowed disabled:opacity-40">+</button>
              </div>
              <p id="rp9-need-note" class="mt-2 min-h-[1.5rem] text-xs leading-relaxed text-lune-faint" aria-live="polite"></p>
            </div>

            <dl class="mt-5 grid grid-cols-2 gap-x-6 gap-y-6" aria-live="polite">
              <div>
                <dd id="rp9-reco-kwc" class="fig text-2xl text-white sm:text-3xl">—</dd>
                <dt class="tech-label mt-1 text-lune-faint">Puissance</dt>
              </div>
              <div>
                <dd id="rp9-reco-panels" class="fig text-2xl text-white sm:text-3xl">—</dd>
                <dt class="tech-label mt-1 text-lune-faint">Panneaux</dt>
              </div>
              <div>
                <dd id="rp9-reco-prod" class="fig text-xl text-white sm:text-2xl">—</dd>
                <dt class="tech-label mt-1 text-lune-faint">Production estimée</dt>
              </div>
              <div>
                <dd id="rp9-reco-cover" class="fig text-xl text-white sm:text-2xl">—</dd>
                <dt class="tech-label mt-1 text-lune-faint">Couverture facture</dt>
              </div>
            </dl>
            <div class="mt-5 border-t border-white/10 pt-5">
              <dd id="rp9-reco-savings" class="fig text-xl text-brass-300 sm:text-2xl">—</dd>
              <dt class="tech-label mt-1 text-lune-faint">Économies estimées</dt>
            </div>
            <p id="rp9-reco-why" class="mt-5 min-h-[3.5rem] text-xs leading-relaxed text-lune-soft">
              Indiquez votre facture et tracez votre toit pour voir la recommandation.
            </p>
            <p id="rp9-reco-bifacial" class="mt-2 text-xs leading-relaxed text-lune-faint/80"></p>
            <!-- W94 — fourchette d'honnêteté Année 1 ↔ Année 25 (dégradation linéaire des
                 panneaux ; économies plafonnées à la facture à chaque horizon). Hauteur
                 réservée (min-h) pour zéro CLS ; aria-live polite pour l'annoncer. -->
            <p id="rp9-reco-band" class="mt-2 min-h-[2.5rem] text-xs leading-relaxed text-lune-faint/80" aria-live="polite"></p>
            <!-- WJ22 — couche de pertes climatiques honnêtes (fourchette de confiance) :
                 bascule opt-in. Corrige la sur-estimation estivale côtière (~15–20 %) et
                 rend la production/les économies en fourchette, pas un chiffre unique. -->
            <div class="mt-3 flex flex-wrap items-center gap-2">
              <button type="button" id="rp9-climate-toggle" class={chipClass} aria-pressed="false">
                Fourchette réaliste (été côtier)
              </button>
            </div>
            <p id="rp9-reco-climate" class="mt-2 min-h-[2.5rem] text-xs leading-relaxed text-lune-faint/80" aria-live="polite"></p>
            <p id="rp9-maxline" class="mt-3 text-xs leading-relaxed text-lune-faint"></p>

            <!-- W86 — libellé HONNÊTE : ce bouton ne fait AUCUNE action WhatsApp ;
                 il ne fait que pré-remplir le diagnostic puis y défiler (l'étape
                 WhatsApp réelle est la soumission du formulaire de diagnostic). -->
            <button type="button" id="rp9-cta" hidden
              class="mt-6 inline-flex w-full items-center justify-center gap-2 bg-ok-600 px-6 py-4 text-base font-bold text-white transition-opacity hover:opacity-90">
              Continuer vers le diagnostic →
            </button>
          </div>
        </div>

        <!-- W110 + diagnostic « une page » (pro-11) : le formulaire est RELOCALISÉ ICI,
             directement sous le résultat/CTA, et passé en mode UNE PAGE (singleStep) — le
             visiteur ne tape que Nom/Téléphone/Adresse, le reste (facture/toit/surface/
             orientation/kWc) est pré-rempli par le simulateur. « Continuer vers le diagnostic »
             y défile (id #simulateur) — JAMAIS de lead posté par le simulateur (garde W85/W97).
             Le composant partagé et tout son flux lead restent intacts. -->
        <DiagnosticFormEnriched heading="Recevez votre étude détaillée" singleStep={true} />

        <!-- ZONES — « Plusieurs zones de panneaux ». Chaque zone est dimensionnée par
             l'optimiseur existant (best-fit) puis ajustable au panneau près ; le total
             SOMME panneaux / kWc / production / économies sur TOUTES les zones. La 3D et
             les sous-panneaux (production, conso, disposition) restent liés à la zone
             ACTIVE. Affichée dès qu'une zone est calculée (script bascule .hidden). -->
        <div id="rp9-areas-window" hidden class="cine-card mt-6 p-5 sm:p-6">
          <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
            <p class="tech-label rule-brass text-brass-300">Total — toutes les zones</p>
            <p class="text-xs text-lune-faint">Chaque zone est dimensionnée puis ajustable ; les totaux additionnent toutes les zones.</p>
          </div>
          <dl class="mt-4 grid grid-cols-2 gap-x-6 gap-y-4 sm:grid-cols-4" aria-live="polite">
            <div>
              <dd id="rp9-areas-total-panels" class="fig text-lg text-white sm:text-xl">—</dd>
              <dt class="tech-label mt-0.5 text-lune-faint">Panneaux</dt>
            </div>
            <div>
              <dd id="rp9-areas-total-kwc" class="fig text-lg text-white sm:text-xl">—</dd>
              <dt class="tech-label mt-0.5 text-lune-faint">Puissance</dt>
            </div>
            <div>
              <dd id="rp9-areas-total-prod" class="fig text-lg text-white sm:text-xl">—</dd>
              <dt class="tech-label mt-0.5 text-lune-faint">Production estimée</dt>
            </div>
            <div>
              <dd id="rp9-areas-total-savings" class="fig text-lg text-brass-300 sm:text-xl">—</dd>
              <dt class="tech-label mt-0.5 text-lune-faint">Économies estimées</dt>
            </div>
          </dl>
          <!-- Liste des zones (script-rendu) : libellé, panneaux, kWc, « Voir » + suppr.
               La zone active est mise en évidence. -->
          <ul id="rp9-areas-list" class="mt-5 space-y-2"></ul>
          <p class="mt-3 text-xs leading-relaxed text-lune-faint">
            « + Ajouter une zone » fige la zone tracée et démarre un nouveau tracé sur la même
            facture. La 3D et les graphes détaillés affichent la zone sélectionnée (« Voir ») ;
            les totaux ci-dessus restent la somme de toutes les zones. Chiffres indicatifs, pas un devis.
          </p>
        </div>

        <!-- V4 — OPTIMUM CALCULÉ : le vrai gagnant de la grille fine (production
             PVGIS au GPS exact). Sa PROPRE ligne quand ce n'est pas une config
             standard ; badgée « Recommandé », avec la raison et la source. -->
        <div id="rp9-optimum-card" hidden class="cine-card mt-6 border-l-4 border-brass-400 p-5">
          <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
            <p class="tech-label text-brass-300">
              Optimum calculé <span class="rp9-reco-badge">✓ Recommandé</span>
            </p>
            <p class="text-xs text-lune-faint">
              Production : <span id="rp9-optimum-source" class="font-semibold text-lune-soft">—</span>
            </p>
          </div>
          <p id="rp9-optimum-label" class="fig mt-3 text-lg text-white sm:text-xl">—</p>
          <dl class="mt-4 grid grid-cols-2 gap-x-6 gap-y-4 sm:grid-cols-4">
            <div><dd id="rp9-optimum-kwc" class="fig text-lg text-white">—</dd><dt class="tech-label mt-0.5 text-lune-faint">kWc</dt></div>
            <div><dd id="rp9-optimum-panels" class="fig text-lg text-white">—</dd><dt class="tech-label mt-0.5 text-lune-faint">Panneaux</dt></div>
            <div><dd id="rp9-optimum-prod" class="fig text-lg text-white">—</dd><dt class="tech-label mt-0.5 text-lune-faint">kWh/an</dt></div>
            <div><dd id="rp9-optimum-cover" class="fig text-lg text-brass-300">—</dd><dt class="tech-label mt-0.5 text-lune-faint">% facture</dt></div>
          </dl>
          <p id="rp9-optimum-why" class="mt-3 text-xs leading-relaxed text-lune-soft">—</p>
          <button type="button" id="rp9-optimum-apply"
            class="mt-4 border border-brass-400 bg-brass-400/10 px-4 py-2.5 text-sm font-bold text-brass-300 transition-colors hover:bg-brass-400/20">
            Appliquer cet optimum
          </button>
        </div>

        <!-- W50 — FENÊTRE « PRODUCTION ESTIMÉE » : Année / Mois / Jour. Reflète le plan
             gagnant (GPS + inclinaison + azimut + pose + panneaux) ; les données viennent
             de /api/roof-production (serveur → PVGIS, jamais le client). Espace graphe
             RÉSERVÉ (hauteur fixe) → zéro saut de mise en page. Masquée tant qu'aucun plan
             n'est calculé. -->
        <div id="rp9-prod-window" hidden class="cine-card mt-6 p-5 sm:p-6">
          <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
            <p class="tech-label rule-brass text-brass-300">Production estimée</p>
            <p id="rp9-prod-source" class="text-xs text-lune-faint">—</p>
          </div>

          <!-- Toggle de portée -->
          <div id="rp9-prod-scope" class="mt-4 flex flex-wrap items-center gap-2" role="group" aria-label="Portée de la production">
            <button type="button" data-prod-scope="year" class={chipClass} aria-pressed="true">Année</button>
            <button type="button" data-prod-scope="month" class={chipClass} aria-pressed="false">Mois</button>
            <button type="button" data-prod-scope="day" class={chipClass} aria-pressed="false">Jour</button>

            <!-- Sélecteur de mois (visible en Mois et Jour) -->
            <div id="rp9-prod-month-picker" hidden class="ml-auto flex items-center gap-2">
              <button type="button" id="rp9-prod-month-prev" aria-label="Mois précédent"
                class="h-9 w-9 border border-white/25 text-lg font-bold text-white transition-colors hover:border-brass-400 hover:text-brass-300">‹</button>
              <span id="rp9-prod-month-label" class="fig min-w-[6.5rem] text-center text-sm font-semibold text-brass-300">—</span>
              <button type="button" id="rp9-prod-month-next" aria-label="Mois suivant"
                class="h-9 w-9 border border-white/25 text-lg font-bold text-white transition-colors hover:border-brass-400 hover:text-brass-300">›</button>
            </div>
          </div>

          <!-- Sélecteur de jour (visible en Jour seulement) : par défaut le « jour type » -->
          <div id="rp9-prod-day-picker" hidden class="mt-3 flex flex-wrap items-center gap-2">
            <span class="tech-label mr-1 text-lune-faint">Jour</span>
            <button type="button" id="rp9-prod-day-prev" aria-label="Jour précédent"
              class="h-9 w-9 border border-white/25 text-lg font-bold text-white transition-colors hover:border-brass-400 hover:text-brass-300">‹</button>
            <span id="rp9-prod-day-label" class="fig min-w-[8rem] text-center text-sm font-semibold text-brass-300">—</span>
            <button type="button" id="rp9-prod-day-next" aria-label="Jour suivant"
              class="h-9 w-9 border border-white/25 text-lg font-bold text-white transition-colors hover:border-brass-400 hover:text-brass-300">›</button>
            <button type="button" id="rp9-prod-day-reset" hidden
              class="ml-1 border border-white/25 px-3 py-1.5 text-xs font-semibold text-lune-soft transition-colors hover:border-brass-400 hover:text-brass-300">
              Jour type
            </button>
          </div>

          <!-- Chiffre de tête — W86 : annoncé aux lecteurs d'écran quand il change. -->
          <p id="rp9-prod-headline" class="fig mt-4 text-2xl text-white sm:text-3xl" aria-live="polite">—</p>
          <p id="rp9-prod-sub" class="mt-1 text-sm text-lune-soft" aria-live="polite">—</p>

          <!-- Graphe inline SVG — hauteur RÉSERVÉE (zéro CLS). viewBox 320×140, étiré en largeur. -->
          <div class="rp9-prod-graph-wrap mt-4">
            <svg id="rp9-prod-graph" viewBox="0 0 320 140" preserveAspectRatio="none"
              class="rp9-prod-graph" role="img" aria-label="Graphe de production estimée"></svg>
          </div>

          <p id="rp9-prod-savings" class="mt-3 text-sm text-brass-300"></p>
          <p class="mt-2 text-xs leading-relaxed text-lune-faint">
            Année : production mensuelle (kWh) sur 12 mois. Mois : production journalière du mois choisi.
            Jour : courbe horaire de puissance (kW) — par défaut le <strong class="text-lune-soft">jour type</strong>
            (moyenne du mois) ; cyclez les jours pour une date précise. Les économies sont
            <strong class="text-lune-soft">plafonnées</strong> à l'autoconsommation réellement alignée — jamais
            production × tarif. Chiffres indicatifs, pas un devis.
          </p>
        </div>

        <!-- W68 — « AFFINER MA CONSOMMATION » : courbe horaire de conso éditable (glissé
             + saisie numérique) ET calculateur d'appareils, qui REDÉFINISSENT
             l'autoconsommation, les économies (plafonnées billMAD), le dimensionnement
             et la batterie. Masqué tant qu'aucun plan de production n'est calculé.
             Espace réservé (hauteur fixe du graphe) → zéro saut de mise en page. -->
        <div id="rp9-cons-window" hidden class="cine-card mt-6 p-5 sm:p-6">
          <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-2">
            <p class="tech-label rule-brass text-brass-300">Affiner ma consommation</p>
            <button type="button" id="rp9-cons-toggle" aria-expanded="false"
              class="border border-brass-400 bg-brass-400/10 px-4 py-2 text-sm font-bold text-brass-300 transition-colors hover:bg-brass-400/20">
              Affiner ma consommation
            </button>
          </div>
          <p class="mt-2 text-xs leading-relaxed text-lune-faint">
            Par défaut votre consommation suit une courbe type calée sur votre facture.
            Affinez-la pour voir l'<strong class="text-lune-soft">autoconsommation</strong>, les
            <strong class="text-lune-soft">économies</strong> (toujours plafonnées à la facture) et la
            <strong class="text-lune-soft">batterie</strong> recommandée bouger en direct.
            Un appareil <strong class="text-lune-soft">déjà compris</strong> ne fait que redessiner la
            répartition (total inchangé) ; un appareil <strong class="text-lune-soft">en plus</strong>
            (clim ou voiture neuve) augmente le total, donc le nombre de panneaux et la batterie.
          </p>

          <div id="rp9-cons-panel" hidden class="mt-5 space-y-6">
            <!-- Bandeau de synthèse : total conso, autoconso, économies, batterie -->
            <dl class="grid grid-cols-2 gap-x-6 gap-y-4 sm:grid-cols-4">
              <div>
                <dd id="rp9-cons-total" class="fig text-lg text-white sm:text-xl">—</dd>
                <dt class="tech-label mt-0.5 text-lune-faint">Conso/jour</dt>
              </div>
              <div>
                <dd id="rp9-cons-self" class="fig text-lg text-brass-300 sm:text-xl">—</dd>
                <dt class="tech-label mt-0.5 text-lune-faint">Autoconsommation</dt>
              </div>
              <div>
                <dd id="rp9-cons-savings" class="fig text-lg text-brass-300 sm:text-xl">—</dd>
                <dt class="tech-label mt-0.5 text-lune-faint">Économies/an</dt>
              </div>
              <div>
                <dd id="rp9-cons-batt" class="fig text-lg text-white sm:text-xl">—</dd>
                <dt class="tech-label mt-0.5 text-lune-faint">Batteries</dt>
              </div>
            </dl>

            <!-- W96 — retour sur investissement INDICATIF de la batterie. Hauteur réservée
                 (min-height) → zéro CLS ; masqué quand aucune batterie/économie honnête.
                 aria-live pour annoncer le retour quand il apparaît. -->
            <p id="rp9-cons-payback" hidden aria-live="polite"
              class="min-h-[1rem] text-xs leading-relaxed text-lune-faint"></p>

            <!-- (A) Édition à la main : barres glissables + saisie numérique -->
            <div>
              <div class="flex flex-wrap items-center justify-between gap-3">
                <p class="tech-label text-lune-faint">Courbe horaire (kWh) — glissez les barres ou tapez les valeurs</p>
                <div class="flex flex-wrap gap-2">
                  <button type="button" id="rp9-cons-recal"
                    class="border border-white/25 px-3 py-2 text-xs font-semibold text-lune-soft transition-colors hover:border-brass-400 hover:text-brass-300">
                    Recaler sur ma facture
                  </button>
                  <!-- W83 — restaure la forme CALCULÉE (socle facture + appareils) après une
                       édition à la main. -->
                  <button type="button" id="rp9-cons-reset"
                    class="border border-white/25 px-3 py-2 text-xs font-semibold text-lune-soft transition-colors hover:border-brass-400 hover:text-brass-300">
                    Réinitialiser la courbe
                  </button>
                </div>
              </div>
              <!-- Graphe SVG de conso (barres glissables) — superpose la production (or pâle).
                   Hauteur RÉSERVÉE → zéro CLS. -->
              <div class="rp9-cons-graph-wrap mt-3">
                <svg id="rp9-cons-graph" viewBox="0 0 480 160" preserveAspectRatio="none"
                  class="rp9-cons-graph" role="img" aria-label="Courbe de consommation horaire éditable"></svg>
              </div>
              <!-- Saisie numérique des 24 heures (obligatoire : mobile + mouvement réduit) -->
              <details class="mt-3">
                <summary class="cursor-pointer text-xs font-semibold text-brass-300">Saisie numérique des 24 heures</summary>
                <div id="rp9-cons-inputs" class="mt-3 grid grid-cols-3 gap-2 sm:grid-cols-6"></div>
              </details>
            </div>

            <!-- W95 — PROFIL SAISONNIER (été ≠ hiver) + mini-graphe d'autoconsommation
                 MENSUELLE. La production est fortement saisonnière ; un split de conso
                 (clim l'été) change HONNÊTEMENT l'autoconsommation annuelle. Hauteurs
                 réservées (graphe) → zéro CLS ; mouvement réduit (CSS). -->
            <div class="border-t border-white/10 pt-5">
              <div class="flex flex-wrap items-center justify-between gap-3">
                <p class="tech-label text-lune-faint">Profil saisonnier (été ≠ hiver) + autoconsommation mensuelle</p>
                <button type="button" id="rp9-cons-seasonal-toggle" aria-pressed="false"
                  class="border border-white/25 px-3 py-2 text-xs font-semibold text-lune-soft transition-colors hover:border-brass-400 hover:text-brass-300">
                  Profil saisonnier : désactivé
                </button>
              </div>
              <!-- Facteurs été/hiver — multiplient le total journalier (la forme est conservée).
                   Tout nombre est accepté (step="any", jamais rejeté). -->
              <div id="rp9-cons-seasonal-controls" hidden class="mt-3 grid grid-cols-2 gap-3 border border-white/10 bg-nuit-900/40 p-3 sm:max-w-md">
                <label class="block text-xs text-lune-soft">
                  Facteur été (juin–sept.)
                  <input id="rp9-cons-summer" type="text" inputmode="decimal" step="any" value="1.3"
                    class="mt-1 block w-full border border-white/15 bg-white/5 px-2 py-2 text-sm text-white outline-none focus:border-brass-400" />
                </label>
                <label class="block text-xs text-lune-soft">
                  Facteur hiver
                  <input id="rp9-cons-winter" type="text" inputmode="decimal" step="any" value="0.9"
                    class="mt-1 block w-full border border-white/15 bg-white/5 px-2 py-2 text-sm text-white outline-none focus:border-brass-400" />
                </label>
              </div>
              <!-- Mini-graphe SVG de l'autoconsommation mensuelle (12 barres) — hauteur RÉSERVÉE. -->
              <div class="rp9-cons-month-wrap mt-3">
                <svg id="rp9-cons-month-chart" viewBox="0 0 360 120" preserveAspectRatio="none"
                  class="rp9-cons-month-chart" role="img"
                  aria-label="Autoconsommation mensuelle estimée (12 mois)"></svg>
              </div>
            </div>

            <!-- (B) Calculateur d'appareils -->
            <div class="border-t border-white/10 pt-5">
              <p class="tech-label text-lune-faint">Ajouter un appareil</p>
              <div class="mt-3 flex flex-wrap items-end gap-3">
                <label class="block text-sm text-lune-soft">
                  Appareil
                  <select id="rp9-appl-kind"
                    class="mt-1 block w-full border border-white/15 bg-white/5 px-3 py-2.5 text-sm text-white outline-none focus:border-brass-400"></select>
                </label>
                <button type="button" id="rp9-appl-add"
                  class="border border-brass-400 bg-brass-400/10 px-4 py-2.5 text-sm font-bold text-brass-300 transition-colors hover:bg-brass-400/20">
                  + Ajouter
                </button>
              </div>
              <!-- Saisie spéciale climatisation (BTU ÷ EER) — visible quand « Climatisation » choisie -->
              <div id="rp9-appl-ac" hidden class="mt-3 grid grid-cols-2 gap-3 border border-white/10 bg-nuit-900/40 p-3 sm:grid-cols-4">
                <label class="block text-xs text-lune-soft">
                  Puissance (BTU)
                  <select id="rp9-ac-btu" class="mt-1 block w-full border border-white/15 bg-white/5 px-2 py-2 text-sm text-white outline-none focus:border-brass-400"></select>
                </label>
                <label class="block text-xs text-lune-soft">
                  EER
                  <input id="rp9-ac-eer" type="text" inputmode="decimal" value="9"
                    class="mt-1 block w-full border border-white/15 bg-white/5 px-2 py-2 text-sm text-white outline-none focus:border-brass-400" />
                </label>
                <label class="block text-xs text-lune-soft">
                  Heures/jour
                  <input id="rp9-ac-hours" type="text" inputmode="decimal" value="6"
                    class="mt-1 block w-full border border-white/15 bg-white/5 px-2 py-2 text-sm text-white outline-none focus:border-brass-400" />
                </label>
                <p id="rp9-ac-watts" class="self-end text-xs text-lune-faint">≈ — W · — kWh/j</p>
              </div>
              <!-- Saisie spéciale voiture électrique (kW × h OU km/jour) -->
              <div id="rp9-appl-ev" hidden class="mt-3 grid grid-cols-2 gap-3 border border-white/10 bg-nuit-900/40 p-3 sm:grid-cols-4">
                <label class="block text-xs text-lune-soft">
                  Chargeur (kW)
                  <select id="rp9-ev-kw" class="mt-1 block w-full border border-white/15 bg-white/5 px-2 py-2 text-sm text-white outline-none focus:border-brass-400"></select>
                </label>
                <label class="block text-xs text-lune-soft">
                  Heures/jour
                  <input id="rp9-ev-hours" type="text" inputmode="decimal" value="3"
                    class="mt-1 block w-full border border-white/15 bg-white/5 px-2 py-2 text-sm text-white outline-none focus:border-brass-400" />
                </label>
                <label class="block text-xs text-lune-soft">
                  ou km/jour
                  <input id="rp9-ev-km" type="text" inputmode="decimal" placeholder="ex. 50"
                    class="mt-1 block w-full border border-white/15 bg-white/5 px-2 py-2 text-sm text-white outline-none focus:border-brass-400" />
                </label>
                <p id="rp9-ev-note" class="self-end text-xs text-lune-faint">Recharger en plein soleil ↑ l'autoconsommation.</p>
              </div>
              <p id="rp9-appl-note" class="mt-2 min-h-[1rem] text-xs leading-relaxed text-lune-faint" aria-live="polite"></p>

              <!-- Liste des appareils ajoutés (chacun : créneau + « en plus » / « déjà compris » + suppr.) -->
              <ul id="rp9-appl-list" class="mt-4 space-y-2"></ul>
            </div>
          </div>
        </div>

        <!-- MATRICE complète balayée (FIX 2 V6) : triable, filtrable, optimum badgé.
             Placée EN BAS (sous la recommandation, la production, la conso et la
             personnalisation) — c'est une référence détaillée, pas l'info principale. -->
        <div id="rp9-compare-wrap" hidden class="cine-card mt-6 p-0">
          <div class="flex flex-wrap items-center justify-between gap-3 px-5 pt-5">
            <p class="tech-label text-brass-300">Matrice complète des configurations sur CE toit — optimum réel badgé « Recommandé »</p>
            <label class="flex items-center gap-2 text-xs text-lune-faint">
              Filtrer
              <select id="rp9-matrix-filter" class="rp9-filter border border-white/15 bg-white/5 px-2 py-1 text-xs text-white outline-none focus:border-brass-400">
                <option value="all">Toutes les orientations</option>
              </select>
            </label>
          </div>
          <div class="mt-3 overflow-x-auto">
            <table class="w-full min-w-[640px] text-left text-sm">
              <thead class="text-lune-faint">
                <tr class="border-b border-white/10">
                  <th class="px-5 py-3 font-semibold">Configuration</th>
                  <th class="px-5 py-3 text-right font-semibold" aria-sort="none">
                    <button type="button" data-rp9-sort="placedCount" class="rp9-sort">Panneaux<span class="rp9-sort-arrow"></span></button>
                  </th>
                  <th class="px-5 py-3 text-right font-semibold">kWc</th>
                  <th class="px-5 py-3 text-right font-semibold" aria-sort="descending">
                    <button type="button" data-rp9-sort="annualKwh" class="rp9-sort">kWh/an<span class="rp9-sort-arrow"></span></button>
                  </th>
                  <th class="px-5 py-3 text-right font-semibold" aria-sort="none">
                    <button type="button" data-rp9-sort="pctOfTarget" class="rp9-sort">% facture<span class="rp9-sort-arrow"></span></button>
                  </th>
                  <th class="px-5 py-3 text-right font-semibold">Économies/an</th>
                </tr>
              </thead>
              <tbody id="rp9-compare" class="text-lune-soft"></tbody>
            </table>
          </div>
          <p class="px-5 pb-5 pt-2 text-xs text-lune-faint">
            Balayage dense (inclinaison 0→35°, azimut sud ±45° + Est-Ouest, portrait/paysage) noté
            sur la production PVGIS au GPS exact. Triez par colonne, filtrez par orientation, cliquez
            une ligne pour la voir en 3D. Chiffres face avant (monoface), pas un devis.
          </p>
        </div>

        <p class="mt-6 text-xs text-lune-faint">
          Modèle panneau : Canadian Solar TOPBiHiKu7 CS7N-690-720TB-AG (720 W, 2384 × 1303 × 33 mm,
          bifacial double-verre, 132 demi-cellules). Productible PVGIS (Commission européenne) /
          table committée par latitude. Base facture→énergie : barème régie ONEE (sélectif, TTC), aligné avec le reste du site.
        </p>
      </div>
    </section>
  </div>
</Layout>

<style>
  /* W1 — Marqueur « Recommandé » calculé par le cerveau, posé sur la bonne option
     de chaque groupe — reste correct même si l'utilisateur a choisi une autre. */
  .rp9-reco-badge {
    margin-left: 0.35rem;
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--color-brass-300, #f3cc66);
    letter-spacing: 0.02em;
  }
  .rp9-map {
    position: relative;
    width: 100%;
    height: 60vh;
    min-height: 360px;
    background: var(--color-nuit-700);
  }
  @media (min-width: 1024px) {
    .rp9-map { height: 560px; }
  }
  .rp9-map-placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
    text-align: center;
  }
  /* Largeur réservée : la recommandation ne provoque aucun saut de mise en page. */
  .rp9-results { min-height: 520px; }
  .rp9-results--ready { border-color: rgb(243 204 102 / 0.25); }
  .rp9-map :global(.maplibregl-map) { position: absolute; inset: 0; }

  /* W192 — Segmented control : état actif/sélectionné bien visible sur canvas sombre */
  .rp9-chip[aria-pressed='true'] {
    border-color: var(--color-brass-400, #e8b54a);
    color: var(--color-brass-300, #f3cc66);
    background: rgb(232 181 74 / 0.15);
    box-shadow: inset 0 0 0 1px var(--color-brass-400, #e8b54a);
  }
  /* Prise de focus clavier bien visible */
  .rp9-chip:focus-visible {
    outline: 2px solid var(--color-azur-200, #b9c8f0);
    outline-offset: 2px;
  }

  /* W192 — Sliders de plage (range) : track + thumb brandés palette
     accent-color fait le track côté rempli (Chrome/Firefox/Safari) ;
     les pseudo-éléments affinent le thumb et le focus ring. */
  input[type='range'].rp9-range {
    -webkit-appearance: none;
    appearance: none;
    accent-color: var(--color-brass-400, #e8b54a);
    width: 100%;
    height: 4px;
    border-radius: 2px;
    cursor: pointer;
    border: none;
    outline: none;
    background: rgb(255 255 255 / 0.15);
  }
  input[type='range'].rp9-range::-webkit-slider-runnable-track {
    height: 4px;
    border-radius: 2px;
    background: rgb(255 255 255 / 0.15);
  }
  input[type='range'].rp9-range::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 18px;
    height: 18px;
    border-radius: 9999px;
    background: var(--color-brass-300, #f3cc66);
    border: 2px solid var(--color-nuit, #070b1d);
    box-shadow: 0 0 0 2px var(--color-brass-400, #e8b54a);
    margin-top: -7px;
    cursor: pointer;
    transition: box-shadow 120ms, background 120ms;
  }
  input[type='range'].rp9-range::-moz-range-track {
    height: 4px;
    border-radius: 2px;
    background: rgb(255 255 255 / 0.15);
  }
  input[type='range'].rp9-range::-moz-range-progress {
    height: 4px;
    border-radius: 2px;
    background: var(--color-brass-400, #e8b54a);
  }
  input[type='range'].rp9-range::-moz-range-thumb {
    width: 18px;
    height: 18px;
    border-radius: 9999px;
    background: var(--color-brass-300, #f3cc66);
    border: 2px solid var(--color-nuit, #070b1d);
    box-shadow: 0 0 0 2px var(--color-brass-400, #e8b54a);
    cursor: pointer;
    transition: box-shadow 120ms, background 120ms;
  }
  input[type='range'].rp9-range:focus-visible {
    outline: none;
  }
  input[type='range'].rp9-range:focus-visible::-webkit-slider-thumb {
