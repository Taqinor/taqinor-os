---
/**
 * PAGE PRIVÉE DE PRÉVISUALISATION — /preview/toiture-3d-pro-2 (noindex, hors nav,
 * exclue du sitemap, non liée). VARIANTE HAUTE FIDÉLITÉ, à comparer avec la 2D
 * (/preview/toiture), la 3D « volumes » (/preview/toiture-3d) et la 3D « racks »
 * (/preview/toiture-3d-pro). Le fondateur garde la préférée ; rien n'est promu.
 *
 * Upgrade de la version « racks » : vrais panneaux Canadian Solar 720 W (tout noir,
 * grille demi-cellules, cadre, boîtier de jonction, verre brillant), inclinaison
 * vers le VRAI sud (géo-ancré + boussole), vrai soleil selon la LATITUDE du toit
 * avec vraies ombres portées et rangées espacées anti-ombrage. Le nombre de vrais
 * panneaux 720 W posés pilote kWc → production PVGIS → économies.
 *
 * Three.js + la carte sont chargés PARESSEUSEMENT (import() dynamique de
 * src/scripts/roof-tool-pro2.ts) : aucune autre page ne les télécharge. Sans clé
 * MapTiler, sans WebGL ou sans JS : repli gracieux, jamais de canvas figé.
 * Voir apps/web/SOLAR_3D_PRO2_NOTES.md.
 */
import Layout from '../../layouts/Layout.astro';
import V2Enhance from '../../components/V2Enhance.astro';
import DiagnosticFormEnriched from '../../components/DiagnosticFormEnriched.astro';

const inputClass =
  'w-full border border-white/15 bg-white/5 px-3 py-3 text-base text-white placeholder:text-lune-faint outline-none transition-colors focus:border-brass-400 focus:ring-2 focus:ring-brass-400/30';
---

<Layout
  title="Prévisualisation privée — estimateur de toiture 3D haute fidélité | Taqinor"
  description="Page de travail privée, non indexée."
  noindex={true}
>
  <div class="v2">
    <V2Enhance />

    <section class="border-b border-white/10 bg-nuit-800 px-4 py-14 sm:py-20">
      <div class="mx-auto max-w-6xl">
        <p class="tech-label rule-brass text-brass-300">Prévisualisation privée · 3D haute fidélité · non publiée</p>
        <h1 class="display v2-page-title mt-5 max-w-[22ch] text-white">
          Vos vrais panneaux 720 W, plein sud, avec leurs ombres
        </h1>
        <p class="v2-lead mt-6 max-w-2xl text-lune-soft">
          Cherchez votre adresse, tracez votre toit : l'outil pose de
          <strong class="text-white">vrais panneaux Canadian Solar 720 W</strong> inclinés sur
          châssis lestés, orientés vers le <strong class="text-white">vrai sud</strong> (ils gardent
          le cap quand vous tournez la carte — une boussole vous repère), et un
          <strong class="text-white">vrai soleil</strong> projette de vraies ombres, avec des rangées
          espacées pour ne pas s'ombrager. Le site et le formulaire en production restent inchangés.
        </p>
        <p class="mt-4 text-sm text-lune-faint">
          Estimation indicative, jamais un devis. Comparez :
          <a href="/preview/toiture" class="text-brass-300 underline underline-offset-2 hover:text-brass-400">2D</a> ·
          <a href="/preview/toiture-3d" class="text-brass-300 underline underline-offset-2 hover:text-brass-400">3D volumes</a> ·
          <a href="/preview/toiture-3d-pro" class="text-brass-300 underline underline-offset-2 hover:text-brass-400">3D racks</a> ·
          <a href="#simulateur" class="text-brass-300 underline underline-offset-2 hover:text-brass-400">diagnostic</a>.
        </p>
      </div>
    </section>

    <section class="bg-nuit px-4 py-16 sm:py-20">
      <div class="mx-auto max-w-6xl">
        <ol class="mb-10 grid gap-4 sm:grid-cols-3">
          <li class="border-l-2 border-brass-400/60 pl-4 text-sm text-lune-soft">
            <span class="tech-label block text-brass-300">Étape 1</span>
            <strong class="mt-1 block text-white">Votre adresse</strong>
            La carte zoome sur votre maison en vue satellite.
          </li>
          <li class="border-l-2 border-brass-400/60 pl-4 text-sm text-lune-soft">
            <span class="tech-label block text-brass-300">Étape 2</span>
            <strong class="mt-1 block text-white">Tracez le toit</strong>
            Cliquez les coins ; double-cliquez (ou « Terminer ») pour passer en 3D.
          </li>
          <li class="border-l-2 border-brass-400/60 pl-4 text-sm text-lune-soft">
            <span class="tech-label block text-brass-300">Étape 3</span>
            <strong class="mt-1 block text-white">Tournez autour</strong>
            Vrais panneaux 720 W, cap sud, ombres réelles et rangées bien espacées.
          </li>
        </ol>

        <div id="rp2-fallback" hidden class="cine-card mb-8 border-l-4 border-alert-300 p-6">
          <p class="font-semibold text-white">Vue 3D haute fidélité momentanément indisponible</p>
          <p class="mt-2 text-sm text-lune-soft">
            La 3D n'est pas accessible sur cet appareil (carte graphique, clé ou JavaScript).
            Essayez <a href="/preview/toiture" class="text-brass-300 underline underline-offset-2">la version 2D</a>,
            <a href="/preview/toiture-3d" class="text-brass-300 underline underline-offset-2">la 3D volumes</a>
            ou obtenez votre étude directement — <a href="#simulateur" class="text-brass-300 underline underline-offset-2">le diagnostic en 60 secondes</a>.
          </p>
        </div>

        <div id="rp2-stage" class="grid gap-6 lg:grid-cols-[1.5fr_1fr] lg:items-start">
          <div class="cine-card overflow-hidden">
            <form id="rp2-search" class="flex flex-col gap-3 border-b border-white/10 p-4 sm:flex-row">
              <label for="rp2-address" class="sr-only">Votre adresse</label>
              <input id="rp2-address" name="address" type="text" autocomplete="street-address"
                placeholder="Adresse, quartier ou ville (ex. Casablanca, Maârif)" class={inputClass} />
              <button type="submit"
                class="flex-none bg-brass-400 px-6 py-3 text-base font-bold text-azur-950 transition-colors hover:bg-brass-300">
                Localiser mon toit
              </button>
            </form>

            <div id="rp2-map" class="rp2-map" role="application" aria-label="Carte satellite 3D haute fidélité pour tracer votre toiture">
              <!-- Boussole : l'aiguille N pivote avec le cap → on voit où est le sud -->
              <div class="rp2-compass" aria-hidden="true">
                <div id="rp2-compass-arrow" class="rp2-compass-arrow">
                  <span class="rp2-compass-n">N</span>
                  <span class="rp2-compass-s">S</span>
                </div>
              </div>
              <div id="rp2-map-placeholder" class="rp2-map-placeholder">
                <p class="text-sm text-lune-soft">
                  Saisissez votre adresse ci-dessus pour afficher la vue satellite, ou
                </p>
                <button type="button" id="rp2-open"
                  class="mt-3 border border-white/30 px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-white/10">
                  ouvrir la carte sans adresse
                </button>
                <noscript>
                  <p class="mt-3 text-sm text-lune-faint">
                    Cet outil nécessite JavaScript. <a href="/preview/toiture" class="text-brass-300 underline">Version 2D</a> ·
                    <a href="#simulateur" class="text-brass-300 underline">diagnostic classique →</a>
                  </p>
                </noscript>
              </div>
            </div>

            <div class="flex flex-wrap items-center gap-3 border-t border-white/10 p-4">
              <button type="button" id="rp2-finish" disabled
                class="border border-white/25 px-4 py-2.5 text-sm font-semibold text-white transition-colors hover:border-brass-400 hover:text-brass-300 disabled:cursor-not-allowed disabled:opacity-40">
                Terminer le tracé
              </button>
              <button type="button" id="rp2-clear"
                class="border border-white/25 px-4 py-2.5 text-sm font-semibold text-lune-soft transition-colors hover:border-white/50 hover:text-white">
                Effacer
              </button>
              <div class="ml-auto flex items-center gap-2">
                <label for="rp2-orient" class="text-sm text-lune-soft">Orientation</label>
                <select id="rp2-orient" class="border border-white/15 bg-nuit-700 px-3 py-2 text-sm text-white outline-none focus:border-brass-400">
                  <option value="sud" selected>Sud (optimal)</option>
                  <option value="sud-est">Sud-Est</option>
                  <option value="sud-ouest">Sud-Ouest</option>
                  <option value="est">Est</option>
                  <option value="ouest">Ouest</option>
                  <option value="nord">Nord</option>
                  <option value="inconnu">Je ne sais pas</option>
                </select>
              </div>
            </div>

            <div id="rp2-build-controls" hidden class="flex flex-wrap items-center gap-x-6 gap-y-3 border-t border-white/10 bg-nuit-800 p-4">
              <div class="flex items-center gap-2">
                <label for="rp2-floors" class="text-sm text-lune-soft">Étages</label>
                <select id="rp2-floors" class="border border-white/15 bg-nuit-700 px-3 py-2 text-sm text-white outline-none focus:border-brass-400">
                  <option value="1">1</option>
                  <option value="2" selected>2</option>
                  <option value="3">3 et +</option>
                </select>
              </div>
              <label class="flex items-center gap-2 text-sm text-lune-soft">
                <input type="checkbox" id="rp2-pitch" class="accent-brass-400" />
                Toit en pente (villa — pose affleurante)
              </label>
              <span class="ml-auto text-xs text-lune-faint">Glissez pour pivoter · le cap sud est conservé</span>
            </div>

            <p id="rp2-status" class="border-t border-white/10 px-4 py-3 text-sm text-lune-faint" aria-live="polite">
              Cherchez votre adresse pour commencer.
            </p>
          </div>

          <div id="rp2-results" class="rp2-results cine-card p-6">
            <p class="tech-label rule-brass text-brass-300">Votre potentiel solaire</p>
            <dl class="mt-6 grid grid-cols-2 gap-x-6 gap-y-7">
              <div>
                <dd id="rp2-res-kwc" class="fig text-3xl text-brass-300 sm:text-4xl">—</dd>
                <dt class="tech-label mt-2 text-lune-faint">Puissance</dt>
              </div>
              <div>
                <dd id="rp2-res-panels" class="fig text-3xl text-white sm:text-4xl">—</dd>
                <dt class="tech-label mt-2 text-lune-faint">Panneaux</dt>
              </div>
              <div>
                <dd id="rp2-res-area" class="fig text-3xl text-white sm:text-4xl">—</dd>
                <dt class="tech-label mt-2 text-lune-faint">Surface tracée</dt>
              </div>
              <div>
                <dd id="rp2-res-prod" class="fig text-2xl text-white sm:text-3xl">—</dd>
                <dt class="tech-label mt-2 text-lune-faint">Production estimée</dt>
              </div>
            </dl>
            <div class="mt-7 border-t border-white/10 pt-6">
              <dd id="rp2-res-savings" class="fig text-2xl text-brass-300 sm:text-3xl">—</dd>
              <dt class="tech-label mt-2 text-lune-faint">Économies estimées</dt>
            </div>
            <p id="rp2-res-note" class="mt-6 text-xs leading-relaxed text-lune-faint">
              Tracez votre toit pour découvrir votre potentiel solaire.
            </p>
            <p class="mt-3 text-xs leading-relaxed text-lune-faint/80">
              Vrais panneaux Canadian Solar 720 W sur installation réaliste, posée sur un volume de
              bâtiment approximatif (pas une copie exacte de la maison). Le nombre de panneaux a
              changé car ce panneau est plus grand (2,38 × 1,30 m) mais chacun produit bien plus
              (720 W) et les rangées sont espacées contre l'ombrage — c'est plus juste.
            </p>
            <button type="button" id="rp2-cta" hidden
              class="mt-6 inline-flex w-full items-center justify-center gap-2 bg-ok-600 px-6 py-4 text-base font-bold text-white transition-opacity hover:opacity-90">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 0 0-8.6 15.1L2 22l5-1.3A10 10 0 1 0 12 2Zm5.4 14.1c-.2.6-1.3 1.2-1.8 1.2-.5.1-1 .2-3.3-.7-2.8-1.1-4.6-4-4.7-4.2-.1-.2-1.1-1.5-1.1-2.9s.7-2 1-2.3c.2-.3.5-.3.7-.3h.5c.2 0 .4 0 .6.4l.9 2.1c.1.2.1.4 0 .6l-.4.6-.5.5c-.2.2-.3.4-.1.7.2.3.9 1.4 1.9 2.3 1.3 1.1 2.3 1.5 2.6 1.6.3.1.5.1.7-.1l1-1.2c.2-.3.4-.2.7-.1l2 1c.3.1.5.2.6.4 0 .1 0 .7-.3 1.4Z"/></svg>
              Recevoir mon étude sur WhatsApp
            </button>
          </div>
        </div>
        <p class="mt-6 text-xs text-lune-faint">
          Modèle panneau : Canadian Solar TOPBiHiKu7 CS7N-690-720TB-AG (720 W, 2384 × 1303 × 33 mm,
          bifacial double-verre, 132 demi-cellules). Géométrie d'après datasheet constructeur.
        </p>
      </div>
    </section>

    <DiagnosticFormEnriched heading="Recevez votre étude détaillée" />
  </div>
</Layout>

<style>
  .rp2-map {
    position: relative;
    width: 100%;
    height: 60vh;
    min-height: 360px;
    background: var(--color-nuit-700);
  }
  @media (min-width: 1024px) {
    .rp2-map { height: 560px; }
  }
  .rp2-map-placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
    text-align: center;
  }
  .rp2-results { min-height: 360px; }
  .rp2-results--ready { border-color: rgb(243 204 102 / 0.25); }
  .rp2-map :global(.maplibregl-map) { position: absolute; inset: 0; }

  /* Boussole : disque en haut à gauche, aiguille N/S qui pivote avec le cap. */
  .rp2-compass {
    position: absolute;
    top: 12px;
    left: 12px;
    z-index: 2;
    width: 52px;
    height: 52px;
    border-radius: 9999px;
    background: rgb(7 11 29 / 0.72);
    border: 1px solid rgb(214 219 233 / 0.25);
    backdrop-filter: blur(4px);
    pointer-events: none;
  }
  .rp2-compass-arrow {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-between;
    padding: 5px 0;
    font: 700 0.7rem/1 var(--font-sans, sans-serif);
    transition: transform 120ms linear;
  }
  .rp2-compass-n { color: var(--color-brass-300, #f3cc66); }
  .rp2-compass-s { color: var(--color-lune-soft, #adb5cd); }
  @media (prefers-reduced-motion: reduce) {
    .rp2-compass-arrow { transition: none; }
  }
</style>

<script>
  // Activation paresseuse : MapLibre + Three.js ne sont téléchargés qu'au premier
  // geste réel. La clé publique MapTiler est lue à l'exécution via /api/roof-config.
  const fallback = document.getElementById('rp2-fallback');
  const stage = document.getElementById('rp2-stage');
  const searchForm = document.getElementById('rp2-search') as HTMLFormElement | null;
  const addressEl = document.getElementById('rp2-address') as HTMLInputElement | null;
  const openBtn = document.getElementById('rp2-open');
  const placeholder = document.getElementById('rp2-map-placeholder');

  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  let started = false;
  let key = '';

  function showFallback() {
    if (fallback) fallback.hidden = false;
    if (stage) stage.hidden = true;
  }

  async function boot(initialQuery?: string) {
    if (started || !key) return;
    started = true;
    let mapCreated = false;
    try {
      const mod = await import('../../scripts/roof-tool-pro2.ts');
      placeholder?.remove();
      mod.initRoofToolPro2({
        maptilerKey: key,
        reducedMotion,
        initialQuery,
        onReady: () => {
          mapCreated = true;
        },
      });
    } catch {
      if (!mapCreated) {
        started = false;
        showFallback();
      }
    }
  }

  (async () => {
    try {
      const res = await fetch('/api/roof-config');
      const cfg = (await res.json()) as { available?: boolean; maptilerKey?: string };
      if (!cfg.available || !cfg.maptilerKey) {
        showFallback();
        return;
      }
      key = cfg.maptilerKey;
      searchForm?.addEventListener('submit', (e) => {
        e.preventDefault();
        boot(addressEl?.value.trim() || undefined);
      });
      openBtn?.addEventListener('click', () => boot());
    } catch {
      showFallback();
    }
  })();
</script>
