<style>
  /* Portrait-crop héro : recadrage en haut sur téléphones verticaux (VERBATIM
     index.astro) — les panneaux restent visibles sur un écran 9:19. */
  @media (orientation: portrait) {
    .hero-portrait-img {
      object-position: center 20%;
    }
  }

  /* Scrim héro RELEVÉ pour la page v3 : compense la chaleur du grade « heure
     dorée » et garantit le contraste AA du headline blanc sur la photo. */
  .hero-scrim-v3 {
    --hero-scrim-strength: 0.52;
  }
</style>

<script>
  // Vidéo héro : différée — première interaction ou 2,8 s après chargement ;
  // jamais si reduced-motion ou économie de données. VERBATIM index.astro.
  const video = document.getElementById('hero-video') as HTMLVideoElement | null;
  const motionOk = matchMedia('(prefers-reduced-motion: no-preference)').matches;
  // @ts-expect-error saveData non typé partout
  const saveData = navigator.connection?.saveData === true;
  if (video && motionOk && !saveData) {
    let started = false;
    const start = () => {
      if (started) return;
      started = true;
      video.src = '/videos/hero.mp4';
      video.play().then(() => video.classList.add('opacity-100')).catch(() => {});
    };
    for (const ev of ['scroll', 'pointerdown', 'touchstart', 'keydown']) {
      addEventListener(ev, start, { once: true, passive: true });
    }
    const arm = () => setTimeout(start, 2800);
    if (document.readyState === 'complete') arm();
    else addEventListener('load', arm, { once: true });
  }
</script>

<script>
  // Count-up sur le chiffre protagoniste héro (21 406). Reduced-motion safe :
  // valeur finale affichée immédiatement. Anti-CLS : largeur verrouillée AVANT
  // toute animation. VERBATIM index.astro.
  import { formatFrame, shouldDigitRoll } from '../../lib/countup';

  const el = document.querySelector<HTMLElement>('[data-hero-tally]');
  if (el) {
    const finalText = el.textContent ?? '';
    if (getComputedStyle(el).display.startsWith('inline')) {
      const w = el.getBoundingClientRect().width;
      el.style.display = 'inline-block';
      el.style.minWidth = w + 'px';
    }

    const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduce || !shouldDigitRoll(finalText)) {
      el.textContent = finalText;
    } else {
      const dur = 1400;
      let start: number | null = null;
      function frame(t: number) {
        if (start === null) start = t;
        const p = Math.min(1, (t - start) / dur);
        const e = 1 - Math.pow(1 - p, 3); // easeOutCubic
        el!.textContent = formatFrame(finalText, e);
        if (p < 1) requestAnimationFrame(frame);
        else el!.textContent = finalText;
      }
      const kick = () => requestAnimationFrame(frame);
      if (document.readyState === 'complete') kick();
      else addEventListener('load', kick, { once: true });
    }
  }
</script>
