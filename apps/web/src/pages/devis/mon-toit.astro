    estimateShown = {
      kwc: est.kwc,
      prodKwh: est.productionKwhYr,
      ecoMadMonthLow: est.savingsMonthlyLow,
      ecoMadMonthHigh: est.savingsMonthlyHigh,
      paybackLabel: est.paybackLabel,
    };
    // W342 — « installation la plus proche de chez vous » : UNIQUEMENT si un
    // repère GPS a été posé (capturePin) et qu'un vrai chantier Taqinor est à
    // proximité honnête (≤ 80 km, cf. nearestRealisation). Sans repère, la
    // carte reste masquée — jamais une ville devinée depuis le texte libre.
    const nearestEl = $('mt-nearest-install');
    if (nearestEl && capturePin) {
