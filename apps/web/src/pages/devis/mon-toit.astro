    for (const id of ['mt-est-kwc', 'mt-est-prod', 'mt-est-savings']) {
      const el = $(id);
      if (el) el.innerHTML = '<span class="mt-est-skeleton mt-skeleton-shimmer"></span>';
    }
    const payEl = $('mt-est-payback');
    if (payEl) payEl.innerHTML = '<span class="mt-est-skeleton mt-skeleton-shimmer"></span>';
  }
  // WJ48/WJ112 — anticipation BRANDÉE, RÉDUITE à ≤500 ms (250–450 ms, tirage
  // aléatoire) : le calcul réel (billEstimate) est synchrone et instantané —
  // un délai perçu très court laisse encore « voir » un calcul se produire
  // (Enpal/EnergySage) sans pénaliser la promesse WJ112 d'un premier chiffre en
  // ≤0.5 s, y compris pour les recalculs en direct (ombrage/kWh exact/mode).
  // reduced-motion → INSTANTANÉ (aucun délai artificiel, aucune roue de
  // chargement à observer) — inchangé.
  const THINKING_MIN_MS = 250;
  const THINKING_MAX_MS = 450;
  function thinkingDelayMs(): number {
    if (reducedMotion) return 0;
    return THINKING_MIN_MS + Math.random() * (THINKING_MAX_MS - THINKING_MIN_MS);
  }
  $('mt-estimate')?.addEventListener('click', (e) => {
    // QX — validation de l'étape AVANT le calcul : erreurs inline + focus +
    // défilement doux vers le premier champ invalide (plus jamais « tout va
    // bien » jusqu'à un refus global à la fin).
    if (!validateStep1()) return;
    showEstimateSkeleton();
    const thinkingEl = $('mt-estimate-thinking');
    if (thinkingEl) thinkingEl.hidden = false;
    goStep(2);
    const triggerEl = e.currentTarget as HTMLElement | null;
    requestAnimationFrame(() => {
      setTimeout(() => {
        if (thinkingEl) thinkingEl.hidden = true;
        const hasEstimate = computeEstimate();
        // WJ46 — pic d'intérêt : dès que l'estimation instantanée est RÉELLEMENT
        // affichée (pas le squelette, pas l'état « indisponible »), on propose
        // l'offre WhatsApp ici plutôt que d'attendre un exit-intent (desktop
        // uniquement, de moins en moins vu) — c'est l'équivalent honnête et
        // mobile-réel du moment de plus fort engagement. Court délai (pas un
        // compte à rebours, aucune urgence affichée) pour laisser les chiffres
        // s'afficher avant l'offre.
        if (hasEstimate) setTimeout(() => showWhatsappOffer(triggerEl), reducedMotion ? 0 : 1500);
      }, thinkingDelayMs());
    });
  });
  // recalcule à la volée si l'utilisateur revient corriger sa facture (ne
  // redéclenche PAS l'offre WhatsApp : showWhatsappOffer n'est ici jamais appelée).
  // QX — la saisie du montant exact synchronise d'abord la tranche dérivée
  // (fix « tranche redondante »), puis recalcule.
  $('mt-facture-hiver')?.addEventListener('input', () => {
    syncBillRangeFromExact();
    computeEstimate();
  });
  $('mt-bill')?.addEventListener('change', computeEstimate);
  // WJ112 — la conso exacte (kWh/mois) EST maintenant utilisée par le calcul
  // (estimateFromBill), donc elle doit recalculer en direct comme la facture.
  $('mt-bill-kwh')?.addEventListener('input', computeEstimate);

  // ——— WJ2 : « voir les panneaux sur votre toit » — facultatif, lazy, dégrade
  // proprement (pas de WebGL / pas de contour tracé → le bloc reste masqué). ———
  const panels3dBlock = $('mt-panels3d') as HTMLElement | null;
  const panels3dStage = $('mt-panels3d-stage') as HTMLElement | null;
  const panels3dOverlay = $('mt-panels3d-overlay') as HTMLElement | null;
  const panels3dStart = $('mt-panels3d-start') as HTMLButtonElement | null;
  const panels3dHint = $('mt-panels3d-hint') as HTMLElement | null;
  let panels3dStarted = false;

  /** Le bouton n'apparaît QUE si un contour (≥3 sommets) a été tracé ET qu'un
   *  kWc est disponible — sinon rien de significatif à montrer (pas de faux
   *  aperçu sur un simple repère). */
  function updatePanels3dVisibility() {
    if (!panels3dBlock) return;
    const eligible = captureOutline.length >= 3 && lastKwc != null;
    panels3dBlock.hidden = !eligible;
  }

  async function startPanels3d() {
    if (panels3dStarted || !panels3dStage || lastKwc == null) return;
    panels3dStarted = true;
    try {
      const [{ capturePreviewLayout, buildViewerModel }, { createRoofViewer }] = await Promise.all([
        import('../../lib/proposition'),
        import('../../scripts/roofPro11/viewerOnly'),
      ]);
      const layout = capturePreviewLayout(captureOutline, lastKwc);
      const model = layout ? buildViewerModel(layout) : null;
      if (!model) throw new Error('modèle indisponible');
      // QX/Lane C — la VRAIE photo satellite du toit, drapée sous les panneaux
      // (contrat Lane C : null → rendu abstrait byte-identique, jamais un
      // blocage). Spec partagé avec l'instantané du document (un seul fetch).
      const roofImage = await fetchRoofImageSpec().catch(() => null);
      const nav = navigator as Navigator & { deviceMemory?: number; connection?: { saveData?: boolean } };
      const lowEnd = (nav.deviceMemory != null && nav.deviceMemory <= 4) || (navigator.hardwareConcurrency || 8) <= 4;
      const handle = createRoofViewer(panels3dStage, model, {
        reducedMotion,
        lowEnd,
        roofImage,
        onReady: () => {
          if (panels3dOverlay) panels3dOverlay.hidden = true;
          if (panels3dHint) panels3dHint.hidden = false;
        },
        onFail: () => { panels3dStarted = false; },
      });
      if (!handle) throw new Error('WebGL indisponible');
    } catch {
      // Repli gracieux : le bouton reste, avec un message sobre — jamais de blocage.
      panels3dStarted = false;
      if (panels3dOverlay) {
        const btn = panels3dStart;
        if (btn) {
          btn.disabled = true;
          btn.textContent = currentLang === 'ar' ? 'المعاينة ثلاثية الأبعاد غير متوفرة' : 'Aperçu 3D indisponible sur cet appareil';
        }
      }
    }
  }
  panels3dStart?.addEventListener('click', () => { void startPanels3d(); });

  // ——— QX : « Imprimer / Enregistrer en PDF » — le document d'estimation
  // s'imprime tel quel (@media print : seul #mt-doc reste visible, bandes
  // navy/or préservées via print-color-adjust). Remplace l'ancien one-pager
  // PNG W356 : même honnêteté (rien de plus que ce qui est affiché), artefact
  // bien meilleur — un vrai document A4. ———
  $('mt-print-estimate')?.addEventListener('click', () => {
    window.print();
  });

  // ——— WJ4 : validation INLINE alignée sur validateLead (avant le round-trip) ———
  function setFieldError(inputId: string, errId: string, message: string | null) {
    const input = $(inputId) as HTMLInputElement | null;
    const err = $(errId);
    if (input) input.setAttribute('aria-invalid', message ? 'true' : 'false');
    if (err) {
      err.textContent = message || '';
      err.hidden = !message;
    }
  }

  // ——— QX : VALIDATION EN DIRECT — chaque champ se valide à la perte de focus
  // (blur), chaque « Continuer » valide SON étape (erreurs inline + focus +
  // défilement doux vers le premier champ invalide). Les valeurs tapées ne sont
  // JAMAIS corrigées/rejetées automatiquement (règle repo : pas de snap). ———
  function scrollToInvalid(el: HTMLElement | null) {
    if (!el) return;
    el.scrollIntoView({ behavior: reducedMotion ? 'auto' : 'smooth', block: 'center' });
    if (typeof el.focus === 'function') el.focus({ preventScroll: true });
  }
  /** Champ numérique FACULTATIF : vide = OK ; non-numérique ou négatif = erreur. */
  function checkOptionalNumber(id: string, label: string): boolean {
    const raw = val(id).trim();
    if (raw === '') {
      setFieldError(id, `${id}-err`, null);
      return true;
    }
    const n = num(id);
    if (n == null || n < 0) {
      setFieldError(id, `${id}-err`, `${label} : chiffres uniquement.`);
      return false;
    }
    setFieldError(id, `${id}-err`, null);
    return true;
  }
  const OPTIONAL_NUMBER_FIELDS: Array<[string, string]> = [
    ['mt-puissance-kva', 'Puissance souscrite'],
    ['mt-surface-m2', 'Surface'],
    ['mt-profondeur', 'Profondeur'],
    ['mt-hmt', 'HMT'],
    ['mt-water-need', 'Besoin en eau'],
    ['mt-surface-ha', 'Surface'],
    ['mt-pompe-cv', 'Puissance (CV)'],
    ['mt-fuel-spend', 'Dépense carburant'],
  ];
  for (const [id, label] of OPTIONAL_NUMBER_FIELDS) {
    $(id)?.addEventListener('blur', () => {
      checkOptionalNumber(id, label);
    });
  }
  /** Facture exacte résidentielle au blur : format + plafond de bon sens. */
  function checkFactureHiver(): boolean {
    const raw = val('mt-facture-hiver').trim();
    if (raw === '') {
      setFieldError('mt-facture-hiver', 'mt-facture-hiver-err', null);
      return true;
    }
    const n = num('mt-facture-hiver');
    if (n == null || n <= 0) {
      setFieldError('mt-facture-hiver', 'mt-facture-hiver-err', 'Montant invalide — chiffres uniquement.');
      return false;
    }
    if (n > maxBillFor('residentiel')) {
      setFieldError('mt-facture-hiver', 'mt-facture-hiver-err', 'Vérifiez le montant saisi.');
      return true; // le document affiche le chemin honnête « vérifiez » — jamais un blocage
    }
    setFieldError('mt-facture-hiver', 'mt-facture-hiver-err', null);
    return true;
  }
  $('mt-facture-hiver')?.addEventListener('blur', () => {
    checkFactureHiver();
  });
  $('mt-pro-bill')?.addEventListener('blur', () => {
    const raw = val('mt-pro-bill').trim();
    if (raw === '') {
      setFieldError('mt-pro-bill', 'mt-pro-bill-err', null);
      return;
    }
    const n = num('mt-pro-bill');
    setFieldError('mt-pro-bill', 'mt-pro-bill-err', n == null || n <= 0 ? 'Montant invalide — chiffres uniquement.' : null);
  });
  // Contact : chaque champ se valide dès la perte de focus (miroir léger de
  // validateLead — l'envoi final reste validé par validateLead au complet).
  $('mt-name')?.addEventListener('blur', () => {
    const v = val('mt-name').trim();
    setFieldError('mt-name', 'mt-name-err', v !== '' && (v.length < 2 || !/\p{L}/u.test(v)) ? 'Nom complet requis' : null);
  });
  $('mt-phone')?.addEventListener('blur', () => {
    const digits = val('mt-phone').replace(/\D/g, '');
    setFieldError('mt-phone', 'mt-phone-err', val('mt-phone').trim() !== '' && digits.length < 9 ? 'Numéro de téléphone invalide' : null);
  });
  $('mt-city')?.addEventListener('blur', () => {
    const v = val('mt-city').trim();
    setFieldError('mt-city', 'mt-city-err', v !== '' && v.length < 2 ? 'Adresse / ville requise' : null);
  });
  /** Étape carte : un profil doit être choisi (nudge inline sur les cartes). */
  function validateStep0(): boolean {
    if (mode) return true;
    const err = $('mt-mode-err');
    if (err) {
      err.textContent = 'Choisissez votre type de projet pour continuer.';
      err.hidden = false;
    }
    scrollToInvalid(document.querySelector<HTMLButtonElement>('.mt-mode'));
    return false;
  }
  /** Étape questions : validation PAR PROFIL avant le calcul. */
  function validateStep1(): boolean {
    if (mode === 'professionnel') {
      if (!checkOptionalNumber('mt-puissance-kva', 'Puissance souscrite')) {
        scrollToInvalid($('mt-puissance-kva'));
        return false;
      }
      const raw = val('mt-pro-bill').trim();
      const n = num('mt-pro-bill');
      if (raw === '' || n == null || n <= 0) {
        setFieldError('mt-pro-bill', 'mt-pro-bill-err', 'Indiquez votre consommation mensuelle (MAD ou kWh) pour calculer votre estimation.');
        scrollToInvalid($('mt-pro-bill'));
        return false;
      }
      setFieldError('mt-pro-bill', 'mt-pro-bill-err', null);
      return true;
    }
    if (mode === 'agricole') {
      // Rien n'est REQUIS (hydraulique manquante = chemin honnête « un
      // ingénieur vous rappelle ») — mais un nombre saisi doit être un nombre.
      for (const [id, label] of OPTIONAL_NUMBER_FIELDS) {
        if (!['mt-profondeur', 'mt-hmt', 'mt-water-need', 'mt-pompe-cv', 'mt-fuel-spend'].includes(id)) continue;
        if (!checkOptionalNumber(id, label)) {
          scrollToInvalid($(id));
          return false;
        }
      }
      return true;
    }
    // Résidentiel : une facture est nécessaire (montant exact OU tranche) + un
    // type de toit (exigé de toute façon par validateLead à l'envoi — autant le
    // dire ICI, pas à la fin).
    const rawF = val('mt-facture-hiver').trim();
    const exact = num('mt-facture-hiver');
    if (rawF !== '' && (exact == null || exact <= 0)) {
      setFieldError('mt-facture-hiver', 'mt-facture-hiver-err', 'Montant invalide — chiffres uniquement.');
      scrollToInvalid($('mt-facture-hiver'));
      return false;
    }
    if ((exact == null || exact <= 0) && !val('mt-bill')) {
      setFieldError('mt-facture-hiver', 'mt-facture-hiver-err', 'Indiquez votre facture : montant exact ou tranche.');
      setFieldError('mt-bill', 'mt-bill-err', 'Choisissez une tranche si vous ne connaissez pas le montant exact.');
      scrollToInvalid($('mt-facture-hiver'));
      return false;
    }
    setFieldError('mt-bill', 'mt-bill-err', null);
    if (!val('mt-roof')) {
      setFieldError('mt-roof', 'mt-roof-err', 'Choisissez votre type de toit.');
      scrollToInvalid(document.querySelector<HTMLButtonElement>('.mt-roof-card'));
      return false;
    }
    return true;
  }

  // ——— QX : billRange PROFESSIONNEL dérivé de la conso saisie — toujours
  // cohérent avec ce qui a piloté l'estimation affichée. En kWh, le MAD
  // implicite = kWh × tarif des hypothèses du moteur (le même chiffre que le
  // document) ; « gt10000 » reste factuellement vrai pour tout gros compte. ———
  function resolveProBillRange(): string {
    const v = num('mt-pro-bill');
    if (v == null || v <= 0) return '';
    let mad: number | null = null;
    if (proUnit === 'mad') mad = v;
    else if (lastProTarifMadKwh != null && lastProTarifMadKwh > 0) mad = v * lastProTarifMadKwh;
    if (mad == null || !(mad > 0)) return '';
    const rid = billRangeFromExact(mad);
    if (rid) return rid;
    return mad > 10_000 ? 'gt10000' : '';
  }
  // ——— QX : roofType par profil — validateLead (lib/lead.ts) l'exige pour
  // toute soumission mon-toit, mais les cartes « type de toit » ne vivent que
  // dans le sous-panneau RÉSIDENTIEL. Pour pro/agricole on DÉRIVE la valeur
  // des vraies réponses (jamais un choix inventé de toiture précise) :
  // bac acier → hangar, toiture-terrasse → toit plat, tout le reste → 'autre'
  // (le bucket honnête — le CRM reçoit de toute façon surfaceType/waterSource,
  // les champs précis). NOTE orchestrateur : si Lane A assouplit roofType par
  // mode plus tard, cette dérivation peut disparaître. ———
  function resolveRoofType(): string {
    if (mode === 'professionnel') {
      if (surfaceType === 'bac_acier') return 'hangar';
      if (surfaceType === 'terrasse') return 'toit_plat';
      return 'autre';
    }
    if (mode === 'agricole') return 'autre';
    return val('mt-roof');
  }
  // ——— WJ52 : référence client courte, générée UNE FOIS côté navigateur ———
  // Stable sur des soumissions répétées (ex. échec réseau puis nouvel essai) :
  // générée à la première tentative, réutilisée telle quelle ensuite — jamais
  // régénérée en silence, jamais une clé d'unicité serveur (cf. lib/lead.ts).
  let clientRef = '';
  function getOrCreateClientRef(): string {
    if (!clientRef) clientRef = buildClientRef();
    return clientRef;
  }

  // WJ116 — reprise fbclid + UTM depuis sessionStorage (capture first-touch du
  // Layout, apps/web/src/layouts/Layout.astro ~l.206) : sans ceci, AUCUNE
  // attribution UTM (parrainage compris — /parrainage) ne partait jamais sur ce
  // funnel PRINCIPAL alors que le webhook / validateLead les acceptent déjà.
  // Miroir exact de DiagnosticForm.astro ~l.279. Seules les clés PRÉSENTES sont
  // jointes (convention WJ30/WJ31 « absent plutôt que vide ») : un visiteur sans
  // paramètre de tracking envoie un corps byte-identique à avant.
  const TRACK_KEYS = ['fbclid', 'utm_source', 'utm_medium', 'utm_campaign', 'utm_content', 'utm_term'] as const;
  function readTrackingParams(): Record<string, string> {
    const out: Record<string, string> = {};
    for (const k of TRACK_KEYS) {
      try {
        const v = sessionStorage.getItem('tq_' + k);
        if (v) out[k] = v;
      } catch {}
    }
    return out;
  }

  /** Construit le corps de lead + renvoie les erreurs client (miroir validateLead). */
  function buildBody(): { body: Record<string, unknown>; errors: Record<string, string> } {
    const eteDifferente = eteToggle?.checked === true;
    const consent = ($('mt-consent') as HTMLInputElement | null)?.checked === true;
    // WJ51 — préférence de contact EXPLICITE (radio « Uniquement WhatsApp » vs
    // « Un conseiller peut m'appeler ») : `whatsappOptIn` reste dérivé pour ne
    // rien casser côté CRM/webhook, `contactPreference` part en plus (mappé
    // sur le champ `canal`).
    const contactPreference = (($('mt-contact-phone') as HTMLInputElement | null)?.checked === true)
      ? 'phone_ok'
      : 'whatsapp_only';
    const whatsappOptIn = contactPreference === 'whatsapp_only';
    const adresse = (val('mt-city') || addressEl?.value.trim() || fallbackAddrEl?.value.trim() || '').trim();
    const body: Record<string, unknown> = {
      fullName: val('mt-name'),
      phone: val('mt-phone'),
      city: adresse,
      // QX — billRange TOUJOURS cohérent avec ce qui a piloté l'estimation
      // affichée : résidentiel = le <select> (auto-dérivé du montant exact,
      // syncBillRangeFromExact) ; professionnel = dérivé de la conso saisie ;
      // agricole = plus requis (lib/lead.ts, mode 'agricole').
      billRange: mode === 'professionnel' ? resolveProBillRange() : mode === 'agricole' ? '' : val('mt-bill'),
      // QX — dérivé des vraies réponses pour pro/agricole (cartes toit =
      // sous-panneau résidentiel uniquement) ; cf. resolveRoofType.
      roofType: resolveRoofType(),
      consent,
      whatsappOptIn,
      contactPreference,
      email: val('mt-email') || undefined,
      factureHiver: num('mt-facture-hiver'),
      factureEte: eteDifferente ? num('mt-facture-ete') : null,
      eteDifferente,
      raccordement: val('mt-raccordement'),
      adresse,
      // WJ30 — le type de projet et la langue active partent aussi au webhook.
      mode,
      langue_preferee: currentLang,
      // WJ31 — questions de capture élargies, TOUTES facultatives (déjà validées
      // une à une côté serveur : un champ vide/malformé est simplement écarté).
      distributeur: val('mt-distributeur') || undefined,
      billKwh: num('mt-bill-kwh'),
      ombrage: ombrage || undefined,
      roofAgeYears: num('mt-roof-age'),
      futureLoads: futureLoads.size > 0 ? Array.from(futureLoads) : undefined,
      batteryInterest: ($('mt-battery-interest') as HTMLInputElement | null)?.checked === true,
      occupantType: val('mt-occupant-type') || undefined,
      projectTiming: val('mt-project-timing') || undefined,
      financingIntent: val('mt-financing-intent') || undefined,
      hasMeterPhoto,
      // WJ52 — référence courte pour l'artefact post-soumission (échoée telle
      // quelle, jamais une clé d'unicité serveur — cf. lib/lead.ts).
      clientRef: getOrCreateClientRef(),
      // W353 — préférence de créneau de visite technique (facultative, STATIQUE).
      visitWindowPart: visitWindowPart || undefined,
      visitWindowWeek: visitWindowWeek || undefined,
      // WJ68 — mode professionnel : facultatif, additif, jamais bloquant. Les
      // champs restent envoyés même si le mode a changé depuis (validateLead
      // les accepte indépendamment du mode — un visiteur qui bascule
      // résidentiel→professionnel→résidentiel ne perd rien de saisi).
      raisonSociale: val('mt-raison-sociale') || undefined,
      facilityType: val('mt-facility-type') || undefined,
      siteCount: val('mt-site-count') || undefined,
      // QX — sous-panneau PROFESSIONNEL. `tensionRaccordement` (bt/mt) est
      // volontairement DISTINCT du select résidentiel `raccordement`
      // (monophasé/triphasé) — jamais les deux sens dans un même champ. Les
      // champs à DÉFAUT visible (tension/activité) ne partent que si le profil
      // professionnel est actif — jamais une donnée fabriquée pour un autre profil.
      tensionRaccordement: mode === 'professionnel' ? tension : undefined,
      puissanceKva: num('mt-puissance-kva') ?? undefined,
      activityProfile: mode === 'professionnel' ? activity : undefined,
      surfaceType: surfaceType || undefined,
      surfaceM2: num('mt-surface-m2') ?? undefined,
      hasGenerator: generator ? generator === 'oui' : undefined,
      proMonthlyKwh: proUnit === 'kwh' ? (num('mt-pro-bill') ?? undefined) : undefined,
      proMonthlyMad: proUnit === 'mad' ? (num('mt-pro-bill') ?? undefined) : undefined,
      // QX — sous-panneau AGRICOLE (pompage).
      waterSource: waterSource || undefined,
      profondeurM: num('mt-profondeur') ?? undefined,
      hmtM: num('mt-hmt') ?? undefined,
      debitM3h: waterUnit === 'm3h' ? (num('mt-water-need') ?? undefined) : undefined,
      besoinM3j: waterUnit === 'm3j' ? (num('mt-water-need') ?? undefined) : undefined,
      heuresPompage: mode === 'agricole' ? (num('mt-heures-pompage') ?? undefined) : undefined,
      irrigation: irrigation || undefined,
      culture: val('mt-culture') || undefined,
      surfaceHa: num('mt-surface-ha') ?? undefined,
      pompeActuelle: val('mt-pompe-actuelle') || undefined,
      pompeCvActuelle: num('mt-pompe-cv') ?? undefined,
      fuelSpendMad: num('mt-fuel-spend') ?? undefined,
      // QX — EXACTEMENT les chiffres affichés dans le document d'estimation
      // (le conseiller CRM voit ce que le client a vu — jamais plus).
      estimateShown: estimateShown ?? undefined,
      // W317 — honeypot : vide pour tout visiteur humain (champ masqué hors
      // écran, jamais rempli sciemment) ; rejeté côté serveur si non vide.
      website_url: val('mt-hp'),
    };
    // WJ116 — fbclid/UTM (parrainage inclus) : joints seulement s'ils existent.
    Object.assign(body, readTrackingParams());
    // WJ4 — repère FACULTATIF : on le joint s'il existe, on ne BLOQUE jamais sans lui.
    if (capturePin) {
      body.roofPoint = capturePin;
      body.gpsLat = capturePin.lat;
      body.gpsLng = capturePin.lng;
    }
    if (captureOutline.length >= 3) body.roofOutline = captureOutline;
    const v = validateLead(body);
    const errors: Record<string, string> = v.ok ? {} : { ...v.errors };
    // WJ65 — validateLead (lib/lead.ts, hors périmètre de cette page) n'exige
    // qu'une longueur ≥ 2 : un nom fait uniquement d'emojis/symboles (ex. « 😀😀 »)
    // passait donc silencieusement. On exige ICI au moins UNE lettre (tout
    // alphabet — \p{L} couvre le latin ET l'arabe) avant l'envoi.
    if (!errors.fullName && !/\p{L}/u.test(val('mt-name'))) {
      errors.fullName = currentLang === 'ar' ? 'الاسم الكامل مطلوب' : 'Nom complet requis';
    }
    return { body, errors };
  }

  function showInlineErrors(errors: Record<string, string>) {
    setFieldError('mt-name', 'mt-name-err', errors.fullName ?? null);
    setFieldError('mt-phone', 'mt-phone-err', errors.phone ?? null);
    setFieldError('mt-city', 'mt-city-err', errors.city ?? null);
    setFieldError('mt-roof', 'mt-roof-err', errors.roofType ?? null);
    setFieldError('mt-bill', 'mt-bill-err', errors.billRange ?? null);
    const cErr = $('mt-consent-err');
    if (cErr) { cErr.textContent = errors.consent ?? ''; cErr.hidden = !errors.consent; }
  }

  // ——— WJ3 : deeplink WhatsApp prérempli avec l'estimation ———
  function buildWaUrl(): string {
    const text = captureWhatsappText({
      fullName: val('mt-name'),
      city: (val('mt-city') || addressEl?.value || '').trim(),
      kwcLabel: lastKwcLabel || undefined,
      savingsLabel: lastSavingsLabel || undefined,
    });
    return whatsappLink(WHATSAPP_LEADS, text);
  }

  // ——— soumission → /api/capture-lead (contrat INCHANGÉ) ———
  const form = $('mt-form') as HTMLFormElement | null;
  const errEl = $('mt-error');
  const okEl = $('mt-success');
  const belowEl = $('mt-belowthreshold');
  const submitBtn = $('mt-submit') as HTMLButtonElement | null;
  const submitLabelEl = $('mt-submit-label');
  const submitPendingEl = $('mt-submit-pending');
  let submitted = false;

  // WJ60 — bascule le CTA sur « Envoi en cours… » pendant l'attente réseau (jamais
  // de bouton muet sur 3G lente) ; restaurée à la fin quel que soit le résultat
  // (sauf succès, où le formulaire entier se désactive juste après).
  function setSubmitPending(pending: boolean) {
    if (submitBtn) submitBtn.disabled = pending;
    if (submitLabelEl) submitLabelEl.hidden = pending;
    if (submitPendingEl) submitPendingEl.hidden = !pending;
  }

  // WJ60 — message HONNÊTE pour une panne CÔTÉ SERVEUR (≥500, JSON malformé,
  // timeout, réseau coupé) : ne blâme plus les champs du visiteur pour une
  // panne qui n'est pas la sienne. WJ63 — le client préfère TOUJOURS sa propre
  // copie localisée à un texte renvoyé par le serveur (ex. le message 429 du
  // rate-limit, en français côté API) : `data.errors` n'est affiché tel quel
  // que pour de VRAIES erreurs de champ (4xx de validation), jamais pour une
  // panne serveur générique. Cette page bascule FR/عربي en direct : les
  // messages suivent `currentLang` plutôt qu'un texte figé en français.
  function serverErrorMsg(): string {
    return currentLang === 'ar'
      ? 'مشكلة تقنية من جانبنا — يرجى إعادة المحاولة.'
      : 'Un problème technique de notre côté — réessayez.';
  }
  // WJ45 — message DISTINCT quand la coupure vient du réseau du visiteur (pas
  // de notre côté) : rassure que rien n'est perdu plutôt que la formule
  // générique « problème technique de notre côté ».
  function offlineMsg(): string {
    return currentLang === 'ar'
      ? 'لا يوجد اتصال — إجاباتكم محفوظة، سنعيد المحاولة فور عودة الشبكة.'
      : "Pas de connexion — vos réponses sont conservées, on réessaie dès le retour du réseau.";
  }
  function fieldsHighlightedMsg(): string {
    return currentLang === 'ar' ? 'يرجى مراجعة الحقول المُبرزة أعلاه.' : 'Vérifiez les champs surlignés ci-dessus.';
  }
  function missingFieldMsg(): string {
    return currentLang === 'ar' ? 'حقل ناقص أو غير صالح. يرجى مراجعة معلوماتكم.' : 'Un champ est manquant ou invalide. Vérifiez vos informations.';
  }
  // WJ60 — 15 s laisse le temps à une connexion lente de répondre, sans
  // laisser le CTA « Envoi en cours… » indéfiniment (l'échec, timeout inclus,
  // retombe dans le message honnête ci-dessus — jamais un blocage silencieux).
  const SUBMIT_TIMEOUT_MS = 15_000;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (errEl) errEl.hidden = true;
    const { body, errors } = buildBody();
    if (Object.keys(errors).length > 0) {
      showInlineErrors(errors);
      if (errEl) {
        errEl.textContent = fieldsHighlightedMsg();
        errEl.hidden = false;
      }
      // amène l'utilisateur au premier champ en erreur.
      // WJ48 — mt-roof est désormais sr-only (le choix visuel se fait via les
      // cartes .mt-roof-card) : focaliser le <select> caché déplacerait le
      // focus clavier sur un élément invisible pour un utilisateur voyant. On
      // focalise plutôt la première carte visible dans ce cas.
      const firstId = ['mt-name', 'mt-phone', 'mt-city', 'mt-roof', 'mt-bill']
        .find((id) => $(id)?.getAttribute('aria-invalid') === 'true');
      if (firstId === 'mt-roof') {
        document.querySelector<HTMLButtonElement>('.mt-roof-card')?.focus();
      } else if (firstId) {
        ($(firstId) as HTMLElement | null)?.focus();
      }
      return;
    }
    showInlineErrors({});

    setSubmitPending(true);
    try {
      const res = await fetch('/api/capture-lead', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify(body),
        signal: AbortSignal.timeout(SUBMIT_TIMEOUT_MS),
      });
      // WJ60/WJ63 — une réponse JSON malformée (corps vide/illisible) est traitée
      // comme une panne serveur, jamais silencieusement comme « aucune erreur ».
      let malformed = false;
      const data = (await res.json().catch(() => {
        malformed = true;
        return {};
      })) as { ok?: boolean; qualified?: boolean; errors?: Record<string, string> };
      if (res.ok && !malformed && data.ok) {
        submitted = true;
        hasEnteredData = false; // WJ61 — succès : plus besoin du garde-fou beforeunload.
        clearWizardState(); // WJ61 — la demande a abouti : l'instantané n'a plus lieu d'être.
        // WJ104 — « rappel demandé » : signal DISTINCT d'un opt-in WhatsApp,
        // émis UNIQUEMENT quand la préférence de contact choisie est « on
        // m'appelle » (mt-contact-phone), jamais pour le repli WhatsApp par
        // défaut. Dédupliqué comme les autres beacons de cette page.
        if (($('mt-contact-phone') as HTMLInputElement | null)?.checked === true) {
          sendFunnelBeacon('contact', 'callback_requested');
        }
        const waUrl = buildWaUrl();
        // WJ5 — réponse HONNÊTE selon le seuil 1 000 MAD (qualified renvoyé par le serveur).
        if (data.qualified) {
          if (okEl) okEl.hidden = false;
          // WJ52 — affiche la référence générée dans buildBody() (déjà incluse
          // dans le body envoyé — on la relit ici via getOrCreateClientRef()
          // pour rester la MÊME valeur, jamais régénérée).
          const refEl = $('mt-client-ref');
          if (refEl) refEl.textContent = getOrCreateClientRef();
          const waLink = $('mt-success-wa') as HTMLAnchorElement | null;
          if (waLink) waLink.href = waUrl;
          // WJ3/WJ51 — sur mobile, on propose WhatsApp tout de suite quand la
          // préférence de contact est « Uniquement sur WhatsApp » (option cochée par défaut).
          const wantsWa = ($('mt-contact-phone') as HTMLInputElement | null)?.checked !== true;
          if (wantsWa && /Mobi|Android|iPhone/i.test(navigator.userAgent) && !reducedMotion) {
            setTimeout(() => { window.location.href = waUrl; }, 900);
          }
        } else {
          // sous le seuil : PAS de faux « enregistré » — message adapté + WhatsApp.
          if (belowEl) belowEl.hidden = false;
          const belowWa = $('mt-belowthreshold-wa') as HTMLAnchorElement | null;
          if (belowWa) belowWa.href = waUrl;
        }
        // désactive les champs après envoi (sauf les liens WhatsApp).
        Array.from(form.elements).forEach((el) => ((el as HTMLInputElement).disabled = true));
        return;
      }
      // WJ60/WJ63 — ≥500 ou JSON malformé : panne CÔTÉ SERVEUR, jamais un message
      // qui blâme les champs. Sous 500 avec des erreurs de champ exploitables
      // (4xx de validation, ex. `errors.fullName`), on les réaffiche inline comme
      // avant — mais un texte serveur qui n'est PAS une erreur de champ connue
      // (ex. `errors.rate`, le 429 du rate-limit, en français côté API) n'écrase
      // jamais notre copie honnête : seul le champ `errors.rate` bascule sur le
      // message serveur générique lui aussi.
      const isServerError = malformed || res.status >= 500 || (!!data.errors && 'rate' in data.errors);
      if (!isServerError && data.errors) showInlineErrors(data.errors);
      const firstFieldErr = !isServerError && data.errors ? Object.values(data.errors)[0] : null;
      if (errEl) {
        errEl.textContent = isServerError ? serverErrorMsg() : (firstFieldErr || missingFieldMsg());
        errEl.hidden = false;
      }
      setSubmitPending(false);
    } catch {
      // WJ60 — englobe le timeout (AbortSignal.timeout) et toute coupure réseau.
      // WJ45 — si le navigateur se sait hors-ligne, on l'affirme explicitement
      // (bandeau + message dédié) plutôt que la formule générique « panne de
      // notre côté » — qui blâmerait à tort notre infrastructure. Le formulaire
      // reste rempli et l'instantané sessionStorage (WJ61) persiste : rien n'est
      // perdu, il suffit de renvoyer une fois le réseau revenu.
      syncOfflineBanner();
      if (errEl) {
        errEl.textContent = navigator.onLine ? serverErrorMsg() : offlineMsg();
        errEl.hidden = false;
      }
      setSubmitPending(false);
    }
  });

  // ——— WJ7/WJ33/WJ46 : offre WhatsApp — exit-intent (desktop + onglet caché
  // mobile) ET pic d'intérêt (estimation instantanée affichée). Même modale,
  // même garde `exitShown` (ne s'affiche qu'UNE fois, quel que soit le
  // déclencheur) : l'exit-intent reste un FILET pour qui n'a pas vu l'offre au
  // pic d'intérêt (ex. ferme l'onglet avant l'étape 3), jamais un doublon. ———
  const exitModal = $('mt-exit') as HTMLElement | null;
  const exitPhoneInput = $('mt-exit-phone') as HTMLInputElement | null;
  const exitWaLink = $('mt-exit-wa') as HTMLAnchorElement | null;
  let exitShown = false;
  let exitTriggerEl: HTMLElement | null = null; // WJ33 — pour restaurer le focus à la fermeture

  /** WJ33 — construit (ou reconstruit) le lien WhatsApp d'abandon depuis l'état actuel. */
  function buildExitWaHref(): string {
    const phone = exitPhoneInput?.value.trim() || '';
    const text = captureWhatsappText({
      fullName: '',
      city: (val('mt-city') || addressEl?.value || '').trim(),
      kwcLabel: lastKwcLabel || undefined,
      savingsLabel: lastSavingsLabel || undefined,
    }) + (phone.length >= 6 ? ` Mon numéro : ${phone}.` : '');
    return whatsappLink(WHATSAPP_LEADS, text);
  }

  // WJ102 — pendant que la modale d'abandon est ouverte, le RESTE du document
  // (en-tête, pied de page, l'assistant lui-même derrière l'overlay) doit
  // devenir réellement inatteignable — pas seulement masqué visuellement.
  // Sans ça, un utilisateur au clavier/lecteur d'écran pouvait Tab-cycler
  // jusqu'à des liens du header/footer DERRIÈRE l'overlay semi-transparent,
  // alors que le piège de focus (Tab/Shift+Tab plus bas) ne couvre que le
  // DERNIER Tab avant de reboucler — pas les liens hors de la modale
  // atteignables par un clic direct/VoiceOver rotor. Même idiome que
  // Header.astro (menu mobile) : `inert` posé sur chaque enfant DIRECT de
  // <body> qui ne contient PAS la modale elle-même.
  const inertedSiblings: HTMLElement[] = [];
  function setBackgroundInert(on: boolean): void {
    if (on) {
      inertedSiblings.length = 0;
      for (const child of Array.from(document.body.children)) {
        if (!(child instanceof HTMLElement)) continue;
        if (child.contains(exitModal)) continue; // ne jamais rendre la modale elle-même inerte
        if (child.hasAttribute('inert')) continue; // déjà inerte pour une autre raison : ne pas y toucher à la fermeture
        child.setAttribute('inert', '');
        inertedSiblings.push(child);
      }
    } else {
      for (const el of inertedSiblings) el.removeAttribute('inert');
      inertedSiblings.length = 0;
    }
  }

  /** WJ46 — affiche l'offre WhatsApp (exit-intent OU pic d'intérêt). Ne
   *  s'affiche qu'une fois par visite (`exitShown`), jamais après soumission. */
  function showWhatsappOffer(triggerEl: HTMLElement | null = null) {
    if (exitShown || submitted) return;
    exitShown = true;
    exitTriggerEl = triggerEl ?? (document.activeElement as HTMLElement | null);
    if (exitWaLink) exitWaLink.href = buildExitWaHref();
    if (exitModal) {
      exitModal.hidden = false;
      // WJ102 — le reste du document devient inerte tant que la modale est ouverte.
      setBackgroundInert(true);
      // WJ33 — focus initial DANS la modale (premier champ interactif).
      exitPhoneInput?.focus();
    }
  }
  // WJ59 — « étape abandonnée » : dédupliquée séparément de l'offre WhatsApp
  // (celle-ci ne s'affiche qu'une fois par visite via `exitShown`, mais le
  // signal de mesure reste utile même si l'offre a déjà été vue une fois).
  let funnelAbandonSent = false;
  function maybeShowExit(triggerEl: HTMLElement | null = null) {
    // WJ46 — grace window : ne PAS interpréter comme un abandon le passage en
    // arrière-plan pendant que le sélecteur de photo compteur/facture est
    // ouvert (l'appareil photo/la galerie masquent l'onglet le temps de la
    // prise de vue — l'exact geste que le formulaire invite à faire).
    if (filePickerOpen) return;
    // ne déranger que si l'utilisateur a au moins commencé (mode/facture ou step > 0)
    const started2 = step > 0 || resolveMonthlyBill() != null || (capturePin != null);
    if (!started2) return;
    // WB30 — pas de beacon « abandonné » avant l'étape de consentement (panneau 2).
    if (!submitted && !funnelAbandonSent && hasReachedConsentStep()) {
      funnelAbandonSent = true;
      const currentStep = step === 0 ? 'toit' : step === 1 ? 'facture' : (lastKwc != null ? 'contact' : 'estimation');
      sendFunnelBeacon(currentStep, 'abandoned');
    }
    showWhatsappOffer(triggerEl);
  }
  function closeExit() {
    if (!exitModal || exitModal.hidden) return;
    exitModal.hidden = true;
    // WJ102 — restaure l'accessibilité du reste du document AVANT de rendre le
    // focus (sinon la cible de focus ci-dessous pourrait encore être inerte).
    setBackgroundInert(false);
    // WJ33 — restauration du focus vers l'élément qui a déclenché l'ouverture
    // (ou, à défaut, un point d'ancrage stable de la page).
    (exitTriggerEl && document.contains(exitTriggerEl) ? exitTriggerEl : $('mt-lang-fr'))?.focus();
    exitTriggerEl = null;
  }
  // desktop : la souris quitte par le haut
  document.addEventListener('mouseout', (e) => {
    if (!e.relatedTarget && (e as MouseEvent).clientY <= 0) maybeShowExit();
  });
  // mobile : l'onglet passe en arrière-plan
  document.addEventListener('visibilitychange', () => {
    if (document.visibilityState === 'hidden') maybeShowExit();
  });
  $('mt-exit-close')?.addEventListener('click', () => closeExit());
  exitModal?.addEventListener('click', (e) => { if (e.target === exitModal) closeExit(); });

  // WJ33 — clavier : Esc ferme + focus trap (Tab/Shift+Tab restent DANS la modale).
  exitModal?.addEventListener('keydown', (e) => {
    const ke = e as KeyboardEvent;
    if (ke.key === 'Escape') { closeExit(); return; }
    if (ke.key !== 'Tab' || !exitModal) return;
    const focusable = Array.from(
      exitModal.querySelectorAll<HTMLElement>('a[href], button:not([disabled]), input:not([disabled]), [tabindex]:not([tabindex="-1"])'),
    ).filter((el) => el.offsetParent !== null || el === document.activeElement);
    if (focusable.length === 0) return;
    const first = focusable[0];
    const last = focusable[focusable.length - 1];
    const active = document.activeElement as HTMLElement | null;
    if (ke.shiftKey && active === first) {
      ke.preventDefault();
      last.focus();
    } else if (!ke.shiftKey && active === last) {
      ke.preventDefault();
      first.focus();
    }
  });

  // WJ33 — le CTA WhatsApp d'abandon : le lien `href` est reconstruit à CHAQUE
  // saisie (pas seulement au clic), pour rester correct si l'utilisateur
  // ouvre WhatsApp via un clic droit / « copier le lien » avant de finir de taper.
  exitPhoneInput?.addEventListener('input', () => {
    const err = $('mt-exit-err');
    if (err) err.hidden = true;
    if (exitWaLink) exitWaLink.href = buildExitWaHref();
  });
  exitWaLink?.addEventListener('click', (e) => {
    const phone = exitPhoneInput?.value.trim() || '';
    const err = $('mt-exit-err');
    if (phone.length < 6) {
      e.preventDefault();
      // WJ63 — suit `currentLang` (bascule FR/عربي en direct) plutôt qu'un
      // texte figé en français.
      if (err) {
        err.textContent = currentLang === 'ar' ? 'يرجى إدخال رقم للرد عليكم.' : 'Indiquez un numéro pour qu\'on vous réponde.';
        err.hidden = false;
      }
      return;
    }
    if (err) err.hidden = true;
  });

  // ——— QX : état initial après réhydratation complète (tout est défini ici) ———
  // Tranche dérivée d'un montant exact restauré (fix « tranche redondante »).
  syncBillRangeFromExact();
  // Parcours restauré directement à l'étape estimation (WJ61) : recalcule le
  // document immédiatement — sinon des tirets jusqu'à la première interaction.
  if (step === 2) computeEstimate();
</script>
