    if (h && h.dayShare > 0) hypParts.push(`part diurne estimée ${pct(h.dayShare)} %`);
    if (h && h.prixKwcLow > 0 && h.prixKwcHigh > 0) hypParts.push(`investissement ${formatMad(h.prixKwcLow)} – ${formatMad(h.prixKwcHigh)} MAD/kWc (fourchette marché)`);
    if (hypEl) {
      hypEl.textContent = hypParts.length > 0 ? `Hypothèses : ${hypParts.join(' · ')} — autoconsommation loi 82-21, sans revente.` : '';
      hypEl.hidden = hypParts.length === 0;
