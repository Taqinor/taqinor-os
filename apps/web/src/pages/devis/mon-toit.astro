          <fieldset class="mt-1">
            <legend class="text-sm text-lune-soft" data-i18n data-fr="Comment préférez-vous qu'on vous recontacte ?" data-ar="كيف تفضّلون أن نتواصل معكم؟">Comment préférez-vous qu'on vous recontacte&nbsp;?</legend>
            <div class="mt-2 grid grid-cols-1 gap-2 sm:grid-cols-2">
