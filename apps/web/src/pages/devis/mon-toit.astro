---
/**
 * « Mon toit » — CAPTURE CLIENT (PUBLIC, noindex). Élevée WJ1-WJ8.
 *
 * Parcours mobile-first en assistant (WJ6) : Votre toit → Votre facture → Votre
 * estimation. La carte/le repère sont FACULTATIFS (WJ4) : on peut soumettre avec
 * l'adresse seule si la carte est indisponible. À l'étape estimation, une
 * FOURCHETTE instantanée (kWc, ≈MAD/mois économisés, amortissement) est calculée
 * par le VRAI moteur (billEstimate → estimatorBrain) AVANT la porte de contact
 * (WJ1). La capture est WhatsApp-first (WJ3) : CTA « Recevoir mon estimation sur
 * WhatsApp » prérempli + e-mail/opt-in transmis au webhook. Le seuil 1 000 MAD est
 * préservé et HONNÊTE (WJ5) : sous le seuil, on n'affiche pas un faux
 * « enregistré » mais un message adapté. Récupération d'abandon (WJ7) + bandeau de
 * confiance (WJ8). Microcopie FR + AR (WJ6).
 *
 * Le contrat de soumission /api/capture-lead est INCHANGÉ (validateLead, seuil,
 * consentement/UTM/fbclid, roofPoint/roofOutline/profil énergétique facultatifs).
 * L'outil 3D est booté en captureOnly : aucun panneau ne s'affiche ici.
 */
import Layout from '../../layouts/Layout.astro';
import { BILL_RANGES } from '../../lib/billRange';
import { ROOF_TYPES } from '../../lib/lead';
import StarRating from '../../components/StarRating.astro';
import CertLogoRow from '../../components/CertLogoRow.astro';
import InstallCounter from '../../components/InstallCounter.astro';
import ZelligeSignature from '../../components/ZelligeSignature.astro';

const inputClass =
  'w-full border border-white/15 bg-white/5 px-3 py-3 text-base text-white placeholder:text-lune-faint outline-none transition-colors focus:border-brass-400 focus:ring-2 focus:ring-brass-400/30 aria-[invalid=true]:border-alert-300 aria-[invalid=true]:ring-2 aria-[invalid=true]:ring-alert-300/30';
const roofTypes = ROOF_TYPES;
const billRanges = BILL_RANGES;

// WJ6 — étapes de l'assistant (libellés FR + AR). data-i18n pour bascule de langue.
const STEPS = [
  { fr: 'Votre toit', ar: 'سطحك' },
  { fr: 'Votre facture', ar: 'فاتورتك' },
  { fr: 'Votre estimation', ar: 'تقديرك' },
];

// WJ6 — sélecteur de mode (résidentiel / professionnel / agricole), FR + AR.
const MODES = [
  { id: 'residentiel', fr: 'Résidentiel', ar: 'سكني', desc_fr: 'Villa, appartement', desc_ar: 'فيلا، شقة' },
  { id: 'professionnel', fr: 'Professionnel', ar: 'مهني', desc_fr: 'Industrie, commerce', desc_ar: 'صناعة، تجارة' },
  { id: 'agricole', fr: 'Agricole', ar: 'فلاحي', desc_fr: 'Pompage, ferme', desc_ar: 'ضخ، مزرعة' },
];

// WJ8 — villes desservies (réelles, NAP) pour la preuve de proximité.
const TOWNS = ['Casablanca', 'Rabat', 'Marrakech', 'Tanger', 'Agadir', 'Kénitra', 'Fès', 'Settat'];
---

<Layout
  title="Recevez votre estimation solaire — Mon toit | Taqinor"
  description="Adresse + facture : recevez instantanément une estimation solaire (puissance, économies, amortissement), puis votre étude personnalisée sur WhatsApp."
  noindex={true}
>
  <section class="bg-nuit px-4 py-8 sm:py-12">
    <div class="mx-auto max-w-2xl">
      <!-- En-tête + bascule de langue FR/AR (WJ6) -->
      <div class="flex items-start justify-between gap-3">
        <div>
          <p class="tech-label rule-brass text-brass-300" data-i18n data-fr="Estimation solaire · gratuit · sans engagement" data-ar="تقدير شمسي · مجاني · بدون التزام">
            Estimation solaire · gratuit · sans engagement
          </p>
          <h1 class="display mt-4 text-2xl text-white sm:text-3xl" data-i18n data-fr="Recevez votre estimation solaire" data-ar="استلم تقديرك الشمسي">
            Recevez votre estimation solaire
          </h1>
        </div>
        <div class="flex flex-none gap-1 rounded-sm border border-white/15 p-0.5" role="group" aria-label="Langue">
          <button type="button" id="mt-lang-fr" aria-pressed="true"
            class="px-3 py-1.5 text-sm font-semibold text-azur-950 bg-brass-400 transition-colors">FR</button>
          <button type="button" id="mt-lang-ar" aria-pressed="false"
            class="px-3 py-1.5 text-sm font-semibold text-lune-soft transition-colors hover:text-white">عربي</button>
        </div>
      </div>

      <!-- WJ6 — microcopie « pas de pression » -->
      <p class="mt-3 text-sm text-lune-soft" data-i18n
        data-fr="Réponse sous 24–48 h · on vous répond sur WhatsApp, pas d'appels commerciaux."
        data-ar="رد خلال 24–48 ساعة · نجيبك على واتساب، بدون مكالمات تجارية.">
        Réponse sous 24–48 h · on vous répond sur WhatsApp, pas d'appels commerciaux.
      </p>

      <!-- WJ6 — barre de progression étiquetée -->
      <ol id="mt-progress" class="mt-6 grid grid-cols-3 gap-2" aria-label="Progression">
        {STEPS.map((s, i) => (
          <li class="mt-step flex flex-col gap-1.5" data-step={i}>
            <span class="h-1.5 w-full rounded-full bg-white/10 mt-step-bar transition-colors"></span>
            <span class="text-xs text-lune-faint mt-step-label" data-i18n data-fr={s.fr} data-ar={s.ar}>{s.fr}</span>
          </li>
        ))}
      </ol>

      <!-- ============ ÉTAPE 0/1 — VOTRE TOIT (mode + carte/repère) ============ -->
      <div id="mt-panel-0" class="mt-step-panel">
        <!-- WJ6 — sélecteur de mode -->
        <fieldset class="mt-6">
          <legend class="text-sm text-lune-soft" data-i18n data-fr="Votre type de projet" data-ar="نوع مشروعك">Votre type de projet</legend>
          <div class="mt-3 grid grid-cols-3 gap-2">
            {MODES.map((m, i) => (
              <button type="button" class="mt-mode cine-card flex flex-col items-start gap-0.5 border p-3 text-left transition-colors"
                data-mode={m.id} aria-pressed={i === 0 ? 'true' : 'false'}>
                <span class="text-sm font-semibold text-white" data-i18n data-fr={m.fr} data-ar={m.ar}>{m.fr}</span>
                <span class="text-xs text-lune-faint" data-i18n data-fr={m.desc_fr} data-ar={m.desc_ar}>{m.desc_fr}</span>
              </button>
            ))}
          </div>
        </fieldset>

        <p class="mt-5 text-lune-soft" data-i18n
          data-fr="Cherchez votre adresse et posez un repère sur votre toit. C'est facultatif — vous pouvez aussi continuer avec votre adresse seule."
          data-ar="ابحث عن عنوانك وضع علامة على سطحك. هذا اختياري — يمكنك أيضاً المتابعة بعنوانك فقط.">
          Cherchez votre adresse et posez un repère sur votre toit. C'est facultatif —
          vous pouvez aussi continuer avec votre adresse seule.
        </p>

        <!-- Repli sans JavaScript / sans clé carte (WJ4) : on demande l'adresse en clair
             et on AUTORISE la suite (plus de cul-de-sac sur le repère). -->
        <div id="mt-fallback" hidden class="cine-card mt-5 border-l-4 border-alert-300 p-5">
          <p class="font-semibold text-white" data-i18n data-fr="Carte momentanément indisponible" data-ar="الخريطة غير متوفرة مؤقتاً">Carte momentanément indisponible</p>
          <p class="mt-2 text-sm text-lune-soft" data-i18n
            data-fr="Pas de souci : indiquez votre adresse complète ci-dessous et continuez. Nous localiserons votre toit pour vous."
            data-ar="لا مشكلة: أدخل عنوانك الكامل أدناه وتابع. سنحدد موقع سطحك من أجلك.">
            Pas de souci : indiquez votre adresse complète ci-dessous et continuez. Nous
            localiserons votre toit pour vous.
          </p>
          <label class="mt-3 block text-sm text-lune-soft">
            <span data-i18n data-fr="Adresse complète" data-ar="العنوان الكامل">Adresse complète</span>
            <input id="mt-fallback-address" type="text" autocomplete="street-address"
              placeholder="Ex. Lot. Al Wifaq, Hay Riad, Rabat" class={`${inputClass} mt-1`} />
          </label>
        </div>

        <!-- CARTE — recherche d'adresse + repère (ids rp9-* câblés par captureBoot). -->
        <div id="mt-stage" class="cine-card mt-5 overflow-hidden">
          <form id="rp9-search" class="flex flex-col gap-3 border-b border-white/10 p-4 sm:flex-row">
            <label for="rp9-address" class="sr-only">Votre adresse</label>
            <div class="relative flex-1">
              <input id="rp9-address" name="address" type="text" autocomplete="off"
                role="combobox" aria-autocomplete="list" aria-expanded="false"
                aria-controls="rp9-suggestions" aria-haspopup="listbox"
                placeholder="Adresse, quartier ou ville (ex. Casablanca, Maârif)" class={inputClass} />
              <ul id="rp9-suggestions" role="listbox" aria-label="Suggestions d'adresses" hidden
                class="absolute left-0 right-0 top-full z-20 mt-1 max-h-72 overflow-auto border border-white/15 bg-nuit-900 shadow-xl">
              </ul>
            </div>
            <button type="submit"
              class="flex-none bg-brass-400 px-6 py-3 text-base font-bold text-azur-950 transition-colors hover:bg-brass-300">
              Localiser
            </button>
          </form>

          <div id="rp9-map" class="mt-0 h-[44vh] min-h-[280px] w-full bg-nuit-700"
            role="application" aria-label="Carte satellite pour repérer votre toit"></div>

          <div class="flex flex-wrap items-center gap-3 border-t border-white/10 p-4">
            <button type="button" id="rp9-finish" disabled
              class="border border-white/25 px-4 py-2.5 text-sm font-semibold text-white transition-colors hover:border-brass-400 hover:text-brass-300 disabled:cursor-not-allowed disabled:opacity-40">
              Terminer le tracé
            </button>
            <button type="button" id="rp9-undo-point" hidden
              class="border border-white/25 px-4 py-2.5 text-sm font-semibold text-lune-soft transition-colors hover:border-brass-400 hover:text-brass-300">
              Annuler le dernier point
            </button>
            <button type="button" id="rp9-clear"
              class="border border-white/25 px-4 py-2.5 text-sm font-semibold text-lune-soft transition-colors hover:border-white/50 hover:text-white">
              Effacer
            </button>
            <p class="ml-auto text-sm text-lune-faint">
              <span>Repère&nbsp;: </span><span id="rp9-area-value" class="text-white">—</span>
            </p>
          </div>
          <p id="rp9-status" class="border-t border-white/10 px-4 py-3 text-sm text-lune-faint" aria-live="polite">
            Cherchez votre adresse, puis posez un repère sur votre toit (facultatif).
          </p>
        </div>

        <div class="mt-5 flex justify-end">
          <button type="button" id="mt-next-0"
            class="inline-flex items-center justify-center gap-2 bg-brass-400 px-6 py-3 text-base font-bold text-azur-950 transition-colors hover:bg-brass-300">
            <span data-i18n data-fr="Continuer" data-ar="متابعة">Continuer</span> →
          </button>
        </div>
      </div>

      <!-- ============ ÉTAPE 2 — VOTRE FACTURE (+ profil énergétique) ============ -->
      <div id="mt-panel-1" class="mt-step-panel" hidden>
        <p class="mt-6 text-lune-soft" data-i18n
          data-fr="Indiquez votre facture pour calculer votre estimation. Le montant exact donne le chiffre le plus juste."
          data-ar="أدخل فاتورتك لحساب تقديرك. المبلغ الدقيق يعطي الرقم الأصح.">
          Indiquez votre facture pour calculer votre estimation. Le montant exact donne le
          chiffre le plus juste.
        </p>

        <div class="cine-card mt-5 space-y-4 p-5 sm:p-6">
          <label class="block text-sm text-lune-soft">
            <span data-i18n data-fr="Facture mensuelle exacte (MAD)" data-ar="الفاتورة الشهرية الدقيقة (درهم)">Facture mensuelle exacte (MAD)</span>
            <input id="mt-facture-hiver" name="factureHiver" type="number" step="any" inputmode="decimal"
              placeholder="Ex. 1 200" class={`${inputClass} mt-1`} />
            <span id="mt-facture-hiver-err" hidden class="mt-1 block text-xs text-alert-300"></span>
          </label>

          <label class="block text-sm text-lune-soft">
            <span data-i18n data-fr="…ou choisissez une tranche" data-ar="…أو اختر شريحة">…ou choisissez une tranche</span>
            <select id="mt-bill" name="billRange" class={`${inputClass} mt-1`}>
              <option value="">Choisir…</option>
              {billRanges.map((b) => <option value={b.id}>{b.label}</option>)}
            </select>
            <span id="mt-bill-err" hidden class="mt-1 block text-xs text-alert-300"></span>
          </label>

          <div class="grid gap-4 sm:grid-cols-2">
            <label class="block text-sm text-lune-soft">
              <span data-i18n data-fr="Type de toit" data-ar="نوع السطح">Type de toit</span>
              <select id="mt-roof" name="roofType" class={`${inputClass} mt-1`}>
                <option value="">Choisir…</option>
                {roofTypes.map((r) => <option value={r.id}>{r.label}</option>)}
              </select>
              <span id="mt-roof-err" hidden class="mt-1 block text-xs text-alert-300"></span>
            </label>
            <label class="block text-sm text-lune-soft">
              <span data-i18n data-fr="Raccordement" data-ar="نوع الربط">Raccordement</span>
              <select id="mt-raccordement" name="raccordement" class={`${inputClass} mt-1`}>
                <option value="">Choisir…</option>
                <option value="monophase">Monophasé</option>
                <option value="triphase">Triphasé</option>
                <option value="inconnu">Je ne sais pas</option>
              </select>
            </label>
          </div>

          <label class="flex items-start gap-3 text-sm text-lune-soft">
            <input id="mt-ete-differente" name="eteDifferente" type="checkbox" class="mt-1 h-5 w-5 flex-none accent-brass-400" />
            <span data-i18n data-fr="L'été est différent de l'hiver ? (climatisation, pompage…)" data-ar="الصيف مختلف عن الشتاء؟ (تكييف، ضخ…)">L'été est différent de l'hiver&nbsp;? (climatisation, pompage…)</span>
          </label>

          <label id="mt-facture-ete-wrap" hidden class="block text-sm text-lune-soft">
            <span data-i18n data-fr="Facture été (MAD)" data-ar="فاتورة الصيف (درهم)">Facture été (MAD)</span>
            <input id="mt-facture-ete" name="factureEte" type="number" step="any" inputmode="decimal"
              placeholder="Ex. 2 500" class={`${inputClass} mt-1`} />
          </label>
        </div>

        <!-- ===== WJ31 — questions best-in-world, TOUTES facultatives, repliées par défaut ===== -->
        <details id="mt-more" class="cine-card mt-4 p-5 sm:p-6">
          <summary class="cursor-pointer select-none text-sm font-semibold text-brass-300" data-i18n
            data-fr="Affiner mon estimation (facultatif, 1 minute)" data-ar="تحسين تقديري (اختياري، دقيقة واحدة)">
            Affiner mon estimation (facultatif, 1 minute)
          </summary>

          <div class="mt-4 grid gap-4 sm:grid-cols-2">
            <label class="block text-sm text-lune-soft">
              <span data-i18n data-fr="Distributeur d'électricité" data-ar="موزع الكهرباء">Distributeur d'électricité</span>
              <select id="mt-distributeur" name="distributeur" class={`${inputClass} mt-1`}>
                <option value="">Choisir…</option>
                <option value="onee" data-i18n data-fr="ONEE" data-ar="المكتب الوطني">ONEE</option>
                <option value="lydec" data-i18n data-fr="Lydec" data-ar="ليديك">Lydec</option>
                <option value="redal" data-i18n data-fr="Redal" data-ar="ريضال">Redal</option>
                <option value="inconnu" data-i18n data-fr="Je ne sais pas" data-ar="لا أعرف">Je ne sais pas</option>
              </select>
            </label>
            <label class="block text-sm text-lune-soft">
              <span data-i18n data-fr="Consommation (kWh/mois, si connue)" data-ar="الاستهلاك (كيلوواط ساعة/شهر، إن عُرف)">Consommation (kWh/mois, si connue)</span>
              <input id="mt-bill-kwh" name="billKwh" type="number" step="any" inputmode="decimal"
                placeholder="Ex. 850" class={`${inputClass} mt-1`} />
            </label>
          </div>

          <!-- Photo compteur/facture — capturée EN LOCAL, jamais uploadée (pas d'endpoint aujourd'hui). -->
          <div class="mt-4">
            <label class="block text-sm text-lune-soft" for="mt-meter-photo" data-i18n
              data-fr="Photo du compteur ou de la facture" data-ar="صورة العداد أو الفاتورة">
              Photo du compteur ou de la facture
            </label>
            <input id="mt-meter-photo" type="file" accept="image/*" capture="environment"
              class="mt-1 block w-full text-sm text-lune-soft file:mr-3 file:border-0 file:bg-white/10 file:px-3 file:py-2 file:text-sm file:font-semibold file:text-white" />
            <p id="mt-meter-photo-note" class="mt-1 text-xs text-lune-faint" data-i18n
              data-fr="Ou envoyez-la nous directement sur WhatsApp après l'envoi du formulaire — c'est souvent plus rapide."
              data-ar="أو أرسلها لنا مباشرة على واتساب بعد إرسال النموذج — غالباً أسرع.">
              Ou envoyez-la nous directement sur WhatsApp après l'envoi du formulaire — c'est
              souvent plus rapide.
            </p>
          </div>

          <fieldset class="mt-4">
            <legend class="text-sm text-lune-soft" data-i18n data-fr="Ombrage sur le toit" data-ar="التظليل على السطح">Ombrage sur le toit</legend>
            <div class="mt-2 grid grid-cols-3 gap-2">
              <button type="button" class="mt-ombrage cine-card border p-2.5 text-center text-sm text-white transition-colors" data-value="aucun" aria-pressed="false" data-i18n data-fr="Aucun" data-ar="لا يوجد">Aucun</button>
              <button type="button" class="mt-ombrage cine-card border p-2.5 text-center text-sm text-white transition-colors" data-value="partiel" aria-pressed="false" data-i18n data-fr="Partiel" data-ar="جزئي">Partiel</button>
              <button type="button" class="mt-ombrage cine-card border p-2.5 text-center text-sm text-white transition-colors" data-value="important" aria-pressed="false" data-i18n data-fr="Important" data-ar="كبير">Important</button>
            </div>
          </fieldset>

          <label class="mt-4 block text-sm text-lune-soft">
            <span data-i18n data-fr="Âge approximatif du toit (années)" data-ar="عمر السطح التقريبي (سنوات)">Âge approximatif du toit (années)</span>
            <input id="mt-roof-age" name="roofAgeYears" type="number" step="1" min="0" inputmode="numeric"
              placeholder="Ex. 10" class={`${inputClass} mt-1`} />
          </label>

          <fieldset class="mt-4">
            <legend class="text-sm text-lune-soft" data-i18n data-fr="Charges futures envisagées" data-ar="أحمال مستقبلية متوقعة">Charges futures envisagées</legend>
            <div class="mt-2 flex flex-wrap gap-2">
              <button type="button" class="mt-future-load cine-card border px-3 py-2 text-sm text-white transition-colors" data-value="clim" aria-pressed="false" data-i18n data-fr="Climatisation" data-ar="تكييف">Climatisation</button>
              <button type="button" class="mt-future-load cine-card border px-3 py-2 text-sm text-white transition-colors" data-value="ve" aria-pressed="false" data-i18n data-fr="Voiture électrique" data-ar="سيارة كهربائية">Voiture électrique</button>
              <button type="button" class="mt-future-load cine-card border px-3 py-2 text-sm text-white transition-colors" data-value="pompe" aria-pressed="false" data-i18n data-fr="Pompage" data-ar="ضخ">Pompage</button>
            </div>
          </fieldset>

          <label class="mt-4 flex items-start gap-3 text-sm text-lune-soft">
            <input id="mt-battery-interest" name="batteryInterest" type="checkbox" class="mt-1 h-5 w-5 flex-none accent-brass-400" />
            <span data-i18n data-fr="Intéressé(e) par une batterie de stockage" data-ar="مهتم بتخزين البطارية">Intéressé(e) par une batterie de stockage</span>
          </label>

          <div class="mt-4 grid gap-4 sm:grid-cols-2">
            <label class="block text-sm text-lune-soft">
              <span data-i18n data-fr="Vous êtes…" data-ar="أنتم…">Vous êtes…</span>
              <select id="mt-occupant-type" name="occupantType" class={`${inputClass} mt-1`}>
                <option value="">Choisir…</option>
                <option value="proprietaire" data-i18n data-fr="Propriétaire" data-ar="مالك">Propriétaire</option>
                <option value="locataire" data-i18n data-fr="Locataire" data-ar="مستأجر">Locataire</option>
                <option value="decideur" data-i18n data-fr="Décideur (entreprise)" data-ar="صاحب القرار (شركة)">Décideur (entreprise)</option>
              </select>
            </label>
            <label class="block text-sm text-lune-soft">
              <span data-i18n data-fr="Votre projet, c'est pour…" data-ar="مشروعكم من أجل…">Votre projet, c'est pour…</span>
              <select id="mt-project-timing" name="projectTiming" class={`${inputClass} mt-1`}>
                <option value="">Choisir…</option>
                <option value="maintenant" data-i18n data-fr="Maintenant" data-ar="الآن">Maintenant</option>
                <option value="3mois" data-i18n data-fr="Dans ~3 mois" data-ar="خلال ~3 أشهر">Dans ~3 mois</option>
                <option value="renseignement" data-i18n data-fr="Juste un renseignement" data-ar="مجرد استعلام">Juste un renseignement</option>
              </select>
            </label>
          </div>

          <label class="mt-4 block text-sm text-lune-soft">
            <span data-i18n data-fr="Mode de financement envisagé" data-ar="طريقة التمويل المتوقعة">Mode de financement envisagé</span>
            <select id="mt-financing-intent" name="financingIntent" class={`${inputClass} mt-1`}>
              <option value="">Choisir…</option>
              <option value="comptant" data-i18n data-fr="Comptant" data-ar="نقداً">Comptant</option>
              <option value="financement" data-i18n data-fr="Financement / crédit" data-ar="تمويل / قرض">Financement / crédit</option>
              <option value="indecis" data-i18n data-fr="Pas encore décidé" data-ar="لم أقرر بعد">Pas encore décidé</option>
            </select>
          </label>
        </details>

        <div class="mt-5 flex items-center justify-between gap-3">
          <button type="button" id="mt-back-1"
