            </label>
            <label class="block text-sm text-lune-soft">
              <span data-i18n data-fr="Téléphone / WhatsApp" data-ar="الهاتف / واتساب">Téléphone / WhatsApp</span>
              <input id="mt-phone" name="phone" type="tel" inputmode="tel" autocomplete="tel" required aria-required="true"
                aria-describedby="mt-phone-err" placeholder="06 XX XX XX XX" class={`${inputClass} mt-1`} />
              <span id="mt-phone-err" hidden role="alert" class="mt-1 block text-xs text-alert-300"></span>
            </label>
          </div>

          <label class="block text-sm text-lune-soft">
            <span data-i18n data-fr="Adresse / ville" data-ar="العنوان / المدينة">Adresse / ville</span>
            <input id="mt-city" name="city" type="text" autocomplete="address-level2" required aria-required="true"
              aria-describedby="mt-city-err" placeholder="Lue depuis la carte — modifiable si besoin" class={`${inputClass} mt-1`} />
            <span id="mt-city-err" hidden role="alert" class="mt-1 block text-xs text-alert-300"></span>
          </label>

          <!-- WJ3 — e-mail (facultatif) + opt-in WhatsApp -->
          <label class="block text-sm text-lune-soft">
            <span data-i18n data-fr="E-mail (facultatif)" data-ar="البريد الإلكتروني (اختياري)">E-mail (facultatif)</span>
            <input id="mt-email" name="email" type="email" inputmode="email" autocomplete="email"
              placeholder="vous@exemple.com" class={`${inputClass} mt-1`} />
          </label>

          <!-- WJ51 — préférence de contact EXPLICITE (remplace la case unique
               « je préfère WhatsApp ») : un choix nommé, jamais une case cochée
               par défaut sans qu'on la voie. Forwardé en `contactPreference`
               (facultatif) + dérive `whatsappOptIn` pour garder le contrat webhook
