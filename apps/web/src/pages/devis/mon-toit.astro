---
/**
 * « Mon toit » — CAPTURE CLIENT (PUBLIC, INDEXABLE depuis W245). Élevée WJ1-WJ8.
 *
 * Parcours mobile-first en assistant (WJ6) : Votre toit → Votre facture → Votre
 * estimation. La carte/le repère sont FACULTATIFS (WJ4) : on peut soumettre avec
 * l'adresse seule si la carte est indisponible. À l'étape estimation, une
 * FOURCHETTE instantanée (kWc, ≈MAD/mois économisés, amortissement) est calculée
 * par le VRAI moteur (billEstimate → estimatorBrain) AVANT la porte de contact
 * (WJ1). La capture est WhatsApp-first (WJ3) : CTA « Recevoir mon estimation sur
 * WhatsApp » prérempli + e-mail/opt-in transmis au webhook. Le seuil 1 000 MAD est
 * préservé et HONNÊTE (WJ5) : sous le seuil, on n'affiche pas un faux
 * « enregistré » mais un message adapté. Récupération d'abandon (WJ7) + bandeau de
 * confiance (WJ8). Microcopie FR + AR (WJ6).
 *
 * Le contrat de soumission /api/capture-lead est INCHANGÉ (validateLead, seuil,
 * consentement/UTM/fbclid, roofPoint/roofOutline/profil énergétique facultatifs).
 * L'outil 3D est booté en captureOnly : aucun panneau ne s'affiche ici.
 *
 * W245 — la page était noindex depuis sa création ("tunnel privé"), alors
 * qu'elle est devenue le CTA principal du site. Retrait du noindex + hreflang
 * (déjà déclarée dans STATIC_TRANSLATED) + meta description vendant
 * l'estimation instantanée + OG dédié.
 */
import Layout from '../../layouts/Layout.astro';
import { BILL_RANGES } from '../../lib/billRange';
import { ROOF_TYPES } from '../../lib/lead';
import { NAP, WHATSAPP_LEADS } from '../../lib/nap';
import { whatsappLink } from '../../lib/whatsapp';
import StarRating from '../../components/StarRating.astro';
import CertLogoRow from '../../components/CertLogoRow.astro';
import InstallCounter from '../../components/InstallCounter.astro';
import ZelligeSignature from '../../components/ZelligeSignature.astro';

const inputClass =
  'w-full border border-white/15 bg-white/5 px-3 py-3 text-base text-white placeholder:text-lune-faint outline-none transition-colors focus:border-brass-400 focus:ring-2 focus:ring-brass-400/30 aria-[invalid=true]:border-alert-300 aria-[invalid=true]:ring-2 aria-[invalid=true]:ring-alert-300/30';
const roofTypes = ROOF_TYPES;
const billRanges = BILL_RANGES;
// WJ48 — libellés AR des cartes « type de toit » (mêmes id que ROOF_TYPES,
// lib/lead.ts hors périmètre) — même paire FR/AR que le reste du data-i18n.
const ROOF_TYPE_LABEL_AR_INLINE: Record<string, string> = {
  villa: 'فيلا',
  hangar: 'مستودع صناعي',
  toit_plat: 'سطح مسطح',
  autre: 'أخرى',
};
// WJ65 — sortie honnête sans JavaScript : ce formulaire dépend entièrement du
// script (calcul d'estimation, soumission fetch) — sans JS, rien ne fonctionne.
// Plutôt qu'une page muette, un lien wa.me + tel: statique (aucun JS requis).
const noscriptWaHref = whatsappLink(
  WHATSAPP_LEADS,
  "Bonjour, je souhaite recevoir mon estimation solaire de taqinor.ma (mon navigateur n'active pas JavaScript).",
);
const noscriptTelHref = `tel:${NAP.phone}`;

// WJ6 — étapes de l'assistant (libellés FR + AR). data-i18n pour bascule de langue.
const STEPS = [
  { fr: 'Votre toit', ar: 'سطحك' },
  { fr: 'Votre facture', ar: 'فاتورتك' },
  { fr: 'Votre estimation', ar: 'تقديرك' },
];

// WJ6 — sélecteur de mode (résidentiel / professionnel / agricole), FR + AR.
const MODES = [
  { id: 'residentiel', fr: 'Résidentiel', ar: 'سكني', desc_fr: 'Villa, appartement', desc_ar: 'فيلا، شقة' },
  { id: 'professionnel', fr: 'Professionnel', ar: 'مهني', desc_fr: 'Industrie, commerce', desc_ar: 'صناعة، تجارة' },
  { id: 'agricole', fr: 'Agricole', ar: 'فلاحي', desc_fr: 'Pompage, ferme', desc_ar: 'ضخ، مزرعة' },
];

// WJ8 — villes desservies (réelles, NAP) pour la preuve de proximité.
const TOWNS = ['Casablanca', 'Rabat', 'Marrakech', 'Tanger', 'Agadir', 'Kénitra', 'Fès', 'Settat'];
---

<Layout
  title="Estimation solaire instantanée — Mon toit | Taqinor"
  description="Estimation instantanée + design 3D de votre toit + signature en ligne : indiquez votre adresse et votre facture, recevez votre puissance, vos économies et votre amortissement en quelques secondes, gratuitement."
  ogSlug="accueil"
  locales={['fr', 'en', 'ar']}
>
  <!-- W320 — préconnexion à l'origine carte (MapTiler style JSON + tuiles
       raster Mapbox/Maxar quand configuré) : le moment le plus interactif de
       cette page (poser un repère sur son toit) payait jusqu'ici une
       poignée de main DNS+TLS série (~100–300 ms sur connexion froide).
       Layout.astro n'expose pas de slot <head> (hors périmètre ici) : ces
       hints sont honorés par le navigateur dès qu'ils sont analysés, où
       qu'ils apparaissent dans le document — sans dépendre du <head>. Coût
       nul si la carte n'est jamais bootée (repli sans clé/adresse). -->
  <link rel="preconnect" href="https://api.maptiler.com" crossorigin />
  <link rel="preconnect" href="https://api.mapbox.com" crossorigin />
  <section class="bg-nuit px-4 py-8 sm:py-12">
    <!-- WJ98 — au-delà de `lg` (≥1024 px), le formulaire restait figé à
         `max-w-2xl` (672 px) : sur un écran de bureau, l'assistant flottait
         dans une colonne étroite avec un vide énorme des deux côtés — aucune
         mise en page « desktop » réelle. On élargit à `lg:max-w-4xl` (896 px)
         UNIQUEMENT à partir de `lg` (le mobile/tablette garde `max-w-2xl`,
         inchangé) ; la largeur récupérée profite directement à la carte
         (hauteur augmentée ci-dessous) et aux formulaires en grille. -->
    <div class="mx-auto max-w-2xl lg:max-w-4xl">
      <!-- WJ65 — sortie honnête SANS JavaScript : cette page est entièrement
           pilotée par script (carte, calcul, envoi) — sans JS elle resterait
           muette. On propose ici même une sortie qui ne demande AUCUN JS. -->
      <noscript>
        <div class="cine-card mb-6 border border-brass-400/40 p-5 text-sm text-white">
          <p class="font-semibold">Cette page nécessite JavaScript pour calculer votre estimation.</p>
          <p class="mt-1 text-lune-soft">
            Pas de souci : contactez-nous directement, gratuitement et sans engagement.
          </p>
          <div class="mt-4 flex flex-col gap-2 sm:flex-row">
            <a href={noscriptWaHref} target="_blank" rel="noopener"
              class="inline-flex flex-1 items-center justify-center gap-2 bg-ok-600 px-5 py-3 text-base font-bold text-white transition-opacity hover:opacity-90">
              Écrire sur WhatsApp
            </a>
            <a href={noscriptTelHref}
              class="inline-flex flex-1 items-center justify-center gap-2 border border-white/25 px-5 py-3 text-base font-bold text-white transition-colors hover:border-brass-400 hover:text-brass-300">
              Appeler {NAP.phoneDisplayIntl}
            </a>
          </div>
        </div>
      </noscript>

      <!-- WJ45 — bandeau hors-ligne (navigator.onLine + écouteurs online/offline) :
           les réseaux mobiles marocains coupent souvent en cours de parcours ;
           plutôt qu'un échec silencieux après un délai d'attente, on prévient
           explicitement ET on rassure que rien n'est perdu (le formulaire reste
           rempli, l'instantané sessionStorage WJ61 persiste). -->
      <div id="mt-offline-banner" hidden role="status" aria-live="polite"
        class="mb-4 flex items-start gap-2 border border-brass-400/40 bg-brass-400/10 p-3 text-sm text-white">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="mt-0.5 flex-none text-brass-300">
          <line x1="1" y1="1" x2="23" y2="23"/><path d="M16.72 11.06A10.94 10.94 0 0 1 19 12.55"/><path d="M5 12.55a10.94 10.94 0 0 1 5.17-2.39"/><path d="M10.71 5.05A16 16 0 0 1 22.58 9"/><path d="M1.42 9a15.91 15.91 0 0 1 4.7-2.88"/><path d="M8.53 16.11a6 6 0 0 1 6.95 0"/><line x1="12" y1="20" x2="12.01" y2="20"/>
        </svg>
        <span data-i18n
          data-fr="Pas de connexion — vos réponses sont conservées, on réessaie dès le retour du réseau."
          data-ar="لا يوجد اتصال — إجاباتكم محفوظة، سنعيد المحاولة فور عودة الشبكة.">
          Pas de connexion — vos réponses sont conservées, on réessaie dès le retour du réseau.
        </span>
      </div>

      <!-- WJ106 — la bascule de langue FR/AR EN PLACE (boutons FR/عربي, WJ6)
           est retirée : `/ar/devis/mon-toit` est désormais la route arabe
           CANONIQUE (dédiée, indexable séparément), rendant ce toggle en
           place redondant — un visiteur arabophone arrive directement sur la
           bonne route plutôt que de re-basculer une page FR en place. La
           plomberie `data-i18n`/`applyLang` sous-jacente reste EN PLACE
           (retrait complet hors périmètre, risque de régression élevé sur un
           mécanisme qui couvre 140+ nœuds) — cette page reste donc figée en
           français, comme le contenu affiché par défaut avant tout clic sur
           l'ancien bouton. -->
      <div class="flex items-start justify-between gap-3">
        <div>
          <p class="tech-label rule-brass text-brass-300" data-i18n data-fr="Estimation solaire · gratuit · sans engagement" data-ar="تقدير شمسي · مجاني · بدون التزام">
            Estimation solaire · gratuit · sans engagement
          </p>
          <h1 class="display mt-4 text-2xl text-white sm:text-3xl" data-i18n data-fr="Recevez votre estimation solaire" data-ar="استلم تقديرك الشمسي">
            Recevez votre estimation solaire
          </h1>
        </div>
      </div>

      <!-- WJ6/WJ58 — microcopie « pas de pression » + promesse de délai honnête
           (WG9 résolu par le fondateur, 2026-07-03 : « sous 1 h, 7j/7 »). -->
      <p class="mt-3 text-sm text-lune-soft" data-i18n
        data-fr="Réponse WhatsApp sous 1 h, 7j/7 · pas d'appels commerciaux."
        data-ar="رد واتساب خلال ساعة واحدة، 7 أيام على 7 · بدون مكالمات تجارية.">
        Réponse WhatsApp sous 1 h, 7j/7 · pas d'appels commerciaux.
      </p>

      <!-- WJ6 — barre de progression étiquetée -->
      <ol id="mt-progress" class="mt-6 grid grid-cols-3 gap-2" aria-label="Progression">
        {STEPS.map((s, i) => (
          <li class="mt-step flex flex-col gap-1.5" data-step={i}>
            <span class="h-1.5 w-full rounded-full bg-white/10 mt-step-bar transition-colors"></span>
            <span class="text-xs text-lune-faint mt-step-label" data-i18n data-fr={s.fr} data-ar={s.ar}>{s.fr}</span>
          </li>
        ))}
      </ol>

      <!-- ============ ÉTAPE 0/1 — VOTRE TOIT (mode + carte/repère) ============ -->
      <div id="mt-panel-0" class="mt-step-panel">
        <!-- WJ88 — landmark h2 réel par étape (repère de navigation pour lecteur
             d'écran) : visuellement masqué (sr-only), la barre de progression
             visible reste la même — mais la page a désormais un vrai plan de
             titres au lieu d'un unique <h1> sur 1 200 lignes. -->
        <h2 class="sr-only" data-i18n data-fr={STEPS[0].fr} data-ar={STEPS[0].ar}>{STEPS[0].fr}</h2>
        <!-- WJ6 — sélecteur de mode -->
        <fieldset class="mt-6">
          <legend class="text-sm text-lune-soft" data-i18n data-fr="Votre type de projet" data-ar="نوع مشروعك">Votre type de projet</legend>
          <!-- WJ65 — sur les tout petits écrans (≲360 px), 3 colonnes serrent trop
               le texte (troncature/chevauchement) : on empile en 1 colonne, puis
               3 dès `sm:` (640 px), cohérent avec le reste de la page. -->
          <div class="mt-3 grid grid-cols-1 gap-2 sm:grid-cols-3">
            {MODES.map((m, i) => (
              <button type="button" class="mt-mode cine-card flex flex-col items-start gap-0.5 border p-3 text-left transition-colors"
                data-mode={m.id} aria-pressed={i === 0 ? 'true' : 'false'}>
                <span class="text-sm font-semibold text-white" data-i18n data-fr={m.fr} data-ar={m.ar}>{m.fr}</span>
                <span class="text-xs text-lune-faint" data-i18n data-fr={m.desc_fr} data-ar={m.desc_ar}>{m.desc_fr}</span>
              </button>
            ))}
          </div>
        </fieldset>

        <!-- WJ68 — mode PROFESSIONNEL : signaux C&I FACULTATIFS, additifs au
             webhook (raisonSociale/facilityType/siteCount — lib/lead.ts). Masqué
             tant que le mode « Professionnel » n'est pas sélectionné (le visiteur
             résidentiel/agricole ne voit jamais ces champs). Aucun de ces champs
             n'est requis — l'assistant reste franchissable sans eux. -->
        <div id="mt-pro-fields" hidden class="cine-card mt-4 space-y-4 p-5 sm:p-6">
          <p class="text-sm font-semibold text-brass-300" data-i18n
            data-fr="Votre entreprise (facultatif)" data-ar="شركتكم (اختياري)">
            Votre entreprise (facultatif)
          </p>
          <label class="block text-sm text-lune-soft">
            <span data-i18n data-fr="Raison sociale" data-ar="التسمية الاجتماعية">Raison sociale</span>
            <input id="mt-raison-sociale" name="raisonSociale" type="text" autocomplete="organization"
              placeholder="Ex. Riad Solaire SARL" class={`${inputClass} mt-1`} />
          </label>
          <div class="grid gap-4 sm:grid-cols-2">
            <label class="block text-sm text-lune-soft">
              <span data-i18n data-fr="Type de site" data-ar="نوع الموقع">Type de site</span>
              <select id="mt-facility-type" name="facilityType" class={`${inputClass} mt-1`}>
                <option value="">Choisir…</option>
                <option value="bureau" data-i18n data-fr="Bureau" data-ar="مكتب">Bureau</option>
                <option value="entrepot" data-i18n data-fr="Entrepôt" data-ar="مستودع">Entrepôt</option>
                <option value="usine" data-i18n data-fr="Usine" data-ar="مصنع">Usine</option>
                <option value="commerce" data-i18n data-fr="Commerce / hôtellerie" data-ar="تجارة / فندقة">Commerce / hôtellerie</option>
                <option value="agricole" data-i18n data-fr="Agricole" data-ar="فلاحي">Agricole</option>
                <option value="autre" data-i18n data-fr="Autre" data-ar="أخرى">Autre</option>
              </select>
            </label>
            <label class="block text-sm text-lune-soft">
              <span data-i18n data-fr="Combien de sites ?" data-ar="كم عدد المواقع؟">Combien de sites&nbsp;?</span>
              <select id="mt-site-count" name="siteCount" class={`${inputClass} mt-1`}>
                <option value="">Choisir…</option>
                <option value="1">1</option>
                <option value="2-5">2–5</option>
                <option value="6+">6+</option>
              </select>
            </label>
          </div>
        </div>

        <p class="mt-5 text-lune-soft" data-i18n
          data-fr="Cherchez votre adresse et posez un repère sur votre toit. C'est facultatif — vous pouvez aussi continuer avec votre adresse seule."
          data-ar="ابحث عن عنوانك وضع علامة على سطحك. هذا اختياري — يمكنك أيضاً المتابعة بعنوانك فقط.">
          Cherchez votre adresse et posez un repère sur votre toit. C'est facultatif —
          vous pouvez aussi continuer avec votre adresse seule.
        </p>

        <!-- Repli sans JavaScript / sans clé carte (WJ4) : on demande l'adresse en clair
             et on AUTORISE la suite (plus de cul-de-sac sur le repère). -->
        <div id="mt-fallback" hidden class="cine-card mt-5 border-l-4 border-alert-300 p-5">
          <p class="font-semibold text-white" data-i18n data-fr="Carte momentanément indisponible" data-ar="الخريطة غير متوفرة مؤقتاً">Carte momentanément indisponible</p>
          <p class="mt-2 text-sm text-lune-soft" data-i18n
            data-fr="Pas de souci : indiquez votre adresse complète ci-dessous et continuez. Nous localiserons votre toit pour vous."
            data-ar="لا مشكلة: أدخل عنوانك الكامل أدناه وتابع. سنحدد موقع سطحك من أجلك.">
            Pas de souci : indiquez votre adresse complète ci-dessous et continuez. Nous
            localiserons votre toit pour vous.
          </p>
          <label class="mt-3 block text-sm text-lune-soft">
            <span data-i18n data-fr="Adresse complète" data-ar="العنوان الكامل">Adresse complète</span>
            <input id="mt-fallback-address" type="text" autocomplete="street-address"
              placeholder="Ex. Lot. Al Wifaq, Hay Riad, Rabat" class={`${inputClass} mt-1`} />
          </label>
        </div>

        <!-- CARTE — recherche d'adresse + repère (ids rp9-* câblés par captureBoot). -->
        <div id="mt-stage" class="cine-card mt-5 overflow-hidden">
          <form id="rp9-search" class="flex flex-col gap-3 border-b border-white/10 p-4 sm:flex-row">
            <label for="rp9-address" class="sr-only">Votre adresse</label>
            <div class="relative flex-1">
              <input id="rp9-address" name="address" type="text" autocomplete="off"
                role="combobox" aria-autocomplete="list" aria-expanded="false"
                aria-controls="rp9-suggestions" aria-haspopup="listbox"
                placeholder="Adresse, quartier ou ville (ex. Casablanca, Maârif)" class={inputClass} />
              <ul id="rp9-suggestions" role="listbox" aria-label="Suggestions d'adresses" hidden
                class="absolute left-0 right-0 top-full z-20 mt-1 max-h-72 overflow-auto border border-white/15 bg-nuit-900 shadow-xl">
              </ul>
            </div>
            <button type="submit"
              class="flex-none bg-brass-400 px-6 py-3 text-base font-bold text-azur-950 transition-colors hover:bg-brass-300">
              Localiser
            </button>
          </form>

          <!-- WJ88 — role="application" retiré : ce rôle ARIA place tout le
               sous-arbre en mode « application » pour un lecteur d'écran (les
               flèches/tab natifs sont désactivés), ce qui rend la carte
               clavier-inerte alors qu'elle n'expose ici aucune interaction
               clavier propre (le pin/tracé est à la souris/au tactile ; la
               recherche d'adresse au-dessus reste un vrai formulaire
               accessible). aria-label seul suffit à la nommer. -->
          <!-- WJ98 — la bande `44dvh` était un compromis TÉLÉPHONE (garder la
               recherche + les boutons visibles sans défiler) ; sur un viewport
               desktop `lg:`, la même hauteur relative laisse une carte trop
               courte pour tracer un contour de toit confortablement. `lg:h-[62vh]`
               (plafonné à 640 px) donne une zone de travail nettement plus
               généreuse dès que l'écran a la place, sans toucher au comportement
               téléphone/tablette (`h-[44dvh]` inchangé en dessous de `lg`). -->
          <div id="rp9-map" class="mt-skeleton-shimmer mt-0 h-[44dvh] min-h-[280px] w-full bg-nuit-700 lg:h-[62vh] lg:max-h-[640px]"
            aria-label="Carte satellite pour repérer votre toit"></div>

          <div class="flex flex-wrap items-center gap-3 border-t border-white/10 p-4">
            <button type="button" id="rp9-finish" disabled
              class="border border-white/25 px-4 py-2.5 text-sm font-semibold text-white transition-colors hover:border-brass-400 hover:text-brass-300 disabled:cursor-not-allowed disabled:opacity-40">
              Terminer le tracé
            </button>
            <button type="button" id="rp9-undo-point" hidden
              class="border border-white/25 px-4 py-2.5 text-sm font-semibold text-lune-soft transition-colors hover:border-brass-400 hover:text-brass-300">
              Annuler le dernier point
            </button>
            <button type="button" id="rp9-clear"
              class="border border-white/25 px-4 py-2.5 text-sm font-semibold text-lune-soft transition-colors hover:border-white/50 hover:text-white">
              Effacer
            </button>
            <p class="ml-auto text-sm text-lune-faint">
              <span>Repère&nbsp;: </span><span id="rp9-area-value" class="text-white">—</span>
            </p>
          </div>
          <p id="rp9-status" class="border-t border-white/10 px-4 py-3 text-sm text-lune-faint" aria-live="polite">
            Cherchez votre adresse, puis posez un repère sur votre toit (facultatif).
          </p>
        </div>

        <div class="mt-5 flex justify-end">
          <button type="button" id="mt-next-0"
            class="inline-flex items-center justify-center gap-2 bg-brass-400 px-6 py-3 text-base font-bold text-azur-950 transition-colors hover:bg-brass-300">
            <span data-i18n data-fr="Continuer" data-ar="متابعة">Continuer</span>
            <!-- WJ89 — chevron SVG auto-retourné en RTL (règle globale.css
                 `[dir="rtl"] button svg[aria-hidden="true"]`), plus jamais un
                 glyphe « → » littéral figé dans le sens LTR. -->
            <svg aria-hidden="true" width="10" height="10" viewBox="0 0 10 10" fill="none">
              <polyline points="3,1 7,5 3,9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </button>
        </div>
      </div>

      <!-- ============ ÉTAPE 2 — VOTRE FACTURE (+ profil énergétique) ============ -->
      <div id="mt-panel-1" class="mt-step-panel" hidden>
        <!-- WJ88 — landmark h2 réel (voir note étape 0). -->
        <h2 class="sr-only" data-i18n data-fr={STEPS[1].fr} data-ar={STEPS[1].ar}>{STEPS[1].fr}</h2>
        <p class="mt-6 text-lune-soft" data-i18n
          data-fr="Indiquez votre facture pour calculer votre estimation. Le montant exact donne le chiffre le plus juste."
          data-ar="أدخل فاتورتك لحساب تقديرك. المبلغ الدقيق يعطي الرقم الأصح.">
          Indiquez votre facture pour calculer votre estimation. Le montant exact donne le
          chiffre le plus juste.
        </p>

        <div class="cine-card mt-5 space-y-4 p-5 sm:p-6">
          <label class="block text-sm text-lune-soft">
            <span data-i18n data-fr="Facture mensuelle exacte (MAD)" data-ar="الفاتورة الشهرية الدقيقة (درهم)">Facture mensuelle exacte (MAD)</span>
            <input id="mt-facture-hiver" name="factureHiver" type="number" step="any" inputmode="decimal"
              aria-describedby="mt-facture-hiver-err" placeholder="Ex. 1 200" class={`${inputClass} mt-1`} />
            <span id="mt-facture-hiver-err" hidden role="alert" class="mt-1 block text-xs text-alert-300"></span>
            <!-- WJ67 — micro-transparence « pourquoi on vous demande ça » : copie
