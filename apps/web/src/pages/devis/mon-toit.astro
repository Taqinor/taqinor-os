  // (autoconsommation C&I) et AGRICOLE (pompage). Le résidentiel reste sur
  // estimateFromBill, inchangé.
  import { estimatePro } from '../../lib/estimatorPro';
  import { estimateAgricole } from '../../lib/estimatorAgricole';
  // QX — dérivation automatique de la tranche depuis le montant exact (fix
  // « tranche redondante ») + libellé pour la ligne de confirmation.
  import { billRangeFromExact, billRangeLabel, type BillRangeId } from '../../lib/billRange';
  import { captureWhatsappText, whatsappLink } from '../../lib/whatsapp';
  import { WHATSAPP_LEADS } from '../../lib/nap';
  import { buildClientRef, validateLead, MAX_BILL_BY_MODE } from '../../lib/lead';
  // QX/Lane C — TYPE seul (effacé au build : Three.js/viewerOnly ne rejoint
  // JAMAIS le bundle initial — WJ18 ; le module réel reste en import() lazy).
  import type { RoofImageSpec } from '../../scripts/roofPro11/viewerOnly';
  // WJ72 — UN SEUL style de nombre kWc, partagé avec la proposition
  // (src/lib/proposition.ts) : virgule décimale, zéros de fin retirés — plus
  // jamais le point brut de `String(est.kwc)`.
  import { formatKwc } from '../../lib/proposition';
  // W342 — « installation la plus proche » : haversine client-side sur le
  // repère GPS posé (aucun appel réseau).
  import { nearestRealisation } from '../../lib/realisations';

  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const $ = (id: string) => document.getElementById(id);
  const fallback = $('mt-fallback');
  const cityEl = $('mt-city') as HTMLInputElement | null;
  const addressEl = $('rp9-address') as HTMLInputElement | null;
  const fallbackAddrEl = $('mt-fallback-address') as HTMLInputElement | null;

  // ——— WJ59 : beacon de funnel étape par étape (privacy-light, aucune PII) ———
  // Jeton anonyme PAR ONGLET (sessionStorage, jamais un identifiant
  // d'appareil/utilisateur) : sert uniquement à dédupliquer/corréler les
  // événements « atteint »/« abandonné » d'UNE MÊME visite, jamais à
  // identifier un visiteur. Voir src/lib/funnelBeacon.ts pour le contrat
  // complet (allowlist stricte de 4 champs, jamais nom/téléphone/e-mail/
  // adresse/GPS/contour).
  const FUNNEL_TOKEN_KEY = 'mt-funnel-token-v1';
  function getFunnelToken(): string {
    try {
      let t = sessionStorage.getItem(FUNNEL_TOKEN_KEY);
      if (!t) {
        t = Math.random().toString(36).slice(2) + Date.now().toString(36);
        sessionStorage.setItem(FUNNEL_TOKEN_KEY, t);
      }
      return t;
    } catch {
      // sessionStorage indisponible : jeton éphémère (une seule requête, pas
      // de corrélation possible) — jamais un blocage de la mesure ni de l'UX.
      return Math.random().toString(36).slice(2);
    }
  }
  const funnelToken = getFunnelToken();
  const funnelStepReached = new Set<string>(); // évite les doublons « reached » sur re-render.
  // WB30 — le consentement (case à cocher) n'existe QUE dans le panneau 2
  // (contact) : tant que le visiteur n'a pas atteint ce panneau, aucun signal
  // comportemental ne doit partir, même anonyme/best-effort. `hasReachedConsentStep`
  // lit la variable `step` (numéro d'étape de l'assistant, déclarée plus bas) —
  // vérifiée à l'APPEL, jamais dans `sendFunnelBeacon` (dont le paramètre `step`
  // masque volontairement cette variable).
  function hasReachedConsentStep(): boolean {
    return step >= 2;
  }
  /** Best-effort, JAMAIS bloquant : sendBeacon survit à la fermeture d'onglet,
   *  avec repli fetch(keepalive) si sendBeacon est indisponible. Aucune PII
   *  possible dans ce corps (4 champs seulement — cf. lib/funnelBeacon.ts).
   *  WB30 : n'émet rien avant que l'étape de consentement (panneau 2) soit
   *  atteinte — voir hasReachedConsentStep, vérifiée par chaque appelant.
   *  WJ104 — `action` élargi à `viewed`/`callback_requested` (delta
   *  d'instrumentation, cf. lib/telemetryEvents.ts toFunnelWire) ; `reached`/
   *  `abandoned` restent inchangés pour tout appelant existant. */
  function sendFunnelBeacon(
    step: 'toit' | 'facture' | 'estimation' | 'contact',
    action: 'reached' | 'abandoned' | 'viewed' | 'callback_requested',
  ) {
    // WJ104 — même discipline de déduplication que « reached » : un événement
    // « atteint une fois » ne doit jamais être renvoyé en boucle (ex. l'estimation
    // qui se recalcule plusieurs fois pendant que le visiteur ajuste sa facture).
    if (action === 'reached' || action === 'viewed' || action === 'callback_requested') {
      const key = `${step}:${action}`;
      if (funnelStepReached.has(key)) return;
      funnelStepReached.add(key);
    }
    try {
      const payload = JSON.stringify({ step, action, sessionToken: funnelToken, path: location.pathname });
      if (navigator.sendBeacon) {
        const blob = new Blob([payload], { type: 'application/json' });
        navigator.sendBeacon('/api/funnel-beacon', blob);
      } else {
        void fetch('/api/funnel-beacon', { method: 'POST', headers: { 'content-type': 'application/json' }, body: payload, keepalive: true }).catch(() => {});
      }
    } catch {
      // Mesure best-effort seulement — ne doit jamais perturber le parcours.
    }
  }

  // ——— état capture (repère / contour) tenu par onCaptureChange ———
  let capturePin: { lat: number; lng: number } | null = null;
  let captureOutline: Array<[number, number]> = [];
  let cityTouched = false;
  cityEl?.addEventListener('input', () => { cityTouched = true; });

  // ——— WJ6/WJ33 : bascule de langue FR/AR (data-i18n) ———
  // WJ30 — la langue active est transmise au webhook (langue_preferee).
  //
  // WJ33 — FIX : `el.textContent = v` APLATISSAIT toute balise imbriquée à
  // l'intérieur d'un élément `data-i18n` (ex. un futur <strong>/<a> perdu au
  // premier passage AR→FR→AR). On bascule désormais par PAIRE DE NŒUDS
  // show/hide : au premier appel, chaque élément `data-i18n` est ENVELOPPÉ de
  // deux <span> — un FR (markup ORIGINAL, capturé une fois via innerHTML avant
  // toute mutation) et un AR (texte simple depuis data-ar, car les libellés AR
  // du DOM sont aujourd'hui du texte brut) — puis on masque/affiche la bonne
  // paire. Aucune balise n'est plus jamais perdue, quel que soit le nombre
  // d'allers-retours FR↔AR.
  let currentLang: 'fr' | 'ar' = 'fr';
  const i18nPairs: Array<{ fr: HTMLElement; ar: HTMLElement }> = [];
  function prepareI18n() {
    document.querySelectorAll<HTMLElement>('[data-i18n]').forEach((el) => {
      const arText = el.dataset.ar;
      if (typeof arText !== 'string') return;
      const frSpan = document.createElement('span');
      // Le markup FR ORIGINAL (pouvant contenir des balises imbriquées) est
      // préservé tel quel — capturé UNE SEULE fois, avant toute mutation.
      frSpan.innerHTML = el.innerHTML;
      const arSpan = document.createElement('span');
      arSpan.textContent = arText;
      arSpan.hidden = true;
      el.textContent = '';
      el.append(frSpan, arSpan);
      i18nPairs.push({ fr: frSpan, ar: arSpan });
    });
  }
  function applyLang(lang: 'fr' | 'ar') {
    const isAr = lang === 'ar';
    currentLang = lang;
    i18nPairs.forEach(({ fr, ar }) => {
      fr.hidden = isAr;
      ar.hidden = !isAr;
    });
    // WJ33 — RTL/langue au niveau DOCUMENT (pas seulement un bloc local) :
    // un lecteur d'écran ou le rendu natif du navigateur doivent voir la vraie
    // langue de la page, pas seulement une classe locale.
    document.documentElement.lang = isAr ? 'ar' : 'fr';
    document.documentElement.dir = isAr ? 'rtl' : 'ltr';
    const root = document.querySelector('section') as HTMLElement | null;
    if (root) {
      root.dir = isAr ? 'rtl' : 'ltr';
      root.style.lineHeight = isAr ? '1.75' : '';
    }
    const frBtn = $('mt-lang-fr');
    const arBtn = $('mt-lang-ar');
    frBtn?.setAttribute('aria-pressed', String(!isAr));
    arBtn?.setAttribute('aria-pressed', String(isAr));
    for (const [btn, on] of [[frBtn, !isAr], [arBtn, isAr]] as const) {
      if (!btn) continue;
      btn.className = on
        ? 'px-3 py-1.5 text-sm font-semibold text-azur-950 bg-brass-400 transition-colors'
        : 'px-3 py-1.5 text-sm font-semibold text-lune-soft transition-colors hover:text-white';
    }
  }
  prepareI18n();
  $('mt-lang-fr')?.addEventListener('click', () => applyLang('fr'));
  $('mt-lang-ar')?.addEventListener('click', () => applyLang('ar'));

  // ——— WJ45 : bandeau hors-ligne (navigator.onLine + online/offline) ———
  // Une coupure réseau mobile ne doit jamais ressembler à un échec muet : le
  // bandeau apparaît/disparaît en direct, indépendamment de toute soumission.
  const offlineBanner = $('mt-offline-banner');
  function syncOfflineBanner() {
    if (offlineBanner) offlineBanner.hidden = navigator.onLine;
  }
  syncOfflineBanner();
  window.addEventListener('online', syncOfflineBanner);
  window.addEventListener('offline', syncOfflineBanner);

  // ——— WJ61 : l'état de l'assistant survit à un rafraîchissement/retour ———
  // Un appel téléphonique ou un balayage arrière accidentel détruisait TOUT ce
  // qui avait été tapé, en silence — l'échec UX le plus coûteux du tunnel. On
  // persiste un instantané minimal (étape/mode/facture/repère-contour/réponses
  // facultatives) dans sessionStorage (par onglet, jamais partagé entre
  // visiteurs) : réhydraté au chargement, effacé au succès. Ne bloque JAMAIS la
  // soumission si sessionStorage est indisponible (navigation privée stricte…).
  const WIZARD_STORAGE_KEY = 'mt-wizard-v1';
  interface WizardSnapshot {
    step?: number;
    mode?: string;
    ombrage?: string;
    visitWindowPart?: string;
    visitWindowWeek?: string;
    futureLoads?: string[];
    // QX — états des groupes de cartes/segments PRO + AGRICOLE (tension,
    // activité, surface, groupe électrogène, source d'eau, irrigation, unités).
    sel?: Record<string, string>;
    capturePin?: { lat: number; lng: number } | null;
    captureOutline?: Array<[number, number]>;
    fields?: Record<string, string>;
    checks?: Record<string, boolean>;
  }
  const PERSISTED_TEXT_FIELDS = [
    'mt-name', 'mt-phone', 'mt-city', 'mt-email', 'mt-facture-hiver', 'mt-facture-ete',
    'mt-bill', 'mt-roof', 'mt-raccordement', 'mt-distributeur', 'mt-bill-kwh', 'mt-roof-age',
    'mt-occupant-type', 'mt-project-timing', 'mt-financing-intent', 'mt-fallback-address',
    'rp9-address',
    // WJ68 — mode professionnel (facultatif, additif).
    'mt-raison-sociale', 'mt-facility-type', 'mt-site-count',
    // QX — sous-panneau PROFESSIONNEL (étape 2).
    'mt-pro-bill', 'mt-puissance-kva', 'mt-surface-m2',
    // QX — sous-panneau AGRICOLE (étape 2).
    'mt-profondeur', 'mt-hmt', 'mt-water-need', 'mt-heures-pompage',
    'mt-culture', 'mt-surface-ha', 'mt-pompe-actuelle', 'mt-pompe-cv', 'mt-fuel-spend',
  ];
  const PERSISTED_CHECK_FIELDS = ['mt-ete-differente', 'mt-contact-whatsapp', 'mt-contact-phone', 'mt-consent', 'mt-battery-interest'];
  let restoring = false; // WJ61 — évite de ré-enregistrer PENDANT la réhydratation elle-même.
  function saveWizardState() {
    if (restoring) return;
    try {
      const fields: Record<string, string> = {};
      for (const id of PERSISTED_TEXT_FIELDS) {
        const v = val(id);
        if (v) fields[id] = v;
      }
      const checks: Record<string, boolean> = {};
      for (const id of PERSISTED_CHECK_FIELDS) {
        const el = $(id) as HTMLInputElement | null;
        if (el) checks[id] = el.checked;
      }
      const snapshot: WizardSnapshot = {
        step, mode, ombrage,
        visitWindowPart, visitWindowWeek,
        futureLoads: Array.from(futureLoads),
        sel: { proUnit, tension, activity, surfaceType, generator, waterSource, irrigation, waterUnit },
        capturePin, captureOutline,
        fields, checks,
      };
      sessionStorage.setItem(WIZARD_STORAGE_KEY, JSON.stringify(snapshot));
    } catch {
      // sessionStorage indisponible (navigation privée stricte, quota…) : la
      // persistance est un CONFORT, jamais un blocage de la saisie/l'envoi.
    }
  }
  function loadWizardState(): WizardSnapshot | null {
    try {
      const raw = sessionStorage.getItem(WIZARD_STORAGE_KEY);
      return raw ? (JSON.parse(raw) as WizardSnapshot) : null;
    } catch {
      return null;
    }
  }
  function clearWizardState() {
    try { sessionStorage.removeItem(WIZARD_STORAGE_KEY); } catch { /* confort seulement */ }
  }
  // WJ61 — garde-fou de sortie : une fois que le visiteur a commencé à saisir
  // quelque chose, un rafraîchissement/fermeture ACCIDENTEL affiche l'invite de
  // confirmation native du navigateur (texte non personnalisable par spec).
  let hasEnteredData = false;
  function markDataEntered() { hasEnteredData = true; }
  window.addEventListener('beforeunload', (e) => {
    if (!hasEnteredData || submitted) return;
    e.preventDefault();
    e.returnValue = '';
  });

  const savedWizard = loadWizardState();

  // ——— WJ6/QX : sélecteur de mode — plus AUCUN défaut silencieux (le profil
  // pilote des questions d'étape 2 entièrement différentes) ; « Continuer »
  // exige un choix explicite (validateStep0, nudge inline sur les cartes). ———
  let mode = savedWizard?.mode || '';
  // QX — libellés du fil d'étapes + habillage du document par profil.
  const STEP_LABELS_BY_MODE: Record<string, [string, string, string]> = {
    residentiel: ['Votre toit', 'Votre facture', 'Votre estimation'],
    professionnel: ['Votre site', 'Votre énergie', 'Votre estimation'],
    agricole: ['Votre terrain', 'Votre pompage', 'Votre estimation'],
  };
  const MODE_LABEL: Record<string, string> = {
    residentiel: 'Résidentiel', professionnel: 'Professionnel', agricole: 'Agricole',
  };
  const MODE_DOC_SUBTITLE: Record<string, string> = {
    residentiel: 'Résidentielle', professionnel: 'Autoconsommation Industrielle', agricole: 'Pompage Agricole',
  };
  /** QX — le fil d'étapes suit le profil. Page FR figée en français (WJ106) :
   *  textContent direct — la paire data-i18n dormante de ces nœuds n'est plus
   *  jamais basculée (aucun bouton de langue sur cette route). */
  function syncStepLabels() {
    const labels = STEP_LABELS_BY_MODE[mode] || STEP_LABELS_BY_MODE.residentiel;
    document.querySelectorAll<HTMLElement>('.mt-step-label').forEach((el, i) => {
      if (labels[i]) el.textContent = labels[i];
    });
    [0, 1, 2].forEach((i) => {
      const h = $(`mt-h2-${i}`);
      if (h && labels[i]) h.textContent = labels[i];
    });
  }
  /** QX — un seul sous-panneau de questions visible à l'étape 2, selon le profil. */
  function syncStep2Panels() {
    const m = mode || 'residentiel';
    const res = $('mt-sub-residentiel');
    const pro = $('mt-sub-professionnel');
    const agri = $('mt-sub-agricole');
    if (res) res.hidden = m !== 'residentiel';
    if (pro) pro.hidden = m !== 'professionnel';
    if (agri) agri.hidden = m !== 'agricole';
  }
  function syncModeCards() {
    document.querySelectorAll<HTMLButtonElement>('.mt-mode').forEach((b) => {
      const on = mode !== '' && b.dataset.mode === mode;
      b.setAttribute('aria-pressed', String(on));
      b.classList.toggle('border-brass-400', on);
      b.classList.toggle('border-white/15', !on);
    });
  }
  document.querySelectorAll<HTMLButtonElement>('.mt-mode').forEach((btn) => {
    btn.addEventListener('click', () => {
      mode = btn.dataset.mode || '';
      syncModeCards();
      const modeErr = $('mt-mode-err');
      if (modeErr) { modeErr.textContent = ''; modeErr.hidden = true; }
      syncStepLabels();
      syncStep2Panels();
      markDataEntered();
      saveWizardState();
      // WJ111 — si l'estimation (étape 3) a déjà été calculée, basculer de/vers
      // agricole doit mettre à jour le document IMMÉDIATEMENT (numérique <->
      // carte qualitative) sans attendre un nouveau clic sur « Voir mon estimation ».
      if (!$('mt-estimate-body')?.hidden || !$('mt-estimate-agricole')?.hidden) computeEstimate();
      else if (docRendered) computeEstimate();
    });
  });
  // état initial : réhydraté depuis l'instantané, sinon AUCUN mode marqué.
  syncModeCards();
  syncStepLabels();
  syncStep2Panels();

  // ——— WJ48 : cartes image « type de toit » — synchronisent le <select>
  // sr-only (mt-roof) qui reste la source de vérité pour val('mt-roof'), la
  // validation (setFieldError) et la persistance WJ61 (déjà câblée sur
  // 'mt-roof' via PERSISTED_TEXT_FIELDS). Un seul choix actif à la fois. ———
  const roofSelect = $('mt-roof') as HTMLSelectElement | null;
  function syncRoofCards() {
    const current = roofSelect?.value || '';
    document.querySelectorAll<HTMLButtonElement>('.mt-roof-card').forEach((b) => {
      const on = b.dataset.roof === current;
      b.setAttribute('aria-pressed', String(on));
      b.classList.toggle('border-brass-400', on);
      b.classList.toggle('border-white/15', !on);
    });
  }
  document.querySelectorAll<HTMLButtonElement>('.mt-roof-card').forEach((btn) => {
    btn.addEventListener('click', () => {
      if (roofSelect) {
        roofSelect.value = btn.dataset.roof || '';
        // WJ4 — miroir la validation inline existante (setFieldError déjà
        // câblée sur mt-roof-err) : un choix visuel efface l'erreur affichée.
        setFieldError('mt-roof', 'mt-roof-err', null);
      }
      syncRoofCards();
      markDataEntered();
      saveWizardState();
    });
  });
  syncRoofCards(); // état initial (réhydraté ou vide).

  // ——— WJ31 : puce à bascule unique (ombrage) — un seul choix actif à la fois ———
  // WJ112 — l'ombrage n'est plus décoratif : il dérate désormais RÉELLEMENT la
  // production/kWc (billEstimate.ts OMBRAGE_DERATE) ; on recalcule donc en
  // direct au clic, exactement comme le mode ou la facture.
  let ombrage = savedWizard?.ombrage || '';
  document.querySelectorAll<HTMLButtonElement>('.mt-ombrage').forEach((btn) => {
    btn.addEventListener('click', () => {
      const same = ombrage === btn.dataset.value;
      ombrage = same ? '' : (btn.dataset.value || '');
      document.querySelectorAll<HTMLButtonElement>('.mt-ombrage').forEach((b) => {
        const on = !same && b === btn;
        b.setAttribute('aria-pressed', String(on));
        b.classList.toggle('border-brass-400', on);
        b.classList.toggle('border-white/15', !on);
      });
      markDataEntered();
      saveWizardState();
      computeEstimate();
    });
  });
  if (ombrage) {
    document.querySelectorAll<HTMLButtonElement>('.mt-ombrage').forEach((b) => {
      const on = b.dataset.value === ombrage;
      b.setAttribute('aria-pressed', String(on));
      b.classList.toggle('border-brass-400', on);
      b.classList.toggle('border-white/15', !on);
    });
  }

  // ——— W353 : créneau de visite technique — deux puces à bascule unique
  // INDÉPENDANTES (moment + semaine), même patron que .mt-ombrage ci-dessus.
  // Préférence STATIQUE et FACULTATIVE : aucun calendrier, aucune réservation
  // confirmée — un humain valide le créneau réel après contact. ———
  let visitWindowPart = savedWizard?.visitWindowPart || '';
  let visitWindowWeek = savedWizard?.visitWindowWeek || '';
  function wireVisitToggle(selector: string, getCurrent: () => string, setCurrent: (v: string) => void) {
    document.querySelectorAll<HTMLButtonElement>(selector).forEach((btn) => {
      btn.addEventListener('click', () => {
        const same = getCurrent() === btn.dataset.value;
        setCurrent(same ? '' : (btn.dataset.value || ''));
        document.querySelectorAll<HTMLButtonElement>(selector).forEach((b) => {
          const on = !same && b === btn;
          b.setAttribute('aria-pressed', String(on));
          b.classList.toggle('border-brass-400', on);
          b.classList.toggle('border-white/15', !on);
        });
        markDataEntered();
        saveWizardState();
      });
    });
    const current = getCurrent();
    if (current) {
      document.querySelectorAll<HTMLButtonElement>(selector).forEach((b) => {
        const on = b.dataset.value === current;
        b.setAttribute('aria-pressed', String(on));
        b.classList.toggle('border-brass-400', on);
        b.classList.toggle('border-white/15', !on);
      });
    }
  }
  wireVisitToggle('.mt-visit-part', () => visitWindowPart, (v) => { visitWindowPart = v; });
  wireVisitToggle('.mt-visit-week', () => visitWindowWeek, (v) => { visitWindowWeek = v; });

  // ——— WJ31 : puces multi-sélection (charges futures) ———
  const futureLoads = new Set<string>(savedWizard?.futureLoads ?? []);
  document.querySelectorAll<HTMLButtonElement>('.mt-future-load').forEach((btn) => {
    const preOn = futureLoads.has(btn.dataset.value || '');
    if (preOn) {
      btn.setAttribute('aria-pressed', 'true');
      btn.classList.add('border-brass-400');
      btn.classList.remove('border-white/15');
    }
    btn.addEventListener('click', () => {
      const v = btn.dataset.value || '';
      const on = !futureLoads.has(v);
      if (on) futureLoads.add(v); else futureLoads.delete(v);
      btn.setAttribute('aria-pressed', String(on));
      btn.classList.toggle('border-brass-400', on);
      btn.classList.toggle('border-white/15', !on);
      markDataEntered();
      saveWizardState();
    });
  });

  // ——— WJ31 : photo compteur/facture — capturée EN LOCAL, JAMAIS uploadée ———
  // Pas d'endpoint d'upload aujourd'hui (cf. PLAN2 QK6 OCR) : on garde un simple
  // signal booléen (hasMeterPhoto) et on encourage l'envoi direct sur WhatsApp.
  // WJ61 — non persisté : un fichier local ne survit pas à sessionStorage (ni ne
  // le devrait — aucune donnée binaire n'est sérialisée ici).
  let hasMeterPhoto = false;
  const meterPhotoInput = $('mt-meter-photo') as HTMLInputElement | null;
  meterPhotoInput?.addEventListener('change', () => {
    hasMeterPhoto = !!(meterPhotoInput.files && meterPhotoInput.files.length > 0);
  });

  // ——— WJ46 : fenêtre de grâce anti-faux-déclenchement de l'exit-intent ———
  // Ouvrir le sélecteur de fichier (photo compteur/facture, capture="environment")
  // fait basculer l'onglet en arrière-plan le temps que l'appareil photo/la
  // galerie s'affiche : le SEUL `visibilitychange→hidden` déclenchait alors
  // l'exit-intent au moment EXACT où le formulaire invite l'utilisateur à
  // prendre une photo. On suspend l'exit-intent pendant que le picker est
  // ouvert : posé au clic/focus sur le champ fichier, levé au retour de focus
  // fenêtre (le picker s'est fermé) — avec un filet de sécurité (timeout) au
  // cas où l'événement de retour de focus n'arrive jamais (repli navigateur).
  let filePickerOpen = false;
  let filePickerGraceTimer: ReturnType<typeof setTimeout> | null = null;
  function openFilePickerGrace() {
    filePickerOpen = true;
    if (filePickerGraceTimer != null) clearTimeout(filePickerGraceTimer);
    // filet de sécurité : 60 s couvre largement une prise de photo, sans
    // bloquer l'exit-intent indéfiniment si le navigateur n'émet jamais de
    // `focus`/`visibilitychange→visible` de retour (cas rare).
    filePickerGraceTimer = setTimeout(() => { filePickerOpen = false; }, 60_000);
  }
  function closeFilePickerGrace() {
    filePickerOpen = false;
    if (filePickerGraceTimer != null) { clearTimeout(filePickerGraceTimer); filePickerGraceTimer = null; }
  }
  meterPhotoInput?.addEventListener('click', openFilePickerGrace);
  meterPhotoInput?.addEventListener('focus', openFilePickerGrace);
  meterPhotoInput?.addEventListener('change', closeFilePickerGrace);
  meterPhotoInput?.addEventListener('cancel', closeFilePickerGrace);
  // Le retour de focus sur la fenêtre est le signal le plus fiable que le
  // picker (caméra/galerie) s'est refermé, qu'un fichier ait été choisi ou non.
  window.addEventListener('focus', closeFilePickerGrace);

  // ——— boot carte (captureOnly). Repli sans clé carte AUTORISE la suite (WJ4) ———
  let started = false;
  const mapEl = $('rp9-map');
  // WJ34 — retire le squelette de chargement dès que la carte annonce son
  // premier rendu (onReady) ou dès qu'on bascule sur le repli sans carte.
  function clearMapSkeleton() { mapEl?.classList.remove('mt-skeleton-shimmer'); }
  async function boot(key: string, mapboxToken: string) {
    if (started) return;
    started = true;
    try {
      // WJ47 — importe roofPro11/captureBoot DIRECTEMENT (pas tout
      // roof-tool-pro11.ts) : le boot complet entraîne scene3d/optimizer/matrix
      // (Three.js + le moteur de calepinage), du code interne à l'outil que
      // cette page publique de capture n'exécute jamais. Ce chunk lazy ne
      // charge plus que MapLibre + le géocodeur + le pin/tracé.
      const { bootCaptureOnly } = await import('../../scripts/roofPro11/captureBoot');
      bootCaptureOnly({
        maptilerKey: key,
        mapboxToken: mapboxToken || undefined,
        reducedMotion,
        onReady: clearMapSkeleton,
        // WJ61 — un repère/contour restauré depuis sessionStorage (rafraîchissement
        // ou retour navigateur en cours de parcours) est semé directement dans la
        // carte au boot, via le même mécanisme que l'hydratation depuis un lead
        // existant (W113) : le visiteur n'a pas à re-pointer son toit.
        hydrate: capturePin
          ? { lead: { roof_point: capturePin, roof_outline: captureOutline.length >= 3 ? captureOutline : null } }
          : undefined,
        onCaptureChange: (s) => {
          capturePin = s.pin;
          captureOutline = s.outline;
          // QX/Lane C — le contour a changé : l'instantané satellite mis en
          // cache ne correspond plus, on le laissera se reconstruire.
          roofImageSpecPromise = null;
          if (cityEl && !cityTouched) {
            const fromMap = (s.address && s.address.trim()) || addressEl?.value.trim() || '';
            if (fromMap) cityEl.value = fromMap;
          }
          // WJ2 — le contour peut arriver/changer APRÈS le calcul d'estimation :
          // on ré-évalue l'éligibilité du bouton « voir les panneaux » à chaque
          // changement de tracé (fonction déclarée plus bas, hissée par `function`).
          updatePanels3dVisibility();
        },
      });
    } catch {
      started = false;
      showFallback();
    }
  }
  // WJ4 — repli carte : on montre le champ d'adresse en clair ET on garde la suite ouverte.
  // QX — et on MASQUE le bloc carte entier (#mt-stage : géocodeur « Localiser »,
  // canevas, boutons de tracé) : sans clé imagerie, ces contrôles sont morts —
  // deux champs d'adresse visibles dont un inerte, c'était de l'UI mensongère.
  function showFallback() {
    if (fallback) fallback.hidden = false;
    const stage = $('mt-stage');
    if (stage) stage.hidden = true;
    clearMapSkeleton();
  }

  // WJ60 — sur 3G lente, un fetch sans délai peut rester en attente indéfiniment
  // (l'UI restait bloquée sur le squelette de la carte). 10 s laisse largement le
  // temps à une connexion lente de répondre tout en bornant l'attente ; l'échec
  // (timeout inclus) tombe dans le repli adresse existant (WJ4), jamais un blocage.
  const FETCH_TIMEOUT_MS = 10_000;
  // W324 — n'engage le fetch /api/roof-config (→ import maplibre-gl, ~200 KB+)
  // QUE lorsque l'étape 0 (carte) est réellement l'étape ACTIVE — jamais au
  // simple chargement de page. Un visiteur qui reprend son parcours à l'étape
  // 1/2 (WJ61 : instantané sessionStorage restauré, ou bouton précédent) ne
  // paie plus jamais ce poids pour une carte qu'il ne verra pas. `mapFetchDone`
  // garde l'appel idempotent (un seul fetch par visite, y compris si l'on
  // revient plusieurs fois à l'étape 0 via Retour/Continuer).
  let mapFetchDone = false;
  function ensureMapBooted() {
    if (mapFetchDone) return;
    mapFetchDone = true;
    (async () => {
      try {
        const res = await fetch('/api/roof-config', { signal: AbortSignal.timeout(FETCH_TIMEOUT_MS) });
        const cfg = (await res.json()) as { available?: boolean; maptilerKey?: string; mapboxToken?: string };
        if (!cfg.available || !cfg.maptilerKey) { showFallback(); return; }
        void boot(cfg.maptilerKey, cfg.mapboxToken || '');
      } catch {
        showFallback();
      }
    })();
  }

  // ——— WJ6 : assistant multi-étapes + barre de progression ———
  // WJ61 — l'étape initiale reprend l'instantané sessionStorage s'il existe
  // (rafraîchissement/retour en cours de parcours), sinon 0 comme avant.
  let step = savedWizard?.step != null ? Math.max(0, Math.min(2, savedWizard.step)) : 0;
  const panels = [0, 1, 2].map((i) => $(`mt-panel-${i}`));
  let firstRender = true;
  function renderStep() {
    panels.forEach((p, i) => { if (p) p.hidden = i !== step; });
    document.querySelectorAll<HTMLElement>('.mt-step').forEach((li, i) => {
      const bar = li.querySelector<HTMLElement>('.mt-step-bar');
      const label = li.querySelector<HTMLElement>('.mt-step-label');
      const active = i <= step;
      if (bar) bar.className = `h-1.5 w-full rounded-full mt-step-bar transition-colors ${active ? 'bg-brass-400' : 'bg-white/10'}`;
      if (label) label.classList.toggle('text-white', i === step);
    });
    // W324 — l'étape carte est ACTIVE : c'est ICI (jamais au simple chargement
    // de page) qu'on engage le fetch de config + l'import lazy de maplibre-gl.
    if (step === 0) ensureMapBooted();
    // WJ59 — « étape atteinte », dédupliquée par sendFunnelBeacon (une seule
    // fois par étape et par visite, y compris après un aller-retour Retour/Continuer).
    // WB30 — pas de beacon avant l'étape de consentement (panneau 2).
    if (hasReachedConsentStep()) sendFunnelBeacon(step === 0 ? 'toit' : step === 1 ? 'facture' : 'estimation', 'reached');
    // WJ61 — au tout premier rendu (chargement/réhydratation), ne pas imposer de
    // défilement : le visiteur vient d'arriver/de revenir, la page n'a pas
    // encore bougé sous lui. Le défilement reste pour chaque étape SUIVANTE.
    if (firstRender) { firstRender = false; return; }
    const root = document.querySelector('section');
    root?.scrollIntoView({ behavior: reducedMotion ? 'auto' : 'smooth', block: 'start' });
  }
  // WJ61 — pushState PAR ÉTAPE : le bouton précédent du navigateur recule d'une
  // étape de l'assistant au lieu de quitter carrément la page (l'échec le plus
  // fréquent d'un « retour » accidentel). `fromPopstate` évite de repousser un
  // état pendant qu'on réagit déjà à un `popstate`.
  function goStep(n: number, fromPopstate = false) {
    step = Math.max(0, Math.min(2, n));
    renderStep();
    saveWizardState();
    if (!fromPopstate) {
      history.pushState({ mtStep: step }, '', location.href);
    }
  }
  window.addEventListener('popstate', (e) => {
    const st = (e.state as { mtStep?: number } | null)?.mtStep;
    goStep(st != null ? st : Math.max(0, step - 1), true);
  });
  // QX — l'étape carte exige un PROFIL choisi (nudge inline sur les cartes,
  // jamais une alerte) : le profil pilote tout le questionnaire d'étape 2.
  $('mt-next-0')?.addEventListener('click', () => {
    if (validateStep0()) goStep(1);
  });
  $('mt-back-1')?.addEventListener('click', () => goStep(0));
  $('mt-back-2')?.addEventListener('click', () => goStep(1));
  // WJ61 — pose une première entrée d'historique dès le chargement pour que le
  // tout premier « retour » ait un état `mtStep` à consulter.
  history.replaceState({ mtStep: step }, '', location.href);
  renderStep();
  // WJ96(c) — un visiteur qui REPREND son parcours (instantané sessionStorage
  // WJ61) directement à l'étape 1/2 ne déclenche PAS `ensureMapBooted()` via
  // `renderStep()` (qui ne boote qu'à `step === 0`) : cliquer « Retour » vers
  // l'étape carte affichait alors le squelette de chargement à chaque fois,
  // au lieu d'une carte déjà prête. On préchauffe la config/carte en arrière-
  // plan dès que l'on sait que ce visiteur a déjà une étape restaurée > 0 —
  // sans jamais bloquer le rendu de l'étape actuelle (best-effort, idempotent
  // via `mapFetchDone`).
  if (savedWizard?.step != null && savedWizard.step > 0) ensureMapBooted();

  // ——— helpers de saisie ———
  const val = (id: string) => (($(id) as HTMLInputElement | HTMLSelectElement | null)?.value ?? '');
  const num = (id: string): number | null => {
    const raw = val(id).trim();
    if (raw === '') return null;
    const n = Number(raw);
    return Number.isFinite(n) ? n : null;
  };

  // toggle été ≠ hiver
  const eteToggle = $('mt-ete-differente') as HTMLInputElement | null;
  const eteWrap = $('mt-facture-ete-wrap') as HTMLElement | null;
  const eteInput = $('mt-facture-ete') as HTMLInputElement | null;
  eteToggle?.addEventListener('change', () => {
    const on = eteToggle.checked === true;
    if (eteWrap) eteWrap.hidden = !on;
    if (!on && eteInput) eteInput.value = '';
  });

  // WJ105 — SLA de rappel concret : visible UNIQUEMENT quand « Un conseiller
  // peut m'appeler » est la préférence active. `sync` est ré-appelée après une
  // éventuelle réhydratation (WJ61, plus bas) : affecter `.checked` par script
  // ne déclenche pas l'événement `change` natif.
  const contactPhoneRadio = $('mt-contact-phone') as HTMLInputElement | null;
  const contactWhatsappRadio = $('mt-contact-whatsapp') as HTMLInputElement | null;
  const callbackSla = $('mt-callback-sla') as HTMLElement | null;
  function syncCallbackSla(): void {
    if (callbackSla) callbackSla.hidden = contactPhoneRadio?.checked !== true;
  }
  contactPhoneRadio?.addEventListener('change', syncCallbackSla);
  contactWhatsappRadio?.addEventListener('change', syncCallbackSla);
  syncCallbackSla();

  // WJ61 — réhydratation des champs de saisie + du repère/contour de carte à
  // partir de l'instantané (AVANT le boot de la carte : `hydrate` plus bas sème
  // le pin/contour directement dans captureBoot, sans attendre un premier
  // clic). `restoring` empêche saveWizardState() de s'auto-déclencher pendant
  // qu'on peuple les champs (les événements `input`/`change` natifs se
  // déclenchent en JS lors d'une affectation `.value`/`.checked`).
  if (savedWizard) {
    restoring = true;
    for (const [id, v] of Object.entries(savedWizard.fields ?? {})) {
      const el = $(id) as HTMLInputElement | HTMLSelectElement | null;
      if (el) el.value = v;
    }
    for (const [id, v] of Object.entries(savedWizard.checks ?? {})) {
      const el = $(id) as HTMLInputElement | null;
      if (el) el.checked = v;
    }
    // WJ61 — une ville restaurée compte comme « déjà touchée » : affecter
    // `.value` par script ne déclenche pas l'événement `input` natif qui pose
    // normalement `cityTouched`, et sans ce garde-fou le prochain repère posé
    // sur la carte écraserait silencieusement la ville qu'on vient de restaurer.
    if (savedWizard.fields?.['mt-city']) cityTouched = true;
    if (eteToggle?.checked && eteWrap) eteWrap.hidden = false;
    // WJ105 — une préférence de contact restaurée doit re-synchroniser la
    // visibilité de la SLA de rappel (affecter `.checked` par script ne
    // déclenche pas `change`).
    syncCallbackSla();
    if (savedWizard.capturePin) capturePin = savedWizard.capturePin;
    if (savedWizard.captureOutline?.length) captureOutline = savedWizard.captureOutline;
    if (Object.keys(savedWizard.fields ?? {}).length > 0 || savedWizard.capturePin) markDataEntered();
    restoring = false;
  }
  // WJ61 — persiste sur toute frappe/changement des champs texte/select/case à
  // cocher restants (au-delà des puces déjà câblées plus haut).
  const PERSIST_ON_INPUT_IDS = [...PERSISTED_TEXT_FIELDS, ...PERSISTED_CHECK_FIELDS];
  for (const id of PERSIST_ON_INPUT_IDS) {
    const el = $(id);
    el?.addEventListener('input', () => { markDataEntered(); saveWizardState(); });
    el?.addEventListener('change', () => { markDataEntered(); saveWizardState(); });
  }

  // ——— QX : groupes de cartes/segments à sélection unique des sous-panneaux
  // PRO et AGRICOLE (même patron visuel/ARIA que .mt-ombrage). `recompute`
  // relance l'estimation en direct quand le choix pilote un chiffre affiché.
  // BT + « Journée » sont présélectionnés : des défauts VISIBLES à l'écran
  // (jamais une hypothèse cachée), modifiables d'un tap. ———
  const savedSel = savedWizard?.sel ?? {};
  let proUnit = savedSel.proUnit || 'mad';
  let tension = savedSel.tension || 'bt';
  let activity = savedSel.activity || 'day';
  let surfaceType = savedSel.surfaceType || '';
  let generator = savedSel.generator || '';
  let waterSource = savedSel.waterSource || '';
  let irrigation = savedSel.irrigation || '';
  let waterUnit = savedSel.waterUnit || 'm3h';
  function wireCardGroup(
    selector: string,
    getCurrent: () => string,
    setCurrent: (v: string) => void,
    opts: { allowUnset?: boolean; recompute?: boolean; onChange?: () => void } = {},
  ) {
    const paint = () => {
      const current = getCurrent();
      document.querySelectorAll<HTMLButtonElement>(selector).forEach((b) => {
        const on = current !== '' && b.dataset.value === current;
        b.setAttribute('aria-pressed', String(on));
        b.classList.toggle('border-brass-400', on);
        b.classList.toggle('border-white/15', !on);
      });
    };
    document.querySelectorAll<HTMLButtonElement>(selector).forEach((btn) => {
      btn.addEventListener('click', () => {
        const same = getCurrent() === btn.dataset.value;
        setCurrent(same && opts.allowUnset ? '' : (btn.dataset.value || ''));
        paint();
        opts.onChange?.();
        markDataEntered();
        saveWizardState();
        if (opts.recompute) computeEstimate();
      });
    });
    paint();
  }
  // PRO — le champ kVA n'apparaît qu'en moyenne tension.
  function syncKvaVisibility() {
    const wrap = $('mt-puissance-kva-wrap');
    if (wrap) wrap.hidden = tension !== 'mt';
  }
  wireCardGroup('.mt-pro-unit', () => proUnit, (v) => { proUnit = v || 'mad'; }, { recompute: true });
  wireCardGroup('.mt-tension', () => tension, (v) => { tension = v || 'bt'; }, { recompute: true, onChange: syncKvaVisibility });
  wireCardGroup('.mt-activity', () => activity, (v) => { activity = v || 'day'; }, { recompute: true });
  wireCardGroup('.mt-surface-type', () => surfaceType, (v) => { surfaceType = v; }, { allowUnset: true, recompute: true });
  wireCardGroup('.mt-generator', () => generator, (v) => { generator = v; }, { allowUnset: true });
  syncKvaVisibility();
  // AGRICOLE — la source d'eau pilote le type de pompe (immergée/surface).
  wireCardGroup('.mt-water-source', () => waterSource, (v) => { waterSource = v; }, { allowUnset: true, recompute: true });
  wireCardGroup('.mt-irrigation', () => irrigation, (v) => { irrigation = v; }, { allowUnset: true });
  wireCardGroup('.mt-water-unit', () => waterUnit, (v) => { waterUnit = v || 'm3h'; }, { recompute: true });
  // Curseur « heures de pompage / jour » — valeur affichée en direct.
  const heuresInput = $('mt-heures-pompage') as HTMLInputElement | null;
  function syncHeuresLabel() {
    const out = $('mt-heures-pompage-value');
    if (out && heuresInput) out.textContent = `${heuresInput.value} h`;
  }
  heuresInput?.addEventListener('input', () => {
    syncHeuresLabel();
    computeEstimate();
  });
  syncHeuresLabel();
  // Recalcul en direct sur chaque champ numérique qui pilote un chiffre affiché
  // (même patron que mt-facture-hiver / mt-bill-kwh côté résidentiel).
  for (const id of ['mt-pro-bill', 'mt-puissance-kva', 'mt-surface-m2', 'mt-profondeur', 'mt-hmt', 'mt-water-need', 'mt-fuel-spend']) {
    $(id)?.addEventListener('input', computeEstimate);
  }

  // ——— WJ1 : résoudre la facture mensuelle (montant exact prioritaire, sinon tranche) ———
  /** Milieu indicatif d'une tranche (MAD) — uniquement pour ESTIMER quand le montant
   *  exact est absent ; ne sert jamais au seuil (le seuil reste sur billRange/qualifies). */
  const RANGE_MIDPOINT: Record<string, number> = {
    'lt800': 600, '800-1000': 900, '1000-1500': 1250, '1500-3000': 2250,
    '3000-5000': 4000, '5000-10000': 7500, 'gt10000': 12000,
  };
  // WJ65/QX — plafond de bon sens PAR PROFIL (MAX_BILL_BY_MODE, lib/lead.ts) :
  // au-delà, une faute de frappe produirait un chiffre affirmé avec assurance —
  // on demande de vérifier (résidentiel) ou on route vers l'étude dédiée (pro).
  // Ne s'applique qu'au montant EXACT saisi, jamais aux tranches.
  function maxBillFor(m: string): number {
    return MAX_BILL_BY_MODE[m as keyof typeof MAX_BILL_BY_MODE] ?? 200_000;
  }
  function resolveMonthlyBill(): number | null {
    const exact = num('mt-facture-hiver');
    if (exact != null && exact > 0) return exact;
    const range = val('mt-bill');
    if (range && RANGE_MIDPOINT[range] != null) return RANGE_MIDPOINT[range];
    return null;
  }

  // ——— QX : FIX « tranche redondante » (résidentiel) — un montant exact VALIDE
  // dérive la tranche automatiquement (billRangeFromExact), masque le <select>
  // et affiche une ligne de confirmation discrète. Le payload billRange (lu sur
  // le <select>) reste ainsi TOUJOURS cohérent avec ce qui a piloté l'estimation
  // affichée. Champ exact vide/invalide → le <select> réapparaît, comme avant. ———
  function syncBillRangeFromExact() {
    const wrap = $('mt-bill-wrap');
    const detected = $('mt-bill-detected');
    const detectedValue = $('mt-bill-detected-value');
    const billSelect = $('mt-bill') as HTMLSelectElement | null;
    const exact = num('mt-facture-hiver');
    if (exact != null && exact > 0 && exact <= maxBillFor('residentiel')) {
      const rid = billRangeFromExact(exact);
      if (rid && billSelect) {
        billSelect.value = rid;
        if (detectedValue) detectedValue.textContent = billRangeLabel(rid as BillRangeId);
        if (wrap) wrap.hidden = true;
        if (detected) detected.hidden = false;
        setFieldError('mt-bill', 'mt-bill-err', null);
        return;
      }
    }
    if (wrap) wrap.hidden = false;
    if (detected) detected.hidden = true;
  }

  // ——— WJ1/QX : calculer + afficher l'estimation dans LE DOCUMENT ———
  let lastKwcLabel = '';
  let lastSavingsLabel = '';
  let lastKwc: number | null = null;
  // QX — le document a-t-il déjà été rendu au moins une fois (fallback compris) ?
  let docRendered = false;
  // QX — estimateShown : EXACTEMENT les chiffres affichés dans le document,
  // joints au lead (le conseiller CRM voit ce que le client a vu — jamais plus).
  let estimateShown: Record<string, number | string> | null = null;
  // QX — tarif MAD/kWh de la dernière estimation PRO affichée (hypothèses du
  // moteur) : sert à dériver un billRange cohérent quand la conso est en kWh.
  let lastProTarifMadKwh: number | null = null;
  // WJ88 — annonce UNIQUE du résultat (jamais pendant la phase squelette) :
  // remplace l'ancien aria-live posé sur toute la carte, qui déclenchait un
  // double-fire lecteur d'écran (squelette PUIS résultat).
  function announceEstimate(message: string) {
    const el = $('mt-estimate-announce');
    if (el) el.textContent = message;
  }
  // ——— QX : petits formateurs du document (fr-FR, déterministes) ———
  const fmtNum = (n: number): string => (Math.round(n * 10) / 10).toLocaleString('fr-FR');
  const fmtYears = (n: number): string => (Math.round(n * 10) / 10).toLocaleString('fr-FR');
  /** Pourcentage robuste : accepte 0–1 (ratio) comme 0–100 (déjà en %). */
  const pct = (v: number): number => (v <= 1 ? Math.round(v * 100) : Math.round(v));
  function setText(id: string, text: string) {
    const el = $(id);
    if (el) el.textContent = text;
  }
  /** Carte KPI honnête : valeur inconnue → la carte DISPARAÎT (jamais un tiret). */
  function setCard(cardId: string, valueId: string, text: string | null) {
    const cardEl = $(cardId);
    if (cardEl) cardEl.hidden = text == null;
    if (text != null) setText(valueId, text);
  }
  // ——— QX : graphe 12 mois (SVG pur, or/navy — aucune lib). Répartition
  // mensuelle INDICATIVE de l'irradiation au Maroc (profil PVGIS type
  // Casablanca, normalisé à 1,00) : sert UNIQUEMENT à répartir sur 12 mois une
  // production ANNUELLE déjà calculée — jamais à créer un chiffre nouveau. ———
  const MONTH_LETTERS = ['J', 'F', 'M', 'A', 'M', 'J', 'J', 'A', 'S', 'O', 'N', 'D'];
  const GHI_MONTHLY_SHARE = [0.057, 0.062, 0.084, 0.094, 0.105, 0.108, 0.113, 0.105, 0.089, 0.075, 0.057, 0.051];
  function renderMonthlyChart(annualKwh: number) {
    const wrap = $('mt-doc-chart-wrap');
    const host = $('mt-doc-chart');
    if (!wrap || !host) return;
    if (!Number.isFinite(annualKwh) || annualKwh <= 0) {
      wrap.hidden = true;
      return;
    }
    const values = GHI_MONTHLY_SHARE.map((s) => annualKwh * s);
    const maxV = Math.max(...values);
    const W = 560;
    const H = 168;
    const pad = 8;
    const baseY = 140;
    const slot = (W - pad * 2) / 12;
    const barW = Math.min(30, slot - 8);
    let bars = '';
    values.forEach((v, i) => {
      const h = maxV > 0 ? Math.max(3, (v / maxV) * 108) : 3;
      const x = pad + slot * i + (slot - barW) / 2;
      const cx = pad + slot * i + slot / 2;
      bars += `<rect x="${x.toFixed(1)}" y="${(baseY - h).toFixed(1)}" width="${barW.toFixed(1)}" height="${h.toFixed(1)}" rx="3" fill="#F5A623"/>`;
      bars += `<text x="${cx.toFixed(1)}" y="${baseY + 17}" text-anchor="middle" font-size="11" fill="#6b7280" font-family="DM Sans, system-ui, sans-serif">${MONTH_LETTERS[i]}</text>`;
    });
    const avg = Math.round(annualKwh / 12);
    host.innerHTML =
      `<svg viewBox="0 0 ${W} ${H}" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid meet">` +
      `<line x1="${pad}" y1="${baseY}" x2="${W - pad}" y2="${baseY}" stroke="#E5E7EB" stroke-width="1"/>` +
      bars +
      `<text x="${W - pad}" y="14" text-anchor="end" font-size="11" fill="#1A2B4A" font-family="DM Sans, system-ui, sans-serif">≈ ${formatMad(avg)} kWh/mois en moyenne</text>` +
      '</svg>';
    wrap.hidden = false;
  }
  // ——— QX : habillage commun du document (date, sous-titre par profil, ville,
  // ligne client/site — uniquement des faits CONNUS, jamais un tiret). ———
  function fillDocChrome() {
    docRendered = true;
    const dateEl = $('mt-doc-date');
    if (dateEl) dateEl.textContent = new Date().toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });
    const m = mode || 'residentiel';
    const subEl = $('mt-doc-subtitle');
    if (subEl) subEl.textContent = MODE_DOC_SUBTITLE[m] || MODE_DOC_SUBTITLE.residentiel;
    const city = (val('mt-city') || addressEl?.value || fallbackAddrEl?.value || '').trim();
    const citySpan = $('mt-doc-city');
    const cityLine = $('mt-doc-city-line');
    if (citySpan) citySpan.textContent = city;
    if (cityLine) cityLine.hidden = !city;
    const metaEl = $('mt-doc-meta');
    if (metaEl) {
      const parts: string[] = [];
      if (city) parts.push(city);
      parts.push(`Projet ${(MODE_LABEL[m] || 'Résidentiel').toLowerCase()}`);
      if (capturePin) parts.push('toit repéré sur carte satellite');
      metaEl.textContent = parts.join(' · ');
      metaEl.hidden = false;
    }
    void tryRoofSnapshot();
  }
  // ——— QX/Lane C : instantané satellite du toit — branché sur le VRAI helper
  // Lane C `buildPublicRoofImageSpec(outline)` (roofPro11/viewerOnly), en
  // import dynamique + garde typeof (défensif : tout échec/absence → null,
  // le document reste complet sans image). Le spec est mis en cache et
  // PARTAGÉ avec l'aperçu 3D (même photo, un seul fetch), invalidé quand le
  // contour change. NOTE orchestrateur : câblage Lane C effectif — le
  // TODO(orchestrator): wire roofImage once Lane C lands est RÉSOLU ici. ———
  let roofImageSpecPromise: Promise<RoofImageSpec | null> | null = null;
  function fetchRoofImageSpec(): Promise<RoofImageSpec | null> {
    if (!roofImageSpecPromise) {
      roofImageSpecPromise = (async () => {
        if (captureOutline.length < 3) return null;
        const mod = await import('../../scripts/roofPro11/viewerOnly');
        if (typeof mod.buildPublicRoofImageSpec !== 'function') return null;
        const spec = await mod.buildPublicRoofImageSpec({ outline: captureOutline });
        return spec && spec.image ? spec : null;
      })().catch(() => null);
    }
    return roofImageSpecPromise;
  }
  /** « Votre toit » dans le document : petite photo satellite + attribution
   *  fournisseur (obligation), UNIQUEMENT quand un contour ≥3 sommets existe. */
  async function tryRoofSnapshot() {
    const fig = $('mt-doc-roof');
    const img = $('mt-doc-roof-img') as HTMLImageElement | null;
    if (!fig || !img) return;
    if (captureOutline.length < 3) {
      fig.hidden = true;
      return;
