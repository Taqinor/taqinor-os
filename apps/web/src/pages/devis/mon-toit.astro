    renderMonthlyChart(est.productionKwhYr);
    if (printBtn) printBtn.hidden = false;
    fillDocChrome();
    updatePanels3dVisibility();
    // WJ59 — l'estimation réelle est le moment où le formulaire de contact
    // devient l'action pertinente : « étape contact atteinte ».
    // WB30 — pas de beacon avant l'étape de consentement (panneau 2).
    if (hasReachedConsentStep()) sendFunnelBeacon('contact', 'reached');
