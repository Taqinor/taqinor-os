  function computeEstimate(): boolean {
    const exact = num('mt-facture-hiver');
    const bill = resolveMonthlyBill();
    const card = $('mt-estimate-body');
    const note = $('mt-estimate-note');
    const unavail = $('mt-estimate-unavailable');
    const toolarge = $('mt-estimate-toolarge');
    const cowEl = $('mt-cost-of-waiting');
    const climateBandEl = $('mt-climate-band');
    const printBtn = $('mt-print-estimate');
    const agricoleEl = $('mt-estimate-agricole');
    resetDocZones();
    if (mode === 'agricole') {
      // WJ111 — jamais estimateFromBill ici : le pompage se dimensionne sur
      // l'hydraulique (profondeur/HMT + besoin en eau), pas sur une facture.
      if (card) card.hidden = true;
      if (note) note.hidden = true;
      if (unavail) unavail.hidden = true;
      if (toolarge) toolarge.hidden = true;
      setFieldError('mt-facture-hiver', 'mt-facture-hiver-err', null);
      const ag = computeAgricoleEstimate();
      if (!ag) {
        // Hydraulique manquante → carte chaleureuse DANS le document (jamais
        // un chiffre résidentiel fabriqué).
        if (agricoleEl) agricoleEl.hidden = false;
        lastKwcLabel = '';
        lastSavingsLabel = '';
        lastKwc = null;
        estimateShown = null;
        if (printBtn) printBtn.hidden = true;
        fillDocChrome();
        updatePanels3dVisibility();
        announceEstimate('Le pompage se dimensionne sur votre profondeur et votre besoin en eau — un ingénieur vous rappelle avec un calcul adapté.');
        return true;
      }
      if (agricoleEl) agricoleEl.hidden = true;
      renderAgricoleEstimate(ag);
      return true;
    }
    if (agricoleEl) agricoleEl.hidden = true;
    if (mode === 'professionnel') {
      if (card) card.hidden = true;
      if (note) note.hidden = true;
      setFieldError('mt-facture-hiver', 'mt-facture-hiver-err', null);
      return computeProEstimate();
    }
    // ——— RÉSIDENTIEL (défaut) — moteur billEstimate inchangé (WJ1/WJ112) ———
    // WJ65 — montant exact au-delà du plafond : message honnête dédié (jamais un
    // chiffre confiant sur une saisie probablement erronée) + erreur inline sur
    // le champ concerné, sans jamais BLOQUER l'étape (le visiteur peut corriger
    // ou repartir sur une tranche).
    if (exact != null && exact > maxBillFor('residentiel')) {
      if (card) card.hidden = true;
      if (note) note.hidden = true;
      if (unavail) unavail.hidden = true;
      if (toolarge) toolarge.hidden = false;
      setFieldError('mt-facture-hiver', 'mt-facture-hiver-err', 'Vérifiez le montant saisi.');
      lastKwcLabel = '';
      lastSavingsLabel = '';
      lastKwc = null;
      estimateShown = null;
      if (printBtn) printBtn.hidden = true;
      fillDocChrome();
      updatePanels3dVisibility();
      announceEstimate('Estimation indisponible — vérifiez le montant saisi.');
      return false;
    }
    setFieldError('mt-facture-hiver', 'mt-facture-hiver-err', null);
    if (toolarge) toolarge.hidden = true;
