---
/**
 * « Mon toit » — CAPTURE CLIENT (PUBLIC, noindex). Élevée WJ1-WJ8.
 *
 * Parcours mobile-first en assistant (WJ6) : Votre toit → Votre facture → Votre
 * estimation. La carte/le repère sont FACULTATIFS (WJ4) : on peut soumettre avec
 * l'adresse seule si la carte est indisponible. À l'étape estimation, une
 * FOURCHETTE instantanée (kWc, ≈MAD/mois économisés, amortissement) est calculée
 * par le VRAI moteur (billEstimate → estimatorBrain) AVANT la porte de contact
 * (WJ1). La capture est WhatsApp-first (WJ3) : CTA « Recevoir mon estimation sur
 * WhatsApp » prérempli + e-mail/opt-in transmis au webhook. Le seuil 1 000 MAD est
 * préservé et HONNÊTE (WJ5) : sous le seuil, on n'affiche pas un faux
 * « enregistré » mais un message adapté. Récupération d'abandon (WJ7) + bandeau de
 * confiance (WJ8). Microcopie FR + AR (WJ6).
 *
 * Le contrat de soumission /api/capture-lead est INCHANGÉ (validateLead, seuil,
 * consentement/UTM/fbclid, roofPoint/roofOutline/profil énergétique facultatifs).
 * L'outil 3D est booté en captureOnly : aucun panneau ne s'affiche ici.
 */
import Layout from '../../layouts/Layout.astro';
import { BILL_RANGES } from '../../lib/billRange';
import { ROOF_TYPES } from '../../lib/lead';

const inputClass =
  'w-full border border-white/15 bg-white/5 px-3 py-3 text-base text-white placeholder:text-lune-faint outline-none transition-colors focus:border-brass-400 focus:ring-2 focus:ring-brass-400/30 aria-[invalid=true]:border-alert-300 aria-[invalid=true]:ring-2 aria-[invalid=true]:ring-alert-300/30';
const roofTypes = ROOF_TYPES;
const billRanges = BILL_RANGES;

// WJ6 — étapes de l'assistant (libellés FR + AR). data-i18n pour bascule de langue.
const STEPS = [
  { fr: 'Votre toit', ar: 'سطحك' },
  { fr: 'Votre facture', ar: 'فاتورتك' },
  { fr: 'Votre estimation', ar: 'تقديرك' },
];

// WJ6 — sélecteur de mode (résidentiel / professionnel / agricole), FR + AR.
const MODES = [
  { id: 'residentiel', fr: 'Résidentiel', ar: 'سكني', desc_fr: 'Villa, appartement', desc_ar: 'فيلا، شقة' },
  { id: 'professionnel', fr: 'Professionnel', ar: 'مهني', desc_fr: 'Industrie, commerce', desc_ar: 'صناعة، تجارة' },
  { id: 'agricole', fr: 'Agricole', ar: 'فلاحي', desc_fr: 'Pompage, ferme', desc_ar: 'ضخ، مزرعة' },
];

// WJ8 — villes desservies (réelles, NAP) pour la preuve de proximité.
const TOWNS = ['Casablanca', 'Rabat', 'Marrakech', 'Tanger', 'Agadir', 'Kénitra', 'Fès', 'Settat'];
---

<Layout
  title="Recevez votre estimation solaire — Mon toit | Taqinor"
  description="Adresse + facture : recevez instantanément une estimation solaire (puissance, économies, amortissement), puis votre étude personnalisée sur WhatsApp."
  noindex={true}
>
  <section class="bg-nuit px-4 py-8 sm:py-12">
    <div class="mx-auto max-w-2xl">
      <!-- En-tête + bascule de langue FR/AR (WJ6) -->
      <div class="flex items-start justify-between gap-3">
        <div>
          <p class="tech-label rule-brass text-brass-300" data-i18n data-fr="Estimation solaire · gratuit · sans engagement" data-ar="تقدير شمسي · مجاني · بدون التزام">
            Estimation solaire · gratuit · sans engagement
          </p>
          <h1 class="display mt-4 text-2xl text-white sm:text-3xl" data-i18n data-fr="Recevez votre estimation solaire" data-ar="استلم تقديرك الشمسي">
            Recevez votre estimation solaire
          </h1>
        </div>
        <div class="flex flex-none gap-1 rounded-sm border border-white/15 p-0.5" role="group" aria-label="Langue">
          <button type="button" id="mt-lang-fr" aria-pressed="true"
            class="px-3 py-1.5 text-sm font-semibold text-azur-950 bg-brass-400 transition-colors">FR</button>
          <button type="button" id="mt-lang-ar" aria-pressed="false"
            class="px-3 py-1.5 text-sm font-semibold text-lune-soft transition-colors hover:text-white">عربي</button>
        </div>
      </div>

      <!-- WJ6 — microcopie « pas de pression » -->
      <p class="mt-3 text-sm text-lune-soft" data-i18n
        data-fr="Réponse sous 24–48 h · on vous répond sur WhatsApp, pas d'appels commerciaux."
        data-ar="رد خلال 24–48 ساعة · نجيبك على واتساب، بدون مكالمات تجارية.">
        Réponse sous 24–48 h · on vous répond sur WhatsApp, pas d'appels commerciaux.
      </p>

      <!-- WJ6 — barre de progression étiquetée -->
      <ol id="mt-progress" class="mt-6 grid grid-cols-3 gap-2" aria-label="Progression">
        {STEPS.map((s, i) => (
          <li class="mt-step flex flex-col gap-1.5" data-step={i}>
            <span class="h-1.5 w-full rounded-full bg-white/10 mt-step-bar transition-colors"></span>
            <span class="text-xs text-lune-faint mt-step-label" data-i18n data-fr={s.fr} data-ar={s.ar}>{s.fr}</span>
          </li>
        ))}
      </ol>

      <!-- ============ ÉTAPE 0/1 — VOTRE TOIT (mode + carte/repère) ============ -->
      <div id="mt-panel-0" class="mt-step-panel">
        <!-- WJ6 — sélecteur de mode -->
        <fieldset class="mt-6">
          <legend class="text-sm text-lune-soft" data-i18n data-fr="Votre type de projet" data-ar="نوع مشروعك">Votre type de projet</legend>
          <div class="mt-3 grid grid-cols-3 gap-2">
            {MODES.map((m, i) => (
              <button type="button" class="mt-mode cine-card flex flex-col items-start gap-0.5 border p-3 text-left transition-colors"
                data-mode={m.id} aria-pressed={i === 0 ? 'true' : 'false'}>
                <span class="text-sm font-semibold text-white" data-i18n data-fr={m.fr} data-ar={m.ar}>{m.fr}</span>
                <span class="text-xs text-lune-faint" data-i18n data-fr={m.desc_fr} data-ar={m.desc_ar}>{m.desc_fr}</span>
              </button>
            ))}
          </div>
        </fieldset>

        <p class="mt-5 text-lune-soft" data-i18n
          data-fr="Cherchez votre adresse et posez un repère sur votre toit. C'est facultatif — vous pouvez aussi continuer avec votre adresse seule."
          data-ar="ابحث عن عنوانك وضع علامة على سطحك. هذا اختياري — يمكنك أيضاً المتابعة بعنوانك فقط.">
          Cherchez votre adresse et posez un repère sur votre toit. C'est facultatif —
          vous pouvez aussi continuer avec votre adresse seule.
        </p>

        <!-- Repli sans JavaScript / sans clé carte (WJ4) : on demande l'adresse en clair
             et on AUTORISE la suite (plus de cul-de-sac sur le repère). -->
        <div id="mt-fallback" hidden class="cine-card mt-5 border-l-4 border-alert-300 p-5">
          <p class="font-semibold text-white" data-i18n data-fr="Carte momentanément indisponible" data-ar="الخريطة غير متوفرة مؤقتاً">Carte momentanément indisponible</p>
          <p class="mt-2 text-sm text-lune-soft" data-i18n
            data-fr="Pas de souci : indiquez votre adresse complète ci-dessous et continuez. Nous localiserons votre toit pour vous."
            data-ar="لا مشكلة: أدخل عنوانك الكامل أدناه وتابع. سنحدد موقع سطحك من أجلك.">
            Pas de souci : indiquez votre adresse complète ci-dessous et continuez. Nous
            localiserons votre toit pour vous.
          </p>
          <label class="mt-3 block text-sm text-lune-soft">
            <span data-i18n data-fr="Adresse complète" data-ar="العنوان الكامل">Adresse complète</span>
            <input id="mt-fallback-address" type="text" autocomplete="street-address"
              placeholder="Ex. Lot. Al Wifaq, Hay Riad, Rabat" class={`${inputClass} mt-1`} />
          </label>
        </div>

        <!-- CARTE — recherche d'adresse + repère (ids rp9-* câblés par captureBoot). -->
        <div id="mt-stage" class="cine-card mt-5 overflow-hidden">
          <form id="rp9-search" class="flex flex-col gap-3 border-b border-white/10 p-4 sm:flex-row">
            <label for="rp9-address" class="sr-only">Votre adresse</label>
            <div class="relative flex-1">
              <input id="rp9-address" name="address" type="text" autocomplete="off"
                role="combobox" aria-autocomplete="list" aria-expanded="false"
                aria-controls="rp9-suggestions" aria-haspopup="listbox"
                placeholder="Adresse, quartier ou ville (ex. Casablanca, Maârif)" class={inputClass} />
              <ul id="rp9-suggestions" role="listbox" aria-label="Suggestions d'adresses" hidden
                class="absolute left-0 right-0 top-full z-20 mt-1 max-h-72 overflow-auto border border-white/15 bg-nuit-900 shadow-xl">
              </ul>
            </div>
            <button type="submit"
              class="flex-none bg-brass-400 px-6 py-3 text-base font-bold text-azur-950 transition-colors hover:bg-brass-300">
              Localiser
            </button>
          </form>

          <div id="rp9-map" class="mt-0 h-[44vh] min-h-[280px] w-full bg-nuit-700"
            role="application" aria-label="Carte satellite pour repérer votre toit"></div>

          <div class="flex flex-wrap items-center gap-3 border-t border-white/10 p-4">
            <button type="button" id="rp9-finish" disabled
              class="border border-white/25 px-4 py-2.5 text-sm font-semibold text-white transition-colors hover:border-brass-400 hover:text-brass-300 disabled:cursor-not-allowed disabled:opacity-40">
              Terminer le tracé
            </button>
            <button type="button" id="rp9-undo-point" hidden
              class="border border-white/25 px-4 py-2.5 text-sm font-semibold text-lune-soft transition-colors hover:border-brass-400 hover:text-brass-300">
              Annuler le dernier point
            </button>
            <button type="button" id="rp9-clear"
              class="border border-white/25 px-4 py-2.5 text-sm font-semibold text-lune-soft transition-colors hover:border-white/50 hover:text-white">
              Effacer
            </button>
            <p class="ml-auto text-sm text-lune-faint">
              <span>Repère&nbsp;: </span><span id="rp9-area-value" class="text-white">—</span>
            </p>
          </div>
          <p id="rp9-status" class="border-t border-white/10 px-4 py-3 text-sm text-lune-faint" aria-live="polite">
            Cherchez votre adresse, puis posez un repère sur votre toit (facultatif).
          </p>
        </div>

        <div class="mt-5 flex justify-end">
          <button type="button" id="mt-next-0"
            class="inline-flex items-center justify-center gap-2 bg-brass-400 px-6 py-3 text-base font-bold text-azur-950 transition-colors hover:bg-brass-300">
            <span data-i18n data-fr="Continuer" data-ar="متابعة">Continuer</span> →
          </button>
        </div>
      </div>

      <!-- ============ ÉTAPE 2 — VOTRE FACTURE (+ profil énergétique) ============ -->
      <div id="mt-panel-1" class="mt-step-panel" hidden>
        <p class="mt-6 text-lune-soft" data-i18n
          data-fr="Indiquez votre facture pour calculer votre estimation. Le montant exact donne le chiffre le plus juste."
          data-ar="أدخل فاتورتك لحساب تقديرك. المبلغ الدقيق يعطي الرقم الأصح.">
          Indiquez votre facture pour calculer votre estimation. Le montant exact donne le
          chiffre le plus juste.
        </p>

        <div class="cine-card mt-5 space-y-4 p-5 sm:p-6">
          <label class="block text-sm text-lune-soft">
            <span data-i18n data-fr="Facture mensuelle exacte (MAD)" data-ar="الفاتورة الشهرية الدقيقة (درهم)">Facture mensuelle exacte (MAD)</span>
            <input id="mt-facture-hiver" name="factureHiver" type="number" step="any" inputmode="decimal"
              placeholder="Ex. 1 200" class={`${inputClass} mt-1`} />
            <span id="mt-facture-hiver-err" hidden class="mt-1 block text-xs text-alert-300"></span>
          </label>

          <label class="block text-sm text-lune-soft">
            <span data-i18n data-fr="…ou choisissez une tranche" data-ar="…أو اختر شريحة">…ou choisissez une tranche</span>
            <select id="mt-bill" name="billRange" class={`${inputClass} mt-1`}>
              <option value="">Choisir…</option>
              {billRanges.map((b) => <option value={b.id}>{b.label}</option>)}
            </select>
            <span id="mt-bill-err" hidden class="mt-1 block text-xs text-alert-300"></span>
          </label>

          <div class="grid gap-4 sm:grid-cols-2">
            <label class="block text-sm text-lune-soft">
              <span data-i18n data-fr="Type de toit" data-ar="نوع السطح">Type de toit</span>
              <select id="mt-roof" name="roofType" class={`${inputClass} mt-1`}>
                <option value="">Choisir…</option>
                {roofTypes.map((r) => <option value={r.id}>{r.label}</option>)}
              </select>
              <span id="mt-roof-err" hidden class="mt-1 block text-xs text-alert-300"></span>
            </label>
            <label class="block text-sm text-lune-soft">
              <span data-i18n data-fr="Raccordement" data-ar="نوع الربط">Raccordement</span>
              <select id="mt-raccordement" name="raccordement" class={`${inputClass} mt-1`}>
                <option value="">Choisir…</option>
                <option value="monophase">Monophasé</option>
                <option value="triphase">Triphasé</option>
                <option value="inconnu">Je ne sais pas</option>
              </select>
            </label>
          </div>

          <label class="flex items-start gap-3 text-sm text-lune-soft">
            <input id="mt-ete-differente" name="eteDifferente" type="checkbox" class="mt-1 h-5 w-5 flex-none accent-brass-400" />
            <span data-i18n data-fr="L'été est différent de l'hiver ? (climatisation, pompage…)" data-ar="الصيف مختلف عن الشتاء؟ (تكييف، ضخ…)">L'été est différent de l'hiver&nbsp;? (climatisation, pompage…)</span>
          </label>

          <label id="mt-facture-ete-wrap" hidden class="block text-sm text-lune-soft">
            <span data-i18n data-fr="Facture été (MAD)" data-ar="فاتورة الصيف (درهم)">Facture été (MAD)</span>
            <input id="mt-facture-ete" name="factureEte" type="number" step="any" inputmode="decimal"
              placeholder="Ex. 2 500" class={`${inputClass} mt-1`} />
          </label>
        </div>

        <div class="mt-5 flex items-center justify-between gap-3">
          <button type="button" id="mt-back-1"
            class="inline-flex items-center gap-1 px-2 py-3 text-base font-semibold text-lune-soft transition-colors hover:text-white">
            ← <span data-i18n data-fr="Retour" data-ar="رجوع">Retour</span>
          </button>
          <button type="button" id="mt-estimate"
            class="inline-flex items-center justify-center gap-2 bg-brass-400 px-6 py-3 text-base font-bold text-azur-950 transition-colors hover:bg-brass-300">
            <span data-i18n data-fr="Voir mon estimation" data-ar="عرض تقديري">Voir mon estimation</span> →
          </button>
        </div>
      </div>

      <!-- ============ ÉTAPE 3 — VOTRE ESTIMATION (WJ1) + CONTACT (WJ3) ============ -->
      <div id="mt-panel-2" class="mt-step-panel" hidden>
        <!-- WJ1 — l'estimation instantanée AVANT la porte de contact -->
        <div id="mt-estimate-card" class="cine-card mt-6 border border-brass-400/30 p-5 sm:p-6" aria-live="polite">
          <p class="tech-label text-brass-300" data-i18n data-fr="Votre estimation instantanée" data-ar="تقديرك الفوري">Votre estimation instantanée</p>
          <div id="mt-estimate-body" class="mt-4 grid grid-cols-1 gap-4 sm:grid-cols-3">
            <div>
              <p class="text-3xl font-bold text-white"><span id="mt-est-kwc">—</span> <span class="text-base font-normal text-lune-soft">kWc</span></p>
              <p class="text-xs text-lune-faint" data-i18n data-fr="Puissance recommandée" data-ar="القدرة الموصى بها">Puissance recommandée</p>
            </div>
            <div>
              <p class="text-3xl font-bold text-ok-400"><span id="mt-est-savings">—</span></p>
              <p class="text-xs text-lune-faint" data-i18n data-fr="Économies estimées / mois" data-ar="التوفير المقدّر / شهر">Économies estimées / mois</p>
            </div>
            <div>
              <p class="text-3xl font-bold text-white" id="mt-est-payback">—</p>
              <p class="text-xs text-lune-faint" data-i18n data-fr="Amortissement" data-ar="استرداد التكلفة">Amortissement</p>
            </div>
          </div>
          <p id="mt-estimate-note" class="mt-4 text-xs text-lune-faint" data-i18n
            data-fr="Fourchette préliminaire calculée à partir de votre facture (autoconsommation, loi 82-21). Le chiffrage exact est établi après visite technique — sans engagement."
            data-ar="شريحة أولية محسوبة من فاتورتك (الاستهلاك الذاتي، القانون 82-21). يُحدَّد التقدير الدقيق بعد زيارة تقنية — بدون التزام.">
            Fourchette préliminaire calculée à partir de votre facture (autoconsommation, loi
            82-21). Le chiffrage exact est établi après visite technique — sans engagement.
          </p>
          <!-- WJ1 — quand l'estimation est indisponible (facture absente/non chiffrable) -->
          <p id="mt-estimate-unavailable" hidden class="mt-4 text-sm text-alert-300" data-i18n
            data-fr="Estimation indisponible : indiquez votre facture mensuelle pour la calculer. Nous l'affinons ensemble sur WhatsApp."
            data-ar="التقدير غير متاح: أدخل فاتورتك الشهرية لحسابه. نحدّده معاً على واتساب.">
            Estimation indisponible : indiquez votre facture mensuelle pour la calculer. Nous
            l'affinons ensemble sur WhatsApp.
          </p>
        </div>

        <!-- Formulaire de contact (la porte vient APRÈS l'estimation). -->
        <form id="mt-form" novalidate class="cine-card mt-5 space-y-4 p-5 sm:p-6">
          <p class="tech-label rule-brass text-brass-300" data-i18n data-fr="Pour recevoir votre étude" data-ar="لاستلام دراستك">Pour recevoir votre étude</p>

          <div class="grid gap-4 sm:grid-cols-2">
            <label class="block text-sm text-lune-soft">
              <span data-i18n data-fr="Nom complet" data-ar="الاسم الكامل">Nom complet</span>
              <input id="mt-name" name="fullName" type="text" autocomplete="name" required aria-required="true" class={`${inputClass} mt-1`} />
              <span id="mt-name-err" hidden class="mt-1 block text-xs text-alert-300"></span>
            </label>
            <label class="block text-sm text-lune-soft">
              <span data-i18n data-fr="Téléphone / WhatsApp" data-ar="الهاتف / واتساب">Téléphone / WhatsApp</span>
              <input id="mt-phone" name="phone" type="tel" inputmode="tel" autocomplete="tel" required aria-required="true"
                placeholder="06 XX XX XX XX" class={`${inputClass} mt-1`} />
              <span id="mt-phone-err" hidden class="mt-1 block text-xs text-alert-300"></span>
            </label>
          </div>

          <label class="block text-sm text-lune-soft">
            <span data-i18n data-fr="Adresse / ville" data-ar="العنوان / المدينة">Adresse / ville</span>
            <input id="mt-city" name="city" type="text" autocomplete="address-level2" required aria-required="true"
              placeholder="Lue depuis la carte — modifiable si besoin" class={`${inputClass} mt-1`} />
            <span id="mt-city-err" hidden class="mt-1 block text-xs text-alert-300"></span>
          </label>

          <!-- WJ3 — e-mail (facultatif) + opt-in WhatsApp -->
          <label class="block text-sm text-lune-soft">
            <span data-i18n data-fr="E-mail (facultatif)" data-ar="البريد الإلكتروني (اختياري)">E-mail (facultatif)</span>
            <input id="mt-email" name="email" type="email" inputmode="email" autocomplete="email"
              placeholder="vous@exemple.com" class={`${inputClass} mt-1`} />
          </label>

          <label class="flex items-start gap-3 text-sm text-lune-soft">
            <input id="mt-wa-optin" name="whatsappOptIn" type="checkbox" checked class="mt-1 h-5 w-5 flex-none accent-ok-600" />
            <span data-i18n data-fr="Je préfère être contacté(e) sur WhatsApp (réponse plus rapide)" data-ar="أفضّل التواصل عبر واتساب (رد أسرع)">Je préfère être contacté(e) sur WhatsApp (réponse plus rapide)</span>
          </label>

          <label class="flex items-start gap-3 text-sm text-lune-soft">
            <input id="mt-consent" name="consent" type="checkbox" required aria-required="true" class="mt-1 h-5 w-5 flex-none accent-brass-400" />
            <span data-i18n data-fr="J'accepte d'être recontacté(e) par Taqinor au sujet de mon projet solaire." data-ar="أوافق على أن تتواصل معي تاكينور بخصوص مشروعي الشمسي.">
              J'accepte d'être recontacté(e) par Taqinor au sujet de mon projet solaire.
            </span>
          </label>
          <span id="mt-consent-err" hidden class="block text-xs text-alert-300"></span>

          <p id="mt-error" hidden class="text-sm text-alert-300" aria-live="polite"></p>

          <!-- WJ3 — CTA PRIMAIRE WhatsApp-first -->
          <button type="submit" id="mt-submit"
            class="inline-flex w-full items-center justify-center gap-2 bg-ok-600 px-6 py-4 text-base font-bold text-white transition-opacity hover:opacity-90 disabled:cursor-not-allowed disabled:opacity-50">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true" class="flex-none"><path d="M.057 24l1.687-6.163a11.867 11.867 0 0 1-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.817 11.817 0 0 1 8.413 3.488 11.824 11.824 0 0 1 3.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 0 1-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 0 0 1.512 5.26l-.999 3.648 3.736-.979z"/></svg>
            <span data-i18n data-fr="Recevoir mon estimation sur WhatsApp" data-ar="استلام تقديري على واتساب">Recevoir mon estimation sur WhatsApp</span>
          </button>

          <div class="flex items-center justify-between gap-3">
            <button type="button" id="mt-back-2"
              class="inline-flex items-center gap-1 px-2 py-2 text-sm font-semibold text-lune-soft transition-colors hover:text-white">
              ← <span data-i18n data-fr="Retour" data-ar="رجوع">Retour</span>
            </button>
          </div>

          <!-- WJ5 — succès qualifié (≥ 1 000 MAD : la demande atteint le CRM) -->
          <div id="mt-success" hidden class="border border-ok-600/40 bg-ok-600/10 p-4 text-sm text-white">
            <p class="font-semibold" data-i18n data-fr="Merci ! Votre demande est enregistrée." data-ar="شكراً! تم تسجيل طلبك.">Merci ! Votre demande est enregistrée.</p>
            <p class="mt-1 text-lune-soft" data-i18n data-fr="Notre équipe prépare votre étude et vous recontacte très vite — souvent sur WhatsApp." data-ar="فريقنا يُعدّ دراستك ويتواصل معك قريباً — غالباً عبر واتساب.">Notre équipe prépare votre étude et vous recontacte très vite — souvent sur WhatsApp.</p>
            <a id="mt-success-wa" href="#" target="_blank" rel="noopener"
              class="mt-3 inline-flex items-center gap-2 bg-ok-600 px-4 py-2.5 text-sm font-bold text-white transition-opacity hover:opacity-90">
              <span data-i18n data-fr="Ouvrir WhatsApp maintenant" data-ar="افتح واتساب الآن">Ouvrir WhatsApp maintenant</span>
            </a>
          </div>

          <!-- WJ5 — chemin HONNÊTE sous le seuil 1 000 MAD (jamais un faux « enregistré ») -->
          <div id="mt-belowthreshold" hidden class="border border-brass-400/40 bg-brass-400/10 p-4 text-sm text-white">
            <p class="font-semibold" data-i18n data-fr="Le solaire n'est pas encore rentable à votre échelle." data-ar="الطاقة الشمسية ليست بعدُ مربحة على نطاقك.">Le solaire n'est pas encore rentable à votre échelle.</p>
            <p class="mt-1 text-lune-soft" data-i18n
              data-fr="En dessous de ~1 000 MAD/mois, l'investissement met trop longtemps à se rentabiliser pour qu'on vous le recommande honnêtement. Gardons le contact : dès que votre facture augmente, ou pour des conseils gratuits d'efficacité énergétique, écrivez-nous sur WhatsApp."
              data-ar="تحت ~1000 درهم/شهر، يستغرق الاستثمار وقتاً طويلاً ليصبح مربحاً بما يكفي لننصحك به بصدق. لنبقَ على تواصل: بمجرد ارتفاع فاتورتك، أو لنصائح مجانية حول كفاءة الطاقة، راسلنا على واتساب.">
              En dessous de ~1 000 MAD/mois, l'investissement met trop longtemps à se rentabiliser
              pour qu'on vous le recommande honnêtement. Gardons le contact : dès que votre facture
              augmente, ou pour des conseils gratuits d'efficacité énergétique, écrivez-nous sur
              WhatsApp.
            </p>
            <a id="mt-belowthreshold-wa" href="#" target="_blank" rel="noopener"
              class="mt-3 inline-flex items-center gap-2 bg-ok-600 px-4 py-2.5 text-sm font-bold text-white transition-opacity hover:opacity-90">
              <span data-i18n data-fr="Discuter sur WhatsApp" data-ar="الدردشة على واتساب">Discuter sur WhatsApp</span>
            </a>
          </div>
        </form>
      </div>

      <!-- ============ WJ8 — CONFIANCE AU POINT DE CAPTURE ============ -->
      <aside class="mt-8 border-t border-white/10 pt-6">
        <!-- pending real content from Reda : nombre de clients + photos d'installations réelles.
             On NE FABRIQUE PAS de chiffre ni d'avis : on affiche des faits vérifiables (loi
             82-21, garanties constructeur standard, zone de service réelle) + un emplacement
             scaffoldé pour les photos. -->
        <div class="grid grid-cols-2 gap-3 sm:grid-cols-4">
          <div class="cine-card p-3 text-center">
            <p class="text-sm font-bold text-white" data-i18n data-fr="Conforme loi 82-21" data-ar="مطابق للقانون 82-21">Conforme loi 82-21</p>
            <p class="text-xs text-lune-faint" data-i18n data-fr="Autoproduction déclarée" data-ar="إنتاج ذاتي مُصرَّح">Autoproduction déclarée</p>
          </div>
          <div class="cine-card p-3 text-center">
            <p class="text-sm font-bold text-white" data-i18n data-fr="Garantie 25 ans" data-ar="ضمان 25 سنة">Garantie 25 ans</p>
            <p class="text-xs text-lune-faint" data-i18n data-fr="Panneaux (constructeur)" data-ar="الألواح (المُصنّع)">Panneaux (constructeur)</p>
          </div>
          <div class="cine-card p-3 text-center">
            <p class="text-sm font-bold text-white" data-i18n data-fr="Matériel certifié" data-ar="معدات معتمدة">Matériel certifié</p>
            <p class="text-xs text-lune-faint">IEC 61215 / 61730</p>
          </div>
          <div class="cine-card p-3 text-center">
            <!-- pending real content from Reda : compteur de clients/installations réel. -->
            <p class="text-sm font-bold text-white" data-i18n data-fr="Partout au Maroc" data-ar="في كل المغرب">Partout au Maroc</p>
            <p class="text-xs text-lune-faint" data-i18n data-fr="Étude locale" data-ar="دراسة محلية">Étude locale</p>
          </div>
        </div>

        <!-- WJ8 — villes desservies (réelles) -->
        <p class="mt-4 text-center text-xs text-lune-faint">
          <span data-i18n data-fr="Installations et études à" data-ar="تركيبات ودراسات في">Installations et études à</span>
          {' '}{TOWNS.join(' · ')}
        </p>

        <!-- WJ8 — emplacement photos d'installations RÉELLES (scaffold, non fabriqué) -->
        <!-- pending real content from Reda : remplacer par 3 photos d'installations réelles
             (chemin /images/installs/*.webp) + légende ville. Tant qu'absentes, on n'affiche
             aucun visuel fabriqué — ce bloc reste masqué. -->
        <div id="mt-install-photos" hidden class="mt-4 grid grid-cols-3 gap-2" aria-label="Installations réalisées"></div>
      </aside>
    </div>
  </section>

  <!-- ============ WJ7 — RÉCUPÉRATION D'ABANDON (exit-intent / sortie mobile) ============ -->
  <div id="mt-exit" hidden class="fixed inset-0 z-50 flex items-end justify-center bg-black/60 p-4 sm:items-center" role="dialog" aria-modal="true" aria-labelledby="mt-exit-title">
    <div class="cine-card w-full max-w-md border border-brass-400/40 p-5">
      <div class="flex items-start justify-between gap-3">
        <p id="mt-exit-title" class="display text-lg text-white" data-i18n data-fr="Recevez votre estimation sur WhatsApp" data-ar="استلم تقديرك على واتساب">Recevez votre estimation sur WhatsApp</p>
        <button type="button" id="mt-exit-close" aria-label="Fermer" class="flex-none text-lune-faint hover:text-white">✕</button>
      </div>
      <p class="mt-2 text-sm text-lune-soft" data-i18n
        data-fr="Laissez juste votre numéro — on vous envoie votre estimation et on répond à vos questions. Gratuit, sans engagement."
        data-ar="اترك رقمك فقط — نرسل لك تقديرك ونجيب عن أسئلتك. مجاناً، بدون التزام.">
        Laissez juste votre numéro — on vous envoie votre estimation et on répond à vos
        questions. Gratuit, sans engagement.
      </p>
      <div class="mt-4 flex flex-col gap-2 sm:flex-row">
        <input id="mt-exit-phone" type="tel" inputmode="tel" autocomplete="tel"
          placeholder="06 XX XX XX XX" class={inputClass} />
        <a id="mt-exit-wa" href="#" target="_blank" rel="noopener"
          class="inline-flex flex-none items-center justify-center gap-2 bg-ok-600 px-5 py-3 text-base font-bold text-white transition-opacity hover:opacity-90">
          <span data-i18n data-fr="Envoyer" data-ar="إرسال">Envoyer</span>
        </a>
      </div>
      <p id="mt-exit-err" hidden class="mt-2 text-xs text-alert-300" aria-live="polite"></p>
    </div>
  </div>
</Layout>

<script>
  import { estimateFromBill, formatMadRange } from '../../lib/billEstimate';
  import { captureWhatsappText, whatsappLink } from '../../lib/whatsapp';
  import { WHATSAPP_LEADS } from '../../lib/nap';
  import { validateLead } from '../../lib/lead';

  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const $ = (id: string) => document.getElementById(id);
  const fallback = $('mt-fallback');
  const cityEl = $('mt-city') as HTMLInputElement | null;
  const addressEl = $('rp9-address') as HTMLInputElement | null;
  const fallbackAddrEl = $('mt-fallback-address') as HTMLInputElement | null;

  // ——— état capture (repère / contour) tenu par onCaptureChange ———
  let capturePin: { lat: number; lng: number } | null = null;
  let captureOutline: Array<[number, number]> = [];
  let cityTouched = false;
  cityEl?.addEventListener('input', () => { cityTouched = true; });

  // ——— WJ6 : bascule de langue FR/AR (data-i18n) ———
  function applyLang(lang: 'fr' | 'ar') {
    const isAr = lang === 'ar';
    document.querySelectorAll<HTMLElement>('[data-i18n]').forEach((el) => {
      const v = isAr ? el.dataset.ar : el.dataset.fr;
      if (typeof v === 'string') el.textContent = v;
    });
    // RTL local au bloc capture (n'altère pas la mise en page globale).
    const root = document.querySelector('section') as HTMLElement | null;
    if (root) {
      root.dir = isAr ? 'rtl' : 'ltr';
      root.style.lineHeight = isAr ? '1.75' : '';
    }
    const frBtn = $('mt-lang-fr');
    const arBtn = $('mt-lang-ar');
    frBtn?.setAttribute('aria-pressed', String(!isAr));
    arBtn?.setAttribute('aria-pressed', String(isAr));
    for (const [btn, on] of [[frBtn, !isAr], [arBtn, isAr]] as const) {
      if (!btn) continue;
      btn.className = on
        ? 'px-3 py-1.5 text-sm font-semibold text-azur-950 bg-brass-400 transition-colors'
        : 'px-3 py-1.5 text-sm font-semibold text-lune-soft transition-colors hover:text-white';
    }
  }
  $('mt-lang-fr')?.addEventListener('click', () => applyLang('fr'));
  $('mt-lang-ar')?.addEventListener('click', () => applyLang('ar'));

  // ——— WJ6 : sélecteur de mode ———
  let mode = 'residentiel';
  document.querySelectorAll<HTMLButtonElement>('.mt-mode').forEach((btn) => {
    btn.addEventListener('click', () => {
      mode = btn.dataset.mode || 'residentiel';
      document.querySelectorAll<HTMLButtonElement>('.mt-mode').forEach((b) => {
        const on = b === btn;
        b.setAttribute('aria-pressed', String(on));
        b.classList.toggle('border-brass-400', on);
        b.classList.toggle('border-white/15', !on);
      });
    });
  });
  // état initial : marquer le mode résidentiel sélectionné visuellement.
  document.querySelector<HTMLButtonElement>('.mt-mode')?.classList.add('border-brass-400');

  // ——— WJ6 : assistant multi-étapes + barre de progression ———
  let step = 0;
  const panels = [0, 1, 2].map((i) => $(`mt-panel-${i}`));
  function renderStep() {
    panels.forEach((p, i) => { if (p) p.hidden = i !== step; });
    document.querySelectorAll<HTMLElement>('.mt-step').forEach((li, i) => {
      const bar = li.querySelector<HTMLElement>('.mt-step-bar');
      const label = li.querySelector<HTMLElement>('.mt-step-label');
      const active = i <= step;
      if (bar) bar.className = `h-1.5 w-full rounded-full mt-step-bar transition-colors ${active ? 'bg-brass-400' : 'bg-white/10'}`;
      if (label) label.classList.toggle('text-white', i === step);
    });
    const root = document.querySelector('section');
    root?.scrollIntoView({ behavior: reducedMotion ? 'auto' : 'smooth', block: 'start' });
  }
  function goStep(n: number) { step = Math.max(0, Math.min(2, n)); renderStep(); }
  $('mt-next-0')?.addEventListener('click', () => goStep(1));
  $('mt-back-1')?.addEventListener('click', () => goStep(0));
  $('mt-back-2')?.addEventListener('click', () => goStep(1));
  renderStep();

  // ——— boot carte (captureOnly). Repli sans clé carte AUTORISE la suite (WJ4) ———
  let started = false;
  async function boot(key: string, mapboxToken: string) {
    if (started) return;
    started = true;
    try {
      const mod = await import('../../scripts/roof-tool-pro11.ts');
      mod.initRoofToolPro8({
        maptilerKey: key,
        mapboxToken: mapboxToken || undefined,
        reducedMotion,
        captureOnly: true,
        onCaptureChange: (s) => {
          capturePin = s.pin;
          captureOutline = s.outline;
          if (cityEl && !cityTouched) {
            const fromMap = (s.address && s.address.trim()) || addressEl?.value.trim() || '';
            if (fromMap) cityEl.value = fromMap;
          }
        },
      });
    } catch {
      started = false;
      showFallback();
    }
  }
  // WJ4 — repli carte : on montre le champ d'adresse en clair ET on garde la suite ouverte.
  function showFallback() { if (fallback) fallback.hidden = false; }

  (async () => {
    try {
      const res = await fetch('/api/roof-config');
      const cfg = (await res.json()) as { available?: boolean; maptilerKey?: string; mapboxToken?: string };
      if (!cfg.available || !cfg.maptilerKey) { showFallback(); return; }
      void boot(cfg.maptilerKey, cfg.mapboxToken || '');
    } catch {
      showFallback();
    }
  })();

  // ——— helpers de saisie ———
  const val = (id: string) => (($(id) as HTMLInputElement | HTMLSelectElement | null)?.value ?? '');
  const num = (id: string): number | null => {
    const raw = val(id).trim();
    if (raw === '') return null;
    const n = Number(raw);
    return Number.isFinite(n) ? n : null;
  };

  // toggle été ≠ hiver
  const eteToggle = $('mt-ete-differente') as HTMLInputElement | null;
  const eteWrap = $('mt-facture-ete-wrap') as HTMLElement | null;
  const eteInput = $('mt-facture-ete') as HTMLInputElement | null;
  eteToggle?.addEventListener('change', () => {
    const on = eteToggle.checked === true;
    if (eteWrap) eteWrap.hidden = !on;
    if (!on && eteInput) eteInput.value = '';
  });

  // ——— WJ1 : résoudre la facture mensuelle (montant exact prioritaire, sinon tranche) ———
  /** Milieu indicatif d'une tranche (MAD) — uniquement pour ESTIMER quand le montant
   *  exact est absent ; ne sert jamais au seuil (le seuil reste sur billRange/qualifies). */
  const RANGE_MIDPOINT: Record<string, number> = {
    'lt800': 600, '800-1000': 900, '1000-1500': 1250, '1500-3000': 2250,
    '3000-5000': 4000, '5000-10000': 7500, 'gt10000': 12000,
  };
  function resolveMonthlyBill(): number | null {
    const exact = num('mt-facture-hiver');
    if (exact != null && exact > 0) return exact;
    const range = val('mt-bill');
    if (range && RANGE_MIDPOINT[range] != null) return RANGE_MIDPOINT[range];
    return null;
  }

  // ——— WJ1 : calculer + afficher l'estimation instantanée ———
  let lastKwcLabel = '';
  let lastSavingsLabel = '';
  function computeEstimate() {
    const bill = resolveMonthlyBill();
    const lat = capturePin?.lat;
    const city = (val('mt-city') || addressEl?.value || '').trim() || undefined;
    const est = bill != null ? estimateFromBill(bill, { lat, city }) : null;
    const card = $('mt-estimate-body');
    const note = $('mt-estimate-note');
    const unavail = $('mt-estimate-unavailable');
    if (!est) {
      if (card) card.hidden = true;
      if (note) note.hidden = true;
      if (unavail) unavail.hidden = false;
      lastKwcLabel = '';
      lastSavingsLabel = '';
      return;
    }
    if (card) card.hidden = false;
    if (note) note.hidden = false;
    if (unavail) unavail.hidden = true;
    const kwcEl = $('mt-est-kwc');
    const savEl = $('mt-est-savings');
    const payEl = $('mt-est-payback');
    if (kwcEl) kwcEl.textContent = String(est.kwc);
    const monthly = formatMadRange(est.savingsMonthlyLow, est.savingsMonthlyHigh);
    if (savEl) savEl.textContent = monthly;
    if (payEl) payEl.textContent = est.paybackLabel;
    lastKwcLabel = `${est.kwc} kWc`;
    lastSavingsLabel = `${monthly}/mois`;
  }
  $('mt-estimate')?.addEventListener('click', () => { computeEstimate(); goStep(2); });
  // recalcule à la volée si l'utilisateur revient corriger sa facture
  $('mt-facture-hiver')?.addEventListener('input', computeEstimate);
  $('mt-bill')?.addEventListener('change', computeEstimate);

  // ——— WJ4 : validation INLINE alignée sur validateLead (avant le round-trip) ———
  function setFieldError(inputId: string, errId: string, message: string | null) {
    const input = $(inputId) as HTMLInputElement | null;
    const err = $(errId);
    if (input) input.setAttribute('aria-invalid', message ? 'true' : 'false');
    if (err) {
      err.textContent = message || '';
      err.hidden = !message;
    }
  }
  /** Construit le corps de lead + renvoie les erreurs client (miroir validateLead). */
  function buildBody(): { body: Record<string, unknown>; errors: Record<string, string> } {
    const eteDifferente = eteToggle?.checked === true;
    const consent = ($('mt-consent') as HTMLInputElement | null)?.checked === true;
    const whatsappOptIn = ($('mt-wa-optin') as HTMLInputElement | null)?.checked === true;
    const adresse = (val('mt-city') || addressEl?.value.trim() || fallbackAddrEl?.value.trim() || '').trim();
    const body: Record<string, unknown> = {
      fullName: val('mt-name'),
      phone: val('mt-phone'),
      city: adresse,
      billRange: val('mt-bill'),
      roofType: val('mt-roof'),
      consent,
      whatsappOptIn,
      email: val('mt-email') || undefined,
      factureHiver: num('mt-facture-hiver'),
      factureEte: eteDifferente ? num('mt-facture-ete') : null,
      eteDifferente,
      raccordement: val('mt-raccordement'),
      adresse,
    };
    // WJ4 — repère FACULTATIF : on le joint s'il existe, on ne BLOQUE jamais sans lui.
    if (capturePin) {
      body.roofPoint = capturePin;
      body.gpsLat = capturePin.lat;
      body.gpsLng = capturePin.lng;
    }
    if (captureOutline.length >= 3) body.roofOutline = captureOutline;
    const v = validateLead(body);
    return { body, errors: v.ok ? {} : v.errors };
  }

  function showInlineErrors(errors: Record<string, string>) {
    setFieldError('mt-name', 'mt-name-err', errors.fullName ?? null);
    setFieldError('mt-phone', 'mt-phone-err', errors.phone ?? null);
    setFieldError('mt-city', 'mt-city-err', errors.city ?? null);
    setFieldError('mt-roof', 'mt-roof-err', errors.roofType ?? null);
    setFieldError('mt-bill', 'mt-bill-err', errors.billRange ?? null);
    const cErr = $('mt-consent-err');
    if (cErr) { cErr.textContent = errors.consent ?? ''; cErr.hidden = !errors.consent; }
  }

  // ——— WJ3 : deeplink WhatsApp prérempli avec l'estimation ———
  function buildWaUrl(): string {
    const text = captureWhatsappText({
      fullName: val('mt-name'),
      city: (val('mt-city') || addressEl?.value || '').trim(),
      kwcLabel: lastKwcLabel || undefined,
      savingsLabel: lastSavingsLabel || undefined,
    });
    return whatsappLink(WHATSAPP_LEADS, text);
  }

  // ——— soumission → /api/capture-lead (contrat INCHANGÉ) ———
  const form = $('mt-form') as HTMLFormElement | null;
  const errEl = $('mt-error');
  const okEl = $('mt-success');
  const belowEl = $('mt-belowthreshold');
  const submitBtn = $('mt-submit') as HTMLButtonElement | null;
  let submitted = false;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (errEl) errEl.hidden = true;
    const { body, errors } = buildBody();
    if (Object.keys(errors).length > 0) {
      showInlineErrors(errors);
      if (errEl) {
        errEl.textContent = 'Vérifiez les champs surlignés ci-dessus.';
        errEl.hidden = false;
      }
      // amène l'utilisateur au premier champ en erreur
      const firstId = ['mt-name', 'mt-phone', 'mt-city', 'mt-roof', 'mt-bill']
        .find((id) => $(id)?.getAttribute('aria-invalid') === 'true');
      if (firstId) ($(firstId) as HTMLElement | null)?.focus();
      return;
    }
    showInlineErrors({});

    if (submitBtn) submitBtn.disabled = true;
    try {
      const res = await fetch('/api/capture-lead', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify(body),
      });
      const data = (await res.json().catch(() => ({}))) as { ok?: boolean; qualified?: boolean; errors?: Record<string, string> };
      if (res.ok && data.ok) {
        submitted = true;
        const waUrl = buildWaUrl();
        // WJ5 — réponse HONNÊTE selon le seuil 1 000 MAD (qualified renvoyé par le serveur).
        if (data.qualified) {
          if (okEl) okEl.hidden = false;
          const waLink = $('mt-success-wa') as HTMLAnchorElement | null;
          if (waLink) waLink.href = waUrl;
          // WJ3 — sur mobile, on propose WhatsApp tout de suite (l'opt-in est coché par défaut)
          const wantsWa = ($('mt-wa-optin') as HTMLInputElement | null)?.checked === true;
          if (wantsWa && /Mobi|Android|iPhone/i.test(navigator.userAgent) && !reducedMotion) {
            setTimeout(() => { window.location.href = waUrl; }, 900);
          }
        } else {
          // sous le seuil : PAS de faux « enregistré » — message adapté + WhatsApp.
          if (belowEl) belowEl.hidden = false;
          const belowWa = $('mt-belowthreshold-wa') as HTMLAnchorElement | null;
          if (belowWa) belowWa.href = waUrl;
        }
        // désactive les champs après envoi (sauf les liens WhatsApp).
        Array.from(form.elements).forEach((el) => ((el as HTMLInputElement).disabled = true));
        return;
      }
      // erreurs serveur → réafficher inline si présentes
      if (data.errors) showInlineErrors(data.errors);
      const firstErr = data.errors ? Object.values(data.errors)[0] : null;
      if (errEl) {
        errEl.textContent = firstErr || 'Un champ est manquant ou invalide. Vérifiez vos informations.';
        errEl.hidden = false;
      }
      if (submitBtn) submitBtn.disabled = false;
    } catch {
      if (errEl) {
        errEl.textContent = 'Envoi impossible pour le moment. Réessayez dans un instant.';
        errEl.hidden = false;
      }
      if (submitBtn) submitBtn.disabled = false;
    }
  });

  // ——— WJ7 : récupération d'abandon (exit-intent desktop + retour/onglet caché mobile) ———
  const exitModal = $('mt-exit');
  let exitShown = false;
  function maybeShowExit() {
    if (exitShown || submitted) return;
    // ne déranger que si l'utilisateur a au moins commencé (mode/facture ou step > 0)
    const started2 = step > 0 || resolveMonthlyBill() != null || (capturePin != null);
    if (!started2) return;
    exitShown = true;
    if (exitModal) exitModal.hidden = false;
  }
  // desktop : la souris quitte par le haut
  document.addEventListener('mouseout', (e) => {
    if (!e.relatedTarget && (e as MouseEvent).clientY <= 0) maybeShowExit();
  });
  // mobile : l'onglet passe en arrière-plan
  document.addEventListener('visibilitychange', () => {
    if (document.visibilityState === 'hidden') maybeShowExit();
  });
  $('mt-exit-close')?.addEventListener('click', () => { if (exitModal) exitModal.hidden = true; });
  exitModal?.addEventListener('click', (e) => { if (e.target === exitModal) exitModal.hidden = true; });
  // le CTA WhatsApp d'abandon : prérempli avec l'estimation si déjà calculée + le numéro saisi
  $('mt-exit-wa')?.addEventListener('click', () => {
    const phone = ($('mt-exit-phone') as HTMLInputElement | null)?.value.trim() || '';
    const err = $('mt-exit-err');
    if (phone.length < 6) {
      if (err) { err.textContent = 'Indiquez un numéro pour qu\'on vous réponde.'; err.hidden = false; }
      return;
    }
    if (err) err.hidden = true;
    const text = captureWhatsappText({
      fullName: '',
      city: (val('mt-city') || addressEl?.value || '').trim(),
      kwcLabel: lastKwcLabel || undefined,
      savingsLabel: lastSavingsLabel || undefined,
    }) + ` Mon numéro : ${phone}.`;
    (($('mt-exit-wa') as HTMLAnchorElement).href) = whatsappLink(WHATSAPP_LEADS, text);
  });
</script>
