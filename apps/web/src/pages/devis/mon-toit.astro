    // squelette — cf. announceEstimate ci-dessus).
    announceEstimate(`Votre estimation : ${formatKwc(est.kwc)} kWc, économies estimées ${monthly}/mois, amortissement ${est.paybackLabel}.`);
    return true;
  }
