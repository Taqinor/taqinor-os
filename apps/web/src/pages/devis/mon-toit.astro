<script>
  import { estimateFromBill, formatMadRange } from '../../lib/billEstimate';
  import { captureWhatsappText, whatsappLink } from '../../lib/whatsapp';
  import { WHATSAPP_LEADS } from '../../lib/nap';
  import { validateLead } from '../../lib/lead';

  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const $ = (id: string) => document.getElementById(id);
  const fallback = $('mt-fallback');
  const cityEl = $('mt-city') as HTMLInputElement | null;
  const addressEl = $('rp9-address') as HTMLInputElement | null;
  const fallbackAddrEl = $('mt-fallback-address') as HTMLInputElement | null;

  // ——— état capture (repère / contour) tenu par onCaptureChange ———
  let capturePin: { lat: number; lng: number } | null = null;
  let captureOutline: Array<[number, number]> = [];
  let cityTouched = false;
  cityEl?.addEventListener('input', () => { cityTouched = true; });

  // ——— WJ6/WJ33 : bascule de langue FR/AR (data-i18n) ———
  // WJ30 — la langue active est transmise au webhook (langue_preferee).
  //
  // WJ33 — FIX : `el.textContent = v` APLATISSAIT toute balise imbriquée à
  // l'intérieur d'un élément `data-i18n` (ex. un futur <strong>/<a> perdu au
  // premier passage AR→FR→AR). On bascule désormais par PAIRE DE NŒUDS
  // show/hide : au premier appel, chaque élément `data-i18n` est ENVELOPPÉ de
  // deux <span> — un FR (markup ORIGINAL, capturé une fois via innerHTML avant
  // toute mutation) et un AR (texte simple depuis data-ar, car les libellés AR
  // du DOM sont aujourd'hui du texte brut) — puis on masque/affiche la bonne
  // paire. Aucune balise n'est plus jamais perdue, quel que soit le nombre
  // d'allers-retours FR↔AR.
  let currentLang: 'fr' | 'ar' = 'fr';
  const i18nPairs: Array<{ fr: HTMLElement; ar: HTMLElement }> = [];
  function prepareI18n() {
    document.querySelectorAll<HTMLElement>('[data-i18n]').forEach((el) => {
      const arText = el.dataset.ar;
      if (typeof arText !== 'string') return;
      const frSpan = document.createElement('span');
      // Le markup FR ORIGINAL (pouvant contenir des balises imbriquées) est
      // préservé tel quel — capturé UNE SEULE fois, avant toute mutation.
      frSpan.innerHTML = el.innerHTML;
      const arSpan = document.createElement('span');
      arSpan.textContent = arText;
      arSpan.hidden = true;
      el.textContent = '';
      el.append(frSpan, arSpan);
      i18nPairs.push({ fr: frSpan, ar: arSpan });
    });
  }
  function applyLang(lang: 'fr' | 'ar') {
    const isAr = lang === 'ar';
    currentLang = lang;
    i18nPairs.forEach(({ fr, ar }) => {
      fr.hidden = isAr;
      ar.hidden = !isAr;
    });
    // WJ33 — RTL/langue au niveau DOCUMENT (pas seulement un bloc local) :
    // un lecteur d'écran ou le rendu natif du navigateur doivent voir la vraie
    // langue de la page, pas seulement une classe locale.
    document.documentElement.lang = isAr ? 'ar' : 'fr';
    document.documentElement.dir = isAr ? 'rtl' : 'ltr';
    const root = document.querySelector('section') as HTMLElement | null;
    if (root) {
      root.dir = isAr ? 'rtl' : 'ltr';
      root.style.lineHeight = isAr ? '1.75' : '';
    }
    const frBtn = $('mt-lang-fr');
    const arBtn = $('mt-lang-ar');
    frBtn?.setAttribute('aria-pressed', String(!isAr));
    arBtn?.setAttribute('aria-pressed', String(isAr));
    for (const [btn, on] of [[frBtn, !isAr], [arBtn, isAr]] as const) {
      if (!btn) continue;
      btn.className = on
        ? 'px-3 py-1.5 text-sm font-semibold text-azur-950 bg-brass-400 transition-colors'
        : 'px-3 py-1.5 text-sm font-semibold text-lune-soft transition-colors hover:text-white';
    }
  }
  prepareI18n();
  $('mt-lang-fr')?.addEventListener('click', () => applyLang('fr'));
  $('mt-lang-ar')?.addEventListener('click', () => applyLang('ar'));

  // ——— WJ6 : sélecteur de mode ———
  let mode = 'residentiel';
  document.querySelectorAll<HTMLButtonElement>('.mt-mode').forEach((btn) => {
    btn.addEventListener('click', () => {
      mode = btn.dataset.mode || 'residentiel';
      document.querySelectorAll<HTMLButtonElement>('.mt-mode').forEach((b) => {
        const on = b === btn;
        b.setAttribute('aria-pressed', String(on));
        b.classList.toggle('border-brass-400', on);
        b.classList.toggle('border-white/15', !on);
      });
    });
  });
  // état initial : marquer le mode résidentiel sélectionné visuellement.
  document.querySelector<HTMLButtonElement>('.mt-mode')?.classList.add('border-brass-400');

  // ——— WJ31 : puce à bascule unique (ombrage) — un seul choix actif à la fois ———
  let ombrage = '';
  document.querySelectorAll<HTMLButtonElement>('.mt-ombrage').forEach((btn) => {
    btn.addEventListener('click', () => {
      const same = ombrage === btn.dataset.value;
      ombrage = same ? '' : (btn.dataset.value || '');
      document.querySelectorAll<HTMLButtonElement>('.mt-ombrage').forEach((b) => {
        const on = !same && b === btn;
        b.setAttribute('aria-pressed', String(on));
        b.classList.toggle('border-brass-400', on);
        b.classList.toggle('border-white/15', !on);
      });
    });
  });

  // ——— WJ31 : puces multi-sélection (charges futures) ———
  const futureLoads = new Set<string>();
  document.querySelectorAll<HTMLButtonElement>('.mt-future-load').forEach((btn) => {
    btn.addEventListener('click', () => {
      const v = btn.dataset.value || '';
      const on = !futureLoads.has(v);
      if (on) futureLoads.add(v); else futureLoads.delete(v);
      btn.setAttribute('aria-pressed', String(on));
      btn.classList.toggle('border-brass-400', on);
      btn.classList.toggle('border-white/15', !on);
    });
  });

  // ——— WJ31 : photo compteur/facture — capturée EN LOCAL, JAMAIS uploadée ———
  // Pas d'endpoint d'upload aujourd'hui (cf. PLAN2 QK6 OCR) : on garde un simple
  // signal booléen (hasMeterPhoto) et on encourage l'envoi direct sur WhatsApp.
  let hasMeterPhoto = false;
  const meterPhotoInput = $('mt-meter-photo') as HTMLInputElement | null;
  meterPhotoInput?.addEventListener('change', () => {
    hasMeterPhoto = !!(meterPhotoInput.files && meterPhotoInput.files.length > 0);
  });

  // ——— WJ6 : assistant multi-étapes + barre de progression ———
  let step = 0;
  const panels = [0, 1, 2].map((i) => $(`mt-panel-${i}`));
  function renderStep() {
    panels.forEach((p, i) => { if (p) p.hidden = i !== step; });
    document.querySelectorAll<HTMLElement>('.mt-step').forEach((li, i) => {
      const bar = li.querySelector<HTMLElement>('.mt-step-bar');
      const label = li.querySelector<HTMLElement>('.mt-step-label');
      const active = i <= step;
      if (bar) bar.className = `h-1.5 w-full rounded-full mt-step-bar transition-colors ${active ? 'bg-brass-400' : 'bg-white/10'}`;
      if (label) label.classList.toggle('text-white', i === step);
    });
    const root = document.querySelector('section');
    root?.scrollIntoView({ behavior: reducedMotion ? 'auto' : 'smooth', block: 'start' });
  }
  function goStep(n: number) { step = Math.max(0, Math.min(2, n)); renderStep(); }
  $('mt-next-0')?.addEventListener('click', () => goStep(1));
  $('mt-back-1')?.addEventListener('click', () => goStep(0));
  $('mt-back-2')?.addEventListener('click', () => goStep(1));
  renderStep();

  // ——— boot carte (captureOnly). Repli sans clé carte AUTORISE la suite (WJ4) ———
  let started = false;
  async function boot(key: string, mapboxToken: string) {
    if (started) return;
    started = true;
    try {
      const mod = await import('../../scripts/roof-tool-pro11.ts');
      mod.initRoofToolPro8({
        maptilerKey: key,
        mapboxToken: mapboxToken || undefined,
        reducedMotion,
        captureOnly: true,
        onCaptureChange: (s) => {
          capturePin = s.pin;
          captureOutline = s.outline;
          if (cityEl && !cityTouched) {
            const fromMap = (s.address && s.address.trim()) || addressEl?.value.trim() || '';
            if (fromMap) cityEl.value = fromMap;
          }
          // WJ2 — le contour peut arriver/changer APRÈS le calcul d'estimation :
          // on ré-évalue l'éligibilité du bouton « voir les panneaux » à chaque
          // changement de tracé (fonction déclarée plus bas, hissée par `function`).
          updatePanels3dVisibility();
        },
      });
    } catch {
      started = false;
      showFallback();
    }
  }
  // WJ4 — repli carte : on montre le champ d'adresse en clair ET on garde la suite ouverte.
  function showFallback() { if (fallback) fallback.hidden = false; }

  (async () => {
    try {
      const res = await fetch('/api/roof-config');
      const cfg = (await res.json()) as { available?: boolean; maptilerKey?: string; mapboxToken?: string };
      if (!cfg.available || !cfg.maptilerKey) { showFallback(); return; }
      void boot(cfg.maptilerKey, cfg.mapboxToken || '');
    } catch {
      showFallback();
    }
  })();

  // ——— helpers de saisie ———
  const val = (id: string) => (($(id) as HTMLInputElement | HTMLSelectElement | null)?.value ?? '');
  const num = (id: string): number | null => {
    const raw = val(id).trim();
    if (raw === '') return null;
    const n = Number(raw);
    return Number.isFinite(n) ? n : null;
  };

  // toggle été ≠ hiver
  const eteToggle = $('mt-ete-differente') as HTMLInputElement | null;
  const eteWrap = $('mt-facture-ete-wrap') as HTMLElement | null;
  const eteInput = $('mt-facture-ete') as HTMLInputElement | null;
  eteToggle?.addEventListener('change', () => {
    const on = eteToggle.checked === true;
    if (eteWrap) eteWrap.hidden = !on;
    if (!on && eteInput) eteInput.value = '';
  });

  // ——— WJ1 : résoudre la facture mensuelle (montant exact prioritaire, sinon tranche) ———
  /** Milieu indicatif d'une tranche (MAD) — uniquement pour ESTIMER quand le montant
   *  exact est absent ; ne sert jamais au seuil (le seuil reste sur billRange/qualifies). */
  const RANGE_MIDPOINT: Record<string, number> = {
    'lt800': 600, '800-1000': 900, '1000-1500': 1250, '1500-3000': 2250,
    '3000-5000': 4000, '5000-10000': 7500, 'gt10000': 12000,
  };
  function resolveMonthlyBill(): number | null {
    const exact = num('mt-facture-hiver');
    if (exact != null && exact > 0) return exact;
    const range = val('mt-bill');
    if (range && RANGE_MIDPOINT[range] != null) return RANGE_MIDPOINT[range];
    return null;
  }

  // ——— WJ1 : calculer + afficher l'estimation instantanée ———
  let lastKwcLabel = '';
  let lastSavingsLabel = '';
  let lastKwc: number | null = null;
  function computeEstimate() {
    const bill = resolveMonthlyBill();
    const lat = capturePin?.lat;
    const city = (val('mt-city') || addressEl?.value || '').trim() || undefined;
    const est = bill != null ? estimateFromBill(bill, { lat, city }) : null;
    const card = $('mt-estimate-body');
    const note = $('mt-estimate-note');
    const unavail = $('mt-estimate-unavailable');
    if (!est) {
      if (card) card.hidden = true;
      if (note) note.hidden = true;
      if (unavail) unavail.hidden = false;
      lastKwcLabel = '';
      lastSavingsLabel = '';
      lastKwc = null;
      updatePanels3dVisibility();
      return;
    }
    if (card) card.hidden = false;
    if (note) note.hidden = false;
    if (unavail) unavail.hidden = true;
    const kwcEl = $('mt-est-kwc');
    const savEl = $('mt-est-savings');
    const payEl = $('mt-est-payback');
    if (kwcEl) kwcEl.textContent = String(est.kwc);
    const monthly = formatMadRange(est.savingsMonthlyLow, est.savingsMonthlyHigh);
    if (savEl) savEl.textContent = monthly;
    if (payEl) payEl.textContent = est.paybackLabel;
    lastKwcLabel = `${est.kwc} kWc`;
    lastSavingsLabel = `${monthly}/mois`;
    lastKwc = est.kwc;
    updatePanels3dVisibility();
  }
  $('mt-estimate')?.addEventListener('click', () => { computeEstimate(); goStep(2); });
  // recalcule à la volée si l'utilisateur revient corriger sa facture
  $('mt-facture-hiver')?.addEventListener('input', computeEstimate);
  $('mt-bill')?.addEventListener('change', computeEstimate);

  // ——— WJ2 : « voir les panneaux sur votre toit » — facultatif, lazy, dégrade
  // proprement (pas de WebGL / pas de contour tracé → le bloc reste masqué). ———
  const panels3dBlock = $('mt-panels3d') as HTMLElement | null;
  const panels3dStage = $('mt-panels3d-stage') as HTMLElement | null;
  const panels3dOverlay = $('mt-panels3d-overlay') as HTMLElement | null;
  const panels3dStart = $('mt-panels3d-start') as HTMLButtonElement | null;
  const panels3dHint = $('mt-panels3d-hint') as HTMLElement | null;
  let panels3dStarted = false;

  /** Le bouton n'apparaît QUE si un contour (≥3 sommets) a été tracé ET qu'un
   *  kWc est disponible — sinon rien de significatif à montrer (pas de faux
   *  aperçu sur un simple repère). */
  function updatePanels3dVisibility() {
    if (!panels3dBlock) return;
    const eligible = captureOutline.length >= 3 && lastKwc != null;
    panels3dBlock.hidden = !eligible;
  }

  async function startPanels3d() {
    if (panels3dStarted || !panels3dStage || lastKwc == null) return;
    panels3dStarted = true;
    try {
      const [{ capturePreviewLayout, buildViewerModel }, { createRoofViewer }] = await Promise.all([
        import('../../lib/proposition'),
        import('../../scripts/roofPro11/viewerOnly'),
      ]);
      const layout = capturePreviewLayout(captureOutline, lastKwc);
      const model = layout ? buildViewerModel(layout) : null;
      if (!model) throw new Error('modèle indisponible');
      const nav = navigator as Navigator & { deviceMemory?: number; connection?: { saveData?: boolean } };
      const lowEnd = (nav.deviceMemory != null && nav.deviceMemory <= 4) || (navigator.hardwareConcurrency || 8) <= 4;
      const handle = createRoofViewer(panels3dStage, model, {
        reducedMotion,
        lowEnd,
        onReady: () => {
          if (panels3dOverlay) panels3dOverlay.hidden = true;
          if (panels3dHint) panels3dHint.hidden = false;
        },
        onFail: () => { panels3dStarted = false; },
      });
      if (!handle) throw new Error('WebGL indisponible');
    } catch {
      // Repli gracieux : le bouton reste, avec un message sobre — jamais de blocage.
      panels3dStarted = false;
      if (panels3dOverlay) {
        const btn = panels3dStart;
        if (btn) {
          btn.disabled = true;
          btn.textContent = currentLang === 'ar' ? 'المعاينة ثلاثية الأبعاد غير متوفرة' : 'Aperçu 3D indisponible sur cet appareil';
        }
      }
    }
  }
  panels3dStart?.addEventListener('click', () => { void startPanels3d(); });

  // ——— WJ4 : validation INLINE alignée sur validateLead (avant le round-trip) ———
  function setFieldError(inputId: string, errId: string, message: string | null) {
    const input = $(inputId) as HTMLInputElement | null;
    const err = $(errId);
    if (input) input.setAttribute('aria-invalid', message ? 'true' : 'false');
    if (err) {
      err.textContent = message || '';
      err.hidden = !message;
    }
  }
  /** Construit le corps de lead + renvoie les erreurs client (miroir validateLead). */
  function buildBody(): { body: Record<string, unknown>; errors: Record<string, string> } {
    const eteDifferente = eteToggle?.checked === true;
    const consent = ($('mt-consent') as HTMLInputElement | null)?.checked === true;
    const whatsappOptIn = ($('mt-wa-optin') as HTMLInputElement | null)?.checked === true;
    const adresse = (val('mt-city') || addressEl?.value.trim() || fallbackAddrEl?.value.trim() || '').trim();
    const body: Record<string, unknown> = {
      fullName: val('mt-name'),
      phone: val('mt-phone'),
      city: adresse,
      billRange: val('mt-bill'),
      roofType: val('mt-roof'),
      consent,
      whatsappOptIn,
      email: val('mt-email') || undefined,
      factureHiver: num('mt-facture-hiver'),
      factureEte: eteDifferente ? num('mt-facture-ete') : null,
      eteDifferente,
      raccordement: val('mt-raccordement'),
      adresse,
      // WJ30 — le type de projet et la langue active partent aussi au webhook.
      mode,
      langue_preferee: currentLang,
      // WJ31 — questions de capture élargies, TOUTES facultatives (déjà validées
      // une à une côté serveur : un champ vide/malformé est simplement écarté).
      distributeur: val('mt-distributeur') || undefined,
      billKwh: num('mt-bill-kwh'),
      ombrage: ombrage || undefined,
      roofAgeYears: num('mt-roof-age'),
      futureLoads: futureLoads.size > 0 ? Array.from(futureLoads) : undefined,
      batteryInterest: ($('mt-battery-interest') as HTMLInputElement | null)?.checked === true,
      occupantType: val('mt-occupant-type') || undefined,
      projectTiming: val('mt-project-timing') || undefined,
      financingIntent: val('mt-financing-intent') || undefined,
      hasMeterPhoto,
    };
    // WJ4 — repère FACULTATIF : on le joint s'il existe, on ne BLOQUE jamais sans lui.
    if (capturePin) {
      body.roofPoint = capturePin;
      body.gpsLat = capturePin.lat;
      body.gpsLng = capturePin.lng;
    }
    if (captureOutline.length >= 3) body.roofOutline = captureOutline;
    const v = validateLead(body);
    return { body, errors: v.ok ? {} : v.errors };
  }

  function showInlineErrors(errors: Record<string, string>) {
    setFieldError('mt-name', 'mt-name-err', errors.fullName ?? null);
    setFieldError('mt-phone', 'mt-phone-err', errors.phone ?? null);
    setFieldError('mt-city', 'mt-city-err', errors.city ?? null);
    setFieldError('mt-roof', 'mt-roof-err', errors.roofType ?? null);
    setFieldError('mt-bill', 'mt-bill-err', errors.billRange ?? null);
    const cErr = $('mt-consent-err');
    if (cErr) { cErr.textContent = errors.consent ?? ''; cErr.hidden = !errors.consent; }
  }

  // ——— WJ3 : deeplink WhatsApp prérempli avec l'estimation ———
  function buildWaUrl(): string {
    const text = captureWhatsappText({
      fullName: val('mt-name'),
      city: (val('mt-city') || addressEl?.value || '').trim(),
      kwcLabel: lastKwcLabel || undefined,
      savingsLabel: lastSavingsLabel || undefined,
    });
    return whatsappLink(WHATSAPP_LEADS, text);
  }

  // ——— soumission → /api/capture-lead (contrat INCHANGÉ) ———
  const form = $('mt-form') as HTMLFormElement | null;
  const errEl = $('mt-error');
  const okEl = $('mt-success');
  const belowEl = $('mt-belowthreshold');
  const submitBtn = $('mt-submit') as HTMLButtonElement | null;
  let submitted = false;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (errEl) errEl.hidden = true;
    const { body, errors } = buildBody();
    if (Object.keys(errors).length > 0) {
      showInlineErrors(errors);
      if (errEl) {
        errEl.textContent = 'Vérifiez les champs surlignés ci-dessus.';
        errEl.hidden = false;
      }
      // amène l'utilisateur au premier champ en erreur
      const firstId = ['mt-name', 'mt-phone', 'mt-city', 'mt-roof', 'mt-bill']
        .find((id) => $(id)?.getAttribute('aria-invalid') === 'true');
      if (firstId) ($(firstId) as HTMLElement | null)?.focus();
      return;
    }
    showInlineErrors({});

    if (submitBtn) submitBtn.disabled = true;
    try {
      const res = await fetch('/api/capture-lead', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify(body),
      });
      const data = (await res.json().catch(() => ({}))) as { ok?: boolean; qualified?: boolean; errors?: Record<string, string> };
      if (res.ok && data.ok) {
        submitted = true;
        const waUrl = buildWaUrl();
        // WJ5 — réponse HONNÊTE selon le seuil 1 000 MAD (qualified renvoyé par le serveur).
        if (data.qualified) {
          if (okEl) okEl.hidden = false;
          const waLink = $('mt-success-wa') as HTMLAnchorElement | null;
          if (waLink) waLink.href = waUrl;
          // WJ3 — sur mobile, on propose WhatsApp tout de suite (l'opt-in est coché par défaut)
          const wantsWa = ($('mt-wa-optin') as HTMLInputElement | null)?.checked === true;
          if (wantsWa && /Mobi|Android|iPhone/i.test(navigator.userAgent) && !reducedMotion) {
            setTimeout(() => { window.location.href = waUrl; }, 900);
          }
        } else {
          // sous le seuil : PAS de faux « enregistré » — message adapté + WhatsApp.
          if (belowEl) belowEl.hidden = false;
          const belowWa = $('mt-belowthreshold-wa') as HTMLAnchorElement | null;
          if (belowWa) belowWa.href = waUrl;
        }
        // désactive les champs après envoi (sauf les liens WhatsApp).
        Array.from(form.elements).forEach((el) => ((el as HTMLInputElement).disabled = true));
        return;
      }
      // erreurs serveur → réafficher inline si présentes
      if (data.errors) showInlineErrors(data.errors);
      const firstErr = data.errors ? Object.values(data.errors)[0] : null;
      if (errEl) {
        errEl.textContent = firstErr || 'Un champ est manquant ou invalide. Vérifiez vos informations.';
        errEl.hidden = false;
      }
      if (submitBtn) submitBtn.disabled = false;
    } catch {
      if (errEl) {
        errEl.textContent = 'Envoi impossible pour le moment. Réessayez dans un instant.';
        errEl.hidden = false;
      }
      if (submitBtn) submitBtn.disabled = false;
    }
  });

  // ——— WJ7/WJ33 : récupération d'abandon (exit-intent desktop + retour/onglet caché mobile) ———
  const exitModal = $('mt-exit') as HTMLElement | null;
  const exitPhoneInput = $('mt-exit-phone') as HTMLInputElement | null;
  const exitWaLink = $('mt-exit-wa') as HTMLAnchorElement | null;
  let exitShown = false;
  let exitTriggerEl: HTMLElement | null = null; // WJ33 — pour restaurer le focus à la fermeture

  /** WJ33 — construit (ou reconstruit) le lien WhatsApp d'abandon depuis l'état actuel. */
  function buildExitWaHref(): string {
    const phone = exitPhoneInput?.value.trim() || '';
    const text = captureWhatsappText({
      fullName: '',
      city: (val('mt-city') || addressEl?.value || '').trim(),
      kwcLabel: lastKwcLabel || undefined,
      savingsLabel: lastSavingsLabel || undefined,
    }) + (phone.length >= 6 ? ` Mon numéro : ${phone}.` : '');
    return whatsappLink(WHATSAPP_LEADS, text);
  }

  function maybeShowExit(triggerEl: HTMLElement | null = null) {
    if (exitShown || submitted) return;
    // ne déranger que si l'utilisateur a au moins commencé (mode/facture ou step > 0)
    const started2 = step > 0 || resolveMonthlyBill() != null || (capturePin != null);
    if (!started2) return;
    exitShown = true;
    exitTriggerEl = triggerEl ?? (document.activeElement as HTMLElement | null);
    if (exitWaLink) exitWaLink.href = buildExitWaHref();
    if (exitModal) {
      exitModal.hidden = false;
      // WJ33 — focus initial DANS la modale (premier champ interactif).
      exitPhoneInput?.focus();
    }
  }
  function closeExit() {
    if (!exitModal || exitModal.hidden) return;
    exitModal.hidden = true;
    // WJ33 — restauration du focus vers l'élément qui a déclenché l'ouverture
    // (ou, à défaut, un point d'ancrage stable de la page).
    (exitTriggerEl && document.contains(exitTriggerEl) ? exitTriggerEl : $('mt-lang-fr'))?.focus();
    exitTriggerEl = null;
  }
  // desktop : la souris quitte par le haut
  document.addEventListener('mouseout', (e) => {
    if (!e.relatedTarget && (e as MouseEvent).clientY <= 0) maybeShowExit();
  });
  // mobile : l'onglet passe en arrière-plan
  document.addEventListener('visibilitychange', () => {
    if (document.visibilityState === 'hidden') maybeShowExit();
  });
  $('mt-exit-close')?.addEventListener('click', () => closeExit());
  exitModal?.addEventListener('click', (e) => { if (e.target === exitModal) closeExit(); });

  // WJ33 — clavier : Esc ferme + focus trap (Tab/Shift+Tab restent DANS la modale).
  exitModal?.addEventListener('keydown', (e) => {
    const ke = e as KeyboardEvent;
    if (ke.key === 'Escape') { closeExit(); return; }
    if (ke.key !== 'Tab' || !exitModal) return;
    const focusable = Array.from(
      exitModal.querySelectorAll<HTMLElement>('a[href], button:not([disabled]), input:not([disabled]), [tabindex]:not([tabindex="-1"])'),
    ).filter((el) => el.offsetParent !== null || el === document.activeElement);
    if (focusable.length === 0) return;
    const first = focusable[0];
    const last = focusable[focusable.length - 1];
    const active = document.activeElement as HTMLElement | null;
    if (ke.shiftKey && active === first) {
      ke.preventDefault();
      last.focus();
    } else if (!ke.shiftKey && active === last) {
      ke.preventDefault();
      first.focus();
    }
  });

  // WJ33 — le CTA WhatsApp d'abandon : le lien `href` est reconstruit à CHAQUE
  // saisie (pas seulement au clic), pour rester correct si l'utilisateur
  // ouvre WhatsApp via un clic droit / « copier le lien » avant de finir de taper.
  exitPhoneInput?.addEventListener('input', () => {
    const err = $('mt-exit-err');
    if (err) err.hidden = true;
    if (exitWaLink) exitWaLink.href = buildExitWaHref();
  });
  exitWaLink?.addEventListener('click', (e) => {
    const phone = exitPhoneInput?.value.trim() || '';
    const err = $('mt-exit-err');
    if (phone.length < 6) {
      e.preventDefault();
      if (err) { err.textContent = 'Indiquez un numéro pour qu\'on vous réponde.'; err.hidden = false; }
      return;
    }
    if (err) err.hidden = true;
  });
</script>
