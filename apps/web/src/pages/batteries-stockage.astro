---
/**
 * Batteries & stockage (W24 / W130). Page publique INDEXÉE. Reprend strictement les
 * faits déjà publiés : le raisonnement autoconsommation/stockage du guide
 * « Faut-il des batteries ? » et les faits matériel Dyness de la page
 * Équipement (réf. BAT). AUCUNE capacité, AUCUN prix, AUCUNE spec inventés.
 * Les kWh des installs (15/10/5 kWh) sont déjà publiés dans realisations.ts.
 * W130 : bloc FAQ visuel via <Faq schema={false}> — /faq reste l'unique FAQPage.
 * Chiffres tracés sur CONTENT_SEO_NOTES.md §1 + §7 (PUBLISH-SAFE).
 */
import Layout from '../layouts/Layout.astro';
import V2Enhance from '../components/V2Enhance.astro';
import Article33Ribbon from '../components/Article33Ribbon.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import CtaBand from '../components/CtaBand.astro';
import StickyCta from '../components/StickyCta.astro';
import Faq from '../components/Faq.astro';
import ServiceWarrantyTable from '../components/ServiceWarrantyTable.astro';
import { serviceFaqItems } from '../lib/serviceFaq';

// Faits matériel — identiques à la page Équipement (réf. BAT), source publiée.
const specs = [
  { item: 'Chimie lithium-fer-phosphate (LFP)', detail: 'Dyness DL5.0C / DL5.0C PRO' },
  { item: 'Durée de vie', detail: '6 000 cycles à 90 % de profondeur de décharge' },
  { item: 'Capacité modulaire', detail: 'Modules de 5 kWh extensibles : 5 à 15 kWh et plus' },
  { item: 'Communication', detail: 'CAN BMS native avec les onduleurs hybrides Deye' },
  { item: 'Certifications', detail: 'CE · IEC 62619 · UN38.3' },
  { item: 'Garantie', detail: '10 ans, capacité conservée ≥ 70 %' },
];

// Cas d'usage — strictement le raisonnement du guide « Faut-il des batteries ? ».
const cas = [
  {
    k: 'Sans stockage',
    title: 'Consommation principalement diurne',
    body: "Quand l'essentiel de votre consommation tombe en journée, le meilleur kWh est celui que vos panneaux alimentent à l'instant même — sans détour par une batterie, sans pertes de charge ni de décharge. C'est le cas des foyers actifs en journée et des sites dont l'activité suit le soleil : pompe, froid, machines, climatisation.",
  },
  {
    k: 'Avec stockage',
    title: 'Consommation nocturne ou continuité de service',
    body: "La batterie devient utile quand votre pic de consommation arrive une fois le soleil couché, ou quand une coupure ne doit rien arrêter. Le surplus produit à midi est mis de côté et restitué le soir, à l'heure où le réseau, lui, se facture au prix fort.",
  },
];

// Installations réelles incluant du stockage — kWh déjà publiés (realisations.ts).
const installs = [
  { kwh: '15 kWh', where: 'El Jadida', ref: '468' },
  { kwh: '10 kWh', where: 'Casablanca', ref: '400' },
  { kwh: '5 kWh', where: 'El Jadida', ref: '236' },
];

// W334 — 4 panneaux jour/soir/coupure/nuit : reprend STRICTEMENT le
// raisonnement déjà publié plus haut (cas « Sans stockage » / « Avec stockage »)
// et dans le guide « Faut-il des batteries ? » — aucun flux ni chiffre nouveau,
// seule la mise en image change. Chaque flux actif est listé en toutes lettres
// pour l'accessibilité (la figure reste lisible sans le SVG).
const flowPanels = [
  {
    k: 'Jour',
    title: 'Le soleil alimente la maison',
    flows: ['Solaire → Consommation', 'Solaire → Batterie (surplus)'],
    note: 'Le meilleur kWh est celui qui part direct des panneaux vers vos appareils, sans détour.',
  },
  {
    k: 'Soir',
    title: 'La batterie prend le relais',
    flows: ['Batterie → Consommation'],
    note: 'Le surplus stocké à midi couvre le pic du soir, à l’heure où le réseau facture le plus cher.',
  },
  {
    k: 'Coupure',
    title: 'Le circuit de secours tient',
    flows: ['Solaire → Batterie (si jour)', 'Batterie → Consommation (circuits EPS)'],
    note: 'L’onduleur hybride isole un circuit de secours ; réseau coupé, la maison ne l’est pas.',
  },
  {
    k: 'Nuit',
    title: 'Ce qu’il reste distribue',
    flows: ['Batterie → Consommation', 'Réseau → Consommation (si batterie vide)'],
    note: 'Batterie épuisée, le réseau reprend le relais — rien d’exceptionnel, juste la suite logique.',
  },
];

// FAQ W130 — questions tracées sur CONTENT_SEO_NOTES.md §7 + §1 (PUBLISH-SAFE).
// schema={false} → /faq reste l'unique page portant le FAQPage JSON-LD.
// W263 — les 5 questions d'usage ci-dessous portent désormais un cluster
// dédié (« Bien choisir sa batterie ») ; la banque partagée
// (entretien/prix/inclus-exclus/délais/garanties, cf. lib/serviceFaq.ts) est
// concaténée à la suite, dans le même bloc <Faq> pour éviter une deuxième
// section FAQ sur la page.
const usageCluster = 'Bien choisir sa batterie';
const faqItems = [
  {
    cluster: usageCluster,
    q: "Ai-je vraiment besoin d'une batterie avec mes panneaux solaires ?",
    a: "Pas nécessairement. Si vous consommez l'essentiel de votre électricité en journée — appareils de froid, pompe, climatisation, machines — vos panneaux alimentent directement vos charges et une batterie n'ajouterait qu'un coût et des pertes de conversion. Elle devient utile si votre pic de consommation tombe le soir, ou si vous avez besoin de continuité de service lors des coupures. Nous analysons votre courbe de consommation heure par heure avant toute recommandation.",
  },
  {
    cluster: usageCluster,
    q: "Quelle est la durée de vie d'une batterie LFP ?",
    a: "Sur le papier, une Dyness LFP tient 6 000 cycles à 90 % de profondeur de décharge, garantie 10 ans avec ≥ 70 % de capacité conservée. Comptez un cycle par jour : les 6 000 cycles couvrent à eux seuls plus de seize ans. Mais une batterie vieillit aussi à l'arrêt — environ 1 à 2 % de capacité perdue par an, même quand on ne s'en sert pas. C'est ce vieillissement calendaire qui finit le plus souvent par décider, et qui ramène la durée utile réelle à 12-15 ans sous le climat marocain. Le bon réflexe pour grappiller ces années : une batterie à l'ombre, ventilée, qui reste entre 15 et 35 °C.",
  },
  {
    cluster: usageCluster,
    q: "Quelle taille de batterie choisir ? (5–10 kWh, 10–20 kWh ou 20 kWh+)",
    a: "Les paliers correspondent à des besoins distincts. 5 à 10 kWh : secours nocturne basique ou recharge de quelques appareils essentiels lors d'une coupure. 10 à 20 kWh : autoconsommation du soir complète pour un foyer moyen — le surplus solaire de la journée couvre la majorité de la consommation nocturne. 20 kWh et plus : quasi-autonomie, sites éloignés ou besoin de 2 à 3 jours d'autonomie sans soleil. Nos modules Dyness s'empilent par tranches de 5 kWh — on cale la capacité sur le creux du soir à couvrir, pas sur un palier commercial. Un guide dédié détaille la méthode de calcul.",
  },
  {
    cluster: usageCluster,
    q: "La batterie me protège-t-elle des coupures de courant ?",
    a: "Oui, si l'onduleur hybride est configuré en mode EPS (Emergency Power Supply). Les onduleurs Deye SG-series assurent un basculement quasi instantané (environ 4 ms) sans boîtier supplémentaire — comparable à un onduleur UPS. La puissance disponible pendant une coupure dépend de la capacité installée et des charges raccordées sur le circuit de secours. À ne pas confondre avec un simple onduleur réseau (« on-grid ») qui coupe lui aussi lors d'une coupure, par sécurité.",
  },
  {
    cluster: usageCluster,
    q: "Vaut-il mieux stocker son surplus ou le revendre au réseau au Maroc ?",
    a: "Au Maroc, la loi 82-21 (en vigueur depuis juin 2026) plafonne l'injection à 20 % de la production annuelle, et le tarif de rachat ANRE est de 0,18 à 0,21 DH/kWh selon l'heure. Or, un kWh acheté sur le réseau vous coûte entre 0,90 DH (première tranche) et 1,66 DH (forte consommation). Autrement dit, un kWh stocké et autoconsommé le soir vaut 4 à 9 fois plus qu'un kWh vendu au réseau. L'ordre de priorité est donc : (1) consommer directement en journée, (2) stocker pour le soir, (3) exporter le solde plafonné à 20 %. Ne surdimensionnez pas vos batteries pour exporter davantage — ce n'est pas rentable.",
  },
  ...serviceFaqItems('batteries-stockage', 'fr'),
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Batteries & stockage',
  serviceType: 'Stockage d\'énergie solaire',
  description: 'Stockage solaire au Maroc : batteries lithium-fer-phosphate (LFP) Dyness, dimensionnées par l\'étude selon le profil de consommation — autoconsommation diurne ou continuité de service.',
  provider: { '@type': 'Organization', name: 'Taqinor', url: 'https://taqinor.ma' },
  areaServed: { '@type': 'Country', name: 'Maroc' },
};
---

<Layout
  title="Batteries solaires Dyness LFP au Maroc : 6 000 cycles, 90 % DoD | Taqinor"
  description="Stockage solaire au Maroc : batteries Dyness lithium-fer-phosphate, plus de 6 000 cycles à 90 % de profondeur de décharge, modules de 5 kWh extensibles, dialogue CAN BMS natif avec les onduleurs hybrides Deye, garantie 10 ans. La vraie question reste votre profil de consommation : si vous consommez surtout en journée, la batterie attend souvent son tour."
  ogSlug="batteries-stockage"
>
  <div class="v2">
    <V2Enhance />
    <Article33Ribbon />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <Breadcrumb items={[{ label: 'Accueil', href: '/' }, { label: 'Batteries & stockage' }]} />

    {/* ── HÉROS ÉDITORIAL — discipline laiton #2 : eyebrow rétrogradé en lune,
        l'or reste réservé aux chiffres .lum et au CTA. Rythme via .section-lg. ── */}
    <section class="section-lg px-4 pb-10 text-white">
      <div class="mx-auto max-w-3xl">
        <p class="tech-label v2-kicker rule-brass cine-in text-lune">Stockage d'énergie</p>
        <h1 class="display v2-page-title cine-in cine-in-1 mt-6">Batteries &amp; stockage</h1>
        <p class="v2-lead cine-in cine-in-2 mt-6 max-w-xl text-white/85">
          Une batterie LFP Dyness encaisse 6 000 cycles à 90 % de profondeur de décharge ; elle
          durera. La question qui décide n'est pourtant pas <em>laquelle</em> mais <em>quand</em>
          vous consommez. Si l'essentiel de votre courant part en journée, ce que vous payez pour
          stocker, vous le payez surtout pour rien.
        </p>
      </div>
    </section>

    <!-- Quand le stockage se justifie / quand non -->
    <section class="section px-4">
      <div class="mx-auto max-w-6xl">
        {/* Eyebrow rétrogradé en lune (discipline laiton #2) */}
        <p class="tech-label v2-kicker rule-brass text-lune">Le bon arbitrage</p>
        <h2 class="display v2-section-title mt-5 text-white">Quand une batterie se justifie — et quand non</h2>
        <div class="mt-12 grid gap-6 md:grid-cols-2" data-stagger>
          {cas.map((c, i) => (
            <div class="v2-rise cine-card flex flex-col p-7" style={`--v2-i:${i}`}>
              {/* Sous-libellé de carte rétrogradé en lune (l'or reste aux chiffres/CTA) */}
              <p class="tech-label text-lune">{c.k}</p>
              <h3 class="display mt-2 text-2xl text-white">{c.title}</h3>
              <p class="mt-3 flex-1 text-sm leading-relaxed text-lune-soft">{c.body}</p>
            </div>
          ))}
        </div>
        {/* Filet rétrogradé en azur + lien secondaire en lune/azur (discipline #2) */}
        <p class="mt-8 max-w-2xl border-l-4 border-azur-200/50 pl-4 text-sm leading-relaxed text-lune-soft">
          Notre intérêt commercial serait de vous en vendre une. On préfère commencer par lire
          votre courbe de consommation heure par heure : c'est elle qui tranche si le stockage se
          rentabilise et, le cas échéant, combien de kWh suffisent vraiment. Bien souvent, la
          réponse honnête tient en deux mots — pas maintenant.
          <a href="/guides/faut-il-des-batteries" class="border-b-2 border-azur-200/60 pb-0.5 font-bold text-azur-200 transition-colors hover:text-white">Lire le guide complet →</a>
        </p>
      </div>
    </section>

    <!-- W334 — Diagramme de flux 24h : jour/soir/coupure/nuit (solaire→consommation→batterie→réseau) -->
    <section class="section px-4">
      <div class="mx-auto max-w-6xl">
        <p class="tech-label v2-kicker rule-brass text-lune">En image</p>
        <h2 class="display v2-section-title mt-5 text-white">Une journée avec batterie, en quatre temps</h2>
        <p class="v2-lead mt-4 max-w-2xl text-lune-soft">
          Le même principe revient quatre fois par jour : produire, consommer, stocker le surplus,
          restituer quand il le faut.
        </p>
        <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4" data-stagger>
          {flowPanels.map((p, i) => (
            <figure class="v2-rise cine-card flex flex-col p-6" style={`--v2-i:${i}`}>
              <figcaption>
                <p class="tech-label text-lune">{p.k}</p>
                <h3 class="display mt-2 text-lg text-white">{p.title}</h3>
              </figcaption>
              <svg
                class="mt-5 w-full"
                viewBox="0 0 220 200"
                role="img"
                aria-label={`${p.title} — flux : ${p.flows.join(', ')}`}
              >
                {/* Soleil */}
                <g transform="translate(110,30)" opacity={p.k === 'Nuit' ? '0.28' : '1'}>
                  <circle r="14" fill="none" stroke="#e8b54a" stroke-width="2.5" />
                  {Array.from({ length: 8 }).map((_, r) => (
                    <line
                      x1="0" y1="-20" x2="0" y2="-26"
                      stroke="#e8b54a" stroke-width="2.5" stroke-linecap="round"
                      transform={`rotate(${r * 45})`}
                    />
                  ))}
                </g>
                {/* Maison (consommation) */}
                <g transform="translate(30,100)">
                  <path d="M-16 8 L-16 -6 L0 -18 L16 -6 L16 8 Z" fill="none" stroke="white" stroke-width="2.5" stroke-linejoin="round" />
                </g>
                {/* Batterie */}
                <g transform="translate(110,100)">
                  <rect x="-14" y="-14" width="28" height="28" rx="3" fill="none" stroke="white" stroke-width="2.5" />
                  <rect x="-6" y="-19" width="12" height="5" rx="1" fill="white" />
                  <rect x="-8" y="-6" width="16" height="12" fill={p.k === 'Nuit' ? 'rgb(255 255 255 / 0.25)' : '#e8b54a'} />
                </g>
                {/* Réseau (pylône) */}
                <g transform="translate(190,100)" opacity={p.k === 'Coupure' ? '0.3' : '1'}>
                  <path d="M0 -16 L0 14 M-10 -6 L10 -6 M-13 4 L13 4" stroke="white" stroke-width="2.5" stroke-linecap="round" />
                  {p.k === 'Coupure' && <path d="M-10 -18 L10 18" stroke="#e8b54a" stroke-width="2.5" stroke-linecap="round" />}
                </g>
                {/* Flèches de flux — libellées dans aria-label ci-dessus, décoratives ici */}
                <g stroke="#7fa8ff" stroke-width="2" fill="none" opacity="0.85" aria-hidden="true">
                  {p.k !== 'Nuit' && <path d="M104 44 L40 88" marker-end="url(#arrow)" />}
                  {(p.k === 'Jour' || p.k === 'Coupure') && <path d="M116 44 L110 84" marker-end="url(#arrow)" />}
                  {(p.k === 'Soir' || p.k === 'Coupure' || p.k === 'Nuit') && <path d="M96 100 L46 100" marker-end="url(#arrow)" />}
                  {p.k === 'Nuit' && <path d="M174 100 L124 100" marker-end="url(#arrow)" />}
                </g>
                <defs>
                  <marker id="arrow" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
                    <path d="M0 0 L6 3 L0 6 Z" fill="#7fa8ff" />
                  </marker>
                </defs>
                <text x="30" y="130" text-anchor="middle" class="fill-lune-soft" font-size="9">Maison</text>
                <text x="110" y="132" text-anchor="middle" class="fill-lune-soft" font-size="9">Batterie</text>
                <text x="190" y="130" text-anchor="middle" class="fill-lune-soft" font-size="9">Réseau</text>
              </svg>
              <ul class="mt-2 space-y-1 text-xs leading-relaxed text-lune-soft">
                {p.flows.map((f) => (<li>{f}</li>))}
              </ul>
              <p class="mt-3 flex-1 text-sm leading-relaxed text-lune-soft">{p.note}</p>
            </figure>
          ))}
        </div>
      </div>
    </section>

    <!-- Le matériel de stockage posé — Dyness LFP -->
    <div class="v2-seam" aria-hidden="true"></div>
    <section class="section bg-blanc-azur px-4 text-encre">
      <div class="mx-auto max-w-3xl">
        <p class="tech-label v2-kicker rule-brass text-azur-600">Le matériel posé</p>
        <h2 class="display v2-section-title mt-5">Batteries Dyness lithium-fer-phosphate</h2>
        <p class="v2-lead mt-4 text-encre-soft">
          Quand le stockage se justifie, nous posons des batteries Dyness LFP. La chimie
          lithium-fer-phosphate ne s'emballe pas thermiquement comme d'autres lithiums et accepte
          d'être vidée à 90 % à chaque cycle sans se ruiner. Le BMS dialogue en CAN avec l'onduleur
          hybride Deye, qui pilote charge et décharge au plus juste. Matériel sourcé via les
          distributeurs officiels au Maroc, garantie activable sur place.
        </p>
        <div class="mt-10 border-t-2 border-azur-900 bg-blanc" data-stagger>
          {specs.map((s, i) => (
            <div class="v2-rise flex items-baseline justify-between gap-4 border-b border-azur-900/15 px-5 py-4" style={`--v2-i:${i}`}>
              <span class="text-sm font-semibold">{s.item}</span>
              <span class="whitespace-normal text-right text-sm text-azur-600">{s.detail}</span>
            </div>
          ))}
        </div>
        <p class="mx-auto mt-6 max-w-xl border-l-4 border-azur-600 pl-4 text-sm leading-relaxed text-encre-soft">
          Les modules s'empilent par tranches de 5 kWh. Concrètement, on mesure le creux que votre
          consommation laisse après le coucher du soleil et on empile juste assez de modules pour le
          combler : c'est ce chiffre qui fixe la capacité, jamais un palier de catalogue.
          <a href="/équipement" class="border-b border-azur-600 pb-0.5 font-semibold text-azur-600 transition-colors hover:text-azur-700">Voir tout le matériel posé →</a>
        </p>

        <!-- Installations réelles avec stockage -->
        <h3 class="display mt-14 text-xl">Du stockage déjà sur nos toits</h3>
        <p class="mt-3 text-sm leading-relaxed text-encre-soft">
          Du 5 kWh au 15 kWh : plusieurs foyers tournent déjà avec des batteries Dyness, chaque
          capacité calée sur le profil de la maison qui l'a reçue.
        </p>
        <div class="mt-6 grid gap-4 sm:grid-cols-3" data-stagger>
          {installs.map((inst, i) => (
            <div class="v2-rise border-l-2 border-azur-600 bg-blanc px-4 py-4" style={`--v2-i:${i}`}>
              <p class="fig whitespace-nowrap text-2xl text-azur-600" data-tally>{inst.kwh}</p>
              <p class="tech-label mt-2 text-encre-faint">Dyness · {inst.where} · réf. {inst.ref}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- W278 — Coupures & prépayé (Nour) : le segment résilience, indépendant du régime tarifaire -->
    <section class="section px-4 text-white">
      <div class="mx-auto max-w-3xl">
        <p class="tech-label v2-kicker rule-brass text-lune">Un besoin, pas un tarif</p>
        <h2 class="display v2-section-title mt-5 text-white">Coupures, compteur prépayé : la batterie répond à l'angoisse, pas au calcul</h2>
        <p class="v2-lead mt-5 text-lune-soft">
          Toute la page qui précède parle d'arbitrage économique — consommer le jour, stocker le
          soir. Il existe un autre foyer, différent : celui qui redoute la coupure elle-même, pas
          son coût. Deux situations reviennent souvent.
        </p>
        <div class="mt-10 grid gap-6 md:grid-cols-2" data-stagger>
          <div class="v2-rise cine-card flex flex-col p-7" style="--v2-i:0">
            <p class="tech-label text-lune">Compteur à prépaiement</p>
            <h3 class="display mt-2 text-xl text-white">Coupure automatique à solde épuisé</h3>
            <p class="mt-3 flex-1 text-sm leading-relaxed text-lune-soft">
              Un compteur électrique prépayé (souvent appelé « Nour » au Maroc) fonctionne comme un
              forfait téléphonique : on recharge un crédit à l'avance, et l'alimentation s'arrête
              automatiquement dès que ce solde tombe à zéro — jusqu'à la prochaine recharge. C'est le
              principe générique de tout compteur à prépaiement, quel que soit le distributeur ;
              nous ne citons ici aucun barème ni délai propre à un opérateur précis, faute de
              source publique à référencer.
            </p>
          </div>
          <div class="v2-rise cine-card flex flex-col p-7" style="--v2-i:1">
            <p class="tech-label text-lune">L'angoisse de la coupure</p>
            <h3 class="display mt-2 text-xl text-white">Le vrai déclencheur, ce n'est pas le kWh</h3>
            <p class="mt-3 flex-1 text-sm leading-relaxed text-lune-soft">
              Une recharge oubliée un week-end, un délestage du réseau, une panne locale : le
              résultat est le même — le courant s'arrête sans préavis. Pour ce foyer-là, la question
              n'est pas « combien vais-je économiser sur ma facture ? » mais « est-ce que je peux
              compter sur l'électricité quand j'en ai besoin ? ».
            </p>
          </div>
        </div>
        <p class="mt-8 max-w-2xl border-l-4 border-azur-200/50 pl-4 text-sm leading-relaxed text-lune-soft">
          Dans les deux cas, la réponse honnête est la même : une batterie couplée à un onduleur
          hybride en mode secours (EPS) donne une autonomie propre à vous, indépendante du réseau et
          de son mode de facturation. Ce n'est pas un raisonnement d'économie — c'est un raisonnement
          de continuité. Il tient debout que votre installation soit raccordée en régime classique
          ou en compteur prépayé, et il ne dépend d'aucun futur tarif de rachat 82-21.
          <a href="/guides/electricite-pendant-les-coupures" class="border-b-2 border-azur-200/60 pb-0.5 font-bold text-azur-200 transition-colors hover:text-white">Comment fonctionne le secours EPS →</a>
        </p>
      </div>
    </section>

    <!-- FAQ visuelle — schema={false} : /faq reste l'unique FAQPage (W130) -->
    <Faq
      schema={false}
      heading="Questions fréquentes sur le stockage solaire"
      items={faqItems}
    />

    <!-- Guides et ressources internes — liens battery (W130) -->
    <section class="section px-4">
      <div class="mx-auto max-w-6xl">
        {/* Eyebrow + sous-libellés + liens rétrogradés en lune/azur (discipline #2) */}
        <p class="tech-label v2-kicker rule-brass text-lune">Pour aller plus loin</p>
