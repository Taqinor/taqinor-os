---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { NAP } from '../lib/nap';
import { DEFAULT_LOCALE, isLocale, LOCALE_BCP47, LOCALE_DIR, type Locale } from '../i18n/config';
import { localizePath, stripLocale } from '../i18n/utils';
import { localesForPath } from '../i18n/pages';

interface Props {
  title: string;
  description: string;
  /** Nom de fichier OG sans extension, ex. "accueil" → /og/accueil.png */
  ogSlug?: string;
  /** Précharge l'affiche du héros vidéo (élément LCP de l'accueil) */
  preloadHeroPoster?: boolean;
  /** Pages de travail privées : jamais indexées */
  noindex?: boolean;
  /** Locales réellement disponibles pour CETTE page (hreflang + sélecteur).
   *  Absent / [fr] → page FR seule : rendu strictement inchangé. */
  locales?: Locale[];
}
const { title, description, ogSlug = 'accueil', preloadHeroPoster = false, noindex = false, locales } = Astro.props;

// Locale courante (FR par défaut à la racine). Le rendu FR reste identique :
// lang="fr" et aucun attribut dir (ltr implicite) ; hreflang seulement si la
// page déclare plusieurs locales.
const lang: Locale = Astro.currentLocale && isLocale(Astro.currentLocale) ? Astro.currentLocale : DEFAULT_LOCALE;
const dir = LOCALE_DIR[lang];
const rootPath = stripLocale(Astro.url.pathname);
// Source unique : si la page ne passe pas `locales` explicitement, on les
// déduit du registre de disponibilité (src/i18n/pages.ts). Une page FR-seule
// renvoie ['fr'] → aucune alternate, aucun changement de rendu.
const pageLocales = locales && locales.length ? locales : localesForPath(rootPath);
const alternates =
  pageLocales.length > 1
    ? pageLocales.map((l) => ({ l, href: new URL(localizePath(rootPath, l), Astro.site).href }))
    : [];

const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL(`/og/${ogSlug}.png`, Astro.site);

// LocalBusiness JSON-LD — mode zone de service (pas d'adresse postale),
// liste de services alignée exactement sur le Google Business Profile.
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: NAP.name,
  url: NAP.url,
  telephone: NAP.phone,
  email: NAP.email,
  image: ogImage.href,
  areaServed: NAP.serviceArea.map((name) =>
    name === 'Maroc' ? { '@type': 'Country', name } : { '@type': 'City', name },
  ),
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Services Taqinor',
    itemListElement: NAP.services.map((s) => ({
      '@type': 'Offer',
      itemOffered: { '@type': 'Service', name: s },
    })),
  },
};
---

<!doctype html>
<html lang={LOCALE_BCP47[lang]} dir={dir === 'rtl' ? 'rtl' : undefined}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#070b1d" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonical.href} />
    {alternates.map((a) => <link rel="alternate" hreflang={a.l} href={a.href} />)}
    {alternates.length > 0 && (
      <link rel="alternate" hreflang="x-default" href={new URL(localizePath(rootPath, DEFAULT_LOCALE), Astro.site).href} />
    )}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <!-- Pas de preload des fontes : font-display swap suffit, et la bande
         passante critique (4G lent) doit aller à l'image LCP du héros. -->
    {preloadHeroPoster && (
      <link
        rel="preload"
        as="image"
        type="image/avif"
        imagesrcset="/videos/hero-poster-540.avif 540w, /videos/hero-poster-720.avif 720w, /videos/hero-poster-1080.avif 1080w, /videos/hero-poster-1600.avif 1600w"
        imagesizes="100vw"
      />
    )}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={NAP.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical.href} />
    <meta property="og:image" content={ogImage.href} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={lang === 'en' ? 'en_US' : lang === 'ar' ? 'ar_MA' : 'fr_MA'} />
    <meta name="twitter:card" content="summary_large_image" />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <script is:inline>
      // Capture first-touch fbclid + UTM sur toute page d'atterrissage —
      // persistés en sessionStorage, repris par le formulaire (gate CAPI).
      (function () {
        try {
          var p = new URLSearchParams(location.search);
          var keys = ['fbclid', 'utm_source', 'utm_medium', 'utm_campaign', 'utm_content', 'utm_term'];
          for (var i = 0; i < keys.length; i++) {
            var v = p.get(keys[i]);
            if (v && !sessionStorage.getItem('tq_' + keys[i])) {
              sessionStorage.setItem('tq_' + keys[i], v);
            }
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body class="bg-nuit font-sans text-lune antialiased">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
