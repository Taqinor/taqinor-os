# Copy to .dev.vars for local development (wrangler/astro dev reads it).
# All variables are optional — the site degrades gracefully without them.

# Upstream simulation API. No simulator endpoint exists in taqinor-os today;
# when the simulator service ships, set its URL here / as a Worker secret.
# Until then the Worker computes a local kWc + ROI band from the bill range.
SIMULATOR_API_URL=

# Lead forwarding webhook (Odoo transition CRM). Leads are POSTed as JSON.
# Absent => leads are logged in the Worker output only (flagged as pending wire-up).
LEAD_WEBHOOK_URL=

# Meta Conversions API relay (lives in taqinor-os, may not be deployed yet).
# Fire-and-forget; absence is tolerated silently.
CAPI_URL=

# WhatsApp destination (Meryem), digits only with country code.
WHATSAPP_NUMBER=212600000000
